    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個！　",
        "unit_id": 105811,
        "voice": "vo_adv_2013016_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好久不見了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "優衣！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我有一個同伴她一直都沒辦法醒過來，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳能不能用恢復魔法",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想想辦法呢……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？　",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是貪吃佩可……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n當時，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的非常感謝妳",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "從魔物的手中救了我！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為了報恩，",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然還有點搞不清楚狀況……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但這一次，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "輪到我來幫助妳們了唷。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個。",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以妳說醒不過來的人，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是哪位呢？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "或許用我的魔法",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "能有什麼辦法可以解決也說不定，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n總之請先讓我來檢查看看吧！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好喔，",
        "unit_id": 105811,
        "voice": "vo_adv_2013016_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是那孩子唷！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是小可蘿非常努力地背在身上的",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那孩子！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……。",
        "unit_id": 106015,
        "voice": "vo_adv_2013016_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哇，",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "又是這個人！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼好像",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "每次看到她都是暈過去的呢……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 105811,
        "voice": "vo_adv_2013016_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對優衣來說的確是有那種印象才是呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這孩子的名字叫做小凱留，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是我非常重要的朋友。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得已經是非常、",
        "unit_id": 105811,
        "voice": "vo_adv_2013016_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常久以前的事情了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但從那時候……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從第一次見面以來，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她就幾乎每天都和我們聚在同一個餐桌前，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "與我們和睦的相處著。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是這樣呀……",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼絕對要",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "幫助她才行呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想想喔。",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n簡單看過以後的感覺，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "她單純只是睡得很熟而已……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我應該可以想點辦法。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我知道可以用來",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "抵銷魔物使人睡著的咒文的方法，",
        "unit_id": 100211
