        "voice": "vo_adv_2013016_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "掉以輕心可是不行的呀。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哇呀！？",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哇哇？",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n妳沒有事吧，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳被用相當驚人的氣勢打飛過來了唷！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咕嗚，",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那隻魔物，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是什麼蠻力啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是因為我體重太輕，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以純靠力量",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "跟牠比拼有點不利嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "蛤，唔啊！？",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n草野優衣！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯、",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒事吧？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n有沒有受傷？　",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "需要我幫妳治療嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……。",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……那個呀。",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我不知道妳是誰，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也不清楚妳知道我的什麼事情。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n也不清楚",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為什麼妳會用那麼可怕的眼神看著我。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起，",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_034"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我真的不清楚……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可是，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想要知道。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不管那是好意還是惡意，",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也不管那是怎樣的感情，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n但我覺得不能當作是沒看到一樣。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "人要把自己的感情告訴別人，",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_036"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的很困難呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也一樣，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一直都把說不出口的感情藏在心裡。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但也因為這樣……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "像那樣這麼強烈的情感，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我才更應該要接受。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我不禁這麼覺得。",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_037"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n所以，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "當所有事情都結束了以後請告訴我吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我不會逃的。",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_038"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我會接受妳的那份感情……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "拜託妳了，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在不要對我",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "做出攻擊。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我最珍惜的那些人，",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_039"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為了守護和平",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "和每一個人，正努力的戰鬥著。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也想和她們一起面對這場戰鬥，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可以的話希望妳也來幫忙。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "畢竟明明能用言語溝通，",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_040"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "卻只能夠互相傷害的話",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就太悲哀了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n或許是我太天真了也說不定，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過是我的任性也說不定，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可以的話",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想跟妳聊看看呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……就是因為是這樣的妳，",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為妳的關係。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不……",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒事，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳的心情我瞭解了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n確實現在",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不是對妳說些狠話，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n或是傷害妳的時候。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "讓我們一塊戰鬥吧，",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "優衣。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我叫諾維姆。",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n在妳們所忘記的那個故事中……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然我一直都是妳們的敵人，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但最後還是成為了朋友。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這麼說來，",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_045"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算只有這個瞬間也說不定，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就算只有這僅僅的一次，我也想成為妳的朋友。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n想和妳一起面對",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這場戰鬥。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……嗯。",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_046"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我也",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有和妳一樣的心情。",
        "unit_id": 100211
    },
    {
        "type": "still",
        "still": "201301601"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "諾維姆，",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_047"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n妳從剛剛就一直倒在地上，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是不是有哪裡不舒服呢？　",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "站得起來嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我把手",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "借給妳吧，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嘿咻……♪",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n謝謝妳。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "她的手",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_049"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好溫暖……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真是像優衣的個性啊，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒有任何隱藏地親切對待他人。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真是一個溫柔的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好孩子呀。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎、",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_050"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼了嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n妳臉色不太好呢，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是有哪裡痛嗎？　",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "需要治療嗎？",
        "unit_id": 100211
    },
    {
        "type": "still",
        "still": "201301602"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我、",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_051"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我沒事啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以不要對我太溫柔了啦，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣我感覺很複雜！",
        "unit_id": 106113
    },
    {
        "type": "background",
        "background": "500783"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……啊，",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_052"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "危險！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "唔呀啊！？",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_053"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不好了呢，",
        "unit_id": 106113,
        "voice": "vo_adv_2013016_054"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "牠們漸漸開始逼近了……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n魔物的包圍圈逐漸變小了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "給我打起精神來！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果輕敵了的話可是會死的啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這附近的魔物開始胡鬧亂來了，",
