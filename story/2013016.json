        "voice": "vo_adv_2013016_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喵哇！？",
        "unit_id": 106015,
        "voice": "vo_adv_2013016_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳別給人家用全力抱上來呀，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要斷了要斷了",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "骨頭要斷了啦！",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別這麼搞啦貪吃佩可，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳的蠻力不是開玩笑的耶！",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿，",
        "unit_id": 105811,
        "voice": "vo_adv_2013016_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起嘛小凱留……",
        "unit_id": 105811
    },
