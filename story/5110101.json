    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n國內各地正在進行建國慶典的準備。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很棒耶──",
        "unit_id": 105812,
        "voice": "vo_adv_5110101_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "慶典準備得很順利。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明慶典還沒開始，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的心臟已經開始砰砰跳了☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "更重要的是",
        "unit_id": 105812,
        "voice": "vo_adv_5110101_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "城鎮的大家都帶著笑容進行準備作業，真令人感到開心。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "希望下一年，",
        "unit_id": 105812,
        "voice": "vo_adv_5110101_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後再下一年",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都可以像這樣慶祝，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想把這份和平與未來聯繫起來☆",
        "unit_id": 105812
    },
    {
