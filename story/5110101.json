        "voice": "vo_adv_5110101_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們就帶著這股幹勁",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再努力一下吧。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "做好充分的準備，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呈現最棒的演唱會囉！",
        "unit_id": 102913
