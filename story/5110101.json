    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼哼～♪",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼回事，祈梨，",
        "unit_id": 106511,
        "voice": "vo_adv_5110101_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳看起來很開心嘛。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這麼喜歡佈置工作的話，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也把我的部分弄一弄吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊？",
        "unit_id": 106611,
        "voice": "vo_adv_5110101_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "別開玩笑了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我才不是因為工作才這麼開心呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我是對建國慶典期待到不能自已！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "畢竟",
        "unit_id": 106611,
        "voice": "vo_adv_5110101_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可以看到慈樂之音的特別演唱會喔？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要想到這個，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就算是麻煩的工作都能開心面對了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "慈樂之音……",
        "unit_id": 106511,
        "voice": "vo_adv_5110101_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "偶像嗎。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "反正",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只要祈梨肯好好工作，原因不重要。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "和平的慶典似乎無法期待有熱血沸騰架能打啊。",
        "unit_id": 106511,
        "voice": "vo_adv_5110101_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我就加減享受慶典吧。",
        "unit_id": 106511
    },
