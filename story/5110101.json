        "type": "dialogue",
        "name": "千歌",
        "words": "不是為了戰鬥，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而是為了粉絲唱歌，",
        "unit_id": 104211
