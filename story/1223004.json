    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "之後的事你還記得嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1223004_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你的朋友來找你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後在屋頂上發現了你。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟也不能說出「我遇見了吸血鬼女孩」這種話，",
        "unit_id": 190011,
        "voice": "vo_adv_1223004_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以你就說了奇怪的藉口……",
        "unit_id": 190011
