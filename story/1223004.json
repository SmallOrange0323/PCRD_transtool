    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "說不定",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "是更～嚇人的生物唷！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "……跟你說。",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_057"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "還有沒能告訴你的事情。",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n你如果知道了，",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "說不定會害怕。",
