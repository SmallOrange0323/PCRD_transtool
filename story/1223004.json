        "name": "班比",
        "words": "很奇怪！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "把教室的燈打開時，",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_043"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n你會擔心班比「會不會消失」……",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "去烹飪教室時，",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_044"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比一舔鹽巴，",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "你也很慌張吧？",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "從屋頂往下看時，",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_045"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n你竟然還突然大叫，嚇了班比一跳！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "一般來說，不會有人擔心幽靈的吧──？",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_046"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "不過……",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_047"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "能和班比一起，",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "普通地聊天、",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "驚訝、",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "歡笑的人……",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "你是第一個！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "所以今天能一起散步，",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_048"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比真的很開心！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "而且而且！",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_049"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n與班比說過這麼多話的，",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "過去就只有貝斯而已……",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "啊，",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_050"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n貝斯",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "是班比的朋友唷！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "對了！",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_051"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n下次再把貝斯介紹給你……",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "………………",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_052"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "沒事！",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_053"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "沒什麼～！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "呀～",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_054"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "真開心！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比很滿足！",
