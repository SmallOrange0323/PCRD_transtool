    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "因為班比滿足了，",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就放你走吧！",
        "unit_id": 122331
