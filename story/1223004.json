    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "但是班比",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "很中意這樣的你♪",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "所以…………",
