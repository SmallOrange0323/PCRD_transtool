    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n不過，",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這不能跟任何人說哦？",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "聽好囉？",
