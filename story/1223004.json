        "type": "dialogue",
        "name": "班比",
        "words": "……咦？",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_055"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n可是……",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "可是",
        "unit_id": 122331,
        "voice": "vo_adv_1223004_056"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "說不定真的是幽靈唷？",
