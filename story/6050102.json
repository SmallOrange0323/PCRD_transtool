    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我雖然",
        "unit_id": 113911,
        "voice": "vo_adv_6050102_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是第一次和茉莉好好聊天，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n該怎麼說，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是個很可愛的孩子呢！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 113911,
        "voice": "vo_adv_6050102_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "她本人是以帥氣為目標啊。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n嗯～",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過將來感覺會變帥氣吧。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n到時候還想製作新的衣服呢，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "感覺會很有趣。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的呢，",
        "unit_id": 113911,
        "voice": "vo_adv_6050102_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "她真是個可愛的人族啊。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯～",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那孩子真的有要隱瞞嗎？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我反而覺得漏洞很多呢……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等等，",
        "unit_id": 113911,
        "voice": "vo_adv_6050102_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個不能說出來吧。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n畢竟她本人是打算隱瞞這件事的啊。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我得尊重她對我的信任把這件事放在心底就好。",
        "unit_id": 113911
    }
]