[
    {
        "type": "dialogue",
        "name": "華音",
        "words": "喔～",
        "unit_id": 134911,
        "voice": "vo_adv_5160301_000"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呵呵呵！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n在新的一年",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "開幕的同時，",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "蘭德索爾的",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "新的",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "公主！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n公主華音大人",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "誕、",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "生、",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "了！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "喔～！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "來吧，",
        "unit_id": 134911,
        "voice": "vo_adv_5160301_001"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "地位卑微的各位♪",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n盡情向我低頭、",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "崇拜我、",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "讚頌我、",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "跪在我面前吧！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "就跪在",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "本小姐的",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "腳邊吧～～～！！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "真是的，",
        "unit_id": 133611,
        "voice": "vo_adv_5160301_002"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "說什麼公主啊！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "那傢伙",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "是連腦子都很新年快樂嗎？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然俗話說",
        "unit_id": 133211,
        "voice": "vo_adv_5160301_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼跟煙都喜歡高處，",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來如此，",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會這樣也是難免的吧。",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該說！",
        "unit_id": 133511,
        "voice": "vo_adv_5160301_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哪有公主穿得像她一樣不檢點！",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n給我知恥啊！",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "好氣──！",
        "unit_id": 134911,
        "voice": "vo_adv_5160301_005"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "一個個都是很失禮的小姑娘們！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "既然如此，我就讓妳們全部變成蛇的飼料，",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "把她們一口吞掉吧！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n可不要違背本小姐的期待喔！？",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然那個自認是公主的蝙蝠女",
        "unit_id": 133511,
        "voice": "vo_adv_5160301_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "似乎決定要作壁上觀了……",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是棘手的是那隻大蛇啊。",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是啊，",
        "unit_id": 133511,
        "voice": "vo_adv_5160301_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不只是很巨大而已，",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "牠的力量也是規格外的呢。",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "明明是那樣，",
        "unit_id": 133611,
        "voice": "vo_adv_5160301_008"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "卻被那種人隨意使喚，真可憐啊……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "在打倒華音之後，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我就順便解放牠吧！",
        "unit_id": 133611
    }
]