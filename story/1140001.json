    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是……？",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_036"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這是萬聖節樂園中所有店都能使用的折價券。",
        "unit_id": 1411,
        "voice": "vo_adv_1140001_037"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n不過只限情侶使用，",
