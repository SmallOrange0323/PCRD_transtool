[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在離萬聖節樂園有點距離的郊外，\n{player}正陪著怜一起進行特訓。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝！",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝啊啊啊！",
        "unit_id": 114011
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "目前就先這樣，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n暫時休息一下吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉，",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還讓你來陪我。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你看我服裝和裝備都換新的了對吧？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以我想盡快先讓身體適應。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "畢竟",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我總不能在忙著準備慶典而人來人往的大街上，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n揮舞自己還用不習慣的劍啊。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你的身手也變好了呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我有好幾次都認真使出攻擊，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "結果都被你漂亮地化解掉了。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……你說",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難怪會覺得手特別酸麻？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為我認為現在的你不會有問題。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這就表示你身手有顯著提升呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話說回來，",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這風真舒服……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說起來，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "萬聖節慶典好像馬上就要開始了？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "慶典嗎？",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還很難說……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也不是沒有興趣……",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但我每天都要鍛鍊，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且一個人去逛也有點怪。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好了，",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "先不說這些，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "等再休息一下後，就繼續開始特訓──",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呀、",
        "unit_id": 1,
        "voice": "vo_adv_1140001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呀啊啊！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n誰來、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "救救我啊～～～～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "悲鳴……！？",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是從那裡傳來的嗎！？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "{player}，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們趕緊過去！！",
        "unit_id": 114011
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "唔哇啊啊啊！！",
        "unit_id": 1411,
        "voice": "vo_adv_1140001_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "載貨馬車被襲擊了……！",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "先擊退魔物吧！",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝啊啊啊啊！",
        "unit_id": 114011
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "解決掉了啊……",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_014"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你、",
        "unit_id": 1411,
        "voice": "vo_adv_1140001_015"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你們是……？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒有錯。",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "先別管那個，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你有沒有受傷？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊、",
        "unit_id": 1411,
        "voice": "vo_adv_1140001_017"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "嗯，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我沒什麼事，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不用擔心。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "只是，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "因為被魔物襲擊的關係，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我的貨物……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……雖然擊退剛才的魔物了，",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但很難說不會有其他的魔物被剛才的騷動吸引過來。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若是可以，",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "最好盡早離開這個地方。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好了，快點走吧，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也來幫忙。",
        "unit_id": 114011
    },
    {
        "type": "background",
        "background": "501130"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "真不好意思，",
        "unit_id": 1411,
        "voice": "vo_adv_1140001_020"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "還讓你們特地送我。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我真的很希望能給小姑娘你們謝禮……",
        "unit_id": 1411,
        "voice": "vo_adv_1140001_021"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但很抱歉，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "情況就如你們所見。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這些貨物……",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是攤販的建材嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看這個樣子……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是啊……",
        "unit_id": 1411,
        "voice": "vo_adv_1140001_023"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我確認過東西的情況了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n但因為被魔物襲擊的關係，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "要在萬聖節出攤的",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n攤位骨架和台面都嚴重毀損了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就算準備好商品了，",
        "unit_id": 1411,
        "voice": "vo_adv_1140001_024"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但若沒有最重要的攤位的話……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不過在這個萬聖節即將到來的時期，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就算去訂製新的攤位",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n也大概趕不上吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這樣子可做不了生意啊……",
        "unit_id": 1411,
        "voice": "vo_adv_1140001_025"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但有保住性命才最重要。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n只好安慰自己",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "能平安無事就算好了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "的確，",
        "unit_id": 1411,
        "voice": "vo_adv_1140001_026"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "只要能調齊攤販用的木材，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n剩下的就總會有辦法解決……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但我總不能讓你幫我到這個程度……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……以防萬一我先問清楚，",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你應該不會說，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要自己一個人去收集建材吧？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "果然……",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我就知道你會那麼說。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但要去的不是一個人，",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而是二個人。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也和你同行，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "畢竟人手還是越多越好。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是這麼回事……",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若是你不介意，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n能夠讓我們幫忙嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可以嗎……？",
        "unit_id": 1411,
        "voice": "vo_adv_1140001_031"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "真不好意思，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "如果你們能提供協助就幫大忙了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我記得",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "街道外的地方應該有座森林，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就在那裡籌措木材吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說不定還會有魔物出現，",
        "unit_id": 114011,
        "voice": "vo_adv_1140001_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
