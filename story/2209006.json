[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──同一時刻，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "阿剌克涅的巢穴‧內部。"
    },
    {
        "type": "background",
        "background": "502150"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_000"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……呼。",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_001"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……沒想到",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_002"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "居然會連過去的世界管理者都出現。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n雖然事前就有情報表示",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "遠野帆稀會進行干涉，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n因此有預料到可能性並非為零……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "不過……",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_003"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "因為這樣。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n讓阿剌克涅女士",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "與尤絲蒂亞娜公主一行人",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n正面交鋒了。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……接下來……",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_004"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……嘿。",
        "unit_id": 130013,
        "voice": "vo_adv_2209006_005"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_006"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那的確",
        "unit_id": 130013,
        "voice": "vo_adv_2209006_007"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是個有趣的珍奇表演呢。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n看到那個巨大蜘蛛",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "被反將一軍的樣子。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……真是匹夫之勇。",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_008"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n要是被本人聽到，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "可是會死的。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……哼。",
        "unit_id": 130013,
        "voice": "vo_adv_2209006_009"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n照那樣子來看，",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "似乎不會由這邊不會主動出擊呢。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n這表示",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那隻大蜘蛛並沒有那麼憤怒嗎？",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "因為膽小……",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_010"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "不。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "那是因為",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "她很謹慎。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……哦。",
        "unit_id": 130013,
        "voice": "vo_adv_2209006_011"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不過，",
        "unit_id": 130013,
        "voice": "vo_adv_2209006_012"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是無所謂啦……",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那麼妳是打算",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n也叫我們守住這裡嗎？",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我們",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "可不是警衛，",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "而是盜賊啊。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "即使多少有不滿，",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_013"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "妳們也得忍耐。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "只要妳們派上用場……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我就會依照契約，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n將我所擁有的",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "皇家裝備送給妳們。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是那把",
        "unit_id": 130013,
        "voice": "vo_adv_2209006_014"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "奇怪的劍吧……",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n光是稍微碰到，",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "似乎也能夠大幅提升",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我的力量……",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n但是妳不用嗎？",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……皇家裝備",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_015"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "與使用者之間有契合度的問題。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "那個和我的戰鬥方式，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "完全不適合。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……誰知道呢。",
        "unit_id": 130013,
        "voice": "vo_adv_2209006_016"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不如說，",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我反倒覺得會很適合呢──",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……唔……",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_017"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……現在沒有時間閒聊了。",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_018"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n為了迎擊尤絲蒂亞娜公主的進攻，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n妳們也去做準備吧。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "…",
        "unit_id": 130013,
        "voice": "vo_adv_2209006_019"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "…是──是。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊、",
        "unit_id": 130113,
        "voice": "vo_adv_2209006_020"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊姊……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……妳們怎麼了，",
        "unit_id": 130013,
        "voice": "vo_adv_2209006_021"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "露出那種表情。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "如果有什麼話想說，",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就說出來聽聽。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……那個、",
        "unit_id": 130113,
        "voice": "vo_adv_2209006_022"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "那個……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……這很不像",
        "unit_id": 130113,
        "voice": "vo_adv_2209006_023"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊姊的作風……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n就算再怎麼想要皇家裝備，",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n為此而服從於他人這種事情……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "…",
        "unit_id": 130213,
        "voice": "vo_adv_2209006_024"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "…沒錯沒錯，",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n妳明明總是說，",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "如果想要就去搶過來啊～",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……哼。",
        "unit_id": 130013,
        "voice": "vo_adv_2209006_025"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n沒什麼，",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這不過是心血來潮罷了。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……該不會……",
        "unit_id": 130113,
        "voice": "vo_adv_2209006_026"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n在一開始來到這裡時。",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n那個大蜘蛛魔物",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "對妳說了些什麼……",
        "unit_id": 130113
    },
    {
        "type": "background",
        "background": "501790"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──幾天前──"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……聽好了。",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_027"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n妳盡可能都別說話就行了。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n因為女士是很在乎禮儀的人。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "…",
        "unit_id": 130012,
        "voice": "vo_adv_2209006_028"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "…喔。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n所以，我才沒有帶布武機來啊？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n順便也讓若菜別跟來了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……話說回來……",
        "unit_id": 130012,
        "voice": "vo_adv_2209006_029"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──這裡",
        "unit_id": 130012,
        "voice": "vo_adv_2209006_030"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是那個叫阿剌克涅的魔物的巢穴最深處。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "跟預想中的一樣，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這裡到處都是金銀財寶啊。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不只是皇家裝備。",
        "unit_id": 130012,
        "voice": "vo_adv_2209006_031"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n這座寶山，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我也一起收下來吧──",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "──妳來做什麼，",
        "unit_id": 136013,
        "voice": "vo_adv_2209006_032"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "傳令。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……我向您介紹，",
        "unit_id": 193711,
        "voice": "vo_adv_2209006_033"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "女士。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n她",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "是【蠻賊三姊妹】的長女，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "倭。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n我招攬了她作為獨立作戰的戰力",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "加入我們。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……請多指教。",
        "unit_id": 130012,
        "voice": "vo_adv_2209006_034"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "……哼。",
        "unit_id": 136013,
        "voice": "vo_adv_2209006_035"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n看起來",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "還算有實力嘛。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n畢竟光靠小蜘蛛和以絲線變成傀儡的魔物，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "可無法放心啊。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "但是──",
        "unit_id": 136013,
