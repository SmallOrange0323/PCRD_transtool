        "type": "dialogue",
        "name": "凱留",
        "words": "也不曉得會從哪裡冒出來。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可別大意了啊……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "幻變少女",
        "words": "「是。」\n「嗯。」",
        "unit_id": 1,
        "voice": "vo_adv_2209006_071"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 105811,
        "voice": "vo_adv_2209006_072"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……阿剌克涅的那個絲線。",
        "unit_id": 105811,
        "voice": "vo_adv_2209006_073"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果能夠切得斷，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想戰鬥就會輕鬆很多了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "同樣是公主的萊拉耶爾小姐",
        "unit_id": 105811,
        "voice": "vo_adv_2209006_074"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n和涅妃‧涅羅小姐，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明都能燒斷或斬斷絲線。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果我",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再更強的話──",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊……",
        "unit_id": 105811,
        "voice": "vo_adv_2209006_075"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒事！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們趕快走吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，",
        "unit_id": 105911,
        "voice": "vo_adv_2209006_076"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是──",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "蜘蛛型魔物",
        "words": "──嘎吱嘎吱嘎吱！",
        "unit_id": 50011
    },
    {
        "type": "dialogue",
        "name": "幻變少女",
        "words": "！！",
        "unit_id": 1,
        "voice": "vo_adv_2209006_077"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來了啊，",
        "unit_id": 106011,
        "voice": "vo_adv_2209006_078"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這些雜碎蜘蛛！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我要把你們全部捏碎！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "芙蕾雅和【蠻賊三姊妹】",
        "unit_id": 105911,
        "voice": "vo_adv_2209006_079"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不曉得會在哪裡等著我們。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果遇到她們，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想必無法避免發生激戰……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小雪菲在等我們。",
        "unit_id": 105811,
        "voice": "vo_adv_2209006_080"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們就打倒所有敵人，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "朝著阿剌克涅的巢穴前進吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "「是！」\n「好！」\n「嗯。」",
        "unit_id": 1,
        "voice": "vo_adv_2209006_081"
    }
]