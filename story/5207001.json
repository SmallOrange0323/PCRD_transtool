    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "要是能買些點心就更好了♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "這樣啊──",
        "unit_id": 129612,
        "voice": "vo_adv_5207001_001"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "那麼，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "先失陪了。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
