    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──！",
        "unit_id": 129612,
        "voice": "vo_adv_5207001_008"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "要找東西的話，",
        "unit_id": 4911,
        "voice": "vo_adv_5207001_009"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "我可以協助您喔！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "還是說，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "您不曉得",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "該選哪個好呢？",
        "unit_id": 4911
    },
