    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "難道我",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "嚇到她了嗎……？",
        "unit_id": 4911
    },
