        "voice": "vo_adv_5207001_010"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "不必了。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "啊、",
        "unit_id": 4911,
        "voice": "vo_adv_5207001_011"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "請等一下！",
