    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "如果是山上的話，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "也要考慮到氣候寒冷──",
