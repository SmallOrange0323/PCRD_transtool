        "words": "順道前往某座村子。"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "前方的路途還很漫長，",
        "unit_id": 126012,
        "voice": "vo_adv_5207001_000"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我們一起去買點食物吧。",
