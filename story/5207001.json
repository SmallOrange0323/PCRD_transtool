        "voice": "vo_adv_5207001_002"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n安、",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "安涅默涅小姐？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──只不過是採購，",
