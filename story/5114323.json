        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我尾巴的毛都蓬起來了喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那傢伙到底",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "會強到什麼程度啊喵！？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就算我們都一起上，",
        "unit_id": 125211,
        "voice": "vo_adv_5114323_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "用一般的方法可能也行不通……",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵喵……",
        "unit_id": 125111,
        "voice": "vo_adv_5114323_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "牠到底要使壞到什麼地步啊喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要是因為這種事情而膽怯，就太不像我們了喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們不會輸的喵～！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒錯！",
        "unit_id": 125211,
        "voice": "vo_adv_5114323_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還有迄今為止培養出來的待客技巧！",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n來個絕地大反攻吧！",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯，",
        "unit_id": 125111,
        "voice": "vo_adv_5114323_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼就像平時一樣喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒錯，",
