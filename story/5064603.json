[
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "文化系的學術展覽也有很多東西呢，",
        "unit_id": 116311,
        "voice": "vo_adv_5064603_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n小論文跟自由研究之類的。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喔，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是啊，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有很多東西……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 116311,
        "voice": "vo_adv_5064603_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "講得很不甘願呢。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n沒有提出平常的研究成果，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮博士是不是很後悔呢？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是想再多也沒用的事。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就連要去想那種事，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也都會不可思議地覺得",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「算了，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "反正也沒差」呢。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我在想的",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不是關於那個，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "而是藝術展覽的事。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哦哦，",
        "unit_id": 116311,
        "voice": "vo_adv_5064603_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是那個醜陋的被詛咒之奇異黏土像，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所謂的優妮藝品。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那群收藏家還說是",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「無名的藝術」，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但我現在",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "想以創作者的身分取「青春」這個名字。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "過去所渴求的風景。",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如今浸身於此的感慨。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那不足掛齒的每一天，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "正是於我歷史上燦爛耀眼的兩個字。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哇～",
        "unit_id": 116311,
        "voice": "vo_adv_5064603_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "聽起來很棒呢。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n琪愛兒覺得這是很棒的作品。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……突、",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "突然是在說什麼啦。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你之前不是一直說醜陋、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "被詛咒的奇異黏土像之類的，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n怎麼突然",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "改口了。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒啦，",
        "unit_id": 116311,
        "voice": "vo_adv_5064603_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就之前以為那是等人吐槽的搞笑藝術嘛。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "如果認真做然後做成那樣，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "看法就會稍微不同喔。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "如果那個就是優妮學姐用盡全力認真做出來的結果，",
        "unit_id": 116311,
        "voice": "vo_adv_5064603_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n嗯，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好的，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也沒有辦法嘛。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這種勉強自己去讚美的社交性，琪愛兒還是有的。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊，",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來是這樣啊……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呃，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那個，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓妳勉強自己了感覺有點抱歉？",
        "unit_id": 116411
    }
]