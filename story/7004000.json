        "voice": "vo_adv_7004000_003"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "　\n我們來接你囉～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "　",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
