        "name": "胡桃",
        "words": "……咦？",
        "unit_id": 102111,
        "voice": "vo_adv_7004000_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　現在要出發去探險所以沒辦法？",
        "unit_id": 102111
