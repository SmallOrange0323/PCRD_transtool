[
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "「捕捉＜找＞」到妳們了，",
        "unit_id": 18211,
        "voice": "vo_adv_5140302_000"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "「脫兔＜小兔子＞」們！",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "事到如今還想靠「飛空艇＜空路＞」逃亡，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "未免太「冒險＜調皮＞」了吧？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "糟了，",
        "unit_id": 111011,
        "voice": "vo_adv_5140302_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們的計畫被察覺到了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可惡，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在兩種意義上都在趕時間的說。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "不過啊……",
        "unit_id": 18211,
        "voice": "vo_adv_5140302_002"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n看著這麼「破天荒＜亂來＞」的妳們，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "不知為何就想到",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "以前還活躍在",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "第一線的「自己＜小官＞」啊……",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊！",
        "unit_id": 110911,
        "voice": "vo_adv_5140302_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在這個忙碌的時刻，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個人打算開始自吹自擂了！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "沒錯，",
        "unit_id": 18211,
        "voice": "vo_adv_5140302_004"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "那是小官，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n還在猶如狂風暴雨的「人生＜每一天＞」中",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n頭破血流地趴伏在地時的故事……",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "糟糕，",
        "unit_id": 110811,
        "voice": "vo_adv_5140302_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "她打算要把我們拉入感動回憶之中。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這是無情敵人的「悲慘過去」篇章啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "現在是會出現過世的恩師之類的角色，大概用掉２～３話篇幅的那種啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦",
        "unit_id": 110911,
        "voice": "vo_adv_5140302_006"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不用了不用了！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然也是有點在意，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但可不是現在啊！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "優妮學姐，",
        "unit_id": 110811,
        "voice": "vo_adv_5140302_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n平常的那個，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "快開始吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "要縮短喔。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那就縮短時間，",
        "unit_id": 111011,
        "voice": "vo_adv_5140302_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "優妮們，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "使出全力上吧！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒錯，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好朋友社，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "使出全力上吧！",
        "unit_id": 111011
    }
]