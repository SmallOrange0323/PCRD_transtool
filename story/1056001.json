        "type": "dialogue",
        "name": "流夏",
        "words": "不僅不付這孩子報酬，",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_035"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n還以失敗為藉口，要求他賠償，",
        "unit_id": 105611
    },
