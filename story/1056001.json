[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，流夏沒有什麼事要處理。\n於是她離開蘭德索爾，到街上隨意漫步。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼啊……",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "難得天氣這麼好，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來睡個覺好了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嘿咻。",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯……？",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "誰啊？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我睡得正香的說。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你找我有什麼事？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈哈！",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來是這樣啊！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我沒事。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我可沒你想像的那麼嬌弱。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這附近的魔物對我來說，",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "連暖身都算不上呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還是要感謝你對我的關心。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "謝謝你喔。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我叫流夏。",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "請多指教。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我在鬧區的魚店裡打工。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n今天閒著沒事，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就到這裡悠哉的午睡。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你手上的那個，",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是釣魚的釣具吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你喜歡",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "釣魚嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "工作內容是釣魚？還真有意思。",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "接下工作的人已經夠怪了，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "委託人更怪。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "搞不清楚還拿在手上？",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你還真怪啊，小哥。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這麼說來，",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你要去哪裡釣什麼魚啊？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}告訴流夏，\n自己的工作是要去沿海的城鎮釣某種魚。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈哈！",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那可是淡水魚喔。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n很遺憾，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就算到了海邊，你也一條都釣不到。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的，",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你怎麼會接了這種到海邊釣淡水魚的工作呢？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我的工作經常需要接觸魚，當然很熟……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來是這樣。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哎呀呀。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喂，小哥。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你能不能，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓我協助你做這個工作？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "再這樣下去，我會因為太在意你到底有沒有釣到魚，",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_014"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n而沒辦法好好睡午覺。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "什麼？",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_015"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別擔心。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要魚的話，我有辦法。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們馬上出發吧。",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好了。",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這裡有一間賣淡水魚的店。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "大叔，你在嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "嘿，歡迎光臨！",
        "unit_id": 1411,
        "voice": "vo_adv_1056001_017"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "原來是流夏。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "妳怎麼這種時間過來，是來批貨的嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是的。",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我今天是陪這孩子過來。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n小哥，是那個對吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就是客人叫你去釣的那種魚。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "啊～這個嗎？",
        "unit_id": 1411,
        "voice": "vo_adv_1056001_019"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "客人，您運氣真好呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n這種魚最近賣得特別好，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "今天這些賣完就沒了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種魚很容易跟海魚搞混。",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這樣工作差不多就結束了嘛。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼結完帳之後，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就可以早早回蘭德索爾──",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "委託人？",
        "words": "老闆──！",
        "unit_id": 311,
        "voice": "vo_adv_1056001_021"
    },
    {
        "type": "dialogue",
        "name": "委託人？",
        "words": "啊，你這傢伙！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "委託人？",
        "words": "你怎麼會在這裡！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你是誰啊？",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我沒見過你……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你說的是真的嗎？",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……那就怪了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喂，你這傢伙。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你既然已經委託別人去釣魚了，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n為何還要親自來買魚？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "委託人？",
        "words": "不是的，那個，這個是……！",
        "unit_id": 311,
        "voice": "vo_adv_1056001_024"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你這傢伙……",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真的是工作的委託人嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這麼說來，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我聽說最近有個新的詐騙手法……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "委託人？",
        "words": "詐騙！？",
        "unit_id": 311,
        "voice": "vo_adv_1056001_026"
    },
    {
        "type": "dialogue",
        "name": "委託人？",
        "words": "沒有這回事！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "委託人？",
        "words": "\n我只是來這裡買魚而已！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "抱歉，",
        "unit_id": 1411,
        "voice": "vo_adv_1056001_027"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "今天的貨賣給這位客人之後沒了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "委託人？",
        "words": "你說什麼！？",
        "unit_id": 311,
        "voice": "vo_adv_1056001_028"
    },
    {
        "type": "dialogue",
        "name": "委託人？",
        "words": "這樣我很困擾啊！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "果然沒錯……",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_029"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你，",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是這孩子真正的委託人吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你假扮成委託人，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "打算要騙這孩子吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這孩子買的魚，",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "應該是真正的委託人要的魚吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "委託人？",
        "words": "什！",
        "unit_id": 311,
        "voice": "vo_adv_1056001_032"
    },
    {
        "type": "dialogue",
        "name": "委託人？",
        "words": "妳有什麼證據……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想必你的同伴",
        "unit_id": 105611,
        "voice": "vo_adv_1056001_033"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "現在正在",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沿海城鎮那裡擺攤，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n等這孩子抵達城鎮，卻釣不到魚的時候出面。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "把海邊釣到的很相像的魚高價賣給這孩子，",
