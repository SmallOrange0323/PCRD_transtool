[
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "唔唔……！",
        "unit_id": 125813,
        "voice": "vo_adv_9070155_000"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n這隻魔物怎麼會這麼凶暴……！",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "如果不靠闇影之力，",
        "unit_id": 126013,
        "voice": "vo_adv_9070155_001"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n實在是無法與其對抗……！",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "莉莉。",
        "unit_id": 126113,
        "voice": "vo_adv_9070155_002"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n後面……！",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "呀啊……！",
        "unit_id": 125813,
        "voice": "vo_adv_9070155_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "──光之精靈啊！",
        "unit_id": 100211,
        "voice": "vo_adv_9070155_004"
    },
    {
        "type": "dialogue",
        "name": "日和、怜",
        "words": "呀啊啊啊！！\n喝啊啊啊啊！！",
        "unit_id": 1,
        "voice": "vo_adv_9070155_005"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是千鈞一髮呢……",
        "unit_id": 100211,
        "voice": "vo_adv_9070155_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "大家，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都沒事吧？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是……",
        "unit_id": 125813,
        "voice": "vo_adv_9070155_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是的。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n真是非常抱歉，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "【破曉之星】的各位。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n像這樣陷入危機中勞煩各位拯救，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我們實在是無地自容……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "別在意，",
        "unit_id": 100111,
        "voice": "vo_adv_9070155_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有困難的時候",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就要互相幫助幫助！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳們在這種地方做什麼？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我們，",
        "unit_id": 126013,
        "voice": "vo_adv_9070155_009"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是作為冒險者",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "前來調查吉歐‧格黑納的。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……還有，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "同時也在訓練不靠闇影之力來戰鬥。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "武者修行──",
        "unit_id": 126113,
        "voice": "vo_adv_9070155_010"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "的意思。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來是這樣！",
        "unit_id": 100111,
        "voice": "vo_adv_9070155_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "接下了討伐魔物的委託過來的……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "目標對象，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "似乎不是這隻魔物耶？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，",
        "unit_id": 100311,
        "voice": "vo_adv_9070155_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "牠的特徵跟接下委託時聽到的不太一樣……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n雖然「總之非常巨大」、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "「像龍一樣的鱗片」",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是有一致。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "卻沒有「巨大的背鰭」。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是這樣嗎？",
        "unit_id": 100211,
        "voice": "vo_adv_9070155_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "被委託討伐的魔物會在哪裡……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "是那裡的，",
        "unit_id": 126113,
        "voice": "vo_adv_9070155_014"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "那個嗎？",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "巨大怪獸",
        "words": "嘎喔喔喔喔喔────！！",
        "unit_id": 50511
    },
    {
        "type": "dialogue",
        "name": "日和、優衣、怜",
        "words": "就是那個──────！？",
        "unit_id": 1,
        "voice": "vo_adv_9070155_015"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那就是討伐目標……",
        "unit_id": 126013,
        "voice": "vo_adv_9070155_016"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "等",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "等，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "會不會太大了點！？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "快要跟蘭德索爾的城堡一樣大了吧……！？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺突然就要挑戰頭目了呢！",
        "unit_id": 100111,
        "voice": "vo_adv_9070155_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好像有點熱血起來了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，",
        "unit_id": 100312,
        "voice": "vo_adv_9070155_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們的力量在背面世界是否也能行得通……",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n正好能拿牠當對象試一試。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "咦咦？",
        "unit_id": 125813,
        "voice": "vo_adv_9070155_019"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n各位，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "難道打算就這樣正面迎擊嗎！？",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這簡直就是",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "螳臂當車、",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "暴虎馮河啊……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若想要進一步調查，",
        "unit_id": 100312,
        "voice": "vo_adv_9070155_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那隻魔物也會成為阻礙吧？",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在這裡為了彼此的目的，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是妳們也能協助我們就幫大忙了。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒錯沒錯～！",
        "unit_id": 100111,
        "voice": "vo_adv_9070155_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "現在還有我們能一起戰鬥！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不管是委託還是武者修行，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都一起努力",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "克服萬難吧──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我的魔法一定會好好保護大家的。",
        "unit_id": 100211,
        "voice": "vo_adv_9070155_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n所以……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "【幻變少女】少女的各位",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也能幫幫我們嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "好、",
        "unit_id": 1,
        "voice": "vo_adv_9070155_023"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "好的！\n嗯。",
        "unit_id": 1
    }
]