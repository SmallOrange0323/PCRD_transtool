[
    {
        "type": "background",
        "background": "501501"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗨。",
        "unit_id": 121211,
        "voice": "vo_adv_5085401_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n少年，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "狀況如何呀？",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯？",
        "unit_id": 121211,
        "voice": "vo_adv_5085401_001"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我這身模樣？",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想說偶爾也該來換一下造型嘛。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n開玩笑的，哈哈。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "願這份力量在將來，",
        "unit_id": 121211,
        "voice": "vo_adv_5085401_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能於正確的時刻，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "以正確的心態被使用。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因此，我想說也來幫一點忙。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以，少年。",
        "unit_id": 121211,
        "voice": "vo_adv_5085401_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你也無須客氣，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "盡量依賴我吧。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "若你願意也讓我加入",
        "unit_id": 121211,
        "voice": "vo_adv_5085401_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「羈絆之力」，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我會很開心的。",
        "unit_id": 121211
    }
]