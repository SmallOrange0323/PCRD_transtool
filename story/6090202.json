[
    {
        "type": "background",
        "background": "500042"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個混帳賭場……！",
        "unit_id": 121611,
        "voice": "vo_adv_6090202_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不管是想對步未未動歪腦筋，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n還是找我們地盤的麻煩！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我都絕對",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不會原諒的！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我要完全、",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "徹底地！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "把它從這個蘭德索爾連根拔除……！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "謝謝你，",
        "unit_id": 121611,
        "voice": "vo_adv_6090202_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥……！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n跟夥伴在一起，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "像那種傢伙就能輕鬆獲勝！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "讓我們痛扁賭場王一頓，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "保護大家吧！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說、",
        "unit_id": 121611,
        "voice": "vo_adv_6090202_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說得也是……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我得注意別再失去理智，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n又自己一個人橫衝直撞才行……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怪盜任何時候都要保持冷靜酷帥，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對吧！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦！？",
        "unit_id": 121611,
        "voice": "vo_adv_6090202_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你在說什麼啊！？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……我逼自己太緊了？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "或、",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "或許的確就如你說的……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才要稍微玩一下，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n讓腦袋冷靜嗎……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就來玩排七吧！",
        "unit_id": 121611
    }
]