[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了賺取租下海邊小屋的錢，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n靜流和{player}開了一間可麗餅店。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在兩人開店的幾天後──"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "聽我說聽我說，{player}！",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們成功囉！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們賺到目標金額了唷♪",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "都是多虧了{player}拼命招攬客人……",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗚嗚～",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我好感動～！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐和弟弟",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n用兩人賺來的錢一起租房子，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這感覺就像……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸嘿嘿，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒什麼啦！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們動作快吧，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個廉價物件",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要是被別人租走就不好了！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不好意思～！",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_005"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1171003_006"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是之前的客人啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n你們考慮清楚了嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這張傳單上的房子，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "應該還沒被租走吧？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們想租下它……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "咦！？",
        "unit_id": 1411,
        "voice": "vo_adv_1171003_008"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳怎麼會有那張傳單……！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n它應該早就被廢棄掉了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "呃，",
        "unit_id": 1411,
        "voice": "vo_adv_1171003_009"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "關於那棟房子……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "應該還沒被租走吧？",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_010"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "唔，",
        "unit_id": 1411,
        "voice": "vo_adv_1171003_011"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是沒有被租走……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "唔～嗯。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "嗯……",
        "unit_id": 1411,
        "voice": "vo_adv_1171003_012"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那棟房子",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "有一些問題。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有問題？",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n該不會是",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有鬼魂出沒",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "之類的？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "雖然無法斷言那就是鬼魂……",
        "unit_id": 1411,
        "voice": "vo_adv_1171003_014"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不過，這麼說也不完全錯。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n聽說那房子明明無人居住",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "卻能感受到視線，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "還能聽見腳步聲等等。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "原來如此，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難怪租金這麼便宜……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但我不介意喔！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不如說，這正合我意！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "作為【拉比林斯】的據點，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒有比這更合適的環境了……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "更重要的是，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果是這種",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒人敢靠近的地方，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我就能和弟弟慢慢享受兩人時光了！　",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "咦，",
        "unit_id": 1411,
        "voice": "vo_adv_1171003_017"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳確定嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這樣啊……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我知道了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不過，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我方也不能不負責任地隨意簽下契約，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n還是",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "請你們先去看看屋況吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我知道了！",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n走吧，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "前往我們的海邊小屋……♪",
        "unit_id": 117111
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是這裡啊……！",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n離海很近，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也很有氣氛，感覺不錯呢！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然建築物有點老舊，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但有許多房間，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這樣就算未來家裡人口增加了，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也完全沒問題呢，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "想住在哪個房間？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你可以第一個選唷♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就選你旁邊的房間♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟晚上睡不著的話，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可以來找姐姐唷。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我會摸摸你的頭，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為你唱搖籃曲的……♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸嘿嘿，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那些家人之間還沒做過的事……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們一項一項來完成吧♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……？",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "剛才",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好像有視線看著我……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難道",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是房仲先生說過的……？　",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐的夢想才不會被那種東西阻礙呢！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "！",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n剛才的聲音……！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你害怕嗎？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難不成弟弟",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "怕鬼？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼來！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你可以抱著姐姐唷！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐會緊～緊抱住你，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "直到你",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不害怕為止♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是的～！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "劍要好好繫在腰間才行唷！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐幫你重新繫好。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n把兩手抬高……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不對，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那是別的聲音啦！？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "視線和腳步聲……",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這不是鬼魂呢！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "現出你的原形吧！",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_032"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "果然",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是魔物……！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "原來如此，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_034"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這間屋子裡發生的怪異現象，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n都是魔物造成的吧……！？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "竟然妄圖阻撓姐姐和弟弟的幸福生活，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_035"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐要狠～狠地懲罰你！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看招！",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_036"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯？",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_037"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "逃走了！？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們追上去！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿呀！",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_038"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "它的動作很靈活呢……！",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_039"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而且，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_040"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "都完全不反擊。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有點讓人",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "無從下手啊……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過！",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_041"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我絕不會放棄",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "與弟弟的這個家！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_042"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "終於把你逼到死角了！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你已經逃不掉了……！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n喝啊啊啊！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦……？",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_043"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n為什麼阻止我，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "……咕唔唔。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊……",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_044"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還有一隻……？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個魔物，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_045"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是在保護另一個",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "小魔物……？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "它們",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_046"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是家人嗎……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……仔細一想，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_047"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個魔物連房仲先生都不知道，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n也就是說它至今為止都在躲躲藏藏，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "頂多只是暗中觀察和製造一些小聲響罷了。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "它不是想襲擊人類……",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_048"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n而是想與孩子生活在安全的地方，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "才把來訪者都嚇跑而已吧。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為了守護",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_049"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "重要的家人……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "…………",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_050"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……唉。",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_051"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_052"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們回去吧。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……嗯。",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_053"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我放棄",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "住在這裡了。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_054"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐不忍心……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "拆散它們一家啊。",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_055"
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳真的確定嗎？",
        "unit_id": 1411,
        "voice": "vo_adv_1171003_056"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是的。",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_057"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n給你，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這是定金。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我知道了。",
        "unit_id": 1411,
        "voice": "vo_adv_1171003_058"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n那麼，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "契約就正式生效了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然我沒有要租來自己住……",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_059"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但要是讓其他人住進去就不好了。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在那個小魔物長大到",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_060"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "足以離開那裡之前，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我就負起責任，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "管理好那棟房子吧。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為我是姐姐嘛。",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_061"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n欸嘿嘿，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟重新迷上我了嗎？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_062"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對不起喔，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你明明這麼努力賺錢，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我卻把我們兩個賺到的",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所有錢都花光光了。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這件事我會補償你……",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_063"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你說不需要？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……！",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_064"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊、",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_065"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗚……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是的！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不能這樣",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "突然讓姐姐心動啦……！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_066"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐果然還是想給",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n帥氣的弟弟獎勵！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你可以向姐姐提出任何願望唷？",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_067"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n無論是什麼願望姐姐都會為你實現♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼？",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_068"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你沒什麼特別的願望？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這怎麼可能嘛！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "吶吶，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "現在的話，無論是什麼願望",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐都能實現唷？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什‧",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "麼‧",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "都‧",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "行‧",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唷？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_069"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就算是夏天，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "太過大膽的要求還是不行的唷？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……適可而止就行，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好嗎？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來吧來吧，",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_070"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼樣的願望都儘管來♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為什麼要逃跑？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "等等姐姐嘛～～～♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟～～～～～弟♪",
        "unit_id": 117111,
        "voice": "vo_adv_1171003_071"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "逃跑的{player}與追逐他的靜流。"
    },
    {
        "type": "dialogue",
