[
    {
        "type": "background",
        "background": "500590"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您好，",
        "unit_id": 190811,
        "voice": "vo_adv_0000500_000"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這裡是【公會管理協會】。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在蘭德索爾的每一天，",
        "unit_id": 190811,
        "voice": "vo_adv_0000500_001"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是不是都很快樂呢？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "感情變好的女孩子",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是否有增加了呢。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在女孩子之中，",
        "unit_id": 190811,
        "voice": "vo_adv_0000500_002"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n有沒有您特別在意的人呢？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "而，",
        "unit_id": 190811,
        "voice": "vo_adv_0000500_003"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "說到這個！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這一次，",
        "unit_id": 190811,
        "voice": "vo_adv_0000500_004"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在蘭德索爾……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "即將舉辦人氣投票！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "而名稱就是",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "第1屆",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "超異域公主連結人氣投票！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "因為這次人氣投票，",
        "unit_id": 190811,
        "voice": "vo_adv_0000500_005"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有許多女孩子報名參加了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您可以選擇想要支持的女孩子，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n為她投下神聖的一票。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這是傳達您心意的絕佳機會。",
        "unit_id": 190811,
        "voice": "vo_adv_0000500_006"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就等您這",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "熱血的一票了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "敬請踴躍參加囉！",
        "unit_id": 190811
    }
]