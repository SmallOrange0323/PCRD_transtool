    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "宵の口……"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "祭囃子が響くオーエド町の横丁に、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n浴衣姿の一団が集まっていた。"
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "それにしても、",
        "unit_id": 51812,
        "voice": "vo_adv_0001004_000"
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "すごい偶然だね！",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "ふふ、",
        "unit_id": 51912,
        "voice": "vo_adv_0001004_001"
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "それはこっちのセリフよ～",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "\n",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "なんだか浴衣の似合う、",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "見覚えのある子がいるな、",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "\nって思ってたんだけど、",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "まさかあなたたちだったなんて。",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "あ、",
        "unit_id": 51812,
        "voice": "vo_adv_0001004_002"
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "ありがとうございます……",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "\n",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "ミサト先生も、",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "すごく似合ってます！",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "ふふ、",
        "unit_id": 51912,
        "voice": "vo_adv_0001004_003"
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "ありがとうね。",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "\n",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "それで、",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "ユイちゃんはどうしてこのツアーに？",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "わたしは、",
        "unit_id": 51812,
        "voice": "vo_adv_0001004_004"
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "レイちゃんが",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "オーエド町で食べたお料理が",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "\nおいしかったって聞いて……",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "気になってたところに",
        "unit_id": 51812,
        "voice": "vo_adv_0001004_005"
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "\nこのツアーを見つけたんです。",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "そうなのね～、",
        "unit_id": 51912,
        "voice": "vo_adv_0001004_006"
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "私は",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "近くにお世話になった温泉宿があるから",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "\nたまには挨拶でもしに行こうって思って参加したの。",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "\n",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "あなたは？",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "うんうん、",
        "unit_id": 51712,
        "voice": "vo_adv_0001004_007"
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "大正解。",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\n",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "このオーエド夏祭りツアーに参加したあなたたち、",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\n本当にツイてるわよ。",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "あら、",
        "unit_id": 51912,
        "voice": "vo_adv_0001004_008"
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "ユカリさんまで♪",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "\n",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "でも、",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "夏祭りなんて参加するのは初めてだから",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "\n",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "どうすればいいのかわからないの。",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "だーいじょうぶ！",
        "unit_id": 51712,
        "voice": "vo_adv_0001004_009"
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\n",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "ここは『夏祭りマイスター』兼",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "『麦しゅわの聖騎士』の",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\nユカリお姉さんに",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "まっかせーなさいっ♪",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "あ、",
        "unit_id": 51812,
        "voice": "vo_adv_0001004_010"
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "そういえば……",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "このツアーって",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "【メルクリウス財団】が主催だし、",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "\nマイスターってことは……",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "もしかして、",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "お仕事ですか？",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "いいえ！　",
        "unit_id": 51712,
        "voice": "vo_adv_0001004_011"
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "完ッ",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "全にプライベートよ！",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\n",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "大人には……",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "なんだかおいしいものを食べなきゃ",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\nやってらんないって時があるのよ……",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "うんうん、",
        "unit_id": 51912,
        "voice": "vo_adv_0001004_012"
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "そうよねえ。",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "\nユカリさんは",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "いつもお仕事を頑張ってて",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "偉いわぁ。",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "う",
        "unit_id": 51712,
        "voice": "vo_adv_0001004_013"
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "うっ、",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "ミサトさんの母性が染みるぅ……",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\n",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "って、",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "今はそれどころじゃないわ。",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\n夏祭りの楽しみ方、",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "ばっちり教えてあげる♪",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "は、",
        "unit_id": 51812,
        "voice": "vo_adv_0001004_014"
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "はい！",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "\n",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "お願いします！",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "まずはこの屋台ね！　",
        "unit_id": 51712,
        "voice": "vo_adv_0001004_015"
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "こちらはうちのギルドが素材を卸してる",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\n【シルバーオクトパス商会】さんが出店しているから、",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\n",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "お値段がお手頃なうえにクオリティが高いのよ。",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "特にたこ焼と、",
        "unit_id": 51712,
        "voice": "vo_adv_0001004_016"
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "鉄板を使った料理が絶品なのよね。",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\n",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "ぜったい後悔させないから、",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "期待していいわよ～！",
        "unit_id": 51712
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "ごくり……",
        "unit_id": 51812,
        "voice": "vo_adv_0001004_017"
    },
    {
        "type": "dialogue",
        "name": "ユイ",
        "words": "とっても気になります！",
        "unit_id": 51812
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "ふふっ、",
        "unit_id": 51912,
        "voice": "vo_adv_0001004_018"
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "素敵ね～",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "\n",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "それじゃあ、",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ミサト",
        "words": "さっそく屋台に行ってみましょうか。",
        "unit_id": 51912
    },
    {
        "type": "dialogue",
        "name": "ユカリ・ユイ",
        "words": "はーい！",
        "unit_id": 1,
        "voice": "vo_adv_0001004_019"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "こうして、夏祭りマイスターことユカリによる"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nオーエド横丁夏祭り屋台攻略戦が始まるのであった。"
    }
