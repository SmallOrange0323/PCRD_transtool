[
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼……",
        "unit_id": 107811,
        "voice": "vo_adv_5004011_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之把可視範圍內的小嘍囉們都收拾完了，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n趕緊前進吧。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，妳辛苦了！",
        "unit_id": 107511,
        "voice": "vo_adv_5004011_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳還真是非常活躍呢～♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，妳沒問題吧？",
        "unit_id": 107511,
        "voice": "vo_adv_5004011_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳的臉色和白紙一樣慘白耶？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊？",
        "unit_id": 107811,
        "voice": "vo_adv_5004011_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n當然有問題啊，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然現在勉強還能撐下來……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "照這個情況下去，過不了多久魔力就會枯竭了。",
        "unit_id": 107811,
        "voice": "vo_adv_5004011_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要嘛死掉要嘛昏迷，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再怎麼說都無法成為戰力了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以我們要",
        "unit_id": 107811,
        "voice": "vo_adv_5004011_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "儘量無視掉這些不斷湧進來的魔物，\n必須把找到並援救可蘿仔這件事當成首要目標才是。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不過感覺這個海底遺跡，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "似乎也很容易迷路的樣子。",
        "unit_id": 107811
    }
]