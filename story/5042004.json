        "words": "呀……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "傷腦筋～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "…………",
        "unit_id": 4611,
        "voice": "vo_adv_5042004_086"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "……嘿，璃乃",
        "unit_id": 4611,
        "voice": "vo_adv_5042004_087"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "，謝謝妳來到",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "這個世界。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n能夠遇見像妳這樣的朋友，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我很開心。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲……？",
        "unit_id": 112911,
        "voice": "vo_adv_5042004_088"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳這是什麼",
        "unit_id": 4611,
        "voice": "vo_adv_5042004_089"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "大吃一驚的表情呀。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n我只是坦率地向妳道謝而已。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲，這是什麼意思……？",
        "unit_id": 112911,
        "voice": "vo_adv_5042004_090"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n為什麼要在這種情況下",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "說這種話呢？",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "現在開始，我要完全解放自己的救世主之力，。",
        "unit_id": 4611,
        "voice": "vo_adv_5042004_091"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n起碼能瞞過黑之王的耳目吧。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳們先暫時退下，",
        "unit_id": 4611,
        "voice": "vo_adv_5042004_092"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "重振旗鼓。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "聽懂了嗎？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "到底是什麼意思！？",
        "unit_id": 112911,
        "voice": "vo_adv_5042004_093"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n為什麼不是愛麗絲妳跟我們一起重振旗鼓呢！？",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這、",
        "unit_id": 106612,
        "voice": "vo_adv_5042004_094"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這是什麼！？",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "突然有光芒……！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲……！？",
        "unit_id": 112911,
        "voice": "vo_adv_5042004_095"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n喂，",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲！！",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "接下來，就交給妳了。",
        "unit_id": 4611,
        "voice": "vo_adv_5042004_096"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "要打倒那傢伙，",
        "unit_id": 4611,
        "voice": "vo_adv_5042004_097"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "救世主之力必須要更一步覺醒。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "要是能和妳一起尋找方法就好了……",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "……真的",
        "unit_id": 4611,
        "voice": "vo_adv_5042004_098"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "很對不起。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "不過，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳一定辦得到。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳一定可以得到",
        "unit_id": 4611,
        "voice": "vo_adv_5042004_099"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "真正的救世主之力……",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n我",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "相信著妳。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "拜託妳了，",
        "unit_id": 4611,
        "voice": "vo_adv_5042004_100"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "守護住這個世界──",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n璃乃──",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "黑之王的出現，讓書中世界充滿了黑暗力量所引發的瘴氣。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而愛麗絲所釋放的光芒，就宛如黑暗中的燈火籠罩著璃乃等人。"
    }
]