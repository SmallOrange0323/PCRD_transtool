        "voice": "vo_adv_5042004_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "根本沒完沒了呀～！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "交給我們吧！",
        "unit_id": 112911,
        "voice": "vo_adv_5042004_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n愛麗絲，",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們上！",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "隨時奉陪！",
        "unit_id": 4611,
        "voice": "vo_adv_5042004_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃、愛麗絲",
        "words": "去吧～～！！",
        "unit_id": 1,
        "voice": "vo_adv_5042004_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "成功了！",
        "unit_id": 112911,
        "voice": "vo_adv_5042004_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們先去跟祈梨她們會合吧！",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "嘻嘻嘻！",
        "unit_id": 811,
        "voice": "vo_adv_5042004_008"
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "黑之王萬歲！！",
        "unit_id": 811
    },
    {
        "type": "background",
        "background": "501020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這、",
        "unit_id": 106612,
        "voice": "vo_adv_5042004_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這些人突然在搞什麼鬼呀！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然如此，",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我只好使出嘉夜夜式無腦談判……",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n那就是，",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "用武力讓他們聽話！！",
        "unit_id": 106612
    },
    {
        "type": "background",
        "background": "501020"
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "唔咿咿咿咿！",
        "unit_id": 811,
        "voice": "vo_adv_5042004_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "大臣，妳也要動手呀！",
        "unit_id": 106612,
        "voice": "vo_adv_5042004_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有呀～？",
        "unit_id": 106711,
        "voice": "vo_adv_5042004_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n……拉格在做了♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉格",
        "words": "嘎喔！",
        "unit_id": 1,
        "voice": "vo_adv_5042004_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳偶爾也該自己動手吧！",
        "unit_id": 106612,
        "voice": "vo_adv_5042004_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔～……",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳對待龍的方式還真是一如往常的蠻橫！！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "祈梨！",
        "unit_id": 112911,
        "voice": "vo_adv_5042004_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "帆稀小姐！",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是我～",
        "unit_id": 106711,
        "voice": "vo_adv_5042004_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "歡迎你們～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "歡迎蒞臨",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "紅心皇后的城堡～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "現在是悠悠哉哉打招呼的時候嗎！？",
        "unit_id": 106612,
        "voice": "vo_adv_5042004_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你們幾個，快把情況解釋清楚！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個嘛，",
        "unit_id": 100113,
        "voice": "vo_adv_5042004_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那些被黑之王侵蝕的人們",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n唰唰地攻擊過來，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "然後我們就嗚哇──！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對吧！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "步未！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖、",
        "unit_id": 113011,
        "voice": "vo_adv_5042004_019"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然我也不清楚，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但差不多就是這樣……！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那種說明方式誰聽得懂啊！？",
        "unit_id": 106612,
        "voice": "vo_adv_5042004_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n妳是笨蛋嗎！？",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來如此～",
        "unit_id": 106711,
        "voice": "vo_adv_5042004_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n也就是說操縱著",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那些瘴氣的敵人名叫黑之王啊～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳怎麼可以透過那些模稜兩可的形容理解情況呀！？",
        "unit_id": 106612,
        "voice": "vo_adv_5042004_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總而言之，",
        "unit_id": 106711,
        "voice": "vo_adv_5042004_023"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "大家平安無事，那我就放心了～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們",
        "unit_id": 106711,
        "voice": "vo_adv_5042004_024"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為了尋找回到原來的世界的方法而踏上旅程，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n遭到形形色色的盜賊襲擊～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "實在是束手無策了，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我就「說服」他們",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來協助我們～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說服……",
        "unit_id": 106612,
        "voice": "vo_adv_5042004_025"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說服！？",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不是吧，",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "與其說是說服，",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不如說是更邪惡的方式吧！？",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而且這種話，",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "誰會相信啊……",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "居然能夠說服盜賊",
        "unit_id": 113011,
        "voice": "vo_adv_5042004_026"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "成為自己的同伴……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "帆稀小姐好厲害呀！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "同樣身為公會長，我好崇拜妳呀！",
        "unit_id": 100113,
        "voice": "vo_adv_5042004_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "帆稀小姐，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "下次妳可以再教教我其他事嗎！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵呵～",
        "unit_id": 106711,
        "voice": "vo_adv_5042004_028"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可以呀～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n之後讓我仔仔細細地教妳，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這、",
        "unit_id": 106612,
        "voice": "vo_adv_5042004_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這群人也太天真過頭了吧！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……",
        "unit_id": 106612,
        "voice": "vo_adv_5042004_030"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咳，",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯，大概就是這麼一回事。",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n所以我們就把這座無人城當作據點了。",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "作為紅心皇后和",
        "unit_id": 106711,
        "voice": "vo_adv_5042004_031"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "她的大臣喲♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼，",
        "unit_id": 112911,
        "voice": "vo_adv_5042004_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "紅心皇后和",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "黑之王聯手的傳聞……",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥～！？",
        "unit_id": 106612,
        "voice": "vo_adv_5042004_033"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那擺明了就是謠言啊。",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說到底，",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "黑之王是什麼啊？",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們",
        "unit_id": 106711,
        "voice": "vo_adv_5042004_034"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "探索的手段好像稍～微粗暴了一點，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n所以在他們眼裡，我們就像是在破壞這個國家吧～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "黑之王呀～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一定是他",
        "unit_id": 106711,
        "voice": "vo_adv_5042004_035"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "唆使底下的人",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "散播紅心皇后的負面謠言……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n打算把我們集結在一起後，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "再一網打盡吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然我有察覺到，有個邪惡的存在籠罩著這個世界……",
        "unit_id": 106711,
        "voice": "vo_adv_5042004_036"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但這倒是被將了一軍呢☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是這樣，皇后大人？",
        "unit_id": 106711,
        "voice": "vo_adv_5042004_037"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "現在爆發叛亂，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們被團團包圍住了～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n該怎麼辦才好呢～？",
        "unit_id": 106711
    },
