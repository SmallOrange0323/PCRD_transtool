        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "特地做好的服裝如果沒有秀出來的話，就太可惜了對吧？",
