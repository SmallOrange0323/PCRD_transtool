    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "比起這件事，妳們兩人有聽到嗎？",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n有聽到大家的聲音嗎？",
