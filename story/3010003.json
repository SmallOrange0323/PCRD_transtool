        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然一直說不上場不上場，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不過還是牢牢記住舞步了！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我才沒有那個意思……！",
