        "voice": "vo_adv_5017007_004"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那是……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過",
        "unit_id": 102811,
        "voice": "vo_adv_5017007_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "至少全員平安回來了。",
