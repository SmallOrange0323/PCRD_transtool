    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是在貝特魯吉烏斯的討伐報告結束，\n菜月昴也順利洗刷嫌疑的當晚――"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "恭喜你被釋放了，",
        "unit_id": 109811,
        "voice": "vo_adv_5017007_000"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "巴魯斯。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "自由世界的空氣清新嗎？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "對一個被不當逮捕的同伴",
