        "voice": "vo_adv_5017007_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n非常擔心大家喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "她其實很高興所有人都平安無事。",
        "unit_id": 102511
    },
