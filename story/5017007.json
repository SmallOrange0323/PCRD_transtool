        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦、",
        "unit_id": 102511,
        "voice": "vo_adv_5017007_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦～？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咲戀大小姐！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是一群樂天的傢伙，",
