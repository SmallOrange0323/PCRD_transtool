        "voice": "vo_adv_5017007_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總是一下就鬆懈了～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雷姆",
