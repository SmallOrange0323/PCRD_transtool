        "voice": "vo_adv_5017007_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也這麼覺得。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉，",
