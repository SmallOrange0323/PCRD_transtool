    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不過",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這麼快就洗刷嫌疑真的是太好了。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n一定是",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "因為咲戀小姐",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "幫你說話的關係。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉，",
