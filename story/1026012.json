        "name": "鈴",
        "words": "在那之後",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總覺得狀態非常好呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "身體暖呼呼的，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_067"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "腦袋也很清醒，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n身體感覺非常輕鬆。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以……",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "500151"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "趕快回伊麗莎白牧場。",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_068"
    },
    {
        "type": "background",
        "background": "500157"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "確實地漱個口、洗個手。",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_069"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這還用說嗎。",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_070"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n來吧，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你也跟著我進房間。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼咿～",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_071"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在自己的房間果然很放鬆～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_072"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你也隨便找個地方坐下吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我會準備很多橡子和飲料的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n通宵三天也沒問題。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_073"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "受你力量的影響，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我現在還精神充沛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n衣服穿起來也",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不可思議地特別舒服。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "果然穿習慣的衣服是最好的嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_074"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_075"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你怎麼僵在那裡？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好了好了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你也要一起玩遊戲喔。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在我計畫發動之日硬插一腳進來，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_076"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你得接受懲罰才行。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_077"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "已經實現，所以可以說了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是在【哞哞自衛隊】的訓練結束後",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "想出來的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我都這麼努力了，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_078"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以如果不偷懶個十倍，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就太不划算了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因此",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_079"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我就開始擬定十倍偷懶計畫。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "裝作認真做警備工作的樣子，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "趁機收集大量橡子。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "裝成",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_080"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在幫真陽的忙，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "去買想要的東西。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "最後用存下來的錢",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_081"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "買下最棒的睡衣。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這樣",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "之後就能一直無所事事下去了呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "計畫雖然在最後功虧一簣，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_082"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "感覺衣服穿起來變舒服了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以沒差啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_083"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說起來，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "衣服的樣式好像變了？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n怎麼回事？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這也是你的力量造成的？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_084"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不說這個了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "現在來玩遊戲吧！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我一開始是想一個人一直偷懶下去的，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_085"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但總覺得好像少了點什麼……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "原本以為是少了件最棒的睡衣，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_086"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但其實不是。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是少了{player}才對。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在發什麼呆啊。",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_087"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你也要玩啊！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為這是雙人遊戲啊。",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_088"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在通關之前都不會讓你睡的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "做好覺悟吧～♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鈴開心晃著脫了一半襪子，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}對她露出了溫柔的笑容。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然後────"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "度過了史上最棒的偷懶時光後不久，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n鈴被誤以為是【哞哞自衛隊】的超級王牌，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n大量湧入的委託讓她哇哇慘叫，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但那又是別的故事了。"
    }
]