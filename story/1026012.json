[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}受到委託，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正要前往伊麗莎白牧場找鈴時──"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，{player}。",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "今天天氣也很好呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "走在街上的人們",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "看起來也都很幸福，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n真是太好了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯嗯。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呵呵呵，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我的計畫也馬上就要達成了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n世界看起來實在太耀眼了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你也來參與我計畫的結尾吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不不，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你不用這麼緊張啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n只是陪我去買個衣服而已。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為是比較高價的衣服，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以我想認真挑選。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你該不會以為我覺醒了愛打扮的嗜好？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊哈哈，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哪有可能啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我在找的是",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "極品的家居服。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n也就是",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "睡衣呦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為了買到最棒的家居服，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我還特地存了錢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為絕對不想失敗，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以你也來陪我挑……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你想拜託我？",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好難得喔。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼事？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你就說說看吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "………………",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃……",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "整理一下事情的原委，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就是……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "前陣子",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "擊退魔物的事傳了出去，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因此有人向【哞哞自衛隊】指名要委託我",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你找我就是為了",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "傳達這件委託",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我知道了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這件委託",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就交給別人去做吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大家會做的比我好吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼會突然提到媽媽啊。",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "又沒有關聯。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "媽媽聽到我很活躍的傳聞，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n去【哞哞自衛隊】的公會小屋打了招呼？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "她說聽到我很活躍覺得很開心……",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這個…………",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那個…………",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～～",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是的～～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "聽到這種事不就不能拒絕了嗎！！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n知道了啦！！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我做就是了嘛，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我做！！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那就趕緊去找委託人吧！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "麻煩事就是要儘速解決！",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喔～～！",
        "unit_id": 4911,
        "voice": "vo_adv_1026012_019"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n真沒想到妳會這麼快",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就過來！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n該說是時機正好、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還是時機太差的關係呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你要委託我什麼？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為想趕快解決，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒仔細聽說明就趕來了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我不想處理麻煩事啊……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "希望是那種",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "能迅速解決的事情呢……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我想拜託鈴小姐",
        "unit_id": 4911,
        "voice": "vo_adv_1026012_023"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "把這一帶的魔物",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "都除掉。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……欸？",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我聽錯了吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你能再說一遍嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "所以說，",
        "unit_id": 4911,
        "voice": "vo_adv_1026012_025"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我想拜託妳",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "把這一帶的魔物都除掉。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就我一個人做？",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_026"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "其實那是非常善於躲藏、",
        "unit_id": 4911,
        "voice": "vo_adv_1026012_027"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "且動作敏捷的魔物，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "很少人有辦法除掉牠們。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我一直找不到能驅除那些魔物的人，",
        "unit_id": 4911,
        "voice": "vo_adv_1026012_028"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "正覺得一籌莫展時，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "剛好聽到了關於妳的傳聞。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "隸屬於【哞哞自衛隊】，",
        "unit_id": 4911,
        "voice": "vo_adv_1026012_029"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "因其才幹，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n被派駐於【伊麗莎白牧場】，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "擁有敏銳的聽覺，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n驅使著華麗的使槍技巧，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是日夜狩獵魔物的松鼠獸人……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不是，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你情緒為什麼那麼高昂。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說起來，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我根本不是那麼了不起的人物，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n最清楚這點的就是你吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚，",
        "unit_id": 102611,
        "voice": "vo_adv_1026012_031"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你用那麼直率的眼神看著我說，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我很困擾耶……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳能夠",
        "unit_id": 4911,
