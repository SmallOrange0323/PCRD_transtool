[
    {
        "type": "still",
        "still": "520306201"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "波波爺爺的",
        "unit_id": 9212,
        "voice": "vo_adv_5203068_000"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "「克蘿茜大解密」",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "要開始啦～！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n把老夫解析的",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "古代兵器",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "巨型軀體的詳細資訊，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n用大家都能懂的方式",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "慢～慢仔細地講解給大家聽喔。",
        "unit_id": 9212
    },
    {
        "type": "still",
        "still": "520306801"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這次要講解的是，",
        "unit_id": 9212,
        "voice": "vo_adv_5203068_001"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "「巨型手臂」。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n它有1100萬馬力的超強力量，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n是巨型克蘿茜的主要武器！",
        "unit_id": 9212
    },
    {
        "type": "still",
        "still": "520306802"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "特徵是在手肘部分的",
        "unit_id": 9212,
        "voice": "vo_adv_5203068_002"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "蓄力裝置。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n在這裡將機體的能量充電、壓縮，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n超級！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "必殺",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "「巨型加農砲」",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "就能夠發射了。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "發射時的反作用力太大，",
        "unit_id": 134511,
        "voice": "vo_adv_5203068_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我差點就摔了個四腳朝天。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "完全就是必殺技！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "的感覺呢。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "咦？",
        "unit_id": 134511,
        "voice": "vo_adv_5203068_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "但我有個疑問……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n要是讓那個",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "裝置？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "一直充好電，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n敵人出現的時候，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不就能夠馬上發射必殺技了嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "一開始就是這樣設計的，",
        "unit_id": 9212,
        "voice": "vo_adv_5203068_005"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "也沒辦法。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "而且……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "能量這種東西有著放著不管",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "就會擴散的特性。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n要把它聚集在同一個地方這件事本身",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "就需要消耗能量了。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也不能夠太頻繁的",
        "unit_id": 134612,
        "voice": "vo_adv_5203068_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n請萊拉耶爾小姐充電……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嗯，",
        "unit_id": 134511,
        "voice": "vo_adv_5203068_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是這樣啊……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我還以為是個好主意呢。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "不過，",
        "unit_id": 9212,
        "voice": "vo_adv_5203068_008"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "充電時間",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "倒是還有縮短的餘地。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n為了不麻煩萊拉耶爾殿下……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "不知道小子",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這個週末有沒有空……",
        "unit_id": 9212
    },
    {
        "type": "still",
        "still": "end"
    }
]