[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "解決了流氓佔領道路的問題後，過了幾天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n日和來到{player}面前。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊──！",
        "unit_id": 100111,
        "voice": "vo_adv_1801004_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "找到騎士先生了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這裡這裡──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我有事要問騎士先生所以在找你呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1801004_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有找到真是太好了──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我說，騎士先生！",
        "unit_id": 100111,
        "voice": "vo_adv_1801004_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n今天我有事想拜託你！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我呀，",
        "unit_id": 100111,
        "voice": "vo_adv_1801004_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "想更加好好掌握公主型態的力量！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "之前戰鬥的時候，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我覺得自己好像還能變得更強！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n所以，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想請騎士先生再和我去城外特訓……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼感覺，",
        "unit_id": 100111,
        "voice": "vo_adv_1801004_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生在發光……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n該不會，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "終於連騎士先生也要變成公主型態了！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……咦，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "連我都被捲進光裡了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼回事，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好睏……",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "510121"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊咧？",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是前輩。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呀呵──！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "能在這裡碰到前輩真巧呢！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……其實也有點不算是巧合啦♪",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我剛剛心想著，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真想碰到前輩呢～",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以就跑來公園看看。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n沒想到前輩真的在，我嚇了一跳，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "又好開心喔──！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "的確是呢，前輩！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "難得碰面，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "待會我們……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊咧……？",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說話的方式和以往一樣……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但為什麼呢？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺好像沒什麼精神……？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n前輩，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你怎麼了……？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……啊，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "等一下！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不要站在公園裡，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們找間店坐下來聊吧！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我想好好地",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "聽前輩說話嘛！",
        "unit_id": 100131
    },
    {
        "type": "still",
        "still": "180100401"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "──嗯～",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然這裡特別讓人放鬆呢──！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "或許是因為來過好多次了，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺就像是我的第二個家一樣──♪",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……那麼",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "前輩，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你怎麼了嗎？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然或許光靠我幫不上什麼忙，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但我還是想盡可能地",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "幫助前輩！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "考試的得分",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不太好……？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呼……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "幸好不是什麼嚴重的問題……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……啊，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "抱歉！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對前輩來說是很大的煩惱呢！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過看前輩這麼煩惱，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我還以為",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "會是更嚴重的事情呢。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可能家人生病了，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還是弄丟錢包了，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n或者，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想想……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "被處罰不能吃晚餐之類的！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學習的問題我也沒轍呢……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我和前輩不同年級，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n也不是什麼很會念書的人……",
        "unit_id": 100131
    },
    {
        "type": "still",
        "still": "180100402"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我可以",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "用別的方式來鼓勵前輩喔！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想想，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "念書的時候幫前輩帶宵夜",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "之類的，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n或是在用功念書的前輩旁邊，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "跳啦啦隊幫忙加油！！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "加油加油，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "努力用功，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "前",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "～",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "輩",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "～！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "之類的，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "需要我幫忙加油的話，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "隨時都可以連絡我喔！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n除了深夜之外我都能去前輩家玩……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不是，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是去前輩家幫忙！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "前輩，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "為什麼要這樣",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "盯著我看呢？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在前輩旁邊跳啦啦隊",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是不是太吵了──？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還是你擔心宵夜的口味？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "放心啦～！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "別看這樣，我可是對料理……",
        "unit_id": 100131
    },
    {
        "type": "background",
        "background": "510050"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "抱歉，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "完全被前輩看穿了，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以我嚇了一跳……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "其實我會想見前輩，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這件事也是其中一個原因。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒想到前輩馬上就發現了呢……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "前輩該不會，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "其實有超能力吧？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只因為這樣就能發現……",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "的確，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛才的我跟平常比起來像是在",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "虛張聲勢……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不過，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "前輩好厲害呢！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明明我的朋友們都沒有發現！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦耶！？",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我雖然很敬佩",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "前輩的這一點……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但能把「我總是看著妳」這句話說出口，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還是讓人聽了很害羞呢……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我的煩惱是……",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n──升學志願表。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我跟老師說，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「雖然還沒決定確切的志願，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但我想繼續參加啦啦隊」，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是老師聽了，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n要我再多考慮一點",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "具體的目標……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我呀，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只決定了要繼續升學，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但是沒有更確切的方向呢。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我只要能幫助有困難的人就好了，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然這麼想，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過這沒辦法寫成志願呢……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈哈哈……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "前輩呢？",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n你的志願決定了嗎？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的嗎！？",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_029"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "和我一樣呢！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "前輩！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_030"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "既然前輩也還沒決定，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就表示我也還可以再多猶豫一陣子嘛！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n雖然對前輩有點抱歉，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但總感覺放心不少呢♪",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……不過，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_031"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說得也是。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n前輩也在煩惱著未來志願啊……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也會加油的，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以希望前輩",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也能快點找到目標呢！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_032"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "會替前輩加油喔──！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "像是念書的時候幫前輩帶宵夜",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "之類的，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "或是在前輩旁邊，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n跳啦啦隊幫忙加油……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，這不就和剛才說的一樣了嗎，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿♪",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我今天原本是想幫前輩打氣的，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n沒想到換我從前輩身上獲得活力了呢。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這也是",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有困難的時候互相幫助幫助、",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "的一種呢！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大哥哥♪",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不過，志願呀……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果有一個，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_035"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n以後都能跟前輩一直在一起的志願就好了呢……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊咧，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我剛才，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說了什麼……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我剛才，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_037"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好像說了很容易讓人誤解的話耶！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那句話好像能解釋成，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「想成為前輩的新娘」",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "之類的感覺……！　",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不、",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_038"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過沒問題對吧……？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "前輩肯定不在意剛才的話……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "超級在意的──！！",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_039"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚嗚，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這、",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這種場合",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就要想辦法蒙混過去…………",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想想，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想想喔……！！　",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個～",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_040"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n從、",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "從事同一種工作之類的！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒、",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_041"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒錯沒錯！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我是說，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "想從事同一種工作的意思！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n絕對不是想嫁給前輩……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我只是稍微講錯了！",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_042"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呃，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這種時候電視上都會說……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛才失言了──！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我收回前言──！！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以快忘記剛才我說的話──！",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_043"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好嗎！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好不好…！！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很好……！",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_044"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也就是說，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n今後絕對不准再提起剛才的內容，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "知道了嗎──！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總、",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_045"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總算蒙混過去了……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚嗚，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今後一定要小心一點說話才行……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過………………",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_046"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我想和前輩一直在一起這件事，",
        "unit_id": 100131,
        "voice": "vo_adv_1801004_047"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是真心的喔。",
        "unit_id": 100131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好～",
        "unit_id": 190011,
        "voice": "vo_adv_1801004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯～",
        "unit_id": 190011,
        "voice": "vo_adv_1801004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
