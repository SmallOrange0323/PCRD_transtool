        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這個是，蝴蝶結……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_039"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這是我不久前，原本在店裡看到的很想要的蝴蝶結……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥是說，因為剛好看到……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_040"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n想要送給我當禮物，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以才買給我的嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "說多虧了我，哥哥才有辦法打工……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_041"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n也賺到了錢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以為了表示感謝，才送禮物給我嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "謝、",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_042"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "謝謝哥哥……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我真的、真的很高興……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥居然還記得呢。",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_043"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "還記得，我想要這個蝴蝶結的事情……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個時候買不到，",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_044"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我還想說是我跟這個蝴蝶結無緣，所以放棄了呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻、嘻嘻……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥，謝謝……♪",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_045"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就算哥哥恢復記憶後，",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_046"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n會把我們像這樣聊天的事，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
