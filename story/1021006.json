[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥……♪",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻、嘻嘻。",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "之前我烤的餅乾還有剩，請哥哥吃……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我現在正在，學習做菜……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "在【咲戀育幼院】這裡，",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n一直都是由鈴莓姐，來準備餐點的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為姐姐很冒失……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n常常會讓廚房爆炸，或是打破碗盤……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "味道的話也是，嗯，感、感覺很有個性……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以，我想要學會做料理……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n如果我學會做家事之類的話，也可以減輕鈴莓姐的負擔……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然，我還沒辦法做得很好……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是我現在也已經，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n會做簡單的料理還有幾種點心了唷……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥、哥哥可以幫忙試試味道嗎……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果能合哥哥的胃口就好了……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻、嘻嘻……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n太好了……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為餅乾有點烤焦，",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n形狀也不好看……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以跟店家賣的餅乾比起來，還有待加強呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，已經吃完了嗎……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "男生真的很會吃呢……♪",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "茶也請趁熱喝……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_012"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過餅乾已經沒有了，是不是再多烤一些呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但是，哥哥……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "在等我烤餅乾的時候，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n就會變得很閒吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，要不要一起來做餅乾呢……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "做點心，很好玩唷……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n啊，但是沒有材料了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我現在正在看家，沒有辦法出去買東西……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥要去幫我買嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不、",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不行……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不、不要離開我……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "陪我嘛，哥哥……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，我、我們來聊天吧……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，但是我，不太習慣聊天……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "要、要玩玩具什麼的嗎……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，怎麼辦……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥說不定覺得，跟我在一起很無聊……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不行……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_020"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果哥哥覺得無聊的話，可能就會回去了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不要……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我得想辦法，努力逗哥哥開心……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "怎、怎怎、怎麼辦呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，這麼說起來……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_022"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這裡有之前綾音做的大富翁遊戲……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "要、要不要，一起玩呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這、這是有如可以重、重新體驗人生般的大富翁……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n從小嬰兒的狀態開始，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n一路成長變成大人，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "還、還可以結婚什麼的……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就是這樣的大富翁遊戲……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n在育幼院，沒有什麼可以打發時間的物品……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以綾音，就自己做了可以玩的東西唷……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "她在大張的圖畫紙上，自己畫上格子之類的……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n骰子就用削過的鉛筆代替……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "很、很好玩唷……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "小孩子做的大富翁遊戲，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n已經是大人的哥哥會不會覺得很無聊呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "大富翁這種遊戲，說不定只有兩個人玩也不好玩……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，哥哥想玩嗎……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥對體驗人生，感到有興趣嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這麼說起來，哥哥好像是喪失了記憶吧……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_028"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然只是大富翁，但如果能用這個再次體驗人生的話……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n說不定會帶來刺激，而回想起什麼也說不定呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_029"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n如果哥哥恢復記憶的話，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "會不會就忘記我了呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不要……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_030"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我已經不想要再被遺忘，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n也不想要再有人從我身邊消失了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果，",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_031"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥就這樣一直無法恢復記憶就好了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不不不，我在想什麼呀……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_032"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥因為失憶，正困擾著呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我要幫助哥哥，把很多事情都回想起來才行……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就算之後哥哥忘記我……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_033"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "只要我再和哥哥成為好朋友就好了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥跟父母「消失」的我不一樣，",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_034"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n說不定哥哥還能找回重要的事物……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "既然這樣，我就必須支持哥哥……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_035"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n什、什麼事……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "為什麼哥哥的手要靠近我……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦……",
        "unit_id": 102111,
        "voice": "vo_adv_1021006_036"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n是想到了有帶要給我伴手禮……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "其實不用什麼伴手禮啦……",
