[
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當像黑泥一般的謎之物體形成了激流，\n在蘭德索爾的城內造成混亂的同時……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人則在『王宮』中，\n和因被洗腦而正在大鬧一番的凱留對峙著。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊啊！　",
        "unit_id": 106013,
        "voice": "vo_adv_2012008_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以我說不要接近我了不是嗎？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你們每一個人都很讓人不爽啊！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n去死去死去死去死，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趕快滾一邊去啦笨蛋！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我哪裡都不會去的！",
        "unit_id": 105811,
        "voice": "vo_adv_2012008_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就像小凱留妳說的一樣我就是個笨蛋，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是因為是笨蛋，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以才不能夠對夥伴見死不救！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我一定會救妳的唷，",
        "unit_id": 105811,
        "voice": "vo_adv_2012008_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "誰拜託妳了啊！",
        "unit_id": 106013,
        "voice": "vo_adv_2012008_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳這傢伙每次都是這樣呢，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管我怎麼樣的罵妳，",
        "unit_id": 106013,
        "voice": "vo_adv_2012008_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說了我討厭妳，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳還是會傻傻的笑著然後黏上來呀！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後笑著抱緊我，",
        "unit_id": 106013,
        "voice": "vo_adv_2012008_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還那麼溫柔的對待我呀！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一次又一次的對我說著，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最喜歡我了！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是每當妳那麼說時，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的肚子就像是要裂開來了一樣痛啊……！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那些什麼飯的味道我根本都吃不出來啦！",
        "unit_id": 106013,
        "voice": "vo_adv_2012008_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明是這樣，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們卻每天又每天……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "找我和妳們一塊吃飯！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n搞不懂妳們在想什麼，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對我來說那根本是活生生的地獄呀！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我已經不想去了，",
        "unit_id": 106013,
        "voice": "vo_adv_2012008_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這話我可是說好多次了吧，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說我不能陪妳們繼續下去！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們這些傢伙卻……！",
        "unit_id": 106013
    },
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……哇呀！？",
        "unit_id": 105811,
        "voice": "vo_adv_2012008_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冷靜一點呀，小凱留，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "別攻擊我們嘛！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "危險，",
        "unit_id": 105911,
        "voice": "vo_adv_2012008_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐！　",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請退下！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是，",
        "unit_id": 105811,
        "voice": "vo_adv_2012008_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和先前比較起來現在的小凱留感覺比較能夠講上話了喔！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道是洗腦稍微被解開了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以小凱留變回原本的她了嗎……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要照這樣子繼續和她講下去的話，",
        "unit_id": 105811,
        "voice": "vo_adv_2012008_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定能夠……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咳、",
        "unit_id": 106013,
        "voice": "vo_adv_2012008_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咳咳！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咳咳咳！？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……小凱留！？",
        "unit_id": 105811,
        "voice": "vo_adv_2012008_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好！　",
        "unit_id": 105911,
        "voice": "vo_adv_2012008_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "方才",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "分明是吐血了吧，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐她已經到極限了！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是因為消耗生命",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來使用魔法的緣故吧！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不能再繼續刺激她，",
        "unit_id": 105911,
        "voice": "vo_adv_2012008_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓凱留小姐如此失控下去了！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若再這麼繼續",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓凱留小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鬧下去真會喪命的呀！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "意、",
        "unit_id": 105811,
        "voice": "vo_adv_2012008_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "意思是已經沒有餘裕能夠花時間慢慢來說服她了對吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那該怎麼辦才好啊，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這不妙過了頭呀！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊真是的，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道就沒有什麼好辦法嗎……！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……咦？　",
        "unit_id": 105811,
        "voice": "vo_adv_2012008_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你怎麼閉著眼睛呆呆的站在那裡呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該不會在這種狀況下還睡著了吧……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦咦？",
        "unit_id": 105911,
        "voice": "vo_adv_2012008_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n怎麼可能，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又不是小嬰兒……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……呣？　",
        "unit_id": 105911,
        "voice": "vo_adv_2012008_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正巧，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下接收到了某種靈感！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是愛梅斯大人的諭示。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位大人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正試圖想要傳達些事情。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔呣，",
        "unit_id": 105911,
        "voice": "vo_adv_2012008_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔呣？　",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就愛梅斯大人所云，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓睡著的主人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接近到凱留小姐的身邊……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像是如此。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n說是如果這樣，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就可能有辦法解決所有事情了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到、",
        "unit_id": 105811,
        "voice": "vo_adv_2012008_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到底是怎麼一回事呀？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然搞不太清楚狀況……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但在這個進也不是退也不是的狀態下，",
        "unit_id": 105811,
        "voice": "vo_adv_2012008_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果有辦法能搞定，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不管是什麼都求之不得呀！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要讓{player}，",
        "unit_id": 105811,
        "voice": "vo_adv_2012008_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n接近到小凱留她的身邊就好了對吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "請問！　",
        "unit_id": 191011,
        "voice": "vo_adv_2012008_024"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "您是貪吃佩可小姐對吧，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "對有困擾的女性親切地伸出援手可乃",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "騎士之義務！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "若您不介意，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "就讓我來扛{player}吧！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼，",
        "unit_id": 104911,
        "voice": "vo_adv_2012008_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我和璃乃來掩護你們！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n那個叫凱留的孩子所放的攻擊魔法，我會想辦法擋下來，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n璃乃妳就趁機擾亂她，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "吸引那孩子的注意！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "遵命，",
        "unit_id": 101112,
        "voice": "vo_adv_2012008_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這就是所謂的適才適所對吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不是",
        "unit_id": 104911,
        "voice": "vo_adv_2012008_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "『適才適所』，這裡應該是……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哎呀，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "意外的講對了！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "耶嘿，",
        "unit_id": 101112,
        "voice": "vo_adv_2012008_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也是有所成長的唷！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有沒有驚喜呀，姐姐！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這就是什麼女孩子只要三天沒見面就認不出來是哪位的那個嘛……☆",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦？",
        "unit_id": 104911,
        "voice": "vo_adv_2012008_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在說什麼東西？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "『士別三日，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "即當刮目相看。』",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是想要表達這個意思嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "閒聊就到此為止！　",
        "unit_id": 191011,
        "voice": "vo_adv_2012008_030"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "那位凱留小姐似乎已到極限了，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n此時此刻，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "她全身崩壞而就此喪命也不無可能！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n得迅速，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "且精確地來行動吧！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟如此可靠……！",
        "unit_id": 105911,
        "voice": "vo_adv_2012008_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n各位，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "倘若萬事順利，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下將不惜一生予以此恩之報！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呵呵～♪",
        "unit_id": 101112,
        "voice": "vo_adv_2012008_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n沒關係的唷，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這就是所謂的同粥共聚的那個嘛！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是『同舟共濟』唷，",
        "unit_id": 104911,
        "voice": "vo_adv_2012008_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃♪",
        "unit_id": 104911
    }
]