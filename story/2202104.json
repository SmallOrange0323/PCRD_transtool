        "type": "dialogue",
        "name": "珠希",
        "words": "這是",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "什麼喵！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "這個嗎？",
        "unit_id": 193511,
        "voice": "vo_adv_2202104_063"
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "鯛魚燒啊！",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "\n",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "這裡的所有居民都在聊說，",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "\n要利用",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "城鎮裡有的材料來製作鯛魚燒看看～",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "聽說這放了15杯份量的鮮奶油喔！",
        "unit_id": 193511,
        "voice": "vo_adv_2202104_064"
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "\n多到裝不下的部分",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "會從嘴巴那邊擠出來！",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嘴巴被塞了大量的鮮奶油的鯛魚燒……！",
        "unit_id": 104611,
        "voice": "vo_adv_2202104_065"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這簡直像在拷問喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "再加上，",
        "unit_id": 193511,
        "voice": "vo_adv_2202104_066"
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "這色彩真是迷人！",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "\n是彩虹色喔～",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "看起來可愛又好吃對吧！",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這顏色會讓人食慾大減喵！！",
        "unit_id": 104611,
        "voice": "vo_adv_2202104_067"
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "嗯？",
        "unit_id": 193511,
        "voice": "vo_adv_2202104_068"
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "怎麼啦？",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "又沒精神了嗎？",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "\n巧克力蝴蝶餅",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "加得不夠嗎……？",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "快、",
        "unit_id": 104611,
        "voice": "vo_adv_2202104_069"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "快住手喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這只是在增加拷問喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚嗚……！",
        "unit_id": 104611,
        "voice": "vo_adv_2202104_070"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n雖然很高興鯛魚燒在新世界能獲得認同……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但這種的根本稱不上是鯛魚燒喵～～～！！",
        "unit_id": 104611,
        "voice": "vo_adv_2202104_071"
    },
    {
        "type": "still",
        "still": "end"
    }
