    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "也是啦～",
        "unit_id": 123311,
        "voice": "vo_adv_2205003_066"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n小默涅跟那群人是第一次見面，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n會提防他們",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "也不奇怪啦～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不過安啦～",
        "unit_id": 123311,
        "voice": "vo_adv_2205003_067"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小騎士他們",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "雖然看起來很怪，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n但都不是壞人喔～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──是這樣",
        "unit_id": 129612,
        "voice": "vo_adv_2205003_068"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "就好了。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "可是……",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "他們刻意",
        "unit_id": 129612,
        "voice": "vo_adv_2205003_069"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "到比較遠的地方去討論──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "這會讓我不禁",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "認為，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "這是因為他們有什麼話不想讓我們聽到。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "哎，",
        "unit_id": 129711,
        "voice": "vo_adv_2205003_070"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這也難怪。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "對他們而言，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家等人同樣不可信。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "況且──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "卡里莎小子，",
        "unit_id": 129711,
        "voice": "vo_adv_2205003_071"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恁說是不是？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁們從前",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "跟騎士閣下他們曾是刀劍相向的關係是吧？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "不要叫我小子！",
        "unit_id": 191611,
        "voice": "vo_adv_2205003_072"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "是說",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "現在也沒變，我們依然是敵人。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "畢竟公主騎士那些傢伙",
        "unit_id": 191611,
        "voice": "vo_adv_2205003_073"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n害我吃了好多苦頭，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "總有一天一定要宰了他們──",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "討厭啦～",
        "unit_id": 123311,
        "voice": "vo_adv_2205003_074"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小卡里莎～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "你怎麼還～在說這種話？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "大家好好相處嘛～！",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "就、",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "像、",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "這、",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "個、",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "樣、",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "子♡",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "呃啊啊啊！",
        "unit_id": 191611,
        "voice": "vo_adv_2205003_075"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "煩死了，不要抱住我──！！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n不只是公主騎士，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我也一定會",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "把妳們通通都宰了！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "混帳～！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "…………",
        "unit_id": 129613,
        "voice": "vo_adv_2205003_076"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "默涅呀，",
        "unit_id": 129711,
        "voice": "vo_adv_2205003_077"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n收起武器。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──可是，",
        "unit_id": 129612,
        "voice": "vo_adv_2205003_078"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n他又說",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "要殺掉您……",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「先下手為強」",
        "unit_id": 129711,
        "voice": "vo_adv_2205003_079"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這句話，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "確實是奴家在汝年幼時教導汝的處事心態──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是在這個弱肉強食的世界活下去的方法。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而當初青澀如嫩葉的汝，",
        "unit_id": 129711,
        "voice": "vo_adv_2205003_080"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "也已綻放出華美的花。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n現在汝已有充分的能力",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "足以保護自己。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下那一行人的來訪是個良機，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝也該趁機學著",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "欣賞一點玩笑話了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "…………",
        "unit_id": 129612,
        "voice": "vo_adv_2205003_081"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不好意思！",
        "unit_id": 105812,
        "voice": "vo_adv_2205003_082"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n涅妃‧涅羅小姐，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有大家！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓你們久等了～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "歡迎回來～",
        "unit_id": 123311,
        "voice": "vo_adv_2205003_083"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "怎麼樣，小佩可，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "你們想到什麼好方法了嗎～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "沒有辦法保證絕對能成功，",
        "unit_id": 125812,
        "voice": "vo_adv_2205003_084"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但是我們擬訂了幾個方案",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "想嘗試看看。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "拚了。",
        "unit_id": 126112,
        "voice": "vo_adv_2205003_085"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "哦，",
        "unit_id": 129711,
        "voice": "vo_adv_2205003_086"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "各位的神色看起來真是可靠啊。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "所以，",
        "unit_id": 126012,
        "voice": "vo_adv_2205003_087"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "關於這次作戰，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "為了實行計畫，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n有些事情",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "希望能麻煩各位幫忙……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯～？",
        "unit_id": 123311,
        "voice": "vo_adv_2205003_088"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是什麼事呀，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "儘管說說看～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家自然會",
        "unit_id": 129711,
        "voice": "vo_adv_2205003_089"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不遺餘力相助。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n畢竟吉歐‧格黑納的存亡，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "即是我等的存亡。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太好了。",
        "unit_id": 106012,
        "voice": "vo_adv_2205003_090"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就要開始囉──",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「煉花鳳凰」迎擊大作戰！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的！",
        "unit_id": 105812,
        "voice": "vo_adv_2205003_091"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家一起來",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "保護卡里莎他們的世界！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "這才不是我的世界──！！",
        "unit_id": 191611,
        "voice": "vo_adv_2205003_092"
    }
]