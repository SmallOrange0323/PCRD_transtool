[
    {
        "type": "still",
        "still": "220500301"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在背面世界「吉歐‧格黑納」，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n既巨大又強大的怪鳥四處徬徨著，將天空燒成一片火紅。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在熊熊燃燒的羽翼之下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不管是野獸、魔物還是妖魔人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n都飽受火炎風暴的殘酷摧殘。"
    },
    {
        "type": "background",
        "background": "502080"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "獨角兔少女",
        "words": "咿咿咿咿咿咿！？",
        "unit_id": 136212,
        "voice": "vo_adv_2205003_000"
    },
    {
        "type": "dialogue",
        "name": "獨角兔少女",
        "words": "\n",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "獨角兔少女",
        "words": "好",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "獨角兔少女",
        "words": "燙好燙好燙～！！",
        "unit_id": 136212
    },
    {
        "type": "background",
        "background": "502090"
    },
    {
        "type": "dialogue",
        "name": "被火焰吞噬的魔物們",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "502072"
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "怎麼會這樣！",
        "unit_id": 50611,
        "voice": "vo_adv_2205003_001"
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "\n",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "鳳凰大人的火",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "會把蒲炎樹也一起燒掉嗎……！",
        "unit_id": 50611
    },
    {
        "type": "background",
        "background": "502110"
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克青年",
        "words": "不行，",
        "unit_id": 50711,
        "voice": "vo_adv_2205003_002"
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克青年",
        "words": "火燒得太快了！",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克青年",
        "words": "\n滅火的速度趕不上！",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "男蜥蜴人",
        "words": "啊啊！",
        "unit_id": 50811,
        "voice": "vo_adv_2205003_003"
    },
    {
        "type": "dialogue",
        "name": "男蜥蜴人",
        "words": "\n我的魔導書",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "男蜥蜴人",
        "words": "會跟房子一起被燒掉啊～！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克青年",
        "words": "不要管那些了！",
        "unit_id": 50711,
        "voice": "vo_adv_2205003_004"
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克青年",
        "words": "\n",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克青年",
        "words": "是說你快點盡全力逃跑！",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克青年",
        "words": "\n要是被燒成黑炭我可不管喔！",
        "unit_id": 50711
    },
    {
        "type": "still",
        "still": "220500301"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因垂老而失去判斷能力的魔鳥失去控制，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正逐步將強大無比的火焰之力散播到世界各地。"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而此時──"
    },
    {
        "type": "background",
        "background": "502070"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁們",
        "unit_id": 129711,
        "voice": "vo_adv_2205003_005"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "意欲如何？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2205003_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……沒有什麼",
        "unit_id": 105811,
        "voice": "vo_adv_2205003_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好猶豫的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們必須",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在這個世界",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n尋找我們要找的東西。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "假如說，不想辦法處理那隻菲尼克斯，",
        "unit_id": 105911,
        "voice": "vo_adv_2205003_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n吉歐‧格黑納就會燃燒殆盡的話……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那也沒有其他選擇。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……剛才",
        "unit_id": 106012,
        "voice": "vo_adv_2205003_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不小心就一口答應了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可是……",
        "unit_id": 106012
    },
    {
        "type": "still",
        "still": "220500302"
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "「要怎麼做～？」\n「要怎麼處理……？」",
        "unit_id": 1,
        "voice": "vo_adv_2205003_010"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……才剛到吉歐‧格黑納，",
        "unit_id": 125812,
        "voice": "vo_adv_2205003_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n馬上就遇到大麻煩了呢……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "涅婭小姐她們",
        "unit_id": 105913,
        "voice": "vo_adv_2205003_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也說好了會協助我們，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但究竟該怎麼辦才好……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "嗯……",
        "unit_id": 1,
        "voice": "vo_adv_2205003_013"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "唔……",
        "unit_id": 126012,
        "voice": "vo_adv_2205003_014"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我們先",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "整理一下狀況吧。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這樣搞不好也能發現什麼線索。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 126112,
        "voice": "vo_adv_2205003_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也對，",
        "unit_id": 105812,
        "voice": "vo_adv_2205003_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼首先……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個吉歐‧格黑納",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n跟吉歐‧提格尼亞不一樣，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是個充滿魔物的世界。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在此之中，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有六隻有能力毀滅世界的魔物。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們必須對抗的",
        "unit_id": 105913,
        "voice": "vo_adv_2205003_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是其中一隻，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也就是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "六凶",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「萬花菲尼克斯」。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "據說牠因為年老力衰，",
        "unit_id": 125812,
        "voice": "vo_adv_2205003_018"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "火力已不如全盛期，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但牠造成的火焰是如此兇猛，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n實在讓人很難以相信這已經是比較弱的火焰。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "而且因為牠有巨大的翅膀，",
        "unit_id": 126012,
        "voice": "vo_adv_2205003_019"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "飛行速度",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "也非同小可呢。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n那速度搞不好比小飯糰還快……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算想用遠距離攻擊",
        "unit_id": 106012,
        "voice": "vo_adv_2205003_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把飛在天上的牠打下來，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n隨隨便便的魔法",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "八成也只會被牠的火焰阻擋，起不了作用。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "既然如此，",
        "unit_id": 125812,
        "voice": "vo_adv_2205003_021"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "該試試看",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "飛到牠身邊，從近距離攻擊牠嗎？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我們可以",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "變身……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要光靠妳們三位對付牠，",
        "unit_id": 105913,
        "voice": "vo_adv_2205003_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那樣太魯莽了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼那麼，",
        "unit_id": 105812,
        "voice": "vo_adv_2205003_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請小凱留用飛行魔法讓大家飛過去吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這個主意怎麼樣？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯……",
        "unit_id": 106012,
        "voice": "vo_adv_2205003_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我有點",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒信心耶。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要控制好飛行魔法，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓所有人都能保持那個速度在空中戰鬥……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n除非我再多長出三個腦袋，不然根本無法維持專注。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "好像，",
        "unit_id": 126112,
        "voice": "vo_adv_2205003_025"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n很困難。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "嗯……",
        "unit_id": 1,
        "voice": "vo_adv_2205003_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──啊──煩死了！",
        "unit_id": 106012,
        "voice": "vo_adv_2205003_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在這種時候，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是可以用公主型態就好了～！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "公主？",
        "unit_id": 126112,
        "voice": "vo_adv_2205003_028"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就是以前兄長大人會用的",
        "unit_id": 125812,
        "voice": "vo_adv_2205003_029"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那種特殊強化嗎？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "的確，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "各位將力量發揮到極限時",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "會展開翅膀……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n「以前的我」記憶中",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "確實有這樣的畫面……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是變成公主型態，",
        "unit_id": 105812,
        "voice": "vo_adv_2205003_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就能咻～一下",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "飛過去，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "砰！一下",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "解決問題呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不，",
        "unit_id": 106012,
        "voice": "vo_adv_2205003_031"
    },
    {
