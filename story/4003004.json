[
    {
        "type": "background",
        "background": "500402"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦呀啊啊啊……！",
        "unit_id": 105811,
        "voice": "vo_adv_4003004_000"
    },
    {
        "type": "background",
        "background": "500402"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105812,
        "voice": "vo_adv_4003004_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是不行！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n難得把『世界第一好吃水果』都拿到手了～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n外皮卻太硬，連刀都切不下去！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔，偏偏香氣這麼誘人！",
        "unit_id": 105812,
        "voice": "vo_adv_4003004_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這真是活活氣死人啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。連力量強大的貪吃佩可小姐經主人強化後都沒辦法，",
        "unit_id": 105913,
        "voice": "vo_adv_4003004_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那這用一般方法大概是很難處理了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下想應該是有什麼特殊的調理方法。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "先回鎮一趟，",
        "unit_id": 105913,
        "voice": "vo_adv_4003004_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n查一查各種文獻再摸索出調理方法吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 106012,
        "voice": "vo_adv_4003004_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就這麼辦吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在這種地方磨蹭也不是辦法啊～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我的話可以到王宮的大圖書館去閱覽資料。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，不要卯起來咬那個水果……",
        "unit_id": 106012,
        "voice": "vo_adv_4003004_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n回去吧，貪吃佩可？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗑嗑。",
        "unit_id": 105812,
        "voice": "vo_adv_4003004_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是～就連外皮也很美味！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n用力吸一吸會滲出些果汁，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "味道非常甜……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是停不了擋不住啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們也很想吃啊，不要把口水沾在上面……",
        "unit_id": 106012,
        "voice": "vo_adv_4003004_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然還長有很多果實，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但光是採集這麼一點就夠吃力了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不想重來好幾次大冒險，所以珍惜現有的這些吧。",
        "unit_id": 106012,
        "voice": "vo_adv_4003004_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚～。",
        "unit_id": 105812,
        "voice": "vo_adv_4003004_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個就帶回公會小屋去栽種吧，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果汁真的非常可口……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n吸吸、吸吸……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你是小嬰兒啊。",
        "unit_id": 106012,
        "voice": "vo_adv_4003004_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了啦，水果我要沒收！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "走那麼小步，是要走到何年何月才能回到鎮上啊？",
        "unit_id": 106012
    }
]