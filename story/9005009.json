[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了選禮物的事，雪菲漫步在蘭德索爾的街上。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而，她卻一直找不到答案。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "光是一味地參考他人意見，",
        "unit_id": 106412,
        "voice": "vo_adv_9005009_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是得不出答案的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗎。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "該怎麼做才好呢……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這不是",
        "unit_id": 101811,
        "voice": "vo_adv_9005009_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雪菲嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……怎麼了嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，",
        "unit_id": 101512,
        "voice": "vo_adv_9005009_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "妳怎麼好像有心事呢～？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不介意的話，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "跟老師們",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "說說好嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "老師……",
        "unit_id": 106412,
        "voice": "vo_adv_9005009_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "們？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n也就是說……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊～！",
        "unit_id": 101611,
        "voice": "vo_adv_9005009_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這不是雪菲寶嗎～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n哈嚕～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "最近好嗎～？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們現在",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "正要去打掃精靈之森喔～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哎呀，",
        "unit_id": 105011,
        "voice": "vo_adv_9005009_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好久不見啦，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雪菲。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真受不了，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "只因為考試沒考好就得去做志工。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n要是害我衣服弄髒了該怎麼辦啦。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對對對、",
        "unit_id": 104011,
        "voice": "vo_adv_9005009_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對不起……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我也很遺憾森林這樣髒兮兮的～～～！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我會盡量",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "帶妳們去沒有毒的地方的……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "等等！？",
        "unit_id": 105011,
        "voice": "vo_adv_9005009_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "森林裡還有有毒的地方！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n怎麼都沒聽說！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "喂，鈴奈！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n做個志工還得賭命啊！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "開什麼玩笑！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的假的！？",
        "unit_id": 101611,
        "voice": "vo_adv_9005009_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太不妙了吧☆",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n那是什麼毒啊？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可以靠化妝蓋過嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 104011,
        "voice": "vo_adv_9005009_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我有準備了一大堆解毒藥，沒問題的！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小碧，",
        "unit_id": 101211,
        "voice": "vo_adv_9005009_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不用先預期自己會中毒啦☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而且",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "大家不用擔心～♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n今天要去的",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是相對安全的地方啦！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵。",
        "unit_id": 106412,
        "voice": "vo_adv_9005009_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "感覺和樂融融呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n好懷念就讀月光學院",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "的那段日子……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以",
        "unit_id": 101811,
        "voice": "vo_adv_9005009_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雪菲。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n妳是不是有什麼煩惱呢？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "妳也是我的學生，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n有什麼事都可以跟我商量喔。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃，",
        "unit_id": 106412,
        "voice": "vo_adv_9005009_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "其實……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我正在思考",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "紀念日該送他什麼禮物才好。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n雖然我已經",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "跟很多人詢問過",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "他的喜好，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但還是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "得不出答案……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 104011,
        "voice": "vo_adv_9005009_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我懂妳的感覺……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "每次只要太多人跟我講話，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我就會頭暈目眩，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "忍不住就逃走了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯嗯。",
        "unit_id": 101211,
        "voice": "vo_adv_9005009_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n小碧，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們過去那邊一下吧。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這個嘛……",
        "unit_id": 101811,
        "voice": "vo_adv_9005009_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我想",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那些給妳提供建議的人，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n肯定每個人說的都是正確答案。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但是──",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "──那些",
        "unit_id": 101512,
        "voice": "vo_adv_9005009_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "都不是妳的答案。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我相信，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "妳的心中也有自己的",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "正確答案才是。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以，",
        "unit_id": 101512,
        "voice": "vo_adv_9005009_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "如果妳想找到答案，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就得真正探究自己的內心喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我的……",
        "unit_id": 106412,
        "voice": "vo_adv_9005009_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "答案？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝",
        "unit_id": 106412,
        "voice": "vo_adv_9005009_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "兩位老師！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我一定會",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "努力找出自己的答案的……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與各種人的相遇，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n推進了雪菲追尋的腳步。"
    }
]