[
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯出現了緊急狀況。",
        "unit_id": 116211,
        "voice": "vo_adv_5064321_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "憂妮們完全復活～",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "以下省略。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔唔唔，",
        "unit_id": 116411,
        "voice": "vo_adv_5064321_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可惡的憂妮們，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "竟然自我修復跟自我進化以下省略。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "討厭啦！",
        "unit_id": 116311,
        "voice": "vo_adv_5064321_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那傢伙超級煩人的耶！！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要是不快點把事情解決，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "聖學祭就要開始收攤了！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒還有很多想看的展示耶，要怎麼辦啦！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 14511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "吵死了。",
        "unit_id": 116211,
        "voice": "vo_adv_5064321_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n現在在說很重要的事，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "給我安靜點。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是的，",
        "unit_id": 116411,
        "voice": "vo_adv_5064321_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什麼嘎喔啊。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n用那種蚊子般的叫聲，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們才不會害怕。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓她聽聽妳",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "靈魂的咆嘯。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "唔喔喔喔──！",
        "unit_id": 116311,
        "voice": "vo_adv_5064321_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳這是瞧不起我們嗎？",
        "unit_id": 116411,
        "voice": "vo_adv_5064321_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不對，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳被敵人瞧不起了喔。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "用給那叫什麼慈樂之音的加油聲，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "拿出真本事來。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "望──望──！",
        "unit_id": 116311,
        "voice": "vo_adv_5064321_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不夠凶，",
        "unit_id": 116411,
        "voice": "vo_adv_5064321_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "音程降兩度。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "望──望────！",
        "unit_id": 116311,
        "voice": "vo_adv_5064321_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "用強弱法，",
        "unit_id": 116411,
        "voice": "vo_adv_5064321_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "漸強。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "望唔唔唔唔",
        "unit_id": 116311,
        "voice": "vo_adv_5064321_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "望啊啊啊啊──！！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "克蘿依，",
        "unit_id": 116411,
        "voice": "vo_adv_5064321_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳也上。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "望唔唔唔唔",
        "unit_id": 116211,
        "voice": "vo_adv_5064321_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "望啊啊啊啊──！！",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐也一起吧！",
        "unit_id": 116311,
        "voice": "vo_adv_5064321_014"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "預備，來！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "好朋友社",
        "words": "望唔唔唔唔",
        "unit_id": 1,
        "voice": "vo_adv_5064321_015"
    },
    {
        "type": "dialogue",
        "name": "好朋友社",
        "words": "望",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "好朋友社",
        "words": "啊啊啊啊──！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "…………？",
        "unit_id": 102912,
        "voice": "vo_adv_5064321_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "學姐，",
        "unit_id": 116211,
        "voice": "vo_adv_5064321_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n路過的望望",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "用「叫我嗎？」的臉在看這邊。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒有叫她。",
        "unit_id": 116411,
        "voice": "vo_adv_5064321_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒有在叫妳──",
        "unit_id": 116211,
        "voice": "vo_adv_5064321_019"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 116311,
        "voice": "vo_adv_5064321_020"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "發生了什麼事嗎？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n話說妳們在跟誰說話啊？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 14511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，糟糕，",
        "unit_id": 116211,
        "voice": "vo_adv_5064321_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "憂妮們超生氣的耶。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "琪愛兒，要上囉──",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 116311,
        "voice": "vo_adv_5064321_022"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好的～！",
        "unit_id": 116311
    }
]