[
    {
        "type": "background",
        "background": "501050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}停留在度假期間造訪的村落，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正當他漫無目的的四處散步時──"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯？",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是你呀。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真巧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你在這裡",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "做什麼呀？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也在到處閒晃呢。",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "難得來度假，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就想體驗一些特別的事。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你也沒有什麼特別要緊的事嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n嗯，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "度假期間",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還睡回籠覺就太浪費了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對了。",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你不嫌棄的話，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要不要陪我呀？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n比起自己一個人，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "和別人一起逛逛比較好玩吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也不曉得這村子哪裡有些什麼。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們就隨便到處走走，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看看有沒有好玩的事吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唔……",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然有各式各樣的伴手禮店，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n但我現在也不是買伴手禮的心情啊。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果有那種只有在這一帶才玩得到的體驗，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那是再好不過了──",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "你們兩個，",
        "unit_id": 1411,
        "voice": "vo_adv_1131001_007"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "是觀光客嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "去體驗看看竹葉舟海釣吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯？",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "竹葉舟海釣？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那是什麼呀？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "就字面上的意思啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1131001_009"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "乘著竹葉舟出去海釣。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n這是艘特別製作的船，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "用好幾百片大竹葉疊成的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "你們看。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔……",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "與其說是船，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "外型更像是筏呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "不只是海釣而已，",
        "unit_id": 1411,
        "voice": "vo_adv_1131001_011"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "這個也可以用來衝浪呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "這裡的當地人",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "大多都是用來衝浪的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "你們可以在竹葉舟上體驗海釣，",
        "unit_id": 1411,
        "voice": "vo_adv_1131001_012"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n也可以在空閒時間欣賞景色。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "怎麼樣？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "聽起來滿有意思的。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們就試試看吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "好，",
        "unit_id": 1411,
        "voice": "vo_adv_1131001_014"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "謝謝惠顧！",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然這船滿大的，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_015"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "聽說兩個人一起搭也沒有問題……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過你，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對自己的平衡感有信心嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼有自信啊。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那就讓我見識見識",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你的程度吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_017"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我感受到你的自信了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是馬上就失去平衡感，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那也沒什麼說服力呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈哈，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說什麼完全沒有信心，也說過頭了吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別那麼擔心，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就只是站到一塊板子上而已。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……抱歉，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_019"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來你真的不擅長啊。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n沒想到會突然翻船。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我姑且確認一下，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你會游泳嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我沒有印象",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看過你在海邊游泳……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔……",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "腳踩不到地就不行嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "既然這樣，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們好好練習，小心不要讓竹葉舟翻船了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "聽好囉？",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n萬一翻船了，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不要慌張，抓住竹葉舟──",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那我們彼此配合，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一起坐上竹葉舟吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "預備……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "二，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "三！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "花時間練習是值得的。",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_024"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n和剛才比起來，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你上船的動作流暢多了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "今天的海浪很平靜，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來不用擔心會被沖走。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "陽光也很舒適，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "最適合悠閒地慢慢來了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_026"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在我們放鬆休息前，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "得先好好釣個魚呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可以幫我拿後面那個箱子嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "謝謝。",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_027"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我現在就組裝釣竿。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哇、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然海浪很平靜，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但在海上還是不好處理呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊！？",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "等、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "等一下，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別碰我！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你突然摸我，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "會嚇到我啊。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是啦，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_029"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那個，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我沒有在生氣啦。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你不用這樣幫我，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我自己也做得來的。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好嗎？",
        "unit_id": 113111
    },
    {
        "type": "still",
        "still": "113100101"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "──嗯，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣就都準備好了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那我們",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就來試試看吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嘿！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種情況下，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "最好瞄準看得見岩石的地方。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n魚通常會躲在那附近……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "上鉤了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嘿咻！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想不到馬上就有魚上鉤了，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_032"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是好兆頭。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你那邊也差不多",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要有魚上鉤了吧？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……嗯？",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_033"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你擺動釣竿的幅度不能那麼大。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你要讓魚容易咬餌的話，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要像這樣，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小幅度的擺動。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_034"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來了！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n抓緊了，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就這樣直接釣上來！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼……",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_035"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "釣這麼多條應該夠了吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然一開始很生疏，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但你現在也",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "越來越有模有樣了呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼了，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_036"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就算你誇獎我也沒好處喔？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不過你能這麼說，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我還是很高興的。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓你陪我做了我喜歡的事，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_037"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過你看起來也玩得很盡興，那就好了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "釣魚先歇會，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_038"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好好放鬆一下。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n悠悠閒閒地欣賞周圍的景色吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "海風真舒服……",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_039"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n同時能享受海洋，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來選擇竹葉舟海釣是正確的呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能和你",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_040"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "像這樣約會也……",
        "unit_id": 113111
    },
    {
        "type": "still",
        "still": "113100102"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……咦！？",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_041"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我在說什麼呀！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n只是一起玩而已，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "居然說成約會……！　",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呃，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_042"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那個，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "剛才我說的那些……！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "該說是語病嗎，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那個……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……啊，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_043"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好像又",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有點想釣魚了呢！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在這附近",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "再釣個一條吧！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對了，",
        "unit_id": 113111,
        "voice": "vo_adv_1131001_044"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們要不要來比賽，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看誰釣得快！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n來，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "開始囉！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嘿咻！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "絲毫沒有察覺到流夏在掩飾羞澀的心情，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}再次沉浸在釣魚的樂趣當中──"
    },
