    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你這個笨蛋！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n話說回來，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你是從哪裡冒出來的！",
