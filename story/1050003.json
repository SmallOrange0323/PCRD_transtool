        "voice": "vo_adv_1050003_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是想說至少去吃一次看看啦……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n不過聽說客人大多是情侶，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一個人去了會很不自在。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但是",
        "unit_id": 105011,
        "voice": "vo_adv_1050003_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你來的時機正好，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "幫了我大忙！",
