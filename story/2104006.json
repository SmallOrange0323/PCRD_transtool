[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……月光學院……",
        "unit_id": 118011,
        "voice": "vo_adv_2104006_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n月光學院！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐……",
        "unit_id": 411,
        "voice": "vo_adv_2104006_001"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n您接下來",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "真的要造訪月光學院嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "當然啊，",
        "unit_id": 118011,
        "voice": "vo_adv_2104006_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那還用說嗎！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我得找個學院長或是教職員代表，好好說他們幾句，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不然我這口氣嚥不下去！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是的，",
        "unit_id": 118011,
        "voice": "vo_adv_2104006_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "到底在想什麼呀！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n他們向國家遞出了修復校舍的申請，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可是卻在明年就要廢校了……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不過，",
        "unit_id": 411,
        "voice": "vo_adv_2104006_004"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "申請會通過審核是上面的人沒有充分調查吧。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n承包維修工程的我們",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n只是一個個去修復那些受到認可的公共設施而已。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就算是這樣，",
        "unit_id": 118011,
        "voice": "vo_adv_2104006_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這種無意義的施工實在是太豈有此理了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n只有應急措施撐著的城牆、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "荒蕪的街道、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "休息站、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "克蕾琪塔高塔！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n還有很多地方在等著重建呢！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "據",
        "unit_id": 411,
        "voice": "vo_adv_2104006_006"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "公會管理協會的說法，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n如果學生們的學力有所提升的話，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n廢校一事似乎還能從長計議。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "他們倒是打從一開始就認真讀書啊！",
        "unit_id": 118011,
        "voice": "vo_adv_2104006_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n要胡鬧也得有點分寸吧！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊，",
        "unit_id": 118011,
        "voice": "vo_adv_2104006_008"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是的！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "當初是以民間交流的名義把公主送進校園，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n藉以展現一下我們【里士滿工商會】的手腕，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "順利的話，\n還可以加以監視並掌握公主的弱點……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您又在盤算這種陰謀嗎？",
        "unit_id": 411,
        "voice": "vo_adv_2104006_009"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "明明就不擅長做這些事……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "囉嗦！吵死了！",
        "unit_id": 118011,
        "voice": "vo_adv_2104006_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "別把妳的雇主講得像廢柴一樣！",
        "unit_id": 118011
    },
    {
        "type": "background",
        "background": "501110"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……聊著聊著就……",
        "unit_id": 118011,
        "voice": "vo_adv_2104006_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "看到了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "月光學院！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然是令人火大的一件事，不過……",
        "unit_id": 118011,
        "voice": "vo_adv_2104006_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "喔呵呵，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號，妳看看！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n在我出馬安排下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "非常完美修復的校舍──",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "竟然又被破壞掉了啊─────！？",
        "unit_id": 118011,
        "voice": "vo_adv_2104006_013"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……變成",
        "unit_id": 411,
        "voice": "vo_adv_2104006_014"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "「曾經」",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "很完美的校舍",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "了呢……",
        "unit_id": 411
    },
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──同一時間。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在伊緒的教室裡，\n失控的學生們使用的攻擊魔法產生爆炸──"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咳、",
        "unit_id": 105011,
        "voice": "vo_adv_2104006_015"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咳……！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "唔……",
        "unit_id": 192011,
        "voice": "vo_adv_2104006_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒事！",
        "unit_id": 101811,
        "voice": "vo_adv_2104006_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可是……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "佩可寶妳還好嗎！？",
        "unit_id": 101611,
        "voice": "vo_adv_2104006_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n妳為了保護我們，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "承受了很多魔法傷害吧！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……唔，",
        "unit_id": 105811,
        "voice": "vo_adv_2104006_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我沒事，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "完全不痛不癢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有了這身皇家裝備，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再加上{player}的強化，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這點攻擊不算什麼……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那倒是，",
        "unit_id": 106011,
        "voice": "vo_adv_2104006_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果是妳的話，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算挨了幾記",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那種程度的魔法也不會死的吧……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "學生們",
        "words": "啊啊啊啊────！",
        "unit_id": 1,
        "voice": "vo_adv_2104006_021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哇！",
        "unit_id": 106411,
        "voice": "vo_adv_2104006_022"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "又要來了！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "大家",
        "unit_id": 101811,
        "voice": "vo_adv_2104006_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "快住手！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你們不能做這種事！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "老師，危險！",
        "unit_id": 105811,
        "voice": "vo_adv_2104006_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快退後！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "——「冰之壁」！",
        "unit_id": 106411,
        "voice": "vo_adv_2104006_025"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚……！",
        "unit_id": 106411,
        "voice": "vo_adv_2104006_026"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呀啊！",
        "unit_id": 192011,
        "voice": "vo_adv_2104006_027"
    },
    {
        "type": "dialogue",
        "name": "學生們",
        "words": "唔喔喔喔喔————！！",
        "unit_id": 1,
        "voice": "vo_adv_2104006_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦咦咦！",
        "unit_id": 101611,
        "voice": "vo_adv_2104006_029"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n又來！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們班上的學生，",
        "unit_id": 105011,
        "voice": "vo_adv_2104006_030"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "有這麼擅長使用魔法嗎！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他們被逼出",
        "unit_id": 106011,
        "voice": "vo_adv_2104006_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "超越自身極限的魔力了……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這些傢伙",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "果然是被洗腦了啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "各位同學！",
        "unit_id": 101811,
        "voice": "vo_adv_2104006_032"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n拜託你們，快住手！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你們幾個！",
        "unit_id": 105011,
        "voice": "vo_adv_2104006_033"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n沒聽到伊緒說的話嗎！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "講了也沒用啦！",
        "unit_id": 106011,
        "voice": "vo_adv_2104006_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒辦法了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只好用粗暴一點的方式了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留！？",
        "unit_id": 106411,
        "voice": "vo_adv_2104006_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──雷之精靈！",
        "unit_id": 106011,
        "voice": "vo_adv_2104006_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n馳騁於地，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "化作盤根束縛！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "學生們",
        "words": "——呀啊啊啊！？",
        "unit_id": 1,
        "voice": "vo_adv_2104006_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！？",
        "unit_id": 105811,
        "voice": "vo_adv_2104006_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳不能真的宰了他們喔！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道啦。",
        "unit_id": 106011,
        "voice": "vo_adv_2104006_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "包在我身上！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "——「雷霆束縛」！",
        "unit_id": 106011,
        "voice": "vo_adv_2104006_040"
    },
    {
        "type": "dialogue",
        "name": "學生們",
        "words": "……嗚！！",
        "unit_id": 1,
