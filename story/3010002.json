        "name": "望",
        "words": "嗚、嗚嗚……",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_071"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我感受到比我更強的熱情……",
