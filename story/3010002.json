        "type": "dialogue",
        "name": "紡希",
        "words": "舞步的部分要由我們三個人討論決定。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我明白了。",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_074"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……望小姐。不只是唱歌，跳舞也是一樣……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我絕對不會輸給望小姐的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哼哼哼～……",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_075"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我可是一直都在當偶像呢，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n妳以為自己能夠贏過我嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "千歌姐吸收的速度非常快，",
        "unit_id": 105411,
        "voice": "vo_adv_3010002_076"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我想妳們兩人的出道演唱會，一定會是場超棒的表演。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也非常地期待呢！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且感覺千歌姐好像也越來越樂在其中了！",
        "unit_id": 105411,
        "voice": "vo_adv_3010002_077"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦……？樂在其中……？",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_078"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我、我看起來樂在其中嗎……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛剛還開心地跟我競爭的人是誰呢～？",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_079"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……像這樣大家一起練習、一起思考……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n朝著相同的目標努力奮鬥，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "很開心吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……是的。至今為止我都只有考慮過戰鬥的事情……",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_080"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我認為……像這樣，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也很不錯。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，那妳最好做好覺悟呦。",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_081"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "正式上場時可是會更有趣！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌對於心中湧起的心情感到有些困惑，\n但他同時也牢記住這股不可思議的興奮感──"
    }
]