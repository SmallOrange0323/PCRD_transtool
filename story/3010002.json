[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這天，慈樂之音的成員為了練習，\n在城外集合。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "停。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "多配合我的腳步一點。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們可是個團體，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這可不是自己一人的舞台哦？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果再多加點舞步進來的話",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就更辛苦了。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不好意思。",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我沒有跟其他人像這樣，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一起跳舞過……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算是戰鬥時，也得和一起戰鬥的人互相配合行動吧？",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "偶像的課程也是如此，總有一天一定也能在戰鬥時上用場的。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這麼說，好像也沒錯呢……",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我沒有想到，居然要兩個人完美地同步配合才行……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不只是同步配合，輪到妳的部份時也要好好唱歌才行。",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那我們休息一下吧。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒關係吧，紡希？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒關係呦。",
        "unit_id": 105411,
        "voice": "vo_adv_3010002_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n妳們已經完成了到這個時間為止該做的練習量。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "兩位辛苦了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你。其實我還撐得住呢。",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……對了。趁休息的時候，我對千歌說明一下那件事吧。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也是呢。反正都已經順利決定了。",
        "unit_id": 105411,
        "voice": "vo_adv_3010002_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那件事，是指什麼……？",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這就要敬請期待囉♪",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_009"
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天呢，有件重要的事情要告訴千歌！",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？那、那個……",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是要發表什麼消息嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鏘鏘！",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳看妳看～！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這張海報是今天早上才做好的！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我看看……",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "「慈樂之音，將要舉辦成立後的第一次演唱會」……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "演唱會！？是要在客人面前表演那些內容嗎！？",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我沒聽過這件事情呀！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯嗯。",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為要是告訴千歌的話，千歌妳一定會反對吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對吧，紡希？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對呀。就是想到這一點所以我們才暗地裡進行。",
        "unit_id": 105411,
        "voice": "vo_adv_3010002_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為了保險起見我再問一下，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "千歌姐果然還是反對舉辦演唱會嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我當然反對。",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我的歌聲和唱喚術",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "的目的是守護人們，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n並不是用來舉辦演唱會的……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "既然目的是用來守護人們，那當然也能用來舉辦演唱會！",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "透過唱歌讓人們快樂起來也是很重要的吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在讓大家變得幸福的意義上，兩邊其實是一樣的，對吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖、雖然妳說的可能也沒錯……",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……該不會，",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳是在害羞吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……是的。",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真的要唱那首歌嗎？還要在許多人的面前唱？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我、我實在是……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那種事情妳不用擔心啦。",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也會跟妳一起唱。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這次不是一人獨唱，而是兩個人一起唱，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以我們兩個要好好配合舞步才行呢！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "順帶一提，我們也已經無路可退了。",
        "unit_id": 105411,
        "voice": "vo_adv_3010002_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我早已經預約好會場，也已經找了贊助商。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就連操作各種機器的工作人員，也都僱用好了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是我們現在取消的話，",
        "unit_id": 105411,
        "voice": "vo_adv_3010002_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可是會造成很多人的麻煩的呦。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這次的贊助商，可是那位秋乃小姐的公會呦？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "準備工作已經進行到這種程度了？",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這都多虧了紡希！",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n他超級俐落地幫忙處理各種工作呢！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們呀，真是找到一位超級厲害的經紀人呢！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既然要做我就會全力以赴。",
        "unit_id": 105411,
        "voice": "vo_adv_3010002_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且，服裝可是由我製作的呦？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣的話，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "當然要辦一場讓服裝能全力發揮的演唱會！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "輕飄飄的裙子……真讓人受不了呀……！！",
        "unit_id": 105411,
        "voice": "vo_adv_3010002_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "紡希對於服裝的熱情真是超厲害的……",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "他的熱情真的很厲害呢。",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "順道一提，要是紡希妳肯和我們一起登台演出的話，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那我會很開心的說～",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳、妳在說什麼！？",
        "unit_id": 105411,
        "voice": "vo_adv_3010002_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我是以幕後人員的身分加入公會的。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n演唱會請由妳們兩個人主打吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個……這樣的話，我在演唱會也負責幕後……",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不行！我們已經在海報的表演者名單寫上千歌的名字了！",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且這樣還會浪費掉至今的練習，妳認命一點陪我上台吧。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "（等等還得把海報換成有紡希名字的版本，",
        "unit_id": 102911,
        "voice": "vo_adv_3010002_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這點可千萬不能忘記了……♪）",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……我明白了。",
        "unit_id": 104211,
        "voice": "vo_adv_3010002_035"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "畢竟這是成立公會時的約定，我可不能破壞約定。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
