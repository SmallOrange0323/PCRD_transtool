[
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "競合店からも視察が来るとはな。",
        "unit_id": 105312,
        "voice": "vo_adv_6106104_000"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そういった手合いへの対処も、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "考えておくに越したことはないな。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nなにか妙案はないものか……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "貴公も意見を聞かせてくれないか。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そうか、",
        "unit_id": 105312,
        "voice": "vo_adv_6106104_001"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "来る者に疑いのまなざしを向けて……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "視線で殺す、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "と。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nきっと後ろ暗い思いのある輩は逃げ出すに違いないな！",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "って、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "それでは普通のお客も入ってくれないではないか！",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "仲良く……？　",
        "unit_id": 105312,
        "voice": "vo_adv_6106104_002"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そうか、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "二重スパイというやつだな！",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nいかにも軍人らしい対処法だ、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "実にカッコいいではないか！",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "それらしき人物を見たら、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "積極的に声をかけてみるとしよう。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ほう、",
        "unit_id": 105312,
        "voice": "vo_adv_6106104_003"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "むしろ堂々とこちらから出向いてやろうというわけか。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "それなら競合店の偵察もできるし、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "甘味も思うさま堪能できて",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n一石二鳥……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "あっ、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "いや、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "今のは聞かなかったことに……",
        "unit_id": 105312
    }
]