[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和伊緒一起買東西時，\n突然被一道詭異的光芒包圍。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸？欸？",
        "unit_id": 101811,
        "voice": "vo_adv_1018004_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這是什麼光？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！！",
        "unit_id": 101811
    },
    {
        "type": "still",
        "still": "101800401"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎麼了？",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n怎麼發呆了……？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為是假日學校都沒有其他人，",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n所以在緊張嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸？這件衣服？",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為今天只有我們兩個人，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n所以就穿了休閒一點的衣服。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然很開心你誇獎我的打扮，",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但不專心的話不行喔？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "難得可以只有兩個人在一起……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒關係。",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n讓我來仔細地指導你吧。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n來，放鬆一點……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那開始上課囉。",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n首先打開現代國文的教科書。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然總是讓你幫忙，",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但課業的話我可以幫你！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我會加油的！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那你哪邊不懂呢？",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……咦？怎麼了？",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n為什麼一直看我……？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "胸部？胸部怎麼了嗎？",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……欸？沒什麼？",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是、是嗎……？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n沒什麼的話就好……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸、欸欸！？",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n突然說什麼奇怪的話？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不可以戲弄老師哦。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……只是，從來沒有被男生",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n說過可愛，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n所以有點開心……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是要好好看教科書才行喔。",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n專心、專心！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你看看這個題目。",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n回答人物的心情這一題。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n上次考試的時候你寫錯了――",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，你又在看我了。",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n集中力已經不夠了嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真拿你沒辦法～",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n那我們休息一下吧。",
        "unit_id": 101831
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510220"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這裡有茶和點心。",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n一邊吃一邊聊聊天吧。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，這種時光很快樂吧？",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我一直很憧憬和朋友一起念書。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "教彼此不懂的地方，休息時間一起吃點心，",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n然後脫離重點變成聊戀愛的話題……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對了！要不要聊戀愛的事？",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你有喜歡的女孩嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣啊……真可惜。",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過好像有點放心了。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "眼前？什麼意思？",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！那女孩就像浮現在眼前一樣，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n總是想著她的意思吧。真好！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸？我喜歡的類型？",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，祕密！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n說不定哪天你就會知道了唷？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……欸、欸，這是在聊戀愛話題對吧？",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n又實現夢想了！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝你！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好，差不多該繼續念書了。",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_026"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還沒辦法專心嗎……？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_027"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對了！這樣的話，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n如果你認真念書，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n老師就幫你來場特別指導做為獎勵。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "非常開心、",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n讓人心跳加速的特別指導唷。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n老師會很溫柔地教你的。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，你變得這麼有幹勁，真開心♪",
        "unit_id": 101831,
        "voice": "vo_adv_1018004_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我會努力教你的。",
        "unit_id": 101831
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？這是我給你的禮物！",
        "unit_id": 190011,
        "voice": "vo_adv_1018004_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你做了個好『夢』嗎？？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛剛的情景，是我依照你和伊緒的『記憶碎片』",
        "unit_id": 190011,
        "voice": "vo_adv_1018004_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n創造出來的『夢』唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很懷念嗎？嗯，還不清楚啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你收集到更多的『記憶碎片』，",
        "unit_id": 190011,
        "voice": "vo_adv_1018004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就會再讓你做『夢』的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你和許多女孩在一起的『夢』做得越多……",
        "unit_id": 190011,
        "voice": "vo_adv_1018004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就可以藉此還原世界的真實面貌。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要加油喔♪♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～♪",
        "unit_id": 190011,
        "voice": "vo_adv_1018004_034"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯、",
        "unit_id": 101811,
        "voice": "vo_adv_1018004_035"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯嗯？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這裡是……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？我和你在買東西……",
        "unit_id": 101811,
        "voice": "vo_adv_1018004_036"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但不知不覺好像睡著了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我夢到在教你功課……",
        "unit_id": 101811,
        "voice": "vo_adv_1018004_037"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸！？",
        "unit_id": 101811,
        "voice": "vo_adv_1018004_038"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你也做了同樣的夢？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n真不可思議呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……怎麼了？",
        "unit_id": 101811,
        "voice": "vo_adv_1018004_039"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n有什麼在意的地方嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸？特別指導的內容？",
        "unit_id": 101811,
        "voice": "vo_adv_1018004_040"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，內容非常精彩唷。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是我最喜歡的戀愛小說的課程唷",
        "unit_id": 101811,
        "voice": "vo_adv_1018004_041"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n非常揪心又讓人心跳加速！",
        "unit_id": 101811
    }
]