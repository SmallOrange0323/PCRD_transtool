[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克蕾琪塔搖搖晃晃，腳步踉蹌的走著。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了配合她的腳步，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人的行進速度也緩了下來。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我的忠義……",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "忠義……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯……",
        "unit_id": 107011,
        "voice": "vo_adv_7024004_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "她一點霸氣都沒有了。",
        "unit_id": 107011,
        "voice": "vo_adv_7024004_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來她也只有這點能耐。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這下妳也能夠",
        "unit_id": 107011,
        "voice": "vo_adv_7024004_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "心無牽掛的加入我了呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我可以晚點",
        "unit_id": 6111,
        "voice": "vo_adv_7024004_004"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "再給您答覆嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那個人……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "接下來才是最有趣的。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你也是這麼想的嗎？",
        "unit_id": 107011,
        "voice": "vo_adv_7024004_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你認為她不會因此",
        "unit_id": 107011,
        "voice": "vo_adv_7024004_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "受挫嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你還挺看好她的呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你認為她",
        "unit_id": 107011,
        "voice": "vo_adv_7024004_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很頑強嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這點倒是沒錯……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……既然你都這麼說了，",
        "unit_id": 107011,
        "voice": "vo_adv_7024004_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那就再觀察一陣子吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "…………",
        "unit_id": 6111,
        "voice": "vo_adv_7024004_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯？",
        "unit_id": 107011,
        "voice": "vo_adv_7024004_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼了嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "剛才，",
        "unit_id": 6111,
        "voice": "vo_adv_7024004_011"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那邊似乎有一些",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "動靜……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我去確認。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n克蕾琪塔小姐請在這裡稍待片刻。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唉……",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "面對自己心中的疑惑，",
        "unit_id": 107011,
        "voice": "vo_adv_7024004_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "並且得不到部下的支援，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n她究竟會如何行動呢……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是太令人期待了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你說我挖角秘書的理由？",
        "unit_id": 107011,
        "voice": "vo_adv_7024004_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "一部分是為了削減對方的棋子，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n另一部分是因為她真的很優秀。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "各位，",
        "unit_id": 6111,
        "voice": "vo_adv_7024004_015"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n那裡有魔物。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "她會像那樣完美地完成任務。",
        "unit_id": 107011,
        "voice": "vo_adv_7024004_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以我是認真",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想把她挖角過來。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在被發現之前我們先動手吧。",
        "unit_id": 107011,
        "voice": "vo_adv_7024004_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你待在這裡負責強化和掩護。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我、",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_018"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也一起……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你們就乖乖地待在這裡。",
        "unit_id": 107011,
        "voice": "vo_adv_7024004_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "單靠一人是連魔物都無法擊中的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不愧是似似花小姐。",
        "unit_id": 6111,
        "voice": "vo_adv_7024004_020"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "和她相比，我簡直……",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呵呵……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就是說啊，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "像我這樣的廢物根本就……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "右翼敵人增援！",
        "unit_id": 6111,
        "voice": "vo_adv_7024004_022"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦……？",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_023"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呀啊啊啊！？",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_024"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐！？",
        "unit_id": 6111,
        "voice": "vo_adv_7024004_025"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我……",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_026"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為什麼飛在空中……？　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被魔物轟到空中的克蕾琪塔。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她的腦海中不斷閃過人生往事。"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這是……",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "走馬燈……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我的人生",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就要在這裡結束了嗎……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不可思議地一點都不痛呢……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我的人生……",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_028"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "曾經是那樣的榮華富貴，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n究竟是怎麼變成這樣的呢……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唉，",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_029"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不用想也知道……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n在克蕾琪塔之塔崩壞的那一天……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不對，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是遇到那些傢伙以後……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "【里士滿工商會】就是從那裡",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_030"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "開始沒落的……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "再加上",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "被豪紳議長陷害",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "導致被通緝……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我真的是跌到谷底呢……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是，",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_031"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這時卻有人對我伸出援手……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那人就是我曾經想暗殺的",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n那個老好人公主……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下……",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_032"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我那個時候……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n真的是……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "非常的……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "非常的火大啊！！！",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_033"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "做事不經大腦！",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_034"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n偏袒徇私！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n用飯糰就想誘人上鉤！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是！",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "更因為如此！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我那時萌生的忠義一定是真心的！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為了報答她那番悠哉的話和飯糰！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我是不能倒在這裡的！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐，",
        "unit_id": 6111,
        "voice": "vo_adv_7024004_036"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您沒事嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "當然沒事！",
        "unit_id": 118011,
        "voice": "vo_adv_7024004_037"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
