[
    {
        "type": "background",
        "background": "500997"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "以那種形式湧出的溫泉居然能派上用場，",
        "unit_id": 103811,
        "voice": "vo_adv_6040407_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真是讓人意想不到呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果沒有發生這種事情，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們應該會放著不管吧……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這座溫泉能成為讓大家都感到高興的東西",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真是太好了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那種華麗的外觀",
        "unit_id": 103811,
        "voice": "vo_adv_6040407_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "以娛樂設施來說",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "剛剛好嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n雖然我是搞不太懂……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過孩子們都笑得很開心，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我想應該是正確的吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "　笑容即是正確的，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "溫泉加上美麗的景色，",
        "unit_id": 103811,
        "voice": "vo_adv_6040407_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的是",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "準備到非常周到呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果能再加上剛擠好的新鮮牛奶",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就是最棒的組合了……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一定要拿回",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們最重要的牛群呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好想要儘早拿回牧場，",
        "unit_id": 103811,
        "voice": "vo_adv_6040407_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "和大家一起泡溫泉呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……啊。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只有……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n可能沒辦法一起泡溫泉呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起。",
        "unit_id": 103811
    }
]