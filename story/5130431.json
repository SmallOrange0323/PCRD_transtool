    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "對於指引我們的兄長大人，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有著道不盡的感謝之意。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
