        "voice": "vo_adv_5130431_005"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥",
        "unit_id": 126012,
        "voice": "vo_adv_5130431_006"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "正在看著我們。",
        "unit_id": 126012
