    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "好了，",
        "unit_id": 106831,
        "voice": "vo_adv_5201088_000"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "大家靠近一點──",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "既然要拍可以趕快嗎？",
        "unit_id": 106931,
        "voice": "vo_adv_5201088_001"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我本就不想看到臉的傢伙們都已到齊，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "別再讓我感到更不悅了。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "意見相同也讓我很不愉快，",
        "unit_id": 107331,
        "voice": "vo_adv_5201088_002"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "但我認同這句話。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "要是再讓我等下去，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "合照就要",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "變成亂鬥的瞬間了。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這也沒辦法啊，",
        "unit_id": 106831,
        "voice": "vo_adv_5201088_003"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "兩位～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n畢竟需要提供宣傳用的照片給媒體。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n也就是用來介紹《阿斯特朗傳奇》主要開發成員",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "的一張照片。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想要照片的是在國外也很知名的媒體。",
        "unit_id": 107131,
        "voice": "vo_adv_5201088_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可以期待有很好的宣傳效果喔？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以我的角度來說，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然能得到利益，要合照就給他們吧☆",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是啊，",
        "unit_id": 107031,
        "voice": "vo_adv_5201088_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就當作這也是行銷策略之一坦然接受吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──話說，克莉絲，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不要擺出那種自我風格強烈的姿勢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n只有妳一個人有模特兒的感覺。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 107131,
        "voice": "vo_adv_5201088_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "拍照為何還非得收斂自我風格才行？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n簡直無法理解。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "反倒是似似花，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳還是努力讓體型看起來更大一點會比較好喔。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊哈哈，",
        "unit_id": 106831,
        "voice": "vo_adv_5201088_007"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這樣下去不管花多久時間都按不了快門呢～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊，對了，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "長老……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "「她」",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "人呢？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "我有轉告她今天的事，",
        "unit_id": 107231,
        "voice": "vo_adv_5201088_008"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "也收到答覆了。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "她果然",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "還是無法來這裡。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "她連開發完成時都沒有露面，",
        "unit_id": 106831,
        "voice": "vo_adv_5201088_009"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我想也是啦。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "她從頭到尾都沒有現身。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "真是貫徹始終啊～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "她在七冠之中是最神祕的吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "別做多餘的探究了。",
        "unit_id": 107231,
        "voice": "vo_adv_5201088_010"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n就算不願現身，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "她也已為開發盡十二分的力。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n我們也沒必要",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "再奢求更多。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "話雖如此，",
        "unit_id": 106831,
        "voice": "vo_adv_5201088_011"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "會認為至少一起拍張合照也好，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就表示",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "算是還滿喜歡",
        "unit_id": 106831,
        "voice": "vo_adv_5201088_012"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這個開發團隊對吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "別說那麼噁心的話。",
        "unit_id": 106931,
        "voice": "vo_adv_5201088_013"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "能讓我感到背脊發涼",
        "unit_id": 107331,
        "voice": "vo_adv_5201088_014"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "算妳有本事。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼可愛的說詞很不適合妳呢。",
        "unit_id": 107031,
        "voice": "vo_adv_5201088_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……呼呼……！",
        "unit_id": 107131,
        "voice": "vo_adv_5201088_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵、",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵……！",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……你們",
        "unit_id": 106831,
        "voice": "vo_adv_5201088_017"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是不是其實很有默契啊？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "嗯，",
        "unit_id": 107231,
        "voice": "vo_adv_5201088_018"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "多虧了晶，大家似乎團結一致了。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "現在",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "就是拍照的好機會。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "OK～",
        "unit_id": 106831,
        "voice": "vo_adv_5201088_019"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n那就按下定時按鈕，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嘿。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n好啦各位，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "笑一個笑一個……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你們不可能會笑吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "七冠們",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5201088_020"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……是說，",
        "unit_id": 106831,
        "voice": "vo_adv_5201088_021"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "剛才",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是不是有陣風吹過來？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼可能有這種事。",
        "unit_id": 107031,
        "voice": "vo_adv_5201088_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這個房間的空調",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可是管理得很完美。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不可能會有風吹來的。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……可是，",
        "unit_id": 107331,
        "voice": "vo_adv_5201088_023"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我好像",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "也感覺到有某種氣息。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "教授，你也是嗎？",
        "unit_id": 107131,
        "voice": "vo_adv_5201088_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也在拍照的瞬間，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n感覺好像有什麼東西穿過我背後。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "無聊。",
        "unit_id": 106931,
        "voice": "vo_adv_5201088_025"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "要是想聊靈異故事，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "可以去其他地方聊嗎？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "我確認了一下拍好的影像資料，",
        "unit_id": 107231,
        "voice": "vo_adv_5201088_026"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "這裡似乎微微拍到了",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "一個奇怪的影子。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊，",
        "unit_id": 106831,
        "voice": "vo_adv_5201088_027"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "真的耶。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這是什麼？靈異照片？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "討厭～好不容易才拍了合照的。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……要不要",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "再拍一張？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "不，",
        "unit_id": 107231,
        "voice": "vo_adv_5201088_028"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "沒那個必要。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n或許",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "這意外地才是正確的。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……哼……",
        "unit_id": 106931,
        "voice": "vo_adv_5201088_029"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "好，",
        "unit_id": 106831,
        "voice": "vo_adv_5201088_030"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這樣也留下了不錯的紀念呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n晚點",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我把這張照片也傳給大家哦！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "七冠們",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5201088_031"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這個「不需要」的氣氛是怎樣！？",
        "unit_id": 106831,
        "voice": "vo_adv_5201088_032"
