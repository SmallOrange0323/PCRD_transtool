    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "終於都結束……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "了吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "它看起來已經不會動了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的，",
        "unit_id": 105611,
        "voice": "vo_adv_5128402_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "機關人偶真的很棘手。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n除非徹底破壞它，不然就沒完沒了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……這傢伙",
        "unit_id": 102811,
        "voice": "vo_adv_5128402_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該不會再從沙漠中復甦了吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n像是，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "突然來個古代國王的靈魂附身到人偶上……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不要說這種恐怖的事情！",
        "unit_id": 105611,
        "voice": "vo_adv_5128402_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 102811,
        "voice": "vo_adv_5128402_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "流夏妳",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會怕幽靈嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎、",
        "unit_id": 105611,
        "voice": "vo_adv_5128402_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼可能啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好了！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別廢話了，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們回去吧！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "吶吶，",
        "unit_id": 102811,
        "voice": "vo_adv_5128402_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "流夏啊！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哎呀──！",
        "unit_id": 105611,
        "voice": "vo_adv_5128402_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我聽不到啦！",
        "unit_id": 105611
    }
]