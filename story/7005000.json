[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這就是露娜之塔……",
        "unit_id": 100311,
        "voice": "vo_adv_7005000_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好大的建築物呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果攻下這裡的話，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說不定你的記憶就能恢復呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了，",
        "unit_id": 100311,
        "voice": "vo_adv_7005000_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從剛剛開始就感覺到有人在監視著。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n可能是敵人，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不要大意喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "已經知道你在那裡了！",
        "unit_id": 100311,
        "voice": "vo_adv_7005000_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n別再躲著，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不如直接現身吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……啊，",
        "unit_id": 105411,
        "voice": "vo_adv_7005000_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "果然被發現了呀……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希！？　",
        "unit_id": 100311,
        "voice": "vo_adv_7005000_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳為什麼會在這裡？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要說為什麼，",
        "unit_id": 105411,
        "voice": "vo_adv_7005000_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為騎士先生跟怜一起走來，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n所以我也跟過來了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的……",
        "unit_id": 105411,
        "voice": "vo_adv_7005000_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "趁我不在竟然對怜放電，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還真是一如往常地不像話呢，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "放、",
        "unit_id": 100311,
        "voice": "vo_adv_7005000_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "放電！？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他才沒做這種事呢！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會到這裡",
        "unit_id": 100311,
        "voice": "vo_adv_7005000_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是為了要讓他恢復記憶。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那我也可以跟著你們嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_7005000_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為了不讓怜發生意外",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "由我來負責擔任護衛吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生。",
        "unit_id": 105411,
        "voice": "vo_adv_7005000_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為了避免你對怜做壞事，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我會好好監視你的，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n請做好覺悟吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不過嘛，",
        "unit_id": 105411,
        "voice": "vo_adv_7005000_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "稍——微幫忙",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "讓騎士先生的記憶回復這件事",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我也是可以勉強答應的唷。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有紡希在，",
        "unit_id": 100311,
        "voice": "vo_adv_7005000_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們就能安心進攻了吧……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n一定會恢復你的記憶，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "加油吧！",
        "unit_id": 100311
    }
]