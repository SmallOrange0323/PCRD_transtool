[
    {
        "type": "dialogue",
        "name": "碧",
        "words": "玩、",
        "unit_id": 116713,
        "voice": "vo_adv_5068301_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "玩具王……",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請聽我們說話！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n現在的你",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "誤會了跟小孩子的友情……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "閉嘴閉嘴閉嘴！",
        "unit_id": 14912,
        "voice": "vo_adv_5068301_001"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "我是小孩子的朋友！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n無論今天、明天，還是後天，",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "我都要一直玩下去！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "照那個樣子看來，",
        "unit_id": 116911,
        "voice": "vo_adv_5068301_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "它並沒有把我們的話聽進去……",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "再爭論下去太沒有效率了。",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "很遺憾的，",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們似乎只能戰鬥了……！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要跟那麼巨大的對象戰鬥嗎！？",
        "unit_id": 116713,
        "voice": "vo_adv_5068301_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們會被踩扁的喔〜！？",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "妳冷靜點，",
        "unit_id": 7311,
        "voice": "vo_adv_5068301_004"
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "碧。",
        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "\n只要同心協力，",
        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "我們沒有辦不到的事情。",
        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說、",
        "unit_id": 116713,
        "voice": "vo_adv_5068301_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說得也是……",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "無敵好朋友號！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為了說服玩具王，",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我會試著努力看看……！",
        "unit_id": 116713
    }
]