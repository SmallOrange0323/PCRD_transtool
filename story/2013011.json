        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "竟然還有能夠顧及週遭的餘力呀。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n這不是挺從容的嘛。",
