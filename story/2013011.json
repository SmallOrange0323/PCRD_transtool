        "voice": "vo_adv_2013011_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呣嗚……！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳瞧，",
        "unit_id": 106914,
        "voice": "vo_adv_2013011_003"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就說了再把精力分一點去防禦吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "吸血鬼。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "難不成妳就只擅長攻擊嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n真是如同外貌一般的半吊子呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我這兒",
        "unit_id": 106914,
        "voice": "vo_adv_2013011_004"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "可也是得平衡時間和魔力之間的收支呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n若妳比我預期的還要輕易地就倒下了，",
        "unit_id": 106914
    },
