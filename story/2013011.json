        "voice": "vo_adv_2013011_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟我可是公主殿下呀！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "先說好了，",
        "unit_id": 105811,
        "voice": "vo_adv_2013011_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正趕來這的可不是只有我一個人而已唷！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在察覺到這裡有誰在搗亂後，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n拉基拉基就利用了空間跳躍把我們送到這裡來了！",
        "unit_id": 105811
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "是的。",
        "unit_id": 107311,
        "voice": "vo_adv_2013011_032"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "儘管空間跳躍",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "在人數上有著限制，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "因此無法將全員送至這來。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n但其他人也是正在急速朝著這前來的途中，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n我想不用多久即可到達了吧。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "你終究是寡不敵眾。",
        "unit_id": 107311,
        "voice": "vo_adv_2013011_033"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n放棄",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "並且投降可就是幫大忙了。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你這番話是認真的？",
        "unit_id": 106914,
        "voice": "vo_adv_2013011_034"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你果真是變了呢，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "拉基尼卡東……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n明明以前的你可是個戰鬥天才，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並且鬥爭心相當旺盛的呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒事。",
        "unit_id": 106914,
        "voice": "vo_adv_2013011_035"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "一個沒了『皇家裝備』就手無縛雞之力的花瓶公主，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n加上窮途末路又淒涼的『七冠』一夥……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳又說說",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還有誰準備趕來這兒的呀？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "能夠將此狀況徹底顛覆的存在，",
        "unit_id": 106914,
        "voice": "vo_adv_2013011_036"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我可是完全想不到呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "和強硬地收集生命力而復活的我不同，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n晶至今",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "大概也還在昏睡狀態才對。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哼哼♪　",
        "unit_id": 105811,
        "voice": "vo_adv_2013011_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那當然是，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們最可靠的救世主！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}唷！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊哈。",
        "unit_id": 106914,
        "voice": "vo_adv_2013011_038"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還真是勇氣可佳呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n至少讓我給你點掌聲吧，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "果然你才是故事的主角呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵。",
        "unit_id": 106914,
        "voice": "vo_adv_2013011_039"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你就是救世主唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是可憐呢……",
