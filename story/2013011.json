        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n那豈不就像是我白費了魔力一樣嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "對吧？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咕……",
        "unit_id": 104411,
        "voice": "vo_adv_2013011_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咕、啊啊啊啊――！！",
        "unit_id": 104411
    },
