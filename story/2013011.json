        "voice": "vo_adv_2013011_048"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n也好，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "做為黃泉路上的餞別禮我就說給妳聽吧。",
