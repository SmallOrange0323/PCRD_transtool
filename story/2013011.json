    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哎呀，",
        "unit_id": 106914,
        "voice": "vo_adv_2013011_029"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "公主殿下。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳來得真不巧……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不對，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "該說不會看氣氛嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯！",
