    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "拚了老命喊得那麼大聲，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n放的魔法卻只是為了爭取點時間阻擋我。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "希望妳能再表現得更好些呢，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不然可讓我連吞噬妳的慾望都沒了啊。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗚咕……",
