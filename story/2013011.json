        "words": "太好了呀……",
        "unit_id": 100711,
        "voice": "vo_adv_2013011_045"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "差點以為自己要消失了，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好害怕來的……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你對這孩子做了什麼事啊，",
        "unit_id": 105811,
        "voice": "vo_adv_2013011_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "霸瞳皇帝？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吸取了她的生命力……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛剛才聽別人說過。",
        "unit_id": 105811,
        "voice": "vo_adv_2013011_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你利用了那個洗腦魔法裝置，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也同樣對似似花做了一樣吸取生命力的事情呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你到底是為了什麼？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……呵呵。",
