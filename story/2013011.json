    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊啊，",
        "unit_id": 106914,
        "voice": "vo_adv_2013011_049"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我還真是名副其實的反派呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "要是慢慢講的話，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳的朋友們就會一窩蜂趕到這兒了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "{player}你就是這樣的人嘛。",
        "unit_id": 106914,
        "voice": "vo_adv_2013011_050"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n受人愛戴著，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "又能將人們聚集起來。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "畢竟你可是",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "故事核心的主角嘛……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "然後我會將聚集於此處的人們全部，",
        "unit_id": 106914,
        "voice": "vo_adv_2013011_051"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在生吞活剝後吸收下肚。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不用特別親自跑去店裡，",
        "unit_id": 106914,
        "voice": "vo_adv_2013011_052"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就有外賣會自動送到面前的話，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我可是求之不得呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就當作報酬，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "讓我稍稍替你們消解一些疑惑吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你還真是一派輕鬆呢。",
        "unit_id": 105811,
        "voice": "vo_adv_2013011_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果我們的同伴聚集起來的話，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像你這種傢伙根本秒殺唷。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳真這麼想？　",
        "unit_id": 106914,
        "voice": "vo_adv_2013011_054"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過嘛也好，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳們就聽聽看嘛……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n當妳們知道真相後，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那絕望且震懾不已的神情我也想見見呢。",
        "unit_id": 106914
    }
