[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與千歌，\n一如往常在進行唱歌練習時……"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}，覺得如何呢？",
        "unit_id": 104211,
        "voice": "vo_adv_1042004_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我認為我剛剛唱得非常棒……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}……？\n",
        "unit_id": 104211,
        "voice": "vo_adv_1042004_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……你睡著了嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵，",
        "unit_id": 104211,
        "voice": "vo_adv_1042004_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "看這一副睡得香甜的睡臉。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "把他叫醒也不太好，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就這樣吧──",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦！？",
        "unit_id": 104211,
        "voice": "vo_adv_1042004_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "什、什麼、這個光……！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然很刺眼……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但有種懷念的感覺……",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "510200"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "──那個，不好意思……",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n不曉得有沒有樂譜被風吹飛到這裡來了呢？",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "剛剛我的樂譜被風給吹走了……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對，就是這個！你幫我都撿起來了嗎？",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……好厲害。全部都收齊了。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你。真是幫了大忙！",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果可以的話，請讓我做點什麼回禮。",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你是說唱這個樂譜上的歌……嗎？",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我還在練習唱這首歌……",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在也正在練習中。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且……",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要在人前唱歌我會覺得很害羞……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你說當作是在人前唱歌的練習嗎？",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……的確，若在很多人面前的話我會緊張，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是只在一個人面前的話，只要習慣了就好……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是，那樣就不能算是回禮了喔？",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "反而變成是陪我練習……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你不在意嗎？",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵，你真是個溫柔的人呢。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n那麼，就麻煩你囉。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……那、那我開始唱囉。",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……唔， ",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真的要開始唱的時候，我果然還是會緊張。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請、請你不要這麼期待。",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這樣反而會讓我唱不好……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，這也算是練習吧……",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我不加油不行呢。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你說你是南瓜嗎？\n……",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "原來如此。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只要我不去想正在被別人看著的話，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n搞不好就能唱歌了。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……我知道了！",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我試看看。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……嗯。我現在唱歌的狀況不錯呢。",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個人也感覺很開心的在聽著……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是怎麼一回事呢……在別人面前唱歌時，",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "平常的話都會很緊張然後完全唱不好……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是不可思議……因為是在這個人面前唱的關係……？",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "………………",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個……",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你、你覺得如何呢……？",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……我唱的歌很無聊吧。",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n你不會覺得想睡覺嗎……？",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你……！",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "被你誇獎歌聲，讓我非常地高興！",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……如果可以的話，請你要再來聽我唱歌喔。",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我叫做三角千歌。你能告訴我……你的名字嗎？",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}……\n今天真的很謝謝你。 那麼，我們下次再見……",
        "unit_id": 104231,
        "voice": "vo_adv_1042004_027"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1042004_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1042004_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說你……難得千歌唱歌給你聽，",
        "unit_id": 190011,
        "voice": "vo_adv_1042004_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你竟然睡著了，是怎麼回事啊？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，這也是因為那是首令人想進入夢鄉的好歌的緣故啊。",
        "unit_id": 190011,
        "voice": "vo_adv_1042004_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n歌曲可是有療癒……或者應該說是有安眠效果嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "千歌也是，她唱歌這麼好聽，",
        "unit_id": 190011,
        "voice": "vo_adv_1042004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果能再更積極地唱就好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在大家面前唱歌會感到害羞什麼的，不就太暴殄天物了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過話說回來在「這邊」可能比起在「那邊」的時候稍微積極點了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1042004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也當了偶像，似乎想讓各式各樣的人可以聽她到唱歌的樣子。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對千歌來說，",
        "unit_id": 190011,
        "voice": "vo_adv_1042004_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n或許出現了好的方面的影響呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，不過在這裡說著長篇大論也沒用呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1042004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次就先這樣吧。再見囉～ ♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯嗯……",
        "unit_id": 104211,
        "voice": "vo_adv_1042004_036"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦……？這裡是……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……我什麼時候睡著了呢？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}，早安。",
        "unit_id": 104211,
        "voice": "vo_adv_1042004_037"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦，你說什麼唱歌的回禮。",
        "unit_id": 104211,
        "voice": "vo_adv_1042004_038"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個可是我作為回禮而唱的……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦！？",
        "unit_id": 104211,
        "voice": "vo_adv_1042004_039"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為什麼{player}會知道夢的事情？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n該不會我們作了相同的夢吧……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是不可思議的事情呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……即使在夢裡，我也被你誇獎歌聲了，真令人高興。",
        "unit_id": 104211,
        "voice": "vo_adv_1042004_040"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n謝謝你。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果是那首歌的話我記得很清楚，",
        "unit_id": 104211,
        "voice": "vo_adv_1042004_041"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以如果你還想聽，請記得跟我說喔。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
