[
    {
        "type": "background",
        "background": "501070"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……呼。",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n結果",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "最後還是沒有辦法說服咲戀回來……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但那也是沒辦法的嘛！純小姐！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且今天主要的目的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只是想把禮物交給她而已。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "說得也是。",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n打從一開始，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就明白要說服她並不是件易事了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……可是……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……是的。",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n關於對【憤怒‧軍團】的對抗手段，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們又得從頭再考慮過了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是啊。",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這座城相當的寬廣……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就算加上了咲戀她的回歸，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n要能夠在敵人開始行動時及時反應，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "再怎麼說也是不太可能。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過嘛，",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要他們引起了騷動後，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們或是【破曉之星】的大家，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就會咻～地趕過去，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後咚～地把他們都解決掉了嘛！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……呃，",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……純小姐，",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳不會和豪紳先生一樣說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『陛下請您乖乖待在王座上～！』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像那樣子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要求我留下來嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……若【王宮騎士團】已準備萬全，",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "並且確保不論\n發生任何的恐怖攻擊都能進行妥善的應對時……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我想我",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "一定也會\n那麼說的吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "畢竟保護您的人身安全，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也是我重要的職責。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "然而現狀來看，",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "完全無法能夠稱上是萬全。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n畢竟先前那名叫做卡里莎的少年，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不但入侵了王宮的地下，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n甚至還放出了魔物。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "既然如此……",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "故意讓陛下親自踏上戰場。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不僅能鼓舞士兵的士氣，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也能除去市民的不安，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "算得上是相當有效的手段。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……這是我個人的想法。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯～☆",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對嘛！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我當然也是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有著一樣的想法喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……陛下。",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n儘管說是有效的手段，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但還請您別忘記這只是非常時期的計謀。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n以我的立場，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "倘若辦得到，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "自然想要策畫出更周詳的作戰。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……妳說的",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也對……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而且。",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這儘管",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可能是我的杞人憂天也說不定……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "？",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "城內的氣氛，",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這一陣子……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "似乎有些不穩定。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n從人們的口中，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "一些奇怪的傳聞口耳相傳的情況也增加了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳說傳聞嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n譬如說",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是怎樣的？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是呢。",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n『我這就去從索爾之塔上跳下來。』什麼的……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n『在死後，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還有真正的世界等著我們。』",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "之類的傳聞。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "——『真正的世界』……？　",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "儘管不論是何者，",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "都只是無須認真看待的傳聞而已也說不定。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n然而，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "卻不禁使人有所疑慮。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n簡直像是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "被遺忘了的舊傷，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "又在隱隱作痛了一般……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……純小姐，",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳認為那個傳聞，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是有誰抱著惡意散布出去的……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳是這個意思嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……是的。",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n像是有人在城中，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有意無意地將惡意蔓延開來一樣……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不禁令人有這樣的感覺。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "究竟是【憤怒‧軍團】的那群人？",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n亦或是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "其他何人的行為？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "目前還無法確定便是……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……非常謝謝妳，",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "純小姐。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這件事我會放在心上的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "麻煩您了。",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我就先行告退……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "——啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "純小姐。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n關於",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳剛剛說的那個傳聞呀。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是。",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……那個。",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n關於『真正的世界』……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "純小姐，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳認為真的有嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……我是將身心",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "獻給陛下與蘭德索爾之人。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n光是守護必須守護之物，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就得用盡全力了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n實在沒有多餘的心思去考慮",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "死後之事。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 105812,
        "voice": "vo_adv_2103003_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……然而。",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若要坦言……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我心中確實有一部分，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "被那個傳聞所吸引住了的感覺。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n並且也同時……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "感到了……",
        "unit_id": 104711,
        "voice": "vo_adv_2103003_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "心中揚起一股非常不安的波瀾。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就像腳下",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "突然開了一個空洞一般——……",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "501040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——距離蘭德索爾相當遙遠的某堡壘內——"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "……",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_035"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "啊呣。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "………………",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "……嗯，",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_036"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "這味道的確相當不容易。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n看來我的隨從們",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "手藝又提升了不少呢。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "～……",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_037"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "哦呀？　",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_038"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "卡里莎。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "你的手似乎停下來了的樣子呢……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n帕拉斯高原產的小牛排",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "難道不合你的胃口嗎？",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "儘管和龍肉排相比還相差甚遠，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "這仍舊是極上的一品唷？",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "煩死了！",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_039"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我只是已經吃飽了而已啦！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "從剛剛開始有什麼壽司、壽喜燒，還有什麼龍蝦，",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_040"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n還不是你讓我吃了這麼多的關係！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……唔噗……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "呵、呵、呵。",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_041"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "明明年紀還輕，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "食量卻真是小呢。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "聽好囉，卡里莎。",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_042"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n好好吃飯、",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "好好運動、",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "好好睡覺。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "如此一來，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "你就能像我或贊恩一樣",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "能夠長得那麼強壯了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "什麼鬼話！",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_043"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n先不說贊恩，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我才不想變得像你這樣一副肥豬樣啦。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……話又說回來。",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_044"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你也差不多該給我進入正題了吧，阿澤爾德。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n今天幹嘛特地把我叫來這？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "呵、呵。",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_045"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n既然你這麼說了……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "今天……",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_046"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "竟然！",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我成功入手了弗麗嘉北海所打撈上岸的皇家螃蟹！",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n這才正是",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我為今日所準備的正餐……！",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我才不是在問你吃的正題啦！",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_047"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我是在問你到底有什麼話要講啦！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "話又說回來你還想吃嗎！？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "那是當然。",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_048"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n畢竟我",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "現在大約才六分飽而已。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "然而——",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "若卡里莎你",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_049"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "這麼想要聽我要和你說的事情，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n那麼也別無他法。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "就把時程的先後調整一下吧。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "……儘管這是很少被打撈上岸的",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "最高級螃蟹……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……真是的。",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_050"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n說有話要說的不也是你嗎。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "總之，",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_051"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "也不是什麼難事。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n——我想差不多，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "也是卡里莎你",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n想要再次前往蘭德索爾的時候了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……嗯。",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_052"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n雖然之前去打探時",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "有些失手，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "但這次我不會再輕易放過她們。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "這一次，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我一定會把她們都揍得屁滾尿流的……！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "嗯嗯。",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_053"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n既然你有再次挑戰的想法……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "那就表示你準備好策略了？",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "廢話。",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_054"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n……簡單啦。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n說到頭來，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "那些傢伙的關鍵——",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "慢著！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "醜話先說在前頭，",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_055"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "再往後的事情可是祕密啊。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n可不是你請這頓飯我就會告訴你的事啊？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "無妨無妨。",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_056"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n只要聽到你並非毫無對策就打算再戰，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我便安心了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哼。",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_057"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n該不會",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "「分我一口」什麼的，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "或「讓我跟你一起去戰鬥吧～」",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你是打算想跟我說這些話吧？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "不不，",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_058"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "如此厚臉皮之事我豈敢和你提呢。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "光憑這個我，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "要站在輕盈的卡里莎你的身邊就是件難事了吧。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……嘛，",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_059"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "看起來你也不像是會藏一手的人嘛……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我想要和你說的，",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_060"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "只是想要給你一點小小的幫助而已。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n可以說是後方支援的意思。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你說支援？",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_061"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哼，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "別小看我了。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我又不是什麼小鬼。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "才不需要什麼保母跟在後面。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "是、",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_062"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "是。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "那是當然。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n保母什麼的當然不需要——",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "然而卡里莎這一般的年紀，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n為了達成目的自然會挑選出最佳的方法吧。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_063"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "對手手中握有的王牌似乎連蘭法小姐都能擊退的樣子。",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_064"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "因此我認為，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我們手牌勢必越多越好。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "而且……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "先不論卡里莎你本身。",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_065"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n你所支配的魔獸們，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n上次被打倒時所留下的傷口",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "也尚未痊癒才對吧？",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "咕喔喔……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……嘖。",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_066"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我所擅長的鍊金術，",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_067"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "也能應用上治癒魔法。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n只要讓我留在後方，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "總還是會有派得上用場的時候喔。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "…………",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_068"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "你的意下如何呢？",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_069"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……就一件事，",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_070"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "先告訴你。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n那個蘭德索爾的白痴王女，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n好像和『變貌大妃』那個蘿莉老太婆",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "有什麼接觸的管道。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "哦？",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_071"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "上次和她們戰鬥時，",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_072"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "有聽到她講了類似的話。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "不知道是在當她的替身，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "還是說在管理關著霸瞳皇帝的牢房之類的……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我猜大概就是那樣吧？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "哦哦哦。",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_073"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n如此貴重的情報，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我就感謝地收下了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哼。",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_074"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n老實講本來我打算自己去把『變貌大妃』給抓起來的……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "但我才不想欠誰人情——。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "不管是你還是誰都一樣。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "真不愧是卡里莎。",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_075"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "真是妥當的判斷呢。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "不論過程和怎樣的手段，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "只捕捉必要數量的『七冠』……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n並且實現我等全員的願望，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "這便是最重要之事了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "嘖。",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_076"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n如果你要跟著我來的話，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "可別扯我後腿啊？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n而且如果你那邊搞砸了，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我可是不會去救你啊。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "呵、呵。",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_077"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n這倒不用你費心。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "話說回來——",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "卡里莎。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "這邊最後還有件事情想問你。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "啊？",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_078"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你剛剛不是說只問一件事嗎？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "這件事相當的重要。",
        "unit_id": 191911,
        "voice": "vo_adv_2103003_079"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "……點心，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "你想吃什麼呢？",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我才不要啦！",
        "unit_id": 191611,
        "voice": "vo_adv_2103003_080"
    }
]