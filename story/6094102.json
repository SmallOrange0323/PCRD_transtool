    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "果然是這樣～",
        "unit_id": 122211,
        "voice": "vo_adv_6094102_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喝麥酒怎麼能沒有下酒菜呢～？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n可是，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這樣就必須要去張羅食材了……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n嗯……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "再讓我喝一下，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
