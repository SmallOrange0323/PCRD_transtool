        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我也許已經",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "醉得不輕了吧……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……嗯，",
        "unit_id": 122211,
        "voice": "vo_adv_6094102_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "他或許會那麼說。",
        "unit_id": 122211
