[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，千歌為了避人耳目而來到了森林深處。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只要來到這附近的話，應該就不會有其他人在了吧……",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒想到我竟然變成要跟望一起以偶像的身分唱歌。",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過雖然說是偶像，唱歌還是唱歌……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "得多加練習讓自己能好好唱才行……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要我像偶像一樣歌唱嗎……",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "光是在腦中空想，也不會有任何改變。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n總之我先唱個幾遍，再來調整狀態吧……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "～～♪",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……嗯。我覺得好多了。",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就以這個狀態持續練習――",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為什麼魔物會……！",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是我太靠近牠的地盤了嗎……！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n牠往這裡來了……！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "既然如此，",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我只好獨自應戰……！",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你是……！？",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你的幫忙！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你光是防禦就已經使盡全力了……？",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我知道了。請你就這樣持續防禦魔物的攻擊。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我也……",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "參與戰鬥！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "風之精靈啊……",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不好意思。可是我為了戰鬥，唱歌是必要的。",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你再稍微忍耐一下。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦！？",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝、謝謝你！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不好意思，我一時慌了手腳。",
        "unit_id": 104211
    },
    {
        "type": "still",
        "still": "104200101"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我再重來一次……",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "風之精靈啊……將擋在我們面前的敵人，",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n徹底擊敗吧……！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "精靈",
        "words": "──！"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "太好了……總算是打敗牠們了呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓你嚇到了……",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "其實我是",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唱喚士……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可以透過唱歌來唱喚精靈。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "多虧你幫我壓制住魔物，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我才能集中精神唱歌。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝、謝謝你……",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……不好意思，因為很少被人誇獎過我唱歌，",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以我不知道",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "該怎麼做才好……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你。",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我能參與戰鬥，也是多虧了這個能力。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只是，",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我為了要唱喚精靈就必須要唱歌，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以必須要有人能跟我一起戰鬥。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你剛才真是幫了大忙。",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我在尋找沒有人煙的場所的時候，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n好像就來到了森林深處……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……其實，我正跟公會的夥伴一起從事偶像活動。",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只是，我沒有什麼自信能以偶像的身份唱歌……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以我才想說要多加練習。",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這裡的話就不太會有人經過，我也能集中精神……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是，只有我自己一個人來的話果然還是很危險吧？",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n只能放棄練習了……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你要陪我一起來這裡練習嗎？",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "的確要是有人陪在我身邊的話，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我想就算有魔物來也沒問題……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是，這樣不會造成你的困擾嗎？",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……你真是個溫柔的人呢。",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然今天發生了麻煩事，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是能遇見你，真是太好了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這麼說來，我還沒有報上姓名。",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我叫做千歌。你是……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}啊……\n今後就請你多多指教囉。",
        "unit_id": 104211,
        "voice": "vo_adv_1042001_029"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從這天開始，{player}便與千歌，\n開始進行兩人專屬的祕密訓練。"
    }
]