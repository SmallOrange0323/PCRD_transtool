        "voice": "vo_adv_2013010_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "　",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你這傢伙，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "豈能讓你把這總有一日會納入妾身支配之下的世界",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "破壞得一團亂！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦哦哦哦！　",
        "unit_id": 104411,
        "voice": "vo_adv_2013010_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身乃不死之身的吸血鬼，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n可別以為這種程度的魔法",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就能夠要了妾身的命啊！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嘎啊啊啊！？",
        "unit_id": 102211,
        "voice": "vo_adv_2013010_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸？　",
        "unit_id": 100611,
        "voice": "vo_adv_2013010_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "明明伊莉亞就把魔法的軌道偏移，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n所以避開了直擊……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但就是震波引發的暴風也還有這種威力嗎！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呼、",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呼……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……總、",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總算是熬過來了嗎。",
        "unit_id": 104412
