        "voice": "vo_adv_2013010_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "身為幽靈的存在啊。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可是。",
        "unit_id": 103111,
        "voice": "vo_adv_2013010_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "她可是我們重要的夥伴，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "絕對要拯救她。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n還不想",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "和她分別呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "伊莉亞！　",
        "unit_id": 103111,
        "voice": "vo_adv_2013010_025"
    },
