        "type": "dialogue",
        "name": "忍",
        "words": "依里和茜里，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳們還可以動嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "此敵人是非常危險的存在，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "應當避於此戰……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還是撤退為先吧！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯、",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這麼做似乎較合常理呢，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n和如此狂徒交手可是絲毫",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒有好處的呀！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "瞭、",
        "unit_id": 102211,
        "voice": "vo_adv_2013010_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "瞭解！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "站得起來嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒、",
        "unit_id": 100611,
        "voice": "vo_adv_2013010_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒問題……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗚嗚，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "撞到頭了所以好暈呀。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……真傻呢。",
        "unit_id": 106914,
        "voice": "vo_adv_2013010_029"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳們以為妳們逃得掉？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可惡呀……！",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_030"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "別笑掉我的大牙了。",
        "unit_id": 106914,
        "voice": "vo_adv_2013010_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n光憑這種程度的力量，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就連我的一根寒毛都傷不著唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要拖延住你已經綽綽有餘了！",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_032"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "趁現在呀，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "趁著妾身把這傢伙拖住之際，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們趕緊逃呀！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若不讓誰來殿後，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "根本不可能逃出這傢伙的手掌心！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可、",
        "unit_id": 102211,
        "voice": "vo_adv_2013010_033"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可是",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們也不能丟下伊莉亞不管呀！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒事……",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_034"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n心地善良的孩子們唷，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這種事情本來就是年長者的責任呀。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "謝謝妳們呀。",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_035"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "從被妳們幾個找到，",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_036"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "從被那床頭上拉了下來之後……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "儘管一開始經常被妳們鬧得頭疼，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但在之後的每一天，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可都是過得相當有意義又愉悅的呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "於妾身如此漫長的人生之中，",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_037"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這可是一段",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "最輝煌璀璨的日子了呀。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過。",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_038"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "天下無不散的筵席，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "儘管可惜但也得在此分別啦。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妳們得平安地存活下去，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "然後，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "將妾身的故事",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "向妳們的子子孫孫傳頌下去。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "將那統御著黑夜的",
        "unit_id": 104411,
        "voice": "vo_adv_2013010_039"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吸血鬼",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "伊莉亞‧奧恩斯坦……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這最珍貴的物語，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "永遠銘記於世人的心中。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哎呀，",
        "unit_id": 106914,
        "voice": "vo_adv_2013010_040"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳還真的不要命了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真煩人呢，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "看來是得要費點勁了。",
        "unit_id": 106914
    }
