        "voice": "vo_adv_2013010_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "伊莉亞變回來了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "僅僅一發，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只為了將敵人攻擊偏移而已，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就將魔力消耗殆盡了呀……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "果然",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如果不讓{player}他來進行強化，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n儘管能變回原本的樣貌",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也無法長時間維持呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……！　",
        "unit_id": 102211,
        "voice": "vo_adv_2013010_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "吶，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那傢伙呢？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n那個飄在空中的怪人，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "消失不見了唷！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳說什麼……？",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不好，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因為暴風與塵埃的緣故不見蹤影了！",
        "unit_id": 104412
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咕嗚嗚！　",
        "unit_id": 104412,
        "voice": "vo_adv_2013010_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你究竟是",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什麼人！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n若再如此",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為非作歹可饒不了你呀！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哎呀，",
        "unit_id": 106914,
        "voice": "vo_adv_2013010_013"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "饒不了我？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那也無妨唷，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "有意見的話就儘管衝著我來吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這場遊戲，",
        "unit_id": 106914,
        "voice": "vo_adv_2013010_014"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "可是為了爭奪實現願望的權利而存在的唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n也就是弱肉強食呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若是有想要擁有的東西，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n除了像我一樣地",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "從他人那裡奪取之外別無他法囉。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而妳們，",
        "unit_id": 106914,
        "voice": "vo_adv_2013010_015"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過就只是遺忘了自身最原本的願望……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n只顧著增進情感，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "然後沉溺在那溫吞的日常之中罷了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳們覺得如此的妳們",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "與我，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "究竟又是哪一邊才符合這個世界的正義呢？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是我唷。",
        "unit_id": 106914,
        "voice": "vo_adv_2013010_016"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n也正因如此，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不論這個世界的神",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "再怎麼祈求，也阻止不了我。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就算我是即將把妳們重要的夥伴一個個消滅的",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "極惡之人也一樣唷？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……！",
        "unit_id": 103111,
        "voice": "vo_adv_2013010_017"
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊。",
        "unit_id": 106914,
        "voice": "vo_adv_2013010_018"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這可還真是過份呢，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我還以為手臂要斷成兩半了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不行呀，",
        "unit_id": 106914,
        "voice": "vo_adv_2013010_019"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我竟然反應不過來……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n真是的，",
        "unit_id": 106914
    },
