    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "很從容呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n……看妳似乎挺不滿足的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那我就再增強些魔法的威力吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咕啊……！",
