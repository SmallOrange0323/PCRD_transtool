    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "換句話說",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就是宮子的存在本身，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n似乎被大量的吸收走了。",
