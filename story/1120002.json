[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "賀年卡的配送工作結束後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n平分完酬勞的凱留與{player}兩人\n在人聲鼎沸的蘭德索爾街上閒晃。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉～",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原本是想在新年好好放鬆的，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n結果卻變得這麼忙碌。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對不起？　",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你不需要",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為了這個道歉吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是我自己要幫忙的，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "況且我也分到酬勞了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "玩？　",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "工作完都這麼累了，為什麼還要……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，好吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正也賺到錢了，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就去玩一下吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "要不要來玩幸運抽獎",
        "unit_id": 311,
        "voice": "vo_adv_1120002_003"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "試試新年的手氣呀～！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n有很多很棒的獎品喔～！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這麼說來，",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "買魔導書的時候",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有拿到抽獎券呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n反正也不會中，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就去抽抽看吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "中大獎了～！",
        "unit_id": 311,
        "voice": "vo_adv_1120002_005"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n是特獎！　",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "真厲害呢，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "小姐！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的嗎！？",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太好了！　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "特獎是什麼呢！？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難、",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次終於能夠前往真正迷人的南國……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "美味年糕，",
        "unit_id": 311,
        "voice": "vo_adv_1120002_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "三個月份！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這是使用了最高級糯米，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "並由專業師傅所精心製作的夢幻逸品喔！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……真微妙。",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該說，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拿到多達三個月份的年糕是能幹嘛啊？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果是貪吃佩可應該會高興到哭吧。",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這麼一想，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還真是不錯的獎品呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼我非得先想到那傢伙不可啊！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這是我抽到的獎品耶！？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒、",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒什麼啦！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "比起這個，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是趕快去領獎品吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "年糕",
        "unit_id": 311,
        "voice": "vo_adv_1120002_012"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "日後會再寄送過去的，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "請好好期待喔！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我會期待的。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n…………",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "年糕要花幾天才消得完呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "獎品雖然是年糕，",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但特獎就是特獎對吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "新年才剛開始運氣就很不錯呢！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "新年限定福袋！　",
        "unit_id": 1411,
        "voice": "vo_adv_1120002_015"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "剩最後一袋囉～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "內容物",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "要打開後才見分曉～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n剩餘的東西",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "是很有福氣的喔～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你聽到了嗎！？　",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他說是最後一袋耶！　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那不就只能買下來了嗎！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總覺得如果是現在的我們，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一定可以得到很棒的東西呢！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n走吧！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吶，",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個福袋",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我買了！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "多謝惠顧！",
        "unit_id": 1411,
        "voice": "vo_adv_1120002_018"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "呃，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "哎呀。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼了？",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n快點給我吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我也",
        "unit_id": 211,
        "voice": "vo_adv_1120002_020"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "想要",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "那個……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼啊，",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算妳是小孩子我也不會讓給妳的喔！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n畢竟是我先來的。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要是對妳太好，妳就無法成為正經的大人了！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "…………",
        "unit_id": 211,
        "voice": "vo_adv_1120002_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道啦！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她一定",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是握著壓歲錢過來的吧……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看就知道了啦！",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要讓她學會哭是不能解決問題的才行……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～！　",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我知道了啦！　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個福袋讓給妳！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n收下來吧！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "可以嗎……？",
        "unit_id": 211,
        "voice": "vo_adv_1120002_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以啦。",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_027"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "謝謝！",
        "unit_id": 211,
        "voice": "vo_adv_1120002_028"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n大姐姐！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "那麼，",
        "unit_id": 1411,
        "voice": "vo_adv_1120002_029"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "給妳。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n這是最後的",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "福袋喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "謝謝！",
        "unit_id": 211,
        "voice": "vo_adv_1120002_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那、",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個啊？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我都讓給妳了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "至少可以讓我看一下",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "裡面的東西吧？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "當然！",
        "unit_id": 211,
        "voice": "vo_adv_1120002_032"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n一起打開吧！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "一～二！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………這是",
        "unit_id": 112011,
        "voice": "vo_adv_1120002_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼東西啊。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "女子",
