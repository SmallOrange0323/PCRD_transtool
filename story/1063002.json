    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和亞里莎因為送信的打工，\n而來到了精靈之森。"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "呼！",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_000"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n這樣就大約完成一半了呢！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……耶嘿嘿。",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_001"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n真的很你謝謝呢。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n我完全",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "忘了還有錢的問題要顧……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "有請你介紹工作真是太好了！",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_002"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "除了能活動身體很開心以外，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n說不定也有機會因此找到蘿莎麗亞！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……沒有。　",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_003"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n目前什麼都還沒……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n畢竟，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "蘭德索爾很寬廣呢……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我有試著向各式各樣的人詢問等等，",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_004"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n卻還是沒有什麼線索……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "不過，沒問題的！",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_005"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n總有一天一定會找到的！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n……絕對，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "會找到！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "在那之前我打算像這樣，",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_006"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n一邊和你一起工作，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n一邊在蘭德索爾生活看看！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……耶嘿嘿，",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_007"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "謝謝。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n有{player}在的話，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n真的很令人放心呢。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "真、",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_008"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "真的嗎！？",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "如果你願意幫我，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n我會非常開心的……！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "好──！",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_009"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n多虧了{player}，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我打起精神了！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n剩下的部分也加油吧！",
        "unit_id": 106311
    },
    {
        "type": "background",
        "background": "500191"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "這些應該就是全部……",
