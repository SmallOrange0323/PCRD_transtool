        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……呵呵，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "也許和這裡有點像。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……我呢，",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_016"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "最喜歡村子了。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n無論是風還是水還是綠意，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "都最喜歡了。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n所以……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "所以……",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_017"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我和蘿莎麗亞約好了。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n要一起當上森林守衛。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "森林守衛呢，",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_018"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "要從邪惡事物的手中保護村裡的人還有大自然！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n是非常重要的職責哦。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……結果蘿莎麗亞卻不見了。",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_019"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n雖然我一個人，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n也可以接受",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "成為森林守衛的測驗……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "但是，",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_020"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我不想要那樣。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "因為",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我和蘿莎麗亞約好要一起的。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……耶嘿嘿。",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_021"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n開玩笑的，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我現在還不夠厲害呢。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
