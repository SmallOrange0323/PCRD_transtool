        "voice": "vo_adv_1063002_010"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "了吧。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "{player}，謝謝你！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n辛苦了！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……呼。",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_011"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n流汗之後，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "吹著風很舒服呢。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n感覺",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "很涼快。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_012"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……啊，",
