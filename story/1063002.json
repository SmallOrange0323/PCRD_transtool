    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "抱歉喔？",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n我剛剛想起了在村子的事。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "和蘭德索爾相比，",
        "unit_id": 106311,
        "voice": "vo_adv_1063002_014"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n雖然是非常小的村子……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "不過，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "是個好地方哦。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "風和水都很乾淨，",
