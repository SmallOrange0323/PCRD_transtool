[
    {
        "type": "background",
        "background": "502460"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天晚上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在宅第的大廳裡。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n格蕾斯正一臉憂心地思考著什麼事。"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "…………",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_000"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "……我有聽說，",
        "unit_id": 52612,
        "voice": "vo_adv_1330003_001"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "妳跟一個騎士少年走得很近。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n這是真的嗎格蕾斯？",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "守護薇歐莉特公主。",
        "unit_id": 52612,
        "voice": "vo_adv_1330003_002"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n如果會影響到這份職責，",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n我是絕不會認可",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "這種輕浮的男女關係。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……這不用你說我也知道。",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_003"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "唔。",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_004"
    },
    {
        "type": "background",
        "background": "502290"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "好乖好乖。",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_005"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "辛苦你了，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "布羅肯。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "布羅肯",
        "words": "嘶嘶──！",
        "unit_id": 52511
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那麼，",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_006"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "感謝你陪我到這麼遠的地方來。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是的。",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_007"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這裡就是骷髏飛龍盤據的地方──",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n牠是會狩獵誤闖沙漠之人的兇猛魔物，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n是這次要討伐的目標。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏。",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_008"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這是相當危險的對手，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你沒問題嗎？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……是",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_009"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "嗎。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……唔。",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_010"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n出現了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "胡鬧。",
        "unit_id": 133013,
        "voice": "vo_adv_1330003_011"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n……如果是那樣，",
        "unit_id": 133013
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "該有多好呢。",
        "unit_id": 133013
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這也是為了，",
        "unit_id": 133013,
        "voice": "vo_adv_1330003_012"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "要做個了斷。",
        "unit_id": 133013
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n……騎士氏。",
        "unit_id": 133013
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我要討伐你。",
        "unit_id": 133013,
        "voice": "vo_adv_1330003_013"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "喝啊啊！",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_014"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你果然很輕易地就被騙了呢。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_015"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n天真也該有個限度。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……來吧，",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_016"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "拔出你的劍。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就如同字面上的意思。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_017"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n我要你拔劍跟我戰鬥。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呵呵。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_018"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這是我至今為止見過你最驚訝的表情呢。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "已經沒有遺憾了。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "來吧，",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_019"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "快點拔劍。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n不然，",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "可是會被我的長槍給貫穿的哦──",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "喝！",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_020"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……理由。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_021"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那麼，",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就當作是送你去陰間的伴手禮吧。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我現在最優先的事項是，",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_022"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "保護菫──",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "保護薇歐莉特公主。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n身為守護騎士，",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這份決心必須如長槍般銳利",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n且不能有任何動搖。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……但是……",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_023"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我只要看到，",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_024"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏你那傻呼呼的表情……",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n槍尖，",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就會開始動搖。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……呼。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_025"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "話就說到這裡。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_026"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你快拔劍吧。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n不然的話──",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "喝啊……！",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_027"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "快拔劍。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_028"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "快拔劍！",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_029"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "喝啊啊！！",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_030"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "…………",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_031"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……哦。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_032"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n你的意思是我只是一臉得意地飄在空中，",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "刺來刺去而已？",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "怎麼了騎士氏。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_033"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n有什麼想說的就說出來吧。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "「這幾天，",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_034"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "與格蕾斯小姐相處之後明白了」？",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "喔？",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "明白了什麼？",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "…………\n……",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_035"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呵……",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_036"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呵呵呵。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "哈哈哈！",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_037"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你說我很喜歡胡鬧！",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n像我這種活在陰暗又潮濕的死者世界裡的亡靈！",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n很喜歡胡鬧！！",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "哈哈哈！！",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你答對了。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_038"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你很有眼光呢騎士氏。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_039"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n我超喜歡的。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "胡鬧。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不過，",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_040"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我也逐漸開始了解你了。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n雖然一臉天真又純真無邪的樣子，",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "但你其實是個會吐槽的人呢。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "可以的哦騎士氏。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_041"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n既然都到這地步了，",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你想吐槽什麼都沒關係。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你說你不知道什麼是吐槽？",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_042"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這個嘛，",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "只要指出你覺得有點奇怪的地方就好了。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不需要有所顧慮。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_043"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n嗯嗯……",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "「那麼，有件事從之前就很在意」？",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "………………",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_044"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……雖然，",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_045"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是我說什麼都可以的……",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "但這會不會太過深入了點……？",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……不過……",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我還是說吧……",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "為什麼我只有一邊打赤腳。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_046"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n這就要從一個，",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "聽者傷心、",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "說者流淚的",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "悲劇故事說起……",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "才沒有這回事。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_047"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n答案就是──",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "「我在等人吐槽」。",
        "unit_id": 133011
    },
    {
        "type": "background",
        "background": "502290"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "啊啊……",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_048"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "至今為止",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "大家都是婉轉地用看到",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "「奇怪打扮」",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "的眼神在看我而已",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n……終於出現對我說出來的人了。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不管是颳風",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_049"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "還是下雨。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我都堅持著這身打扮，",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就是為了哪天能有人來吐槽我。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這樣我就能毫無遺憾地",
        "unit_id": 133013,
        "voice": "vo_adv_1330003_050"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "成佛了。",
        "unit_id": 133013
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "太棒了。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_051"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n看來你的吐槽才能開花了。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那麼，",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_052"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "差不多該拔劍了吧。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不。",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_053"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這並不是在開玩笑。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我說真的。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "認真。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你看，",
        "unit_id": 133011,
        "voice": "vo_adv_1330003_054"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "上面。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "骷髏飛龍",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "出現了呢，",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_055"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "骷髏飛龍。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是啊。",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_056"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n看起來牠收集了不少骨頭……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n是單憑我一人有點難以對付的魔物。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "雖然都來到這了，我想你也不可能拒絕我。",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_057"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "但是你願意一起戰鬥嗎？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……！",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_058"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n全身充滿了力量……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "果然騎士氏的強化，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "能讓我想起已經忘記的心跳……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這樣一來。",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_059"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "長槍的銳利度，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就能再提升五成。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "喝啊啊！！",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_060"
    },
    {
        "type": "background",
        "background": "502290"
    },
    {
        "type": "dialogue",
        "name": "骷髏飛龍",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "502440"
    },
    {
        "type": "dialogue",
        "name": "殭屍１",
        "words": "哦哦……！",
        "unit_id": 314,
        "voice": "vo_adv_1330003_061"
    },
    {
        "type": "dialogue",
        "name": "殭屍１",
        "words": "\n格蕾斯大人她回來了！",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "殭屍２",
        "words": "好厲害，",
        "unit_id": 917,
        "voice": "vo_adv_1330003_062"
    },
    {
        "type": "dialogue",
        "name": "殭屍２",
        "words": "聽說她討伐了那隻骷髏飛龍！",
        "unit_id": 917
    },
    {
        "type": "dialogue",
        "name": "殭屍２",
        "words": "\n不愧是薇歐莉特公主的守護騎士，",
        "unit_id": 917
    },
    {
        "type": "dialogue",
        "name": "殭屍２",
        "words": "格蕾斯大人！",
        "unit_id": 917
    },
    {
        "type": "dialogue",
        "name": "殭屍群",
        "words": "噢噢噢噢噢！！",
        "unit_id": 1,
        "voice": "vo_adv_1330003_063"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "格蕾斯，",
        "unit_id": 52612,
        "voice": "vo_adv_1330003_064"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "妳回來了啊。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n能夠成功討伐巨大化的骷髏飛龍，",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n我身為妳的祖父也感到臉上有光呢。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不過你根本就沒有臉呢。",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_065"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "……我差不多",
        "unit_id": 52612,
        "voice": "vo_adv_1330003_066"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "要開始覺得沮喪了哦。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "算了。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n異國的騎士閣下。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "我也要向你道謝。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n感謝閣下為此不餘遺力。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "格蕾斯，",
        "unit_id": 52612,
        "voice": "vo_adv_1330003_067"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "我之前似乎妄言說妳沒有善盡職責。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n真是抱歉啊。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "沒關係，",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_068"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你能了解就好了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……是的？",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_069"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n怎麼了嗎，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你說「這幾天，",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_070"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "很感謝有我陪你……？」",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不會，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我只是在接待客人而已。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "………………",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_071"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "─",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_072"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "─沒事。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n什麼事都沒有。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "只是有種……",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_073"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n受到了強化的感覺，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "僅此而已。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "──你不懂這是什麼意思？",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_074"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "嗯……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "解說的話也很不解風情，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就留到下次再說吧。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "當騎士氏臨終之時，",
        "unit_id": 133012,
        "voice": "vo_adv_1330003_075"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "再拿來當作去陰間的伴手禮。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "面帶微笑的格蕾斯如此說道，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n便溫柔地揮了揮手，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "身影朝向宅第深處消失而去──"
    }
]