        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "現在可以免費體驗最適合這個季節的搭配和妝容喔──♪",
        "unit_id": 1231,
        "voice": "vo_adv_1013008_009"
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "\n這位小姐要不要試試呢──？",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不、",
        "unit_id": 101332,
        "voice": "vo_adv_1013008_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不了，",
        "unit_id": 101332
