        "voice": "vo_adv_1013008_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……咦，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "變身？",
        "unit_id": 101332
