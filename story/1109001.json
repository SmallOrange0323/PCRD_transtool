[
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在聖德蕾莎女子學院內部，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一群正值青春年華的少女們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在放學後聚在一塊聊起了女孩間的悄悄話。"
    },
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "欸欸～",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_000"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "大家聽說了嗎？",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n聽說隔壁班的班長，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "昨天和男孩子走在一起耶！",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "男、",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_001"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "男孩子！？",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n真假！　為什麼！　",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "他們在交往嗎？",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "是那樣嗎～……",
        "unit_id": 2911,
        "voice": "vo_adv_1109001_002"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "\n",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "真羨慕呢，",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "我也想要男朋友～！　",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "妳們有誰能介紹一下啊～！",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "就算妳那樣說……",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_003"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "吶？",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "所以，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "大家自己那邊",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "又怎樣？",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "…………",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_004"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "呃……",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_005"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n總之，我們這裡頭最受歡迎的是誰啊？",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n嗯，應該是琪愛兒吧？",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "什麼？",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_006"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "是琪愛兒呢。",
        "unit_id": 2911,
        "voice": "vo_adv_1109001_007"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "\n長得好看？　",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "也很討人喜愛？　",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "而且跟誰都能馬上變成好朋友。",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "等等，等等，學姐們，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "什麼什麼？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我才一回過神，怎麼大家就舉辦起誇獎琪愛兒大會啦？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "抱歉，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_009"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我還以為是無聊的事所以沒有仔細聽。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "麻煩大家請再從頭說一次啦。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "我們是在說……",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_010"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n琪愛兒妳很受男孩子歡迎啦。",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是的，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "非常。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "喔、",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_012"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "喔喔……",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "妳不否認也不謙虛一下喔……",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "不過，",
        "unit_id": 2911,
        "voice": "vo_adv_1109001_013"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "說得也是啦，",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "妳長得就是一臉美少女臉嘛。",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是說啊，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_014"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的就是那樣～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是不是～？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳們不覺得男孩子都很喜歡長得可愛的女孩子嗎～？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "不僅不否認，還完全同意……",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_015"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "而且不知道為什麼，還一副說得自己是受害者一樣……",
        "unit_id": 2911,
        "voice": "vo_adv_1109001_016"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的是這樣啊～",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_017"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n琪愛兒的這副長相",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "從以前就莫名超受歡迎，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n雖然這樣說真的有點抱歉，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過說實話很煩。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "唔哇……",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_018"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "該怎麼說……",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_019"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "雖然都事到如今才在說，",
        "unit_id": 2911,
        "voice": "vo_adv_1109001_020"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "但這女孩真不得了……",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？　",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_021"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學姐們，該不會是",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "有點被我嚇到了吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "有點。",
        "unit_id": 2911,
        "voice": "vo_adv_1109001_022"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "\n",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "不是啦，",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "可是啊，",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "不知該說妳是很誠實還是奔放，",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "\n就是有種琪愛兒還真是自由的感覺，",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "反倒令人很欽佩呢。",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_023"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是要那種……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好的好的，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我懂了，原來如此～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n那重來一次～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "Take 2～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我、",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_024"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我很受歡迎！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怎麼可能怎麼可能，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "才沒有～！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "根本沒有啦～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "——像這樣的謙虛版本對吧？",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_025"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯嗯，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要做的話我是做得到啦～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_026"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "反正我那樣做的話，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「嘖，裝什麼傻！」",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「長成那樣怎麼可能不受歡迎？」",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "最後氣氛不也是會變成這個樣子嗎～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "結果",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_027"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不管我怎麼回答，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家心裡對琪愛兒可都是「嘖」的感覺哦？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不覺得根本莫名其妙嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_028"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在蘭德索爾長得可愛是罪過嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不好意思，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒長得還算可愛，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這樣還有",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "人權嗎？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒問題嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "雖然我不清楚，",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_029"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "不過妳那個性大概沒問題的吧……",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "可是琪愛兒，",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_030"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "妳那樣很可惜呢。",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n明明那麼受歡迎，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "可是妳對交男朋友",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "或是談戀愛之類的，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "完全沒興趣吧？",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也不算沒興趣，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_031"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這個嘛，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是優先順序還滿後面的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "比友情",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "或興趣",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "或讀書之類的還要後面呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "竟然比讀書還後面，",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_032"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "根本就是最後一名了吧！",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "不行不行，真不敢相信！　",
        "unit_id": 2911,
        "voice": "vo_adv_1109001_033"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "我絕對要談戀愛～～！",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家在熱衷談戀愛的這個年紀",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_034"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n每天都會吵吵鬧鬧地聊著",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "自己或其他人的戀情。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我想大概是因為那就是最開心的事吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是我還有很多",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_035"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "其他「開心的事」。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "像是這樣和大家在放學後聊個不停，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還有",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "去各種地方，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "認識各式各樣的人——",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "名為青春的這段期間，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_036"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "一定不會太長。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以我在度過",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這有限的特別時節時，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n想要盡可能地去接觸很多「開心的事」。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_037"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "熱烈討論的",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "戀愛之類的事情也是，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我想",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的開始談戀愛的話，應該也會滿開心的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n畢竟這是人類從以前就很著迷的必備娛樂嘛。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_038"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "和特定的某一個人",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n成為戀人，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "締結一個無期限的互相獨佔協定這種事，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對我來說實在太不自由，壞處未免太多了吧？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我是這樣想的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "人生苦短，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_039"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "別戀愛吧少女。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "我說琪愛兒，",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_040"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "妳在喃喃自語什麼啊！",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n妳有聽到我們剛才",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "說的話嗎！？",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不，完全沒聽到。",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_041"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n咦～？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "什麼什麼？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "跟妳說！",
        "unit_id": 2911,
        "voice": "vo_adv_1109001_042"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "\n美衣子她啊！",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "\n說她有喜歡的男生了～！！",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_043"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的假的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "應該說，又來了哦。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "畢竟美衣子，",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_044"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "對每個遇到的男生都很容易暈船嘛～",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "不是啦，",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_045"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "也不是喜歡，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "還不到那程度啦～！",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "就是有個男生",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "讓我有點在意的感覺啦～！",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "美衣子妳雖然這樣說，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_046"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n可是妳一臉害羞，有夠明顯的！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "欸，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_047"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那對方是誰？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這次是怎樣的人？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "她說是偶爾會去她家，",
        "unit_id": 2911,
        "voice": "vo_adv_1109001_048"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "年紀差不多大的送貨員打工仔！",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "送貨員。",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_049"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "原來如此，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "意思是他把愛情",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "跟信件一起送來給妳了呀。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我還真是說了番很不錯的話呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "先不管說得好不好，",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_050"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "說的人是琪愛兒吧。",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "先不管是不是琪愛兒，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_051"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "剛才那話說得可是很不錯呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "欸",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_052"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那所以",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對方的外表和個性怎樣？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "以偶像來形容的話，長得像誰？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "用Cute、Cool、Passion來說的話是哪種？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "咦咦～？　",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_053"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "該怎麼說……",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "他單純的感覺很Cute，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n寡言又不易動搖的感覺很Cool，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "偶爾有些",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "讓人意想不到的言行，則是滿Passion的呢。",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "三種屬性全部都有？",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_054"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n咦？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真有這種人嗎？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怎麼回事？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n綜合起來就是，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "又單純又會裝傻還會突然失控嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "是啊，",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_055"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "他的確是個",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n無法用其他人來形容，很不可思議的類型的男生。",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "呵呵呵，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "來做個名字筆劃占卜，測測契合度吧～",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "{player}……\n哇，他叫這名字啊？　",
        "unit_id": 2911,
        "voice": "vo_adv_1109001_056"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "名字真不錯～！",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_057"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "他好像又單純又會裝傻還會突然失控耶？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "臉呢？　",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_058"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "臉長得怎樣！？",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "咦～",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_059"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "該怎麼說？",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "就我而言，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "應該還算俊美就是了，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "呵呵呵。",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_060"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "他好像又單純又會裝傻還會突然失控耶？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哎呀，",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_061"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "反正人各有所好，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n美衣子很開心那就最好了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "唉……",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_062"
    },
    {
