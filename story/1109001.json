    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "咦？",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_064"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_065"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "…………",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_066"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "奇怪？　",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_067"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家怎麼不說話。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為妳說",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "想和那個人交往不是嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n那",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "既然這樣就去啊，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對不對？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就趕快",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_068"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "去跟他告白",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不就好了嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "…………",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_069"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦～？",
        "unit_id": 110911,
        "voice": "vo_adv_1109001_070"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怎麼了怎麼了？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n大家為什麼",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "一言不發地妳看我我看妳？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n琪愛兒剛才說了什麼奇怪的話嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "是、",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_071"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "是不奇怪啦……",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "只是該說是有點趕進度，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "還是建議得有點隨便？",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "要是有辦法做得到的話，一開始就不用那麼辛苦了……",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "妳想嘛，就是那個啊。",
        "unit_id": 3111,
        "voice": "vo_adv_1109001_072"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n因為琪愛兒的顏值很高，",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "人生中的桃花隨隨便便就信手拈來。",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "所以對一般女生談戀愛的方法反倒很不了解呢。",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "畢竟這就是強者的理論嘛。",
        "unit_id": 2911,
        "voice": "vo_adv_1109001_073"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "\n在『遊戲』的攻略裡，",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "不是偶爾也會看到嗎。",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "\n",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "「在這關只要穿這個裝備就能輕鬆獲勝！」之類的話。",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "哎呀，妳真不擅長教人呢。",
        "unit_id": 2911,
        "voice": "vo_adv_1109001_074"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "\n我們就是沒有那種稀有裝備，",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "所以才苦惱的嘛。",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "\n真是的，",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "世上應該要多考慮一下弱者的處境啦。",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "嗯，",
        "unit_id": 3011,
        "voice": "vo_adv_1109001_075"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "我這種弱者辦不到啦……",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "要我去告白，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "怎麼可能……",
