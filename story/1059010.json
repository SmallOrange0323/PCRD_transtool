[
    {
        "type": "background",
        "background": "500351"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在一個和平的午後，咲戀育幼院的庭院裡，\n傳來可可蘿和狗的聲音。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n來吧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是主人最喜歡的球喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘿咻，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "快去撿！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "狗",
        "words": "汪，汪！",
        "unit_id": 1811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的跑得很快呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一下就撿回來了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀，",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請不要壓在在下的身上。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下的纖細身體，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無法承受主人的體重……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要再一次，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是嗎？　",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人你還真有精神。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我要丟球了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘿咻！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "人類主人！？",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您接得真準！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "人類主人！？",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不行喔，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼可以把球咬在嘴裡！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "快",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "吐出來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "吐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的是非常抱歉，",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我跟汪汪主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "玩得太專注了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您有事",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要找在下嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是……",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "寄給在下的信？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是特地拿來給在下的嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像是蘭德索爾公務機關的來信……",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是什麼事呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們已經找到您所通報",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那隻迷路的狗狗的飼主……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "了？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "找到汪汪主人的",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人了……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "狗",
        "words": "汪。",
        "unit_id": 1811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來是",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "太好了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就能讓真正的主人好好疼愛牠了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……人家說好事不宜遲。",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n馬上聯絡對方，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明天就",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "前往公務機關看看吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_013"
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "狗",
        "words": "汪！　汪！",
        "unit_id": 1811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "汪汪主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不要這麼急嘛。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然我知道你很喜歡散步，",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不過",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請你稍微配合一下在下的步伐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……因為，",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是我們最後一次散步",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "時間不長，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但真的很謝謝你。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然你一開始連飯都不願意吃，",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是當我耐心地跟你溝通之後，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "你也對在下打開心房，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們已經可以同床而寢了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幫你取名叫做主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想睡時唱催眠曲給你聽……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要在下撫摸你柔軟的毛，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "你就會很舒服似地用鼻子發出撒嬌的聲音。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣的日子……",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到今天",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就要結束了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗚嗚。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很抱歉，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明應該替牠高興才對，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但竟然卻掉眼淚。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總有一天要分開這種事，",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "心底明明很清楚，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下的心",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻好像無法忍受似的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "翻騰著難以言喻的複雜心情。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……這種感覺，",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最近似乎也",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能感受到。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那就是人類主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n逐漸離開在下的手，彷彿漸行漸遠的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "寂寞感……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次的分離，",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總覺得跟人類主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像也必須得分開一樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的覺得很寂寞。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n分離太痛苦了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "簡直無法忍受。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您這是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼意思……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算分開了……",
        "unit_id": 105913,
        "voice": "vo_adv_1059010_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還能",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再相見？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要心裡想著對方，",
