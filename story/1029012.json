[
    {
        "type": "background",
        "background": "500552"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "祭典前一天晚上，望和{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來做第二天舞台的最後確認。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明天終於",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要站上這個舞台了呢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "至今為止雖然也上過好幾次大型舞台，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但還是第一次在神殿舉辦演唱會，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真令人緊張。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你那是什麼擔心的表情。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然說",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這次發生了很多事情，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但我已經不要緊了喔。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明明幾天前都還那麼焦躁不安，",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "現在卻像沒那回事似地冷靜。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n總覺得好不可思議呢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我離那個境界還早啦。",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我覺得我已經抓到一點感覺，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剩下就要靠自己了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n要是",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明天的演出能傳達給神明的話，想必就能……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈，",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣的話我就沒什麼好怕的了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這下開始期待明天了呢。",
        "unit_id": 102913
    },
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我說騎士先生，",
        "unit_id": 105411,
        "voice": "vo_adv_1029012_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "外面狀況如何？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有觀眾來了嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "慈樂之音的粉絲也來捧場了呢。",
        "unit_id": 104211,
        "voice": "vo_adv_1029012_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真令人安心。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……不過",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "和平常的客群還是有點不一樣呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有些年長觀眾不是來看我們，",
        "unit_id": 104211,
        "voice": "vo_adv_1029012_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是為了「奉音祭祀」",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而來的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為不是我們的粉絲，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n也許會嚴格審查我們的表演呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不用擔心！",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "神官大人不是也說了嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們的音樂相當出色，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不會輸給傳統音樂。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是我們的粉絲也好，不是我們的粉絲也罷，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們來讓所有人全部露出笑容吧♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是可靠呢。",
        "unit_id": 105411,
        "voice": "vo_adv_1029012_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不愧是慈樂之音的Center！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……啊！",
        "unit_id": 104211,
        "voice": "vo_adv_1029012_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你們看那個！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等、",
        "unit_id": 105411,
        "voice": "vo_adv_1029012_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等一下！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "天空突然開始烏雲密布了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呀！",
        "unit_id": 105411,
        "voice": "vo_adv_1029012_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "竟、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "竟然還打雷……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的，等一下祭典就要開始了說！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "怎、",
        "unit_id": 1511,
        "voice": "vo_adv_1029012_014"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "怎麼會發生這種事？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "神明生氣了……！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "還請您息怒！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "果然",
        "unit_id": 511,
        "voice": "vo_adv_1029012_015"
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "把神聖的祭典交給偶像什麼的，\n是個錯誤的決定！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "才沒有這種事！",
        "unit_id": 1011,
        "voice": "vo_adv_1029012_016"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "慈樂之音最棒了！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "\n只要看過一次她們的表演",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "你就會懂了！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "但、",
        "unit_id": 311,
        "voice": "vo_adv_1029012_017"
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "但是",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "慈樂之音粉絲以外的人們看起來都很驚慌……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "這樣子祭典還辦得了嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "神啊，",
        "unit_id": 1,
        "voice": "vo_adv_1029012_018"
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "您真的發怒了嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "\n還是這是場試煉呢？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……千歌、",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我要改變計畫了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "先由我單獨上台打頭陣。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n妳們等到歌唱完的時候再配合時間出場。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我知道了。",
        "unit_id": 104211,
        "voice": "vo_adv_1029012_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那就拜託妳了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "讓神明好好見識一番吧！",
        "unit_id": 105411,
        "voice": "vo_adv_1029012_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……嗯，",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那我上場了！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "嗯？",
        "unit_id": 1011,
        "voice": "vo_adv_1029012_023"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "喂、",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "喂，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "你們看那個！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_024"
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "那是，",
        "unit_id": 311,
        "voice": "vo_adv_1029012_025"
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "望、",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "望望──！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "啊、",
        "unit_id": 1511,
        "voice": "vo_adv_1029012_026"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "啊啊……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "何等神聖的姿態……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "簡直就像是",
        "unit_id": 511,
        "voice": "vo_adv_1029012_027"
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "女神一般……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "好厲害，",
        "unit_id": 1,
        "voice": "vo_adv_1029012_028"
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "她只是站上舞台，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "就一口氣吸引住原本還在台下吵鬧的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "\n觀眾目光了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "望小姐的存在感實在太驚人了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……要開始囉。",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "～～～♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "這、",
        "unit_id": 1011,
        "voice": "vo_adv_1029012_030"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "這是……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "和平常的望望",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "不一樣……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "不過，",
        "unit_id": 311,
        "voice": "vo_adv_1029012_031"
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "這歌聲實在既柔美又有力！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "這、",
        "unit_id": 1511,
        "voice": "vo_adv_1029012_032"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "這就是偶像的力量……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "我第一次有這種感覺！",
        "unit_id": 511,
        "voice": "vo_adv_1029012_033"
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "剛才氣氛還那麼紛亂，",
        "unit_id": 1,
        "voice": "vo_adv_1029012_034"
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "現在所有人注意力卻都在望小姐一人身上。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "\n沒想到她是擁有這般實力的歌手……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "喂，你們看那個！",
        "unit_id": 1011,
        "voice": "vo_adv_1029012_035"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "剛才還烏雲密布的天空，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "已經開始放晴了！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "好厲害！",
        "unit_id": 311,
        "voice": "vo_adv_1029012_036"
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "望望引發奇蹟了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "這、",
        "unit_id": 511,
        "voice": "vo_adv_1029012_037"
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "這只是偶然吧……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "不過，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "就像是她引發奇蹟似地，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "\n我被那女孩深深地吸引住了，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "完全移不開視線……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "我也是。",
        "unit_id": 1511,
        "voice": "vo_adv_1029012_038"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "之前居然還",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "看不起偶像，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "實在太丟人了。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "她真的很了不起，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "我看得很感動。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼，",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_039"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "似乎總算讓大家冷靜下來了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "神明這套演出也太誇張了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嚇死我了！　",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過太好了。",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家看了我的演出，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n聽了我的歌曲之後都露出笑臉了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對偶像的質疑",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "以及意外所引起的不安，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這些全都不見了！　",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是這個──",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_042"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這正是",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我所追求的，真正頂尖偶像的姿態！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "單是追求聲望以及銷量，",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_043"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "絕對沒辦法走到這一步。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n如何成為能使人感動的偶像，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "答案其實就在那場夢裡。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "像她們一樣，",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_044"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "展現自己努力的姿態，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來讓觀眾露出笑容。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我至今也想要成為那樣的人。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_045"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想要再往前跨出一步。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不只是讓人露出笑容，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就連人們感到不安或是迷惘的心，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我也要一併震撼，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "使他們沉浸於表演之中。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只要看了我的表演，",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_046"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "心中就會湧現活下去的希望。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n能成為他人心目中的",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「希望」的人，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "才是",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想成為的真正頂尖偶像！　",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖是第一次見，",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_047"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "卻不像初次見面的偶像小姐，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝妳們。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "多虧妳們，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我才能察覺到這麼重要的事。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "之前雖然答案就近在咫尺，",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_048"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我卻無法順利察覺到解答，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但現在我已經不會再迷惘了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "獻給聚集在這裡的人們、",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_049"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "各位工作人員、",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "技藝之神、",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n一路上陪伴、",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "支持著我的千歌和紡希，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n以及──",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "灌注我所有的感情──",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "傳達出去吧～！　",
        "unit_id": 102913
    },
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_051"
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_1029012_052"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "嗯？",
        "unit_id": 1511,
        "voice": "vo_adv_1029012_053"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "啊啊！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "光、",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "光芒，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "光芒開始灑落在",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "她身上了！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "太驚人了……",
        "unit_id": 1,
        "voice": "vo_adv_1029012_054"
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "這簡直就是神的祝福。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "\n望小姐，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "神官",
        "words": "妳果然是位很了不起的人！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "唔喔喔喔喔喔喔！",
        "unit_id": 1,
        "voice": "vo_adv_1029012_055"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈……",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_056"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再怎麼說這也太湊巧了吧？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這應該就代表運氣也站在我這邊吧。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且",
        "unit_id": 102913,
        "voice": "vo_adv_1029012_057"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家都非常高興。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的成功成為「希望」了……！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望，",
        "unit_id": 104211,
        "voice": "vo_adv_1029012_058"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這還只是第一首喔！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在就覺得滿足還太早了。",
        "unit_id": 105411,
        "voice": "vo_adv_1029012_059"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們也要開場就使出渾身解數喔！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嘿～！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "好、",
        "unit_id": 311,
        "voice": "vo_adv_1029012_060"
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "好厲害！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "一瞬間就變換了服裝！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……我說，",
        "unit_id": 102912,
        "voice": "vo_adv_1029012_061"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你也一起來幫忙吧？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為能走到這地步，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "都是多虧有你在嘛。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓我們慈樂之音",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "跟你一起，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "創造一場最棒的舞台吧！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你{player}。",
        "unit_id": 102912,
        "voice": "vo_adv_1029012_062"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n嗯，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天似乎會是至今為止",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "最棒的一場演出呢！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼",
        "unit_id": 102912,
        "voice": "vo_adv_1029012_063"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要上囉～！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "慈樂之音……",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "登台！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望等人",
        "words": "喔～！",
        "unit_id": 1,
        "voice": "vo_adv_1029012_064"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我說，",
        "unit_id": 102912,
        "voice": "vo_adv_1029012_065"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你看到了嗎？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有仔細聽著嗎？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我作為真正頂尖偶像的",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "最初的一步。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102912,
        "voice": "vo_adv_1029012_066"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這只不過是開始。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我得去證明",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這一切並非只是偶然。\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "接下來才是關鍵。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但我卻完全不會感到不安，",
