[
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──當{player}投身於和【憤怒‧軍團】的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n新的戰鬥中時，某個人物"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n則在另一個世界中展開了行動。"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "來，讓妳久等了，",
        "unit_id": 106832,
        "voice": "vo_adv_1068001_000"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "草莓可麗餅！",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "很好吃喔〜！",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "大姐姐，",
        "unit_id": 231,
        "voice": "vo_adv_1068001_001"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "謝謝妳〜！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "歡迎再來〜！",
        "unit_id": 106832,
        "voice": "vo_adv_1068001_002"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "哎呀～",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "做可麗餅果然很開心～！",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_003"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "拉基拉基！",
        "unit_id": 106832,
        "voice": "vo_adv_1068001_004"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "歡迎光臨～！",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你要點什麼？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……說明現況。",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_005"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "抱歉，",
        "unit_id": 106832,
        "voice": "vo_adv_1068001_006"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那個賣完了♪",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n你看，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "正如你所見，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我這裡可是可麗餅店啊。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "要我把妳揍飛嗎？",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_007"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "開玩笑的，我是開玩笑的！",
        "unit_id": 106832,
        "voice": "vo_adv_1068001_008"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你別生氣啦！",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "別像那樣",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "馬上就要用上全接觸空手道的規則啊！",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我原本人就沒好到",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_009"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "能聽妳開玩笑了。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n麻煩妳別轉移話題。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "真是的，",
        "unit_id": 106832,
        "voice": "vo_adv_1068001_010"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "難得好久不見，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你還是這麼冷淡耶……",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "在阿斯特朗",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_011"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "開始營運後我就立刻陷入了昏睡狀態。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n現在可沒有多餘的閒功夫",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "去在意態度好不好。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "說的也是呢。",
        "unit_id": 106832,
        "voice": "vo_adv_1068001_012"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n不過既然這樣，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你為什麼沒有立刻來找我打聽？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "因為從醒來到現在的這段時間，",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_013"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n我最優先做的是讓變差的體力恢復正常。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "而在那段時間裡",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_014"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我也有一點一滴在收集情報，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "所以才得知了……",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n晶，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "和真那他們不同，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "最近回到了「這一側」的只有妳。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我也有隱隱約約聽到消息囉。",
        "unit_id": 106832,
        "voice": "vo_adv_1068001_015"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n聽說拉基拉基在這一側也",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "開始行動了。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "那事情就好說了。",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_016"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n我認為妳對那邊的情況瞭若指掌，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n一定能夠提供我想要的情報，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "因此才會來到這裡。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這樣啊，",
        "unit_id": 106832,
        "voice": "vo_adv_1068001_017"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "歡迎你遠道前來日本。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n所以呢？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你想知道什麼事？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……有關於這邊與那邊，",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_018"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "這兩個世界目前的現況。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "OK。",
        "unit_id": 106832,
        "voice": "vo_adv_1068001_019"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……今天就打烊吧。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我會邊收拾東西邊說話，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "沒關係吧？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "無所謂，",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_020"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "只要不影響情報內容就好。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "好～",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_021"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "首先是",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這裡的世界",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "已經大致安定下來了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我回來的時候，有不少事情都還一團糟，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n但我全用WISDOM的權限想辦法處理了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "就靠妳一個人？",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_022"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "那想必讓妳耗費了不少心力吧。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就是啊！",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_023"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我是真的很辛苦耶〜！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "從復職以後就一直沒休假，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n如果不是義體的話，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我現在",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "早就滿身瘡痍了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "義體……",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_024"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "是長老製造的機械肉體嗎？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "晶，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "等話談完之後，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "和我稍微比試一下……",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我才不要！",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_025"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "拉基拉基",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你不知道這副身體要花多少錢吧！？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n就算只是素體，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也要花上大都市一整年左右的預算啊！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "正因如此才更讓人想破壞看看……",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_026"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "現在就先作罷吧。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "才不只「現在」，",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_027"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "以後也不行！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "總之，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在阿斯特朗中的人們的肉體都平安無事。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "妳說肉體……",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_028"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "這麼說的話，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "意識呢？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯……",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_029"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "大概沒辦法輕易恢復。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n比起真那實現野心的世界，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "情況又變得更加複雜了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在那裡的玩家，",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_030"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n所有人都被迫認為阿斯特朗是現實，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n甚至連記憶都遭到竄改。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "嗯……",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_031"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "不只是細節，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "連整體的意識資料都沒有和肉體同步嗎。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我是不清楚這是誰搞的鬼，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "但還真是被設了個麻煩的限制啊。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n這根本是",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "強制將活人拉進冥府的行為。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "真～",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_032"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不愧是拉基拉基！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就算大睡特睡一頓也依舊是七冠，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "理解得真快！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我姑且有採取對策嘗試從玩家方面進行同步，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但不曉得",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "能不能順利。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "原本只要打倒掌控阿斯特朗的真那，",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_033"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這一切就應該能畫下句點……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但結果並非如此。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而我目前",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "正在尋找導致這結果的原因。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "原來如此……",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_034"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n那麼妳",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "暫時",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "會將心力專注在處理阿斯特朗的問題上？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是啊，",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_035"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我也很擔心我的公主騎士。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "拉基拉基呢？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你打算怎麼辦？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "既然手邊沒有能夠操縱的帳號，",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_036"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "那麼我考慮",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "在這邊的世界從WISDOM內部採取對策。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n畢竟我好歹",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "也是七冠之一啊。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這麼說也是啊。",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_037"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我在那邊看到的拉基拉基，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那到底是什麼人啊？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n既不是本人，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也不可能是那孩子……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "無論在操縱的人是誰，",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_038"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "對我而言都不重要。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n等事情結束之後我會搶回來，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "僅此而已。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……我突然想到啊，",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_039"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "拉基拉基你，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "該不會覺得\n自己對這次的事情有責任吧！？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "明明你也沒做什麼壞事，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n只是一直在睡覺而已！？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "難道是我聽錯了嗎……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……晶。",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_040"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "從剛才開始妳的行為舉止，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n只會讓人覺得妳是在主動討打呢。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "可是我真的很驚訝啊！",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_041"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n畢竟你可是那個獨善其身的拉基拉基耶！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "關於那點我不否認。",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_042"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "對吧？",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_043"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這樣我就算覺得驚訝也很合情合理吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_044"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "就身為參與開發阿斯特朗人員的立場，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n在道義上對此件事抱有責任感，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "有這麼令人不可思議嗎？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯，",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_045"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "很不可思議。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……回答得真直接。",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_046"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "就像是個在戰鬥前就敗退出場的人。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "所以，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n我只是不希望圍繞著米奈娃的鬥爭再繼續擴大。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "哼嗯……",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_047"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所謂的",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "戰士、",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "或該說是",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "格鬥家，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就是這樣的人嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不過，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "以在這邊的七冠來看，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我認為拉基拉基是最適任的，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n也沒什麼不好的吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "不過這也是為了揍毀米奈娃。",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_048"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "撤、",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_049"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "回、",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "前、",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "言！！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "呵……",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_050"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "是開玩笑的。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "這是在回敬妳剛才的仇。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "騙人。",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_051"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你肯定還是一心想要找那孩子反擊……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這種討人厭的地方也都沒變，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "能看到你這麼有精神真是太好了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "妳也是。",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_052"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "像迷宮一樣蠱惑他人的性格，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "也還是都沒變呢。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是嗎？",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_053"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "別看我這樣，我這還不是萬全的狀態喔。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n結果我也還沒回到原本的身體去……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "好，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "收拾",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "完畢！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那麼，",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_054"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我差不多要回阿斯特朗了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n之後就麻煩你了！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "等一下。",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_055"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我雖然有說過要接手，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "但妳給我等一下。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "怎麼了？",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_056"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊啊，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你如果想觀測那邊的影像，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n有我使用過的螢幕和器材，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就隨便你用吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "妳是認真的嗎？",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_057"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "一回去有可能會再也無法醒來啊。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不用擔心。",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_058"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我雖然不是克莉絲，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但「絕對」會醒來的。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n況且那邊",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也有值得信賴的人們在呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "是似似花和克莉絲提娜嗎？",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_059"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n還是",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "諾維姆和尾狗刀？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不是不是。",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_060"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是我挑選為公主騎士的少年，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "和他的夥伴們。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n他們很可靠。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "似似花",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "現在也在幫助他們。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "這樣啊。",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_061"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "晶，",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_062"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "妳從一開始",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "就打算把我留在這裡……",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n……",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "這樣",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我們彼此就算互不相欠吧。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯〜？",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_063"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你在說什麼〜？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我可是知道的。",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_064"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n陷入昏睡狀態時替我保護肉體的人，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "就是妳。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "哎呀，",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_065"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "被發現了啊。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我明明都說過要保密了！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……只要知道答案，",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_066"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "就沒什麼事比這更簡單了。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n受不了，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "妳真的還是老樣子，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "腦海裡",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "根本就是一座迷宮，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "晶。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "畢竟我可是",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_067"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "迷宮女王啊。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n不用擔心，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我不是睡美人，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不用人親也會醒來啦！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "無論是否擔心",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_068"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我也完全不會有",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "要親吻妳的想法。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n快點走吧。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嘖～",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_069"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你還是老樣子開不起玩笑耶。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……那邊的事情",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_070"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "就拜託妳了。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……嗯，",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_071"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "交給我吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……話說回來，晶。",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_072"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "妳停在這的這輛車",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "要怎麼辦──",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "──潛入，阿斯特朗！",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_073"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你們等我喔，",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_074"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "少年、",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "大家──！！　",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "晶！",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_075"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "給我等一下，晶！",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……來不及阻止她。",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_076"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n雖然我也沒資格說別人，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "但她還真是我行我素。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n果然",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "七冠等人，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "都不是些正常的傢伙。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "接下來……",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_077"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "說實話，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我是很想把這東西直接打壞，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n真是沒辦法。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "得把這個搬到某個地方去才行──",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "嗯，",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_078"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "這是……",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "信嗎？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "呀呵～拉基拉基！",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_079"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你好嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你生氣了嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就算生氣也別揍我喔！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我把地址寫在這，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "麻煩幫我把攤車",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "開到這個地方去喔！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n若是不知道地點的話，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就打開",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "放在那邊的平板裡的",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "地圖App吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "還有",
        "unit_id": 106831,
        "voice": "vo_adv_1068001_080"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "義體的管理，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我留下從長老那裡拿到的說明書了，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n把那個看一看吧！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那就再見囉〜！　",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……她從一開始就打算採取這麼獨斷的行動了嗎？",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_081"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "算了，也罷。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "這件事",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我也會算在人情裡有借有還的。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "願妳與妳的夥伴，",
        "unit_id": 107331,
        "voice": "vo_adv_1068001_082"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "獲得太陽與星星的祝福。",
        "unit_id": 107331
    },
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯……",
        "unit_id": 106812,
        "voice": "vo_adv_1068001_083"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯〜！",
        "unit_id": 106812,
        "voice": "vo_adv_1068001_084"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我回來了〜！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "咦？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "璃乃和靜流都不在……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "先從",
        "unit_id": 106812,
        "voice": "vo_adv_1068001_085"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "收集情報開始著手吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n少年，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有大家，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你們等我喔！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "再次來到另一個世界的拉比林斯達，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了與夥伴會合而開始展開了行動。"
    }
]