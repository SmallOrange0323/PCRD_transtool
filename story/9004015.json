        "voice": "vo_adv_9004015_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也要",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "確實可行呢。",
