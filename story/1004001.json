[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}正自己一人在散步時……"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "痛死啦！",
        "unit_id": 811,
        "voice": "vo_adv_1004001_000"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n你這小子！走路在看那呀，混蛋！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "啊啊，好痛呀！",
        "unit_id": 811,
        "voice": "vo_adv_1004001_001"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "看來我搞不好骨折了！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "你得賠償我醫藥費呀！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "吶吶，哥哥你們在做什麼呀？",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_002"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "妳誰呀？",
        "unit_id": 811,
        "voice": "vo_adv_1004001_003"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n和妳這小鬼頭沒有關係。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "給我滾遠點！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦～才不會沒關係咧！",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為呢，嗯嗯……那個……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，對了！",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_005"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這個人可是禊的哥哥呢！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣就有關係了吧？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "妹妹？",
        "unit_id": 811,
        "voice": "vo_adv_1004001_006"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "那就得讓你們兩個人負起責任囉？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n妳的哥哥撞到我，讓我骨折了。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "你們不付醫藥費的話可別想回家！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣呀？",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那就由禊代替哥哥",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n付醫藥費給你們吧！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊真的有錢呦。",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_008"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊一直都把錢存在這個寶箱裡呢！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "哎呀……真是個氣派的箱子。",
        "unit_id": 811,
        "voice": "vo_adv_1004001_009"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "裡頭放了多少錢呢？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n我看看……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "哇啊！",
        "unit_id": 811,
        "voice": "vo_adv_1004001_010"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n這是在搞啥！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊哈哈，你中招囉～！",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_011"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這是煙霧的嚇人箱！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥、哥哥！",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_012"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "趁現在快點逃走吧～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "欸，這樣呀？",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_013"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊因為常常使用煙霧，所以已經習慣了……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那邊是牆壁啦！？",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_014"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哎呀，連哥哥都因為煙霧看不清前方了……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真拿哥哥沒辦法。",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_015"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊就拉著哥哥的手前進吧！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "走這邊呦！",
        "unit_id": 100411
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "呼……",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "逃到這裡來，應該就沒問題了吧？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥得小心點呀！",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n不要被那種怪人給纏上了。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥不用謝謝禊啦。",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊因為能夠惡作劇，所以也很開心呢！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊呀，看到有困難的人，",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_019"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "實在沒有辦法放著不管呢～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……很了不起？",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "才沒有這種事情呢～ 哥哥的名字是？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥叫做{player}呀。",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_021"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥看起來很容易被牽扯進麻煩之中，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n所以要小心一點比較好喔。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……咦？",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_022"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n哥哥四處張望著，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "怎麼了嗎？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥不知道回家的路？",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_023"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣呀，因為我們急著逃跑，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n所以逃到了一個哥哥不認識的地方啊。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……那個～",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_024"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊！我們剛剛的地方就在對面，",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_025"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "只要走這條路繞過去就行了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥，再見囉～！",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_026"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "呀哈哈！",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_027"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n耶～哥哥中招了～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這可是禊特製的陷阱地洞喔！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這是今天早上挖的，很厲害吧？",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊一直在尋找容易掉到地洞裡的人呢～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "因為禊剛剛有幫哥哥的忙，",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_029"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這麼一來就扯平囉♪",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊呀～雖然看到有困難的人就沒有辦法丟著不管，",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_030"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "但是看到沒有困難的人時，就想要作弄一下呢♪",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥的反應，真的是超棒超有趣的～",
        "unit_id": 100411,
        "voice": "vo_adv_1004001_031"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n呀哈哈哈！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幫助他人又愛惡作劇，\n禊到底是個好孩子，還是個搗蛋鬼呢？\n真是讓人搞不懂的女孩。"
    }
]