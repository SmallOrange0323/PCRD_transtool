[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在{player}等人\n抵達伊麗莎白牧場之前不久──"
    },
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "大吾。",
        "unit_id": 107311,
        "voice": "vo_adv_2112010_000"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n調整後的「結界」，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "你適應了嗎？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "……啊呣。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "呿，",
        "unit_id": 190711,
        "voice": "vo_adv_2112010_001"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "別小看我好嗎，老兄。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n這點小變動，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我會靠氣勢來讓它聽話的！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "……啊呣。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "那就好。",
        "unit_id": 107311,
        "voice": "vo_adv_2112010_002"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n那麼──",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "喂，",
        "unit_id": 190711,
        "voice": "vo_adv_2112010_003"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "真軌！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾、拉基拉基",
        "words": "「再來一碗！」\n「再來一碗」",
        "unit_id": 1,
        "voice": "vo_adv_2112010_004"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我說兩位，",
        "unit_id": 191011,
        "voice": "vo_adv_2112010_005"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我又不是你們的侍從……！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "請你們放尊重一點好嗎！？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "啥？",
        "unit_id": 190711,
        "voice": "vo_adv_2112010_006"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "別這麼死板板的好嗎。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n這裡可是你家耶。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "雖不得已，但這回就讓我接受你的招待吧。",
        "unit_id": 107311,
        "voice": "vo_adv_2112010_007"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n我必須努力恢復體力才行。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "可是啊……",
        "unit_id": 191011,
        "voice": "vo_adv_2112010_008"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "那有什麼辦法？",
        "unit_id": 190711,
        "voice": "vo_adv_2112010_009"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n畢竟拉基拉基兄在大病初癒的狀況下，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n又勉強使用力量幫我",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "「調整」能力啊。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我是負責展開遮蔽魔力的結界",
        "unit_id": 190711,
        "voice": "vo_adv_2112010_010"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "來讓大嬸她們解除洗腦魔法的人。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n老兄他是負責使用空間跳躍來移動的人。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "你又沒有負責什麼工作，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "至少也幫我們準備吃的吧。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "……沒辦法了。",
        "unit_id": 191011,
        "voice": "vo_adv_2112010_011"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n這都是為了主人……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "兩位",
        "unit_id": 191011,
        "voice": "vo_adv_2112010_012"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "請用吧。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我開動了。",
        "unit_id": 107311,
        "voice": "vo_adv_2112010_013"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "……話說兩位。",
        "unit_id": 191011,
        "voice": "vo_adv_2112010_014"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n你們打算怎麼找出主人她們？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n有什麼線索嗎？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "啊？",
        "unit_id": 190711,
        "voice": "vo_adv_2112010_015"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "這種事，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "當然……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "目前，",
        "unit_id": 107311,
        "voice": "vo_adv_2112010_016"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "並沒有什麼確切的情報。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "什麼……",
        "unit_id": 191011,
        "voice": "vo_adv_2112010_017"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n那麼，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "即便改善了那個「結界」，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n也是無用武之地不是嗎！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "別激動。",
        "unit_id": 107311,
        "voice": "vo_adv_2112010_018"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "真的沒辦法的話",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "就去把霸瞳皇帝放出來。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n借助他的「瞳」…………",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "啊？",
        "unit_id": 190711,
        "voice": "vo_adv_2112010_019"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n那是",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "什麼聲音──",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "……是主人設置的",
        "unit_id": 191011,
        "voice": "vo_adv_2112010_020"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "魔力警報裝置。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "侵入者──",
        "unit_id": 191011,
        "voice": "vo_adv_2112010_021"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "有三人。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "很接近了……！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "是厄莉絲派來的追兵嗎！？",
        "unit_id": 190711,
        "voice": "vo_adv_2112010_022"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "嘿嘿，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "正好動一動幫助消化！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "等一下。",
        "unit_id": 107311,
        "voice": "vo_adv_2112010_023"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "這股氣息",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "似乎沒有敵意……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "望的聲音",
        "words": "不好意思──！",
        "unit_id": 1,
        "voice": "vo_adv_2112010_024"
    },
    {
        "type": "dialogue",
        "name": "望的聲音",
        "words": "\n有人在嗎──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌的聲音",
        "words": "雖然祕密基地的位置",
        "unit_id": 1,
        "voice": "vo_adv_2112010_025"
    },
    {
        "type": "dialogue",
        "name": "千歌的聲音",
        "words": "是以前製作人小姐告訴我們的……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌的聲音",
        "words": "\n但我們這樣",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌的聲音",
        "words": "擅自闖進來真的好嗎……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "紡希的聲音",
        "words": "現在是非常時期，",
        "unit_id": 1,
        "voice": "vo_adv_2112010_026"
    },
    {
        "type": "dialogue",
        "name": "紡希的聲音",
        "words": "不要這麼不知變通嘛，千歌！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2112010_027"
    },
    {
        "type": "background",
        "background": "500993"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……就是因為這樣！",
        "unit_id": 102913,
        "voice": "vo_adv_2112010_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們又跟大吾先生和真軌先生",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再次進行了舞台PK！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖說我本來，",
        "unit_id": 105411,
        "voice": "vo_adv_2112010_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n是很不想把關鍵任務交付給一個",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒品味的打赤膊男子就是了～",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "又在那邊放話了，妳這個臭粉紅女！",
        "unit_id": 190711,
        "voice": "vo_adv_2112010_030"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n想討架打是吧！！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "然而……",
        "unit_id": 107311,
        "voice": "vo_adv_2112010_031"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "若似似花和克莉絲提娜處於萬全狀態，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n想要搶下面具並且展開結界",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "想必是難如登天。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "還得感謝公主等人擔當馬前卒。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_2112010_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "突然接收到通訊魔法的時候我還嚇了一跳……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n幸好計畫",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "順利成功了☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是的～",
        "unit_id": 112711,
        "voice": "vo_adv_2112010_033"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還好我們的努力",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒有白費～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且也成功",
        "unit_id": 105913,
        "voice": "vo_adv_2112010_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將主人從厄莉絲的陷阱中救出來了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "太好了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "似似花也恢復原狀了，",
        "unit_id": 105213,
        "voice": "vo_adv_2112010_035"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "太好了呢～！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "各位，",
        "unit_id": 107011,
        "voice": "vo_adv_2112010_036"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "讓你們擔心了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你也辛苦了，真軌。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不！",
        "unit_id": 191011,
        "voice": "vo_adv_2112010_037"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "您千萬別這麼說！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "……真要追究起來，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n都是我護衛不力",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
