    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "竟然還會再增強？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n強到這個地步",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有點出乎意料之外呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不可以示弱。",
        "unit_id": 122011,
        "voice": "vo_adv_5092308_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "終結會",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "平等地造訪萬物。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "即使是",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "頑強的守護者也一樣。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "接下來就是",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "比毅力了。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那麼",
        "unit_id": 121911,
        "voice": "vo_adv_5092308_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們沒有理由會輸。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們可是有絕不屈服的精神，",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "以及",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "並肩作戰的夥伴啊。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不管過幾萬年，這個機械化的木人偶",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "都不可能超越我們！",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……呼，",
        "unit_id": 101411,
        "voice": "vo_adv_5092308_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "被妳說到這個份上，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要是不振作我就不配當偵探了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很好，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓我來揭露名為勝利的真相。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "寶藏守護者啊，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就在這裡劃下句點吧！",
        "unit_id": 101411
    }
