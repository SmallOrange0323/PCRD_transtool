    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "手裡拿著神祕書本、來到【伊麗莎白牧場】的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}──"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦～",
        "unit_id": 103311,
        "voice": "vo_adv_9002008_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天配送也辛苦啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "書？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是栞栞的包裹的啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真陽，",
        "unit_id": 103813,
        "voice": "vo_adv_9002008_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不是啦。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n今天是……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒錯沒錯，",
        "unit_id": 105213,
        "voice": "vo_adv_9002008_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "今天是那個日子對吧♪",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊、",
        "unit_id": 103311,
        "voice": "vo_adv_9002008_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊～！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大家明明就準備了這麼久，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n結果我卻忘記了最重要的老哥到來之日啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "栞栞，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝妳告訴我啊！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不，",
        "unit_id": 103813,
        "voice": "vo_adv_9002008_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那並不是什麼了不起的事……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "比起這個，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "鈴怎麼了呢？",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "明明那麼努力準備了。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "今天還沒有看見她，",
        "unit_id": 105213,
        "voice": "vo_adv_9002008_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "該不會一直在睡覺吧？",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "八成就是在睡覺啦。",
        "unit_id": 103311,
        "voice": "vo_adv_9002008_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "栞栞、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不好意思，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n去把鈴鈴",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "叫起床吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我知道了。",
        "unit_id": 103813,
        "voice": "vo_adv_9002008_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "鈴的房間裡大概",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n也有那個，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我一起拿過來唷。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "鈴～！",
        "unit_id": 105213,
        "voice": "vo_adv_9002008_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "重要的日子裡不許睡過頭啊～！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈，",
        "unit_id": 103311,
        "voice": "vo_adv_9002008_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "笨手笨腳的對不起呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥從那麼遠的地方走過來，應該累了的啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不如",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就泡個溫泉等一下吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "泡完澡後，喝個印有伊麗莎白牧場標記的牛奶，",
        "unit_id": 103311,
        "voice": "vo_adv_9002008_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "很美味喔～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你還有必須要去的地方呢。",
        "unit_id": 103311,
        "voice": "vo_adv_9002008_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "既然如此，還強留你就太不識相的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不過",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還是至少喝杯牛奶吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒什麼，",
        "unit_id": 103311,
        "voice": "vo_adv_9002008_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要說謝謝的是我這邊的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "畢竟一直受到老哥你的幫助嘛。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牧場快要被沒收的時候也是，",
        "unit_id": 103311,
        "voice": "vo_adv_9002008_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n真的承蒙老哥諸多照顧啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "能有現在的牧場",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "都是多虧了大家",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還有老哥的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不管我多麼想要報恩，",
        "unit_id": 103311,
        "voice": "vo_adv_9002008_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n感覺恩情也只是越積越多，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過能和大家、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n和老哥一直在一起的話，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就太幸福啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "久等了～",
        "unit_id": 102611,
        "voice": "vo_adv_9002008_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那個東西",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我帶過來囉～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳雖然一副理所當然的樣子登場，",
        "unit_id": 103311,
        "voice": "vo_adv_9002008_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但睡著了對吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "叫她起床真是太辛苦了……",
        "unit_id": 103813,
        "voice": "vo_adv_9002008_017"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "而且叫起床之後，她還不太能理解狀況。",
        "unit_id": 105213,
        "voice": "vo_adv_9002008_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好了好了，",
        "unit_id": 102611,
        "voice": "vo_adv_9002008_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這些細節就不要在意、不要在意。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "然後呢？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就是這本書對吧，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "借我一下喔。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "把這個這樣～",
        "unit_id": 102611,
        "voice": "vo_adv_9002008_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這裡就這樣～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "完成了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還給你吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要好好送到下一個地方唷。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥的話",
        "unit_id": 103311,
        "voice": "vo_adv_9002008_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不必擔心就是了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "路上小心。",
        "unit_id": 103813,
        "voice": "vo_adv_9002008_022"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "慢走唷～♪",
        "unit_id": 105213,
        "voice": "vo_adv_9002008_023"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在【伊麗莎白牧場】諸位成員目送中離去，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}邁步出發前往"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n下一個目的地。"
    }
]