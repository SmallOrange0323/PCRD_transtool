[
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "各位，",
        "unit_id": 16711,
        "voice": "vo_adv_5102321_000"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "你們來了啊。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "那麼……",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "雖然這場秀也可以就這樣直接開始，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "不過，我想要來點更有意思的演出。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "你們配合點吧！",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這是……！？",
        "unit_id": 123511,
        "voice": "vo_adv_5102321_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不僅劍在燃燒，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "舞台也被火焰包圍了……！？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "呵呵呵……",
        "unit_id": 16711,
        "voice": "vo_adv_5102321_002"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "因為觀眾們果然",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "會對盛大的表演反應熱烈啊。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "怎麼樣，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "你們喜歡嗎？",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "給我等一下，",
        "unit_id": 123711,
        "voice": "vo_adv_5102321_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "直播主不能自己搞炎上吧！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……呃，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "現在好像不是吐槽的時候。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這些火焰",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可能會很棘手喔……！？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果隨便靠近輝美閣下的話，",
        "unit_id": 123711,
        "voice": "vo_adv_5102321_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "說不定會被火灼傷的！！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "像這種狀況，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "從後面用魔法之類的攻擊……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呃，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "智閣下！？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我打頭陣！",
        "unit_id": 123611,
        "voice": "vo_adv_5102321_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n七七香你們掩護我！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……看來我也阻止不了妳吧。",
        "unit_id": 123711,
        "voice": "vo_adv_5102321_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "知道了！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳就盡情攻擊！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我會用魔法掩護妳的！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……我不會魔法，",
        "unit_id": 123511,
        "voice": "vo_adv_5102321_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我就先在後面替你們助陣吧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "智，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "七七香，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "加油～",
        "unit_id": 123511
    }
]