        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "仔細一看，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你是最近剛開的雜貨店那位……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "沒錯沒錯！",
        "unit_id": 414,
        "voice": "vo_adv_1098007_078"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n最近你們很常來買東西對吧？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "所以有關於你們的事，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "我應該也還算",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "清楚。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "請別隨便過來搭話。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_079"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "啊，",
        "unit_id": 414,
        "voice": "vo_adv_1098007_080"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "畢竟我這樣算是亂入。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "真不好意思。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n哎呀，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "因為來吃午餐時偶然聽到你們的對話。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "想說這個我得來附和一下才行。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "你們的夥伴啊，",
        "unit_id": 414,
        "voice": "vo_adv_1098007_081"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "人真的是有夠好的～",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "你們很常混在一起對吧？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "只不過因為太溫柔了，",
        "unit_id": 414,
        "voice": "vo_adv_1098007_082"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "讓我有點擔心。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n所以我就對她們說多少要去懷疑一下別人會比較好。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "因為我知道經商的世界有多嚴酷，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "算是稍微",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "給一點忠告吧？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "結果啊、",
        "unit_id": 414,
        "voice": "vo_adv_1098007_083"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "她們很有禮貌地",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "對著我說──！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "感謝您這麼替我們著想，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "但是，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "在下幾人想要",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "維持這樣就好……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "居然這樣回答。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_084"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我腦海裡，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能浮現出那個景象。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不如說這以外的回答還比較難想像呢。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_085"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "如果有貼錯的折價貼紙也會跟我說。",
        "unit_id": 414,
        "voice": "vo_adv_1098007_086"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "而且這陣子，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "你們不是又多了些新人嗎？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "新人？",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_087"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "銀色長髮的女孩，",
        "unit_id": 414,
        "voice": "vo_adv_1098007_088"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "跟一位長得與妳很像的女僕。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "該說是物以類聚嗎。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "這兩位也都是超級大好人啊。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "我有試過故意多找錢給她們，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "結果都有好好地還回來。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "到了這種地步反而會讓人開始擔心對吧？",
        "unit_id": 414,
        "voice": "vo_adv_1098007_089"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "善良過頭，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "會讓人懷疑是不是有什麼內幕……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "之類的。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "別看我這樣，",
        "unit_id": 414,
        "voice": "vo_adv_1098007_090"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "我可是很敏銳的。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "那些新人們，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "實在是無法讓人信任。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "要小心點啊。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n搞不好是裝成夥伴拉攏你們，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "等到取得信任後……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "凱留、拉姆",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_1098007_091"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "咦……",
        "unit_id": 414,
        "voice": "vo_adv_1098007_092"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "兩位，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "表情怎麼那麼認真。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "我，說了什麼奇怪的話了嗎？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……大叔。",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_093"
    },
    {
        "type": "dialogue",
        "name": "凱留、拉姆",
        "words": "「我宰了你哦！」\n「好大的膽子。去死吧。」",
        "unit_id": 1,
        "voice": "vo_adv_1098007_094"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "欸！？",
        "unit_id": 414,
        "voice": "vo_adv_1098007_095"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你這個外人，",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_096"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又懂她們的什麼了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你要是在繼續亂說下去我可不饒你！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "或是讓拉姆來把你這張亂說話的嘴給縫起來。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_097"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "至少，",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_098"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "像你這種明明在做生意，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n卻會說客人壞話的傢伙是沒有人會信任你的。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n今天可能是拉姆最後一次看到你這張骯髒臉了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "咦、",
        "unit_id": 414,
        "voice": "vo_adv_1098007_099"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "咦咦咦咦？？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "話說回來……",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_100"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "居然會有人內心這麼下流。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "肯定每天都過得很空虛。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n啊啊，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真可憐。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是說啊，",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_101"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是可憐的傢伙！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "啥……！",
        "unit_id": 414,
        "voice": "vo_adv_1098007_102"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n我只是附和一下妳們說的話而已，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "為什麼要被妳們罵成這樣～！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "還不想死就快消失吧。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_103"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n別再張開你那張臭嘴呼吸了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "嗚",
        "unit_id": 414,
        "voice": "vo_adv_1098007_104"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "嗚……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n我才不會再跟妳們說話～～！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你別再出現了！",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_105"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼！",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_106"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "凱留，",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_107"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那種傢伙連目送他離開的價值都沒有。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "比起這個，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "餐點快冷掉了。",
        "unit_id": 109811
    },
    {
        "type": "still",
        "still": "109800701"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_108"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來吃吧來吃吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n再來加點個東西。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不好意思～！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我啊～",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_109"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很喜歡這裡的燉煮料理。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然好像不是什麼人氣品項就是了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "妳在說什麼。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_110"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n來到這裡卻不吃燉煮料理，這根本就不可能。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒錯！",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_111"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說得真對。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我搞不懂為什麼大家都不點。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
