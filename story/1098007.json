[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，在採買結束後順道繞去餐廳的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n拉姆與{player}。"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……\n……",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_000"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不是。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_001"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n雖然不及雷姆親手做的料理，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "但是很好吃。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……\n……",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_002"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆只是，",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_003"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "在認真地品嘗餐點而已。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "還是說，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這樣做在這個世界裡很不可思議嗎？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_004"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "自從那次跟蹤以來，",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_005"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆偶爾會像這樣觀察這個男人。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "還是一樣那麼濫好人，",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_006"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "過度的博愛主義者。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n而且，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "老實到像個笨蛋一樣。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "如果要再補充的話，",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_007"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那就是還有花心大蘿蔔的一面。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "儘管如此，",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_008"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這個城鎮上的居民",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n似乎都非常喜歡這個男人。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆完全無法理解。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_009"
    },
    {
        "type": "dialogue",
        "name": "拉姆、？？？",
        "words": "……唉。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_010"
    },
    {
        "type": "dialogue",
        "name": "拉姆、？？？",
        "words": "隔壁也傳來了嘆氣聲？",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}！",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有拉姆！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們在這裡做什麼。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "用看的就知道。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_013"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n在吃東西。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這麼多餐廳居然會進到同一間，",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_014"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "還坐在隔壁的座位。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是啊。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_015"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "感覺有點不太自然呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "該不會……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "難道說，凱留。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_016"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n妳喜歡拉姆嗎？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啥啊啊！？",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說到底如果我知道你們在這，",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就不會坐在隔壁了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞不好甚至",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不會進來這間店吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "如果不是追著拉姆跑的話不可能會這麼巧。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_019"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n誠實一點吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唯獨妳，我才不想被妳這麼說呢。",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……{player}你、",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你怎麼了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一直盯著我們兩個看。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道臉上有沾東西嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說我跟拉姆很像？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留、拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_023"
    },
    {
        "type": "background",
        "background": "500333"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總覺得",
        "unit_id": 105911,
        "voice": "vo_adv_1098007_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位好相像呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "拉姆、凱留",
        "words": "哪裡像（啊！）",
        "unit_id": 1,
        "voice": "vo_adv_1098007_025"
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我想起來了。",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是在跟貝特魯吉烏斯戰鬥的時候……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是不實指控啦。",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我跟她何止不像，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本是完全相反好嗎！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n混在一起很危險，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就連接近都很危險！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說對吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拉姆。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這次拉姆也同意妳。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_028"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "跟凱留混在一起會讓拉姆的格調降低的。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆在用餐時可不會像凱留一樣不解風情地嘆氣。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是說那個！？",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對妳也一樣有嘆氣吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那只是，",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_031"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "說了一聲唉而已。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n不是嘆氣。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……這到底是。",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n什麼道理啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳的話我完全無法理解！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一點都不像！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我跟妳絕對不像！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雖然凱留要用什麼表情吃飯跟拉姆一點關係也沒有，",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_033"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "但如果在隔壁像那樣大聲嘆氣的話會讓飯變難吃的。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n原來凱留妳也會有煩惱啊。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "反正一定是有關你們公會的事吧。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_034"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n因為你們明明吃飯時幾乎都一起吃，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n這次卻很稀奇地分頭行動。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳的直覺好到讓人有點火大……",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說得沒錯。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你問說發生了什麼事，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……其實啊。",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是貪吃佩可她又，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "隨口答應接下了委託。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "狩獵來的魔物隨便妳吃，",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以免費幫忙驅除吧～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n像這種委託，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她很輕易地就接下來了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "實際上，",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種委託也開始逐漸增加。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "工作就是工作啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該拿的報酬還是得拿。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再這樣下去",
        "unit_id": 106012,
        "voice": "vo_adv_1098007_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "【美食殿堂】會變成一個無償公會的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好人做過頭反而害到自己的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總有一天會經營不下去。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "原來如此。",
        "unit_id": 109811,
        "voice": "vo_adv_1098007_041"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n以凱留來說還真是正常的煩惱呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
