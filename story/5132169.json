[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "12月25日，聖誕節當天終於到來。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在外出的人群還不多的清晨，克蕾琪塔獨自前去進行最後一次巡視。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……終於來到這一天了呢。",
        "unit_id": 128011,
        "voice": "vo_adv_5132169_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐──！",
        "unit_id": 127911,
        "voice": "vo_adv_5132169_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "早安──！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛、",
        "unit_id": 128011,
        "voice": "vo_adv_5132169_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "早安！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "距離派對開始時間還很久不是嗎……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿，",
        "unit_id": 127911,
        "voice": "vo_adv_5132169_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實是",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "昨天發生了很多事……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "於是",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我睡不著覺",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就直接過來了。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 127911,
        "voice": "vo_adv_5132169_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}也很平安哦。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想他一定會趕上派對的。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您口中的「很多事」讓人十分惶恐，",
        "unit_id": 128011,
        "voice": "vo_adv_5132169_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但現在就暫且不追問了。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那個，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "冒昧請教您一件事，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您對今天的聖誕節",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是否感到不安呢？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不安",
        "unit_id": 127911,
        "voice": "vo_adv_5132169_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是嗎……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的確，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是無法阻止小律",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那該怎麼辦，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓人",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不禁有這種想法。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 127911,
        "voice": "vo_adv_5132169_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "以克蕾琪塔小姐為首的",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為我完全實現了理想中的聖誕節不是嗎！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "烹煮了許多美味的料理，",
        "unit_id": 127911,
        "voice": "vo_adv_5132169_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "企劃了有趣的活動，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且慈樂之音的兩人也願意特別參加，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n咲戀小姐還帶來了好多小孩子們。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "光是用想的",
        "unit_id": 127911,
        "voice": "vo_adv_5132169_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我心中就已經爆發出期待，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不安全都消失得無影無蹤了☆",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "原來如此……",
        "unit_id": 128011,
        "voice": "vo_adv_5132169_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我完全明白了。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那麼我也會",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "全心全意享受這次聖誕節的！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "話是這麼說……",
        "unit_id": 128011,
        "voice": "vo_adv_5132169_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "其實我",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不太清楚要怎麼享受聖誕節。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "畢竟我一直都在經商中度日。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然前些日子",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "少年告訴過我一些就是了。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這",
        "unit_id": 127911,
        "voice": "vo_adv_5132169_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "令人有點意外呢。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我一直以為像克蕾琪塔小姐",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣的成熟女性",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n很清楚該如何度過美妙的聖誕節。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過老實說，",
        "unit_id": 127911,
        "voice": "vo_adv_5132169_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為我也算是皇族一員，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對大家所說度過聖誕節的方式",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並不熟悉。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因此，",
        "unit_id": 127911,
        "voice": "vo_adv_5132169_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "每次聽到大家的描述，都讓我感到",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像很開心、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又羨慕，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "以及憧憬。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以說",
        "unit_id": 127911,
        "voice": "vo_adv_5132169_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天一定會成為在我心中",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n第一次也是最棒的一次聖誕節。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "同為初學者，",
        "unit_id": 127911,
        "voice": "vo_adv_5132169_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就讓我們一起同樂吧，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐☆",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好、",
        "unit_id": 128011,
        "voice": "vo_adv_5132169_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好的！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那當然！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我克蕾琪塔‧凱許，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n將會全心全意享受的！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我知道您很開心，",
        "unit_id": 6111,
        "voice": "vo_adv_5132169_018"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "但大清早就過度興奮",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n會對周遭的人造成困擾，還請您克制。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哼，",
        "unit_id": 128011,
        "voice": "vo_adv_5132169_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "說這種話的妳不也一樣期待得睡不著覺嗎？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "抱著期待一事我並不否定，",
        "unit_id": 6111,
        "voice": "vo_adv_5132169_020"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "可是我一大早就陪著",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n工作狂般的上司，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "請您好好感謝我。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "知道了知道了，",
        "unit_id": 128011,
        "voice": "vo_adv_5132169_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是謝謝妳哦。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈☆",
        "unit_id": 127911,
        "voice": "vo_adv_5132169_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "站著說話也不太方便，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "找個地方吃早餐",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n再一起巡視會場吧！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不錯呢。",
        "unit_id": 6111,
        "voice": "vo_adv_5132169_023"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "就讓您請客了，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……妳啊，",
        "unit_id": 128011,
        "voice": "vo_adv_5132169_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是不是把我當成錢包看待了？",
        "unit_id": 128011
    }
]