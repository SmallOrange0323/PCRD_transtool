[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "圍繞在璃乃心中的情感爆發了出來。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n姐妹之間也因此產生了誤解，然後──"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "…………",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我說了",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "很過分的話呢。",
        "unit_id": 101112
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "「羈絆」什麼的──",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "根本打從一開始就不曾有過嘛！",
        "unit_id": 101112
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……我明明",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒有打算說出那種話的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是，",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒辦法提升力量……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就表示是",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼回事對吧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "自從第一天失敗的那時起，",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我就一直感到很不安。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個實驗沒成功的話，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那意味著什麼，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這個不安一直盤踞在我心中。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我和姐姐之間……",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "根本沒有所謂的",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "羈絆存在。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們既不像親生姊妹般有血緣關係，",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "即使作為祕密結社的夥伴，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐一個人也什麼事都辦得到。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "到底……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "算什麼呢……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "察覺到這點的我……",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "下意識就",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對姐姐……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "…………",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……我必須",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "變得更強才行。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就算沒辦法透過羈絆提升力量。",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我至少",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也要努力變強，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "變得能和姐姐並肩作戰。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n現在不是垂頭喪氣的時候了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n既然決定了，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就要金星姐力地努力囉～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "金星姐力？",
        "unit_id": 106815,
        "voice": "vo_adv_1811003_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "金星……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "難不成是",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "盡心竭力",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗎……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n真佩服靜流",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以每次都馬上知道妳要說什麼……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "公會長？",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n怎麼了嗎……？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗨，",
        "unit_id": 106815,
        "voice": "vo_adv_1811003_016"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "璃乃。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很抱歉，我知道妳有事在身，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但我還是想請妳",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "幫忙處理一下",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "祕密結社的工作。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊……",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就只有……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我一個人嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對，",
        "unit_id": 106815,
        "voice": "vo_adv_1811003_018"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只有璃乃一人。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n別擔心，只是想請妳幫忙討伐一點魔物而已。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……能拜託妳嗎？",
        "unit_id": 106815,
        "voice": "vo_adv_1811003_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好的，",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當然沒問題！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我好歹也是",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "【拉比林斯】的一分子！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n舉頭過勞！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳是想說「舉手之勞」",
        "unit_id": 106815,
        "voice": "vo_adv_1811003_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對吧？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，璃乃。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n雖然地點距離蘭德索爾有些遙遠──",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "──我都記住了！",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "正好。",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n一個人完成任務，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "拿出自信",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "去向姐姐報告吧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那就",
        "unit_id": 106815,
        "voice": "vo_adv_1811003_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "麻煩了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n交給妳囉。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好的！",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n包在我身上──",
        "unit_id": 101112
    },
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "──雖然我保證的那麼有自信～",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是不管那邊……",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_027"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "…………",
        "unit_id": 10111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還是這邊……",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_028"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "…………",
        "unit_id": 10211
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "怎麼都有",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "超大隻的怪物駐守啦～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個地方",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是怎麼回事啊……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n很明顯的不太尋常吧……！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這哪叫一點魔物啊，",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "公會長！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這要我一個人解決",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "絕對沒辦法啦……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要是有姐姐在……",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_031"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……不。",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我不是才下定決心",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_033"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要努力變強嗎！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n倒不如說，任務越難越好！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "順利完成任務，",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "得到姐姐的認可，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "並且讓姐姐對我說出",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "「璃乃，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我的背後就交給妳囉」……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……要是可以",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "變成那樣就好了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如此一來……",
        "unit_id": 101112,
        "voice": "vo_adv_1811003_035"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們的羈絆應該也會變得更強韌才對。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以──！",
        "unit_id": 101111,
        "voice": "vo_adv_1811003_036"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 3
