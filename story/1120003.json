[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "將騙子交給了王宮騎士團的{player}與凱留，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在前往美食殿堂的公會小屋途中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n注意到了貼在佈告欄上的傳單。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n怎麼了啊？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "突然停下來。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "公會管理協會主辦的",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "新年題字大會的公告？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟是過年啊，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "新年題字沒什麼好稀奇的吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "叫我看獎品？",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n獎品是……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "特大招財貓？　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想要這種東西嗎？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種東西只會佔空間吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說是這麼說，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又覺得特大招財貓",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有點可愛……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n其實還滿想放在",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "公會小屋的。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真、",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真拿你沒辦法耶！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n既然你想要特大招財貓的話，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就來幫你吧！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "加油！　",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "個頭啦，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你也要參加啊。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這是理所當然的吧？",
        "unit_id": 112011
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了。",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n新年題字的用具都備齊了，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要開始囉！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還問",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "開始什麼。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "當然是新年題字……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對喔。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你根本連新年題字是什麼都不知道呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我來示範給你看，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你看好了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "首先是",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像這樣子沾墨水，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n然後用筆寫下今年的目標。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要注意紙張有正反面。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？　",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哪邊才是正面呢？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我記得",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是光滑的那一面才對！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n嗯，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有錯！　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一定是！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要來寫字囉。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要寫什麼呢？　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "保守一點寫",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全家平安",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "之類的？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之就先寫那個吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全、",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "家、",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "平、",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "安……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "完成了！　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如何？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你、",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你那是什麼眼神啊！　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你想要說我寫得很差嗎？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那也沒辦法啊！　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我一直過著像流浪貓一樣的生活，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以沒學過要怎麼寫出漂亮的字啊！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我都已經示範給你看了，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你也快點寫吧！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "光是有兩個人參賽，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就能提高特大招財貓到手的機率了！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "回答得很好，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是這種氣勢！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我雖然沒對你抱持期待……",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但你果然",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也寫得很差呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還說什麼",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對不起。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這不是需要道歉的事情吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你只要努力練習，變厲害就好了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我就是為了這個目的才買來這麼多的紙啊。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "相對的，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可不允許你放棄……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但我想",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你也不會那麼做吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總之，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "盡力去做吧！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯──",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然跟一開始比起來好多了，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但總覺得不太行啊──",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我覺得",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你也進步滿多的喔？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我寫得很差，由我來說也沒什麼說服力就是了……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別露出那麼高興的表情！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你寫得還很差啦！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趕快再重新開始練習吧！",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你看，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "寫好了寫好了！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "點、",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "鉤、",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "撇",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是很重要的部分吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "光是注意著這些地方書寫，寫出來的字就很不一樣了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你問我",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是什麼嗎？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我來教你，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之你先寫吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒錯，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是撇。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那邊是點。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就是鉤喔。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n…………",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大概。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也沒辦法嘛，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這只是聽來的知識啊。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "仔細看著你書寫之後，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總覺得我好像懂了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓我示範一下喔？",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_027"
    },
    {
        "type": "still",
        "still": "112000301"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大概是",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡要這樣寫，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該會比較好看吧……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再來，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡要",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？　",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯──",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是很順利呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明在旁邊看的時候，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺好像已經懂了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再來一次。",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡要",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好好停住。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡是",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "順順地撇過去。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡則是",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "往上面",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "勾起來的感覺，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接著是停……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃！？",
        "unit_id": 112011
    },
    {
        "type": "still",
        "still": "112000302"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道啦！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "筆、",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "筆滑了一下啦！",
        "unit_id": 112011
    },
    {
        "type": "still",
        "still": "112000302"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒、",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒錯，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我突然打了個嗝！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真、",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真傷腦筋呢！　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難得寫得很順的說！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n唔、",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎、",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼辦。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n仔細一想，這個姿勢",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就和抱住他沒什麼兩樣啊！　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且這傢伙還一臉沒事的樣子。",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好歹也給我稍微不知所措一點啊……！　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉～～",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就我一個人在那邊瞎忙，跟傻瓜一樣。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你不用特地回答我也知道啦！",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在寫出滿意的字之前，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就這樣繼續練習吧！",
        "unit_id": 112011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "非常",
        "unit_id": 311,
        "voice": "vo_adv_1120003_038"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "感謝",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "各位踴躍參加！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那麼，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "新年題字大會",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就在此告一段落！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "明年",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "也請各位",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "踴躍參加！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然已經非常努力去寫了，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但光靠臨時抱佛腳，是沒辦法得到特大招財貓的呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正參加獎得到的招財貓護身符也滿可愛的，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就這樣吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦！？",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是、",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啊……！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽你這麼一說，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這的確是一樣的呢……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "本來是想帶在身上的，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但跟他一樣又有點害羞？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應、",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該也沒有人會去在意那種事吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒問題。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒問題的！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啊。",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n努力過的事情化為了實際成果，這種感覺真的很不錯呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？　",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很開心能和我擁有一樣的護身符？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你突然在說些什麼啊……！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢、",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也不能不愛惜東西呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我會好好珍惜這個護身符的，",
        "unit_id": 112011,
        "voice": "vo_adv_1120003_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你也別弄丟囉？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "凱留這麼說道，\n並溫柔地握住了護身符。"
    }
]