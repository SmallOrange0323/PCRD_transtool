[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "路人",
        "words": "不好意思。",
        "unit_id": 311,
        "voice": "vo_adv_1022005_000"
    },
    {
        "type": "dialogue",
        "name": "路人",
        "words": "\n請問這附近有武器店嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸欸！？你、你在問我嗎？",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，那個……欸……！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "路人",
        "words": "啊啊，不知道的話沒關係。",
        "unit_id": 311,
        "voice": "vo_adv_1022005_002"
    },
    {
        "type": "dialogue",
        "name": "路人",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "路人",
        "words": "我去問別人。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，真是的！我明明就知道武器店！",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n為什麼我沒辦法好好回答呢！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "為什麼我沒辦法和別人好好地交談呢？",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n特別是男性的話幾乎說不好話……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n可以正常對話的男生，大概只有那傢伙了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦？等等！",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n仔細想想，我和那傢伙說不定也沒能好好地說話？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我從來也沒能好好地向他道謝……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊啊啊啊",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我真是，太沒用了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚哇！什、什麼！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n有什麼東西掉到臉上了！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "噗哈！",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n……搞什麼，是傳單啊。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "被風吹過來的嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好像是委託的傳單……上頭寫了什麼呢？",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n希望有人幫忙摘取「真實果實」？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸！？吃了之後會一段時間內不能說謊！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "竟然有這種東西！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n嗚哇！報酬的金額也好驚人！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……不對，比起報酬這個「真實果實」更重要！",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_011"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有這個的話，或許我也能坦率地道謝！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "既然這裡有寫哪裡可以採集，",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我立刻就去看看……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，可是一個人去感覺有點不安……",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可是又沒有可以拜託的人……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "――啊！對了！",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_014"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "讓、讓你幫忙真抱歉啊。",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_015"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n因為有個報酬很高的委託。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n委託內容只要找一種果實就好了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "很簡單吧？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "找想道謝的對象來幫忙，",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_016"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n好像有點奇怪……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過我也沒有其他可以拜託的人了，這也沒辦法。",
        "unit_id": 102211
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "找到了嗎？",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_017"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這裡也完全沒看到呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯～好奇怪喔。",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_018"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n傳單上確實寫的是這一帶啊……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你等一下，我再確認一次傳單內容。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……嗯，地圖沒有錯啊。",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_019"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "果然是這附近――",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸？什麼？",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_020"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這個傳單怎麼了嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸欸！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_021"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這是最近到處流傳的惡作劇傳單！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這個委託是騙人的！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n那「真實果實」也是騙人的囉！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎、怎麼會這樣……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……嗯，",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是啊。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n比起報酬，其實我想要的是果實。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "才不是呢！",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我想要的是「真實果實」！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我原本還想說，",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_025"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n那果實非常適合解決我的煩惱……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸？找到果實之後要做什麼？",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_026"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那當然是自己吃了，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n然後跟你道謝――",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇，為什麼套我的話啊！",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "要拿去做什麼，是我的自由吧！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不要問奇怪的問題！",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_028"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我要回去了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真、真是的！該說那傢伙不懂少女心，",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_029"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n還是太遲鈍呢……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "…………太、太暗了不知道路怎麼走。",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_030"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "幹嘛呆著不動！",
        "unit_id": 102211,
        "voice": "vo_adv_1022005_031"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這座森林那麼陰暗，自己一個人的話會很害怕呀！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n好啦，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們快回去吧！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "回程也完全依靠{player}，\n但依里依舊無法好好道謝。"
    }
]