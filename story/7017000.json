[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "來到露娜之塔的{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而在他身旁，還有另外一人的身影。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還以為你打算",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "穿過這茂密的森林去哪裡……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n沒想到在這種地方還有遺跡呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼，",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你好像有話想說啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和像我這樣的大美女約會，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你可以再開心一點唷♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你小子總是被捲入各種事件，",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那只要跟著你，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不就可以遇上有趣的事了嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再加上",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個遺跡",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n沉眠著小子你的記憶之鑰對吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的直覺",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "告訴我，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "絕對會發生什麼事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好吧，",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "講白一點是這樣沒錯……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別說這種潑冷水的話嘛，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這可是難得的約會。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要開口的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真希望你能講句情話給我聽呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊～",
        "unit_id": 100811,
        "voice": "vo_adv_7017000_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "累死我了！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "渾身是汗",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "加上腳痛、",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "行李又重得要命……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我可沒聽說是在這種森林深處啊。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呃、",
        "unit_id": 100811,
        "voice": "vo_adv_7017000_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來得正好！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可以幫我拿一下行李嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嘿咻。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這個？",
        "unit_id": 100811,
        "voice": "vo_adv_7017000_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這些是我蒐集的魔導具唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n比方說妖精製作的水晶高跟鞋、",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "掌管永恆之美的靈草等等……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都是循著童話或傳說找到的哦。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很辛苦唷？",
        "unit_id": 100811,
        "voice": "vo_adv_7017000_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "翻山",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "跨海……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n還跑到森林的這麼深處。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "害我還迷路了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼回事？",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "突然冒出來一個人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳是誰？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是小子認識的人嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "果然，",
        "unit_id": 100811,
        "voice": "vo_adv_7017000_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美麗的事物在我手中才能互相輝映。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這樣我不就會",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "更加地登峰造極嗎……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我是多麼罪惡深重的存在呀……！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟敢忽視我克莉絲提娜大人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是吃了熊心豹子膽啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 100811,
        "voice": "vo_adv_7017000_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是不是真貨要用過才會知道呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "然後啊，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "接著是要找聽說在這附近的遺跡……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哼！",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_013"
    },
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦？",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "反應不錯快嘛。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈☆",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒事，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就覺得她是不是",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n沒把我放在眼裡嘛。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想說如果睡迷糊了的話，",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那我就讓她清醒一點而已啦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "克莉絲提娜姐姐開個小玩笑罷了♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳再這樣下去的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可能會不小心失手喔……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過對我來說",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那樣也不錯",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼了嗎？",
        "unit_id": 100811,
        "voice": "vo_adv_7017000_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這麼熱情的看著我。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "難道妳……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看我看入迷了嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也難怪，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為我實在太可愛了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好，",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "吃我一劍。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯？",
        "unit_id": 100811,
        "voice": "vo_adv_7017000_020"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼了嗎？{player}。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n看起來這麼慌張。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "喔，",
        "unit_id": 100811,
        "voice": "vo_adv_7017000_021"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我忘了自我介紹呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我叫做雪。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "今後請多指教。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "然後啊，",
        "unit_id": 100811,
        "voice": "vo_adv_7017000_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "姐姐。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n如果妳願意把劍收回去就幫大忙了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "假如傷到我的肌膚，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "事情就很嚴重了唷？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦？",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這傢伙……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在喉嚨被劍指著的狀況下",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還能不為所動？　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有趣……",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我來試試她。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼了，",
        "unit_id": 107111,
        "voice": "vo_adv_7017000_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不願意的話，妳也拔出武器來吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不要讓我等太久嘛，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
