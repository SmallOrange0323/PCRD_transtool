[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "歡迎光臨～♪",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不好意思，現在還不到開店的時間哦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們是居酒屋……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n基本上晚上才開始營業。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是您先預約的話，我們就會替您保留座位。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n請晚上再過來，麻煩您了～♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉呀，這不是{player}嗎？\n",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你好啊～♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎～麼啦，到我們的店裡有什麼事？",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還是說，找我有事嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過啊，我的直覺告訴我，",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n唔嗯，你是偶然進到店裡看見我在才嚇了一跳對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊哈哈，這真是巧遇呢～♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這裡是我家。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "二樓是住家～",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我就睡在那裡。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n一樓是居酒屋，我偶爾也會被叫來幫忙哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "基本上是我的父母在經營居酒屋。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我白天到黃昏都有【哞哞自衛隊】的工作，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n晚上回來之後就當居酒屋的服務生。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在年底有很多聚餐酒會的時期，",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就會向【哞哞自衛隊】請假……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n所以也會有在這裡工作一整天的情形。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真的是每天每天都好忙♪",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊哈哈。也不會辛苦到讓我累倒的啦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n【哞哞自衛隊】的工作悠閒又輕鬆，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n而且居酒屋的生意也沒有多興隆。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n最近這附近的大型連鎖店越來越多了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n對我們家這種私人經營的小居酒屋可是大危機哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過我們也有常客，所以不至於馬上面臨停業。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過經營上是有點困難～也沒錢雇用打工的人哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n所以啊，就只能讓身為女兒的我來工作了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。我現在在做開店前的準備哦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n差不多不到一個小時就要開店了，我正在打掃店裡……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以抱歉了，還不能進來哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我有點粗手粗腳～",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不太擅長打掃之類的事。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是你在旁邊我就沒辦法專心，",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n總覺得會不小心弄壞什麼東西。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不過我可不是把你當成礙事的人哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "謝謝你啦，不過你有這個心意就夠了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "交辦給我的工作，",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要是不自己做完就會渾身不自在的啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我的個性就是這樣。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦？",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n啊……嗯，謝謝你啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這是在誇獎我對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，應該還有其他說法吧……",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n說我「很努力」，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總覺得被當成小孩，讓我感覺很微妙啊～？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "欸，說我「會成為一個好妻子」？",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n是、是嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～你的用詞遣字還真的很微妙啊～？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，算了。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總之……你原本來這裡有什麼事？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呵，在找吃晚飯的店啊。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n所以就這樣偶然發現然後走進我們這家店了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原來如此～我懂了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那麼剛剛好。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你就在我們這裡吃晚飯吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我的員工餐做的太多了呢。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我一個人吃不完，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不介意的話你也一起吃吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我不會跟你收錢，因為這是用剩菜剩飯做的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，不要客氣哦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這也算是報答你幫了優衣。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在這裡吃我們提供的飯菜，",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n比起花錢去其他店吃的還要好上幾百倍呢♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過這是我做的料理，可不要太期待味道哦？",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，那邊坐吧。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我現在就去準備餐點之類的給你。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哼哼。",
        "unit_id": 104311,
        "voice": "vo_adv_1043002_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們店的服務很好吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要是你想變成常客也行喔～{player}♪",
        "unit_id": 104311
    }
]