[
    {
        "type": "background",
        "background": "500120"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "打擾了。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n起床時間到囉。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，您睡醒了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喔呀，還在熟睡中呢。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，貪睡鬼……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "開始在【咲戀育幼院】過夜，",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也不過才幾天而已……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "枕頭和床都還沒習慣吧。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不過發生了許多事情，主人一定也累積了不少疲勞。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然今天也沒什麼要緊的事情，",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也想讓主人盡情放鬆地睡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是紊亂的生活步調是不健康的，",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【咲戀育幼院】的夥伴為我們所準備的早餐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也都快冷掉了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下還是狠下心來，把主人叫起來吧。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "醒醒啊，主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，叫不起來呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是讓人困擾的主人。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一個人叫不起來的話……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就讓在下也一起鑽到被窩裡睡比較好吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由於主人喪失記憶……",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n即使說主人跟嬰兒沒兩樣也不為過。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像在下這樣的監護人，",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從早到晚都有必要照顧好主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……絕對不是因為在下一個人睡很寂寞的關係。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，您剛才是不是在偷笑？",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難道早就醒了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，您果然已經醒了啊。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您還在睡……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼搔您癢也不會有反應吧。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為主人還在睡嘛。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咕嘰、咕嘰……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是的，您果然是在裝睡呀。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n叫您起床又不起來的話，在下很困擾的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是棘手的主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n早安，主人……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉，您還沒睡飽就勉強叫醒您。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是讓您感到不悅，請懲罰在下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人若是能早睡早起、健康生活的話……",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了達成這個目的，在下就算犧牲小我也在所不辭。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論被您如何虐待，在下都樂於接受。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說什麼！？",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主、主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您睡糊塗了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼要抓著在下的肩膀，把臉靠近呢……？",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也覺得一個人睡很寂寞嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在、在下也是……",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是這樣的，那個？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下很困擾的，該怎麼做才好？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要、要接吻嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就是所謂的早安之吻嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀……",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦，額頭？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為什麼要和在下額頭碰額頭呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼？",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下發燒了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，您是為了確認這個啊。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來剛剛謎樣的肌膚之親還有這樣的用意啊……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。在下也累積了不少疲勞，",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n說不定因此搞壞了身體，這真是在下一生的敗筆啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "傳染給主人就不好了，在下先告退了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇哇……？　",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，為什麼要將在下抱起來呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人把在下抱到您的床邊、溫柔地放到床上……",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還給在下蓋被子、摸摸在下的頭……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問，這究竟有什麼用意？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下睡在主人的床上沒關係嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說在下既然把身體搞壞了，就需要安靜地休養……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，感謝主人這麼關心在下……",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是如此，在下就回到自己的房間休息好了？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下不過是著了點風寒～這種輕微的程度罷了。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並沒有嚴重到不能走路。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且在下的感冒病菌還會因此留在主人的床上。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……啊，主人",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼也沒說明，一個人不知道跑去哪裡了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以聽到主人從遠方傳來的聲音……",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是去叫【咲戀育幼院】",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n的人過來的樣子呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像是打算請她們拿藥給在下、照顧在下的樣子。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，主人果然很溫柔呢……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但該說主人有點離題還是沒說清楚，現場一片混亂呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人對在下的關心，在下實在愧不敢當。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，這張床還留著主人的餘溫呢……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在、在下覺得很安心，而且開始有點睏了。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下最近一直都是一個人睡，",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n果然是很寂寞呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為睡不好而睡眠不足。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也因為這個緣故才把身體搞壞的呢。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就像小孩子一樣呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下覺得羞愧，作為『嚮導』真是失職。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是……即使是這樣不爭氣的在下，",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人也絕對不會拋棄在下呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人總是溫柔地對待在下、珍惜在下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻。",
        "unit_id": 105913,
        "voice": "vo_adv_1059005_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能伺候這樣的主人，在下真是幸福的人♪",
        "unit_id": 105913
