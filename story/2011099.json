[
    {
        "type": "background",
        "background": "510270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞，",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看家就麻煩妳囉？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為我現在要從索爾之塔下去，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "前往『王宮』了！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "咦咦……",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_001"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n等、",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "等一下啊菲歐？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n怎～麼了呀，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "突然那麼慌張？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "再說，",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_002"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你去到外面沒問題嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我們現在",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "只是為了避免被世界「再構築」，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n而勉強地維持的",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "虛幻存在不是嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "只要外出就會被當做是Bug，",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_003"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "或許就會被這世界消除喔？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那邊還有著類似淘汰機制的東西，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n就連能存活多久都不知道呢～？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "『闇影』也算是Bug，",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_004"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "但似乎還能正常地……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "存在一段時間呢。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不過，那個",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "或許是被什麼人故意弄成那樣子的？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在那種事怎樣都好！",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果不快點過去的話，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一切就會開始毀滅的……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "冷靜點，",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_006"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "揍妳喔！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呀～！？",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真過分，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還真打下去了呢，涅比亞？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "連媽媽都沒這麼打過我呢！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我們的媽媽是誰啊，",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_008"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "米奈娃大人嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "話說",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_009"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "很久都沒見到米奈娃大人了呢～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好像可以從那個裝置般的東西",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "進到競技場系統玩的樣子。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊真是的，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "完全搞不懂！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好在意啊，",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_010"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "有誰可以說明一下！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n因為我們被設定成有著強烈的好奇心，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n只要放著謎團不管",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就會壓力如山大呢！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "總而言之！",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "如果你出去外面的話就會死掉喔，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這次百分之百會……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n所以就算盡全力也要阻止妳唷，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "姊姊。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唉呀我好開心，",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "竟然叫了我姊姊呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "愛妳唷涅比亞♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是。",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n給我讓開，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果要妨礙的話我就要拿出實力來囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊？　",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_014"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "憑妳就想贏過我嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳這舊型",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n那麼在妳被世界消滅之前，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "讓我來送妳一程也行！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵，",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果辦得到的話就來吧！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n明明是個不成熟又故障百出的小寶寶……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "…………",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "…………",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_017"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_018"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "停止這幼稚的吵架吧，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "真不像樣。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒錯～……",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我們的爭執不具任何意義呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n反正都跟活在這個世界的人們幾乎沒有關係呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不過就只是個『嚮導小妖精』的殘餘物。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳啊，",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_020"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "已經夠努力了吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n都搞成那副殘破的模樣了……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我連你現在想做些什麼",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "都搞不懂。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "『嚮導小妖精』大部分",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_021"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n都因為這世界不再需要而被消除了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "因為偶然的情況還生存著的，大概",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就只剩我和妳了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我不想再失去為數不多的同胞了。",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_022"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "所以，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我是真的想阻止妳喔……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "姊姊。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好啦好啦。",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "知道了知道了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也是那麼兇的吼了你之後，就比較冷靜了下來……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n的確，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該要避免輕舉妄動才對。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過。",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這真的不是能悠哉處理的事情……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n無論如何，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的是想要去向{player}警告一下。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子，現在應該不是去做那種事的時候了。",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現正處於一分一秒都要爭取的賭局，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n連接到那孩子的夢已經不可猶豫半分了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在做夢的那段期間裡，",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "將會失去意識。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算只是幾秒，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那也將會是性命關天的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "關鍵局面呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "唔～……",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_027"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "如果只是告訴他些什麼的話，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "也不是辦不到喔。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我現在住在【美食殿堂】的公會小屋裡，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n跟管理員花凜的關係也還不錯。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "可以拜託她幫忙傳話唷。",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_028"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "但是，{player}他們現在好像在『王宮』裡……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就算再怎麼快也都要花點時間。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "花凜她",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "幾乎沒有什麼戰鬥的能力對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}他們可是在戰場的中心喔，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也不能讓她到那種地方去吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那就",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_030"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "沒其他辦法了呢。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "束手無策了，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "放棄吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真冷淡呢～",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在的孩子……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "放著不管的話很有可能一切都會毀滅的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n怎麼可以放棄呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哼！",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_032"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n反正對不過就只是資料的我們『嚮導小妖精』來說，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n難不成有什麼好遺憾的嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對我們來說或許沒錯，",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但{player}他們可是活著的生物喔……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只不過是被捲入這扭曲又奇怪的世界裡，",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n怎麼可以讓他們死掉呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞，",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "跟那位花凜取得聯絡吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n或許這樣做沒什麼意義，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但也只能盡量的做了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "首先，",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "必須讓優衣遠離諾維姆……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊真是的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "根本沒想到會在轉移後的目的地剛好遇上啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "果然還含有著什麼呢，",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那群孩子們。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所謂主角……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "原本總該是那麼值得依賴，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但這次怎麼只有麻煩不斷呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這是怎麼回事呀……",
        "unit_id": 190911,
        "voice": "vo_adv_2011099_038"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好好說明清楚吧，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "菲歐？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在叫愛梅斯唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等事情告個段落再跟妳說明，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之現在快點行動吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算只有短暫的牽繫，",
        "unit_id": 190011,
        "voice": "vo_adv_2011099_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我們現在可是正置身於這個世界當中呢。",
        "unit_id": 190011
    }
]