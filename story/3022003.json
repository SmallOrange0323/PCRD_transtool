[
    {
        "type": "background",
        "background": "502540"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是距離【阿爾克絲鍊金堂】創立大約一年前的事──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一名少女垂頭喪氣地走著。"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "…………",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_000"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……唉～",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "爺爺是大笨蛋，",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_001"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "大白癡。",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽最討厭爺爺……",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "騙人的，",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "最喜歡了。",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……可是好討厭。",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "但是又最喜歡……",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽搞不懂啦。",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "唔唔……",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_002"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "可惡……",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n……嗚嗚。",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "彩羽～",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_003"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……哦？",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "怎麼了？",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_004"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "總是充滿活力的妳竟然擺著一張苦瓜臉。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n明天是不是要下雪了啊？",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "苑姑姑……！",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_005"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗚……",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗚",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……！！",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗚哇啊啊啊啊啊啊～～～！！",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_006"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哎呀，",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_007"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哭得這麼慘啊。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……來，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我給妳摸摸頭，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "過來這邊。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n來吧，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "好乖好乖。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……唔。",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_008"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "對不起，",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "小苑。",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n妳的衣服上",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "都是彩羽的鼻涕了……",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……哦，",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_009"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這件衣服我嫌麻煩一直沒洗，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n現在有藉口可以洗了，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這鼻涕來得正好。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……所以，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "發生什麼事了？",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗯……",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_010"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "就是啊。",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n爺爺他啊，",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "真的很過分……",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……嗯嗯嗯，",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_011"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "妳想認真跟爺爺來場劍術對決，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n可是他卻沒有認真跟妳對打。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "他的說法是因為妳還小。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不是，",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_012"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這是理所當然的吧。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "咦！？",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_013"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "小苑妳也認同爺爺嗎！？",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "對喔，",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "畢竟爺爺是小苑的爸爸嘛……！",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n比起三等親的姪女，",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "妳更重視一等親的爸爸……！",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "竟然搬出這麼刁鑽的理論。",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_014"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "就說跟那個沒關係啦。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是說，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我對妳到底有多麼疼愛……",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "可不容妳小看喔。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "爸爸他……",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_015"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "彩羽妳的爺爺",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是石動流劍術的開山始祖。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "雖然我不太清楚，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "但他好像有什麼劍聖的稱號不是嗎？",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n門下徒弟也是多到數不清。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽也是他的徒弟啊。",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_016"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗯，",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_017"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "妳雖然是個孩子，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "卻是最厲害的呢。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n爺爺他",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "一直都很以妳為傲喔。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "總之，",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_018"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不用那麼急。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "妳今年就滿10歲了不是嗎？",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n很快就是大人了，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "再忍忍吧。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "等不下去了啦。",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_019"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽現在就想打……",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "因為……",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "…",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "…總之，",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽現在就想跟爺爺對打啦……！",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "如果因為不是大人就不跟彩羽打的話……",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_020"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "那彩羽現在就想變成大人！",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哇啊～",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_021"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "太奢侈了。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我勸妳還是不要比較好。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n孩提時期的光陰，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "可是這個世界上最珍貴的寶物喔！",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n是每一個大人不管再怎麼渴望，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "都絕對得不到的寶物。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……那麼，",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_022"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n小苑妳也想要變成小孩嗎？",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗯～？",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_023"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這個嘛，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "算是吧。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……呃，",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_024"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "喂！？",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "妳突然拉著我要去哪啊……！？",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嘿嘿……",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_025"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽想到了一個好點子！",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "小苑，問妳喔！",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "妳知道住在高地房子裡的那個",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "鹿姐姐嗎！？",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "鹿……",
        "unit_id": 132712,
        "voice": "vo_adv_3022003_026"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哦，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是那個少女鍊金術師對吧。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n她是瑪莉絲黛菈小姐的孫女……",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "叫什麼名字來著？",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "她叫露易絲瑪莉！",
        "unit_id": 132612,
        "voice": "vo_adv_3022003_027"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽碰巧在書店遇到她的！",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "彩羽",
