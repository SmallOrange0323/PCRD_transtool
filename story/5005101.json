[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈──！",
        "unit_id": 107911,
        "voice": "vo_adv_5005101_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是大海喵是大海喵──！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為我討厭水所以不打算進去海裡，",
        "unit_id": 107911,
        "voice": "vo_adv_5005101_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過好喜歡大海喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "炒麵、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "刨冰、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "鯛魚燒……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "海之家好浪漫喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "珠希妳在說什麼啊。",
        "unit_id": 108011,
        "voice": "vo_adv_5005101_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "在海邊亂花錢什麼的可是愚蠢至極哦？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "雖然工作的話可以使用經費，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但花自己的錢就要節儉再節儉！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "美冬太嚴以律己了喵……",
        "unit_id": 107911,
        "voice": "vo_adv_5005101_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這個夏天就打破對自己的限制，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n再活得更隨心所欲一點就好了喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就算妳要我隨心所欲……",
        "unit_id": 108011,
        "voice": "vo_adv_5005101_004"
    },
    {
        "type": "dialogue",
        "name": "珠希・美冬",
        "words": "下一回，",
        "unit_id": 1,
        "voice": "vo_adv_5005101_005"
    },
    {
        "type": "dialogue",
        "name": "珠希・美冬",
        "words": "「珠希和美冬的無人島０盧幣生活」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊。",
        "unit_id": 108011,
        "voice": "vo_adv_5005101_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣的話，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我想要每天都去特賣會！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我想過著一邊被貓咪包圍著，",
        "unit_id": 107911,
        "voice": "vo_adv_5005101_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一邊吃鯛魚燒吃到飽的生活喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果有那樣的生活，",
        "unit_id": 107911,
        "voice": "vo_adv_5005101_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就好了喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有的話就好了呢～",
        "unit_id": 108011,
        "voice": "vo_adv_5005101_009"
    }
]