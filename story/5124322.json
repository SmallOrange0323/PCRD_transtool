[
    {
        "type": "dialogue",
        "name": "空花",
        "words": "哎呀～～？",
        "unit_id": 127011,
        "voice": "vo_adv_5124322_000"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "看來",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "惡靈的行動",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好像有了變化呢～～？",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這個是……",
        "unit_id": 127111,
        "voice": "vo_adv_5124322_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "騷靈現象……？",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "它打算讓東西飄起後，",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "往我們砸過來！",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "是幽靈常用的招式！",
        "unit_id": 2414,
        "voice": "vo_adv_5124322_002"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n最好先把飄起來的東西打下來比較安全！",
        "unit_id": 2414
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我、",
        "unit_id": 126911,
        "voice": "vo_adv_5124322_003"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我知道了……",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n那麼",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "惡靈就留到後面",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "再來處理，",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "對吧……？",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒錯。",
        "unit_id": 127111,
        "voice": "vo_adv_5124322_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看那個靈氣的流向，",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n應該會有相當大量的東西朝著我們飛過來吧。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "與其個別擊落，",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不如一次全部打下來比較安全。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "全部打下來，",
        "unit_id": 127011,
        "voice": "vo_adv_5124322_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是嗎～～",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "懂是懂了，",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不過能順利辦到嗎～～？",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "也只能試試看了！",
        "unit_id": 2414,
        "voice": "vo_adv_5124322_006"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "而且啊……",
        "unit_id": 2414
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "哼哼哼♪",
        "unit_id": 2414
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n說到把東西打下來，就是我和忍表現的時候了！",
        "unit_id": 2414
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n利用返還咒術，",
        "unit_id": 2414
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "把東西全部往對方那裡丟回去！",
        "unit_id": 2414
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "好、",
        "unit_id": 126911,
        "voice": "vo_adv_5124322_007"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "好厲害……！",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n連這種事",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "也能做到嗎……？",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯，",
        "unit_id": 127111,
        "voice": "vo_adv_5124322_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "做得到喔。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「害人者終將害己」……",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "以其人之道，",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n還治其人之身，",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這就是詛咒的規矩。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "說的沒錯！",
        "unit_id": 2414,
        "voice": "vo_adv_5124322_009"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n呵呵呵，",
        "unit_id": 2414
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "好～",
        "unit_id": 2414
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "啦……",
        "unit_id": 2414
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n我們要來整治騷靈現象啦！！",
        "unit_id": 2414
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "哇、",
        "unit_id": 127011,
        "voice": "vo_adv_5124322_010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "哇啊……",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花絕對不想要……",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n和忍還有骷髏老爸為敵呢……",
        "unit_id": 127011
    }
]