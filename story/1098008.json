        "voice": "vo_adv_1098008_109"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "凱留。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "想要知曉一切，那是何等「強欲」。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_110"
    },
