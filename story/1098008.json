[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}邀請拉姆一起去散步。"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "話說回來，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_000"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n為什麼拉姆非得陪你一起散步不可。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆沒在跟你討論開不開心。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_001"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n而是不知道這樣漫無目地走著到底有什麼意義。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆要回去了。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_002"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "什麼？",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_003"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "反正一定又是在計劃什麼才會把拉姆給帶出來對吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你有問題想問？",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_004"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……你問說拉姆有沒有開始變得信任你們，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_005"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是嗎？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "還以為你要問什麼呢……",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_006"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_007"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "唉……",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_008"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n你以為擺出一副悲傷的表情",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆就會溫柔地回答你的話可就大錯特錯了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_009"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……不過。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_010"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "與你們處在一起，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_011"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n至少讓拉姆，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "了解到了一件事。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "哎呀，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_012"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "已經走到公會小屋了呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "散步可以結束了吧。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_013"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n拉姆已經累了。",
        "unit_id": 109811
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拉姆！",
        "unit_id": 105812,
        "voice": "vo_adv_1098008_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "歡迎妳來！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一定很累了對吧。",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這邊請，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請到那裡坐吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "…………\n不用妳說拉姆也會休息的。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_016"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "因為多虧了某人讓我浪費了體力。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}，辛苦了。",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n拉姆那傢伙，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是一樣很冷漠呢……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "時機勉強沒問題。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然稍微早到了一點，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但總算是有準備好了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拉姆她有起疑嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯，",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很好。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "以你來說做得很棒了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可，",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "準備好了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "了解了！",
        "unit_id": 105812,
        "voice": "vo_adv_1098008_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要上了哦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n預備……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "美食殿堂",
        "words": "「拉姆！」\n「拉姆小姐。」\n「拉姆！」",
        "unit_id": 1,
        "voice": "vo_adv_1098008_023"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "什麼？",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實我們，",
        "unit_id": 105812,
        "voice": "vo_adv_1098008_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為拉姆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "準備了一個驚喜派對！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "鏘鏘鏘～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這是──",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_026"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "傳說的番薯！",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯，",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正是那個傳說的番薯。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n居然一眼就能看出來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真不愧是拉姆小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "當然啊，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_028"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "怎麼可能忘記。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n拚上性命去採的番薯，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不管是過去還是未來都只有那次了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過……",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那時候採到的番薯",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該都被大家吃完了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那這番薯是從哪來的呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是不可思議……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯哼。",
        "unit_id": 105812,
        "voice": "vo_adv_1098008_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實啊。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們居然居然，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了能讓拉姆開心，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n又再一次",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "去到那個地方採集傳說的番薯了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "居然特地，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_031"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "又再一次……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "上一次，",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐透過",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n親自招待我們傳說的蒸番薯，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來表達感謝之意。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是拉姆小姐才是，",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從平日就",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "陪著我們一起，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幫了我們很多忙。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆可沒有幫你們的意思。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "失禮了。",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這只是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就結果來說。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下幾人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n事實上真的有受到拉姆小姐的幫助。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下幾人才會打算，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這次換成由我們這邊，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來對拉姆小姐表達感謝之意。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過畢竟對象是妳啊？",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以想說普通的方法妳應該不會高興。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以才會，",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n像這樣計劃了一個驚喜派對。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳看，",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這麼多傳說的番薯！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳應該也沒想過，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以再吃到它吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼哼。",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算是拉姆，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也被嚇到說不出話來了吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼哼哼哼！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱、",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是太得意過頭的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "驚喜派對的價值會有降低的危險……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚……",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也對。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為採番薯的過程實在是太辛苦了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以我不禁就。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不會，",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下很了解您的心情。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這段路途並沒有輕鬆到，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為是第二次",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就能比較簡單……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "委婉一點講",
        "unit_id": 105812,
        "voice": "vo_adv_1098008_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是個地獄呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然已經有所覺悟……",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但果然還是超乎想像的嚴酷，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就連凱留小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "途中也都眼眶泛淚。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "甚至還有一些地方",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是讓貪吃佩可小姐背著走的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這樣虧妳還能擺出那副得意的臉呢，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_049"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "凱留。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別、",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_050"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別再提我的事了！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽好囉？",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_051"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們想說的是……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想對妳……",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_052"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對拉姆妳。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "表達感謝之意，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是這樣啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐。",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您可以允許在下幾人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n來舉辦蒸番薯的驚喜派對嗎。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_054"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "哈！",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_055"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n對拉姆表達感謝是理所當然的事。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n隨你們喜歡吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……不過話說回來，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_056"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n居然能將那番薯給採了這麼多回來。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真的是，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_057"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "太不正常了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……拉姆小姐她……？",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看起來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像有點開心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對吧？",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_059"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我也這麼認為！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來有點開心對吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是太好了。",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為在下幾人一直煩惱著該如何讓拉姆小姐開心，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只想著這件事，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一路祕密準備了過來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們做到了～！",
        "unit_id": 105812,
        "voice": "vo_adv_1098008_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n驚喜",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大成功☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嘿嘿。",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_062"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如何啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拉姆！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "如果妳是說讓拉姆驚喜這件事的話……",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_063"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n確實你們準備了傳說的番薯讓拉姆嚇一跳，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "但你們私底下在計劃著什麼，這拉姆早就發現了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……咦？",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_064"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦咦咦！？",
        "unit_id": 105812,
        "voice": "vo_adv_1098008_065"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也就是說",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_066"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "如果想瞞著拉姆還得再做得更好一點呢。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_067"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這陣子，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "很常從廚房裡傳來",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n有人正在談論著拉姆的聲音──",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "而且公會小屋也一直聞得到番薯的味道。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_068"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "很明顯是在研究蒸番薯的方法。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "居、",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_069"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "居然，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "早就露餡了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "順便姑且還是說一下。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_070"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你們為了生火而想放進爐灶的柴火，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_071"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n之前下雨時淋濕了，所以是燒不起來的。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可、凱留",
        "words": "……咦！！！！",
        "unit_id": 1,
        "voice": "vo_adv_1098008_072"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雖然你們為了今天而把柴火保存在屋簷下，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_073"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n但雨水是會飄進那裡的。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是不小心呢，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "凱留。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實……",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_074"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n前陣子剛下過雨……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳……",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_075"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳有發現的話倒是說一聲啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們這樣鬼鬼祟祟不就顯得很丟臉嗎！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "別太小看拉姆好嗎。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_076"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那種不解風情的事拉姆怎麼可能會做呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "如果是為了拉姆而準備的東西，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_077"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n那麼好好收下才是該有的禮貌。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_078"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "而且，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_079"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "如果還是傳說的番薯。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n沒在最佳狀態下收下就太可惜了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "所以說，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_080"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "{player}，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "把力量借給拉姆吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這是在懲罰你帶著拉姆四處走動浪費體力。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_081"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "別站著發呆啊，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_082"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n你平常對貪吃佩可她們做的那個也對拉姆做吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐……！",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_083"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "芙拉！",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_084"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇、",
        "unit_id": 105812,
        "voice": "vo_adv_1098008_085"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇哇哇！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n風把柴火……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一瞬間就吹乾了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "把番薯放到上面的容器後，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_086"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n就把火種加進柴火裡吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好、",
        "unit_id": 105812,
        "voice": "vo_adv_1098008_087"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的～～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_088"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n準備，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都完成了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "如果不想被燒傷的話，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_089"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n就離遠一點。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……呼！",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_090"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇啊啊啊啊！",
        "unit_id": 105812,
        "voice": "vo_adv_1098008_091"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這次換成柴火，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被芙拉的風給一口氣……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "蒸番薯最重要的就是火候。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_092"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n好好看著拉姆是怎麼做的。",
        "unit_id": 109811
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "美食殿堂",
        "words": "哇啊啊啊啊……！",
        "unit_id": 1,
        "voice": "vo_adv_1098008_093"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "蒸好的傳說番薯，",
        "unit_id": 105812,
        "voice": "vo_adv_1098008_094"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n熱騰騰閃亮亮☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "香甜的味道裡還帶了點，",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_095"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n撲鼻的極致香氣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是……",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_096"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明是要給驚喜，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "結果卻還是讓拉姆幫忙了……",
