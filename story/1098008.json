        "words": "妳哦……",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_116"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n別隨便把人當成搞笑藝人啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "哎呀。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_117"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "妳這不是很有自知之明嗎，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "凱留。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "比起這種事，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_118"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n這難得的傳說蒸番薯，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "來趁熱吃吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接受善意的方式，",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_119"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳再重新思考一下會比較好哦！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好啦好啦小凱留。",
        "unit_id": 105812,
        "voice": "vo_adv_1098008_120"
    },
