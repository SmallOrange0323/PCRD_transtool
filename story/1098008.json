    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有點不甘心～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "跟你們特地去採集傳說番薯所耗費的勞力比起來，這根本不算什麼。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_097"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "越來越覺得不甘心了！",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_098"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆只是，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_099"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "在對善意做出回應而已。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……你居然還記得？",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_100"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……算了，也罷。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_101"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "關於你們，拉姆了解到一件事。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_102"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那就是，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_103"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "想再多也沒有用。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "因為有太多拉姆無法理解的行為了。",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_104"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n對於無法理解的事想再多也沒有用不是嗎。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "所以，對於你們的善意，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_105"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆決定就這樣直接收下了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "到頭來，",
        "unit_id": 109811,
        "voice": "vo_adv_1098008_106"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆的結論就是這樣做最好。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_1098008_107"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n原來您之所以接受這個派對，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是因為這個緣故。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……可、",
        "unit_id": 106012,
        "voice": "vo_adv_1098008_108"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一直都無法了解，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拉姆妳，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "覺得這樣就好了嗎……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都不會想要",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "稍微去",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "了解一點嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是蠢問題呢，",
