[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在牧場度過了安穩的日子後，莉瑪收到了一封通知。"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "太好了……",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "太好了，{player}！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "通過最終選拔了！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n啊啊，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "簡直像在做夢一樣。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "距離我憧憬的舞會就只差一步了。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦咦，",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真了不起呢！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不對，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你是為了工作的緣故吧？",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我們都在課程中一起努力過來了，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n如果能一起出席舞會就太好了呢。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也就是說",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果順利的話，就能在憧憬的舞會中，\n跟{player}一起……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "討厭，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我有點心跳加速了！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒、",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒事啦！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "只不過是太高興了，所以有些興奮而已。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好了，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我們快點前往宅邸吧！",
        "unit_id": 115812
    },
    {
        "type": "background",
        "background": "501240"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "我們已經恭候多時了。",
        "unit_id": 1514,
        "voice": "vo_adv_5061005_004"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "……",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "兩位好！",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "羅伊德先生、",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "瑪莎小姐。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……那個，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "其他人還沒到嗎？",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "很遺憾，",
        "unit_id": 1514,
        "voice": "vo_adv_5061005_007"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "從最終選拔脫穎而出的人，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "就只有莉瑪小姐而已。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦！？",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是、",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣啊……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我原本還想跟大家一起參加舞會的……",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "既然如此，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我要連大家的份一起努力，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "絕對要出席舞會！　",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "莉瑪小姐，",
        "unit_id": 1514,
        "voice": "vo_adv_5061005_010"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "您經由許多的課程，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n獲得了足以被稱作淑女的",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "美麗與光輝。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "接著就只剩通過最終測驗了。",
        "unit_id": 1514,
        "voice": "vo_adv_5061005_011"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n只要通過測驗，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "您就能正式地出席舞會──",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "……已經，",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_012"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "夠了……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_013"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "羅伊德大人，",
        "unit_id": 1514,
        "voice": "vo_adv_5061005_014"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "您說什麼……",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "這原本就是我的問題，",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_015"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "\n我不能讓無辜的女性陪我一起承擔！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "但、",
        "unit_id": 1514,
        "voice": "vo_adv_5061005_016"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "但是那樣的話羅伊德大人會……",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "那無所謂，",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_017"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "已經夠了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "為了得救而不惜欺騙她們，這件事本身就是錯的。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "我會親自做個了斷。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "等、",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "等一下！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "您說欺騙我們",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "什麼意思……？",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "完全搞不懂是怎麼回事！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪小姐說得沒錯，",
        "unit_id": 116011,
        "voice": "vo_adv_5061005_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n羅伊德先生，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "能不能",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也跟咱們說明白呢？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "妳、",
        "unit_id": 1514,
        "voice": "vo_adv_5061005_020"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "妳們幾位……",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "全都聽到了嗎？",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "畢竟她們是我們的學生嘛，",
        "unit_id": 115911,
        "voice": "vo_adv_5061005_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n當然會在意結果呀。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是，",
        "unit_id": 115911,
        "voice": "vo_adv_5061005_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這個結果實在讓人難以接受啊。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n莉瑪被選上自然是沒話說，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "其他的小姐們竟然全部都落選，這我可無法認同。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "……",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "吶，",
        "unit_id": 115911,
        "voice": "vo_adv_5061005_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "能不能把真相",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "告訴我們？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要我教導大小姐們戰鬥技巧，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還有讓這傢伙擔任護衛，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這些事怎麼想都很可疑呢。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你們真的打算舉辦舞會嗎？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真步、",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_025"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真琴……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n妳們兩人也不知道詳情嗎？",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是啊，",
        "unit_id": 115911,
        "voice": "vo_adv_5061005_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我跟公主受那邊那位瑪莎小姐所託，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n負責擔任小姐們的課程講師，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還有",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "貴族的護衛。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "先不論講師，",
        "unit_id": 116011,
        "voice": "vo_adv_5061005_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "護衛的話",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是人越多越好吧？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以人家也邀請了王子先生",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一起來哦。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這傢伙之所以一起接受課程，",
        "unit_id": 115911,
        "voice": "vo_adv_5061005_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n則是因為在附近能夠迅速應對狀況。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的，",
        "unit_id": 115911,
        "voice": "vo_adv_5061005_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "竟然邊工作邊享受，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還真有你的風格呢。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只不過，",
        "unit_id": 116011,
        "voice": "vo_adv_5061005_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "關於",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "到底要從",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "什麼手中保護對象，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們也沒有聽說呢。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n差不多可以告訴咱們了吧？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "……",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_031"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "我知道了，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "我就把一切都告訴你們吧。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "\n其實……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "我被某個人給盯上了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "您說的，",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_032"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "該不會是殺手，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "之類的……？",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "不，",
        "unit_id": 1514,
        "voice": "vo_adv_5061005_033"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "盯上了羅伊德大人的，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "是住在邊境的某個強大魔物。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是魔物啊……",
        "unit_id": 115911,
        "voice": "vo_adv_5061005_034"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼魔物要取貴族的命啊？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "不，",
        "unit_id": 1514,
        "voice": "vo_adv_5061005_035"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "她並不是要取羅伊德大人的命。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n那個魔物──",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "自稱為公主的魔物，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "她的目標是羅伊德大人本身，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "她似乎……",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "傾慕著羅伊德大人。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所謂的傾慕，",
        "unit_id": 116011,
        "voice": "vo_adv_5061005_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就是",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "愛慕著對方的意思，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也就是",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "迷上了對方哦～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "莉瑪・真琴",
        "words": "咦……",
        "unit_id": 1,
        "voice": "vo_adv_5061005_037"
    },
    {
        "type": "dialogue",
        "name": "莉瑪・真琴",
        "words": "咦咦咦咦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "公主好幾次出現於羅伊德大人面前，",
        "unit_id": 1514,
        "voice": "vo_adv_5061005_038"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "逼迫大人與其訂婚。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "不管怎麼拒絕她都一而再再而三地來訪，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "而且每次",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "都輕易地就把",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "強壯的護衛們制服。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原本還以為只是個魔物，",
        "unit_id": 115911,
        "voice": "vo_adv_5061005_039"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "卻非常棘手呢，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n從各方面來說都是。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "然後在不知第幾次的來襲時，",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_040"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "公主這麼說了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「去找比妾身更美麗、",
        "unit_id": 1,
        "voice": "vo_adv_5061005_041"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "更強大的女性過來，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n如果辦得到的話，我就放棄追求你。」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501240"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "原來如此呀～",
        "unit_id": 116011,
        "voice": "vo_adv_5061005_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "你們才會為此",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而招集女孩子啊。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "是的。",
        "unit_id": 1514,
        "voice": "vo_adv_5061005_043"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "只是要美麗的話還好說，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "但如果要比那個魔物更強大，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n那要找到符合條件的女性，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "可不是件簡單的事。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "於是",
        "unit_id": 1514,
        "voice": "vo_adv_5061005_044"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "我們以邀請參加舞會的名義，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "招集了許多女性。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n打算佯稱是課程，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "來培育並選出",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "能與公主一戰的人。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "……我本來",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_045"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "就不想採取這個手段。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "這相當於以甜言蜜語來引誘她們，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "讓她們背負危險的使命。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "再加上隨著課程的進行，",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_046"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "\n在目睹了以莉瑪小姐為首的參加者們純粹、專一的模樣後，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "\n到了這最後關頭，我已經不忍心再繼續欺騙各位了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "對於隱瞞真相，",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_047"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "並欺騙了你們這件事，我真的感到非常抱歉。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "但是要恨的話，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "請你們恨我一個人就好。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "都是因為我如此無能，",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_048"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "才會讓瑪莎及其他家臣們，\n必須擔任這種惹人厭的角色。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "他們都是為了我才會這麼做的。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "莉瑪小姐，",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_049"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "還有真步小姐們也是，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "希望你們能從這件事收手。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "\n因為像我這種人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "沒有資格接受你們的保護……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "羅伊德先生……",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_050"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，",
        "unit_id": 115911,
        "voice": "vo_adv_5061005_051"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "事前說明的確是不夠充分呢。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "以結果而言，也確實是欺騙了小姐們。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，",
        "unit_id": 115911,
        "voice": "vo_adv_5061005_052"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們從一開始就是被僱來保護你的，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那些瑣碎的事根本無所謂。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是這時候撤退，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可就有辱【哞哞自衛隊】的名號了。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒問題吧？",
        "unit_id": 115911,
        "voice": "vo_adv_5061005_053"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就算妳不打算幫忙，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也要做到底哦？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒問題哦，",
        "unit_id": 116011,
        "voice": "vo_adv_5061005_054"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "當然也要去。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為真琴一個人的話，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "搞不好會亂來呢。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "妳們兩位……",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_055"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "謝謝妳們。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我、",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_056"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我也要去！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "莉瑪小姐！？",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_057"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "為什麼……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "我明明欺騙了妳，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "\n妳已經沒有必要",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "再為此去冒險了啊……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "事情居然有內幕，",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_058"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "的確讓我有些受到打擊。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n拚了命努力過來的大家，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是知道了事實，我想也會很難受吧。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但是",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_059"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我對於在這裡接受的課程，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "並沒有絲毫的後悔。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n畢竟多虧如此，才讓我接觸到了原以為一生都無緣的夢想世界，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n即使那只是暫時的事。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "在這裡度過的日子，",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_060"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "充滿了無可取代的璀璨光輝，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "請讓我回報你吧。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "而且，",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_061"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "羅伊德先生和瑪莎小姐正感到痛苦不是嗎？",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n真正的淑女就應該對有困擾的人伸出援手，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "對吧？",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "莉瑪小姐……",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_062"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要說是交換條件也有點奇怪，",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_063"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不過為了參加課程的那些女孩著想，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我希望你能照常舉辦舞會。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我不想讓大家的努力白費，",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_064"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n況且",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "照理來說，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "她們比我這種人還更適合參加舞會呢。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "那、",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_065"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "那倒是完全沒問題，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "不，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "可是如果妳有個萬一的話……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒問題的啦。",
        "unit_id": 115911,
        "voice": "vo_adv_5061005_066"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "莉瑪她很強，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這點我可以掛保證。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且",
        "unit_id": 116011,
        "voice": "vo_adv_5061005_067"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還有咱們在一起呢。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n【哞哞自衛隊】",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可不是虛有其表哦。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "各位……",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_068"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝你們！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "羅伊德大人，",
        "unit_id": 1514,
        "voice": "vo_adv_5061005_069"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "就相信她們吧。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "瑪莎……",
        "unit_id": 2511,
        "voice": "vo_adv_5061005_070"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "我明白了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "但是請務必要平安無事地回來。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好，",
        "unit_id": 115911,
        "voice": "vo_adv_5061005_071"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "都談妥了吧。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這最後的重要任務，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓我們確實地把它解決掉吧！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唉，",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_072"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "原本還以為距離舞會只差一步了，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n結果竟然變成這種情況，真是太出乎我的意料了。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然是個非常辛苦的最終測驗，",
        "unit_id": 115812,
        "voice": "vo_adv_5061005_073"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n但是感覺只要跨越了這個難關，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我就能變成更加出色的女孩子呢！　",
        "unit_id": 115812
    }
]