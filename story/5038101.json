[
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～……",
        "unit_id": 110911,
        "voice": "vo_adv_5038101_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒這個月的零用錢，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "餘額已經有點不妙了……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真巧。",
        "unit_id": 111011,
        "voice": "vo_adv_5038101_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n從我家鄉寄來的生活費也快不夠用了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐妳應該沒差吧。",
        "unit_id": 110911,
        "voice": "vo_adv_5038101_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n畢竟妳是學院中的特權階級，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n只要說是研究上的需要，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不管什麼東西都可以拿去請款吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒錯。",
        "unit_id": 111011,
        "voice": "vo_adv_5038101_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但因為我剛開始",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一直亂申請一些有的沒的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以現在會計變得很神經質。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我是不是該學克蘿依",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "開始偷偷去打工呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說啊。",
        "unit_id": 110811,
        "voice": "vo_adv_5038101_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "既然妳都知道我是偷偷摸摸的，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那可不可以請妳不要刻意多此一舉把我的名字講出來啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這間學校可是禁止打工的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這麼說起來，",
        "unit_id": 110911,
        "voice": "vo_adv_5038101_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "年底的時候克蘿依學姐",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n向學校請了一個禮拜的假對吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那也是為了去打工嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊～沒錯，",
        "unit_id": 110811,
        "voice": "vo_adv_5038101_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我突然被找去。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那是個要把一堆會不斷冒出的盔甲",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "徹底擊潰的打工。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是",
        "unit_id": 111011,
        "voice": "vo_adv_5038101_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什麼啊？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "誰知道。",
        "unit_id": 110811,
        "voice": "vo_adv_5038101_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我是說真的，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "他們完全沒向我做任何解釋，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "突然就莫名其妙地要我去現場。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但那是無所謂啦，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "總之我去拯救了世界。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喔～",
        "unit_id": 110911,
        "voice": "vo_adv_5038101_009"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "時薪多少啊？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不曉得耶？",
        "unit_id": 110811,
        "voice": "vo_adv_5038101_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我也還沒有收到明細呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "而且……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "請款單到底應該寄去哪裡啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀呀，",
        "unit_id": 111011,
        "voice": "vo_adv_5038101_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "果然這個世界今天還是一樣的瘋狂。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n有沒有什麼有賺頭的工作啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對吧～？　",
        "unit_id": 110911,
        "voice": "vo_adv_5038101_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我是不會期望天降鉅款這種事啦，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過妳看嘛，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒不是一個有心就做得到的孩子嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不曉得會不會",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n出現個有錢人看出琪愛兒的潛力而切嚕地投資我們呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5038101_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳說的是所謂的天使投資人嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "天使……？",
        "unit_id": 110911,
        "voice": "vo_adv_5038101_014"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我記得優妮學姐",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是那種會突然拿一些童話舉例的人啊。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "應該是死期將近所以預見了什麼吧。",
        "unit_id": 110811,
        "voice": "vo_adv_5038101_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n妳別管她。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳這蠢蛋。",
        "unit_id": 111011,
        "voice": "vo_adv_5038101_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我可不是在說什麼長著翅膀的嬰兒。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我說的是商業天使——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就是會對經濟能力堪慮的創業家伸出援手，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那些富有的個人投資人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉……",
        "unit_id": 110811,
        "voice": "vo_adv_5038101_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n就算突然跟我說什麼創業，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "又講什麼投資的，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我還是有點傻眼就是了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "打個比方，",
        "unit_id": 111011,
        "voice": "vo_adv_5038101_018"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不是有些貴族會因為相信對方的才華有天會開花結果，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n而花錢養一些沒沒無聞的藝術家或音樂家嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講簡單一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這大概可以算是那個的商業版。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "以金錢資助那些剛起跑、具有才能的年輕人——",
        "unit_id": 111011,
        "voice": "vo_adv_5038101_019"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n在那個領域，有這種特殊喜好的投資家",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "似乎就叫做天使。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦～真好～！",
        "unit_id": 110911,
        "voice": "vo_adv_5038101_020"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n琪愛兒也想見見天使～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒、優妮、克蘿依",
        "words": "下一回，",
        "unit_id": 1,
        "voice": "vo_adv_5038101_021"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒、優妮、克蘿依",
        "words": "「恩賜的財團與",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "琪愛兒、優妮、克蘿依",
        "words": "神聖學院的問題兒童」。",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這裡就是聖德蕾莎女子學院吧 。",
        "unit_id": 103211,
        "voice": "vo_adv_5038101_022"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "感覺事情越來越有趣了呢，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊～哈哈哈……！",
        "unit_id": 103211
    }
]