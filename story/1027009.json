[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}在散步時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看見惠理子似乎正在找人。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "…………",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人……？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……嘻嘻。",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n嘻嘻嘻……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我找到您了……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n{player}大人……♪",
        "unit_id": 102711
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您醒來了嗎？",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n嘻嘻嘻嘻……♪",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您露出了",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不知道這是哪裡的表情呢……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n還請放心，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這裡是位於蘭德索爾郊區的一間空屋……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您說自己",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "無法動彈……？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我想也是。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "畢竟，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我把您的手腳都綁起來了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還請不要在意這種小事……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為從今天起，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們兩人……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就要一起在這裡生活了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "命中注定要結合的兩人……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "今後要",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一年四季！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一天24小時！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "直到永遠！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n都只看著對方活下去……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然如此，就算身體無法動彈……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n也算不了什麼……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦……？",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒有這回事喔……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我是惠理子……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是大人您的",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "惠理子……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而您則是……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我的……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n沒錯……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我的{player}大人……♪",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_012"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n請您好好看清楚……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我的眼睛、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "臉蛋、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "身體……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "將我的一切，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_013"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "盡收眼底……！！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳這頭野獸，",
        "unit_id": 1,
        "voice": "vo_adv_1027009_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "給我住手。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "唔！",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這個聲音是……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子？",
        "words": "我可不准妳繼續胡作非為。",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子？",
        "words": "\n別用那骯髒的臉，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子？",
        "words": "接近那位大人。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真遺憾……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "被妳找到了……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還以為妳無法掌握我的行蹤呢……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子？",
        "words": "{player}大人，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子？",
        "words": "您搞錯了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子？",
        "words": "我才是惠理子。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子？",
        "words": "而那頭野獸",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子？",
        "words": "並不是我……",
        "unit_id": 102711
    },
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "唔…",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "…！？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "不明魔物",
        "words": "嗚嗚……！",
        "unit_id": 1611,
        "voice": "vo_adv_1027009_020"
    },
    {
        "type": "dialogue",
        "name": "不明魔物",
        "words": "\n這傢伙……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "不明魔物",
        "words": "一口氣就拉近了距離……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "總算變回原本的樣子了。",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n接下來……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我要懲罰妳擅自觸碰那位大人！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "不明魔物",
        "words": "哼……",
        "unit_id": 1611,
        "voice": "vo_adv_1027009_022"
    },
    {
        "type": "dialogue",
        "name": "不明魔物",
        "words": "我可不會讓妳得逞……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "不明魔物",
        "words": "\n現在就先暫時撤退……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "不明魔物",
        "words": "大人……",
        "unit_id": 1611,
        "voice": "vo_adv_1027009_023"
    },
    {
        "type": "dialogue",
        "name": "不明魔物",
        "words": "\n這次的幽會被人打擾了，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "不明魔物",
        "words": "就讓我們下次再相見吧……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "不明魔物",
        "words": "再會了……♪",
        "unit_id": 1611,
        "voice": "vo_adv_1027009_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "被它逃掉了嗎……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n動作那麼俐落，真是礙眼……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_026"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "更重要的是……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您沒有受傷吧……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我解開繩子了……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那隻魔物竟然對您這麼粗暴……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "果然",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不能就這樣放過它……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這個……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_028"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "目前的狀況有些複雜。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我一定會跟您說明清楚……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但我們先離開這個地方吧。",
        "unit_id": 102711
    },
    {
        "type": "background",
        "background": "500950"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來吧，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "到這裡應該就安全了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人您",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也能夠好好休息……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您想問剛才那隻魔物的事情，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對吧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我這就跟您解釋。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人您還記得",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "之前在森林裡，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n遇到的",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "「會變身成他人的魔物」嗎？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就是那隻變成我的樣子，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_032"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "並欺騙您的下流魔物。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不瞞您說，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_033"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在打倒那隻魔物後，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我偷偷地回收了它的殘骸，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "並用來開發鍊金術的新藥。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這麼做都是為了",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_034"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "挑戰鍊金術的極限──",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "「究竟能做出跟本尊多相似的人工產物」。",
        "unit_id": 102711
    },
    {
        "type": "background",
        "background": "500950"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒錯……！",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_035"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只要能做出這個藥，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就能創造出任何人……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就算是跟您一模一樣的小孩，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也沒有問題……！！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "當成功做出這個藥時，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_036"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n正是我們的愛情化為實體的一刻！！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_037"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻嘻……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n嘻嘻嘻嘻嘻嘻嘻……♪",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_038"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "非常抱歉。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我竟然不小心",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "把內心話說出來了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還請您忘記剛才的話吧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓我們回到原本的話題……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_039"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n其實就在幾天前，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我終於完成了藥的試作品。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了盡快測試效果，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_040"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我先試著複製出自己的分身。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然實驗成功，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "創造出了跟我一模一樣的魔物……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "然而複製的精確度卻超出了我的預期。",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_041"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n魔物使用「破壞者」的力量",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "摧毀牢籠，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "逃了出去。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "至今為止，我拼命地在找它……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_042"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒想到，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "它竟然會犯下綁架並監禁您的罪行……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "區區一隻魔物竟敢把大人您綁起來，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_043"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n還露出那麼下流的眼神……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n不可原諒……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不可原諒……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不可原諒",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是我",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_044"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "做出了那隻魔物。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您會陷入這次的危機，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也必須負起一部分的責任。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我絕對",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "會消滅它……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您是在擔心我嗎？",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_045"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是太溫柔了……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而且兩人一起行動",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_046"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也是個好主意！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n那隻魔物",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "說了會再來見大人您。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓我待在您的身邊，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還能兼任保鑣。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請讓我接受您的好意。",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_047"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然要勞煩大人您幫忙，讓我很過意不去，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這段時間",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還請多多指教。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_048"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "最重要的是先確保您的人身安全。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我知道一個最合適的場所，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還請跟我來",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 102711
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊……！",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_049"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "太棒了……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n{player}大人，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只要待在這裡",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就安全了……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我這就把牢房給鎖上！",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_050"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "上兩道……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "上三道鎖！！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻嘻……♪",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "當然是",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_051"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了保護您！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這裡是我其中一間實驗室，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_052"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n那隻魔物並不知道這個地方。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就算",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "被它找到了，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只要待在牢房內就不會有事。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在我打倒魔物之前，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_053"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "絕對不會讓它碰到您一根寒毛！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為此，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還請您過上一陣子不自由的生活。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖說是在牢裡生活，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_054"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但絕不會讓您感到不便。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有任何想要的東西，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "都請跟我說一聲。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不管是麵包還是牛奶，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我都會在5分鐘內買回來。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因此，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_055"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您忍耐到",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我打倒它為止。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這段期間……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我一定會讓您過上",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "安全舒適的照護生活！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "早安，",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_056"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我已經準備了早餐。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "今天是豪華全餐，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還請趁熱享用。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_057"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "早餐太豐盛了？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我只是做出值得讓您享用的餐點罷了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您問說是不是加了什麼奇怪的東西……？",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_058"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒有這回事喔。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就算真的加了點什麼……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也不會有任何顏色",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "跟味道。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒錯，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您一定立刻就會喜歡上的。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "所以就別在意了……",
        "unit_id": 102711,
        "voice": "vo_adv_1027009_059"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
