    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "時間儀啊……",
        "unit_id": 116611,
        "voice": "vo_adv_6066202_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒想到還真的能穿越時空呢。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "既然有這種方便的東西，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "為什麼老大要藏起來呢？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "的確老大她，",
        "unit_id": 116611,
        "voice": "vo_adv_6066202_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "腦袋好到幾乎讓人以為她會預知未來呢。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n況且使用時間儀好像也不是沒有風險，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總覺得我好像懂",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "為什麼老大她不使用這個了……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你是說那個人不知道有這個功能嗎？",
        "unit_id": 116611,
        "voice": "vo_adv_6066202_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣想",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "很合理……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但她可是老大，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總覺得背後有什麼謀算呢……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……你也是這麼想嗎？",
        "unit_id": 116611,
        "voice": "vo_adv_6066202_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "果然是這樣沒錯吧……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "實際上我們也",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "差點就大事不妙了。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n還是不要過度使用比較好……",
        "unit_id": 116611
    }
]