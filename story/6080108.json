[
    {
        "type": "background",
        "background": "501050"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "今回のアタシは、",
        "unit_id": 113111,
        "voice": "vo_adv_6044108_000"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "なんか先走っちまって",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "よくなかったね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "アンナやナナカがいてくれて",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "本当に助かったよ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "誰かに頼ったり任せることも、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "必要だって",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "忘れちまってたね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "はは、",
        "unit_id": 113111,
        "voice": "vo_adv_6044108_001"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "お前さんには",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "いつも頼らせてもらってるよ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "そんな風に心配する必要は無いから",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "安心しとくれ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "……ありがとさん。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "ああ、",
        "unit_id": 113111,
        "voice": "vo_adv_6044108_002"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "そうだね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "いつもバカなことばっかりしてると思ってたけど",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\nいざって時にはやってくれる仲間だってこと、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "頭から抜けてたよ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "もうちょい普段からしっかりしてくれると",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "うれしいんだけどね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "アタシは一人旅が長かったから、",
        "unit_id": 113111,
        "voice": "vo_adv_6044108_003"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "一人で動くのが癖になってたんだね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n巻き込まれた形とはいえ、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "ギルドの仲間ができたんだからね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "少しずつ癖が抜けるように、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "意識を変えていくつもりだよ。",
        "unit_id": 113111
    }
]