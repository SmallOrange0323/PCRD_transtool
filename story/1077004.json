        "voice": "vo_adv_1077004_088"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以可能會出現魔物之類的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請好好地戒備。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n總之，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "像這樣悠閒的睡懶覺是不行的哦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哈哈。",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_089"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然你的心意我很開心，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過應該不用了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你看，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_090"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "看得到嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n好像因為我晚歸的關係，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大小姐擔心我",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就跑來迎接的樣子。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是的，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_091"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總是愛操心呢……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐～！",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_092"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n鈴莓在這裡，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不好意思讓您擔心了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請放心！",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_093"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n無論發生什麼事，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會好好地回到大小姐的身邊！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_094"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那麼，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我就先告辭了哦……{player}。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "【美食殿堂】的大家，旅行",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_095"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "預計是四天三夜嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這樣的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明天也能遇到呢……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果可以的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明天請再光顧海之家吧。",
