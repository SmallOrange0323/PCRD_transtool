        "name": "鈴莓",
        "words": "{player}呢，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_067"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n總之先不要動",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "給我保持安靜。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "等一下，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_068"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會好好地和你道謝還有賠罪。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n……那麼，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我就暫時先離開囉♪",
        "unit_id": 102531
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦你了。",
        "unit_id": 190011,
        "voice": "vo_adv_1077004_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1077004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n醒來之後，就會全都忘光囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不是我要說，你真的是很常差點死掉呢……",
        "unit_id": 190011,
        "voice": "vo_adv_1077004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n難道是命中帶有劫難嗎，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你冒失的程度偶爾和鈴莓不相上下，還是說你犯的程度比他還厲害？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小心一點哦～，",
        "unit_id": 190011,
        "voice": "vo_adv_1077004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要生命還在就有無限可能呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n特別是『這邊』",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "相對『那邊』該說是氣氛比較肅殺嗎，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這邊的世界是血腥殘酷的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一不小心，真的就會突然死掉哦。",
        "unit_id": 190011,
        "voice": "vo_adv_1077004_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過算了。",
        "unit_id": 190011,
        "voice": "vo_adv_1077004_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在夜裡的海邊睡著的話，好像會被海浪捲走……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n快點給我醒來，{player}。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後，好好慰勞一下一直都很努力工作的女僕吧♪",
        "unit_id": 190011,
        "voice": "vo_adv_1077004_075"
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呼嚕、",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_076"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呼嚕……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……",
