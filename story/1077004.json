        "voice": "vo_adv_1077004_062"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n嚇了我一跳，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}恢復呼吸了呢！",
