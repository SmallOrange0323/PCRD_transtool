    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那天晚上。"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "…………",
        "unit_id": 1411,
        "voice": "vo_adv_1077004_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……結果，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一個客人也沒來呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為什麼呢？",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然對我來說",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "能在客人沒來的時候，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n把工作方法之類的",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好好練習一輪，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以覺得得救了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過對店裡來說，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "客人不來的話",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "果然很困擾吧……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "就是呢……",
        "unit_id": 1411,
        "voice": "vo_adv_1077004_004"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n啊啊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這下子也許得認真思考全家同歸於盡了也說不定。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "別、",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "別這麼灰心啊，店長！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不能這麼悲觀！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我也會一起加油的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請您打起精神來～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "謝謝……",
        "unit_id": 1411,
        "voice": "vo_adv_1077004_006"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不過冷靜地思考後覺得，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n明明是來海邊玩的季節，卻沒有客人來",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "果然有點奇怪呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "今天太陽也下山了，",
        "unit_id": 1411,
        "voice": "vo_adv_1077004_007"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "雖然店也要打烊了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n明天……開店前，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n我會稍微試著在城鎮調查各種情報還有宣傳之類的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我想一邊查明海邊空無一人的原因，",
        "unit_id": 1411,
        "voice": "vo_adv_1077004_008"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n一邊想辦法招攬客人。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "就像你說的，",
        "unit_id": 1411,
        "voice": "vo_adv_1077004_009"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不能這麼悲觀……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n夏天才正要開始呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就、",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就是這樣！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就是這個志氣哦！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那麼也許明天開始",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "客人就會蜂湧過來，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n會變得很忙也說不定呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "既然要打烊的話，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我想今天就快點回去，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n好好的休息。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "嗯。",
        "unit_id": 1411,
        "voice": "vo_adv_1077004_013"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n鈴莓辛苦你，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "先給你今天工作的薪水。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊啊……",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不對",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "今天",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒什麼客人，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "根本沒什麼工作！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "出勤工作一直到最後一天為止，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n再看營業額之類的",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "結算差不多的薪水給我就好了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這樣不行啦。",
        "unit_id": 1411,
        "voice": "vo_adv_1077004_016"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n而且打工招募的事項上面，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n也寫著每天會",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "好好支付薪水呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不會不會，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒問題的啦。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n話說如果",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為我領薪水的關係，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n害得店長一家人要上吊自殺的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我晚上會睡不著覺的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "嗯嗯。",
        "unit_id": 1411,
        "voice": "vo_adv_1077004_018"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不好意思呢……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "明天開始我會好好地招攬客人產出營收，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n然後支付你薪水的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "拜託別拋下我，",
        "unit_id": 1411,
        "voice": "vo_adv_1077004_019"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "希望你明天也能來好好地工作。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n如果能順利的產出營收，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n再努力一點的話也許能付你獎金！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不～，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請別太勉強自己呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對我來說",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "光是能讓我獲得這麼珍貴的經驗，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就已經非常的感激您了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那麼那麼，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我先回去囉～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明天見，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還請多多指教哦♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "嗯嗯。",
        "unit_id": 1411,
        "voice": "vo_adv_1077004_022"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "真是個好孩子……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n就算是為了鈴莓也好，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "來努力地招攬客人吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唉……",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n天色完全變暗了呢，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "得快回去才行。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果太晚回去的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "會讓大小姐他們擔心呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過這種感覺，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還滿新奇的呢……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可能因為以前",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總是在家裡，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n等著大小姐和其它人回來的關係）",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "從店長那邊得到了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "很珍貴的經驗呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……嗯？",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，{player}！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "晚安～，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還待在海邊呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不過太陽已經下山了有點涼，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n像這樣還穿著泳裝發呆的話",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "會感冒的哦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚啊！？",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n咦，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎麼突然發光了呢……！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唉呀，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唉呀呀？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n嚇到的瞬間被沙子給絆倒了，要、要跌倒了……！？",
        "unit_id": 102511
    },
    {
        "type": "background",
        "background": "510190"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你好呀～、{player}♪",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}也來泳池玩嗎？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "畢竟最近",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_032"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "每天都好熱呢～。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我們家",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為大小姐不太愛開冷氣之類的，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n夜晚變得悶熱的話，真的難以入睡。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為這樣，有點睡眠不足……",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然身為女僕，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n必須在任何時候都做好能侍奉主人的萬全準備才行。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不不，這是理所當然的技能！",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n而且雖然嘴上說得很了不起，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但能不能做到還很難說……♪",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的。",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n今天純粹是來陪大家～，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒有游泳的打算。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n而且",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我原本就沒帶泳裝。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然這麼說有點晚。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我是",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為大小姐要和同學一起去泳池玩，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以才來陪他的。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "偶爾也會有",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣的時候……",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然大小姐多半會說，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n鈴莓也一起來玩吧～",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "像這樣邀請我。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但因為大小姐的同學，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "都是比我年長的高中生……",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n與其說有點讓人害怕，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "比較像是讓人感到誠惶誠恐。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過如果有什麼狀況的話，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還是希望能在她身邊馬上幫她處理……",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然很煩惱，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_040"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n像這樣保持微妙的距離，有種從遠方守護她的感覺。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只是遠遠地眺望著，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n好像玩得很開心的大小姐……",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我就很滿足了。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是什麼都無法取代的幸福短暫時光哦。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。難得來泳池，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_042"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然不游泳的話好像很可惜。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是因為我很冒失，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_043"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不小心溺水的話好像會給你添麻煩……",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀哇？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_044"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n才剛說完就犯了冒失，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n在濕濕的泳池地板上腳滑……",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要跌倒了！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "話說，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_045"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要掉到泳池了……",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀啊啊啊啊！？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咕嚕咕嚕……",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n啊啊，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我又做了冒失的事！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "　好、好難受！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n衣服纏繞著身體，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒辦法隨心所欲的動作！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如、",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_047"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果知道會這樣，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也許早點穿著泳裝就好了？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然這麼說，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "現在才感嘆也只能算馬後砲呢！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總之先認真的在溺水前，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n想辦法浮上水面……",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "奇怪？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_049"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}突然跳進來了呢！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是打算",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "來救我……",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "的嗎？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀啊……？",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_050"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}，\n頭是不是",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "撞到泳池的底部了？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為氣勢十足地跳進來呢……！",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_051"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n嗚哇，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有沒有失去意識？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}～！\n沒事的，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_052"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我現在就來救你哦！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾分鐘後。"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呼、",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_053"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呼……",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你沒事吧，{player}？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊啊，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_054"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這下已經完全失去意識了呢！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n該怎麼辦才好啊，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這種時候……？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n回想起溺水事件時的緊急處理手冊吧！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "首先要確保呼吸道暢通，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_055"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "按摩心臟！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "喝啊喝啊，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "快復活～吧！",
        "unit_id": 102531
    },
    {
        "type": "still",
        "still": "107700401"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "然後",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_056"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘴對嘴人工呼吸……！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "…………",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_057"
    },
    {
        "type": "still",
        "still": "107700402"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……嗚嗚，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_058"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我在猶豫什麼呢！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這個是神聖的，拯救生命啊！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這和親吻是不一樣的事情，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不需要覺得害羞",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "才對！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "抱歉了，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_059"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}！\n雖然可能是你的第一次，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n對於要奪走你人生只有一次重要的那個我也感到很難過！",
        "unit_id": 102531
    },
    {
        "type": "still",
        "still": "107700403"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒辦法，",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_060"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請原諒我！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就算之後責怪我也沒關係，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}的生命",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "比較重要！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "………！",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_061"
    },
    {
        "type": "background",
