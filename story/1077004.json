        "voice": "vo_adv_1077004_096"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明天見囉……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在這個大海再次相見吧♪",
        "unit_id": 102511
