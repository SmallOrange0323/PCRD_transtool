        "voice": "vo_adv_1077004_077"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哈嗚？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n奇怪，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我真是的，不小心睡著了嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唔……",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_078"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在沙灘摔了一大跤，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n好像就這樣",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "輕易地失去意識了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "太丟臉了～，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我真是冒失啊♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊啊，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_079"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "女僕裝都沾滿沙子了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n回去之後得洗一洗才行。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_080"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}就睡在我的正側方！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n為什麼呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為了掩護跌倒的我，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_081"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "滑倒掉進去……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n被倒下的我給撞倒的時候撞到了頭，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n然後就暈過去了嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然不是很懂……",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_082"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}的臉也太近了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不小心就會親到嘴的距離啊～。",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_083"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不行，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要等變成大人之後才行！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}！",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_084"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n快醒來，{player}！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不醒來的話，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_085"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n難、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難道要人工呼吸嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸，",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_086"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀啊啊！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請不要突然坐起來，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "剛剛",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我說的話你都聽到了嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請把它忘記，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那是我一時混亂！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚……",
        "unit_id": 102511,
        "voice": "vo_adv_1077004_087"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總之因為夜已經深了，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請注意著腳步朝著住宿地點前進吧。",
