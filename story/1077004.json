        "voice": "vo_adv_1077004_063"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是千鈞一髮！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n剛剛真的很危險呢！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是的。",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_064"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然全都是因為我的冒失，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n好像也不太能對你說教……",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不過救人的人竟然還溺水什麼的，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是難以想像的大失誤呢。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "給我好好反省！",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_065"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n……",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過太好了，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}平安無事。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唉呀……",
        "unit_id": 102531,
        "voice": "vo_adv_1077004_066"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n因為大小姐好像察覺到騷動就跑了過來，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我去解釋一下事情的原委哦。",
        "unit_id": 102531
    },
    {
