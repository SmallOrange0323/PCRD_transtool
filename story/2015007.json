    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好、",
        "unit_id": 101112,
        "voice": "vo_adv_2015007_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好像有效了耶……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們的攻擊！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不可以大意喔！",
        "unit_id": 104911,
        "voice": "vo_adv_2015007_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們這邊也一樣，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "光是大家還能站著就已經很不可思議了……！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是……",
        "unit_id": 100111,
        "voice": "vo_adv_2015007_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不到最後，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我是絕對",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不會放棄的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了這座城市……",
        "unit_id": 100312,
        "voice": "vo_adv_2015007_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "同時，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也是為了守護這個世界！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯！",
        "unit_id": 100211,
        "voice": "vo_adv_2015007_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n和騎士先生一起！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……啊啊，",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_005"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這真是……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "太糟糕了。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "令人反胃也該有個限度。",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_006"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n每當我被你們添上了一道新的傷痕，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "每當我又再白白浪費了一絲力量之時，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我的理想鄉、",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "新世界，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就離我愈來愈遠……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下……",
        "unit_id": 106011,
        "voice": "vo_adv_2015007_007"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是讓人費解啊。",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_008"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n為何",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們能如此愚鈍、",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "無知地活下去呢？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們對這個錯誤的世界，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "難道就沒有抱持過一絲疑問嗎？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還說什麼",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_009"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "守護？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那有如奴隸對身上的枷鎖引以為傲般的愚昧之舉！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是讓人看不下去啊……！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呃……",
        "unit_id": 100312,
        "voice": "vo_adv_2015007_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哇啊！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔……",
        "unit_id": 107111,
        "voice": "vo_adv_2015007_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒想到，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "您還留有如此驚人的力量……！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n果然厲害啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "陛下！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "是啊，",
        "unit_id": 191011,
        "voice": "vo_adv_2015007_012"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "但是……！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "嗚……",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_013"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "咳咳！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n咳、",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "咳咳……！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對我們進行攻擊的",
        "unit_id": 100211,
        "voice": "vo_adv_2015007_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "霸瞳皇帝，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "反而還比較痛苦的樣子……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "原來如此……！",
        "unit_id": 101711,
        "voice": "vo_adv_2015007_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n是因為我們剛才讓她受的傷……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n導致她的身體承受不住",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "釋放魔法的副作用了呀！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……已經夠了，",
        "unit_id": 106011,
        "voice": "vo_adv_2015007_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請您住手吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼您不惜做到這個地步……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳真是不懂事的孩子呢，",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_017"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "凱留！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我從剛才開始，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不就說過好幾次了嗎！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這都是為了我的願望！",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_018"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n為了構築出",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "值得由我統治的嶄新世界……！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下……",
        "unit_id": 106011,
        "voice": "vo_adv_2015007_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那番話――",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是真的嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦……",
        "unit_id": 105811,
        "voice": "vo_adv_2015007_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小可蘿？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔……？",
        "unit_id": 106011,
        "voice": "vo_adv_2015007_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "霸瞳皇帝。",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若真如您所言，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "構築新世界之事就是您最大的願望……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼您……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為何您還要",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "奪走貪吃佩可小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的身分呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_025"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "像妳這樣的孩子，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "或許還無法理解這種事情也說不定……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n不過，一旦成為一國之君，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "能掌控的權力也會無比龐大。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不但能擁有國家全部的財產。",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_026"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "連機密的情報也能自由取得",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "或隱藏。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "另外，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還能擁有如同奴隸般的士兵們。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在成就我願望的這條路上……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "他們也還算是",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "派得上用場唷？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳這傢伙……！",
        "unit_id": 104711,
        "voice": "vo_adv_2015007_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……確實，",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如您所言。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n坐上王座之人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將會有無數的利益得以相伴也說不定。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與此同時……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不論是多麼有才幹的統治者，",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或是暴君。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了治理國家",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所需要的勞力，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想必也相當龐大才是。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105811,
        "voice": "vo_adv_2015007_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是這樣沒錯……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n的確不管是父皇還是母后，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總是看起來很忙的樣子……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是如此……",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這便是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相當弔詭之事。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您這樣就等同於將非達成不可的願望擱至一旁，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而選擇浪費時間繞遠路一樣。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……儘管事到如今",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經不必多言……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下的願望，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便是替主人指引路途、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "照料主人的一切，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n以及",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直陪著主人向前邁進。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "方才，",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人陷入了生死存亡的關頭。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下才明白",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個願望對自己來說是多麼地深切，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又是多麼地重要，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下又重新體悟到了這個事實。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "霸瞳皇帝。",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您同樣也抱持著",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此深切",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而重要的願望……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如今的在下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也能夠想見。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "統治國家時所能獲得的財產、",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "權力，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或是人力，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論在下如何思索，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這些事物對您來說都絕非必要。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "光以現況來看，",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您不就以一人之身，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n輕易地制衡住在下等人了嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也因此得出了一個疑問……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……住口……",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "得出了霸瞳皇帝",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "之所以奪走貪吃佩可小姐的身分，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是否還有其他理由──",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的疑問。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "譬如說……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "給我住口！",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔……！",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "譬如說……",
        "unit_id": 105811,
        "voice": "vo_adv_2015007_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n該不會，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實是想當當看公主嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊……！",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_044"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳在說什麼蠢話啊？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n那麼",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "幼稚的願望，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我怎麼可能……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……原來如此，",
        "unit_id": 107011,
        "voice": "vo_adv_2015007_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是這麼一回事啊……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n最後一塊拼圖終於湊齊了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該說是我終於回想起",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我那原本曖昧不明的記憶了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……真那。",
        "unit_id": 107011,
        "voice": "vo_adv_2015007_046"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n剛才貪吃佩可的那番話，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "即使沒有說中，也相去不遠了對吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105811,
        "voice": "vo_adv_2015007_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那果然是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想要當公主嗎……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊……！",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_048"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不是！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我……！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我直到剛剛",
        "unit_id": 107011,
        "voice": "vo_adv_2015007_049"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都還很在意。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不久前，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真那才向優衣如此說道……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「我很羨慕妳。」",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "的、",
        "unit_id": 100211,
        "voice": "vo_adv_2015007_050"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "的確有說過呢……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且，",
        "unit_id": 100211,
        "voice": "vo_adv_2015007_051"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我記得……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "她還說過自己簡直",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就像是壞皇后一樣",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "的話。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n雖然我當時",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "並不明白這是什麼意思……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯。",
        "unit_id": 107011,
        "voice": "vo_adv_2015007_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而且還有，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n「我已經不再是適合夢與冒險的世界的年紀了……」",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n她也說了這番話。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……真那。",
        "unit_id": 107011,
        "voice": "vo_adv_2015007_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳之所以帶領七冠，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "製作出阿斯特朗……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是因為妳想像故事中那樣，",
        "unit_id": 107011,
        "voice": "vo_adv_2015007_054"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "進行一場令人雀躍不已的冒險。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是因為妳想像故事中那樣，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "成為一名被騎士所守護的公主。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "被眾人所愛戴──",
        "unit_id": 107011,
        "voice": "vo_adv_2015007_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳想成為這樣的公主……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我說的沒有錯吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_056"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……唉……",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_057"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……是啊。",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_058"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這麼無趣、",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "愚蠢又不切實際的夢想……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n或許我也曾經有過呢。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "然而，",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_059"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就算是那樣又如何？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n對即將",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在這裡",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "被我殺光的你們來說……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n不論我的願望是什麼，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "都和你們沒有任何關係……！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "的確，",
        "unit_id": 104711,
        "voice": "vo_adv_2015007_060"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳說得沒錯……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不論妳有什麼隱情，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n事到如今我們也不會因為這樣就手下留情。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……妳一直覺得很無趣的理由，",
        "unit_id": 105811,
        "voice": "vo_adv_2015007_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我終於明白了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果妳的願望是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想要成為一名真正的公主……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼只是扮演我的替身，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是不可能會讓妳感到滿足的嘛。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是……",
        "unit_id": 105811,
        "voice": "vo_adv_2015007_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算真的是這樣，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還是不得不把妳打倒。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家都已經快到極限了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺也非常不妙……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "霸瞳皇帝的身邊也是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不僅沒有能夠幫助她的夥伴，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想必也沒有恢復的手段了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這場戰鬥應該還有勝算才是……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是嗎……",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_064"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是否真是如此呢？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……？",
        "unit_id": 105911,
        "voice": "vo_adv_2015007_065"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "能夠幫助我的夥伴……",
        "unit_id": 106915,
        "voice": "vo_adv_2015007_066"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "現在這個地方，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還有一個人在啊。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n吶，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我說的沒錯吧！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n凱留……！",
        "unit_id": 106915
    }
]