[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是傳說的吸血鬼伊莉亞‧奧恩斯坦\n透過惡魔偽王國軍之手而\n復活之後不久的事……"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼呼呼……",
        "unit_id": 1,
        "voice": "vo_adv_5003000_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這種程度的光就想打倒妾身嗎……",
        "unit_id": 1,
        "voice": "vo_adv_5003000_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "笑死我了……！",
        "unit_id": 1,
        "voice": "vo_adv_5003000_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n無論多少人也妨礙不了妾身的甦醒啦……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哈哈哈……",
        "unit_id": 1,
        "voice": "vo_adv_5003000_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n哈────哈哈────！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈哈哈……哈哈……",
        "unit_id": 104412,
        "voice": "vo_adv_5003000_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呼啊─……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然想試著一口氣清醒，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但身體卻很老實……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好睏哦……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "黑暗鬧鐘",
        "words": "睡吧──！睡吧──！",
        "unit_id": 1,
        "voice": "vo_adv_5003000_005"
    },
    {
        "type": "dialogue",
        "name": "黑暗鬧鐘",
        "words": "\n時間還早啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看吧……",
        "unit_id": 104412,
        "voice": "vo_adv_5003000_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n連黑暗鬧鐘都說繼續睡了……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可是……妾身不想再那樣一直優雅地睡下去了。",
        "unit_id": 104412,
        "voice": "vo_adv_5003000_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然甦醒是好事，",
        "unit_id": 104412,
        "voice": "vo_adv_5003000_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n只不過身體要恢復原來的狀態還早得很……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然明白讓身為眷屬的那傢伙碰到的話，",
        "unit_id": 104412,
        "voice": "vo_adv_5003000_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身就能勉強恢復大人的姿態，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但仍能感覺到基礎魔力壓倒性地不足……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "果然是睡了太長時間，",
        "unit_id": 104412,
        "voice": "vo_adv_5003000_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n身體僵硬了嗎……？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼呣……該不會是因為在這個時代甦醒，",
        "unit_id": 104412,
        "voice": "vo_adv_5003000_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n所以沒做什麼像樣的運動的緣故呢……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是不是偶爾也該散散步呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "茜里也說過，動動身體會感覺舒服些呢。",
        "unit_id": 104412,
        "voice": "vo_adv_5003000_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好！那就出發吧！",
        "unit_id": 104412,
        "voice": "vo_adv_5003000_013"
    },
    {
        "type": "dialogue",
        "name": "黑暗鬧鐘",
        "words": "睡著吧──！睡著吧──！",
        "unit_id": 1,
        "voice": "vo_adv_5003000_014"
    },
    {
        "type": "dialogue",
        "name": "黑暗鬧鐘",
        "words": "\n白天太陽很刺眼哦──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吵死了啦！",
        "unit_id": 104412,
        "voice": "vo_adv_5003000_015"
    },
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "另一方面，這時候有一個消息在【哞哞自衛隊】\n的公會小屋裡傳開了。"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "大家聽到了嗎！？",
        "unit_id": 104311,
        "voice": "vo_adv_5003000_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　糟糕了！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "什麼事啊。真琴怎麼臉色大變地衝了進來呢。",
        "unit_id": 101011,
        "voice": "vo_adv_5003000_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "何必那麼著急呢？",
        "unit_id": 101011,
        "voice": "vo_adv_5003000_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴的那份點心，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還好好地留著哦。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這是紅豆大福哦。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嘴巴張開，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說啊～……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂，公主……",
        "unit_id": 104311,
        "voice": "vo_adv_5003000_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……咦？啊、啊～……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不對，",
        "unit_id": 104311,
        "voice": "vo_adv_5003000_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不是做這種事的時候啦！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "昨日，有一對雙胞胎魔族女孩",
        "unit_id": 104311,
        "voice": "vo_adv_5003000_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n來我打工的小酒館吃飯……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我不小心聽到了她們的對話……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "她們竟然說，過去曾企圖征服世界的傳說吸血鬼……的傢伙，",
        "unit_id": 104311,
        "voice": "vo_adv_5003000_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n在蘭德索爾甦醒了！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "傳說的吸血鬼……？",
        "unit_id": 101711,
        "voice": "vo_adv_5003000_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n怎麼覺得好像有聽過又好像沒聽過的感覺～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，雖說我也是第一次聽到……",
        "unit_id": 104311,
        "voice": "vo_adv_5003000_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n吸血鬼就是啊……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n像這樣長著獠牙的怪物……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊！是說風獅爺嗎～？",
        "unit_id": 101711,
        "voice": "vo_adv_5003000_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那就不必擔心啦～！風獅爺是守護神嘛～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "才不是風獅爺咧！",
        "unit_id": 104311,
        "voice": "vo_adv_5003000_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就說是吸血鬼了啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "吸血鬼……就是那種在漆黑深夜出沒在街上，",
        "unit_id": 101411,
        "voice": "vo_adv_5003000_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n吸食年輕少女鮮血的怪物呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，原來如此……",
        "unit_id": 101011,
        "voice": "vo_adv_5003000_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那蘭德索爾還真是甦醒了可怕的傢伙哦～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "確實，人家好像也在真步真步王國流傳的繪本裡讀過，",
        "unit_id": 101011,
        "voice": "vo_adv_5003000_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n過去蘭德索爾曾因為傳說的吸血鬼而陷入",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n天翻地覆……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "果然",
        "unit_id": 104311,
        "voice": "vo_adv_5003000_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不能放著不管呢……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "獸人的……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "夥伴們的安全就是我們自衛隊的使命啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們去打倒那個吸血鬼吧！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可是，那個吸血鬼……到底在哪裡～？",
        "unit_id": 101711,
        "voice": "vo_adv_5003000_031"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃……那個嘛……",
        "unit_id": 104311,
        "voice": "vo_adv_5003000_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴可真是急躁呢～。",
        "unit_id": 101011,
        "voice": "vo_adv_5003000_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n首先必須要收集那個吸血鬼的情報才對吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且畢竟【哞哞自衛隊】的工作已經堆積如山了，",
        "unit_id": 101011,
        "voice": "vo_adv_5003000_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n突然全體出動也可能白白浪費人力呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "確實是像公主說的呢……",
        "unit_id": 104311,
        "voice": "vo_adv_5003000_035"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也有巡邏的工作不能任意離開。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我的文書工作也還沒做完，而收集情報是很花時間又很麻煩的。",
        "unit_id": 101411,
        "voice": "vo_adv_5003000_036"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我想現在還不適合隨便行動吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是吧？找個人去調查就好了吧，",
        "unit_id": 101011,
        "voice": "vo_adv_5003000_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n畢竟也不能疏忽手邊的工作。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴有巡邏的工作，",
        "unit_id": 101011,
        "voice": "vo_adv_5003000_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "霞有文書相關工作。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那吸血鬼的情報，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就由人家和香織去蒐集吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "畢竟咱們今天已經沒事了。",
        "unit_id": 101011,
        "voice": "vo_adv_5003000_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n香織也沒問題吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒問題～！",
        "unit_id": 101711,
        "voice": "vo_adv_5003000_040"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n蘭德索爾的和平就讓我們來守護吧～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真可靠♪",
        "unit_id": 101011,
        "voice": "vo_adv_5003000_041"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "照這樣子，別說是調查吸血鬼，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n說不定甚至可以收拾掉它呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔嗯……",
        "unit_id": 101411,
        "voice": "vo_adv_5003000_042"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣妳們兩人就是傳說中，挺身對付傳說吸血鬼的，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n【吸血鬼獵人】了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你說【船到橋頭自然直】？",
        "unit_id": 101711,
        "voice": "vo_adv_5003000_043"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我平常就是船到橋頭自然直哦？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我說的是吸血鬼獵人啦。",
        "unit_id": 101411,
        "voice": "vo_adv_5003000_044"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
