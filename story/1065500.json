[
    {
        "type": "background",
        "background": "509010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘿！　",
        "unit_id": 106511,
        "voice": "vo_adv_1065500_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你突然找我出來是有什麼事嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是不是帶了什麼好康的消息過來啊？　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "快點告訴我吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我還在想是什麼事呢！",
        "unit_id": 106511,
        "voice": "vo_adv_1065500_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "原來是老娘的生日啊！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你還真是個細心的人呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這一點，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我倒是不討厭！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "工作的案件當然也很好，",
        "unit_id": 106511,
        "voice": "vo_adv_1065500_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過死黨幫自己慶生也很棒。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然不太符合我的個性，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過如果你要幫我慶生當然沒問題。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也算我",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一份吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈！　",
        "unit_id": 106511,
        "voice": "vo_adv_1065500_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你在說什麼啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "打架這種事情我可是一天也不會休……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊～原來如此！　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天是老娘的生日啊！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "最近每天都在打架，",
        "unit_id": 106511,
        "voice": "vo_adv_1065500_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這事都被我忘得一乾二淨了……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這麼重要的事，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還是死黨提醒我才想起來的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂喂……",
        "unit_id": 106511,
        "voice": "vo_adv_1065500_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就算我再怎麼愛打架，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也沒有興趣跟死黨對打。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊？　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是這個意思？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你說你要幫老娘慶生……？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "既然這樣你要早點說啊。",
        "unit_id": 106511,
        "voice": "vo_adv_1065500_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我都擺好架式了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "完全被你的驚喜給騙到了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼今天一整天，",
        "unit_id": 106511,
        "voice": "vo_adv_1065500_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你可要陪我到最後喔。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "畢竟你都找我出來了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "想必早有心理準備了吧？",
        "unit_id": 106511
    }
]