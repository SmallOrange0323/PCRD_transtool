        "words": "\nちゃんと",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "戦うための準備はしてあるわよ。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\nどんな状況にも対応できてこそだものね。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
