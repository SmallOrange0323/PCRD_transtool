        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "怎麼會這樣……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "她、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "她們兩個",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "變成石頭……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "喔～",
        "unit_id": 134911,
        "voice": "vo_adv_5160322_003"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呵呵！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "石化不是妳的專利啊。",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "好啦，",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "妳也乖乖變成石頭吧。",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n我會讓妳沒有痛苦地結束的！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "……結束？",
        "unit_id": 133611,
        "voice": "vo_adv_5160322_004"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "別開玩笑了啊。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n這兩個人沒有那麼簡單就會結束的！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "她們馬上就會復活的，",
        "unit_id": 134911,
        "voice": "vo_adv_5160322_005"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n在那之前我會一個人",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "撐過去給妳看看！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "好氣──！",
        "unit_id": 134911,
        "voice": "vo_adv_5160322_006"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "就是這樣我才覺得小孩子很麻煩啊！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n把她們三個全部變成壓醬菜的石頭吧──！",
        "unit_id": 134911
    }
]