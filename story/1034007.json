[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}走在城鎮裡時，\n發現了正在露天陽台喝酒的優花梨。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，你好～。",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喂喂，你看一下這本雜誌！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "上面寫著『變成大嬸前想體驗看看！\n女性憧憬的心跳加速場面排行榜』……",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呣唔唔唔，真是抱歉呢！",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n反正我就是……沒有體驗過――嘛！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就連能讓我體驗那種場面的對象也沒有――！\n我都還沒體驗過，就要直接變成大嬸了啊――！",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……嗚、嗚嗚，我不要那――樣――！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你在安慰我嗎……？\n",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那麼，你來做？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你為什麼這麼吃驚？ 如果你要安慰我的話……",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就對我做這個排行榜上寫的事情？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，我當然只是打算玩一下而已喔？",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我也想在真的成為大嬸前體驗這種酸甜滋味，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n哪怕只有氣氛也好……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯――？ 唔呵呵，你在擔心什麼呢――？",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "畢竟身為姐姐的我，不可能會對你這種",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n年紀比我小的對象認真嘛――？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對你來說也可以當作練習，\n儘管",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對姐姐出招――吧！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你答應了？ ",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "太好了！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n嗯，那麼就請你從女性憧憬的心跳加速場面排行榜",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n第3名開始依照順序做喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "首先是……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "第3名是壁咚！",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好，我已經試著將背貼到牆邊了喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來吧，放馬過來！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊………………………………",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你、你的臉好近，而且氣息灼熱……",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我也沒有地方可逃……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n一、一被你那樣直直地注視……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我、我……",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不禁變得想要",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n就這麼任你擺佈……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……哎呀？ ",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼、呼。的、的確有點心跳加速了呢！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "若是我少了點成熟大人的從容的話，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n可是會發生不得了的事呢！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……好、好，下一個！",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n嗯，第2名，摸摸頭！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來、來吧！ 請摸吧！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……哈呼～……\n這素怎摸回事，偶要融化惹……",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "欸嘿嘿，讓你的手摸頭好舒服……",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n好想一直被你像這樣摸頭，不管多久……啊！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不、不是，我一點也不覺得心蕩神馳。",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_018"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n因為我是成熟的女性嘛，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "綽、綽綽有餘――喔！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼……呼……",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來吧，迅速地解決吧！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n第１名…………",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "從、從背後擁抱？",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不、不不，這實在是……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n因為這實在……對吧？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不，我是綽綽有餘喔？",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_021"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n但你一定比較不願意吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n對吧？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你、你願意從背後抱我？",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這樣啊……那、那麼，隨時都可以喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼……哎、哎呀。",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你的胸膛相當厚實呢……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊――，這是，原來如此，啊――……",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好、好溫暖……",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "心臟噗通噗通的跳動聲重疊在一起……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n耳邊也能聽見呼吸聲……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，討厭……！\n如果再繼續被你這樣緊抱著……！",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_026"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我對你……！ ",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不、不行！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼――，",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼――……好、好險。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n剛才若是再繼續下去的話，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你差點就會喜歡上我了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是，雜誌的資訊不容小覷……",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n書頁被掀起來……我看看。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n唯獨這個不能被看見的女性姿態排行榜第1名？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "未成年女孩是邋遢的模樣……",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n成年女性則是喝太多時的模樣……？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這完全是在說我……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_030"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "果、果然，這種以迎合大眾口味為目標的雜誌，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不能認真看待呢！ 嗯！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "欸？ 啊、是啊，那、那是，已經……",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_031"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n應該",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "說是有精神過頭了，那個……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……啊，已經這麼晚了！",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_032"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "今天謝謝你喔！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我要回去了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……再、",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_033"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "再見囉♪",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊嗚～，",
        "unit_id": 103411,
        "voice": "vo_adv_1034007_034"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "跌倒了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我的心跳太快，所以腰腿還使不上力……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優花梨對於今天發生的事情明顯感到強烈動搖，\n慌慌張張地回去了……"
    }
]