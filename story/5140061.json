[
    {
        "type": "background",
        "background": "501070"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "王家主催のクリスマスイベントまで一ヵ月を切ったある日。"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n執務室でクレジッタは頭を抱えていた。"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ああっ……",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_000"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "不安ですわ！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "不安不安っ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n「安からず」と書いて不安！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "当日まで時間がないというのに、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "不安でおかしくなりそうですわ……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "綿密に立てたプランに、",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_001"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "資材や商品、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "催し……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "全てこの目で選び抜いた一級品ばかり。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n必ずや陛下のお眼鏡にかなうはずですのに、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "なぜなんですの！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "やっぱり計画を一から見直すべき？　",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_002"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いいえいいえ、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nどこかにミスがないか、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "まずは計画書を最初からチェックして……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ほら、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女も手伝いなさいな！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そっちの山を頼みますわよ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_003"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不安なお気持ちは分かりますが、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\nここまで進んだ計画を",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "今ひっくり返したら",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "経費がどれだけ",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\nかかるかも",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "お分かりでしょう。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "計算してお見せしますか？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "いまさら大枠は変えられない以上、",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_004"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n腹をくくっていただかないと。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "言われなくともわかってますわ。",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_005"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nですが、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "これは陛下自らがわたくしに任せてくださった仕事！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n万全に万全を期すためには",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "労も金も惜しみませんわよ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "まあ、",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_006"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "慎重になってくれているのはいいことです。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "うっかり調子に乗った挙句",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "失敗してクビになっても",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "困りますしね。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女ねえ！　",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_007"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ただでさえ不安にさいなまれている雇い主に",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n縁起の悪いこと言わないでくださる！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "これでもし失敗して陛下のおそばにいられなくなったら",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_008"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nどうしてくれるんですの！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "わたくしの心痛、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n貴女のボーナスをカットするだけじゃ補填できませんわよ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "困りましたね、",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_009"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "すっかりテンパってしまっています。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "私に腹パンや首根っこをストッとやれる技術があれば",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "クレジッタさまを落ち着かせて差し上げられたのですが……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ちょっ、",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_010"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "秘書１号っ！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n物騒なセリフを吐きつつ",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n腕まくりしながら近づかないでいただけますことかしらっ！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "あ、",
        "unit_id": 105812,
        "voice": "vo_adv_5132061_011"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "あの……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "大きな声が聞こえましたが",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "大丈夫ですか？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "へ、",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_012"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "陛下！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いえいえいえ",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ななななんでもありませんわほほほほほ……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "丁度いいところにいらっしゃいました、",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_013"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "陛下。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "クレジッタさまがイベントへの不安から",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "右往左往しておりますので、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n優しいお言葉の一つでも",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "かけてあげていただけませんか？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "こ、",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_014"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "こら！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "余計なことは言わなくていいんですのよ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "クレジッタさんでも不安に思うこと、",
        "unit_id": 105812,
        "voice": "vo_adv_5132061_015"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "あるんですね☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "今回はクレジッタさんを信頼してお任せしたのですから、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "思うようにばーんとやってください！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "陛下……",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_016"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "なんと寛大で深いお心をお持ちなのでしょう！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いえ",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "もちろん前から知っていましたが",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "何度でも感動してしまいますわっ。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "商人として確かな目を持つクレジッタさんなら大丈夫です！",
        "unit_id": 105812,
        "voice": "vo_adv_5132061_017"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "わたしも秘書さんも信じてますから☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "ええ、",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_018"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "信じてます。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女いくら何でも棒読みが過ぎませんこといつも以上にっ！？",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_019"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "でももし、",
        "unit_id": 105812,
        "voice": "vo_adv_5132061_020"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "執務室で不安になっちゃうようでしたら、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "気分転換に",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "街に出てみてはどうですか？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "街のみなさん、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "クリスマスイベントを楽しみにしてるみたいですよ☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ありがとうございます、",
        "unit_id": 118011,
        "voice": "vo_adv_5132061_021"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "陛下。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "では、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "お言葉に甘えさせていただきます。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "現場を見ずして催事の成功などありえませんもの。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n頭を冷やして",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "よりいいイベントにするとお約束いたします。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "失礼！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……ふぅ、",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_022"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "助かりました、陛下。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "あの方はお金稼ぎに関しては",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\nピカイチですが、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "人を楽しませることは",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "まだ経験値が足りませんから。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "本人の動きなどは",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "見ていて楽しいのですが……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "いえ、",
        "unit_id": 105812,
        "voice": "vo_adv_5132061_023"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "それだけ真摯にイベントに取り組んで",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\nもらえてるってことですから。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "よければ陛下も",
        "unit_id": 6111,
        "voice": "vo_adv_5132061_024"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "街の様子を見てきていただけないでしょうか？",
        "unit_id": 6111
