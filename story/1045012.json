    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這點程度不算什麼……♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "唔！",
        "unit_id": 104511,
        "voice": "vo_adv_1045012_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……不、",
        "unit_id": 104511,
        "voice": "vo_adv_1045012_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不要緊的～♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n流口水……♪",
