[
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "已經很習慣被帆稀叫過去的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n動身前往"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "她所在的【龍族巢穴】公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "歡迎你來～",
        "unit_id": 106711,
        "voice": "vo_adv_1067004_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n可以請你快點來",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "幫我按摩一下肩膀嗎～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只有這樣就不能叫你過來嗎？",
        "unit_id": 106711,
        "voice": "vo_adv_1067004_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "想說以你和我的交情～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "應該不成問題吧♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊～",
        "unit_id": 106711,
        "voice": "vo_adv_1067004_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這麼爽快就讓步啦～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……不過，你的這般溫柔，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我很喜歡呢♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "突然把你叫來，我也覺得很不好意思～",
        "unit_id": 106711,
        "voice": "vo_adv_1067004_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我倒是可以讓你",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "以按摩為藉口，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n稍微做點不正經的事喔～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還是說，",
        "unit_id": 106711,
        "voice": "vo_adv_1067004_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要由我來做呢……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "開玩笑的啦☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你已經開始按摩啦？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……喔喔～☆",
        "unit_id": 106711,
        "voice": "vo_adv_1067004_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "感覺很舒服呢♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n原來你也具有這般才能啊……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯？",
        "unit_id": 106711,
        "voice": "vo_adv_1067004_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好刺眼……？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n咦……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是因為你按摩技術高超的關係嗎……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我覺得、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有點……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "睏",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "了……",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，{player}為了買東西，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了樁丘的商店街。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "午安～！",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "伯母～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "請問流夏在嗎～？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦～？",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "又去釣魚了～？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n她還是老樣子……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那我下次再來～！",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……？",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我說你啊，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "該不會是",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "找我有事吧～？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也對～",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "再怎麼說",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我們也是第一次見面。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "抱歉，問了你奇怪的問題～☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "掰掰～☆",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……他往我這邊看，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "卻不是有事找我。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這也就是說～？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊啊～！",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "他是去買魚的吧～！",
        "unit_id": 106731
    },
    {
        "type": "background",
        "background": "510370"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "──簽名板專用筆已經用完的顏色",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是這個和",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "備用的也順便買起來吧。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……咦？",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你是剛才的……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你好～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n又見面了～♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這本書是",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "龍膽掃帚的……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真巧～♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我也曾看過",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這本漫畫呢～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊！",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "東西",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "掉了一地……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝～！",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你真體貼～☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那個，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你待會有空嗎？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我想向你道謝……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "請你喝杯茶好嗎？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那當然！",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊啊，不過，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣好像變成",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在搭訕似的～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總之……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒問題吧？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為這是經過",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雙方同意的決定嘛♪",
        "unit_id": 106731
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呃～",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "得先自我介紹一下吧？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我是遠野帆稀。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "跟你第一次碰到面的那間商店老闆的女兒，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n是我學生時代的同學。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我出來買東西，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_023"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "想說順便繞過去看一下她，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n結果她好像出門去了。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為我們已經很久沒碰面，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n本來想找她聊聊阿斯特朗的～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒錯～",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_024"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "難不成，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你也",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "認識流夏？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……原來如此～",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你和流夏是一起玩阿斯特朗的夥伴啊～♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "流夏也真有兩下子～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以說，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_026"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你如果有在玩阿斯特朗，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n會買龍膽掃帚的漫畫也",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不足為奇了～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我說，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_027"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你方便告訴我嗎？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你想買那本漫畫的理由。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我也曾看過那本漫畫，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是流夏推薦你買的？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯～？",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_028"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我自己這樣說有點那個，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不過，我不曾聽說",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "流夏有在看那本漫畫。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來如此～☆",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_029"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n推薦你買的夥伴是什麼樣的人呢？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可以告訴我嗎？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好的～♪",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_030"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真抱歉，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n明明我們才剛認識，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我就追根究柢地問個不停。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我一旦碰到自己有興趣的事，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就會很想深入了解……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為你是正值青春洋溢的男孩子嘛。",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_031"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n會有一、兩件想保守祕密的事",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也是正常的嘛～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……不過，我想～",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_032"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n會是祈梨嗎～☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……咦？",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_033"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "等一下喔。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n難道",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真的是祈梨……？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n那個龍人族的女孩……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗎？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別擔心。",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_034"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我知道那孩子的情況，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我不會告訴任何人的。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為，祈梨和我是……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "開外掛的夥伴呢♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_035"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看你又一臉吃驚的樣子～☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n剛才",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是因為祈梨有開外掛，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n所以你才很難開口是吧？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒問題的。",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_036"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "關於那孩子，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我對她的了解，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就像是我自己的事一樣清楚。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你會感到混亂也不無道理～",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_037"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "說得明白點，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我和祈梨",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是朋友♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n雖然沒跟她提到過龍膽掃帚。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我和祈梨",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_038"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在阿斯特朗裡遊玩時，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n也常會聊到現實的事，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以一說到住在樁丘，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n而且還是我的粉絲的人，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我能想到的就只有她。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒錯。",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_039"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我的另一個名字是",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "龍膽掃帚。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n謝謝你剛剛買了我的作品♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "今後也請多指教，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我的新讀者♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊哈哈☆",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_040"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你又大吃一驚了～♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n說得也是，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒想到會在這種地方見到作者吧～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這件事",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你可以向祈梨保密嗎？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "話雖如此，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_041"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也沒想到竟然會猜中……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "剛才的事可說是意外，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你別太在意。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來是這樣……",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_042"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然你認識祈梨，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我應該可以跟你多聊一些吧。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "老實說，別看我這樣，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_043"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "外掛的情報",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "和技術，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n正是我告訴祈梨的～☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "換言之，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_044"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我和那孩子也是夥伴♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "覺得如何？知道我為何會猜中的原因後，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n心情有比較",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "舒暢一點了嗎？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為好像很有趣啊♪",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_045"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "再說，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_046"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你應該知道吧？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n開發阿斯特朗，名為七冠的那群人，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n其實做了很多",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "非常不可取的壞事。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……你沒說你不知道，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_047"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這就表示你是知道的吧？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n看來你對於阿斯特朗的情況也很清楚嘛♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然如此，我就以你已經知道為前提來說囉。",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_048"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n身為開發者的七冠，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "簡直就像是把遊戲，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n當作他們自己的所有物似的，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在阿斯特朗裡為非作歹。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那些人不只是在阿斯特朗裡胡來，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_049"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n甚至還會竄改玩家的帳號",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "隨心所欲地把玩呢？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然如此，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_050"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為何我們玩家就不能這麼做呢？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們根本不知道自己哪一天也會被捲入",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n他們任意妄為的行動中對吧？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣的話，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_051"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不就非～常不公平嗎～？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就好比只有西洋棋或將棋的發明者，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n可以隨意",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "移動旗子或改變局面，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "根本沒有這種規則對吧？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我只是覺得，既然是同個遊戲的玩家，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_052"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n對方可用的手段，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "自己也應該要能夠使用才對。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只是這樣而已。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要是你和",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_053"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你的夥伴，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n遭到只有七冠或公主騎士才能使用的力量襲擊，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你會怎麼想？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你不會想",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_054"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "使用同樣的力量",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "狠狠地反擊回去嗎？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……至於我嘛，",
        "unit_id": 106731,
        "voice": "vo_adv_1067004_055"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我希望大家，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n可以公平地盡情遊玩阿斯特朗這款遊戲。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n哪怕對戰對手是開發者也是一樣。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為",
