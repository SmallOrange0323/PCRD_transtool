[
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "很～好，",
        "unit_id": 18211,
        "voice": "vo_adv_5140321_000"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "豬隻們！",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n接下來就換個旨趣，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "來「一對一＜單挑＞」吧！？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "妳們之中",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "「最」強的那一隻，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "到「賽場上＜前面＞」來。",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是在叫我嗎？",
        "unit_id": 111011,
        "voice": "vo_adv_5140321_001"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "不是妳，去旁邊坐好。",
        "unit_id": 18211,
        "voice": "vo_adv_5140321_002"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "粉色頭髮雖然有「資質＜潛力＞」，",
        "unit_id": 18211,
        "voice": "vo_adv_5140321_003"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "但終究只是「臨陣磨槍＜外行人＞」。",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "在這點上，金髮精靈族──",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "妳受過的「訓練」可是異常地多啊？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是，",
        "unit_id": 110811,
        "voice": "vo_adv_5140321_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n在教育現場分出第一還第二這種排序，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是違反時代潮流的吧？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "的確有這種說法呢。",
        "unit_id": 110911,
        "voice": "vo_adv_5140321_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "聽說最近甚至有學校舉辦運動會比賽跑時，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n是全體喊「預備～」後一起抵達終點的呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "啊？",
        "unit_id": 18211,
        "voice": "vo_adv_5140321_006"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "那是在搞啥？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n沒有「到達順序」的話是要賭「什麼」才好啊？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n那種「賭場＜比賽＞」是吸引不到客人的吧。",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "奇怪……？",
        "unit_id": 110911,
        "voice": "vo_adv_5140321_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們現在是在說運動會對吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然妳應該是在開玩笑，",
        "unit_id": 111011,
        "voice": "vo_adv_5140321_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但以防萬一我還是先說一下，修女。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒有獲得官方承認的賭博行為",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是被法律禁止的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "法律？",
        "unit_id": 18211,
        "voice": "vo_adv_5140321_009"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n啊啊，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "是那個趁小官不在場時擅自定下的東西啊？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這傢伙，",
        "unit_id": 110811,
        "voice": "vo_adv_5140321_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真厲害啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n竟然把法律",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "說得像是在跟打工的同事喝酒聚會一樣。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過，",
        "unit_id": 111011,
        "voice": "vo_adv_5140321_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是意外啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n正義的學生會竟然與違法行為沾邊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這讓我們獲得了名為告發的王牌。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "蠢蛋，",
        "unit_id": 18211,
        "voice": "vo_adv_5140321_012"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "開玩笑的。",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "小官才不會去賭博，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "小官跟你們打賭。",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "她的腦袋完全變得像是賭徒一樣了，這樣沒問題嗎？",
        "unit_id": 110911,
        "voice": "vo_adv_5140321_013"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "…………",
        "unit_id": 190811,
        "voice": "vo_adv_5140321_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔，",
        "unit_id": 111011,
        "voice": "vo_adv_5140321_015"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不妙！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n綠之監視員一直刻意地在瞥手錶！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那麼，",
        "unit_id": 110911,
        "voice": "vo_adv_5140321_016"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就縮短時間，立刻開始吧！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n優妮們，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "使出全力上吧！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒錯，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好朋友社，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "使出全力上吧！",
        "unit_id": 110911
    }
]