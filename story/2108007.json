        "voice": "vo_adv_2108007_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你說得對。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
