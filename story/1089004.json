[
    {
        "type": "background",
        "background": "500042"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "勸退了追兵的怜與{player}，\n回到【破曉之星】的公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總算是回來了。",
        "unit_id": 108911,
        "voice": "vo_adv_1089004_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是門沒被弄壞就好……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我去泡茶吧。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你坐著等一下。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯？",
        "unit_id": 108911,
        "voice": "vo_adv_1089004_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明在房間裡，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼感覺特別亮。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "到底這個光……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是哪裡……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來的──",
        "unit_id": 108911
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "元旦的隔天。{player}\n接到了怜打來的電話，來到車站前。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喂──",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看這邊。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是這裡喔。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "上這輛車。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不想引人注意，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "快點。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……開車吧。",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_003"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "知道了。",
        "unit_id": 1,
        "voice": "vo_adv_1089004_004"
    },
    {
        "type": "still",
        "still": "108900401"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗨。",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "新年快樂。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉，突然叫你出來。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n當我在思考正好有空不知道做什麼時，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就想到了你。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你過得好嗎？",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "年假還愉快嗎？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯……？",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看你一臉訝異。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……喔喔，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這身打扮嗎？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "直到剛才我還在老家的宴席陪場呢。",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為不想浪費時間，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就直接穿著過來了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝。",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……真是奇妙。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "同樣一句話在宴席上，\n明明已經聽到厭煩，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都不想再聽了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但聽到你這麼說，",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我卻不覺得討厭。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也不枉費我穿這身衣服了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真，",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也真是……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這樣說就太輕浮了不是嗎？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過如果那是真心話就好……",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好、",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好啦。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我知道了！",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不用對我比讚啦！",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "言歸正傳吧。",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你的新年，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "過得怎麼樣？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n應該不會整天都在睡吧？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……難道我說中了？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你還真懶散呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不過，",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能這樣自甘墮落也很讓人羨慕。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我可是",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "每天都過得像招攬客人的熊貓一樣啊。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日復一日，每天都在宴客。",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "陪那些政界財界的大人物……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n感覺快窒息了，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一點活著的實感都沒有。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說起那些傢伙，",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過是仗著家族的權勢對人頤指氣使，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n再把別人的血汗結晶說成自己的成果，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "掛在嘴邊自誇的強盜……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……但說這些話的我，",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "司機是父親雇用，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這輛車也是家裡的……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和他們根本是一丘之貉……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊……",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對不起。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我明明不是為了抱怨",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "才來見你的……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真丟臉呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能去哪裡嗎……",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也好。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難得的機會，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就試試看吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "找個遠一點的……",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不好意思，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "麻煩到海邊。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "知道了。",
        "unit_id": 1,
        "voice": "vo_adv_1089004_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "愉快的車程要開始囉。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這條路是……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可以稍微閒晃一下的樣子。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想吃點甜的東西呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看得到海了。",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n海平線一望無際呢……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "景觀真美。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好，",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "隨便找地方停下來，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們去海邊玩吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不好意思，",
        "unit_id": 1,
        "voice": "vo_adv_1089004_025"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "怜小姐。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n時間已經差不多了。",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "108900402"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊……",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是這樣",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗎。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我知道了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝您。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不客氣……",
        "unit_id": 1,
        "voice": "vo_adv_1089004_027"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "您與朋友的時間，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n請務必",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "要好好珍惜。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……完全就是籠中鳥對吧？",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也是呢。",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難得都來到這邊了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n至少要感受一下氣氛……",
        "unit_id": 100332
    },
    {
        "type": "still",
        "still": "108900403"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……嗯，",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺得到海。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "海風，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "與這個氣味……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣的話，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算在車上也能十足享受到海了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝。",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n像這樣子和你來到海邊的這件事，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會是我重要的回憶。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是……",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在還是，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只能到此為止嗎。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n真不甘心呢。",
        "unit_id": 100332
    },
    {
        "type": "still",
        "still": "108900404"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……嗯，",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說的沒錯呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "跟你……",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有夥伴們一起的話，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該能走得更遠。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "世界的盡頭，",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或者再更遠……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總有一天一定會。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就算是宇宙也感覺能去。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只要你在我身邊，",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我就能一直……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感受到溫暖呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天也是，",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你讓我有了勇氣。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的是",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了。",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_038"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "下次就由你親手，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "把我帶出去好不好？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n然後，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不管哪裡我們都一起去。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……呵。",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是開玩笑的。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦？",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛剛那是開玩笑……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是。",
        "unit_id": 100332,
        "voice": "vo_adv_1089004_041"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你這個人啊。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們就說好囉？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "毀約的話我可饒不了你喔？",
        "unit_id": 100332
    },
