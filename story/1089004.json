    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我絕不放棄。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n總有一天，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
