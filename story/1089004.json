    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我呢。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是，",
        "unit_id": 108911,
        "voice": "vo_adv_1089004_051"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從今以後，",
