    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "覺得如何？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "用你原本記憶作成的夢，待起來舒服嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看怜這樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1089004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就讓人覺得一切都被他人決定的人生還真辛苦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要是本人也不覺得幸福，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就更不用說了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我無法完全理解怜的人生，",
        "unit_id": 190011,
        "voice": "vo_adv_1089004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以除了表示同情以外也不能說什麼。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或許現在的你",
        "unit_id": 190011,
        "voice": "vo_adv_1089004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "跟我一樣也說不定。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是你",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有跟我不一樣的地方。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就是，",
        "unit_id": 190011,
        "voice": "vo_adv_1089004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你能夠陪在怜的身邊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就算是現在的你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也能做到這一點吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和沒有人陪伴比起來，",
        "unit_id": 190011,
        "voice": "vo_adv_1089004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "絕對是有人在身邊比較好嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "回到那邊以後如果發生什麼事，",
        "unit_id": 190011,
        "voice": "vo_adv_1089004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請你一定要為她出一份力喔。",
        "unit_id": 190011
