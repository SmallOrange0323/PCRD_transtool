[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然說是對料理拿手，",
        "unit_id": 114511,
        "voice": "vo_adv_6054207_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但我其實也做不出太精緻的料理就是了……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過呢，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在味道方面我可是很有自信的喔。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是啊，",
        "unit_id": 114511,
        "voice": "vo_adv_6054207_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "的確是。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……那、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "之後",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我打算在育幼院",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "做點什麼料理。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "到時會做我最拿手的菜，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你有空的話也來品嚐看看吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵，",
        "unit_id": 114511,
        "voice": "vo_adv_6054207_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不如我們倆一起挑戰看看吧？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼事情就這麼說定，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "之後別忘了騰出時間來。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……一言為定喔？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……哎唷，",
        "unit_id": 114511,
        "voice": "vo_adv_6054207_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你這人實在是，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真不知道該說你天真，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是該說你狡猾。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是坦白講，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是這樣的讚美",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "最讓人開心了。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……謝謝你。",
        "unit_id": 114511
    }
]