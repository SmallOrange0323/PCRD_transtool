[
    {
        "type": "background",
        "background": "500403"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "噹噹噹～噹☆",
        "unit_id": 105812,
        "voice": "vo_adv_4003005_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n第三次【美食殿堂】吃遍之旅開始囉！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請問解說員小可蘿，有何感想呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，",
        "unit_id": 105913,
        "voice": "vo_adv_4003005_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "突然這樣問在下……解說是指？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那就來說說關於這次祕境",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現有的情報吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個。",
        "unit_id": 105913,
        "voice": "vo_adv_4003005_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這次，我們要到訪的是『斷崖遺跡』。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『斷崖遺跡』可是緊黏在火山噴發而形成的岩層上的，",
        "unit_id": 105913,
        "voice": "vo_adv_4003005_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n謎之遺跡呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡，好像是已經覆滅的古代文明遺跡啊。",
        "unit_id": 105913,
        "voice": "vo_adv_4003005_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為處在很容易崩塌的斷崖中，無法輕易靠近，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此難以調查，不知其詳細狀況。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼這次的祕境巡禮會來到這種地方……",
        "unit_id": 105913,
        "voice": "vo_adv_4003005_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n更正，吃遍之旅的目的地選到這裡也真是謎上加謎啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遺跡中可能還埋藏著未知的食譜呢。",
        "unit_id": 105913,
        "voice": "vo_adv_4003005_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也許貪吃佩可小姐的目的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n照估計就是這個吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 105812,
        "voice": "vo_adv_4003005_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好孩子～好孩子～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我最喜歡說話非常認真的小可蘿了～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿，雖然不用那麼認真，隨便說說就好了啦？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_4003005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可大人的話有時候很難懂，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也不確定能不能夠回答得得體啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒關係呦，不用想得太複雜！",
        "unit_id": 105812,
        "voice": "vo_adv_4003005_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大致上到現場看狀況再說也沒問題啦☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……………",
        "unit_id": 106012,
        "voice": "vo_adv_4003005_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_4003005_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀呀？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n怎麼了小凱留，沒什麼精神？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是肚子餓了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請放心吧！　快去攻略遺跡，找出食譜，",
        "unit_id": 105812,
        "voice": "vo_adv_4003005_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n回家後買食材回來調理，完全重現上古的美味！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這一場美食企畫夠很不錯吧……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "稍微忍耐一下，馬上就有料理可以吃到飽啦！",
        "unit_id": 105812,
        "voice": "vo_adv_4003005_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一定能煮出一桌印象深刻的好菜，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "空腹就是最好的調味料了……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……自吹自擂的話也說夠了，快點出發了啦",
        "unit_id": 106012,
        "voice": "vo_adv_4003005_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎唷，居然這麼有衝勁啊！",
        "unit_id": 105812,
        "voice": "vo_adv_4003005_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟，小凱留也很喜歡吃飯嘛～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……這次沒問題，因為我做了充分準備。",
        "unit_id": 106012,
        "voice": "vo_adv_4003005_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為了活著從各種誇張的祕境中歸來，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n每天都踏實的訓練著。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我絕對要繼續活下去啊。",
        "unit_id": 106012,
        "voice": "vo_adv_4003005_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為我才不想死在這種傻事上面。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇，",
        "unit_id": 105812,
        "voice": "vo_adv_4003005_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留的眼神有殺氣呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不行喔～吃飯就是要笑著開心的吃嘛！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n氣氛陰沉的話，辛苦煮的飯都沒滋味啦？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "囉嗦！",
        "unit_id": 106012,
        "voice": "vo_adv_4003005_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我就是不想死啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "討厭啦啦啦，",
        "unit_id": 106012,
        "voice": "vo_adv_4003005_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吃遍之旅不是該更歡樂更和平一點嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼每次都是要冒著生命危險呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈～吃飯就是為了生存嘛！",
        "unit_id": 105812,
        "voice": "vo_adv_4003005_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論何時都是要拚命的……☆",
        "unit_id": 105812
    }
]