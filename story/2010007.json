[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "同一時間。於『索爾之塔』的上層……\n【破曉之星】的成員們，正歡樂地進行著冒險。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們是【破曉之星】！",
        "unit_id": 100111,
        "voice": "vo_adv_2010007_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n是為了找尋那被稱為",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "索爾魔珠的謎之秘寶，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n日日夜夜，熱心投入於冒險的公會唷！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這幾天，",
        "unit_id": 100111,
        "voice": "vo_adv_2010007_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "照著這張從鎮上取得的可疑地圖，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n在這被叫做『索爾之塔』，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "公認是世界上最不可思議的地方冒險中……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但在發現唯一線索的地圖是隨便亂寫的之後，",
        "unit_id": 100111,
        "voice": "vo_adv_2010007_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們已經深陷在",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "幾乎沒辦法回頭的地方了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "該怎麼辦呢？【破曉之星】！",
        "unit_id": 100111,
        "voice": "vo_adv_2010007_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n加油呀！【破曉之星】！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們的冒險，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "正要開始而已呢……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和。",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有精神雖然是好事，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但請降低一點音量。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "再怎麼說我們也還在地下城之中，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n何時會讓魔物查覺到聲響而被襲擊也無從知曉。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇啊，",
        "unit_id": 100111,
        "voice": "vo_adv_2010007_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜對不起！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不用道歉啦，",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是之後記得要小心一點。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過事到如今，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n為何還要像『前情提要』一樣來報告這些事呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不是呀，",
        "unit_id": 100111,
        "voice": "vo_adv_2010007_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就覺得一片混亂了嘛！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才一回過神，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就已經站在這～麼不可思議的地方了耶！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "到底是怎麼回事，",
        "unit_id": 100111,
        "voice": "vo_adv_2010007_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這佈置的很華麗又像是庭院的地方是哪啊？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "直到剛剛，",
        "unit_id": 100111,
        "voice": "vo_adv_2010007_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們明明都還在個陰陰森森的迷宮裡頭呀……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這裡雖然很漂亮，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但完全沒有動物的氣息好可怕哇～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就像是死後的世界。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊……",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以是為了要找回冷靜，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n才會試著整理了一下我們的現況嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵。",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和平時總是做些出奇不意的事，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但卻意外的有道理，挺有趣的呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哦哦～",
        "unit_id": 100111,
        "voice": "vo_adv_2010007_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳這應該是在讚美我的對吧……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這當然是在讚美唷。",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就連我也有點不知所措了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不過看到妳這樣，就覺得冷靜了不少。",
        "unit_id": 100311
    },
    {
        "type": "still",
        "still": "201000701"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "大家～",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我準備了一點下午茶唷♪",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不不不妳等一下優衣，",
        "unit_id": 100111,
        "voice": "vo_adv_2010007_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在這種情況下喝茶嗎！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……妳似乎也有點混亂呢，",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不。",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "其實就連我自己也很訝異，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "竟然可以這麼冷靜呢……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可能是因為和大家冒險了這麼久，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n令人難以置信的事情",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "看過太多的關係也說不定。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以這陣子，",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不管遇上什麼事情",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都已經不太會覺得驚訝了呢……♪",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣啊～",
        "unit_id": 100111,
        "voice": "vo_adv_2010007_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "變得可靠了呢，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "人家，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好感動呀……☆",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然可能只是感到麻痺了呢。",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這茶我就拿來喝囉，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝妳優衣。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯。",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個茶有著能夠讓人放鬆的效果，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n就邊喝邊冷靜來想想該怎麼辦吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們到底是遇上了什麼狀況呢？",
        "unit_id": 100211
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唔～嗯。",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才日和也把我們到現在的來龍去脈回顧了一下，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就順著推敲看看吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們所依據的這個線索，",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "標示著索爾魔珠所在處的地圖",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "其實是假的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而這是不知道誰惡作劇做出來的地圖，",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n若順著上頭記載的指示前進，就會落入陷阱……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就像是這種感覺吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯嗯……",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n有很多呢，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那種踩到就會被傳送到別的地方的陷阱。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "特別像是在索爾之塔的高樓層，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "或是老舊的遺跡裡。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯。",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但是轉移魔法，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該是受到法律禁止的高級魔法才對。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不對。",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然還是得看距離或移動的人數，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n但其實魔法本身並沒有想像中的那麼困難喔。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "只要加把勁修行一下，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說不定就連我也可以學得會呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然因為法律嚴格的限制，現在誰都不能用。",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不過在很久以前，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可能大家隨便就能使出轉移魔法吧……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "畢竟非常便利，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "想不通不用的理由呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯嗯。",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以索爾之塔和古老的遺跡中，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n才會像這樣有一大堆傳送用的魔法陣呀。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯。",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就算不是陷阱，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n單純移動用的魔法陣到處都有設置呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而我們就只是，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不小心踩到那些魔法陣了也說不定？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且啊，",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n雖然妳們好像都覺得這地圖是亂寫的，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想有沒有可能不是這樣呢……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "畢竟這座誰也沒有成功攻略過的",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "索爾之塔內部通道之類的，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n都被完整地記載在這張地圖上唷？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯。",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "地圖是正確的，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是我們搞錯的意思嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比起說是誰為了惡作劇或挖洞給人跳而做出假地圖，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這種以警告他人的惡意為前提的思考方式，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "確實較為妥當呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯嗯，",
        "unit_id": 100111,
        "voice": "vo_adv_2010007_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "讓我們相信人性的善良吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣子想，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才比較像我們的風格呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是呀。",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過就是改變了想法，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在這事態也不會好轉呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "究竟該如何是好呢。",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "乍看之下這個空間相對的和平多了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要不然三人分頭找找看出口如何？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n一旦找到類似的東西，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "便出聲叫另外的兩個人。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "姑且有對周遭保持著警戒，",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "卻完全沒有魔物的氣息……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "大概，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "大膽一點的行動也沒有問題。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哦哦～",
        "unit_id": 100111,
        "voice": "vo_adv_2010007_038"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就這麼辦吧！　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就這麼決定囉！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯。",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "索爾之塔的攻略曠日廢時，已經花上不少時間，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n糧食也所剩無幾了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "趕緊離開這裡，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "重整旗鼓以後再做打算似乎比較好呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對啊。",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_040"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生似乎常常和【美食殿堂】的夥伴一起，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n把魔物做成料理來吃的樣子……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然真的快餓死了的話，",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_041"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不這麼做不行。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但在索爾之塔中出沒的魔物，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "長得可愛的特別多嘛，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果吃掉牠們",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "感覺也有點可憐……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯。",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然只是湊巧提到，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但{player}這些日子很難約呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是有事情要忙吧……",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過他那強化同伴的能力，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n對索爾之塔的攻略，可是非常有效的呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果有跟我們一起來的話，",
        "unit_id": 100311,
        "voice": "vo_adv_2010007_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就幫大忙了呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯……",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_045"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n雖然有點可惜但這也沒辦法唷，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生他有",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "自己該過的生活嘛。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然如果可以的話，",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_046"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "能夠一直和我們在一起就好了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但是這樣的願望，",
        "unit_id": 100211,
        "voice": "vo_adv_2010007_047"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說起來簡單，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "實際上卻很困難呢。",
        "unit_id": 100211
    }
]