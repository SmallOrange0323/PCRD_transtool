[
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "讓你久等了，主人～♪",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不對，",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿，是{player}……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我準備了料理，請享用吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這是你幫我搬行李的謝禮～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀……？　",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇哇，嗚哇！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對、對不起。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我差點就跌倒了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為我今天走太多路，所以腳步都不穩了呢～",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你扶住我真是幫了大忙。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "料理也平安無事，沒有掉在地上……",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個，{player}？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n對不起，你可以放開我了嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我不要緊的！",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我沒有受傷，也沒事！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是的……剛剛是因為意外，所以沒辦法，",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但隨便抱住女生是不行的喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我開玩笑～的，明明被你幫了一把還這麼自以為是。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n總之，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請享用料理吧♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "小胡桃……",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n啊，她是我在【咲戀育幼院】照顧的孩子，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "她連我的晚餐都做好了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我只是把飯菜重新加熱，",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n馬上就能準備好，真是幫了大忙。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "小胡桃比我擅長做菜，因此保證好吃喔♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為我和大小姐都不在，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我原本很擔心【咲戀育幼院】的孩子們……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但她們似乎有好好地待在育幼院裡看家。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也有確實打掃、洗衣服。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然我有告訴她們，",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n家事留給我來做就好呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n飯菜我也事先煮好了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但她們似乎覺得總是被照顧很不好意思，",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以做了自己能力範圍內的事情呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的是一群懂事的好孩子。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "懂事到簡直不需要我照顧…",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "…",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}，怎麼了？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀，菜已經吃光了呢。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n男生果然食量很大呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請稍等一下，我再去煮點東西喔～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那個……我不是很擅長做菜。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣也沒關係嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你那麼想吃我做的菜嗎？",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n感覺很開心，或者該說是很榮幸……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那麼，我去準備小菜喔。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請你在等的時候，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就讀一下這裡的繪本，玩一下玩具。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我從故鄉搬運過來的就是這些繪本和玩具。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還有舊衣服之類的。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然算不上生活必需品，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "卻是「有了就會很開心的東西」呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為大小姐會確實準備生活的必需品，",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以我想如果能給孩子們其他的東西就好了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我這麼想著，就回故鄉一趟了。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但如果因此讓孩子們感到寂寞，可就本末倒置了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我真是沒用，總是欠缺周詳思慮。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n孩子們似乎一直等著我回來……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "他們一看見我，就跑過來抱住我，",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "看到玩具和繪本也很開心喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然我很冒失，也派不上用場，老是給別人添麻煩，",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但即使不是絕對需要，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我是否也能成為「有你在就會很開心」般的存在呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n對不起，我去做菜囉。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}應該也累了，請好好休息吧。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然倫理上來說，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "讓你留宿在這裡實在是有困難。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯？",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你想玩那個玩具嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過那是給幼童玩的玩具……",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n也有像小孩的時候呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我知道了，吃完飯後我們一起玩吧。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就讓在下鈴莓來陪{player}一起玩，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n直到你滿意為止～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不。",
        "unit_id": 102511,
        "voice": "vo_adv_1025007_032"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我會多多服侍你的喔，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "主人……♪",
        "unit_id": 102511
    }
]