[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "盛裝打扮的【美食殿堂】成員，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在蘭德索爾的街上偶然遇見了流夏和伊莉亞。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n幾人站在一起讓四周的氣氛變得華麗起來。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來流夏小姐與伊莉亞小姐",
        "unit_id": 111811,
        "voice": "vo_adv_5082001_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "交情很好呢。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身還是頭一次",
        "unit_id": 120912,
        "voice": "vo_adv_5082001_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "與她如此對話！",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身是從依里那",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "聽說有個很了解新年的人。",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我則是從七七香那聽說",
        "unit_id": 120811,
        "voice": "vo_adv_5082001_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有想要了解新年的人，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n所以才來的。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的確，",
        "unit_id": 112011,
        "voice": "vo_adv_5082001_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "流夏看起來對這種習俗很了解呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "穿新年和服盛裝慶祝",
        "unit_id": 120811,
        "voice": "vo_adv_5082001_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是東國的習俗。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "東國出身的我",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "當然會曉得。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們也穿新年和服……",
        "unit_id": 120912,
        "voice": "vo_adv_5082001_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "該不會……",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們和妾身同樣",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也想稱霸新年？",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哼哼哼，",
        "unit_id": 111811,
        "voice": "vo_adv_5082001_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實就是那樣！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什麼！",
        "unit_id": 120912,
        "voice": "vo_adv_5082001_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們竟敢",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "攔阻在妾身面前？",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "既然如此",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就算對手是【美食殿堂】",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也不會放水的！",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不，",
        "unit_id": 112011,
        "voice": "vo_adv_5082001_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是的。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們正要",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "去蒐集年菜的材料。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這就是「【美食殿堂】",
        "unit_id": 111811,
        "voice": "vo_adv_5082001_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "回憶的年菜作戰」！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什麼嘛，",
        "unit_id": 120912,
        "voice": "vo_adv_5082001_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不是那樣就好……",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "話說，",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "年菜是什麼啊？",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽說是有新年氣氛的",
        "unit_id": 111911,
        "voice": "vo_adv_5082001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "祝賀料理。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯。",
        "unit_id": 120811,
        "voice": "vo_adv_5082001_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就是那樣。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那原本是",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "為了祈願長壽和繁榮而做的料理集合。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "貪吃佩可小姐說過",
        "unit_id": 120711,
        "voice": "vo_adv_5082001_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那是吉祥物",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對吧？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我記得",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "年菜原本也是東國的文化。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吉祥物",
        "unit_id": 120912,
        "voice": "vo_adv_5082001_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗎……",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦？",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就是指",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有特別力量的料理，",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是這個意思嗎？",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的。",
        "unit_id": 111811,
        "voice": "vo_adv_5082001_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就是在新年大家一起吃的特別料理！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也就是說",
        "unit_id": 120912,
        "voice": "vo_adv_5082001_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吃了那個之後說不定就能取回失去的力量……",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有趣！",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們的旅行，",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也要參加！",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好耶！",
        "unit_id": 111811,
        "voice": "vo_adv_5082001_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這就是「出外靠旅伴，處世靠人情」！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈，",
        "unit_id": 120811,
        "voice": "vo_adv_5082001_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳知道不錯的俗語嘛。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳們打算去哪一帶旅行？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人打算",
        "unit_id": 111911,
        "voice": "vo_adv_5082001_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "去目前為止到過的地方。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為追求每塊土地不同的美味",
        "unit_id": 112011,
        "voice": "vo_adv_5082001_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "上山下海、踏遍原野……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們去過相當多地方了呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魚果然還是大間那邊的好！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "大間",
        "unit_id": 120811,
        "voice": "vo_adv_5082001_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是那個以海產聞名的",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "大間嗎？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "妳知道嗎？",
        "unit_id": 111911,
        "voice": "vo_adv_5082001_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "當然。",
        "unit_id": 120811,
        "voice": "vo_adv_5082001_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n大間就像是",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "海釣的聖地一樣。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們之前",
        "unit_id": 111811,
        "voice": "vo_adv_5082001_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "曾經在大間釣過金槍鮪喲！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦……",
        "unit_id": 120811,
        "voice": "vo_adv_5082001_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還真讓人羨繤。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也想釣一次看看。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "既然如此",
        "unit_id": 120912,
        "voice": "vo_adv_5082001_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "流夏也一起來如何？",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也一起去嗎？",
        "unit_id": 120811,
        "voice": "vo_adv_5082001_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有個不只是年菜，",
        "unit_id": 112011,
        "voice": "vo_adv_5082001_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "連東國文化都一清二楚的顧問在，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我會很開心的。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟也不太放心全部交給貪吃佩可。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……她一副動不動就會提議用魔物料理當年菜的樣子。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "確實，",
        "unit_id": 120711,
        "voice": "vo_adv_5082001_029"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "流夏小姐能來的話",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很令人安心呢。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "魔物年菜明明也很好吃的說……",
        "unit_id": 111811,
        "voice": "vo_adv_5082001_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要有發源地的知識",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就可以吃到好吃的年菜了♪",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們才務必要",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請妳多多指教！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "之前曾經接受過【美食殿堂】的幫忙嘛。",
        "unit_id": 120811,
        "voice": "vo_adv_5082001_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n就讓我助妳們一臂之力吧。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼主人，",
        "unit_id": 111911,
        "voice": "vo_adv_5082001_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您下達出發的號令吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 120912,
        "voice": "vo_adv_5082001_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒錯。",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這次說到底可是",
        "unit_id": 120912
