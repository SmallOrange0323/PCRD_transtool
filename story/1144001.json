        "type": "dialogue",
        "name": "秋乃",
        "words": "放了大量的香料，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n是偏向大人的口味，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總之能享受到各種不同的風味喔！",
