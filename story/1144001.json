        "voice": "vo_adv_1144001_047"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那是煮過的火雞蛋！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還有啊，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在這部分放有",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n孩子們會喜歡的",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "肉丸，",
