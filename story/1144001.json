    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "連我自己都沒體驗過的完美派對料理！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……請容我將這道料理撤掉。",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "把下一道料理端上來！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "女僕1",
        "words": "明白了。",
        "unit_id": 1,
        "voice": "vo_adv_1144001_027"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "──讓你久等啦！",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_028"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請嘗嘗看這道料理。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這些是",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_029"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "連我也不曾吃過的料理。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n有堪稱珍餚的魚或蛋，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還有其他各式各樣的料理喔。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "來吧，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請享用！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那、",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那個……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你一臉困惑的樣子，",
