    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是什麼樣的料理……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦……",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_033"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我、",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我來做嗎！？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那、",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_034"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那個……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "別看我這樣，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我雖然能完成大部分的事，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但就只有料理……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呃……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "從來沒有學過……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嗚、",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_035"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嗚嗚……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我、",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我知道了！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我會做出最完美的料理！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "…………！？",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_036"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你的這句話，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "讓我下定決心了！",
