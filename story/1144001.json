    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "──為我準備好廚房！",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_037"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我秋乃‧紫藤，",
