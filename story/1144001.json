        "voice": "vo_adv_1144001_039"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只要把這隻火雞拿去烤就行了吧？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n包在我身上！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就用這纏繞著烈焰的劍技！",
