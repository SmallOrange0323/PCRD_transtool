        "voice": "vo_adv_1144001_046"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "它可不是普通的烤火雞喔！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我在製作過程中下了不少工夫呢！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請你先",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "用刀子切開看看吧。",
