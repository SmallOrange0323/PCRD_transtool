        "voice": "vo_adv_1144001_043"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "先從烤箱裡拿出來，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n在焦黃的表面塗上蜂蜜或奶油，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "以提升色澤和風味……",
