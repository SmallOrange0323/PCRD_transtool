    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "最重要的是，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "能讓無論是我",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還是參加者都能",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "展露出笑容的料理。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可是，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "究竟該",
