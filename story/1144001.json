[
    {
        "type": "background",
        "background": "500025"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──聖誕節前夕，熱鬧的蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n出現了秋乃有些焦躁的身影。"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好奇怪……",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這真是太奇怪了。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "派對結束後，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我明明只需要搭上前來迎接我的馬車……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "──然而！",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我為什麼還在這裡啊～～！！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "馬車停靠的地方",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "照理說用走的就能到……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嗚嗚……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我路痴的毛病",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還真是讓人困擾。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n再這樣下去……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那位是……！？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在我最困擾的時候帥氣出場……",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n{player}大人果然",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n是我命中注定的",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "守護騎士呢！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦……",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你問我在困擾什麼？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這個嘛，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "說、",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "說來慚愧，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我又……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "…………是的。",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "唉，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "早知道會變成這樣，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我就不去參加派對了。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這個時期派對非常多，",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n而且內容都大同小異，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "說實話很無聊。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……主辦人的自吹自擂、",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "料理的種類、",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "約定俗成的",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "舞會。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我已經厭倦了。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果我是派對主辦人，",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就會在料理上多下功夫，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n派對活動就選擇那種能讓大家盡情享受的……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我來舉辦派對……",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就、",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就是這個！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n還可以順便宣傳【墨丘利財團】，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n就讓我來舉辦一個盛大的派對吧！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我會舉辦無論誰都能自由參加，",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n然後，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "連我自己都沒有體驗過的那種……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "能讓大家",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n打從心底感到快樂的",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "完美派對！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真的嗎！？",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "謝謝你！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n真不愧是未來要",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "與我互相扶持的騎士呢♪",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所、",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_012"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以啊，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我現在就有事想拜託你……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……說來慚愧，",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_013"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n能不能麻煩你",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "把我送回宅邸呢？",
        "unit_id": 114411
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──隔天，受秋乃之託，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}來到了已被包場的\n紫藤家經營的料理店。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而秋乃早已在那裡等候多時了。"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你終於來了！",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們趕緊",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "來討論",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "要如何舉辦完美派對吧！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這次派對",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我特別著重的部分，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n是真心實意的",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「款待」所有參加者，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n然後，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "讓大家度過一段「歡樂時光」。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以，",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_016"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "首先是",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「款待」的方式，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我想了幾種派對料理！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "事不宜遲，",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_017"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就麻煩你來試吃看看囉！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "把料理端上來。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "女僕1",
        "words": "是的，",
        "unit_id": 1,
        "voice": "vo_adv_1144001_018"
    },
    {
        "type": "dialogue",
        "name": "女僕1",
        "words": "大小姐。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "來，",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_019"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請看！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這些……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這些正是，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我所想出的",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「款待」方式！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n既是誰都能開心品嘗的料理，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也是最棒的聖誕晚餐哦！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這道料理，",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "食材選用數年才會出現一隻，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n傳說中的火雞所製成的烤火雞喔！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "來，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不用客氣，盡量吃吧……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊，",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那個，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你的手停下來了，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n是有什麼問題嗎？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不知道",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "該怎麼吃？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這、",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這確實",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不算一道常見的料理呢。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這隻烤火雞",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_022"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "能食用的部位是固定的……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不能像那樣把刀子深插進去！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "應該要從旁邊",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_023"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "將肉片切下，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n淋上醬汁，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "最後沾取這個盤子裡面的",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n火雞蛋的蛋黃……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好了，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這樣就行了。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "確實是有些困難呢。",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我第一次",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "接觸這道料理時，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n也像剛剛的{player}大人一樣不知該從何吃起……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊！？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我曾經吃過……",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_025"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就和一般的派對料理\n沒什麼差別……",
