    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "有什麼問題嗎？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不像派對料理……",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "說的沒錯呢。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這樣的話，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就只是珍稀料理的大集合而已。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我的目標是端出",
        "unit_id": 114411,
        "voice": "vo_adv_1144001_032"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "連我自己都沒有體驗過的……",
