        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雙方都因此而快樂，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "簡直就是",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "一石二鳥呢！",
