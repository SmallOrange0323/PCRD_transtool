[
    {
        "type": "background",
        "background": "500242"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "終於露出傳說吸血鬼真面目的伊莉亞。對峙的三人。\n究竟，能否打破決戰的態勢呢……？"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "…………",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "…………",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "…………",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還是算了……",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要人家和伊莉亞戰鬥……",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家做不到……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家……選擇投降……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯……我也是……",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n要除掉朋友，我根本做不到啊……！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "傳說的吸血鬼什麼的，根本只是傳言……",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可是……現在在我們眼前的，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n又不是可怕的吸血鬼……只是人家的朋友啊！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對啊～！這次旅程受了伊莉亞很多幫助……",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n今天一整天一起克服許多困難的朋友，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不可能當成敵人的啦～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是嗎……這還真巧。",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也是，怎麼樣也無法把妳們兩人當成敵人……",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身也該放下這把武器了吧……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就像王子先生說的。咱們都是朋友啊，那樣就好了吧？",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "說什麼呢！咱們從一開始就沒有打起來吧！",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_011"
    },
    {
        "type": "still",
        "still": "500300601"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對啊！我們以後也要維持好感情！",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n根本就沒有什麼邪惡吸血鬼啦──！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哇哇哇！伊莉亞──！",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n永遠，從今以後，也要當我們的朋友呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身的目的是征服世界……這一點是不會變的……",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是……那件事……要什麼時候達成妾身可沒說。",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "說不定，一百年、兩百年後也有可能……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵呵……妾身覺得……",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n想和妳們兩人……再多相處一段時間。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "對啊對啊！",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n沒問題的！從今以後，就更加更加了解彼此吧！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n也要招待妳來真步真步王國！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦哦！那還真令人期待呢！",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "唔唔……沒有演變成戰鬥，真是太好了──！",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要感謝這場邂逅呢。",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵呵……",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n雖然有點肉麻，不過友情這東西還真不錯呢……",
        "unit_id": 104411
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500242"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要是一開始妳們兩人沒有在那街上幫助妾身的話，",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n咱們現在就是在互相打鬥了是嗎……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒演變成那樣真是太好了──！",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "話說回來，要是沒認識伊莉亞，我覺得",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n現在應該還在找『像苦瓜的東西』！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呼……說起來，那時候真步還真厲害……！",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n蟲子跑進衣服裡面就整個人慌了起來！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那、",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個真的很恐怖啦！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那種蟲子在身上打轉的感觸……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗚嗚，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "背脊發寒……！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈哈……哈哈哈哈哈！",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n現在回想起來還是想笑呢！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "伊莉亞還不是被蟲子弄得心浮氣躁──！",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那是因為，只不過是隻蟲子，竟敢妄想吸妾身的血！",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "偏偏跑來吸我這傳說吸血鬼的血……！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都已經那樣了，香織卻還是一副事不關己的樣子……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "後來就找到像苦瓜的東西了，",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n接著為了尋找『烏龍麵擀麵棍』而來到這裡。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊啊，即使如此……為什麼大蒜變成了『像苦瓜的東西』，",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n白木樁變成了『烏龍麵擀麵棍』？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "為了對付傳說的吸血鬼，",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_031"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我們兩個決定要用更厲害的東西來對抗嘛～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "話說在前頭，對妾身而言，『像苦瓜的東西』",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_032"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n和『烏龍麵擀麵棍』可是沒有用的哦！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只不過，",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那種品味啊……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們可是很認真的呢～",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_034"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對啊──。認真的啊！",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_035"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要是妳們兩人拿著那種東西出現在妾身面前……",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_036"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵呵……哈──哈哈哈哈！",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_037"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n糟了！笑得停不下來了啦！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可，可是，如果伊莉亞一直用小孩子的姿態，",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n咱們是絕對不會知道的！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔……",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_039"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身可不是因為喜歡小孩子的模樣才變成這樣的哦！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n要變成大人的話，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就得抱著{player}才行呢！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這世界可沒那麼簡單呢……真是的。",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_040"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然這麼說，還是很棒的旅行啊……",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_041"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真的是很棒的旅行～！",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯嗯。真的真的！",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_043"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好吧，現在總之大家一起回去……",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_044"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔",
        "unit_id": 10311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 10311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什麼！？你是……",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_045"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n難道，自力從洞穴裡爬到這裡來了嗎！？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔！",
        "unit_id": 10311
    },
    {
        "type": "background",
        "background": "500242"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗚！反應太慢了！！",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_046"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喝呀呀呀呀呀！！",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_047"
    },
    {
        "type": "background",
        "background": "500242"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔！",
        "unit_id": 10311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "香織！？",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_048"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不好意思，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "謝謝妳！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "幫助朋友是理所當然的啊─！",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_049"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對吧，真步！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就是說呀，",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_050"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎麼可能眼睜睜地看著",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "重要的朋友受傷呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n魔物呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "你有點鬧得太過份了哦。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵，原來如此……咱們不是主從關係，而是朋友啊……",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_051"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那我們走吧，",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_052"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "盟友們啊！　",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "盡量拿出我們的全力吧！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "把膽敢擋在我們面前的蠢貨們，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "全部消滅！",
        "unit_id": 101011
    },
