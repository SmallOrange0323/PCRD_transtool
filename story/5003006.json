    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "成功啦─！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "打倒魔物啦─！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯……多虧有妳們兩人的協力。",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_054"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "光靠咱們，竟然能打倒那麼厲害的魔物……",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_055"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只有一個人、兩個人都不行！",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_056"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是因為有三個人才辦得到！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯？你在說誰啊？其他還有誰嗎？",
        "unit_id": 104411,
        "voice": "vo_adv_5003006_057"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哈，徹底忘記王子先生了！",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_058"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "抱歉抱歉！",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_059"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為{player}也在才能獲勝的！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好吧，這次就坦率地向你道謝吧。",
        "unit_id": 104412,
        "voice": "vo_adv_5003006_060"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦，奇怪？妳的樣子……",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_061"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯？哦哦！？變回小孩子模樣了！",
        "unit_id": 104412,
        "voice": "vo_adv_5003006_062"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "魔力用盡了嗎！？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "今天已經很晚了，小孩子一個人走夜路是很危險的！",
        "unit_id": 101711,
        "voice": "vo_adv_5003006_063"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "先來我們的公會小屋吧──！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一定要來作客，我們會招待妳的！",
        "unit_id": 101011,
        "voice": "vo_adv_5003006_064"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣啊。那麼機會難得，就麻煩妳們了。",
        "unit_id": 104412,
        "voice": "vo_adv_5003006_065"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "請客那件事也約好了哦！",
        "unit_id": 104412
    },
