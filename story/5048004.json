    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n【惡魔偽王國軍】的天使",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "都是怪物嗎！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "嗯，",
        "unit_id": 411,
        "voice": "vo_adv_5048004_056"
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "這遊戲規則簡單，初學者也很有勝算，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "\n但明明眼看就快要贏了，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "\n最後卻還是被妳擊倒。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "遊戲實力果然名不虛傳呢！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "嘻嘻，",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_057"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "妳們也把我捧太高了吧。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "太好了……",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_058"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "還好這個遊戲",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我陪姊姊玩過好幾次，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n也是我唯一贏得過姊姊的遊戲。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "欸，",
        "unit_id": 1111,
        "voice": "vo_adv_5048004_059"
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "我們再比一場吧！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "\n我覺得",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "我好像玩這遊戲玩上癮了啊！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "好的，",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_060"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "要比幾次都歡迎。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n只不過，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我是絕對不會輸的喔♪",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "那個……",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_061"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "今天因為不少生面孔，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "害我有點緊張。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n沒能好好表達真是對不起。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "然後，",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_062"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "要是可以的話，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "下次也請邀我參加喔。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我下次一定會表現得比這次更好的！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "喔喔，",
        "unit_id": 1111,
        "voice": "vo_adv_5048004_063"
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "沒問題！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "我們竭誠歡迎！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "呼，",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_064"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "總算是撐過去了……",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n這大概是我這輩子碰過的最大危機吧。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "謝謝你，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "哥哥。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "要是那時哥哥沒來當忙解圍，",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_065"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n我現在應該已經搞砸了吧。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "果然",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "還是哥哥最可靠了！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "嗯。",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_066"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "幸好她們倆當時替我解圍。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "其實鈴跟七七香",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "應該早就察覺出什麼，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "但還是配合著我，什麼都沒過問。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "姊姊還真是",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_067"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "交到了一群好朋友呢。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "這就像是",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "自己的事一樣令人開心。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "但是，除了哥哥你們幫我大忙之外，",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_068"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "更重要的是我重新回想過了有關姊姊的事。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "要不然，",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_069"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "線下聚現在應該已經被我搞砸了，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n就算維持住場面，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "給人的印象也肯定不會太好呢。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "嗯～",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_070"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "看來姊姊她",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "遠超出我的認識，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n是個更更更～",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "棒的好姊姊呢。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "啊～",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_071"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "想著想著突然好想看看姊姊。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我們快回去吧，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "哥哥！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "腦海裡浮現心愛的姊姊依里的模樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n茜里輕快地邁開了腳步。"
    }
]