        "voice": "vo_adv_5048004_000"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "你真的好專業喔。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "真是讓人",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "太佩服了！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "哪有，",
        "unit_id": 1111,
        "voice": "vo_adv_5048004_001"
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "我只是小兒科而已。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "我反而聽人說",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "依里妳才是遊戲方面的行家。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "\n像妳這次帶的那遊戲",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "就是內行人才知道的。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "哪裡，",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_002"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我還差得遠了。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "所以今天",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我要仔細聽大家聊天，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "好好向大家學習♪",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "欸，",
        "unit_id": 411,
        "voice": "vo_adv_5048004_003"
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "依里妳看！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "這布偶",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "是我之前抽獎抽中的！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "哇！",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_004"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "好可愛喔！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "這個角色",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "叫什麼呀？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "咦？",
        "unit_id": 411,
        "voice": "vo_adv_5048004_005"
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "這是",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "「Grateful Eight」的那個倉鼠人……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "\n應該還算蠻有名的角色吧？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "對對對，",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_006"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "就是那個！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "剛剛不小心搞錯了。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "真是太糊塗了♪",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔～",
        "unit_id": 101311,
        "voice": "vo_adv_5048004_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "依里閣下！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好厲害的角色切換。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "小惡魔指數高到破表了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "依里這孩子，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不容小覷！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……呃，",
        "unit_id": 102611,
        "voice": "vo_adv_5048004_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "與其說是角色切換，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "感覺更像是變了一個人似的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔唷？",
        "unit_id": 101311,
        "voice": "vo_adv_5048004_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "鈴閣下，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳是什麼時候到的？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "其實前不久就到了，",
        "unit_id": 102611,
        "voice": "vo_adv_5048004_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只是看到她跟之前判若兩人，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "一不小心就",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "出神到現在了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我記得之前聽別人說，",
        "unit_id": 102611,
        "voice": "vo_adv_5048004_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n個性陽光的",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "應該是妹妹才對呀～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "依里依里妳今天",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "該不會是別人扮演的吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "討、",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_012"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "討厭啦，鈴妳真會開玩笑～",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "這只是比較誇張的角色切換啦～♪",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我想也是啦。",
        "unit_id": 102611,
        "voice": "vo_adv_5048004_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只是開個玩笑，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不要放在心上。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "呼……",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_014"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "嚇死我了。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "想不到鈴她看起來好像很溫吞，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n直覺卻出奇的敏銳啊。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "不過總之，",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_015"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "既然氣氛也差不多炒熱了，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "接下來就算行為誇張一點，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "也該設法給大家留下好印象。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "畢竟姊姊她是這麼的可愛，",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_016"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n當然要變得更人見人愛才行♪　",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "欸，",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_017"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "各位！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我現在想玩個遊戲，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n各位要一起來玩嗎？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "喔？",
        "unit_id": 1111,
        "voice": "vo_adv_5048004_018"
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "好啊。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "依里想玩的遊戲",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "我也很感興趣！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我想玩的是──",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_019"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "真心話大冒險！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "鈴、七七香",
        "words": "真、",
        "unit_id": 1,
        "voice": "vo_adv_5048004_020"
    },
    {
        "type": "dialogue",
        "name": "鈴、七七香",
        "words": "真心話大冒險──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "真心話大冒險就是那個……",
        "unit_id": 411,
        "voice": "vo_adv_5048004_021"
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "現充與",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "玩咖們",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "專屬的派對遊戲……！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "我、",
        "unit_id": 1111,
        "voice": "vo_adv_5048004_022"
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "我們的確是遊戲愛好者，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "\n可是這類遊戲實在有點超出範圍了……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "奇、",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_023"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "奇怪了？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "還以為",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "大家會",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n反應熱絡地大喊著「耶～！」呢……",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "而且話說",
        "unit_id": 411,
        "voice": "vo_adv_5048004_024"
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "我比較想跟依里妳聊更多有關遊戲的話題。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "\n其實我對",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "「天魔學園默示錄」有點興趣，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性參賽者",
        "words": "想請教依里妳的感想。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "喔喔，",
        "unit_id": 1111,
        "voice": "vo_adv_5048004_025"
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "畢竟依里可是七七香認證過的硬派玩家嘛。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性參賽者",
        "words": "也教我怎麼打「黑暗求生者」的隱藏Boss好嗎？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "怎、",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_026"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "怎麼辦……",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "完全聽不懂他們在說什麼……",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "呃，",
        "unit_id": 113812,
        "voice": "vo_adv_5048004_027"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "就是……",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "對啊，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "嗯，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "那款真的很精采！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n怎麼說呢，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "真是動人心弦！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "然後",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "Boss的話……",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
