    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "都很便宜喲",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "很便宜喲──！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "打擾一下，",
        "unit_id": 105913,
        "voice": "vo_adv_2105001_069"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魚店老闆。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "歡迎光臨！",
        "unit_id": 1411,
        "voice": "vo_adv_2105001_070"
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "\n精靈族的小姑娘，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "妳想要什麼呢？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼……",
        "unit_id": 105913,
        "voice": "vo_adv_2105001_071"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下想要那邊的鮭魚、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沙丁魚、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和鰤魚的魚骨。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還有，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果有喵喵可能會喜歡的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "柴魚片的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也想買一些。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "當然好啊！",
        "unit_id": 1411,
        "voice": "vo_adv_2105001_072"
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "\n我們今後會持續進貨銷售，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "\n請多支持一下",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "我們的店喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，",
        "unit_id": 105913,
        "voice": "vo_adv_2105001_073"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那當然。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼這邊的店，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "價格會這麼便宜呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n隔壁的蔬果店也是一樣……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "喔喔！",
        "unit_id": 1411,
        "voice": "vo_adv_2105001_074"
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "\n因為我們業主的批發商公會",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "很慷慨啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "多虧如此，我們才能夠",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "給顧客更多優惠！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "批發商……",
        "unit_id": 105913,
        "voice": "vo_adv_2105001_075"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔嗯。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下記得這附近最大的批發商，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該是【墨丘利財團】吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "【墨丘利財團】？",
        "unit_id": 1411,
        "voice": "vo_adv_2105001_076"
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "不對不對，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "\n我們店的業主，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店",
        "words": "是【銀汞貿易】啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【銀汞貿易】……？",
        "unit_id": 105913,
        "voice": "vo_adv_2105001_077"
    }
]