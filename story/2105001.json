        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有「另一個世界」存在，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳願意相信嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼？",
        "unit_id": 106012,
        "voice": "vo_adv_2105001_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳怎麼沒頭沒尾就說這種話……",
        "unit_id": 106012
    },
