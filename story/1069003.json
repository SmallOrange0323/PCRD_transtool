[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與【憤怒‧軍團】多次接觸後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有一天，{player}帶著凱留，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n前去拜訪霸瞳皇帝。"
    },
    {
        "type": "still",
        "still": "106900201"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……真是好久不見啊。",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_000"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我差點都要開始以為你不會再來煩我了呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……陛下。",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "之前的事很感謝您。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不嫌棄的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請吃我做的飯糰。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "之前的事？",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_002"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "什麼事？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是厚臉皮的誤會啊。",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_003"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我做的一切都是為了我自己。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n若你們因此而想報答我，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那大可不必，太噁心了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我明白了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_005"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳是有目的才來的吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n有話快說，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "別在那邊拖拖拉拉的。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個……",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "其實是因為，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在有一群難纏的傢伙",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一直在找我們麻煩。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我知道",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_007"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳為何而來。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但妳要說的不是這個吧……？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n用妳那愚鈍的腦袋想清楚了再說話。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "抱歉……",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我其實是想來見陛下一面，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n把話好好說清楚。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n畢竟當時我們根本完全無法靜下心說話。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "唉，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_009"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳果然很愚笨呢，凱留……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n明明不用開口就已經夠令我作嘔了，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳還是想要一派天真地繼續折磨我是吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "光是看到背叛者帶著幸福的氛圍出現在我眼前，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_010"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就讓我的內心，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n甚至全身都痛得像是",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "要被撕裂了一樣。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "連這麼簡單的事都不懂，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_011"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我再跟妳多說什麼都是無益。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你也一樣……",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_012"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我已經對你無話可說，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也不想聽你說任何話。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "快快給我制裁吧。",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_013"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不是透過律法，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n而是透過那攪亂我命運的，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你的雙手。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若你下不了手，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_014"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "凱留，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "由妳來也行。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n膽敢背叛我，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這點程度的決心應該是有的吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下……？",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "您這是什麼意思……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我怎麼可能殺死陛下！",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這就是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下您負責任的方式嗎……！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "嗯……",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_017"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "怎麼？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "難不成妳覺得",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我是刻意選了一個輕鬆的方式解脫？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃、",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_019"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "確實是啊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這是最簡潔",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "又輕鬆的解脫方式。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我只是選擇讓遊戲結束而已。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "之後",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_020"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就輪到你們拚命悲慘掙扎給我看了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我會在地獄裡",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "悠悠哉哉地欣賞這場好戲。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "好了……",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_021"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "隨便誰都好，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n讓我",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "一死了之吧……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不……",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不可以！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請您活下去，陛下！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們並不是為此",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才來見您的！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_023"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們怎麼會有如此荒誕的想法？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n……是想用二虎競食之計，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "讓我跟那些傢伙互相殘殺嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不是那樣！",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們只是不希望陛下",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在此殞命。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為陛下您……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……那是很久以前的事了，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_025"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我甚至已經無法清楚回想起來。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……不過你們說得對。",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_026"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我確實",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "曾經是其中的一員。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n但那又如何？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我可是害慘許許多多人的大罪人啊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這我明白。",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然不及陛下的程度，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但我也背負著許多罪。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也正因為有陛下等人所創造的這個世界存在，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我才有幸遇見這傢伙和其他夥伴。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過就是願望的產物順勢引發的後果，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_029"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n真虧你們能說得如此意義非凡啊……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "太厚顏無恥了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "您要怎麼想都無所謂。",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只想",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "以我自己的方式報答您，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n期望有朝一日，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我能成為一個有能力",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拯救陛下的人。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……妳現在變得傲慢極了。",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n而他則是一向都很傲慢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這不是傲慢……",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我還是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很需要陛下。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "直到現在，",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的心裡還是存在著那個，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n想要繼續崇拜陛下的我。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……這就是所謂的傲慢。",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_034"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳不知道嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "讓一心求死的罪人",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_035"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "繼續活下去，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n是最最難堪的懲罰。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這次你們又要",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_036"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "阻撓我的願望了是嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "讓你對我產生罪惡感，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_037"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "本身就是種屈辱。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請您活下去，",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果對陛下而言，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這是最沉重、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最痛苦的懲罰，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼您更該這麼做。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "即便是像我這樣罪大惡極的人……",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_039"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "多麼崇高的思想啊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "莫非你認為放我一條生路，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_040"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我就會甘願助你們一臂之力嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n若真是如此，你實在天真到令我哭笑不得啊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "要是現在不殺我，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_041"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "讓我苟活下去……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n而我將來又再次成為你們的心腹大患，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那要怎麼辦呢？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這可不會只有一次喔。",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_042"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我會一而再、",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "再而三的捲土重來……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "屆時，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你會選擇怎麼樣的未來？",
        "unit_id": 106911
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──{player}一時語塞。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n腦海中浮現出不久後的將來或許會成真的戰場光景。"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊哈哈哈哈哈！",
        "unit_id": 106912,
        "voice": "vo_adv_1069003_043"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "很好……！",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你我就是該如此廝殺！",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你似乎誤以為我會一直乖乖順服於你，",
        "unit_id": 106912,
        "voice": "vo_adv_1069003_044"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n要打破你那種妄想簡直易如反掌！",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這次",
        "unit_id": 106912,
        "voice": "vo_adv_1069003_045"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "終於可以真正做個了斷！",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你和我，",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "注定有一方要在此殞命……！",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "賭上彼此的願望",
        "unit_id": 106912,
        "voice": "vo_adv_1069003_046"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "與這個世界的未來，",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "全力一戰吧！",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這才是",
        "unit_id": 106912,
        "voice": "vo_adv_1069003_047"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我所期望的終局……！",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我乃至高無上之神，",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "有本事就來殺我吧！",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "公主騎士！",
        "unit_id": 106912
    },
    {
        "type": "still",
        "still": "106900201"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "快點，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_048"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "給我個答案。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你會……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_049"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這樣啊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你選擇",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那樣的未來。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……那麼，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_050"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我會繼續反抗下去，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n直到你願意殺了我。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_051"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也是！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果那就是陛下的願望！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_052"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "都不先徵得其他夥伴的同意，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就這樣擅作主張可以嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊！",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_053"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們之後會設法說服大家的！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很抱歉！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "具體的答覆，我們下次一定──",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "──一定要給出",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_054"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我所期望的答案。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n在那之前，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我這條命就暫且保留。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下……",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_055"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一定會的！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太好了！",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_056"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n陛下願意活下來！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我不認為我是那個意思……",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_057"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是個蠢孩子。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……雖然不想承認，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_058"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但我心底，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n確實還存在著一絲絲鬥志",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "和想要活下去的慾望……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "今後我會靜觀你們的",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_059"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "一舉一動。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "除了我之外，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們不許輸給任何人。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "聽清楚了嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下。",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_060"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請您",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "照看著我們。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們會贏的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就先告辭了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "等一下。",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_061"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_062"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "把你手上那東西",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_063"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "留下。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我要吃點東西養精蓄銳。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "！",
        "unit_id": 106012,
        "voice": "vo_adv_1069003_064"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……好的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我會再給您送來……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "送很多很多。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n今天真的很謝謝您，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……如果這點程度的未來就能滿足，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_065"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我倒不如死了痛快……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過有再戰的可能性，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_066"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "讓這條路線顯得像樣了點……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊嗯……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "鹹死了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這什麼東西……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "有夠難吃。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……如果要跟一向百折不撓的少年再戰，",
        "unit_id": 106812,
        "voice": "vo_adv_1069003_067"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你起碼得吃些他們供奉的餐點啊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "明明就忙得不可開交，",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_068"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n虧妳還能特地跑來找我講廢話……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你才是，",
        "unit_id": 106812,
        "voice": "vo_adv_1069003_069"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "簡直像個處處刁難嫂嫂的小姑，好意思說我？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n講話老是那麼尖酸刻薄可不討喜喔？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我本就沒有想要討人喜歡。",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_070"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "騙誰啊……",
        "unit_id": 106812,
        "voice": "vo_adv_1069003_071"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真那。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果你還想以神的姿態備受愛戴，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我覺得只要偶爾",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對人類這種程度的存在，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n稍微展現一些奇蹟",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就行了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……別跟我說妳沒聽過",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_072"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "「對佛講經」這句話。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊～好好好，抱歉囉。",
        "unit_id": 106812,
        "voice": "vo_adv_1069003_073"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……總之，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哪天你心血來潮",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就跟我們一起去拯救世界吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這位大神。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哼……",
        "unit_id": 106911,
        "voice": "vo_adv_1069003_074"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在這之後又過了一段時間──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n重獲自由並恢復力量的霸瞳皇帝，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n遇上了蹂躪阿斯特朗的巨神。"
    },
    {
        "type": "background",
        "background": "500135"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……那個大塊頭",
        "unit_id": 106914,
        "voice": "vo_adv_1069003_075"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真礙眼。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "把別人費心佈置的基礎建設和環境搞得七零八落，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n實在令人火大……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而且……",
        "unit_id": 106914,
        "voice": "vo_adv_1069003_076"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我還沒有",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "使出全力來對抗啊──！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "霸瞳皇帝像是要迎向{player}為他帶來"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n的結局一般，對巨神發動試探性攻擊。"
    }
