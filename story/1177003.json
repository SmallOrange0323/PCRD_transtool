        "voice": "vo_adv_1177003_066"
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "我感到很幸福。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n謝謝",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "你們兩個。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～♪",
