    {
        "type": "dialogue",
        "name": "旁白",
        "words": "香織說有事需要幫忙，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n於是{player}來到"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【哞哞自衛隊】的據點。"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～♪",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n謝謝你",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "過來～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你問要幫忙什麼事？",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我沒講嗎？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "其實啊～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我想請你幫忙",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "做開口笑～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我跟【動物苑】的其他人討論了一下，",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n今年的萬聖節想做點什麼～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "於是",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們決定要發送點心，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n給蘭德索爾的人們～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我打算",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "做很多開口笑，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以才想請{player}幫忙～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～♪",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n就是這個氣勢～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……你們說，要做好吃的",
        "unit_id": 1,
        "voice": "vo_adv_1177003_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "開口笑？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～？",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "剛才的聲音是……？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n有人在嗎～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "哎呀，",
        "unit_id": 1,
        "voice": "vo_adv_1177003_008"
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "我是不是嚇到你們了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n我就在這裡啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n雖然",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "你們應該看不到我。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真的耶～",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "聽得到聲音",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "卻看不到身影～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n……這代表，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳是幽靈吧～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "是啊。",
        "unit_id": 1,
        "voice": "vo_adv_1177003_010"
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "我只是剛好路過而已……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n不過一聽到開口笑，我就沒辦法不吭聲呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "阿婆，",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳知道",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "開口笑嗎？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "是啊，",
        "unit_id": 1,
        "voice": "vo_adv_1177003_012"
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "何止是知道，我非常喜歡喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n我以前，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "去過某座島旅行……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n在那裡吃到的開口笑，真的很好吃呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "阿婆",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "旅行時去的那個島，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可能就是我的故鄉～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那裡是個好地方對吧！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "那座島很棒啊，去過後會讓人生變得不一樣。",
        "unit_id": 1,
        "voice": "vo_adv_1177003_014"
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n經過那一次旅行之後，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n我自己也學會做開口笑了呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "開口笑是這麼好吃的東西，",
        "unit_id": 1,
        "voice": "vo_adv_1177003_015"
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n我想讓更多人知道這個甜點。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n這曾經",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "是我的夢想。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "可是",
        "unit_id": 1,
        "voice": "vo_adv_1177003_016"
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "像我這樣的老太婆，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n能做到的事很有限哪。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n結果",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "沒能實現夢想，人生就這麼結束了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣呀～",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n明明是很美好的夢想，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒辦法實現真遺憾呢……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我決定了！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "阿婆的夢想，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "由我們來實現吧～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "真的嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1177003_019"
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n小姑娘你們……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "要幫我實現？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "當然呀～！",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n畢竟我也想把開口笑，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n推廣給大家知道嘛～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那麼，",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們馬上，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就來做開口笑吧～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "油溫",
        "unit_id": 1,
        "voice": "vo_adv_1177003_022"
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "要再低一點點。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n這樣",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "形狀才能炸得漂亮喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "原來如此～",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "阿婆真是開口笑博士呢～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "希望妳再多教我一些～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "我沒有太多可以教小姑娘妳的呢。",
        "unit_id": 1,
        "voice": "vo_adv_1177003_024"
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n妳已經，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "早就學會最重要的事了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "做開口笑來說最重要的事，",
        "unit_id": 1,
        "voice": "vo_adv_1177003_025"
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n就是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "對開口笑的愛啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～♪",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_026"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "的確，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我非常喜歡",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "開口笑喔～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我要灌注愛心來製作～♪",
        "unit_id": 117711
    },
    {
        "type": "background",
        "background": "505034"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "開心地做點心之後，",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要來",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "發點心了～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我要把這些開口笑全部發完，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n實現",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "阿婆的夢想～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有個女生來了～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我拿去送給她～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "萬聖節快樂♪",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "歡迎嘗嘗看好吃的開口笑～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "開口",
        "unit_id": 1,
        "voice": "vo_adv_1177003_030"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "笑……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "那是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "什麼呢？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "開口笑就是開口笑呀～",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_031"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "看起來超好吃的吧，",
        "unit_id": 117711
    },
