        "voice": "vo_adv_1177003_063"
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n居然能這麼受歡迎……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
        "words": "\n簡直像在做夢一樣啊……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "做了一大堆的萬聖節開口笑，",
        "unit_id": 117711,
        "voice": "vo_adv_1177003_064"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n通～通發完了呀～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家辛苦了～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "老婆婆幽靈",
