        "voice": "vo_adv_2108005_000"
    },
    {
        "type": "background",
        "background": "501300"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然是勉強",
        "unit_id": 100111,
        "voice": "vo_adv_2108005_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在位於島嶼角落的",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這片淺灘降落了……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝！",
        "unit_id": 100312,
        "voice": "vo_adv_2108005_002"
    },
    {
        "type": "background",
        "background": "501300"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……！",
        "unit_id": 105911,
        "voice": "vo_adv_2108005_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n【憤怒‧軍團】的據點所在的島嶼，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n確實就是這座島嗎……！？",
        "unit_id": 105911
    },
    {
        "type": "background",
        "background": "501300"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔……！",
        "unit_id": 106011,
        "voice": "vo_adv_2108005_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就航線來看，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該就是這樣沒錯……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n再說四周就是一望無際的大海，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "除此之外什麼都沒有啊！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "501300"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這裡到處",
        "unit_id": 106411,
        "voice": "vo_adv_2108005_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "都是魔物……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "而且別說是樹了，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "根本寸草不生！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我不認為",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有人會住在這種地方啊……！？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可是，",
        "unit_id": 100211,
        "voice": "vo_adv_2108005_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "【憤怒‧軍團】的那些人",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "畢竟能夠使用空間跳躍……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不管是惡劣的環境還是魔物，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對他們來說搞不好都不是問題……！？",
        "unit_id": 100211
    },
    {
        "type": "background",
        "background": "501300"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……呼。",
        "unit_id": 100311,
        "voice": "vo_adv_2108005_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n總而言之，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們好像成功收拾掉魔物了啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "各位，",
        "unit_id": 100211,
        "voice": "vo_adv_2108005_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你們有沒有受傷？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們都還沒抵達敵人的據點啊。",
        "unit_id": 106411,
        "voice": "vo_adv_2108005_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可不能在這種地方",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "陷入苦戰。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，",
        "unit_id": 100111,
        "voice": "vo_adv_2108005_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為魔物的數量很多，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我們剛才可能挺吵的……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是很想再沉穩一點地",
        "unit_id": 105811,
        "voice": "vo_adv_2108005_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "安靜登陸……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但這也沒辦法呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟我們沒料到",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "居然會有這麼多魔物。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過說穿了，",
        "unit_id": 106011,
        "voice": "vo_adv_2108005_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "打從我們想從空中闖進來開始，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就已經沒有隱匿作戰的感覺了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 100311,
        "voice": "vo_adv_2108005_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "以奇襲來說，這樣應該還算成功。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n接下來就要與時間賽跑了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在那個方向……",
        "unit_id": 106411,
        "voice": "vo_adv_2108005_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "島嶼的正中央，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "能看見像是塔的東西呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這座島與好像沒多大，",
        "unit_id": 105911,
        "voice": "vo_adv_2108005_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也找不到其他",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像是建築物的東西。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果【憤怒‧軍團】的據點就在這裡，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n最可疑的就是那座塔……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～！",
        "unit_id": 105811,
        "voice": "vo_adv_2108005_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們走吧，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "嗯！",
        "unit_id": 1,
        "voice": "vo_adv_2108005_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一邊跑步",
        "unit_id": 106011,
        "voice": "vo_adv_2108005_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一邊確認作戰吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是遇到了【憤怒‧軍團】那群人……",
        "unit_id": 106011,
        "voice": "vo_adv_2108005_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而那群傢伙",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又有四個人以上的話要怎麼做？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "全力以赴地逃跑！",
        "unit_id": 106411,
        "voice": "vo_adv_2108005_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只能祈禱那些人",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒有通通待在這座島上……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然因為他們",
        "unit_id": 100311,
        "voice": "vo_adv_2108005_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也正在尋找七冠，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我認為這個可能性很大……！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "遇到兩或三個人時呢？",
        "unit_id": 106011,
        "voice": "vo_adv_2108005_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由某個人當誘餌，",
        "unit_id": 105911,
        "voice": "vo_adv_2108005_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "形成一對一的局面，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果是三個人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就製造出兩組一對一的局面，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n然後對剩下的敵人展開",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "集中攻擊……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "畢竟我們之前是",
        "unit_id": 100211,
        "voice": "vo_adv_2108005_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "四個人一起上，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n才打倒了那個",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "叫阿澤爾德先生的人啊。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然那時非常驚險……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 106011,
        "voice": "vo_adv_2108005_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果敵人只有一個人的話呢？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n日和！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯……！",
        "unit_id": 100111,
        "voice": "vo_adv_2108005_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "到時候就使出全力，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "迅速地解決對方！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果能在敵人的援軍抵達前擊敗對方，",
        "unit_id": 105811,
        "voice": "vo_adv_2108005_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n最好的情況就是只遇到一個人啊……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 100211,
        "voice": "vo_adv_2108005_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不是沒遇到任何人才好嗎……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯……！",
        "unit_id": 105811,
        "voice": "vo_adv_2108005_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為過往都是我們先遭到攻擊，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總是被先發制人……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但這次",
        "unit_id": 105811,
        "voice": "vo_adv_2108005_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是我們第一次主動展開攻擊。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n趁著這個機會，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想盡量削弱【憤怒‧軍團】的戰力……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啊……！",
        "unit_id": 106011,
        "voice": "vo_adv_2108005_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳難得講了句對的話啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就是說，",
        "unit_id": 105911,
        "voice": "vo_adv_2108005_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們的目標是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
