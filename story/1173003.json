[
    {
        "type": "background",
        "background": "500280"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為與魔物戰鬥而遇難的千歌和{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在漂流一陣子後，終於抵達了陸地。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼，",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好險……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是千鈞一髮呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這艘船已經到極限了。",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n它沒辦法再繼續航海了呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "看來這裡是",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "漲潮時會跟陸地分開，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n類似潮汐島的地方……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "感覺等退潮後",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就能往對面的陸地移動，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但在不熟悉的環境隨意行動是很危險的。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……所以，",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在乖乖等救援來",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "才是明智之舉。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "放鬆",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗎？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "說得也是呢……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……那個，",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真的很抱歉。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我不只把你牽扯進戰鬥裡，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還害你遇難……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且，",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我姑且算是很習慣旅行，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但我沒什麼野外求生的知識……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "畢竟不曉得救援何時才會來，",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在這種不安的狀況下，我不曉得自己有沒有辦法放鬆，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "無人島！？",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對不起……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為你的發言太過出人意料，我才會嚇一跳。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒什麼人",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "會有機會去無人島對吧？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那不是會用像是「我之前去過道具店」的語氣說的話喔。",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你果然是個",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很有趣的人呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "的確，",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在再怎麼沮喪，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n漂流到這裡的事實也不會改變……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那還不如好好享受，",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "肯定是這樣會比較好。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這種心情的轉換跟",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "樂觀正面的思考，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n對以前的我來說，是很困難的。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這也是多虧了你對吧……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "說得也是呢。",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就讓我們一起享受吧！",
        "unit_id": 117311
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你看。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那棵樹",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有長出果實耶。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "看起來很好吃，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但它是可以吃的嗎？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這樣啊。",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那馬上摘一個看看……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "摘到了！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "剛摘下來就直接吃，",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n或許有點沒規矩，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但現在沒有關係對吧？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我要開動了……",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯～",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好甜好好吃！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在店裡買的是也不錯，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但很奇妙的，我覺得這個更加好吃。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n是自己找跟摘的行為",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓它變好吃的嗎。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我總覺得",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有些開心起來了。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}，接下來要做什麼？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "捉、",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "捉蟲嗎？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "捉蟲確實也是夏天的娛樂之一，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但我",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不怎麼擅長……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這麼說來，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我聽說有人會花大錢購買某一些蟲。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "莫非",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你是要找那種蟲嗎？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……看來不是呢。",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我明白了。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這是個好機會，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我也要挑戰捉蟲──",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呀啊！",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對不起，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "果然還是容我婉拒吧！",
        "unit_id": 117311
    },
    {
        "type": "background",
        "background": "500280"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不好意思，",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓你看到那麼丟臉的模樣……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "接下來我會試著努力的。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "摘完果實後換釣魚，",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "越來越有野外求生的感覺了呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n釣魚的話，我似乎也辦得到……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們沒有釣竿呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "原來如此！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n用藤蔓",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "代替釣魚線綁在樹枝上，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就成為應急的釣竿了嗎。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "居然三兩下就做得出這種東西……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你真的很厲害呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那我們就努力",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "釣起大魚吧！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……雖然",
        "unit_id": 117311,
        "voice": "vo_adv_1173003_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "剛才鼓足了幹勁，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "結果卻完全釣不到。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
