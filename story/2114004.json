        "voice": "vo_adv_2114004_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該也不會毫無動作才對。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是能設法跟她們會合就好了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是到處都是一片混亂，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來沒有那麼容易啊……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啊……",
        "unit_id": 106011,
        "voice": "vo_adv_2114004_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "闇影P",
        "words": "──！",
        "unit_id": 192921,
        "voice": "vo_adv_2114004_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔……！",
        "unit_id": 106011,
        "voice": "vo_adv_2114004_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "休想得逞！",
        "unit_id": 105811,
        "voice": "vo_adv_2114004_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n公主突襲──！",
        "unit_id": 105811
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "謝、",
        "unit_id": 106011,
        "voice": "vo_adv_2114004_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "謝謝妳……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不、",
        "unit_id": 106011,
        "voice": "vo_adv_2114004_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這恐怕會是一場持久戰！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳可別衝過頭了喔……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的！",
        "unit_id": 105811,
        "voice": "vo_adv_2114004_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我還很有衝勁喔──！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎唷真是的，",
        "unit_id": 106011,
        "voice": "vo_adv_2114004_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好好聽人家說話好嗎……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真受不了……！",
        "unit_id": 106011,
        "voice": "vo_adv_2114004_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不知道前往索爾之塔的{player}他們，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n有沒有好好進行人質交換……！　",
        "unit_id": 106011
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好──",
