        "voice": "vo_adv_2114004_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "到了～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "多虧有怜小姐和日和小姐引路，",
        "unit_id": 105911,
        "voice": "vo_adv_2114004_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們才能這麼快就到達中層。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "畢竟我們之前",
        "unit_id": 100311,
        "voice": "vo_adv_2114004_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了探路和尋找索爾魔珠的線索，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n已經挑戰過好幾次這座塔了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "至少不會迷路的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯。",
        "unit_id": 100111,
        "voice": "vo_adv_2114004_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n話說回來……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "想不到竟然把索爾魔珠",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都收集到了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 100311,
        "voice": "vo_adv_2114004_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總算",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "全部集齊了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_2114004_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只要使用這個，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就能打開塔頂的門……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和、可可蘿",
        "words": "「怜！？」\n「怜小姐……！？」",
        "unit_id": 1,
        "voice": "vo_adv_2114004_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呃、",
        "unit_id": 100311,
        "voice": "vo_adv_2114004_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我當然不是認真的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抵達塔頂的那一刻，",
        "unit_id": 100311,
        "voice": "vo_adv_2114004_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣肯定也要在我們身邊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有菲歐也是。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯！",
        "unit_id": 100111,
        "voice": "vo_adv_2114004_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只要救回菲歐，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "然後打倒彌勒，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n或許就能在塔頂執行拉比林斯達小姐的計畫了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "──很遺憾，",
        "unit_id": 192611,
        "voice": "vo_adv_2114004_028"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n我不會讓你們那麼做的。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "彌勒……！",
        "unit_id": 100311,
        "voice": "vo_adv_2114004_029"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "各位，",
        "unit_id": 192611,
        "voice": "vo_adv_2114004_030"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "日安。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "不過，",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "嗯……",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "公主殿下她們留守城中是嗎。",
        "unit_id": 192611,
        "voice": "vo_adv_2114004_031"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "我個人",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "是很樂意再跟",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "百地希留耶小姐暢談一番的。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對付你，",
        "unit_id": 105911,
        "voice": "vo_adv_2114004_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有在下等人就夠了……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "哎呀哎呀，",
        "unit_id": 192611,
        "voice": "vo_adv_2114004_033"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "請不要對我如此劍拔弩張的。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "今天不是來戰鬥，",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "只是一場交涉的會談。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n難道不是嗎？",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你還敢說……！",
        "unit_id": 100311,
        "voice": "vo_adv_2114004_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n明明是你",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "先用人質要脅我們的……！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "呵呵。",
        "unit_id": 192611,
        "voice": "vo_adv_2114004_035"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "那麼……",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "閒話就到此為止。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "終炎巨神",
        "words": "…………",
        "unit_id": 16111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……！",
        "unit_id": 100111,
        "voice": "vo_adv_2114004_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "困住菲歐的魔物……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "我的要求如同先前所述。",
        "unit_id": 192611,
        "voice": "vo_adv_2114004_037"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n你們會來此與我會面，",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n想必是已經準備好我想要交易的東西了吧……？",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這是我們收集到的索爾魔珠，",
        "unit_id": 100311,
        "voice": "vo_adv_2114004_038"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "十二顆。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n全部",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都裝在這個袋子裡。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "很好。",
        "unit_id": 192611,
        "voice": "vo_adv_2114004_039"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n那麼，",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "請把袋子放在妳腳邊。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n我們彼此順時鐘移動半圈，",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "走到要交易的東西旁邊吧。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
