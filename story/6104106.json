    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嘿嘿，",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "怎麼樣？",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "帥嗎！？",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你這麼誇我，我會害羞的啦～♪",
        "unit_id": 123911,
        "voice": "vo_adv_6104106_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過，",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "說得也是呢。",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為了不愧對這副模樣，",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我會燃燒自己的正義之魂活下去的！",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嘿嘿♪",
        "unit_id": 123911,
        "voice": "vo_adv_6104106_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為英雄是我憧憬的目標啊。",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為了守護世界的和平，",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為了守護大家的笑容……",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我絕對會成為虎虎那種",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "守護他人的英雄！",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我都忘記了！",
        "unit_id": 123911,
        "voice": "vo_adv_6104106_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "難得都報上名號了，",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n最後要是沒有招牌姿勢可不行呢！",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那麼就",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "把劍高高舉起……",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這種姿勢怎麼樣啊？",
        "unit_id": 123911
    }
