        "voice": "vo_adv_1018012_036"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "老師的愛之鞭！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n大家冷靜下來～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "居然不聽老師的話，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_037"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "大家什麼時候變成不良了？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n有精神是好事，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但也不能給他人造成麻煩，不是嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "別擔心，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_038"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "他是非常好的人。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n人既溫柔",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "又很可靠……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "他",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總是會來幫助我喔。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你們能夠得救，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_039"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也都是多虧有他在！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "咪、",
        "unit_id": 1,
        "voice": "vo_adv_1018012_040"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "咪～～～……♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "老師的想法",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_041"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有好好傳遞給大家了嗎……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n讓我和他說個話。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "明白了嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "咪～♪　",
        "unit_id": 1,
        "voice": "vo_adv_1018012_042"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "咪～♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太好了，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_043"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "大家都變回乖孩子了～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可以和他",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "友好地握手嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "咪咪～～～♪",
        "unit_id": 1,
        "voice": "vo_adv_1018012_044"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}的朋友能變多，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_045"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我也好開心。",
        "unit_id": 101811
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_046"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你應該很驚訝吧？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n被這麼多魔物包圍，會驚訝也",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是難免的吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "之前呀，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_047"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我救下來的魔物",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "差點就要被鎮上的人驅除的事情，你還記得嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那時候，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_048"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是你站在我們這邊",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "幫助了我們對吧？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你可靠的身影",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓我非常感動。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而且你",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_049"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "從我們第一次見面後，就不斷成長，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n連測驗的成績也一點一滴在進步，不是嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我身為老師，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_050"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "卻總是受到你的幫助，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我認為自己也必須像你一樣做點什麼事，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "才會像這樣照顧著受傷的魔物們。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果牠們因為中了陷阱，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_051"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而討厭人類去襲擊人類就不好了吧？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這附近是上下學路線，會有很多學生往來，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一想到月光學院的學生們要是出了什麼萬一……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "小型魔物",
        "words": "咪～！",
        "unit_id": 1,
        "voice": "vo_adv_1018012_052"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來，你看。",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_053"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "去了解牠們每隻魔物以後，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "大家都是乖孩子，對吧？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這孩子是加爾，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這邊的是阿豪",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "和奇碰！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "小加爾們（魔物）",
        "words": "凹嗚凹嗚！",
        "unit_id": 1,
        "voice": "vo_adv_1018012_054"
    },
    {
        "type": "dialogue",
        "name": "小加爾們（魔物）",
        "words": "\n咕呼咕呼！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小加爾們（魔物）",
        "words": "\n唔嘰嘰～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剛才你過來的時候，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_055"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我正在和這些孩子們玩耍。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "大家一開始都受了傷，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但似乎已經完全恢復精神了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那時候，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_056"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你突然拉著我跑掉，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "大家可能",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是因為這樣才誤以為你是壞人吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_057"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天多虧有你在我身邊，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我才能夠馬上救下新的孩子。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "難道說",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我又受到你的幫助了？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這麼說來，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_058"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你應該正在打工才對吧？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n為什麼會在這種地方？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯嗯……",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_059"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你去了我拜訪過的學生家啊。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "才會追在我後頭過來。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦！",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_060"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n那個人也認為你是我的男朋友？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你為什麼每次都不否定嘛～！",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_061"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那意思是",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "難道你也是那麼想嗎……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你是我的學生，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_062"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我怎麼能把你當男朋友。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n的確，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我是希望",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "第一個男朋友是個可靠、溫柔，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "像你一樣的人……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣啊，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_063"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你是……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你是第一個……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "的話……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "吶，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_064"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我說。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n下個週末",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你有沒有空？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真的？",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_065"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n那麼……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要不要一起外出？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不是之前那種像約會一樣的購物，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_066"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而是那個……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "情侶會做的……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "約會……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真的？　",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_067"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太好了～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "練習題就結束囉。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_068"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒想到邀請人約會，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n居然會這麼緊張",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "又難為情，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我都不知道呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_069"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我差不多該回去繼續做家庭訪問了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你打工",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也要小心點喔！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呀啊！",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_070"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊啊嗯～！",
        "unit_id": 101811,
        "voice": "vo_adv_1018012_071"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n被庫爾的尾巴纏住了～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "幫幫我～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不久後，伊緒照料的魔物們，\n成為月光學院守護學生們上下學的吉祥物，\n而被附近居民所接受。"
    }
