[
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雨吉！",
        "unit_id": 110011,
        "voice": "vo_adv_5019321_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n再一下下就能見到晴吉了，你冷靜點！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果你也是淑女，",
        "unit_id": 110211,
        "voice": "vo_adv_5019321_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就乖乖待著！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "突、",
        "unit_id": 110211,
        "voice": "vo_adv_5019321_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "突然發生什麼事了，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這個聲音是！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "美咲，快看！",
        "unit_id": 110011,
        "voice": "vo_adv_5019321_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n雨吉的周圍好像出現了什麼！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個是屏障？",
        "unit_id": 110211,
        "voice": "vo_adv_5019321_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "討厭！　",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "看來他不管怎樣就是不聽我們說話呢！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "從剛才開始，",
        "unit_id": 110211,
        "voice": "vo_adv_5019321_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就一直傳來奇怪的聲音耶～！？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個聲音，",
        "unit_id": 110011,
        "voice": "vo_adv_5019321_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像是說話聲……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "難道是雨吉",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "想說些什麼嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "想說些什麼……",
        "unit_id": 110211,
        "voice": "vo_adv_5019321_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果這個聲音是說話聲，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我只聽得出來你很痛苦啊！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是啊，美咲！",
        "unit_id": 110011,
        "voice": "vo_adv_5019321_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雨吉一定是一直很痛苦！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也是，",
        "unit_id": 110011,
        "voice": "vo_adv_5019321_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和美咲吵架之後，獨自一人的時候，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n就想說我說得太過分了，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是不是無法和好了，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一直很痛苦、",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "很難過……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "鈴奈……",
        "unit_id": 110211,
        "voice": "vo_adv_5019321_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "妳",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "竟然是那樣想的……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雨吉",
        "unit_id": 110011,
        "voice": "vo_adv_5019321_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一定也和人家那時一樣。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那道屏障一定也是",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雨吉想要獨處才做出來的，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n就像是內心的城牆一樣！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在人家獨自一人的時候，",
        "unit_id": 110011,
        "voice": "vo_adv_5019321_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在身旁為人家加油打氣的就是雨吉……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以這次，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就換我來幫你了！",
        "unit_id": 110011
    }
]