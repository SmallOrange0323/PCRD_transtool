[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在工作告了一段落後，美里和{player}\n帶著充實的疲倦感在沙灘上散步著。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "來海邊後，",
        "unit_id": 113511,
        "voice": "vo_adv_1135004_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我體驗到了很多事情。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "跟{player}在一起",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "總是很快樂呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "下次會發生什麼樣的事情呢。",
        "unit_id": 113511,
        "voice": "vo_adv_1135004_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我開始有些期待了。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過，",
        "unit_id": 113511,
        "voice": "vo_adv_1135004_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我也很喜歡像這樣",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "兩人一起在沙灘上",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "悠悠哉哉地散步喔？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那……",
        "unit_id": 113511,
        "voice": "vo_adv_1135004_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你呢？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀？",
        "unit_id": 113511,
        "voice": "vo_adv_1135004_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n總覺得陽光",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "突然變強了呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n哎呀哎呀？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "眼前變得",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一片空白……？",
        "unit_id": 113511
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "終於到了。",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "海浪的聲音真是悅耳。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "謝謝你今天陪我來。",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n很快就要到",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "托兒所的遠足日了，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n但我想做好",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "事前勘查。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "找你來的話，",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你應該會注意到",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我沒察覺到的地方，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "今天",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就請你多多幫忙囉？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好了，",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們馬上去沙灘那邊繞繞吧。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n要是沙灘上有掉什麼危險物品就不好了，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們得仔細",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "確認才行。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦？",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "難不成",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你是在問我為什麼不換上泳裝嗎？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "今天",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "只是來做事前勘查，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不需要特地換上泳裝的。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你看起來像是",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "有些惋惜耶？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n……沒有嗎？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是真的嗎。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "海浪很平緩，",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_011"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沙灘很柔軟，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "感覺就算跌倒也不會受傷。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "在這裡玩的話，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "孩子們肯定也會很高興。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但是……",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真的不會有問題嗎。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒有在海邊玩過。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我有辦法讓孩子們",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "玩得盡興嗎。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "而且，",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_014"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "如果孩子們",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "在海裡溺水，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我有辦法救他們上岸嗎。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對不起。",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_015"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我明明是老師，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "卻老想著這種事情……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我很怕",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真的發生什麼狀況時，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "自己卻什麼都辦不到──",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "──哎呀？",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n那個浮在海面上的東西……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是人？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大、",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大事不好了！",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "他是溺水了嗎！？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "得快點去救他才行！",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n要是我有什麼意外，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你就負責去",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "找人來幫忙！",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你等著，",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我這就過去救你……！",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呀！",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒想到穿著衣服下海",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n會這麼難活動……！",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過，",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_021"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "幸好他沒被沖到海上……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n這個",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不是人……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……是海藻？",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我、",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_023"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我也真是的，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真是太貿然行事了……！",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "唉……",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_024"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好丟臉哦。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n回岸上吧……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦？",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_025"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n哎呀，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}你也跑來了？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "為我感到擔心？",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_026"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "謝謝你。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師我",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很開心。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過，",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_027"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對不起，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n原本還以為有人溺水，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是老師誤會了，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "結果只是海藻在水上飄。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很好笑對吧。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我記得你",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_028"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不會游泳對吧？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但你卻還是",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "為我跑到這裡來了……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你真的",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是個好孩子呢。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "可是，",
        "unit_id": 101532,
        "voice": "vo_adv_1135004_029"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你不可以勉強自己喔？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "遭遇危險的模樣……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師一點都不想看到。",
