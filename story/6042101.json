        "voice": "vo_adv_6042101_001"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "喂喂",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "你突然幹什麼啦！？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "怎麼會有人二話不說就動手拽女孩子的身體！？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n璃乃！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "這傢伙是怎麼回事啦！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "呀啊啊，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "而且竟然還不打算收手！？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "嗯……",
        "unit_id": 4611,
        "voice": "vo_adv_6042101_002"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "怎麼了？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "你對我很好奇？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我是能理解你很想",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n觸碰看看如此高雅的我啦，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "但也要稍微多動點腦再行動吧。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "你看，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "璃乃的臉都紅透了。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "你這變態要摸到什麼時候啦。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "唔……！",
        "unit_id": 4611,
        "voice": "vo_adv_6042101_003"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我說過了別突然戳過來吧！？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "你這變態！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "變態可疑分子！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "……咦，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "什麼？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "你已經習慣被這樣叫了？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "璃乃啊，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "這傢伙沒問題嗎？",
        "unit_id": 112912
