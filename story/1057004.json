[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束了騎空團承接的工作，\n吉塔與{player}在郊外稍作休息。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "來，給你。",
        "unit_id": 105711,
        "voice": "vo_adv_1057004_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "鯛魚燒和茶。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "聽說累的時候很推薦吃個鯛魚燒喔。",
        "unit_id": 105711,
        "voice": "vo_adv_1057004_001"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "「不只是又甜又好吃而已喵」，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n店員是這樣告訴我的。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "啊姆……",
        "unit_id": 105711,
        "voice": "vo_adv_1057004_002"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嗯！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "果然這種食物，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就是剛出爐的最好吃呢！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "怎麼樣？",
        "unit_id": 105711,
        "voice": "vo_adv_1057004_003"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好吃嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "對吧？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你能吃得開心，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "真是太好了。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嗯……？",
        "unit_id": 105711,
        "voice": "vo_adv_1057004_004"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "怎麼回事，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "鯛魚燒看起來有點刺眼，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n是不是錯覺……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不對，",
        "unit_id": 105711,
        "voice": "vo_adv_1057004_005"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "鯛魚燒才不會發光！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這道光怎麼回事！？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "太刺眼了，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "什麼都看不見……！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……咦？",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_006"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好奇怪……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "應該是在這裡轉彎沒錯，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "為什麼……？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "完全沒有想到會迷路成這樣……",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_007"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n怎麼辦……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "再這樣下去就要在留學第一天遲到了……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "明明應該是上學路線，",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_008"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "卻完全沒有穿相同制服的人經過……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是不是只能連絡學校，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "請老師來接我了……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "啊！",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_009"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那個人，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "穿的是椿丘的制服！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那個──！",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_010"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不好意思──！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n吶，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "等等……！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……走掉了。",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_011"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "唔哇！",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_012"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "太好了……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你注意到我了。\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那個，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "其實我想要去椿丘高中，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n但是卻迷路了……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你也是椿丘的學生對吧？",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_013"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "拜託你！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "請帶我去學校！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝！",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_014"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我是吉塔。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是２年級哦。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你是幾年級的？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "還有，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "名字是──",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "要是不快一點……？",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_015"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "對了！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "會遲到的！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "跑一下沒問題的，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "快點吧！",
        "unit_id": 105731
    },
    {
        "type": "background",
        "background": "510240"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "呼……呼……",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_016"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "太好了……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "趕上了……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝……",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_017"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你幫了我大忙哦。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "學校裡面有地圖所以沒問題，",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_018"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我能找到教職員室。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n你也得去教室了對吧。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n畢竟在同一所學校裡，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "一定馬上就能再見面的。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那就再見了！",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_019"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "真的謝謝你！",
        "unit_id": 105731
    },
    {
        "type": "background",
        "background": "510210"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是個溫柔的人呢……",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_020"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n要是班上",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "也有像他一樣的人就好了……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "話說回來，",
        "unit_id": 1,
        "voice": "vo_adv_1057004_021"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "妳能趕上實在太好了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n我會拜託班上的同學，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n明天開始盡量和妳一起上學的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "非常抱歉，",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_022"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "讓您擔心了……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我會自己拜託班上的同學看看的。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我也想快點和大家成為朋友。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "真積極呢。",
        "unit_id": 1,
        "voice": "vo_adv_1057004_023"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "很好很好。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n好了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "到教室了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "自我介紹準備好了嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……是的。",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_024"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "沒有問題。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "麻煩您了。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "我先進去和大家說明，",
        "unit_id": 1,
        "voice": "vo_adv_1057004_025"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "妳先在這裡等一下。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n我叫妳之後再進來。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我知道了。",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_026"
    },
    {
        "type": "dialogue",
        "name": "班長",
        "words": "起立！",
        "unit_id": 1,
        "voice": "vo_adv_1057004_027"
    },
    {
        "type": "dialogue",
        "name": "班長",
        "words": "敬禮！……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "班長",
        "words": "坐下！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……",
        "unit_id": 105731,
        "voice": "vo_adv_1057004_028"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嗚，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好緊張啊……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "能不能成功",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "交到朋友呢……？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "好的，",
        "unit_id": 1,
        "voice": "vo_adv_1057004_029"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "各位早安。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n今天有件事要向大家報告。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n有轉學生",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "要轉來我們班上。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "學生",
        "words": "轉學生！？",
        "unit_id": 1,
        "voice": "vo_adv_1057004_030"
    },
    {
        "type": "dialogue",
        "name": "學生",
        "words": "真的假的！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "雖然是來自國外的留學生，",
        "unit_id": 1,
        "voice": "vo_adv_1057004_031"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n但她的日文說的很好，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n請各位不要害怕，盡量和她搭話哦。",
        "unit_id": 1
    },
