    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "育幼院的聖誕派對當天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n派對準備進展得很順利，咲戀心情很好。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵，",
        "unit_id": 102811,
        "voice": "vo_adv_1145003_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有了最棒的烤雞和蛋糕，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n今年的聖誕節已經能",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "算是圓滿成功了吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "飲料",
        "unit_id": 102811,
        "voice": "vo_adv_1145003_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要等下午才會送到，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n現在就剩下其他料理和",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "布置了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "料理就用從獵人先生那裡得到的野生食材，",
        "unit_id": 102811,
        "voice": "vo_adv_1145003_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "布置的話，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和孩子們一起做好像挺不錯的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811,
        "voice": "vo_adv_1145003_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "變得有趣起來了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼就一口氣",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "把所有事情都做完吧♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "咲戀媽媽──！",
        "unit_id": 111,
        "voice": "vo_adv_1145003_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀，",
        "unit_id": 102811,
        "voice": "vo_adv_1145003_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是你們啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來得正好。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們一起來──",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "那個呀，咲戀媽媽，",
        "unit_id": 211,
        "voice": "vo_adv_1145003_006"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "請妳離開。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……咦？",
        "unit_id": 102811,
        "voice": "vo_adv_1145003_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為什麼要說這種話……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "笨蛋，",
        "unit_id": 111,
        "voice": "vo_adv_1145003_008"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "那種說法很像是在趕咲戀媽媽走耶。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "我說啊，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "咲戀媽媽妳，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "最近一直都很忙吧？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯、",
        "unit_id": 102811,
        "voice": "vo_adv_1145003_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對不起呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我最近工作很多……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不能說出",
        "unit_id": 102811,
        "voice": "vo_adv_1145003_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我其實是在為大家偷偷準備聖誕派對。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "所以呀，",
        "unit_id": 211,
        "voice": "vo_adv_1145003_011"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "咲戀媽媽也",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "不能不聖誕一下喔。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "蘭德索爾上下都在慶祝聖誕節，",
        "unit_id": 5311,
        "voice": "vo_adv_1145003_012"
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "\n咲戀媽媽一直工作會累壞的。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "所以咲戀媽媽現在",
        "unit_id": 5311,
        "voice": "vo_adv_1145003_013"
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "就上街去享受聖誕節吧！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦，",
        "unit_id": 102811,
        "voice": "vo_adv_1145003_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算你們突然這麼說……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "在太陽公公落下之前",
        "unit_id": 111,
        "voice": "vo_adv_1145003_015"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "不可以回來喔！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "來，這個，",
        "unit_id": 211,
        "voice": "vo_adv_1145003_016"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "是咲戀媽媽的禮服喔。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "聖誕節",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "要打扮得漂漂亮亮才行。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦，",
        "unit_id": 102811,
        "voice": "vo_adv_1145003_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等一下……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "玩得開心點哦～！",
        "unit_id": 1,
        "voice": "vo_adv_1145003_018"
    },
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真傷腦筋。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "突然叫我來街上玩，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也不知道派對準備",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會不會有問題……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓她們也在，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該能放心吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "準備工作就剩最後一點點了，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我本來想好好做完的。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話雖如此，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也不能辜負了",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "孩子們的好意。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然聽他們的話來到了街上……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "果然到處都是情侶呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不是情侶",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是家長帶小孩。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然看著他們幸福的樣子是很好，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但這下子",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不就更襯托出我是",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "孤單一個人了嘛。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也不想被陌生男子搭話。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真沒辦法，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "隨便找一間店進去",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "殺時間吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看吧，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我一說就出現了……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我不需要……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼嘛，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是{player}啊。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對了對了，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "上次謝謝你啦。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n多虧了你，我們似乎能過上一個很棒的聖誕節呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "派對晚上才會開始，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "記得準時來喔。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說到這個，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "其實……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "──總之，就是這麼一回事。",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "到時一定會是場認真的派對，這點你可以放心。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話說回來，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那你在這裡做什麼？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n該不會，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你連聖誕節這天都得打工吧？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然我沒什麼資格說你，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但至少聖誕節這天要好好休息啦。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這張傳單",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是什麼……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "「蘭德索爾雪祭」？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n哼～",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會展示雪做的雕像啊。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來有這種活動。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺是很有趣啦，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但這種地方，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "全都是成雙成對的情侶吧？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我看你應該也",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不在意這種事。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼？",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和我一起？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你不是有",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很多女性朋友嘛。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也不用特地",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "找我去吧……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什、",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼啊……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也不是不願意啦……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "現在和這傢伙一起",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "去那種閃亮浪漫的活動，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不就會讓我胡思亂想嗎！　",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "更不用說，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "之前發生了那麼多事，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓我明白了他的優點，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但我們之間又不是那種關係……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然都這樣麻煩他幫我準備聖誕節了，現在才提起這些有點說不過去，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但、但",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "聖誕節當天",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "果然是特別的日子啊！　",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……仔細想想，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這傢伙的話，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n應該完全沒有意識到",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "情侶啊、聖誕節之類的事。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只有我一個人過度在意，搞得這麼慌張，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總覺得有點不爽呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我就應下",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個邀約吧！　",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不、",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "比起一個人四處亂晃，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n和你在一起好像",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還比較好。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好吧，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "既然你都說到這份上了，我就陪你去。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能和我一起去欣賞雪祭，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你可要心懷感恩喔♪",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哇……！",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好厲害，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這些竟然通通都是用雪做的，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是難以置信！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n多麼美麗莊嚴啊！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "快看快看，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_041"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個王宮的雪雕！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還原度真高！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個是鈴鈴噹吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "胡桃看到了一定會很開心！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是雪做的溜滑梯？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼辦，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我有點感興趣呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這一定只開放給小孩子玩吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊──",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可是可是……！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你看你看，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_043"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那邊的雪堡",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "成人好像也能進去喔。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們去看看吧！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哈哈……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一不小心",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n看到雪這麼興奮，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像有點小孩子氣，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但看了這麼厲害的東西，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是會讓人不由自主地高興起來嘛。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_045"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "最近這段日子都過得手忙腳亂，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n總算能感受到了街上的聖誕氣氛，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也讓我很開心呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要好好感謝",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_046"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那些說著",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "「咲戀媽媽也要享受聖誕節」，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n而把我送出門的",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "孩子們呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊──",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_047"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這種舒暢感",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是久違了……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哈啾！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n嗚嗚，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雲出來了，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像變得",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有點冷。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呀！",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_048"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你突然做什麼啦。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為我看起來很冷，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "才握了我的手？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝、",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_049"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要突然對",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n戀人以外的對象做這種事啦。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會讓人嚇一跳的。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_050"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這傢伙總是會毫無惡意地做出這種事，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真是",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "拿他沒轍。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_051"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "玩得真開心。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n偶爾忘記工作，悠閒地玩樂",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也還不壞呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_052"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "已經玩夠了，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是時候回去吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然離傍晚還有很久，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但我很在意育幼院的情況呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_053"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那裡……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是孩子們的作品區啊。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "每個作品都能感受到孩子們拼命努力的心情，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真可愛呢……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你看，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_054"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不覺得",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個雪雕",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "長得和我很像嗎？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n作品標題是……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "「給最愛的媽媽」？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這、",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_055"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這雪雕，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "創作者是……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "「咲戀育幼院的",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "孩子們」……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哈哈……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "討厭啦，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣的聖誕禮物，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也太讓人驚喜了吧……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那些孩子們，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_056"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然我把他們當作孩子，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但在不知不覺間，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "已經能自己做到這些事了。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "小孩子",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的是，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一下子就能超乎我們的想像呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_057"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這點真是讓人欣慰。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n讓我不禁覺得，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "至今為止所做的這一切都是正確的。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我竟然能以這麼美好的形式",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_058"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感受到這件事，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n說不定真的有所謂的",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "聖誕奇蹟呢♪",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_059"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你也",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和那些孩子們",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "認識很久了嘛。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能一起度過相同的時光，",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_060"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是件美妙的事呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們甚至都能",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "共享這份情感了嘛……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這應該",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_061"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就叫做幸福吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……謝謝你讓我度過了一個",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_062"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "最棒的聖誕節，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n{player}。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "！？",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_063"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n咦？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是啊，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那就約好囉！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嚇我一跳……",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_064"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這傢伙就是會毫不做作地說出這種話，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真是大意不得呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所、",
        "unit_id": 114511,
        "voice": "vo_adv_1145003_065"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以說，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你接下來",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有什麼計畫？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……咦？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有想和我",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一起去的地方？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真拿你沒辦法。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "都到這裡了，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我就奉陪到底吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼，",
