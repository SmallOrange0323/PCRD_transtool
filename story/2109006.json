    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你被關在一個像魔法結晶的",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "東西裡了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "【憤怒‧軍團】……",
