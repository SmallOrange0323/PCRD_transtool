        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "就算是我，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "都會吃敗仗的程度……",
        "unit_id": 107311
    },
