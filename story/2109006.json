        "name": "拉基拉基",
        "words": "一個忠告吧。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n要小心【憤怒‧軍團】公會長，",
        "unit_id": 107311
