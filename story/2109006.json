        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你的忠告。",
        "unit_id": 100311
