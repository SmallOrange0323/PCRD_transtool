[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍將軍，",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "糟糕了、糟糕了，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n聽我說是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "妮諾氣勢十足地朝著{player}跑過去。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "最近溪谷附近出現了魔物，往來的商人們好像都很傷腦筋。",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "由於整個城鎮的人都覺得很困擾，因此打算組成大規模部隊，",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n進行魔物討伐計畫。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "討伐部隊好像打算明天中午出發是也～！",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "若我們將魔物打倒的話，一定能獲得城池的。",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "領地百萬石就是我們的目標是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們統一天下的目標，也能夠一口氣接近，",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n妮諾我們正可說是坐享其成是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "欸……？",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍你說魔物好像真的很強？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n突然就這樣跑去也無法保證能打倒牠，非常危險是也？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯……",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可是要是大家一起去、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n一起戰鬥的話，總會有辦法的是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而且……我最近學會",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "秘藏又秘藏的必殺技了！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "若真的發生什麼事，我會使出這個必殺技的，",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍像搭屋形船一樣，放十二萬個心是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍與屋形船……",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_010"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真浪漫是也～",
        "unit_id": 103011
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天中午。討伐隊終於抵達溪谷裡，\n魔物所在的位置……"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗚……",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好強是也…… ",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "竟然是這麼強的敵人……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "再這樣下去的話，大家都會被幹掉是也……",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n大家的士氣也一直在下降……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "謝謝你，將軍！",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_013"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是呢，我們可不能輸了！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有、有沒有什麼作戰計畫呢……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "秘藏必殺技……？",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_014"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哈……就是啊！",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_015"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "現在正是我使出秘藏必殺忍法的時候！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "妮諾向前踏出一步，\n然後轉身朝著討伐隊全員大叫。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "諸位夥伴────們！",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_016"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "接下來我要使出必殺的忍法，希望在這裡的各位",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n能助我一臂之力是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "幫助我的人越多，效果會越好是也～！",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_017"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "希望大家一定要幫忙是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "噢……！該不會是要使出什麼很厲害的魔法嗎！？",
        "unit_id": 1011,
        "voice": "vo_adv_1030003_018"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "好啊，小姐，我們就照妳的話去做！",
        "unit_id": 1111,
        "voice": "vo_adv_1030003_019"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那麼，各位請跟我做出一樣的動作！",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_020"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要上囉────！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "妮諾彎下身體、膝蓋著地，\n並向前低下頭……"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真是對不──────────────起！！",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_021"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "正如你所見，請原諒我們吧！",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_022"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍法・「東國・傳統式・磕頭下跪法」是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "喂喂喂喂喂喂！",
        "unit_id": 1011,
        "voice": "vo_adv_1030003_023"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n這招哪裡算得上忍法啊啊啊！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不……聽說這是很久以前，從別的國家來的無能冒險者，",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_024"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "傳到我們王國的忍法是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "只要使出這個忍法……好像不管怎樣的魔物都會逃跑是也……",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_025"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看了那個忍法後，魔物的動作稍微停止了。"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "喂、喂、該不會真的有效……",
        "unit_id": 1111,
        "voice": "vo_adv_1030003_026"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "（更加激烈的咆哮）",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "嗚哇哇哇哇哇！",
        "unit_id": 1011,
        "voice": "vo_adv_1030003_027"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n果然還是沒有效啊啊啊！！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "什、什麼！",
        "unit_id": 103011,
        "voice": "vo_adv_1030003_028"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "總、總之，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "先逃的先贏是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "冒險者們一邊體驗到事先計劃果然很重要，\n一邊死命地從襲擊而來的魔物爪下逃走……"
    }
]