    {
        "type": "dialogue",
        "name": "旁白",
        "words": "滋滋……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "沙沙沙……"
    },
    {
        "type": "dialogue",
        "name": "偶然在場的居民",
