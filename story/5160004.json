[
    {
        "type": "background",
        "background": "502114"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從前夕祭典過了一晚，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "終於來到蛇祭當天──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n梅杜莎正一個人走在早晨的居住區之間。"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "……終於",
        "unit_id": 133611,
        "voice": "vo_adv_5160004_000"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "到了這一天呢。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "姊姊，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我會做到的。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n我一定會打倒涅妃‧涅羅，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "救出妳們。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哦，",
        "unit_id": 133212,
        "voice": "vo_adv_5160004_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼啦梅杜莎，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳起得真早。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n蛇祭是從下午才開始吧？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我看妳那樣子，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "似乎是緊張到沒能睡著呢。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "啊？",
        "unit_id": 133611,
        "voice": "vo_adv_5160004_002"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "那、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "那怎麼可能……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我是期待過頭，才太早醒來了而已！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是這樣嗎。",
        "unit_id": 133212,
        "voice": "vo_adv_5160004_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然參加者們",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都是一些強者，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但妳也很強不是嗎？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不用著急，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "去發揮妳平常的實力就好了。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "就說我沒有在緊張了嘛！",
        "unit_id": 133611,
        "voice": "vo_adv_5160004_004"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "畢竟",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我會奪冠這點已經是確定了的。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我思考的是奪冠之後，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "有關涅妃‧涅羅的事。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……",
        "unit_id": 133212,
        "voice": "vo_adv_5160004_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣啊。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n雖然咲戀他們",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "回蘭德索爾了，沒辦法觀戰，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但作為代替，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我會連他們的分一起替妳加油的！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我是不需要被加油啦……",
        "unit_id": 133611,
        "voice": "vo_adv_5160004_006"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "不過，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "畢竟我也稍微有受妳一點照顧，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "就讓妳看看我華麗勝出",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "的樣子吧。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "啊啊！",
        "unit_id": 51611,
        "voice": "vo_adv_5160004_007"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "莫妮卡小姐～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n不好了，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "大事不妙了～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "米亞？",
        "unit_id": 133212,
        "voice": "vo_adv_5160004_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼啦，那麼慌張……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "該不會是",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "蛇祭參加者在失控搗亂吧？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "不，",
        "unit_id": 51611,
        "voice": "vo_adv_5160004_009"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "情況反過來～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "參加者",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "全部不見了！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "全、",
        "unit_id": 133212,
        "voice": "vo_adv_5160004_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "全部！？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果是一兩個人還好說，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "居然是全部？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "一時之間讓人很難相信……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "就、",
        "unit_id": 51611,
        "voice": "vo_adv_5160004_011"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "就是說啊……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "他們都是充滿自信",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n從吉歐‧格黑納各地",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "前來參加的，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "實在難以想像他們會在比賽開始前放棄～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然如此，",
        "unit_id": 133212,
        "voice": "vo_adv_5160004_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "他們究竟",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是上哪去了？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然也可能是綁架，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但參加者全是強者，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要把他們所有人帶走，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n是無法辦到的吧。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有沒有",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼可疑之處呢？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "嗯～",
        "unit_id": 50811,
        "voice": "vo_adv_5160004_013"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "競技場有",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "留下宴會的痕跡，",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "\n卻、",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "卻沒有爭執",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "的痕跡啊。",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "首先，",
        "unit_id": 52111,
        "voice": "vo_adv_5160004_014"
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "血氣方剛的吉歐‧格黑納人",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "\n居然會毫不抵抗地被帶走，",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "正常來說是不可能的啦。",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "啊，",
        "unit_id": 50811,
        "voice": "vo_adv_5160004_015"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "要說可疑的話，",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "聽說",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "有人在半夜聽見了吹笛聲。",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "\n",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "前夜祭典也沒有準備笛子之類的，",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "要說可疑",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "是挺可疑的……",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "對了對了，",
        "unit_id": 51611,
        "voice": "vo_adv_5160004_016"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "一樣是昨天半夜，也有人說聽見了女人的大笑聲。",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n我自己",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "昨天帶著耳塞睡覺，所以沒注意到……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "不過那究竟是什麼呢？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "會是新型魔物之類的嗎～？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "大笑……",
        "unit_id": 133611,
        "voice": "vo_adv_5160004_017"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我說，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "莫妮卡？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，",
        "unit_id": 133212,
        "voice": "vo_adv_5160004_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也有相同想法。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n……前幾天",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那個暴露狂很可疑。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "暴露狂",
        "unit_id": 51611,
        "voice": "vo_adv_5160004_019"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "嗎……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "該不會",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "是華音小姐吧～？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "可是，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "雖然那個人身手不錯，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n還是難以想像她能贏過所有參加者……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "莫妮卡閣下──！",
        "unit_id": 711,
        "voice": "vo_adv_5160004_020"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "發現消失的參加者們的下落了──！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哦哦！",
        "unit_id": 133212,
        "voice": "vo_adv_5160004_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不愧是【王宮騎士團】！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
