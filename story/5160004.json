    {
        "type": "dialogue",
        "name": "華音",
        "words": "喔～",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呵呵！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團隊長",
        "words": "唔，",
        "unit_id": 712,
        "voice": "vo_adv_5160004_039"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團隊長",
        "words": "有妄想症的暴露狂真難應付……！",
