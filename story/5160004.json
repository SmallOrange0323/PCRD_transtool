    },
    {
        "type": "dialogue",
        "name": "偶然在場的觀光客",
        "words": "該不會是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "偶然在場的觀光客",
        "words": "這邊也要辦蛇祭了嗎！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "偶然在場的觀光客",
        "words": "\n我還以為我正在旅遊看不到了，真幸運！",
