        "voice": "vo_adv_5160004_037"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團隊長",
        "words": "你們",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團隊長",
        "words": "是吉歐‧格黑納的人對吧？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團隊長",
        "words": "\n我有聽說交流祭的事，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團隊長",
        "words": "\n但這麼大規模的活動可沒有獲得允許！",
