        "type": "dialogue",
        "name": "王宮騎士團隊長",
        "words": "\n總之現在立刻掉頭回去吧！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團隊長",
        "words": "否則……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "哎呀，",
        "unit_id": 134912,
        "voice": "vo_adv_5160004_040"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "從新年一開始就這麼熱衷在工作啊。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "等本小姐獲得這個國家後，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n可以讓你當管家來聽我使喚。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "不、",
        "unit_id": 134912,
        "voice": "vo_adv_5160004_041"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "過、",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呢，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "拿刀指向我的罪過，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "可絕非小事。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n我要你用自己的身體",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "好好贖罪。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "來，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "盡情聆聽吧！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "莊嚴的弄蛇之曲！",
        "unit_id": 134912
    },
