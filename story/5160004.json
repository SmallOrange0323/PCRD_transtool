        "type": "dialogue",
        "name": "偶然在場的居民",
        "words": "有、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "偶然在場的居民",
        "words": "有好大的蛇在城鎮裡……！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "偶然在場的居民",
        "words": "\n而且",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "偶然在場的居民",
