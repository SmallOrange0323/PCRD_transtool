[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人在進入露娜之塔後便不斷受到魔物的襲擊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是在靜流的活躍下，每次都輕鬆化解了危機。"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我是不會放過妨礙弟弟的壞人的！",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐手刀──！",
        "unit_id": 104911
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳叫做靜流是嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是厲害。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不帶一絲迷惘的精采劍法──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "更正，是手刀法才對。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n非常輕鬆就開通道路了呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要是為了保護{player}，",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐不管是化為惡魔還是邪神都在所不惜喔。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐力量全開，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看招♪",
        "unit_id": 104911
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "居然瞬間就擊潰了整群的魔物……",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看來妳說交給妳，並不是只在說大話。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這樣的話，就算是我這麼柔弱的人，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也能悠哉地在後方擺軍師的架子了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我軍所向無敵！",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n全軍進攻～！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呼哈哈～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "把所有人都殺了～！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟，你還好嗎？",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會不會累？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要不要休息一下？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "別對軍師的指令充耳不聞啊。",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不用擔心，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "他的體力沒有問題，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "他剛才自己也這麼說了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不如說他還生龍活虎到都不懂得看氣氛呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真的嗎？",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不可以勉強自己喔。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你如果是在顧慮某個學校的學姐，那就更該跟我說喔。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "別擔心，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐絕不會做不利於你的事情。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看來有個很危險的家長在呢……",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學姐我還是稍微安分點吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦？",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n優妮，妳怎麼了？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "怎麼突然用雙手堵住嘴巴了呢？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳應該不會對在學校霸凌學弟這件事，真的心裡有數吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "別這樣。",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n拜託妳別用充滿壓迫感的笑容來俯視人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，對喔！",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我個子高，很自然就……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對不起，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我以後會多注意的，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "優妮。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不必了，",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n妳不需要特地彎下腰來配合我的視線。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦咦～",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那我該怎麼辦……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n{player}，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是不是被優妮給討厭了呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "正是如此。",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "與楚楚可憐的外表相反，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就是個表面恭維又容易受人敬畏的人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不好意思，我是冷酷的優妮。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好可愛！",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐可以抱她嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "別這樣。",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "拜託妳別把和妳同年齡的才女抱起來舉高高。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可是{player}學弟，",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_017"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這不是很好嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我聽說你失去記憶，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "而且也沒有",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "家和家人，是孤獨一人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但你卻在不知不覺間和這麼棒的姐姐重逢了呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦！？",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "居然說我是很棒的姐姐！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "討厭啦，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "優妮真是的，別這麼老實說出來嘛♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "放心吧，",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_019"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是客套話。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n畢竟我們還沒熟識到",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓我足以評價靜流的為人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是我為{player}有姐姐這件事感到高興也是個事實。",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_020"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我回去家鄉的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是有幾個自稱是父親把我當家人的人，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但那些不過都是順勢而為的結果所產生的溫柔謊言。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就不客氣地直說了，",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_021"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我甚至覺得很羨慕。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n名為血緣關係的羈絆，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是我無論怎麼渴求都得不到的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……嗯？",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_022"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什麼，",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_023"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你說什麼？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是什麼意思？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐和{player}，",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n是超越血緣關係的命運之姐弟！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喔……",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_025"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這是你們沒有血緣關係",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "的意思……？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這麼說的話，",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_026"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你們的近親中有誰因為某種緣故而在戶籍上結為姻緣，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是像這類的嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒有，",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "並不是。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好難啊，",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這是怎麼回事……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "既沒有血緣關係，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也不是繼親關係。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也就是說，靜流",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳對{player}而言只是個外人──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我是他的姐姐！",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不對，",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_030"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但經過我整理情報之後，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "結果妳就只是個外人──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我是他命運中的姐姐！",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_031"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "…………",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_032"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "OK羅塞塔，",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_033"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "她到底在說些什麼？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～！",
        "unit_id": 1,
        "voice": "vo_adv_7015001_034"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n無法分析！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n不存在其他物證足以證明嫌疑人的供詞！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那種事根本沒有關係。",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_035"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐是打從心底就是他的姐姐呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "她是這麼說的……",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_036"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這又如何？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～！",
        "unit_id": 1,
        "voice": "vo_adv_7015001_037"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n偽證，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "又或是對方可能擁有認知功能上的障礙！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_038"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "她看起來不像在說謊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳看看她，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "她那對自己身為姐姐不存有一絲懷疑的姐姐眼神。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這麼一來，原因是後者啊……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "講白一點，",
        "unit_id": 1,
        "voice": "vo_adv_7015001_039"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "她是很可憐的人！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然不應該隨意去猜測他人的事情……",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_040"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但她或許有什麼複雜的背景，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n迫使她只能這麼對此深信不疑才能解決。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "連我這無機質都要哭了！",
        "unit_id": 1,
        "voice": "vo_adv_7015001_041"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "嗚哇啊啊──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "{player}學弟。",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_042"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我想你也很為難，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但你先暫時附和她的妄想吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你應該也差不多習慣該怎麼應付有點切嚕的人了吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然後是靜流。",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_043"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n好吧，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就暫時接受妳說",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n自己是姐姐的事情吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳就算一輩子都接受也沒關係呀，",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_044"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過謝謝妳，優妮。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐好高興。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯。",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_045"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n妳不需要急，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓我們慢慢來面對現實吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐會努力讓優妮",
        "unit_id": 104911,
        "voice": "vo_adv_7015001_046"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "遲早也能夠理解的！　",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我會努力讓靜流",
        "unit_id": 111011,
        "voice": "vo_adv_7015001_047"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "遲早能夠恢復正常的！　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人各自在內心中下定了與彼此完全相反的決心。"
    }
]