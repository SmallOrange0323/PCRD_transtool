[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "喂～！",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n嘻嘻",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "，最近很常見面呢♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，我又要運送木材到城鎮。",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "最近因為魔物作亂，損壞了房舍，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以為了修復房屋，需要的木材似乎就增加了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "連房屋都被破壞了，\n也就是魔物闖進了城鎮裡吧。",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "很可怕對吧～你沒事嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n有沒有撞見魔物？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？沒事吧？好擔心！",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你看起來也沒有很強壯，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n被魔物襲擊一定要立刻逃走哦？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大聲呼救說不定也行。\n要是我就在附近，就會去幫助你的。",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家雖然看起來這樣，不過還挺強的哦♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？哪裡？",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n好可怕！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "果然在城鎮外很不平靜呢～……？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯嗯？\n到處都沒有魔物啊？",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "難道說，你說的魔物是指我？",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n真沒禮貌！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然外表和普通人類有點不同。",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，人家才不是什麼魔物哦？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘻嘻，先不提這個……",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你今天也在做運送郵件的工作嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不是嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_011"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唔，因為城鎮外出現了大量魔物……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以在調查實際情形，如果可以就討伐魔物是吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "感覺是很不簡單的工作呢～辛苦了♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你真是勤勞呢。\n總覺得每次遇見你，都是在工作。",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "多玩玩、好好放鬆不也很好嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦，我也一樣？",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_013"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "說的也是～……不過我外表長這樣呢？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "進入城鎮會引起騷動，\n也不可能到遊樂場所閒晃呢～？",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_014"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "其實人家很想要去店裡逛逛衣服選些飾品，\n一面逛街一面吃甜點……",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過這種像普通女孩子會做的事，對我來說有點困難。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦，為什麼……嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你看",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "看我，外表就像是魔物對吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是進入城鎮，就會被警備士兵討伐哦～？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一輩子一次就好，真想試著約會看看。",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_017"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就像小栞常常看的少女漫畫……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n很羅曼蒂克，像個普通女孩子一樣。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？\n要幫忙我搬運木材嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然很高興你有那份心意。",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_019"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，以你的力氣，應該搬不動木材吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就連人家也得把木材擺到滑車上才搬得動。",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "非常重的哦～？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "而且……你也有",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n自己的工作對吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "調查魔物，還有討伐啊…",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_022"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "…",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n要是進行得不順利，把我當成魔物制伏也行哦？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呵呵呵，開玩笑的。",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_023"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，{player}不可能做出那麼殘忍的事情對吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "畢竟面對人家還能還無顧慮地搭話，\n是個待人溫柔的男孩子呢。",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_024"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的就像少女漫畫裡的男主角一樣。",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_025"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不過",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "，就是因為這樣……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n請你",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不要把人家當成怪物，而是普通的女孩子來對待哦。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哦唷。不能繼續站在這裡閒聊了，",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_026"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我得走了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n要是不快點把木材運送到指定的地方，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就會和前去收貨的人碰上的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣就會嚇到他們呢……",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "再見囉。\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052002_028"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能和你聊天很開心，你也要努力工作哦！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "掰掰～再見囉♪",
        "unit_id": 105211
    }
]