        "type": "dialogue",
        "name": "店長",
        "words": "\n話說",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "妳的家人似乎也過來了呢，",
        "unit_id": 1411
    },
