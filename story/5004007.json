        "words": "來，",
        "unit_id": 107611,
        "voice": "vo_adv_5004007_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人您也嘗嘗……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊～♪",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
