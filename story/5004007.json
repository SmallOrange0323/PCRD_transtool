    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下來吹吹吧，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼♪",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該死，",
        "unit_id": 107811,
        "voice": "vo_adv_5004007_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我又吃到怪異料理啦～！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我說過好幾遍了吧，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我從生理上就排斥食用魔物了啊！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不行不行，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我突然覺得噁心反胃了……！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_041"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "還是乖乖地把它吃下去吧，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "凱留小姐。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "高等的魔物",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "含有大量能量，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n您剛好",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "可以補足大量消耗掉的魔力哦。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦！？",
        "unit_id": 107811,
        "voice": "vo_adv_5004007_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "花凜，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是妳～！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，",
        "unit_id": 107811,
        "voice": "vo_adv_5004007_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳一定知道什麼隱情對吧！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這次的旅遊我怎麼想都覺得不對勁，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明是海水浴場旺季，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但除了我們海邊一個人也沒有啊！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我已經聽說了此處有危險魔物的出沒，",
        "unit_id": 107811,
        "voice": "vo_adv_5004007_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "禁止下水游泳的事情了！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這樣妳居然還敢招待我們，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們才被搞得落到這副田地！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都是妳一手策劃的對吧，",
        "unit_id": 107811,
        "voice": "vo_adv_5004007_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這一切！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是想把我們丟進修羅場，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓我們去解決這個大問題吧！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n絕、",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對是這樣！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　之前好像也是這樣來著……！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_046"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n這就任憑各位想像了♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不過，",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_047"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們身為【公會管理協會】……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n對那些完全不做有意義的活動，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "成天只會拿補助的費用去吃吃喝喝的公會，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我們是無法置之不理的。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "偶爾也必須要讓他們幹點活～",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_048"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "才行。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不過呢這次是",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "出乎意料地變成相當危險的狀況，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n這方面我們還是要好好反省的。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "作為諸位這次，",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_049"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "漂亮解決瑪爾傑海岸異變的獎勵……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n目前",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "【美食殿堂】依然是受到認可的公認公會，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我們會繼續提供補助金。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "再來，我們額外再奉送一些優惠。",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_050"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n真正的",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「迷人的南國之旅」，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n度假區免費招待券♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊！",
        "unit_id": 107811,
        "voice": "vo_adv_5004007_051"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "果然是這樣！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真正的「迷人的南國之旅」的舉辦地，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n根本不是在瑪爾傑海岸對吧？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這裡分明就還是在本國啊，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "之前就覺得奇怪了！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_052"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "還有，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們也為貪吃佩可小姐準備了一份禮物哦。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　這是",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼呢……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n和我戴在頭上的髮飾一模一樣耶？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是的。",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_054"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "雖然長得一模一樣，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n不過這是有得到特別的神靈庇護的東西。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有了這個東西的加持，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所有力量應該都會被強化的。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就算穿著泳裝，",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_055"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "應該還是可以稍微戰鬥。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這次是",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「皇家裝備」遺失是吧……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們得知裝備遺失，G",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n造成您相當大的困擾。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們也認為要是再碰上同樣的狀況就麻煩了，",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_056"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n這是我們思考了該如何才能在身穿泳裝",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "的狀況下也能作戰，所得出來的方式。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "也算是表示對這次，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "你們相當努力的讚賞。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇，",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是幫大忙了。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不然這次真的是一直在拖大家的後腿，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺心裡好難受啊～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_058"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "真是一場災難呢～",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n那隻盤踞在海底遺跡的魔物，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "會利用牠的手下",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "去搜刮貴重金屬，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n或是人類等較有價值的東西，納為己有。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「皇家裝備」之所以會被盜走，",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_059"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n或者可可蘿會被擄走都是這個原因導致的吧。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n附近一帶的船舶也是經常遭到襲擊，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "漁獲量因此而大減。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "真的，",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_060"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就是一場大災難的感覺呢。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n魔物就是為人類帶來禍害的生物總稱，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n讓我不禁想起",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那在字典上的定義。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "最近，",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_061"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "各地似乎都有魔物活躍的跡象……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n恐怕再過不久，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n人類社會就會發生",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "傷亡慘重的災難也說不定。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "到時候恐怕就要和這次一樣，",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_062"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n需要再度麻煩各位解決。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "屆時，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就有勞各位幫忙了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳給我等一下，",
        "unit_id": 107811,
        "voice": "vo_adv_5004007_063"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳剛才是不是說了「這次」？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n花凜～",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會下次妳又要讓我們去搞定類似的事情了吧！？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_064"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那就要看各位，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "今後的活動表現而定了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我們是不會去刁難那些平時勤奮努力、",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n表現認真的公會的。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼接下來，",
        "unit_id": 190811,
        "voice": "vo_adv_5004007_065"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我還有一些待處理的業務……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "先走一步了哦♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 107811,
        "voice": "vo_adv_5004007_066"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "站住！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　別想逃啊！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可惡，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "下次再讓我碰到絕不饒她，那個該死的眼鏡女……！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "算了算了啦……",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_067"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "花凜可能也是",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為身為【公會管理協會】的職員，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無可奈何才出此下策吧。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家現在都平安無事的不是很好嗎。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那只是結果論啊！",
        "unit_id": 107811,
        "voice": "vo_adv_5004007_068"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n啊真是弄得亂七八糟的，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了我要大吃特吃了！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n喂店長，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "除了魔物以外的魚",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都給我烤起來！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "好、",
        "unit_id": 1411,
        "voice": "vo_adv_5004007_069"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "好的！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "樂意之至……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_5004007_070"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只要結尾好",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就一切都好……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是指這麼一回事呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位。",
        "unit_id": 107611,
        "voice": "vo_adv_5004007_071"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n再一次，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感謝諸位",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "救了在下。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像這樣",
        "unit_id": 107611,
        "voice": "vo_adv_5004007_072"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家圍著餐桌聚在一起，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對在下來說",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是無上的快樂了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對呀。",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_073"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……妳能平安無事的真是太好了，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是說啊～。",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_074"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說到底還不是小可蘿，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了讓{player}逃生，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n居然犧牲了自己而被擄走。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我覺得妳這麼做，",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_075"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}也不會高興的。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳應該更珍惜妳自己才對啊，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_076"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都是非常珍惜妳，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喜歡妳的。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白了……",
        "unit_id": 107611,
        "voice": "vo_adv_5004007_077"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的很對不起各位。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀，",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_078"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "搞得像是在說教一樣。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
