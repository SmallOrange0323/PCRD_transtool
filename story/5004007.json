    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，{player}一行人安然無恙地從海底遺跡逃脫出來了。\n當時剛好也是午餐時間，\n大家便開開心心地在海邊烤肉順便慶功。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要開動～囉☆",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會盡量串盡量烤的，",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n喜歡的大家就盡量拿吧！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且這一頓",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "居然不用錢哦，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n走路路過不要錯過，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "盡情地吃吧～♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "啊，",
        "unit_id": 1411,
        "voice": "vo_adv_5004007_003"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "但飲料要另外計費的！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "如此",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "盛況空前，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這下有得忙囉……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這位大叔",
        "unit_id": 107811,
        "voice": "vo_adv_5004007_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是誰啊？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n怎麼突然和我們算起帳來了……？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哈哈。",
        "unit_id": 107711,
        "voice": "vo_adv_5004007_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這位是",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "聘我來海之家短期打工的",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "店長先生。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 107611,
        "voice": "vo_adv_5004007_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鈴莓小姐",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在海之家打工啊。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您工作",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "辛苦了。",
