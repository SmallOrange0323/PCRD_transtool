        "type": "dialogue",
        "name": "店長",
        "words": "嗯，",
        "unit_id": 1411,
        "voice": "vo_adv_5004007_013"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "鈴莓妳就好好休息吧。",
        "unit_id": 1411
    },
