    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要是在最後一刻冒失地跌了一跤受重傷的話",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就太糟糕了，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "感覺像付出的辛勞全都變成放水流了一樣。",
        "unit_id": 107711
    },
