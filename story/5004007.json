    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哪裡哪裡～",
        "unit_id": 107711,
        "voice": "vo_adv_5004007_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n各位才是經歷了一場大冒險，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "相當勞累了吧，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請各位好好休息，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "多吃一點來補充營養吧。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還請各位",
        "unit_id": 107711,
        "voice": "vo_adv_5004007_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "盡情享用！",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然我",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不是很擅長料理，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不過只是串起來然後拿去烤的話",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也很難失敗吧♪",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇，",
        "unit_id": 107711,
        "voice": "vo_adv_5004007_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唉唷……",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀啊啊啊！？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔哇，",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是請妳小心一點吧！？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是頭撞上碰過火的金屬網和鐵板的話可就悲劇了，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n會受重傷的！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿……",
        "unit_id": 107711,
        "voice": "vo_adv_5004007_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不好意思，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "看來我的魔力和體力似乎也消耗得差不多了。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "暈頭轉向的～",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我還是別到處亂走好了。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難得大家都平安無事，",
        "unit_id": 107711,
        "voice": "vo_adv_5004007_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還是畫下一個完美的句點吧。",
        "unit_id": 107711
