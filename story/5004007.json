    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "海底遺跡的魔物被驅除了之後，",
        "unit_id": 1411,
        "voice": "vo_adv_5004007_027"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n變得安全多了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "人潮都開始增加……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "照這情況看來",
        "unit_id": 1411,
        "voice": "vo_adv_5004007_028"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "能轉虧為盈，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n我們家也就不用過著縮衣節食的生活了啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這都是你們的功勞。",
        "unit_id": 1411,
        "voice": "vo_adv_5004007_029"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n真的很謝謝你們！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n你們真是我的……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是瑪爾傑海岸的救世主啊。",
        "unit_id": 1411
    },
    {
        "type": "still",
        "still": "500400703"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不用客氣啦～",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n欸嘿嘿，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然碰上了許多插曲，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但感覺是個不錯的結局呢♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我把打倒的魔物作為食材都帶回來了，",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "切開來後一看……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n魔物的肚子裡，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n除了皇冠之外的「皇家裝備」也都好好地躺在裡頭。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是我非常重要的東西，",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有變成海裡的碎藻泥垢真是太好了。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 107811,
        "voice": "vo_adv_5004007_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　欸，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "剛才那些串在一起烤肉的東西，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n難道都是魔物的肉嗎？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那隻被我們打倒的，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "長了好幾根觸手的傢伙？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的！",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　然後",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在海底遺跡探索所遭遇到一併打倒的",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n魔物小嘍囉們也都一起……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟棄置一旁任其腐爛也是浪費嘛，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "索性也一起吃了吧♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不做沒益處的殺生，",
        "unit_id": 107511,
        "voice": "vo_adv_5004007_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把擊殺的魔物吃得乾乾淨淨！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這便是我們【美食殿堂】的作風啊……☆",
        "unit_id": 107511
    },
    {
        "type": "still",
        "still": "500400704"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呸、",
        "unit_id": 107811,
        "voice": "vo_adv_5004007_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呸，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種事妳早點說啊！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n唔哇，那些噁心的魔物肉，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道我都吞下肚了……！？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_5004007_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您不需要吐出來的，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "挺美味的啊。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "經過適當的處理，",
        "unit_id": 107611,
        "voice": "vo_adv_5004007_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也用了魔法解析",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "證明了無毒，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是相當安全的肉。",
        "unit_id": 107611
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
