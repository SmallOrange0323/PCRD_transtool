[
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該不會這樣才對……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不對，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "果然是這樣吧……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只能問問本人了……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "吶，",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我確認一下。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我啊，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該沒有被你",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "求婚過吧？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "果然是這樣對吧！？",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但是，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果這樣的話，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們為什麼已經締結婚約了呢？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼，",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就這樣做好了。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n現在開始，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你重新跟我求婚。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然順序顛倒了，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但這種時候我就睜一隻眼閉一隻眼吧。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……因為不知道怎麼求婚，",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以想看我示範！？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所謂的求婚，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不是邊看示範邊做的事吧……？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "求婚這種事，",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也沒做過啊……！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總而言之，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "類似戀愛小說的台詞那種感覺就行了吧！？　",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那就……",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咳咳！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n今、",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "今天，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "月色真美呢？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "剛剛的話當我沒說。",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n果然，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要用自己的話傳達比較好呢。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……咳咳！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我，",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會一直愛著你。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "無盡的",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "慈悲心、",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不屈不撓的",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "堅毅勇氣，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在我們一起度過的時光中，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你向我證明了無數次。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真實的愛，",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "與身分無關，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也與財富無關，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n而是透過這個樣子",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來實踐的。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你讓我打從心底如此確信。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還請你與我",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一起度過接下來的人生。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n請讓我",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "作為你的伴侶，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "陪伴在你靈魂左右。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果你能答應，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我發誓會永遠愛著你，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "直到死亡將我們分離。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……呵呵♪",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n像這樣",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "正式說出口，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總覺得心臟都開始砰砰跳了呢。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我說……",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要不要就這樣",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再繼續一下……？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不只是言語，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也想要",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱抱你。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你……",
        "unit_id": 127512,
        "voice": "vo_adv_5128075_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我可以",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再抱緊你一點嗎……？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……真的好愛你，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "最喜歡你了。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，兩人彼此相擁，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n直到心滿意足為止。"
    }
]