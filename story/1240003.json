    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}受到茜里要求，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n要跟她約會當作先前演奏會努力的獎勵。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n到了當天，茜里有點晚到約好碰面的地方。"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "──呼、",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呼……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯、",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "讓、",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "讓你久等了……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "昨天興奮到睡不著，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n所以有點睡過頭了。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "來、",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "來嘛哥哥，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們這可是獎勵約會。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所以請再跟茜里靠緊一點♪",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "比平常還要緊貼對方──",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦……",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊、",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊哈哈。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n因為茜里",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "一直很期待",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "今天的約會……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n嗯、",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可能因為這樣身體才會發燙♪",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……而且那個，",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里是一路跑到這裡來的……\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所、",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所以才會",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "流滿身汗──",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呀！？",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……哥、",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不可以……！",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n不、",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不能突然摸女孩子的臉……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呀！",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不可以摩擦",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "額頭啦……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n被你這樣摸的話，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里會──",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗚……",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "才、",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "才沒那回事。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n雖然茜里今天，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "精神可能有點不太好沒錯……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但那是因為",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "前陣子的祕密特訓……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n所以才覺得有點疲倦而已。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這、",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這種程度，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對茜里來說完全不要緊的。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我們快去約會吧？",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好嗎？",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥──",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "怎麼這樣……",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不去！",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n因為茜里",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "一直很期待今天的約會。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里連衣服都洗得很乾淨，",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n還洗了好幾次澡，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "做了很多準備的說……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……茜、",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里知道了。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不過，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就只休息一下下而已喔！",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "然後等茜里恢復精神了，",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "請再繼續",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "跟茜里約會。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……拜託你了，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥──",
        "unit_id": 124012
    },
    {
        "type": "background",
        "background": "500950"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}安撫茜里，讓她躺在床上睡覺。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}姑且先聯絡了依里，請她把照顧病人的東西送來，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然後回到了旅館房間。"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "──啊……",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "歡迎回來。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦？",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊呢……？",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這、",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這樣啊……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥手上拿的，",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "都是照顧病人需要的東西……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這些一定是姊姊幫忙送過來的吧？　",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗚嗚，",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "還讓姊姊擔心了……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這都要怪",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里太勉強自己，把身體搞垮了──",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "──真、",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真是",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "的，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥跟姊姊都太愛操心了啦。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你看茜里",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "已經這麼有精神了……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我說，",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_019"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們回去約會吧？",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "有好多地方想去呢。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就連約會行程，",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "都已經先在紙上寫好了喔。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你看，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥想去哪裡呀？",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "唔……",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥、",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥是笨蛋！",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "大笨蛋！",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不理你了……！",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "………………",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_022"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n嗚嗚……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……不要。",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_023"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就是不想脫掉這件衣服。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好不容易出來約會，",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "要是連這件衣服也脫掉的話……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗚嗚……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就不再是約會了……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……哥、",
