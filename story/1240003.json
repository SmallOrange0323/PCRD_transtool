        "voice": "vo_adv_1240003_025"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥你",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒有做錯，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "任何事……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……對不起……",
        "unit_id": 124012,
        "voice": "vo_adv_1240003_026"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里",
        "unit_id": 124012
    },
