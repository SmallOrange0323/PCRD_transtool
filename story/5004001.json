[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【美食殿堂】的大家依照計畫參加了「迷人的南國之旅」，並在第一天充分地享受了在海邊的玩樂。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "眾人玩到精疲力盡幾乎動彈不得，\n回到訂好的度假小屋裡去悠閒地休息。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「迷人的南國之旅」為期四天三夜，\n誰都以為歡樂的時光會一直持續下去。\n但沒想到，隔天早上竟然發生了怪事……"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，真是的～……",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n全身肌肉都在痠痛。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "昨天",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "玩得太過頭了啦。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n過度使用平時沒有在用的肌肉，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n玩水玩得太開心，又不小心玩到體力透支了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再加上貪吃佩可那傢伙又不讓我好好睡覺，",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n根本沒怎麼休息到嘛……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n四天三夜的行程，怎麼才到第二天就一整個累翻了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔～",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是不是該用魔法來恢復體力呢。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但昨天魔法的使用量也是比想像中的大啊……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n感覺魔力都要枯竭了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明體力和魔力都是有限的，",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "卻在第一天就消耗過量了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，至少算是舒服的疲勞感……",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然和合得來的夥伴們愉快地玩耍，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也賺不了錢。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是，感覺好幸福啊。",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n欸嘿嘿♪",
        "unit_id": 107811
    },
    {
        "type": "still",
        "still": "500400101"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要發球了唷～",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人♪",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼在下就把沙灘排球……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉呀？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n怎麼了嗎……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉呀？",
        "unit_id": 107611
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐！",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n早安♪",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，早安啊。",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們一大清早的精神可真好呢～",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "已經玩起來了？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。昨晚睡得很熟，",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在精力充沛。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一想到今天也……",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能在海邊玩一整天，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就興奮得",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "坐立難安。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下和主人為了醒腦一起來海邊散步，",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺非常開心……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回過神來，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經玩起了自備的沙灘排球了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還蠻愉快的哦，",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐也一起來玩嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不用了～我現在整個身心俱疲的，",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n原本就不太能早起了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是一早就劇烈活動，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺馬上就會貧血發作而不支倒地的。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐體能不佳，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要不要多鍛鍊一下身體呢？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我沒關係，魔法師的體力不好也沒差……",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真是的，你們兩個的肌膚也太亮麗了吧。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看來，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "昨天是真的睡得挺好的呢？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真好真好。",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n房間分配就是我和貪吃佩可同一間，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可蘿仔和{player}同一間。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們雖然看上去就像一家人一樣，",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過成年男女兩人同在一個屋簷下的～……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n感覺很讓人容易誤會，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總讓人有些擔心呢？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔嗯。",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您說的誤會，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是指……？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來。",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐似乎有點睡眠不足的樣子，眼睛都腫腫的。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，看出來啦？",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是～啊，不知道是怎麼的，半夜貪吃佩可因為惡夢而呻吟……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還以為能睡了結果又被她吵醒，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拜託饒了我吧。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在那之後，那傢伙又跑來找我講話，根本不讓我休息。",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還像個做惡夢的幼稚園小朋友似的，硬要鑽進人家的床上一起睡，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我光要把她踢下床去就忙死我了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊哈哈……",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然不是很了解狀況，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但跟她睡同張床不行嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才不要。",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那傢伙一股蠻勁的，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是睡迷糊把我脖子擰斷，我不就完蛋了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　不過",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙力量會這麼大，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n應該是因為受到「皇家裝備」強化的緣故吧……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "昨夜是穿著睡衣，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或許可以不用那麼警戒？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我太想睡了，",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "居然完全沒想到這一點。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「皇家裝備」……",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就是那個貪吃佩可小姐一直戴在身上，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n長得像王冠的透明頭飾或",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "墊肩之類的配件總稱嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是多虧了那些東西，貪吃佩可小姐才能發揮出無與倫比的戰鬥力吧。",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n……也就是說昨天一直穿著泳裝的貪吃佩可小姐，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有可能處在相當脆弱的狀態下呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為穿著泳裝，沒有辦法把「皇家裝備」戴在身上的緣故吧。",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回想起來，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "昨天看她不僅動作遲鈍，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還馬上就累得跑去休息的樣子。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為言行舉止跟以往一樣有朝氣，",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以完全沒有察覺到。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，這樣說起來……",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「皇家裝備」可說是那傢伙的生命線了吧，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n難道這次的旅行都不打算穿了嗎。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……那傢伙，該不會是旅遊太開心而鬆懈了吧。",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在要是誰趁這時候來索命的話，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不就要陷入大危機了嗎。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下認為，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該沒那麼容易就被人盯上性命吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……咦？",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎、怎麼了，可蘿仔？",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不……",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然可能只是錯覺，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下剛才感受到海中",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "傳來怪異的氣息呢？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔～",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是睡迷糊了嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看上去，",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海還是",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和昨天一樣平靜。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而且瑪爾傑海岸……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "特別是淺灘處，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n聽說是個鮮少",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "目擊魔物，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相當安穩的地方。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯……",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果在意的話，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可以憑藉探測魔法在海中調查看看？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，不需要到這個地步……",
        "unit_id": 107611,
        "voice": "vo_adv_5004001_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐昨天，用了這麼多魔法應該相當累了吧？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n今天就不要浪費魔法了，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您儘量地恢復魔力。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過魔力基本上是靠睡眠或是進食就能恢復的，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我是想來吃點早餐",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "補充營養呢。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然有點不好意思……能請你們到我的渡假小屋去，",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n幫我叫醒貪吃佩可嗎？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我到附近走走順便消除一下睡意，",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n再找間能夠用餐的地方。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "海之家",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個時間應該也還沒營業，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n最糟的情況可能就只能",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "回城鎮上找餐廳了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～啊，",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "早知道會遇到這種事",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就自備一點食材過來了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我以為是會有豪華料理招待的優雅假期，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就沒有做什麼準備了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……咦？",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想說怎麼沒有反應……",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可蘿仔？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}？　你們跑哪兒去了？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦……？　怎、怎麼回事？",
        "unit_id": 107811,
        "voice": "vo_adv_5004001_049"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n才一離開視線，這兩個人就不見蹤影了？",
        "unit_id": 107811
    }
]