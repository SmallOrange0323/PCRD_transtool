[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哼哼哼～……♪",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n打掃，打～掃♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n啦、啦啦啦……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呼，非常完美！",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然我做其他家事時很冒失，但唯有打掃我可是很拿手呢♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐～鈴莓不是「沒用的孩子」對吧……☆",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這棟【咲戀育幼院】的建築也是，",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n明明一開始跟廢棄房屋一樣……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但總算是整理到能夠生活的程度了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是的……",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n因為大小姐很吝嗇，找了間便宜的房子，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可苦了我呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐以低價購買了原定要拆除的建築。",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n因為屋內到處破爛不堪，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "光是打掃和修繕，就費了不少力氣。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐的雙親及曾經待過的【王宮騎士團】，",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n也有許多原因所以很難依靠他們……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是她也沒有必要特地將重擔背負在自己身上啊。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過，這就是大小姐的性格。",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我會尊重她，就算只有我，也會全力支持的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會努力的～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "加油加油♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖是這麼說，因為育幼院的建築相當寬敞……",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n很多地方都還沒有著手整理呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過孩子們的房間和大廳已經趕忙打掃完畢了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "其他房間和走道等，",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n一處處依序整理的話……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "照這個情況來看是永遠整理不完呢。",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為剛打掃完又會被孩子們弄髒。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也會因為冒失而搞得一團亂，或是把東西弄壞呢～。",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然我也想把建築外牆、屋頂和庭院打理乾淨。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是只有我一個人忙不過來呢，",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n有種人手完全不足的感覺。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖是這麼說，我覺得讓孩子們幫忙也不太好。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，我想到好點子了！",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難得我會使用魔法……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只要有效地利用魔法做家事不就好了？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然我不太擅長魔法，",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n只是被父母強迫學習而已。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但身為女僕，就是要使出渾身解數來服侍主人☆",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我想想？",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我記得似乎有打掃的魔法……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然記憶有點模糊，我就來試試那個吧♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿噫，變乾淨吧……☆",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哈哇……！？",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦、咦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "眼前的牆壁被轟飛了，好奇怪啊？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難道我剛剛唸的是攻擊魔法……！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，這麼說來？",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n剛剛的是「將弱小魔物一次清除的魔法」……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我只記得「清除」的部分，",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n原來這不是做家事的魔法啊？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚啊啊，我又搞砸了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，難道是我想要用魔法來輕鬆解決反而遭到報應了？",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "笨蛋笨蛋，我是笨蛋……！　",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "該該該、該怎麼辦！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我把建築的牆壁弄壞了！",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "竟然犯這種錯，我無顏見大小姐！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、我只能切腹謝罪……！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "爸媽，對不起，我是個不孝的女兒！",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我先走一步了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "祝大小姐將來幸福……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿噫☆",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯？",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n咦，不會痛！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n為什麼？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，為了切腹而拿出的菜刀，",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n好像被誰奪走了……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀？",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那個，請問你是哪位？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "來、來這裡有什麼事嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我隸屬於【咲戀育幼院】，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我叫鈴莓。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "正確來說，我服侍著管理育幼院的人，",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n是個身分低微的女僕。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你叫{player}呀。\n對不起，對客人你招待不周……",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如你所見，我有點忙。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇？啊，對不起！",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我才在想你為什麼會是這副焦黑的模樣～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n難道是被我的攻擊魔法直接命中嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不只轟飛牆壁，還害路人受傷～！？",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n哇，我更加感到抱歉了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我沒有資格選擇切腹這種有尊嚴的死法！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只能用攻擊魔法轟飛自己的頭來負責了……！",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "現現現、",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "現在可不是冷靜下來的時候啊！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果我不馬上負責的話……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯？",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_032"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，這是什麼意思？\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我不是很懂！",
