    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唔～是這樣沒錯呢。",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我好像有點理解",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}想表達什麼了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就算我死了，也沒有人會開心。",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n只有我自己解脫是不對的呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總之，",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我先打掃被轟飛的牆壁殘骸吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好好把該做的事做好後……",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我再不留麻煩地切腹吧♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，不能切腹嗎？",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那、那自斬手指……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那樣也不行嗎？",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是，我不知道其他負責任的方法……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但現在是【咲戀育幼院】",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n剛成立不久的重要時期……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就算是我，只要活著也許還能派上用場。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我要活著拼命工作來負責。",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_040"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個，這樣可以嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀？",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你要幫我整理善後？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個，{player}？",
        "unit_id": 102511,
        "voice": "vo_adv_1025001_042"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n為什麼要對我這麼親切呢……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯，算了，畢竟我也得救了。",
