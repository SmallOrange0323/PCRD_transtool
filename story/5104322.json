    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "敵人的外層太硬了，",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n很難對它造成傷害！",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "茉莉，",
        "unit_id": 123811,
        "voice": "vo_adv_5104322_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我來告訴妳一件好事吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所謂的戰鬥，並不是只有老實地從正面迎戰這種方式。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓敵人行動遲緩、",
        "unit_id": 123811,
        "voice": "vo_adv_5104322_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "削弱其防禦……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "用盡所有能用的手段來戰鬥吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不論如何訴說自身的正義，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一旦沒有足夠力量就什麼都辦不到。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "的確是這樣沒錯呢。",
        "unit_id": 123911,
        "voice": "vo_adv_5104322_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "現在就先同心協力，",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "確實地削弱敵人的體力吧！",
        "unit_id": 123911
    }
