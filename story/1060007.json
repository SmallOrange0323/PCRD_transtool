[
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂～等等我啊？",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n到底要走到哪啊，我的腳開始痛啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼啊，這個陰森森的地方……",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你帶我到這個沒有什麼人煙的地方，到底想幹嘛？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n喂、你啊～？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（嗯～……因為有變態出沒在神秘森林，",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n害我也不想再靠近那裡。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以要找替代的練習場所。）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（這傢伙說自己有些想法，",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以我暫且就先這麼跟過來了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是我太疏忽了嗎？）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（該不會，這傢伙發現了我的真實身份，",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以設計把我拐到其他人看不到的地方，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n打算偷偷地把我解決掉嗎？）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（是這樣吧？",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n歸根究底，我跟你是敵對關係啊？）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（好啊，要來我就奉陪到底啊！",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我本來就想說，這樣的日子總有一天會到來啦！）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（才怪～……",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不可能吧，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟是這傢伙啊。）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（相反地，這傢伙可是老好人，好到幾乎要讓我擔心了。",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是太沈默寡言了，讓我不知道他在想什麼？）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "歡迎光臨～！",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_009"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n歡迎來到第二十四屆怪獸大賽會場☆",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦……？",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，你是之前的那個變態！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "哦哦，你是上次罵得我心情舒爽的美少女！",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_011"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n請再罵我吧！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗄？",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "開什麼玩笑啊，為什麼你沒有被抓走啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n變態就該被關進監獄啊，死了算了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "謝謝您☆",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_013"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "總之！",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_014"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n我雖然被抓了，但由於是初犯，所以馬上就被釋放了！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "現在，我已經洗心革面……",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_015"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n在這裡做著零碎的生意！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你永遠吃牢飯就好了……做什麼生意啊，",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反～正是變態中的變態為了變態所做的噁心犯罪吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被繩之以法就好啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "才沒這回事呢！",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_017"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n這可是正經生意喔，讓魔物們互相競爭，然後去猜測輸贏",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n的賭博場呢。像是賽馬那樣喔？",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "我的老家，代代都在經營政府公認的賭場。",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_018"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n只是，最近這附近魔物都變得很凶惡呢。",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n要捕獲跟調教牠們，可說是越來越辛苦了。",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "不過，女王大人不是能操控魔物嗎？",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_019"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n所以我想要將那樣的工作委託於妳，",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n才把妳請到這裡的喔……！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，『女王大人』是說我嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為、為什麼你會知道我作為『公主騎士』的權能啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你在哪裡查到的？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "是的！",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_021"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n我向這個人聽說了！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，你幹嘛跟變態變成朋友啊？",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊……幾天前，我曾在這傢伙面前，",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不小心將這件事說出口了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～魔物的捕獲跟調教嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "確實，作為操控魔物的練習說不定挺合適的。",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "先說喔！在操控魔物的時候，我可是連指尖都動不了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以當騎手什麼的是不可能的喔？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "沒問題，我有僱用專門的騎手。",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_025"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n就算如此，這生意也意外地賺錢喔～",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "大家都喜歡賭博嘛……",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_026"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n只是，再這樣下去這門生意就要垮掉了。",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "所以！",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_027"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n請您務必跟我們簽約，幫忙調教魔物等事情！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～有變態在的職場真討厭……",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過我剛好在找練習場所，如果是偶爾的話就OK。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟陛下完全不會給我零用錢，而我也想要有收入呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "那就契約成立囉！",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_029"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n請多多指教，那麼請馬上調教我☆",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你不是魔物吧？",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只是裝作魔物的變態而已吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的～感覺不三不四的。",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之先謝謝你啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n多虧了你，我不僅練習場所，連工作都有啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你啊，幹嘛對我這麼好啊？",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔……",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你真是個好人呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（陛下為什麼要對這樣無害的老好人……",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，雖然我也只是遵從陛下而已。）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（但是我不得不背叛",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如此親切對待我的人呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真討厭呢……光只是想，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就讓我感到鬱卒啦。）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們什麼時候變成朋友啦。",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n喂，你太親近我囉？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不是不行呢……",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我也一直想要同年齡層的朋友呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "哎呀，下場比賽要開始了！",
        "unit_id": 1614,
        "voice": "vo_adv_1060007_038"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n工作內容之類的說明就稍後再進行了，",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n可以的話，你們兩人也請盡情享受喔♪",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……就這樣。",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，怎～麼辦？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們去看比賽吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你也是特地陪我一起來……",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我也不希望你認為跟我在一起度過是很浪費時間，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n嗯～所以希望你也能適度享受。",
        "unit_id": 106012
    },
    {
        "type": "still",
        "still": "106000701"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你看，好像也有攤販之類的喔。",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我請你些什麼吧，就當作這一切的回禮。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣就扯平囉～？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好啦，我們走吧。",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒想到人群這麼擁擠呢～？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要不要牽手以防走散？",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是，我們並沒有那麼熟嗎……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦，你看你看！",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好厲害，是真的是魔物在比賽啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說不定出乎意料地有趣～真刺激♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我走太久，腳在痛了……",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們找個位子坐下來，悠閒地觀戰吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊……你去攤販那裡買了鯛魚燒來了呢。",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你還真是出乎意料地迅速呢～？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也非～常喜歡鯛魚燒。",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也讓我嚐一口吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈。",
        "unit_id": 106012,
        "voice": "vo_adv_1060007_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總覺得我們有點像在約會呢……♪",
        "unit_id": 106012
    }
]