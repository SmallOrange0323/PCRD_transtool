[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "高聳入雲的露娜之塔的面前一角──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一名少女雙手抱著玩偶，形單影隻地站著。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "初次見面日安我叫做碧……",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "初次見面日安我叫做碧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "初次見面日安我叫做碧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……好、",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我能完整說清楚了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這下就算緊張到腦海一片空白也沒問題呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "畢竟今天可是",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "和團長的熟人見面的日子……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "當然，",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我也很明白奢望跟對方成為朋友",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n是多麼厚顏無恥的事……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "──但是，",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "即便如此！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "至少",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我想活用在BB團累積的經驗，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "和那位小姐……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「露娜」",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "變得要好！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好朋友號！",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n除了打招呼之外，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還有什麼要注意的事情嗎！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "…………",
        "unit_id": 7211,
        "voice": "vo_adv_7026000_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "笑容？",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "…………",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來如此，原來如此？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這麼說起來，",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有句名言叫做",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「人不是因為快樂才笑，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而是因為笑了才快樂」呢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也就是說，如果我面帶笑容的話，對方也會露出笑容……",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n每個人都笑容滿面，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "每個人都會很快樂……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n好朋友號，你想表達的是這個意思吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "集合時間是中午過後……",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n因為怕遲到，所以我一大早就來了，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就算我不夠討人喜歡，也還有充足的時間！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就從我在聖德蕾莎女子學院學到的",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「優雅微笑」……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n演練一千次開始！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哦、",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哦",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呵呵……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咕咕咕──！？",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團、",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n怎麼了嗎！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你是不是來得太早了！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n約定的時間還沒到呢！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真不愧是BB團的團長……！",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來我的想法通通都被你看透了呀……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 111411,
        "voice": "vo_adv_7026000_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "…………啊！？",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長身後的那一位是……！",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "現、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "現在正是展現自我介紹練習的成果之時！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "初、",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "初次……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我叫……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "做……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "碧……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……請、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請請……！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "練習的、",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "成果…………",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "…………",
        "unit_id": 111411,
        "voice": "vo_adv_7026000_023"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "…………初次見面。",
        "unit_id": 111411,
        "voice": "vo_adv_7026000_024"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n露娜叫做露娜喔。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊、",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我才要請你們多多關照……！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真不愧是團長！",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不動聲色地幫我圓場！　",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "…………",
        "unit_id": 111411,
        "voice": "vo_adv_7026000_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那孩子？",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是指好朋友號嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嘿、",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嘿嘿……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "露娜",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也抱著很可愛的玩偶呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "…………嗯。",
        "unit_id": 111411,
        "voice": "vo_adv_7026000_030"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呃，",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_031"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個玩偶的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "名字是……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……大哥哥。",
        "unit_id": 111411,
        "voice": "vo_adv_7026000_032"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n還不走嗎？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說、",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_033"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說得對……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是來尋找團長的記憶線索呢……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長，",
        "unit_id": 104011,
        "voice": "vo_adv_7026000_034"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們走吧！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在略微尷尬的氣氛中，三人即將挑戰露娜之塔。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n究竟碧和露娜是否能變得更要好呢？"
    }
]