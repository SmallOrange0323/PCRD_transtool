[
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "噗……",
        "unit_id": 116211,
        "voice": "vo_adv_5064203_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "結束了～",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怎麼樣，",
        "unit_id": 116311,
        "voice": "vo_adv_5064203_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "認輸了嗎！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可惡的神祕暗黑組織憂妮們！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "到底是什麼東西啊？",
        "unit_id": 7112,
        "voice": "vo_adv_5064203_002"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "那個叫憂妮們的。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我們學校才沒有那種「們」──",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔！",
        "unit_id": 116411,
        "voice": "vo_adv_5064203_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不好，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "憂妮們分裂後要逃跑了！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "豈能就這樣放虎歸山！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "各位我們追！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "追上去湮滅所有證據！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "湮滅證據……？",
        "unit_id": 7112,
        "voice": "vo_adv_5064203_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊啊不是，",
        "unit_id": 116411,
        "voice": "vo_adv_5064203_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "更正。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是為了守護學園的和平，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n正義的優妮們要繼續戰鬥！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是啊！",
        "unit_id": 116311,
        "voice": "vo_adv_5064203_006"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "讓正義的好朋友社吧繼續戰鬥吧！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "啊……！",
        "unit_id": 7112,
        "voice": "vo_adv_5064203_007"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "給我等一下，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "話還沒──",
        "unit_id": 7112
    }
]