    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吉塔與{player}承接了一個工作，\n護衛一名男性從附近的城鎮來到蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "平安無事抵達城鎮了呢。",
        "unit_id": 105711,
        "voice": "vo_adv_1057005_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "辛苦了！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這些是報酬。",
        "unit_id": 1011,
        "voice": "vo_adv_1057005_001"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "魔物出現的時候雖然嚇出一身冷汗，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不過你們很厲害呢。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n就和傳聞中的一樣。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "委託你們實在太好了。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "傳聞？",
        "unit_id": 105711,
        "voice": "vo_adv_1057005_002"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "什麼樣的傳聞？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "傳聞說「如果在蘭德索爾一帶要找人委託工作，",
        "unit_id": 1011,
        "voice": "vo_adv_1057005_003"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n就去找騎空士或是騎空團吧」。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "最近在這一帶已經完全沒聽到什麼騎空團，",
        "unit_id": 1011,
        "voice": "vo_adv_1057005_004"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n原本還半信半疑的……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不過看來選擇請你們幫忙是正確的呢。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n如果之後還有機會，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就拜託你們了。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好的……！",
        "unit_id": 105711,
        "voice": "vo_adv_1057005_005"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "非常感謝你！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "剛才他說的話真不得了呢！",
        "unit_id": 105711,
        "voice": "vo_adv_1057005_006"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "已經開始有人推薦",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我們了……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "最近就算不主動去找工作，",
        "unit_id": 105711,
        "voice": "vo_adv_1057005_007"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n也會有很多人來委託，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "想不到竟然是成為話題了……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "有好好努力到現在實在太好了！",
        "unit_id": 105711,
        "voice": "vo_adv_1057005_008"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "之後只要存到能買騎空艇的錢，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n就能變成像樣的騎空團了呢！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嗯！",
        "unit_id": 105711,
        "voice": "vo_adv_1057005_009"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "然後呢，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "總有一天前往天空冒險……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好──",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "要繼續努力囉──！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "噠啊！",
