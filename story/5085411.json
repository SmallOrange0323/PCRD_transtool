        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次戰鬥結束後，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我要過上好一段吃飽睡、睡飽吃的日子，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "絕對不要來把我叫醒喔。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不行啦～？",
        "unit_id": 121211,
        "voice": "vo_adv_5085411_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不能說「這次戰鬥結束後」",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這種話啦。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別計較這麼多啦。",
        "unit_id": 121111,
        "voice": "vo_adv_5085411_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之我就是想休息！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次戰鬥結束後，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我一定要吃一堆美味食物，然後睡個過癮！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對了，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就來吃之前特地藏起來的",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "私房甜點好了～♪",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊，",
        "unit_id": 121011,
        "voice": "vo_adv_5085411_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳說的私房甜點……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該不會是……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 121111,
        "voice": "vo_adv_5085411_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳怎麼了，貪吃佩可？",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳為什麼把視線從我身上別開了？",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看著我啊！？",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喂喂，妳們兩位。",
        "unit_id": 121211,
        "voice": "vo_adv_5085411_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不到最後一刻，可是不能鬆懈的唷～？",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "想要一起暢飲勝利美酒，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也是要等到全部都結束以後呀。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 121111,
        "voice": "vo_adv_5085411_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道啦……",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 121011,
        "voice": "vo_adv_5085411_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就火力全開地上吧～！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n幫我們打氣吧！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n拜託囉！",
        "unit_id": 121011
    },
