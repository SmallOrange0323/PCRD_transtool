    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為牠明白是栞栞你們治好牠",
        "unit_id": 103311,
        "voice": "vo_adv_5116007_077"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n痛到受不了的蛀牙啊。",
