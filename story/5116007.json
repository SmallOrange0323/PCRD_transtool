[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從集訓返家的幾天後──"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牧場周圍也沒有任何異狀。",
        "unit_id": 103813,
        "voice": "vo_adv_5116007_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣就",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "巡過一輪了呢。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "栞栞，",
        "unit_id": 103311,
        "voice": "vo_adv_5116007_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "辛苦啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n雖然時間有點早，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過要不要來吃午餐？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 103813,
        "voice": "vo_adv_5116007_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "已經到這個時間了啊。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "嘎嚕嚕……",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喵特也辛苦啦。",
        "unit_id": 103311,
        "voice": "vo_adv_5116007_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……我說，",
        "unit_id": 103311,
        "voice": "vo_adv_5116007_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "栞栞。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我很感謝妳留下來……",
        "unit_id": 103311,
        "voice": "vo_adv_5116007_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳沒必要跟我們客氣喔。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "客氣……",
        "unit_id": 103813,
        "voice": "vo_adv_5116007_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "在說什麼啊？",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "聽說",
        "unit_id": 103311,
        "voice": "vo_adv_5116007_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只要持有遊俠資格，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n對於獵人體系的公會來說是很搶手的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "比起待在像我這樣貧窮的公會裡，",
        "unit_id": 103311,
        "voice": "vo_adv_5116007_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不如去那裡的待遇也比較好……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真陽……",
        "unit_id": 103813,
        "voice": "vo_adv_5116007_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個……",
        "unit_id": 103311,
        "voice": "vo_adv_5116007_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為了栞栞著想的話，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "去其他公會會比待在我這裡好吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……其實，",
        "unit_id": 103813,
        "voice": "vo_adv_5116007_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "當我拿到證書的時候有受到邀請，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n問我說要不要加入獵人公會成為正式的遊俠。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "既然這樣，",
        "unit_id": 103311,
        "voice": "vo_adv_5116007_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為什麼……？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為──",
        "unit_id": 103813,
        "voice": "vo_adv_5116007_013"
    },
    {
        "type": "background",
        "background": "500371"
    },
    {
        "type": "dialogue",
        "name": "集訓櫃台人員",
        "words": "──那麼，",
        "unit_id": 1,
        "voice": "vo_adv_5116007_014"
    },
    {
        "type": "dialogue",
        "name": "集訓櫃台人員",
        "words": "通過最終測驗的所有人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "集訓櫃台人員",
        "words": "\n請收下證書。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這就是",
        "unit_id": 125414,
        "voice": "vo_adv_5116007_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "遊俠資格的證書……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是啊，",
        "unit_id": 125312,
        "voice": "vo_adv_5116007_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也非常努力了。",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "栞小姐，",
        "unit_id": 125312,
        "voice": "vo_adv_5116007_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您。",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相信並守候主人……",
        "unit_id": 125312,
        "voice": "vo_adv_5116007_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您讓在下",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在這場集訓中",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "學到了，",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也有那樣子的強韌意志。",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哪裡，",
        "unit_id": 125414,
        "voice": "vo_adv_5116007_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我才是",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "受到了可可蘿和",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n{player}",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很多的幫助……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "集訓櫃台人員",
        "words": "栞小姐、",
        "unit_id": 1,
        "voice": "vo_adv_5116007_020"
    },
    {
        "type": "dialogue",
        "name": "集訓櫃台人員",
        "words": "可可蘿小姐，請確認遊俠動物登記證",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "集訓櫃台人員",
        "words": "\n上面的資料",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "集訓櫃台人員",
        "words": "是否有缺漏。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 125414,
        "voice": "vo_adv_5116007_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不好意思。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我看看，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只要寫我的名字",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "和所屬公會──",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "嗨，",
        "unit_id": 414,
        "voice": "vo_adv_5116007_022"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "恭喜你們通過了。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n幸好你們還沒回去。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "教官先生，",
        "unit_id": 125312,
        "voice": "vo_adv_5116007_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感謝您",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此貼心。",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是為了祝賀",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才特地過來的嗎？",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "呃，",
        "unit_id": 414,
        "voice": "vo_adv_5116007_024"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "我真的是誠心祝賀各位啦……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "不過我找你們是有別的事情。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "我就直話直說了……",
        "unit_id": 414,
        "voice": "vo_adv_5116007_025"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n你們三個",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "有沒有打算加入獵人公會？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這是",
        "unit_id": 125414,
        "voice": "vo_adv_5116007_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "在邀我們……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "轉移公會會籍嗎？",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "嗯，",
        "unit_id": 414,
        "voice": "vo_adv_5116007_027"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "你們要這麼想也無所謂。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "在集訓中見到你們，",
        "unit_id": 414,
        "voice": "vo_adv_5116007_028"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "我就一直在注意了。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "畢竟有人強烈推薦你們啊。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "集訓營地的醫生",
        "words": "……是我推薦的，",
        "unit_id": 7511,
        "voice": "vo_adv_5116007_029"
    },
    {
        "type": "dialogue",
        "name": "集訓營地的醫生",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "集訓營地的醫生",
        "words": "我很希望跟你們一起工作。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "集訓營地的醫生",
        "words": "解決這次事情的俐落手腕，",
        "unit_id": 7511,
        "voice": "vo_adv_5116007_030"
    },
    {
        "type": "dialogue",
        "name": "集訓營地的醫生",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "集訓營地的醫生",
        "words": "以及",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "集訓營地的醫生",
        "words": "身為遊俠的資質……",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "集訓營地的醫生",
        "words": "最重要的是，",
        "unit_id": 7511,
        "voice": "vo_adv_5116007_031"
    },
    {
        "type": "dialogue",
        "name": "集訓營地的醫生",
        "words": "你們想保護包含了魔物和動物生態系的意志。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "集訓營地的醫生",
        "words": "\n你們可以",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "集訓營地的醫生",
        "words": "當作",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "集訓營地的醫生",
        "words": "我是看中這些才來挖角的。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "我們每年",
        "unit_id": 414,
        "voice": "vo_adv_5116007_032"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "都會從合格者之中",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "去找我們認為「",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "就是他！」",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "這樣的人聊聊。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n只要願意轉會籍，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "我們可以提供比大部分公會還優渥的條件。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "別看我們這樣，",
        "unit_id": 414,
        "voice": "vo_adv_5116007_033"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "我們可是深受高層信賴的公會喔。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "畢竟",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "我們可是有在頒發遊俠的公認執照啊。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "怎麼樣？",
        "unit_id": 414,
        "voice": "vo_adv_5116007_034"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "我覺得條件不差喔。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "若有其他需求，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "條件的部分也能協議──",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起。",
        "unit_id": 125414,
        "voice": "vo_adv_5116007_035"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很高興能受到賞識，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但我無法答應。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "當機立斷也是遊俠的必要資質，",
