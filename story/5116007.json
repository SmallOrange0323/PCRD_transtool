    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有點太多了……",
        "unit_id": 125411
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原來如此，",
        "unit_id": 103311,
        "voice": "vo_adv_5116007_074"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n發生了那樣的事啊。",
        "unit_id": 103311
    },
