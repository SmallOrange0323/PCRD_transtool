        "words": "味道跟色澤都不錯，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n感覺是現採過來的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這到底是誰……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這些水果",
        "unit_id": 103813,
        "voice": "vo_adv_5116007_071"
    },
    {
