[
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "珠希、美冬和{player}\n在找到筆記本後，聊著之後的打算。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "接下來要怎麼辦呢……",
        "unit_id": 108011,
        "voice": "vo_adv_5005005_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n對我們來說",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有兩個選項。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "一個是，",
        "unit_id": 108011,
        "voice": "vo_adv_5005005_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "讓島鯨滿足我們的欲望，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n盡其所能地享受奢華生活，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "結束短短的一生……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "另一個則是，",
        "unit_id": 107911,
        "voice": "vo_adv_5005005_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n打倒或說服島鯨",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "讓我們回到現實世界嗎",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵……？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對我們來說，哪一個選項才是幸福呢……",
        "unit_id": 108011,
        "voice": "vo_adv_5005005_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我能說的是……",
        "unit_id": 107911,
        "voice": "vo_adv_5005005_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "現在的生活，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "直白來講就是舒適喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也是呢，",
        "unit_id": 108011,
        "voice": "vo_adv_5005005_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "可以做所有喜歡的事情",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "悠哉悠哉地生活。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n可說是理想的世界呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "果然……",
        "unit_id": 107911,
        "voice": "vo_adv_5005005_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n一直待在這裡，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "也是可行的喵……？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有什麼關係喵！",
        "unit_id": 107911,
        "voice": "vo_adv_5005005_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要失去現在的生活什麼的，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我受不了喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "老實說，",
        "unit_id": 108011,
        "voice": "vo_adv_5005005_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我也同意呢……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒有那種事喵！",
        "unit_id": 107911,
        "voice": "vo_adv_5005005_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我不想要{player}管這麼多喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "總之，",
        "unit_id": 108011,
        "voice": "vo_adv_5005005_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "先在這座島上",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "再生活一陣子一邊思考吧！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯呵呵……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我贊成喵！",
        "unit_id": 107911,
        "voice": "vo_adv_5005005_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總之，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n今天我們也玩完後才回家，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n{player}可以先悠哉地回去就好了喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵呵呵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "沒錯呢，",
        "unit_id": 108011,
        "voice": "vo_adv_5005005_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯呵呵……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n先鍛鍊，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "接著再去特賣會唷──！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n晚點見，{player}！",
        "unit_id": 108011
    },
    {
        "type": "background",
        "background": "500280"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和珠希、美冬分開的{player}，\n在洞窟的入口處，\n想著接下來該怎麼辦才好。"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呼、",
        "unit_id": 103211,
        "voice": "vo_adv_5005005_013"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呼……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這座島很大呢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在那裡的該不會是，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n{player}大人嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊──",
        "unit_id": 103411,
        "voice": "vo_adv_5005005_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "果然是{player}！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n能見到你真是太好了！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你在這個地方做什麼呢？",
        "unit_id": 103211,
        "voice": "vo_adv_5005005_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n珠希和美冬",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒有和你在一起嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嗯嗯……",
        "unit_id": 103211,
        "voice": "vo_adv_5005005_016"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「實現願望之島」，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n是叫做島鯨的魔物呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "狀況我了解了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "然後，那兩人",
        "unit_id": 103411,
        "voice": "vo_adv_5005005_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "被這個島的魅力迷惑住，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n所以你正在思考該怎麼辦才好……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "既然如此，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "接下來就交給我們吧！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩個小時過後……"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚喵～",
        "unit_id": 107912,
        "voice": "vo_adv_5005005_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "今天也玩得好累喵～",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雇幾隻貓",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "請牠們送我到珠希宮殿喵～",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那邊的小貓咪──！",
        "unit_id": 107912,
        "voice": "vo_adv_5005005_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n用這個貓幣，",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我想請你把我送到宮殿喵！",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦？",
        "unit_id": 107912,
        "voice": "vo_adv_5005005_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這個錢幣不能用？",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為、",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為什麼喵？",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n咦……",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "海邊的方向好像有誰在喵！？",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那是……",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "秋乃喵！？",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哦──呵呵呵！",
        "unit_id": 103211,
        "voice": "vo_adv_5005005_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n如此一來這座島的流通貨幣就全是我的東西了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n因為我全都買下來了，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以這個錢幣已經不能再用了喔！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "接下來",
        "unit_id": 103211,
        "voice": "vo_adv_5005005_022"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不是「貓幣」，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "而是冠上我名字的",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n「秋乃幣」要在市場上流通唷──！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呀，",
        "unit_id": 107912,
        "voice": "vo_adv_5005005_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "貓幣的經濟圈，",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n因為一個超級有錢人的關係而崩壞了喵──！",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀",
        "unit_id": 103211,
        "voice": "vo_adv_5005005_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "珠希！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳果然在這裡呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n平安無事真是太好了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "秋乃……",
        "unit_id": 107912,
        "voice": "vo_adv_5005005_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳為什麼在這裡喵！？",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那當然是因為，",
        "unit_id": 103211,
        "voice": "vo_adv_5005005_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為了來救妳們兩位和{player}大人而來的啊！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n和優花梨一起！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "優花梨？",
        "unit_id": 107912,
        "voice": "vo_adv_5005005_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒看到人呀，",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在哪裡喵？",
        "unit_id": 107912
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "優花梨的話，",
        "unit_id": 103211,
        "voice": "vo_adv_5005005_028"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "應該是去了無人商店街唷！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n為了讓美冬清醒過來！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這個時候，在無人商店街……"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵──",
        "unit_id": 108012,
        "voice": "vo_adv_5005005_029"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "今天要攻略哪家店的特賣會呢～",
        "unit_id": 108012
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n泳裝店嗎，",
        "unit_id": 108012
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還是藥草店呢……",
        "unit_id": 108012
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦？",
        "unit_id": 108012,
        "voice": "vo_adv_5005005_030"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "怎麼回事……",
        "unit_id": 108012
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n在那家「讓心情變好的水」店裡",
        "unit_id": 108012
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好像有什麼聲音……",
        "unit_id": 108012
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "裡、",
        "unit_id": 108012,
        "voice": "vo_adv_5005005_031"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "裡面好像有誰在呢……",
        "unit_id": 108012
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那是……",
        "unit_id": 108012
