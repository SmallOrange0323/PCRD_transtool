        "name": "靜流",
        "words": "對吧！",
        "unit_id": 117111,
        "voice": "vo_adv_5070004_048"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n畢竟我們要在這裡跟弟弟一起生活嘛！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對啊！",
        "unit_id": 117011,
        "voice": "vo_adv_5070004_049"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那是不可或缺的東西！",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是我們的家啊！",
        "unit_id": 117111,
        "voice": "vo_adv_5070004_050"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們會蓋一棟適合您住的",
        "unit_id": 117011,
        "voice": "vo_adv_5070004_051"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "氣派的房子！",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然您請我們吃了這麼美味的料理，",
