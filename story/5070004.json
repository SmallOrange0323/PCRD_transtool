        "type": "dialogue",
        "name": "惠理子",
        "words": "不斷……",
        "unit_id": 102711,
        "voice": "vo_adv_5070004_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "延續……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "永不結束的暑假……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
