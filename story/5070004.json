    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這種事可不在我的預想之中……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我無法想像再也見不到弟弟的日子……",
