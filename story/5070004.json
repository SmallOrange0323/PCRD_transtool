        "voice": "vo_adv_5070004_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n但幸好我們",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在失去之前就發現了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "應該會有什麼辦法才對……",
        "unit_id": 102711
    },
