[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吃完冰淇淋的{player}與七七香\n決定繼續美少女遊戲模擬約會──"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "…………",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "討厭啦，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "害、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "害我也有點緊張起來了……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛才那句話……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只要和我在一起就很開心，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "應該",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是真心的吧？　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔～",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "本來只是想體驗經典的主流約會事件，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n怎麼氣氛變得",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有點奇怪了呢～！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這一切通通都是",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛才那句話害的啦～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n有種「對七七香的心臟造成暴擊！」",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "的感覺～！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……嗯！？",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒有，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒事啦～",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我只是在",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "計劃下一個約會事件而已☆",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "話說回來，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這個態度是什麼意思呀！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n你可是在和名為七七香的美少女約會耶？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n應該要更興奮、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "更加小鹿亂撞才對吧～！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就只有我在害羞，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對方連半點害羞的感覺都沒有，這是怎麼回事！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n好歹稍微在意一點，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "心動☆",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一下啊！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……我要雪剛才的恥，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再找個食物",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當題材吧？　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔……",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好像可以再去吃點東西～",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嘿，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你有想吃什麼東西嗎？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不不不，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們不是才剛吃完冰淇淋嗎！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "身體受寒的話會搞壞肚子，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "別想了！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好！",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那我們一起去狩獵吧！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喂不對，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那是別種遊戲啦！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們現在是美少女遊戲呢！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不對，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等一下！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "冷靜下來。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n就算我再想用食物讓他心跳加速，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n感覺也只會被他忽視。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "或許我應該改用",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「手碰手心跳加速☆」的題材攻略他。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "說到海邊的經典美少女遊戲事件……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我想想，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還是游個泳再去吃東西吧！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那樣肚子也比較餓，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "時間點正好。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "主流中的主流，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "海邊的超近距離臉紅心跳事件！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這樣一來，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我的心動回憶就能確實展開了！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……啊，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對了！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n如果用上看剛才買的書一定會很有意思，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我去把書拿來～",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "鏘鏘～",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這是我剛剛買的潛水魔法♪",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n今天",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們就用這個魔法",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "到海裡看看吧！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哼，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不必擔心。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我已經大致掌握內容了。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n何況七七香還是個天才魔法少女，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "小菜一碟啦！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還有，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我要用的不是所有魔法，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只是一小部分而已，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "安心又安全！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只要限制在確保視野及呼吸的條件下，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就可以簡化魔法了。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……你這個眼神是還在懷疑吧～？",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不敢一下子就嘗試太深的水域的話，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "先就近試試吧。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "附魔！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣一來就沒問題了☆",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n快點，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "把臉埋到海裡試試？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼！？",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……啊，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我忘了眼睛的防護！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "眼睛裡進了不少海水吧！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對不起、對不起！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這個時候應該要用……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "構築！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n把臉埋進",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這些純水裡，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "眼睛眨一眨！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呃，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咳。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然出了一點小差錯，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但現在已經萬無一失了！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "走，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們一起潛進海裡吧！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一，二，三！",
        "unit_id": 113311
    },
    {
        "type": "still",
        "still": "113300301"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇～",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好壯觀的景色！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n看來魔法控制得非常成功呢～♪",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哼哼，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這下你明白七七香的厲害之處了吧？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這樣的福利",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可是不可多得的機會喔☆",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "現在你的身體",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_025"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "應該可以自在活動了，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n要不要試著",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "接近魚呀？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哦，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "連海豚都湊過來了呢！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n其實",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你滿討動物喜歡的吧？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "別謙虛～",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_027"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "靠近你的不只是一般的魚，連海豚都來了！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我覺得這是你具備的專長呢！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼？",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你還有其他類似的經驗嗎？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n……去牧場的時候基本上都是這樣？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你的交友圈真廣泛呢……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼難得的機會，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不如我用個轉印魔法吧！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "和七七香的美少女遊戲約會紀念合照。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咔嚓☆",
        "unit_id": 113311
    },
    {
        "type": "still",
        "still": "113300302"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呵呵呵，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "目前為止都很順利！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "接下來我要觸發縮短距離的事件！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那我們",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再到深一點的地方……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對了。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n魔法的時效快結束了。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_032"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "先回沙灘上吧。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n重新",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "施加魔法以後，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再到海裡散步！",
        "unit_id": 113311
    },
