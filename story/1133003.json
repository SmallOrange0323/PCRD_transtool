        "voice": "vo_adv_1133003_036"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……嗚、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇啊啊啊啊啊！！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n為、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為為、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為什麼我的泳衣會在你手上！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n你隨手撈到的！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你這是走什麼運啊！！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然我想要觸發臉紅心跳的意外，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_037"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n但不是這種幸運色狼事件啦──！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還有，",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_038"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你為什麼可以這麼若無其事地遞給我啊！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "起碼稍微羞澀一點吧，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "笨蛋！！",
        "unit_id": 113311
    },
