        "voice": "vo_adv_1133003_035"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "別突然來個",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼猛的浪啊～",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n呼……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嚇死我了。",
