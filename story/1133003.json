        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "算了，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "反正觸發事件的機會多得是。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那就",
        "unit_id": 113311,
        "voice": "vo_adv_1133003_034"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再重施魔法……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇啊！？",
        "unit_id": 113311
    },
    {
        "type": "background",
