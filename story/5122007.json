    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "大間的海洋恢復成原本的美麗模樣──"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "優花梨、",
        "unit_id": 126711,
        "voice": "vo_adv_5122007_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真軌先生！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "和正先生",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "說要展示很有趣的捕魚法給我們看！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "哼哼，",
        "unit_id": 6411,
        "voice": "vo_adv_5122007_001"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "這是大海驚喜箱。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "你們看著喔，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "就用這個來誘導金槍鮪──",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "唉唷！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "犯傻啦。",
        "unit_id": 6411,
        "voice": "vo_adv_5122007_002"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "嘩啦！"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "連、",
        "unit_id": 126711,
        "voice": "vo_adv_5122007_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "連同大海驚喜箱",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "一起掉進海裡了！？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──咻砰砰砰砰砰砰砰砰──！！"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "可、",
        "unit_id": 191011,
        "voice": "vo_adv_5122007_004"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "可媲美水上煙火的大爆炸──！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "……但是爆炸掀起的浪，",
        "unit_id": 191011,
        "voice": "vo_adv_5122007_005"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "一口氣把金槍鮪全沖到海灘上了！？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "喔喔，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "真是大豐收。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "太、",
        "unit_id": 126711,
        "voice": "vo_adv_5122007_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "太厲害了！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "和正先生，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "難道這一開始就是你的目的……？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "…………啊，",
        "unit_id": 6411,
        "voice": "vo_adv_5122007_007"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "嗯。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "是這樣沒錯。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……！",
        "unit_id": 126711,
        "voice": "vo_adv_5122007_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n優花梨！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那個人相當能幹呢。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "一定要",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "把他挖角過來當我們的外部顧問！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "秋乃，這個主意………………",
        "unit_id": 126811,
        "voice": "vo_adv_5122007_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "實在太棒了！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "妳、",
        "unit_id": 6411,
        "voice": "vo_adv_5122007_010"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "妳們啊……",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n因為發生了太多事的反作用，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "讓妳們的大腦完全進入度假模式了吧……",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "聽我的勸，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "妳們還是先把那個主意",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "收回去吧。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "那些小事情就先別管了！",
        "unit_id": 191011,
        "voice": "vo_adv_5122007_011"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "總之先來切魚吧！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我已經受夠曖昧模糊的味道了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "快來享用美味到會讓人大吃一驚的金槍鮪吧！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "贊成～！",
        "unit_id": 1,
        "voice": "vo_adv_5122007_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……呵呵，",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "大家看起來都很開心呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "太好了，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "大間又恢復原本美麗的模樣了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是多虧了秋乃她們",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "強到可稱作是執念的毅力。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我稱讚別人很難得嗎？",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……呵呵。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "人與人之間，",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "到頭來",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "終究都是各自獨立。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算手牽著手，",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "感覺自己與他人產生了聯繫……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "每個人心裡還是會藏著一個，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "絕對不會敞開的祕密房間。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那扇門不能打開。",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不能",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "揭露出那些祕密。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這就是",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我所認為的",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "世間真理。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……嗯，",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "差不多就是這樣吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……是啊。",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真令人驚訝。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "秋乃她們堅決不顧我的反對，",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n把自己弄得渾身是傷，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "卻還是靠著那股不顧後果的信念穿破了世間真理，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n最終",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "打開了眾人的心扉。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……除了痛快以外，沒有別的詞可以形容了。",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n看來這一次，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是「祕密主義者似似花」",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "輸了呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……咦？",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……！",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你為什麼會知道這件事？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……原來如此。",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "畢竟真軌也是急壞了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他大概是認為",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果是你就不會多問，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "願意陪他一起找吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能正確計算風險與報酬的交叉點，",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n採取最能符合主人心意的方法。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不愧是我的僕人。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然也有冒失之處，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但可稱得上是模範隨從。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……沒錯。",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這個資料記錄裝置，",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_031"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是我的祕密。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很小一個對不對？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可是，",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "卻很沉重。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真想拋開它啊……",
        "unit_id": 126611,
        "voice": "vo_adv_5122007_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要是我能拋開一切，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "說出這個祕密，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "會有多麼自由呢……",
        "unit_id": 126611
    },
    {
