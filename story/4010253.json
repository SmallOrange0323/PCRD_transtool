        "words": "老哥，",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你還好吧？",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "慢慢來就好，",
        "unit_id": 103333,
        "voice": "vo_adv_4010253_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小心不要滑倒啦。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "搞笑藝人可是嚴禁",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "滑鐵盧的～♪",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "話說回來，",
        "unit_id": 103333,
        "voice": "vo_adv_4010253_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝你今天陪我來。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒想到",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這邊居然可以爬山的啦。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n雖然在故鄉的話，",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "想爬多少山都可以的說。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～",
        "unit_id": 103333,
        "voice": "vo_adv_4010253_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "又老了一歲吧。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也是許願",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "自己一定要實現",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "成為搞笑藝人的夢想啦。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在山頂上",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大聲喊出",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "「我的目標是成為頂尖的搞笑藝人」。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "讓老哥陪我一起來",
        "unit_id": 103333,
        "voice": "vo_adv_4010253_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n……",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是希望",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你能見證這一刻啦。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嘿嘿。",
        "unit_id": 103333,
        "voice": "vo_adv_4010253_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n那是當然的啦。",
        "unit_id": 103333
    },
    {
        "type": "background",
        "background": "510270"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊～",
        "unit_id": 103333,
        "voice": "vo_adv_4010253_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好美的景色，",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "讓我想起故鄉了。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n能平安順利登頂，真是太好了啦。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n……",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果是自己一個人來的話，",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大概就沒有這樣的成就感了吧。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這一切都是",
        "unit_id": 103333,
        "voice": "vo_adv_4010253_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為有老哥啦。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我沒有放棄成為搞笑藝人，",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也是因為",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有你這個可靠的搭檔在我身邊。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嘿嘿、",
        "unit_id": 103333,
        "voice": "vo_adv_4010253_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝你啦。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你還準備了禮物嗎！？",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n……",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "明明會增加負擔，",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還是一路為我背到這裡嗎……",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 103333,
        "voice": "vo_adv_4010253_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "超開心的啦。",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我一定會成為搞笑藝人給你看的！",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個……",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "請你",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一直在我身邊",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看著",
        "unit_id": 103333
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我吧……♪",
        "unit_id": 103333
    }
