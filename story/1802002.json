[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與自稱為【憤怒‧軍團】成員的卡里莎戰鬥過後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n優衣為了重新鍛鍊自己，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "便前往城外想進行祕密特訓。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "上次幸好大家都沒事……",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n以後又得繼續戰鬥了，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "跟不同於霸瞳皇帝的敵人們……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且……",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "公主型態……",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "既然能變身成這種型態，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n使出強大的攻擊魔法，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那我就得重新審視",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "戰鬥方式才行。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我今天要好好加油！",
        "unit_id": 100211
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我不能只懂得防守與治癒，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也必須熟練攻擊能力才行。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n一定要跟大家合作，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "保護好騎士先生！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "花朵射擊！",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "唔……",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "既然現在有可能變身成公主型態，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我就要訓練自己，在平常支援大家的同時，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n也能依戰況變身，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "加入攻擊的行列。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……第一次變身的時候，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是跟貪吃佩可一起變身的，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且很大一部分是憑著衝勁，莫名的就成功了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "希望往後不再只是靠衝勁，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而是能夠依情勢做出妥善的判斷，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "培養出比現在",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "更加沉著的心態。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過，攻擊不會動的目標，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "本來就沒有難度……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我本來是想私下練習，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n但是不是該找個人陪我練比較好呢？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且……",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "其實應該要變身成公主型態再練習，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n才能獲得最大的成效，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但若要變身，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "又需要騎士先生在場……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果這個時候，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生能夠在身邊的話……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……我在說什麼傻話。",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼能在特訓的時候就洩氣了呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……嗯。",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "重新打起精神，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "加油吧！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生！？",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你怎麼會在這裡！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可可蘿跟凱留呢？",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "她們沒有跟你在一起嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你自己一個人過來的？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "竟然跑這麼遠……！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有沒有哪裡受傷？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "走這麼久，你累不累？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……太好了。",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "看起來很有精神。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎士先生，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你為什麼會跑到這裡來？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "看到我……？",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "什麼時候的事？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在城裡的時候？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n難道說，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "從出城前你就一直……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你看到我，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以就跟過來了……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我滿腦子都想著特訓，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "完全沒注意到這件事……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這麼說來，我來到這裡的路上，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一次都沒有回過頭……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還好沒有得意忘形地跑去平原……",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n要是讓騎士先生跟著我跑到那邊，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "肯定會出事的……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且要是在城外，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "被卡里莎或其他人襲擊，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n光靠我一個人，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也許無法保護好騎士先生。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "得快點回城裡！　",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒注意到你，真不好意思。",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們一起回去吧？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "大家一定都很擔心你。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你問",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為什麼……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n要是讓騎士先生遇到危險就糟糕了，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n所以，我覺得回去還是比較好。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個……",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為我會擔心騎士先生，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n所以沒辦法繼續練下去了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我不想給騎士先生",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還有大家添麻煩，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n所以特訓就等下次再說。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "畢竟，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "連下一次能變身成公主型態的時機都不知道，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然我也是很想嘗試看看，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但這也沒辦法。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎士先生的人身安危，是無可取代的。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒有這回事。",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "只有我一個人的話並沒有那麼厲害……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我很高興騎士先生願意信賴我，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但同時也會感到壓力……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "靠我自己一個人，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的能保護好騎士先生嗎……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n就算真的是這樣……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚嗚嗚，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我沒有信心啊……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……在這種時候，",
        "unit_id": 100211,
        "voice": "vo_adv_1802002_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "換作是騎士先生會怎麼做呢？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎士先生",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總是會對我伸出援手，沒有絲毫猶豫……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那我也希望，",
        "unit_id": 100211,
