[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "聽說鈴",
        "unit_id": 113811,
        "voice": "vo_adv_6048104_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是個家裡蹲，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n不過很風趣，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "意外的是個很正經的人呢！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "平常的她",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是什麼樣子呢？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "的確",
        "unit_id": 113811,
        "voice": "vo_adv_6048104_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有聽到她說",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "歡迎隨時去牧場玩，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也就是",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "她隨時都沒在工作所以隨時都能一起玩的意思吧？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這樣不會惹牧場的人生氣嗎……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這種說法是",
        "unit_id": 113811,
        "voice": "vo_adv_6048104_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "她平常都不肯好好工作的意思吧……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還是這是",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "某種從容？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n鈴認真起來是什麼感覺呢？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好在意啊！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真、",
        "unit_id": 113811,
        "voice": "vo_adv_6048104_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真好懂啊。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "遇到關乎輸贏的事，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我也會整個人變得滿認真的，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "說不定",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們是很像的同伴呢。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n稍微有一點親切感了呢。",
        "unit_id": 113811
    }
]