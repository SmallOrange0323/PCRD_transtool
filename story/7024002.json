    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是要",
        "unit_id": 6111,
        "voice": "vo_adv_7024002_052"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "挖角我的意思嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳要這麼想也沒關係。",
        "unit_id": 107011,
        "voice": "vo_adv_7024002_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n當然",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "待遇一定會",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比現在還要好得多。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我認為妳有這個價值，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是很有用的人物。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳說什麼！？",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_054"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我現在無法馬上回覆您……",
        "unit_id": 6111,
        "voice": "vo_adv_7024002_055"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n請給我一些時間。",
