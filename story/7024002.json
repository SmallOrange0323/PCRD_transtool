    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人戰勝了幾場戰鬥，在露娜之塔裡不斷前進。"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯……",
        "unit_id": 107011,
        "voice": "vo_adv_7024002_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不愧是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "名為露娜之塔呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "太陽和月亮……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "簡直像……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔嗯，",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "原來是這樣啊。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 107011,
        "voice": "vo_adv_7024002_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "原來如此呀～！",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_003"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐，",
        "unit_id": 6111,
        "voice": "vo_adv_7024002_004"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您從剛才開始就在做什麼？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "看了還不知道嗎？",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我在調查啊，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "調查！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我無論如何",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "都要在調查上幫上忙……！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "原來是這樣啊。",
        "unit_id": 6111,
        "voice": "vo_adv_7024002_007"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我還以為",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您是在妨礙似似花小姐呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳、",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_008"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳說這什麼話！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這種需要知識的調查正是我的專長。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那些頭腦簡單，只會戰鬥的人是不會懂的啦！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "喔？",
        "unit_id": 107011,
        "voice": "vo_adv_7024002_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就讓我們瞧瞧妳的本事吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗚……",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳就在一旁等著瞧吧！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "首先我要用這個煉金術的反應劑",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "調查材質！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "它會因應不同材質產生不同反應……",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "才對，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "的說……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一點反應都沒有。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好奇怪呀。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這個",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "和這個都沒有反應……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這個密度明明有這樣的硬度……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "該不會",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不是金屬？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n怎麼可能",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "會有這種物質存在！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原來如此，",
        "unit_id": 107011,
        "voice": "vo_adv_7024002_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳知道了其實妳不知道，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳、",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_014"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳說什麼！？ ",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "少瞧不起人了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號！ ",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "從我的行李裡拿反應劑過來！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n既然如此我就徹底地好好調查！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯……",
        "unit_id": 107011,
        "voice": "vo_adv_7024002_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來至少她看出",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這裡不是尋常地方。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "找出自己不懂的地方",
        "unit_id": 107011,
        "voice": "vo_adv_7024002_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這件事情",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是往真相的第一步。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來她不是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "完全不懂的門外漢呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "被常識侷限住的人",
        "unit_id": 107011,
        "voice": "vo_adv_7024002_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在遇到無法理解的事時",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n總會用自己曉得的知識",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "穿鑿附會。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "她沒有這麼做就表示",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "她不是一般的愚笨之人。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只不過……",
        "unit_id": 107011,
        "voice": "vo_adv_7024002_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "越接近世界之謎也代表",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n越接近我們的領域。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n若她再繼續深入探究的話……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼了？",
        "unit_id": 107011,
        "voice": "vo_adv_7024002_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我的表情很恐怖？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真奇怪呢，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那是絕對不可能的……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這是……",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_020"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "搞不好我發現了一個恐怖的東西……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如此輕巧但又強韌，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對各種物質又有耐侵蝕性。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這是世上不可存在的物質……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要是把這個物質拿來用作飛空艇的材料……",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還可以用在更貼近生活的東西上……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這個世界就會改變。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這是什麼意思？",
        "unit_id": 6111,
        "voice": "vo_adv_7024002_022"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳還不明白嗎？",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等到這個物質可以量產的時候……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "的時候……？",
        "unit_id": 6111,
        "voice": "vo_adv_7024002_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "大把",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_025"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "大把的錢！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n財富就會滾滾而來呀～！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "啊，",
        "unit_id": 6111,
        "voice": "vo_adv_7024002_026"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這樣啊。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如此一來再造克蕾琪塔之塔就不是夢！！！",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等等，秘書一號， ",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳要去哪裡？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n為什麼一副傻眼的表情！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不然",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_028"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我問妳，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "魔法師！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我的慧眼讓妳嚇到說不出話來了吧！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就這點程度嗎？",
        "unit_id": 107011,
        "voice": "vo_adv_7024002_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是庸俗呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳、",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_030"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳說什麼！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
