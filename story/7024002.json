        "voice": "vo_adv_7024002_058"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而且挖的不是我，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是秘書一號……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不僅僅是少年和陛下，",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_059"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就連秘書一號",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n都要被那個臭臉魔法師哄騙了嗎……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "怎麼、",
