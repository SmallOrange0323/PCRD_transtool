        "unit_id": 6111,
        "voice": "vo_adv_7024002_048"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n我還以為確認行程和內容",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是秘書的工作呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n順帶一提",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我們目前沒有僱用關係，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "所以也沒有上下關係喔。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是、",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_049"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是沒錯啦……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯……",
