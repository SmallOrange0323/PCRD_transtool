        "voice": "vo_adv_7024002_051"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳說什麼！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n那、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那是什麼意思！？",
