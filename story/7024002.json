        "voice": "vo_adv_7024002_046"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是很合理的判斷。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能做出這種判斷的人",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n為什麼會待在那種人底下？",
