    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為什麼都那麼喜歡那個魔法師……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你就算了，",
