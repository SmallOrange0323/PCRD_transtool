        "voice": "vo_adv_7024002_037"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是惹人厭的魔法師！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "最好別再和這種人往來了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什麼？ ",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_038"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你說那個不知道在想什麼的人嗎？",
