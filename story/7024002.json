        "voice": "vo_adv_7024002_039"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "喜歡這種的？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n嗯……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也是會有這種特殊需求啊……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唉……",
        "unit_id": 118011,
        "voice": "vo_adv_7024002_040"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "問你這個問題我真是笨蛋。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下也好，你也好，",
