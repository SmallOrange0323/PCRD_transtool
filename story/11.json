        "unit_id": 106913
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就讓我將它畫下句點",
        "unit_id": 106913
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "別再打了好嗎……？",
        "unit_id": 100112,
        "voice": "vo_adv_0000011_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n即使繼續打下去，",
        "unit_id": 100112
    },
    {
        "type": "dialogue",
