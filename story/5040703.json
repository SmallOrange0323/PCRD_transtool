[
    {
        "type": "background",
        "background": "500997"
    },
    {
        "type": "dialogue",
        "name": "老鼠",
        "words": "吱～～！"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼，",
        "unit_id": 102611,
        "voice": "vo_adv_5040703_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總算趕走了！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我怎麼感覺老鼠們",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好像越來越拼命了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是我的錯覺嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過算了，",
        "unit_id": 102611,
        "voice": "vo_adv_5040703_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總算是守住了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你們也是，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒被吃掉真的太好了呢……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我為什麼",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要跟起司說話呢？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "難道是因為我為了這些孩子們而戰，所以產生了感情嗎……？",
        "unit_id": 102611,
        "voice": "vo_adv_5040703_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯？　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我竟然用這些孩子來稱呼……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我到底是怎麼了啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n無論如何，它們還是逃不了被吃掉的命運。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過起司要是沒了，",
        "unit_id": 102611,
        "voice": "vo_adv_5040703_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真陽一定會很難過的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只是因為這樣而已。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "老鼠",
        "words": "吱～～！！"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎麼又來了？　",
        "unit_id": 102611,
        "voice": "vo_adv_5040703_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是學不乖耶～……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦！？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也太巨大了吧！！　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這真的是老鼠嗎！？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "老鼠",
        "words": "吱～～！！"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但牠發出吱吱的叫聲，所以應該是老鼠沒錯吧。",
        "unit_id": 102611,
        "voice": "vo_adv_5040703_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～～真是的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不管來幾次都沒用啦！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我不會讓你們過去的！！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這些孩子們就由我來守護到底！！",
        "unit_id": 102611,
        "voice": "vo_adv_5040703_006"
    }
]