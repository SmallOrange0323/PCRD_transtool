        "voice": "vo_adv_1051001_046"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好了。這是今天的報酬唷。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，怎麼了？",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_047"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……是哦。你也吸到剛才的花粉了呢。",
