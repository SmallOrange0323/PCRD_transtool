[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}為了完成在蘭德索爾接下的任務，\n往大街出發。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，你就是接下任務的人？",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我是委託人，深月。拜託你了哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "今天我想採集開在這附近的花朵。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n能請你幫忙做這份工作嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我這樣說你大概也分辨不了採集的目標吧，",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n所以我先摘了一朵。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這就是那種花唷。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀……你不能這樣大咧咧地靠近啦。 ",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n花朵中也是有危險的品種。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這種花的花粉可是有毒的唷？",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嚴格來說，是它的花粉對人類有毒……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "而且在花的下面……仔細看它的莖，有小小的刺對吧？",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n那裡也是有毒的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是被刺刺到、或是吸入了花粉，",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n可是會很糟糕的。你採集的時候要注意哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但是呢，這種花的毒很特殊，處理得當的話還能做成藥。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就算是毒也能視用法成為救人的藥，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你不覺得很棒嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "說到為什麼我會知道這種事情，",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我是個科學家，平常都在研究植物。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所謂的科學是……",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "現在還是到此為止吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就算是細小的花粉也會構成危險，",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n所以要一朵一朵，小心地放進這個玻璃容器裡哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼，馬上開始採集吧。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n雖然剛才也說過了，你千萬記住要小心點。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……怎麼了？難道出事了？",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒事嗎？讓我來診斷一下。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "別擔心。這種情形我也經常幫人醫治的。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "應急處理的話我還是能應付。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……傷口還很淺。這樣的話滲入的毒也不多，",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "應該馬上就能好。也不需要特別治療呢……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……話說不只你的手，就連手臂和肩膀也……",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n出乎意外地強壯呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個嘛？這只是觸診唷。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你看起來很纖細，卻鍛鍊得很壯呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n實在是理想的身體…",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "――你……要不要成為我的實驗品？",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我想嘗試的藥物和實驗有很多呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你來當實驗品的話肯定能試出很好的結果。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼樣？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一點都不可疑哦。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "當實驗品也算是一份好工作唷……？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你願意考慮嗎？",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也就是「好」的意思呢……？我真高興……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "喂庸醫！ 終於找到妳了！",
        "unit_id": 911,
        "voice": "vo_adv_1051001_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是誰……明明氣氛正好，",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "竟然有礙事的傢伙來了呢。真可惜……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我想想，你們是……誰來著？",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_023"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "妳可別說忘記了啊！",
        "unit_id": 811,
        "voice": "vo_adv_1051001_024"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n我們是被妳治療過的病人！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……你這麼一說，我還真有點印象呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "然後呢？你們這些前病人找我有什麼事？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "治療費啊！",
        "unit_id": 911,
        "voice": "vo_adv_1051001_026"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "妳這開的是天價，是跟我開玩笑吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n這個價錢誰付得起吧！妳這個骯髒的密醫！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我的確是密醫，但你們也只能依靠我，",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "到底有什麼立場向我抱怨？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是得被你們抱怨的話還不如不救你們呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣的話你們就可以不用交治療費了 吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "能有命來我這裡就該慶幸了。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n只要你們好好工作的話，就應該付得起這個價格唷。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "別給我開玩笑了！妳態度好的話我還打算用商量的方式解決， ",
        "unit_id": 811,
        "voice": "vo_adv_1051001_030"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n這樣就只能靠實力來讓妳改變想法！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就連一般不該幫的我也都幫你們了……",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_031"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看來得對不知感恩的人必須好好教訓一番呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "唔……",
        "unit_id": 911,
        "voice": "vo_adv_1051001_032"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "妳是要來開幹嗎！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "先露出敵意的可是你們。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_033"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……給我準備好了！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "嗚哇！這風是怎麼回事！？",
        "unit_id": 811,
        "voice": "vo_adv_1051001_034"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "站不穩腳……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "別亂了陣腳！只不過是風而已！",
        "unit_id": 911,
        "voice": "vo_adv_1051001_035"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n這種程度嚇不倒我們的！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "的確……",
        "unit_id": 811,
        "voice": "vo_adv_1051001_036"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "嘿嘿，竟敢威脅我們。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n這次輪到我們出手了！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "喔喔！……",
        "unit_id": 911,
        "voice": "vo_adv_1051001_037"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "欸，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "欸？怎麼回事？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "我的腳怎麼動不了……！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "我、",
        "unit_id": 811,
        "voice": "vo_adv_1051001_038"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "我也是……！我、我的身體也……麻痺了……！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "不能呼吸……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "咳！咳咳！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵呵……！果不其然。馬上就奏效了呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_039"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這種花的刺和花粉裡可是有痲痹人體的成分唷。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "然後剛才的那陣風裡呢……",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_040"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n就藏了不少這種花粉哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真的有很多……憑肉眼沒法看見的小花粉。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "吸了這麼多的花粉，你們呼吸困難了吧？",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_041"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不過放心吧♪ ",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……因為你們再也不用呼吸了♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，你……",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_042"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "為什麼要擋著我？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你站在那裡我可給不了最後一擊哦……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……呵呵。的確，你說得對呢。",
