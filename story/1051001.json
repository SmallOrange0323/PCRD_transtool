    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不只是刺裡的毒，",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_048"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n連花粉也進到體內的話可就相當危險唷。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你不馬上接受治療的話，說不定會有生命危險。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_049"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n雖然我能治好你……",
