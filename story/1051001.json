        "voice": "vo_adv_1051001_043"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在這裡幹掉他們的話，我可就收不了治療費呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這次就放過你們了。記得要向他道謝呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051001_044"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……還有別忘了交治療費哦？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "反正花朵也採集好了，我們回城鎮去吧。",
