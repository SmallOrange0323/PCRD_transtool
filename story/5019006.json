    {
        "type": "dialogue",
        "name": "旁白",
        "words": "海水浴開幕活動當天。\n聚集在會場海灘上的觀光客們，\n一直期待著鈴奈出場。"
    },
    {
        "type": "dialogue",
        "name": "女觀光客",
        "words": "能在這麼美麗的海灘上看到鈴奈，實在太棒了！",
        "unit_id": 1212,
        "voice": "vo_adv_5019006_000"
    },
    {
        "type": "dialogue",
        "name": "男觀光客",
        "words": "是啊，",
        "unit_id": 312,
        "voice": "vo_adv_5019006_001"
    },
    {
        "type": "dialogue",
        "name": "男觀光客",
        "words": "就是啊！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男觀光客",
        "words": "\n",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男觀光客",
        "words": "活動怎麼還不快點開始！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "女觀光客",
        "words": "以鈴奈開啟的夏天，",
        "unit_id": 1212,
        "voice": "vo_adv_5019006_002"
    },
    {
        "type": "dialogue",
        "name": "女觀光客",
        "words": "實在棒極了～！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女觀光客",
        "words": "\n",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女觀光客",
        "words": "呀～",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女觀光客",
        "words": "鈴奈",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女觀光客",
        "words": "怎麼還不出來呀～！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "聚集了很多來支持鈴奈的觀光客呢。",
        "unit_id": 110111,
        "voice": "vo_adv_5019006_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就算是待在舞台旁邊的待機區，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也能感受到熱情～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "有這麼多人一起祈禱的話，",
        "unit_id": 511,
        "voice": "vo_adv_5019006_004"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "晴神大人也能甦醒過來了吧！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n一定",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "會成功的！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這個人數",
        "unit_id": 110211,
        "voice": "vo_adv_5019006_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真的很不得了……！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "鈴奈，",
        "unit_id": 110211,
        "voice": "vo_adv_5019006_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒事吧？　　",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "緊不緊張？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "只要和平常一樣，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "放輕鬆",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就行了？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "當然！",
        "unit_id": 110011,
        "voice": "vo_adv_5019006_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是說，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "美咲妳在緊張什麼啊？　　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真好笑～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因、",
        "unit_id": 110211,
        "voice": "vo_adv_5019006_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為～",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "又還沒開始下雨，",
        "unit_id": 110011,
        "voice": "vo_adv_5019006_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還好吧？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n我會很快的表演完，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喚醒晴吉的！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有各位粉絲在下面，",
        "unit_id": 110011,
        "voice": "vo_adv_5019006_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n還有島上的人們的支持，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我好像比平時還要有活力！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "離活動開演，",
        "unit_id": 110111,
        "voice": "vo_adv_5019006_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還有一點時間。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "只要天氣依然保持這樣就――",
        "unit_id": 110111
    },
    {
        "type": "background",
        "background": "500681"
    },
    {
        "type": "dialogue",
        "name": "女觀光客",
        "words": "咦，什麼？　",
        "unit_id": 1212,
        "voice": "vo_adv_5019006_012"
    },
    {
        "type": "dialogue",
        "name": "女觀光客",
        "words": "突然下起雨了！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女觀光客",
        "words": "\n",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女觀光客",
        "words": "剛才明明還是大晴天的？",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "男觀光客",
        "words": "欸，",
        "unit_id": 312,
        "voice": "vo_adv_5019006_013"
    },
    {
        "type": "dialogue",
        "name": "男觀光客",
        "words": "快看啊！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男觀光客",
        "words": "\n那裡有東西！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "女觀光客",
        "words": "好可愛！",
        "unit_id": 1212,
        "voice": "vo_adv_5019006_014"
    },
    {
        "type": "dialogue",
        "name": "女觀光客",
        "words": "\n是這座海灘的吉祥物嗎？",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊啊！　",
        "unit_id": 110211,
        "voice": "vo_adv_5019006_015"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就只差一點點了說～！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n雖然時間還沒到，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們要不要先開始啊？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "趕快弄一弄，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "讓天氣放晴吧！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "是啊！　",
        "unit_id": 511,
        "voice": "vo_adv_5019006_016"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我們開始活動吧！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "鈴奈小姐，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "請準備――",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "觀光客們",
        "words": "呀啊――！！",
        "unit_id": 1,
        "voice": "vo_adv_5019006_017"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "有人尖叫！？",
        "unit_id": 110211,
        "voice": "vo_adv_5019006_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "該不會……？　",
        "unit_id": 110011,
        "voice": "vo_adv_5019006_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我去看一下！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "果然是雨吉！",
        "unit_id": 110011,
        "voice": "vo_adv_5019006_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你冷靜點！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "見不到朋友，",
        "unit_id": 11611,
        "voice": "vo_adv_5019006_021"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n都是你們",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "人類的錯……！",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你在聽我說話嗎～？",
        "unit_id": 110011,
        "voice": "vo_adv_5019006_022"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "為什麼",
        "unit_id": 11611,
        "voice": "vo_adv_5019006_023"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n我見不到晴吉……！",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不會吧？　",
        "unit_id": 110011,
        "voice": "vo_adv_5019006_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "他好像聽不到人家的聲音。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "怎麼辦！？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "雨神大人！",
        "unit_id": 511,
        "voice": "vo_adv_5019006_025"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n請平靜下來！　",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "再忍耐一下！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "現在在這裡的所有人會進行祈禱！",
        "unit_id": 511,
        "voice": "vo_adv_5019006_026"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "為了晴神大人，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "有很多人從島外聚集至此！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "……！",
        "unit_id": 11611,
        "voice": "vo_adv_5019006_027"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n從島外……？",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "沒錯！",
        "unit_id": 511,
        "voice": "vo_adv_5019006_028"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "我聽說了……！",
        "unit_id": 11611,
        "voice": "vo_adv_5019006_029"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n從島外來的人……",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "鈴奈的友情也被破壞……！",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦！？",
        "unit_id": 110011,
        "voice": "vo_adv_5019006_030"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "你們又想這樣去破壞誰的友情！",
        "unit_id": 11611,
        "voice": "vo_adv_5019006_031"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n這座島上的人",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "全部都不能相信！",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n饒不了你們！",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "如果見不到晴吉，",
        "unit_id": 11611,
        "voice": "vo_adv_5019006_032"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "這座島也沒有存在的意義！",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "等一下！　",
        "unit_id": 110011,
        "voice": "vo_adv_5019006_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雨吉！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n我們",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "已經和好了！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你看，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "她就是之前說過",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家的朋友，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "美咲！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是、",
        "unit_id": 110211,
        "voice": "vo_adv_5019006_034"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是～的？　",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我就是",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "美咲。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n是鈴奈的朋友。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "請多指教？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "請不要生氣，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "和我們兩位淑女",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好好聊一下吧？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好嗎？",
        "unit_id": 110011,
        "voice": "vo_adv_5019006_035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你先冷靜一下～？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "雨吉",
