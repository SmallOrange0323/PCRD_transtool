[
    {
        "type": "background",
        "background": "510200"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔……",
        "unit_id": 106031,
        "voice": "vo_adv_2012014_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "辦不到啊。",
        "unit_id": 106031,
        "voice": "vo_adv_2012014_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是做了不能挽回的事情呀……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n做了絕對沒辦法補償的事情啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我可是想要殺了妳們唷，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想要殺了像這樣願意愛著我的夥伴們。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那是因為妳被洗腦的關係。",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那不是妳的錯唷，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然每次小凱留妳嘴巴上總是講著宰了妳宰了妳，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但妳看！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是都沒有死掉嗎！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像這樣還活跳跳的嘛，",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以完全沒有問題唷！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就當成平時開的玩笑話，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起笑著讓它過去吧……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留♪",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以說，",
        "unit_id": 106031,
        "voice": "vo_adv_2012014_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本就不是開玩笑的啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我是真的打算殺了妳們才接近妳們的，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只是被妳們奇怪的節奏牽著鼻子走才成為了妳們的夥伴啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的。",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不管過程是怎樣，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們還是成為了夥伴對吧？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不管小凱留，",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳有著怎樣的目的。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n每一天又一天，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家一起渡過的幸福時光，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "絕對不是假的。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "交織而成的羈絆，",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "孕育而出的愛情，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既不是夢境也不是幻覺。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n直到現在，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "它們還是在我的心裡頭。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在小凱留妳的心裡面，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有嗎？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果這樣，",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那還真讓人有點遺憾呢。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不對，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我才應該要跟妳道歉……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明小凱留是那麼的痛苦，",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我卻沒有辦法察覺到，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我很抱歉。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還在不知不覺的時候，",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓妳受傷了。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的很對不起，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留明明就還是個孩子。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n年紀最大的我，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明更應該要好好替妳設想才對的。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起……",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "希望妳能原諒我，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼妳要道歉啊，",
        "unit_id": 106031,
        "voice": "vo_adv_2012014_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣不是把立場搞顛倒了嗎……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳到底，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是哪裡冒出來的公主殿下啊？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這也沒辦法的嘛，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟我是做為一名公主被生下來的嘛。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後小凱留妳也一樣，",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不過是在個令人心疼的環境下長大，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以才會稍微有一點走歪了而已……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我們都知道",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳是個能夠愛人，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且能溫柔對待人的好孩子。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就因為是這樣的小凱留，",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我們才會最喜歡妳了。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就像剛剛小可蘿已經說過了的一樣。",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就因為是這樣的妳，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才會想要和妳再次一起聚在餐桌前。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想和妳再創造出",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "更多更多幸福的回憶。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也一樣這麼想的對吧？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最喜歡什麼的，",
        "unit_id": 106031,
        "voice": "vo_adv_2012014_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別這麼簡單就說出口啊……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不久前明明才講過的，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們都忘掉了嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算喜歡上了像我這樣的人，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也只是會被背叛而已啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一群怪人，",
        "unit_id": 106031,
        "voice": "vo_adv_2012014_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞不懂妳們在想什麼……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把邊走邊吃當成目的、",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又隨便、",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且還很可疑的一群人。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明是這樣，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但又為什麼，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會變得這麼的重要了呢？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果妳們，",
        "unit_id": 106031,
        "voice": "vo_adv_2012014_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "至少像其他那些傢伙，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n像那些傷害了我的傢伙們一樣……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是些骯髒，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓人討厭，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是些只會讓人不愉快的存在就好了啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼妳們",
        "unit_id": 106031,
        "voice": "vo_adv_2012014_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會是像這樣子的",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好人啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣的話，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算是我，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是也就只能喜歡上妳們了嗎。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的可以嗎？",
        "unit_id": 106031,
        "voice": "vo_adv_2012014_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像我這種人……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真的可以被誰愛著，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被誰期望，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以和誰在一起嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就連爸爸和媽媽，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都不願意愛我的啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們，",
        "unit_id": 106031,
        "voice": "vo_adv_2012014_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的願意愛我嗎？　",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不懂，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我已經什麼跟什麼……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都完全搞不懂了啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……！",
        "unit_id": 105931,
        "voice": "vo_adv_2012014_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "方才，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "發生了一個相當強大的衝擊呢！　",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟為何事？",
        "unit_id": 105931
    },
    {
        "type": "still",
        "still": "201201401"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我、",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也不知道是什麼！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但是妳待在那個不安全的地方會掉下去的，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n趕快到我們這邊來，小凱留！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可，",
        "unit_id": 106031,
        "voice": "vo_adv_2012014_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我……！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽我的話！　",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來，快點，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要拉妳的手過來了唷！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果不喜歡的話要說啊！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇哇？　",
        "unit_id": 106031,
        "voice": "vo_adv_2012014_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是怎樣啦，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳每次都這樣！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n每次都完全不管別人的想法和心情，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳也站在別人的立場想看看啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起！",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會反省的，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但現在什麼都別講了趕快抓住我的手！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請不要再離開我們了！",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n跟我們一起活下去吧……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我最喜歡的小凱留！",
        "unit_id": 105831,
        "voice": "vo_adv_2012014_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請妳回來吧，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "回到我們大家的身邊！",
        "unit_id": 105831
    },
    {
        "type": "still",
        "still": "end"
    }
]