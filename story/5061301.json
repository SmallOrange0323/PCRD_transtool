[
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哇哇哇，",
        "unit_id": 115811,
        "voice": "vo_adv_5061301_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "魔物的公主殿下，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這完全不是可以問她話的氛圍。",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我並不想跟她戰鬥啊……",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪，",
        "unit_id": 116011,
        "voice": "vo_adv_5061301_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這裡就交給",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "同為公主的人家吧。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "首先，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家會招待她來真步真步王國，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "給她穿可愛的衣服，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n享用甜～甜的點心，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "然後",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "再讓她成為真步真步王國的居民──",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等等公主！",
        "unit_id": 115911,
        "voice": "vo_adv_5061301_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓妳出面事情會變得很複雜啊。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "什麼嘛，",
        "unit_id": 116011,
        "voice": "vo_adv_5061301_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是壞心眼。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖說真步的作戰計畫是最好的方式，",
        "unit_id": 115811,
        "voice": "vo_adv_5061301_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過我想",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大概行不通。",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒關係，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我已經做好心理準備了。",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我們走吧，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真步、",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真琴！",
        "unit_id": 115811
    }
]