[
    {
        "type": "background",
        "background": "501050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}停留在度假期間造訪的村落，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n沒有特別規劃行程的他正在悠閒地消磨時間時──"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "啊，",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "剛好在這裡遇見你！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "和我一起去",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "尋找沉睡在這片土地下的傳說魔具吧！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵，",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這麼臨時的事情，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你會訝異也是正常的……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "在這裡講可能被會「機關」的那些人發現，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們找個隱密的地方說吧。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "其實",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我剛才在尋找有沒有關於前世的書籍。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我覺得這種平時沒機會造訪的地區",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "更有可能存在著不為人知的情報。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "然後呀，",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我在看這本書的時候，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "發現了這張紙夾在書裡！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "來，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "給你看看！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "秘藏的傳說魔具！？破解海底城的謎團！"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n突破所有考驗之人，將能獲得莫大的祝福……"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "聽說只要通過阻擋挑戰者的考驗，",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就能在女神的引導下",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "前往海底城。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎麼樣？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是不是很意外呀！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哼哼哼，",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對吧！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我們",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "「熾炎戰鬼煉獄血盟暗黑團」",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "可是具有吸引命運的力量呢！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特啊，",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這下你明白我為什麼會找你了吧？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就是你想的那樣！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "助我一臂之力，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "取得這些財寶吧！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你、",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你這是什麼話！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你懷疑它是假的嗎！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這麼磅礡有力的字，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "肯定是真的呀！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "既然你心存懷疑，",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_008"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那你就跟我一起來吧。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這個情報究竟是真是假，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就用你的雙眼親自見證！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "第一道關卡的地點和暗號",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "都記載在這張紙上。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們得動作快，不能被「機關」發現了！",
        "unit_id": 113211
    },
    {
        "type": "background",
        "background": "501050"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "歡迎光臨～",
        "unit_id": 1411,
        "voice": "vo_adv_1132001_010"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "兩位嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……「海底城的邀請」。",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_011"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "……！",
        "unit_id": 1411,
        "voice": "vo_adv_1132001_012"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "你們兩個",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "是挑戰者吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "歡迎來到第一關卡。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "不過，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "你們有足夠的決心挑戰凍結考驗嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "想要通過考驗，就必須與時間賽跑。",
        "unit_id": 1411,
        "voice": "vo_adv_1132001_013"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "但是，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "你越是著急就越是痛苦，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "是個相當可怕的考驗……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哼，",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_014"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真是愚昧的問題。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這點程度對我們來說，根本不足畏懼！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "快，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "帶路吧！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "呵呵呵，",
        "unit_id": 1411,
        "voice": "vo_adv_1132001_015"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "這些虛張聲勢還能持續多久呢……？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……聽他這個語氣，",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_016"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "或許已經出現過失敗的挑戰者了呢。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "一旦察覺到危險，你一定要保護好自己逃走，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "明白嗎？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特……！",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_017"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "說得對，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們打從前世就是命運共同體，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "要死也要死一起！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喂，吉格魯特！",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_018"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你這話說得有點太冷淡了吧！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這種情況下，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你應該要說「我絕對不會對你見死不救」吧！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "來吧，",
        "unit_id": 1411,
        "voice": "vo_adv_1132001_019"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "你們有辦法突破凍結地獄嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "什麼……！",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_020"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這是……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "刨冰",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗎！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n怎麼這麼大……！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不過，端出這種尺寸的刨冰，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "到底要我們做什麼啊！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "別擔心，",
        "unit_id": 1411,
        "voice": "vo_adv_1132001_021"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "我們不會強人所難的……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "只是30秒以內沒吃完的話，就算你們輸而已啦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "這次你們是兩個人進行挑戰，",
        "unit_id": 1411,
        "voice": "vo_adv_1132001_022"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n只要其中一個人完成了，就算是過關……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "說吧，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "要不要挑戰呢？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "當然，",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_023"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "接受挑戰！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們才不會畏首畏尾！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "或許，",
        "unit_id": 113211,
        "voice": "vo_adv_1132001_024"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這個刨冰具有什麼特殊意義吧。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "如果吃不完，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就無法負荷海底城的環境之類的，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "可能是這個意思……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "比想像中的還要危險呢……",
        "unit_id": 113211,
