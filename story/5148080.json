    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n史萊姆們",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是在跟怪奇怪靈戰鬥？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n這是什麼情況啊？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊──",
        "unit_id": 131213,
        "voice": "vo_adv_5148080_001"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "被拍到了嗎──",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這個",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是秘密的特訓喔──",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "被發現了嗎──",
        "unit_id": 131111,
        "voice": "vo_adv_5148080_002"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "其實",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我作為史萊姆在特訓喔～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我",
        "unit_id": 131111,
        "voice": "vo_adv_5148080_003"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "雖然能躲過小卡里莎的攻擊──",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n但是紅跟藍經常被打倒，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "所以我才請小美空來幫我修行──",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那是段很充實的時間啊──",
        "unit_id": 131213,
        "voice": "vo_adv_5148080_004"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n託那個的福，妳學會新招式了對吧？",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您說新招式嗎……？",
        "unit_id": 131611,
        "voice": "vo_adv_5148080_005"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯……？",
        "unit_id": 131111,
        "voice": "vo_adv_5148080_006"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "啊，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "沒錯～沒錯～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我跟紅、藍還有",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小卡里莎會融合",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n變成超級史萊姆戰士喔～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "超、",
        "unit_id": 131611,
        "voice": "vo_adv_5148080_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "超級史萊姆戰士……！？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n是很厲害的新招式……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有沒有那時候的照片啊，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "請務必讓我看看……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯──",
        "unit_id": 131213,
        "voice": "vo_adv_5148080_008"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "很遺憾",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n似乎沒有呢──",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是那樣嗎……",
        "unit_id": 131611,
        "voice": "vo_adv_5148080_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那麼，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "可以跟我說那時候的事情嗎……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "請務必當場展示給我看！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "咦……",
        "unit_id": 131213,
        "voice": "vo_adv_5148080_010"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "要、",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "要怎麼辦啊？",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n涅婭小姐？",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯～",
        "unit_id": 131111,
        "voice": "vo_adv_5148080_011"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是可以啦～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "但是下次再合體的話，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n小卡里莎的屁股可能就會爆炸啊──",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那、",
        "unit_id": 131611,
        "voice": "vo_adv_5148080_012"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那是那麼亂來的招式嗎……！？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要使用它時",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要付出巨大的代價呢……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "就是這樣，",
        "unit_id": 131111,
        "voice": "vo_adv_5148080_013"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "所以要暫時封印那招啊～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "抱歉～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過，那是騙人的就是了★",
        "unit_id": 131213,
