    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "伊麗莎白牧場",
        "unit_id": 121311,
        "voice": "vo_adv_6088203_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真的是個",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "很恬靜的好地方呢。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然我起先會害怕牛牛，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但牠們其實都是溫和的好孩子。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我想再",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "多體驗各式各樣的工作。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呃、",
        "unit_id": 121311,
        "voice": "vo_adv_6088203_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這個，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "諧星嘛……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果是演戲的話，我可能會想嘗試。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但要跟真陽小姐搭檔……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好像有點困難，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "還是交給伊麗莎白和\n哥哥吧。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "牧場保全……？",
        "unit_id": 121311,
        "voice": "vo_adv_6088203_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你是說鈴小姐吧！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這樣啊。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這麼說也對。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "她並不是只有在保護起司而已呢。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "感覺是個值得揣摩的角色，我想幫忙。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然應該無法像莉瑪小姐那麼厲害，",
        "unit_id": 121311,
        "voice": "vo_adv_6088203_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但如果我學會伐木的話，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n應該也能幫上咲戀媽媽",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "許多忙對吧。",
        "unit_id": 121311
    }
]