    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "おせち料理の材料集めの旅も、",
        "unit_id": 120711,
        "voice": "vo_adv_5082431_000"
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "もう終わりね……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "色々なことがあったから",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "ずいぶん長く感じたけれど、",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "\n実際は",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "思っていたよりも短い期間だったのね。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "一人旅ってのは",
        "unit_id": 120811,
        "voice": "vo_adv_5082431_001"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "どうしても考え事が多くなるからねえ。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n長く感じちまうものさ。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "イリヤ",
        "words": "色々なことがあったのも",
        "unit_id": 120912,
        "voice": "vo_adv_5082431_002"
    },
    {
        "type": "dialogue",
        "name": "イリヤ",
        "words": "事実じゃがのう。",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "イリヤ",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "イリヤ",
        "words": "奪われた材料を取り返すのは",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "イリヤ",
        "words": "大変じゃったが……",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "あの時は",
        "unit_id": 120711,
        "voice": "vo_adv_5082431_003"
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "本当にありがとう。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "\n二人がいてくれて",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "本当に助かったわ。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "イリヤ",
        "words": "気にするでないわ。",
        "unit_id": 120912,
        "voice": "vo_adv_5082431_004"
    },
    {
        "type": "dialogue",
        "name": "イリヤ",
        "words": "\nわらわはいつもと違った面子での旅、",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "イリヤ",
        "words": "楽しかったぞ。",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "イリヤ",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "イリヤ",
        "words": "おせち料理も美味しかったしのう。",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "アタシも楽しかったよ。",
        "unit_id": 120811,
        "voice": "vo_adv_5082431_005"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\nこれまでしてきた一人旅とは",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "また違った風情があったしね。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "私も、",
        "unit_id": 120711,
        "voice": "vo_adv_5082431_006"
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "みんなと旅ができてよかったわ。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "絶対に忘れたくない、",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "大切な思い出よ。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "なら、",
        "unit_id": 120811,
        "voice": "vo_adv_5082431_007"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "最後のひと踏ん張りといこうじゃないか。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "さあ、",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "行くよ！",
        "unit_id": 120811
    }
]