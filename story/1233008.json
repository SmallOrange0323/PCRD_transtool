    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不管是握手還是坐下，都會好好教你唷～♪",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "這樣一來，你就可以變得更坦率～",
