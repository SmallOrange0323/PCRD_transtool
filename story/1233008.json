    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳在說什麼噁心的話啊！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n誰要做那種事！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯嗯～",
        "unit_id": 123311,
        "voice": "vo_adv_1233008_071"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "一開始都會這樣想吧～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不過你放心～♪",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "姐姐會充分疼愛你的～",
