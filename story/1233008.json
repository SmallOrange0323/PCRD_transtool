    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "那孩子吧～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "我剛才不是也有提過～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_028"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "他是個性格有點扭曲的孩子嗎～？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "不過，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "這就是他口愛的地方啦～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "所以我想說～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "希望能更加了解更多關於他的各種事～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "之類的～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "而且去了解更多有關",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_029"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "在意的人的事情～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "不是也可能變得更～加喜歡對方嗎～？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n嗯呵呵～♪",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
