        "voice": "vo_adv_1233008_067"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n那當然是因為～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n我想到可以再多和小卡里莎",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "加深感情的好方法了呀～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "欸～欸～",
        "unit_id": 123311,
        "voice": "vo_adv_1233008_068"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小卡里莎～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n下次來做狗狗打扮如何呀～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n戴項圈～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "裝上尾巴～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "就從",
        "unit_id": 123311,
        "voice": "vo_adv_1233008_069"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "學狗狗",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "「汪汪！」叫開始吧～♪",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "然後～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "還要握手～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "坐下～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "當然～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "還要會站起來唷～♪",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "什、",
