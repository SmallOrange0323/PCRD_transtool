        "voice": "vo_adv_1233008_073"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "住手……！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n別過來！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "不准過來啊～！",
