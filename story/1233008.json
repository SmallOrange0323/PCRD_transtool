        "name": "卡里莎",
        "words": "該不會是黃的",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳做的好事吧！？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是我沒錯啊～",
        "unit_id": 123311,
        "voice": "vo_adv_1233008_062"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "但也沒什麼關係吧～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "畢竟我們剛才為止都在「那一邊」～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n很熱情地～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "抱在一起呢～♪",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……呃！！",
        "unit_id": 191611,
        "voice": "vo_adv_1233008_063"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n為、",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "為什麼妳會知道剛才的夢……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "該不會，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "這是那陰沉女的什麼魔法！？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯呵呵，",
        "unit_id": 123311,
        "voice": "vo_adv_1233008_064"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "雖然就是這樣沒錯～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不過，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "這種事情怎樣都好吧～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n比起這個……",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "原來是喜歡狗狗的小少爺呀……",
        "unit_id": 123311,
        "voice": "vo_adv_1233008_065"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n唔呵呵呵呵呵呵……♪",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "什麼啦，有夠噁心……",
        "unit_id": 191611,
        "voice": "vo_adv_1233008_066"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳在那邊笑什麼啦，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "這個蠢蛋史萊姆！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯呵呵呵呵呵……",
