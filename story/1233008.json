    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天下午。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當{player}坐在長椅上休息時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n突然有一陣很強的睡意襲來……"
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嗨嗨～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_000"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n在這邊的話，是好久不見呢～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "啊～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_001"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "這次你感覺起來",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "好像記得我的事～？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嘿嘿～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_002"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n我又來玩囉～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "畢竟，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "也算是有約定過嘛～？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "不過～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_003"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n今天呀～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n比起玩～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "重點應該算放在找人上吧～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "對對對～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_004"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n我希望今天真的要找到他～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "因為那孩子，",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_005"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "個性算是",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "有～點扭曲啦～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "搞不好他在這邊",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "也都在使壞也不一定～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "事情～就是這樣囉～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_006"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n你能幫忙找嗎～？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "呵呵♪",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_007"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "瞧你答應得一副理所當然的樣子～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n你這老好人～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "雖然我就是喜歡這一點～♪",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "那我們就出發吧～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_008"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "我猜～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "他大概不會在太熱鬧的地方吧～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n畢竟我們之前去的地方也不對～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "所以囉～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_009"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n麻煩你帶路，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "到安靜的地點吧～♪",
        "unit_id": 123331
    },
    {
        "type": "background",
        "background": "510390"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "這裡是公園～？",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_010"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n有好多",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "樹喔～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n而且，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "這裡感覺好寬廣～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嗯～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_011"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "不如說，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "好像有點太寬廣了？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n感覺找起來好累喔～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "啊～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_012"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "沒關係。",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n我會好好找的～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "雖然我很討厭運動～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_013"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n但畢竟不好好找，就沒有機會找到人嘛～？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "好啦，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "走吧走吧～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "哈啊……",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_014"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "哈啊……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n有夠累的……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "一點也～不好……",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_015"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "呼……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "雖然姊姊她早說過，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "要我多訓練一點體力……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n但真的很懶得運動耶……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "不過，",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_016"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "今天也不能說什麼好懶了……",
