    {
        "type": "background",
        "background": "510200"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "哦～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_017"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "這裡的景色不錯嘛～♪",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "雖然來這邊的路上全是爬坡，",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_018"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "是美中很不足之處啦……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "唉～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_019"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n也不在這裡嗎～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n我們去下一個地方吧～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嗚～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_020"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "唉唉唉……",
        "unit_id": 123331
    },
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "哈啊……",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_021"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "哈啊……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n下一個地方",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "就是這裡～？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嗚哇……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "前面的路",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "有夠長……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "要走這條路喔……",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_022"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "唉……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嗯……",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_023"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "我～想想～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n那就讓我稍微坐一下……",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "……呼～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_024"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "有夠累～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "我好久沒到處走這麼多路了～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "嗯～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_025"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "不如說，",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "也沒辦法呀～？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n比起麻煩的事～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "更想做開心的事～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "人不是應該都會這樣想嗎？",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "如果可以的話，我也想吃吃甜點～",
        "unit_id": 123331,
        "voice": "vo_adv_1233008_026"
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "打扮得美美的～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "疼愛小正太～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "\n",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
        "words": "就這樣懶散過一輩子呀～",
        "unit_id": 123331
    },
    {
        "type": "dialogue",
        "name": "寢亞",
