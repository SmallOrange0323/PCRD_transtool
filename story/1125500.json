[
    {
        "type": "background",
        "background": "509010"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯，",
        "unit_id": 112511,
        "voice": "vo_adv_1125500_000"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "辛苦了。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我在等你呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "所以突然叫我出來，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "有什麼事呢？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "慶祝……？",
        "unit_id": 112511,
        "voice": "vo_adv_1125500_001"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "對喔，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我的生日……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "這樣啊，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "你要幫我慶祝嗎……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "感覺不壞。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……那個。",
        "unit_id": 112511,
        "voice": "vo_adv_1125500_002"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "畢竟我這個人",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "很冷淡。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n或許沒辦法好好傳達給你……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "但是我，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "其實很高興喔。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "所以說，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "謝謝你。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "哇、",
        "unit_id": 112511,
        "voice": "vo_adv_1125500_003"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "謝謝……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "對喔，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "是我的生日。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "這是你特地準備的禮物吧？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "呵呵……",
        "unit_id": 112511,
        "voice": "vo_adv_1125500_004"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "感覺挺不錯的呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "如果要把現在的心情用顏色來舉例……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "應該是「蒼藍」吧。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n就像萬里無雲的天空，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "或是吹拂而過的風一樣，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "非常爽朗的顏色喔。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "對喔，",
        "unit_id": 112511,
        "voice": "vo_adv_1125500_005"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "好像是今天呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "又是練習又是冒險，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "要做的事情太多，自己都忘記了。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不過……",
        "unit_id": 112511,
        "voice": "vo_adv_1125500_006"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "就算我自己都忘記了，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "你卻還記得呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "你這種認真的地方，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我覺得很不錯。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "還有像這樣，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "連禮物都確實準備好的地方也是。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……總覺得很高興呢。",
        "unit_id": 112511,
        "voice": "vo_adv_1125500_007"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "能夠收到祝福就已經很高興了，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n更讓我高興的是你的心意。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我會好好回應你的心意。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n接下來我也會繼續前進，並以此來回應你。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "所以",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "請你好好期待吧。",
        "unit_id": 112511
    }
]