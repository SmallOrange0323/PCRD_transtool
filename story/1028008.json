[
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊～",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總覺得好久沒這樣",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好好放鬆了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝，{player}。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你陪我",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n一起消磨時間。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我很感謝你哦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是真的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總覺得很不可思議呢。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只要和你待在一起，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n感覺就像回到了孩提時代。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的是，",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n非常地開心呢……♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果可以，",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n之後有空的時候再一起玩吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就像今天一樣，兩人一起買買東西，",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n或是聊些無關緊要的事也好。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……說不定",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你並不覺得有趣。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟是和我這種",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n只顧工作的人一起玩。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "談話的內容，也全都和工作有關。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你應該也會認為，",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n既然要一起消磨時間……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能夠和更可愛的女孩子會比較好吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對於自己是個無趣的人這件事，",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我還是有自覺的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但這也是沒有辦法的。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我得要繼承父親事業，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "像個貴族的樣子，在第一線努力工作。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且工作或是算錢之類的事，",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也喜歡得不得了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "以前不是這樣的。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n和青梅竹馬的他，一起玩樂的時候……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我，",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那時候明明更像個鄰家女孩。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算現在再次和他相會……",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n說不定也只會讓他心中的我幻滅吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那樣子，",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n感覺……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n會很寂寞呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那個，{player}？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你那是怎麼回事，好像又在發光了哦……！？",
        "unit_id": 102811
    },
    {
        "type": "still",
        "still": "102800801"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的！",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想說怎麼會這麼吵，竟然是{player}？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你在做什麼啊，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n來櫻庭學院有什麼事？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你啊～",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想你應該知道吧，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們這裡是貴族子弟就讀的豪華私立高中。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "警備也很森嚴，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你在這裡閒晃，可是會被抓的呢？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你看，那些小姐少爺們都露出害怕的表情了。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這裡的學生都是溫室裡的花朵，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n看到衣衫襤褸的平民，可是會反應過度的。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你看，都被說成是「可疑人物！ 」",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n或是「跟蹤狂？」之類了吧。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "現場已經是不只警備人員，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n甚至可能會通報警察過來的氣氛了。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你打算怎麼辦啊，{player}？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "欸……",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n等等，你發什麼愣呢？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你到底有沒有了解現在的狀況？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呀……",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n等等，欸！",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要在眾目睽睽之下抱住我啦！",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我、我知道了啦。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我會想想辦法的，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你先冷靜下來。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不會有事的，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好乖好乖……♪",
        "unit_id": 102831
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510230"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，算了吧。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "反正，就你的情況，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n應該只是運氣不好的路過這裡而已吧。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我就幫你蒙混過去吧，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你可欠我一次人情哦。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "欸～咳咳！",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "各位，請放心好嗎？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個男孩子是無害的，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n並且也沒有做壞事的膽量！",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "至於這個人處置，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就交給身為學生會長的我……",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "請各位不要在意的放學離開吧，不會有事的。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呼。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "太好了。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n大家都乖巧地聽從了我的話呢。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "基本上，我們這裡的學生不知道該說很老實，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n或者說家教都很好。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "先不說這些了，{player}……",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你也真是的，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就是因為行為舉止奇怪，才會被人懷疑。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你可要再\n堂堂正正一點才行。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你怎麼了……",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有事找我，才到櫻庭學院來的嗎？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來不是偶然路過啊。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，你有什麼事嗎？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_041"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你說要帶我去一個令人懷念的地方？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那是哪裡啊。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊、難道說……？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……哦呀。\n抱歉，有人來接我了。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_043"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我明明說了不需要，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還是每天都派轎車來接送呢。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過啊，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_045"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n要是不偶爾走一走，腿和腰都要退化了。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉，賽巴斯欽，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_046"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n今天我用走的回去……",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然你特地來接我，不過不好意思，能麻煩你先回去嗎？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_047"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n抱歉囉～",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n掰掰♪",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那就走吧，{player} 。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_048"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……你不是說要帶我到",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n某個很棒的地方嗎？",
        "unit_id": 102831
    },
    {
        "type": "background",
        "background": "510340"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哇，真的好懷念！",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_049"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這間懷舊零食店，竟然還在呢～♪",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈，一樣還有在賣炒麵麵包。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_050"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然當時完全不覺得奇怪，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過現在想想，為什麼懷舊零食店裡會賣炒麵麵包？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，算了。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_051"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n好久沒吃，所以好想吃……",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "阿婆～",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_052"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n請給我一個炒麵麵包♪",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，您認得出我？",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_053"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是的～我就是以前經常在這附近玩的佐佐木咲戀！",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n好久不見～♪",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "欸嘿嘿。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_054"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n被阿婆稱讚「變漂亮了呢」……♪",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就我個人",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_055"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是沒有什麼改變的實感。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，果然還是變得跟以前完全不同了呢。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而有個一點都沒變的懷舊零食店，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_056"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n反而令人覺得有些開心……♪",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_057"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你也買點零食吧？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你也要為這間店的業績做點貢獻啦，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_058"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你也不希望充滿我們回憶的地方不見吧？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過啊……",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_059"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你怎麼這麼突然，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n想找我一起來這裡呢？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_060"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n實在是令人懷念，我也覺得很開心就是了。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯哼。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_061"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在阿斯特朗總是受到我的照顧，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以這算是表示謝意嗎？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們算是彼此彼此吧。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_062"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你還真是禮數周到呢～",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "算了。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_063"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝，你的這份心意讓我很開心。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是因為這樣的你，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_064"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n才會讓我們關係這麼要好呢。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我當時很貧窮，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_065"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還被大家當成嘲笑……",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你卻向我搭話，",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_066"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n給我炒麵麵包，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還陪我一起玩到渾身是泥巴。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你，{player}。",
        "unit_id": 102831,
        "voice": "vo_adv_1028008_067"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我能與你相遇，實在是太好了……♪",
        "unit_id": 102831
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯～嗯。",
        "unit_id": 190011,
        "voice": "vo_adv_1028008_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這一次，似乎沒有產生不協調的感覺呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也漸漸取回了回憶……",
        "unit_id": 190011,
        "voice": "vo_adv_1028008_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n大概是開始逐漸整合，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n慢慢變回「從前的你」吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過說不定是因為咲戀也很高興……",
        "unit_id": 190011,
        "voice": "vo_adv_1028008_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以變得比較不拘小節",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所帶來結果。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然她總是擺出嚴肅的表情，",
        "unit_id": 190011,
        "voice": "vo_adv_1028008_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n一直都在講有關工作的事情。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但其實也會和孩子一樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1028008_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n會露出天真無邪的笑容呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不不。",
        "unit_id": 190011,
        "voice": "vo_adv_1028008_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是只有對你，她才會摘下「學生會長」還有",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n「大小姐」的標籤……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "作為青梅竹馬的玩伴，",
        "unit_id": 190011,
        "voice": "vo_adv_1028008_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n放鬆地來與你相處。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要好好珍惜喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1028008_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這個結下如此珍貴牽絆的青梅竹馬，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這可是其他人想要也得不到的呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見囉。",
        "unit_id": 190011,
        "voice": "vo_adv_1028008_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要是佔用太多咲戀的開心時刻，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可是會感到不好意思了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天就聊到這裡，我先失陪了。",
        "unit_id": 190011,
        "voice": "vo_adv_1028008_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}～？",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_078"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n怎麼了呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你在發呆哦？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好好清醒一下啦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_079"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "拿去，我在旁邊買了咖啡回來。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "喝吧喝吧。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_080"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n攝取一些咖啡因，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n把瞌睡蟲都趕跑吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是你不保持清醒，我可困擾了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_081"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你或許已經很累了……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但如果你不能陪我，",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_082"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也會感到有點寂寞的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嚼啊嚼。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_083"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……嗯？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，因為肚子有點餓，所以買咖啡時順便買了點東西哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你看，炒麵麵包♪",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_084"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也有買你的份，請用。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_085"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就當作是今天陪我消磨時間的謝禮……♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_086"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你是怎麼了，擺出那麼奇怪的表情……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "炒麵麵包，不合你的胃口嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "欸？",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_087"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n嗯……我是咲戀沒錯哦？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "幹嘛突然叫我的名字？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_088"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你說我們以前有見過面？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "吃了炒麵麵包後，",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_089"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有種令你懷念的感覺？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以就想起了我的事……嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你說「想起來了」……",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_090"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你果然就是「他」嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是我的青梅竹馬？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣啊。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_091"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我內心有種莫名的感覺，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n認為會不會就是那樣呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_092"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你也一樣，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n只是「內心有種莫名的感覺」嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "至於具體的回憶，",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_093"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n大部分都忘掉了是吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟你喪失記憶的症狀還挺嚴重的呢～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒關係，不用急著回想起來。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_094"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我只要能夠確認你就是「他」，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n現在這樣就夠了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我的記憶似乎也有點模糊，",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_095"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "算是彼此彼此吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣啊。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_096"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n原來是這樣啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "太好了……♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_097"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n謝謝回想起來。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不，應該說。",
        "unit_id": 102811,
        "voice": "vo_adv_1028008_098"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能和你再次相會，我真的很開心，{player}……♪",
        "unit_id": 102811
    }
