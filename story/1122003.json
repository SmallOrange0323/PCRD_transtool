[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在逮捕魔導具賣家的數天後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}與霞兩人前往了某個地方。"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼，",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n來回顧一下事件的經過吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "事情的開端是在數天前，",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我和你遭遇了",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "某個奇怪現象而開始的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒錯。",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "接著發現了",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n那個現象是透過使用某種魔導具所引發的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「解放潛藏的力量」。",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那魔導具就是利用這樣的宣傳句子來販賣的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但那是個",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要使用一次，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就會讓人變成像是魔物一樣的",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n來路不明的道具。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "無論是什麼時代，",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總是不斷會有人在追求力量呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過我不認為要到不惜變成那種姿態會是值得追求的力量呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "經過之後的調查，",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們找到了魔導具的賣家，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n並順利",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "將對方逮捕。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n以偵探的身分逮捕了販賣危險物品的犯人。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n名偵探霞的職責",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原本到這裡就結束了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是啊，",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "希望你別笑我喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這次",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "Misty★霞……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我身為魔法偵探的心",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在蠢蠢欲動了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "賣家持有的那個魔導具。",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是個非常危險的東西。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那種東西要是在城鎮裡流通的話，",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "蘭德索爾的和平會受到威脅的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這麼一想，",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我的心情就怎麼都靜不下來。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "明明是希望做為偵探才禁止自己變身的，",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是身為魔法少女的心",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "卻無法壓抑下來。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很滑稽對吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生……！",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我在偵探與魔法少女兩者之間搖擺不定，",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n居然還稱讚像我這樣的半吊子呢，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "多虧你，我做好覺悟了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "走吧，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "目的地就在這前方。",
        "unit_id": 101411
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "根據從賣家身上問出的情報，",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n那個魔導具的原料似乎就是在這裡發現的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "掉在這洞窟裡的碎片……",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n用那些東西所加工製作而成的",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是那個魔導具。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你要小心點，助手先生。",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這裡的路不是很好走——",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哦！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謝……",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謝謝，助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "幫大忙了……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這、",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "公主抱！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n怎、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "怎麼辦？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我現在",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "全身都託付給助手先生了……！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我會不會很重！？　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我會不會很重！？　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我最近",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都沒有變成魔法少女，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以運動不足了對吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不曉得是不是我的錯覺，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我怎麼覺得助手先生的手好像在發抖？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不對……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在發抖的人其實是我？　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊～",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n很感謝你能幫我，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是不是差不多能把我放下來了？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……那個，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……我很重吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是、",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_023"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那就好。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不對，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我並不是在介意體重喔！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是的！　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n既然你是偵探助手的話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那就再多注意一點他人心思的細微變化啊！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真、",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真的嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "太、",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "太好了……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為助手先生很溫柔，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以說不定是在顧慮到我的心情？　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔唔，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好想知道他的真實想法……！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我明明是個偵探，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "怎麼還這麼心浮氣躁啊……！　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真受不了，",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要和你在一起，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總是會讓人分散注意力呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當然，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是好的意思。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看來……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "差不多該要繃緊神經了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這邊傳來了明顯的氣息。",
        "unit_id": 101411,
        "voice": "vo_adv_1122003_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "和那個在魔導具上",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "感受到的邪惡感是一樣的……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
