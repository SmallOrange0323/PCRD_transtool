[
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呼、",
        "unit_id": 128011,
        "voice": "vo_adv_5132308_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呼……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "多、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "多麼驚人的強大。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這就是變得更強的模樣……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "負傷的野獸",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還真可怕呢……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 127911,
        "voice": "vo_adv_5132308_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這也代表",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對方只剩一口氣了。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "勞動和飢餓就是最棒的調味料。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要現在撐過去，",
        "unit_id": 127911,
        "voice": "vo_adv_5132308_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "之後就是烤雞派對了！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "麻煩各位",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再稍微幫我一下下！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……就是啊。",
        "unit_id": 128011,
        "voice": "vo_adv_5132308_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我肚子也差不多餓起來了。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然我不是陛下，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但就讓我好好享用你吧！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐終究也",
        "unit_id": 6111,
        "voice": "vo_adv_5132308_004"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "融入那種氛圍了呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您看起來開心真是再好不過了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐，",
        "unit_id": 6111,
        "voice": "vo_adv_5132308_005"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "要是您有不測，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n我會徹底",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "將金錢和貴重物品等遺物收回來的，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n所以請放心吧。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也給我撿骨啊，",
        "unit_id": 128011,
        "voice": "vo_adv_5132308_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "話說開什麼玩笑，我絕對不會死的好嗎──！",
        "unit_id": 128011
    }
]