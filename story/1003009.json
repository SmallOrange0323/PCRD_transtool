[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——受到怜的邀約，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}在港口附近的海邊與怜一起釣魚。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但怜的動作卻顯得非常僵硬。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……釣不到耶。",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n真奇怪。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明天氣不差，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "海浪也很平穩……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……沒問題。",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一定只是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "魚群們跑到別的地方去了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n照理來說今天應該會有不錯的潮汐才對……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果你能",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n陪我一起耐心等候",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我會很開心的……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "才、",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "才沒",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這回事？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我和平常一樣……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "隱瞞你好像也沒什麼意義。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我果然沒有事能瞞得住你。",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n本來想要",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "用釣魚緩和心情後再和你說的……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但現在這樣，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來是沒辦法的呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……其實前陣子",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "父親派人來找我。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他說希望我",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能夠代替他的名義，前往各地視察。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "與霸瞳皇帝的戰鬥",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為蘭德索爾帶來了極大的傷害。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對王國來說",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "迅速振興是一個重要的課題。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但若要以復興為優先的話，",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就得維持整個大陸的治安。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "然而到了現在，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "人員及資源仍然不足。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以他希望我這個女兒",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n即便是形式上的也好，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "前去視察給眾人看。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若有時間的話",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也去與蘭德索爾外的居民交涉",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n看能不能請他們幫忙協助復興……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這大概也是真正的目的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……真是個任性的人啊。",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也不徵詢我的意願，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他覺得我理所當然的應該照他說的做。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……其實我都懂。",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我應該接下這任務。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "至今，蘭德索爾",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還是有許多為災害所苦的人。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了他們",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而盡其所能的父親，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那樣其實才是正確的吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯……",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "父親是在做正確的事。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該為了人們而出點力。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……但是",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對於要接受那個人的請託，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我心中的某處還是有種不情願。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不像我……？",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣嗎……",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的確呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為我想要幫助人，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為那是正確的事，所以我想去做。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要做為行動的理由，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那樣便足矣。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……是啊。",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我到底在猶豫什麼。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "初次離家時也是……",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為想那麼做、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為認為那樣是對的所以做了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "儘管力量綿薄，但我想幫助人……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這理由就夠充足了對吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……嗯，",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我決定了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我會去視察的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是為了父親而去，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是我自己下的決定。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "認為我任性、",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那不過只是我一時興起的父母們",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n對於接受視察任務的我，一定會擺出",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "『果然我們是正確的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n妳看吧』",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那樣的嘴臉。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能夠有機會告訴他們我不是一時興起的，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就留待下次再說吧",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……謝謝你。",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你總是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在我迷惘和挫折時",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n在身後支持我呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這麼一來都分不清誰是師傅了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "聽你這麼說我很開心。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "弟子總有一天會超越師傅的喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n比起我，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我倒是更希望你變成更有成就的人。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵……",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣好像也不錯。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若在你的門下",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從頭開始審視自己",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也是不錯的修行呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不然哪天",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "加入你的門下好了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "然後",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這不是順口問問的……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "視察……",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可以請你跟我一起來嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這次的視察",
        "unit_id": 100311,
        "voice": "vo_adv_1003009_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不能太多人。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但最近",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "聽說鎮外的魔物有越來越殘暴的趨勢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我一個人的話",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總覺得有些不安……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若有你一起，我就安心多了。",
        "unit_id": 100311
    },
    {
