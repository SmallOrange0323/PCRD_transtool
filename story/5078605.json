[
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "聖学祭の花形、",
        "unit_id": 116411,
        "voice": "vo_adv_5064605_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "全員参加の総合リレーか。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いま目を閉じれば、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "嗚呼、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あのときの光景が目蓋によみがえる。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n風となって走るぼく、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "視界を流れてゆく景色、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "耳朶を打つ歓声……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "…………",
        "unit_id": 116411,
        "voice": "vo_adv_5064605_001"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "お、",
        "unit_id": 116411,
        "voice": "vo_adv_5064605_002"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "おいクロエ君、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なぜツッコんでくれないんだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ユニ先輩走ってないじゃん、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "と殺し屋のような目で言ってくれ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "このままでは、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "まるでぼくの虚言癖ないし",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "妄想癖みたいじゃあないか。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "え……",
        "unit_id": 116211,
        "voice": "vo_adv_5064605_003"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "あ、なんすか？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\nぜんぜん聞いてなかった。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "ちょっと今、",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "目蓋にミフユねえさんの勇姿浮かんでたんで。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "おいおいおい、",
        "unit_id": 116411,
        "voice": "vo_adv_5064605_004"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼかあ寂しいぞ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君はいつだって",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ユニ先輩ユニ先輩と懐いていたじゃあないか。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "遠慮などいらん、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "この小さな胸にとびこんでくるんだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "さあ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "おいで。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "え……",
        "unit_id": 116211,
        "voice": "vo_adv_5064605_005"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "あ、なんすか？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\nぜんぜん聞いてなかった。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "クロエくぅ～ん……！",
        "unit_id": 116411,
        "voice": "vo_adv_5064605_006"
    }
]