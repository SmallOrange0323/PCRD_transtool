        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但是如果熟練了，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
