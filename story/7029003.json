        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不管是為了大家，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是為了我自己。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯嗯。",
