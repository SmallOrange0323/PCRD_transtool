[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "碧運用休息時間，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在和{player}他們有段距離的地方，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和好朋友號召開了數不清是第幾次的反省會。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「妳有興趣的話要不要一起聊個天呢？」",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "──之前我抱著必死的決心，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "打算向露娜這麼說。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我很害怕被露娜拒絕……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因此變得極度緊張。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "結果嘴巴就自己唸起了饒舌……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我……",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一定讓她覺得傻眼了對吧？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為從那之後，",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我就完全沒能和露娜說上話……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我……",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是不是被露娜討厭了呢……！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……好朋友號，",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "怎麼看？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "…………",
        "unit_id": 7211,
        "voice": "vo_adv_7026003_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……啊！",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……也對。",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這種時候更不該獨自煩惱，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "來去找團長商量吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我完成偵查回來──",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哇哇……！",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_010"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "…………",
        "unit_id": 111411,
        "voice": "vo_adv_7026003_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……露娜她",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n睡著了呢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那不好意思，我就在旁邊一起休息……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "欸嘿嘿……",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "露娜",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n緊抱著玩偶入睡呢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這玩偶看來有點舊了，",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n但感覺有細心地在呵護……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然她說過這不是朋友，",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n但對她而言肯定是很重要的存在吧。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長也這樣想嗎……！",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是……",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我擔心會不會因為我……",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n讓露娜",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "感到困擾了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是不是造成你們的麻煩了呢……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦……？",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_021"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}把和露娜相遇後"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n到交情變好為止的事都告訴了碧。"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……原、",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來如此。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n團長和露娜",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n是相遇後過了很久很久感情才變好的啊……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不管是總算能走出家門，",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n還是總算能出門遠行，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n對露娜來說都是很不容易的事……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "即使如此……",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n她還是走到這裡，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也來和我見面了。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……我也一樣。",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我也一樣。",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "明明一直很想交朋友，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n卻遲遲沒有付諸行動，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "直到和團長相遇才鼓起勇氣嘗試。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "成立BB團之後，",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也是反覆地一波三折……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "進三步退兩步……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只能一小步一小步地前進。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "需要花上不少時間才能和他人建立交情的",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n不只是露娜，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實我也是一樣的。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然我很嚮往相遇後就能立刻互相交心的情況，",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但或許雙方一點一滴、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "慢慢走近彼此的方式，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n比較適合我們。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_030"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長，",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_031"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝謝你告訴我這些……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我不會",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "再一個人橫衝直撞",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "乾著急了……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我希望接下來能讓露娜慢慢了解我，",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我也一點一滴地",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "去了解露娜……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "然後，如果有天能和露娜開心地談話，",
        "unit_id": 104011,
        "voice": "vo_adv_7026003_033"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我就很高興了……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聽了{player}的話之後，碧重新下定了決心，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她看著露娜的睡臉，靜靜地泛起了一抹微笑。"
    }
]