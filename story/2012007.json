[
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈呀，",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈呀！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n果然要連發天樓霸斷劍還是有點勉強呀！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別閃了，草野優衣，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "讓我一擊給妳個痛快不就好了～！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "休想得逞！",
        "unit_id": 100311,
        "voice": "vo_adv_2012007_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳夠了吧，",
        "unit_id": 100111,
        "voice": "vo_adv_2012007_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這可是開開心心的歡慶之日唷。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就跟妳說不能搗亂了呀～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個人是……？",
        "unit_id": 104311,
        "voice": "vo_adv_2012007_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　我對她有印象，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好像是和我同為獸人的日和？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "其他兩個人，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一個是優衣的朋友……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還有個是記得叫矛依未嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n是不久前，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "尾狗刀前輩想要抓的那孩子？　",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "到底怎麼回事呀，",
        "unit_id": 104311,
        "voice": "vo_adv_2012007_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這狀況？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n為什麼那個叫矛依未的，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "會和優衣她們打起來了呢？　",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳這傢伙才是，",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "給我適可而止！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "　少在那一直妨礙人了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是那傢伙……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "全都是草野優衣那傢伙的錯，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n只是妳們這些人全部都忘掉了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唔唔～",
        "unit_id": 100111,
        "voice": "vo_adv_2012007_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳不要淨說些人家聽不懂的話啦！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……真是平行線呢。",
        "unit_id": 100311,
        "voice": "vo_adv_2012007_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n再繼續讓妳鬧下去，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就會造成過多的傷害了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也不想對孩子做出些不人道的行動。",
        "unit_id": 100311,
        "voice": "vo_adv_2012007_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "趁我們這兒還能溫柔應對的時候，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "希望妳能趕緊收手。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈哈哈！",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "　好啊不錯呀，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算不溫柔也沒差！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果想要阻止我的話，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看是要一條手還一條腿有種就來拿拿看啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒錯，",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個地方不管是手還腳想砍還是砍得斷的！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是會流血、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "會飽受飢餓之苦、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "會死的世界！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是妳把這裡變成那種世界的，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "草野優衣……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只為了拯救一個人的性命，",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就把靈魂賣給了惡魔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n將那些和平地在理想鄉中過著生活的人們全部打進了地獄，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n讓他們必須得永遠嘗著苦痛……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是、",
        "unit_id": 100211,
        "voice": "vo_adv_2012007_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是在說什麼呢……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n妳究竟",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是知道我些什麼事情呢？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喂～",
        "unit_id": 104611,
        "voice": "vo_adv_2012007_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "從剛剛開始就在亂來的是誰喵～！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "竟把人家的攤子整個轟飛了喵～！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n今天的目標營收都還沒達到啊喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100111,
        "voice": "vo_adv_2012007_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "珠姐！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　稍微幫個忙吧～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們想把那孩子給綁起來，削弱她的力量！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哎呀日和，",
        "unit_id": 104611,
        "voice": "vo_adv_2012007_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好久不見了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "別總是跑出去冒險嘛，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n偶爾也來【動物苑】露露臉或是參加個懇親會之類的喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不是嘛，",
        "unit_id": 100111,
        "voice": "vo_adv_2012007_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為現在熱衷於冒險……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "等下，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "現在不是閒聊的時候吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這附近，",
        "unit_id": 100111,
        "voice": "vo_adv_2012007_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是獸人的居住區？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就只是光顧著邊打邊躲，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "什麼時候竟然打到這種地方來了？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "機會～來了☆",
        "unit_id": 100111,
        "voice": "vo_adv_2012007_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這附近的話我認識很多人，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n大家應該都會願意幫忙的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "畢竟獸人都很重情重義的嘛！",
        "unit_id": 100111,
        "voice": "vo_adv_2012007_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要搗亂也就到此為止了唷，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個什麼",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "諾維姆！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "克莉絲提娜！",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "幫大忙了，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳竟然會願意趕過來呢！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別一副開心的表情。",
        "unit_id": 107111,
        "voice": "vo_adv_2012007_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我可不是因為",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "察覺夥伴的危機，才來幫忙啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是碰巧而已……",
        "unit_id": 107111,
        "voice": "vo_adv_2012007_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可是唯我獨尊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不論何時腦子裡都只會考慮到自己的人唷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只是從那黑色的不明物體附近，",
        "unit_id": 107111,
        "voice": "vo_adv_2012007_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n帶著【慈樂之音】的那群孩子們逃了出來……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "接著在半途聽見不知道誰鬧得挺歡樂的騷動聲，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "才過來瞧瞧樣子的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "黑色的不明物體？",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗚噁～",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那是什麼！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n整座城，漸漸被像爛泥巴一樣的東西覆蓋住了呀！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個是……",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n什麼啊？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "克莉絲提娜。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也不是很清楚。",
        "unit_id": 107111,
        "voice": "vo_adv_2012007_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可能是『闇影』溶解成液態後的集合體",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n的樣子……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也不太懂。",
        "unit_id": 107111,
        "voice": "vo_adv_2012007_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然像是生命體，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但好像無法對話的樣子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂喂！",
        "unit_id": 104311,
        "voice": "vo_adv_2012007_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n別在那邊給我東張西望了呀，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "前陣子結的樑子今天就一次算個清楚啦！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒錯呀～！",
        "unit_id": 101711,
        "voice": "vo_adv_2012007_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "　妳那時竟敢破壞【哞哞自衛隊】的小屋，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n還打傷了大家！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n甚至連孩子都被妳弄哭了，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我絕對不會原諒妳的～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊真是的，",
        "unit_id": 107111,
        "voice": "vo_adv_2012007_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是煩人！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳們想打我是很想奉陪啦，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但現在不是時候！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我要扛妳走囉，諾維姆，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們得迅速遠離這裡了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦、",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊啊……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嘿咻！",
        "unit_id": 107111,
        "voice": "vo_adv_2012007_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真輕啊？妳這傢伙，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "根本是個小鬼嘛！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "先沿著建築物的屋頂逃脫，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n接著和在城外避難的【慈樂之音】會合！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以說，",
        "unit_id": 104311,
        "voice": "vo_adv_2012007_033"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎可能會讓你們逃掉啊啊啊啊啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真琴！",
        "unit_id": 104611,
        "voice": "vo_adv_2012007_034"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n雖然我也搞不清楚狀況，但那黑色的泥沼以驚人之勢流過來了喵，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n總之現在得先讓大家避難才行呀喵～！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我不清楚那是什麼東西，",
        "unit_id": 104611,
        "voice": "vo_adv_2012007_035"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但總覺得有很不妙的感覺呀喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n若來幫忙開店的孩子們，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n被那種東西吞沒了，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們可就沒臉見他們的父母了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咕嗚，",
        "unit_id": 104311,
        "voice": "vo_adv_2012007_036"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "確實不是吵架的時候了啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "給我記住了呀，克莉絲提娜妳這傢伙，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n總有一天我一定會把妳殺得片甲不留的啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會期待那天到來的。",
        "unit_id": 107111,
        "voice": "vo_adv_2012007_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "走囉，諾維姆。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳可要小心點別咬著舌頭了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哇哇，",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_038"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "扛著人別那麼粗魯啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然我不要求",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你得對待我如公主啦～？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊啊！",
        "unit_id": 100511,
        "voice": "vo_adv_2012007_039"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還在想會是誰，原來是克莉絲提娜阿姨呀！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳這陣子到底在哪裡做些什麼事呀，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n【王宮騎士團】的大家都很擔心妳的唷！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦呀茉莉，",
        "unit_id": 107111,
        "voice": "vo_adv_2012007_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好久不見了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "幫我和團長還有小智傳個話吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n說克莉絲提娜直到今日",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也依然愉快地過著每一天呀！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳自己和她們說不就好了嘛！",
        "unit_id": 100511,
        "voice": "vo_adv_2012007_041"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "話又說回來，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我還希望妳能夠趕緊回來的呀！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "克莉絲提娜阿姨一不在，",
        "unit_id": 100511,
        "voice": "vo_adv_2012007_042"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n大家就不知道怎麼搞得",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很尷尬又很奇怪的感覺呀！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_2012007_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是嗎。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來人類真不論是誰都無法獨自一人孤獨活下去呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "克莉絲提娜！",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n抱歉，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "稍微等一下行嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看起來那謎之黑泥沼，",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_045"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都朝著『王宮』的方向流過去了……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "或許是『王宮』那出了什麼事也說不定！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也很在意{player}他們的事，",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我覺得我們應該往那邊去才對！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔呣。",
        "unit_id": 107111,
        "voice": "vo_adv_2012007_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n意外地妳還挺冷靜的在觀察呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不錯不錯。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這主意我跟了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "豈能忍受最終決戰的舞台上竟沒有自己的一席之地呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "華麗地！",
        "unit_id": 107111,
        "voice": "vo_adv_2012007_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "　奏起那最終的樂章吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "光是被謎團給玩在手掌心中，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我已經受夠了這種只能無趣地隨波逐流又東躲西藏的情況！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔！",
        "unit_id": 106113,
        "voice": "vo_adv_2012007_049"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "讓我們這一次，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "以Happy Ending為目標全力以赴上吧……！",
        "unit_id": 106113
    }
]