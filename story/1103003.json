        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我如果這麼說",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會讓你反感嗎……？　",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_050"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那邊海上",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有看到光？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的呢。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "似乎是救援的船……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "太好了。",
