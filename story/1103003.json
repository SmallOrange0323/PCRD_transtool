        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那種事",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "又不是{player}的錯。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "比起那種事……",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n{player}，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你為什麼要一個人對抗魔物？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "別一臉呆樣，",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我是認真在問你。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可是在生氣喔。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "反正因為是{player}，",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我猜你大概是",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一心想要救大家吧……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過{player}要是受傷了，",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有人會",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "替你難過的。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "請你",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "別忘了這件事。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唔唔……\n你、",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你別露出這麼悲傷的表情啦。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也有點",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說過頭了。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那是當然的啊？",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}衝出去的時候，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我可是嚇了一身冷汗呢。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……不過啊。",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}的那種地方，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我真心認為很厲害喔。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "居然不顧自己的危險",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "捨身救人，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這可不是能輕易做到的事。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的，",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不管是你那行動力，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是溫柔的地方――",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "…………",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_041"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "　你問我",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在想些什麼？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我、",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我只是覺得夕陽很漂亮，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不小心看入迷了。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不這麼認為嗎？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……吶，{player}。",
