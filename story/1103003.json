    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_051"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不曉得是來得正好，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是很不巧了……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "現在",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_052"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說這種事",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還太早了呢。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "況且{player}的記憶",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還模模糊糊的。",
