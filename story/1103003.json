        "voice": "vo_adv_1103003_048"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和{player}――",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "今後也",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_049"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能夠一直在一起……",
