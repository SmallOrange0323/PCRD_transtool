        "voice": "vo_adv_1103003_043"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n剛才",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我有和你",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "聊過我們之間是怎樣的關係",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對吧？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我……",
        "unit_id": 110311,
        "voice": "vo_adv_1103003_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "覺得{player}",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是『夥伴』",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "喔。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "時而將背後託付給彼此，",
