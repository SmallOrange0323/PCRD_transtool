[
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "找到了～！",
        "unit_id": 116311,
        "voice": "vo_adv_5064302_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是神祕暗黑組織憂妮們！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這可是大發現！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說也太好笑。",
        "unit_id": 116211,
        "voice": "vo_adv_5064302_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n憂妮們",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "完全復活了嘛。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哼，",
        "unit_id": 116411,
        "voice": "vo_adv_5064302_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "區區的小垃圾還會自我修復，還真是令人不快。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n該說是不愧能四處逃跑到現在嗎。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "魔力的流動甚至比剛才都還要流暢。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "講白一點就是很強嗎？",
        "unit_id": 116211,
        "voice": "vo_adv_5064302_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是啊，",
        "unit_id": 116411,
        "voice": "vo_adv_5064302_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點就是很強。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個～",
        "unit_id": 116311,
        "voice": "vo_adv_5064302_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "打倒之後就復活又變強，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不覺得這個套路很眼熟嗎？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "確實。",
        "unit_id": 116211,
        "voice": "vo_adv_5064302_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n滿滿都是又來了的感覺。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "具體來說合計第三次。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是啊。",
        "unit_id": 116411,
        "voice": "vo_adv_5064302_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n如同被世界的既定法則玩弄一樣，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是無趣。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那我們就必須要",
        "unit_id": 116411,
        "voice": "vo_adv_5064302_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n脫離這名為套路的命運輪迴才行。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "各位，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要連半點碎片都不留，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "徹底擊潰！",
        "unit_id": 116411
    }
]