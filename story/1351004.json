    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "那邊的泳道是游泳專用的，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "水也會變深喔。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "當然會。",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_014"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n只要漸漸增加能做到的事，",
        "unit_id": 106432
