        "voice": "vo_adv_1351004_015"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "就從水中步行開始吧。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n要先習慣水喔。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "沒問題的，",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_016"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "你不用害怕。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "如果你會怕的話，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "那個……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "也可以",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "牽住你的手……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "嗯、",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_017"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "嗯。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我知道了……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "怎麼樣，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "放心了嗎？",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "咦咦……！？",
