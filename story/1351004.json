        "unit_id": 106431,
        "voice": "vo_adv_1351004_004"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "醫生也那樣跟你說了嗎？",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "嗯。",
