        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "是你的話，",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "總有一天一定",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "能克服喔。",
