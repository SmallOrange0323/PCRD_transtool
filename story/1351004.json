    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "不會，",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_024"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我才要謝謝你。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n謝謝你陪我復健。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "不知道是不是因為有跟你聊天，",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_025"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n總覺得和平常不太一樣。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "因為平常",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "就像是在跟",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "自己戰鬥一樣……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "有點孤獨的感覺。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "有你在的話，",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_026"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "該說感覺心情跟身體都很輕快嗎。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n讓我覺得復健很開心……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "所以說，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "謝謝你。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "狀況比之前還要好喔。",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_027"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "但是，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "奇蹟是不會那麼輕易就發生的。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "其實，",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_028"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "剛剛回診的時候，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "醫生跟我說了。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n要像以前一樣",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "進行花式滑冰，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "果然還是有困難",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "的樣子。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "當然，",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_029"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "因為初診時他就這麼跟我說過了，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "所以我明白的。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "不過就算是那樣，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n我還是想著",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "要是有一天",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "能顛覆",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "那個診斷",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "就好了呢。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "啊，",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_030"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "對不起。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我並不是打算說些讓人消沉的話題。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "之前",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_031"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "你有跟我",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "提過，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n許願是「表明想要實現願望的決心」吧？",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "在那之後我想了很多，",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_032"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "最後決定要努力到自己能接受為止。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "不管醫生說了什麼，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我都要",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "努力到最後。",
        "unit_id": 106432
    },
    {
        "type": "still",
        "still": "135100402"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "因為，",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_033"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我很喜歡花式滑冰啊。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "就算沒辦法再做出一樣的跳躍……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我還是喜歡。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "而且在不能滑冰的空白期間裡，",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_034"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我也注意到了",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "很多事情。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……注意到",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "周圍有著願意幫助我的人，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "這件事。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "總之，",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_035"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "不管什麼我都打算去做喔。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "不然，",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "感覺會留下留戀啊。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "所以",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_036"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我就跟哥哥一起開始玩LoA了。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "這可是受了你的影響喔？",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "呵呵，",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_037"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "當然好啊！",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n我很期待喔。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "那麼，",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_038"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我們繼續練習吧！",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "一、",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "二。",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "一、",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "二……！",
        "unit_id": 106432
    },
    {
        "type": "background",
        "background": "500510"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……",
        "unit_id": 135011,
        "voice": "vo_adv_1351004_039"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "辛苦你了。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對不起，",
        "unit_id": 135011,
        "voice": "vo_adv_1351004_040"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嚇到你了。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "剛剛的夢，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是我讓你做的。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……那是因為……",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我想著要是能稍微療癒到",
        "unit_id": 135011,
        "voice": "vo_adv_1351004_041"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "阿賀斗紫布菜的心就好了。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……因為就像我之前說的，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我覺得",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "她有恩於我。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我能像這樣跟騎士先生講話，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也是因為她的自我犧牲。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……夢裡的她……",
        "unit_id": 135011,
        "voice": "vo_adv_1351004_042"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n雖然承受著挫折，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但是看起來很正向。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生還有其他人跟她的聯繫，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "或許成為她的支柱了呢。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "──但是，",
        "unit_id": 135011,
        "voice": "vo_adv_1351004_043"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我也看到了幾個該反省的部分。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "首先，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嘴上說著是復健，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但是看起來卻像是在跟騎士先生玩的部分。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n問題的原因，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "應該是與阿賀斗紫布菜的距離太近了。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不對，",
        "unit_id": 135011,
        "voice": "vo_adv_1351004_044"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這跟騎士先生說也無濟於事。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "雖然還有很多部分，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但我就說到這裡吧。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那麼騎士先生，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "晚點見了喔。",
        "unit_id": 135011
    },
    {
        "type": "background",
        "background": "501033"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生，",
        "unit_id": 135011,
        "voice": "vo_adv_1351004_045"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "阿賀斗紫布菜……",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "差不多該醒來了。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這樣下去，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會感冒。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呼哇……",
        "unit_id": 135111,
        "voice": "vo_adv_1351004_046"
