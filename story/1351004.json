    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……咦，",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "不是玩笑嗎……？",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "對不起，",
