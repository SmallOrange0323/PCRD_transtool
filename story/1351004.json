        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我接下來",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "要去做復健的地方",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "有游泳池。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "那個……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "如果你有空，",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "要一起去嗎？",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "那個，",
