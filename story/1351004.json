        "type": "dialogue",
        "name": "紫布菜",
        "words": "設備的感覺也很棒對吧？",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "呵呵。",
        "unit_id": 106432,
        "voice": "vo_adv_1351004_013"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "因為這條泳道",
        "unit_id": 106432
