        "voice": "vo_adv_1351004_003"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "我沒有惡意。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n因為我沒想到",
        "unit_id": 106431
    },
