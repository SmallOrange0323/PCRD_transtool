        "voice": "vo_adv_1351004_006"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "的心情，",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "去嘗試各種事，",
