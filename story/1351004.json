        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n我覺得跟別人商量自己的煩惱，",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
