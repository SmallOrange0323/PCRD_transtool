        "words": "{player}你",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "怎麼了嗎……？",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "呵呵，",
        "unit_id": 106431,
        "voice": "vo_adv_1351004_002"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
