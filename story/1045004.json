[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在散步的時候，\n與空花偶然相遇了。"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊……虐待狂先生……",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_000"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在、在這種地方等著偷襲空花呢……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "然後把抵抗的空花拖到暗處……嘻嘻。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦？空花要做什麼嗎？",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花正想去咖啡店……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "要、要一起去嗎！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n和虐待狂先生一起去咖啡店嗎！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不是不想……！",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n才不是不想呢！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但是，那個……其實……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊！好刺眼……",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這道光是什麼呀！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "感覺全身發燙……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊啊啊啊！",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "！",
        "unit_id": 104511
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻……",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_006"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在柔軟纖細的身體上，塗滿甜甜的奶油，",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n把水嫩的紅色部分放到上面……流口水。",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀、",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_007"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊啊！？虐待狂先生！？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n什什什、什麼時候開始在那裡的！？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "話說回來，虐待狂先生來都是女生的咖啡店，",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是在尋找新的奴隸吧！？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……只是來喝個茶嗎？",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這、這樣啊……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦！？要跟空花共用桌子嗎！？",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這這這、這不就是併桌嗎！？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不、",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_011"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不是！不是不想一起坐……！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n請……請坐……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "和、和男生同桌而坐，",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_012"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n是空花人生中的第一次……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n好、",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好緊張……！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一、一定要冷靜下來……",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_013"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生，要、要點什麼？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "想、",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_014"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "想、想吃！？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花在這種地方被吃掉的話，",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n就會在空花的心中留下難忘的回憶……！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "想喝！？",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_015"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "也就是說，想喝空花的……！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n突然就要玩得這麼狂野……！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n不、不愧是虐待狂先生！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻、",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_016"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "「我來讓妳體驗比砂糖更甜蜜的事吧」。",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "少年說完，就像品嚐美食般，",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_017"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n來回舔著少女海綿般的柔軟肌膚……流口水。",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "太精采了！",
        "unit_id": 1031,
        "voice": "vo_adv_1045004_018"
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "太讚了！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "\n太驚艷了！！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸……？",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_019"
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "我從剛才就一直在觀察妳，",
        "unit_id": 1031,
        "voice": "vo_adv_1045004_020"
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "\n妳的幻想像呼吸一樣渾然天成，",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "\n希望妳能來我們這裡發揮這樣的才能！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "請、請問您是？",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_021"
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "不好意思。",
        "unit_id": 1031,
        "voice": "vo_adv_1045004_022"
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "\n這是我的名片。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗯……",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_023"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n後宮公主出版社編輯部，",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "官音多義流……！？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "後、",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_024"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "後宮公主出版社……！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這是色情小說界當中，",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n最大間的公司……！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "方便的話，我想跟妳深入聊聊。",
        "unit_id": 1031,
        "voice": "vo_adv_1045004_025"
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "\n有關於讓妳成為小說家的事！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好、",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_026"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好的……！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n一定要的！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "呵呵呵，太好了。",
        "unit_id": 1031,
        "voice": "vo_adv_1045004_027"
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "\n發現妳的時候，我整個人太震撼了。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "\n沒想到我要找的人才就在這裡。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "謝、",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_028"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "謝謝您……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "那麼，進入正題……",
        "unit_id": 1031,
        "voice": "vo_adv_1045004_029"
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "\n好的編輯是作家背後的推手，",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "\n有時候也是助手的角色。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "別看我這樣，我可是個栽培了許多大作家的天才編輯。",
        "unit_id": 1031,
        "voice": "vo_adv_1045004_030"
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "\n我有一些不可退讓的原則。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "為了了解作家們的想法，",
        "unit_id": 1031,
        "voice": "vo_adv_1045004_031"
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "\n我自己也要親自上陣，",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "成為他們幻想的對象呢！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊啊啊！？",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_032"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n為為為、為什麼要脫衣服呢！？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "來吧，對我上下其手吧！！",
        "unit_id": 1031,
        "voice": "vo_adv_1045004_033"
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "把妳的幻想加在我身上吧！！！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸、",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_034"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸欸欸欸！！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "好痛",
        "unit_id": 1031,
        "voice": "vo_adv_1045004_035"
    },
    {
        "type": "dialogue",
        "name": "多義流",
        "words": "！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐、虐待狂先生！？",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_036"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "哇、哇哇哇……！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "為為、為什麼要拉空花的手！？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "哇哇哇哇……！",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_037"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n要、要去哪裡啊──！？",
        "unit_id": 104532
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呼……",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_038"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呼……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生救了空花呢……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "的、的確，剛剛那個人太誇張了……",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_039"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那個……但是，先別說那個了……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n要、要握空花的手到什麼時候……？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不、不是！不是覺得討厭！？",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_040"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "只是那個……空花是第一次和男孩子牽手……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊哇、",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_041"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊哇哇哇……好、好害羞，",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n完全沒辦法正視虐待狂先生的臉……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊！",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_042"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n看、看不見前面……空花要跌倒了！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n要要要、要找個東西抓！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦、咦……這是？",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_043"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n好不可思議的觸感……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生……空花現在抓著什麼東西啊？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生，不要慘叫了，",
        "unit_id": 104532,
        "voice": "vo_adv_1045004_044"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n請回答空花的問題……！",
        "unit_id": 104532
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1045004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你現在看到的，是像夢境的東西唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1045004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想等你醒了之後就會馬上忘記，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以現在不用太在意。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然我之前就覺得空花的幻想力，",
        "unit_id": 190011,
        "voice": "vo_adv_1045004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n非常了不起……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但居然是可以出書的程度呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也想要讀讀看呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1045004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，應該不是什麼正經的書就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說最後你是被抓到什麼地方了？",
        "unit_id": 190011,
        "voice": "vo_adv_1045004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n發出這麼淒厲的慘叫……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀呀，你怎麼滿臉通紅了……",
        "unit_id": 190011,
        "voice": "vo_adv_1045004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "原～來如此，應該是難以啟齒的地方吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被摸到那種地方，",
        "unit_id": 190011,
        "voice": "vo_adv_1045004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你和空花的交往，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也許就不是單純的幻想了呢♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵呵，開玩笑的啦，開玩笑而已！",
        "unit_id": 190011,
        "voice": "vo_adv_1045004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，閒聊就到此為止吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～ ♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_053"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這、這裡是……！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花剛剛睡著了嗎……",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_054"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "該不會是虐待狂先生給空花喝了安眠藥吧……！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐、虐待狂先生剛剛也睡著了嗎……？",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_055"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "怎麼覺得身體好熱。",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_056"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n因為做了害羞的夢吧……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "和虐待狂先生一起在咖啡店裡……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "對、對呀！",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_057"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n從奇怪的人那裡，牽著空花的手逃跑……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生也做了一樣的夢？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "連做夢都不放過空花，",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_058"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "莫非是想把空花的夢也弄得難以啟齒嗎！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "睡著也好醒著也好，",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_059"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花都逃不出虐待狂先生的手掌心呢……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸？啊，是……",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_060"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n是真的要去咖啡店了啊……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那個……其實……",
        "unit_id": 104511,
        "voice": "vo_adv_1045004_061"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花是第一次和男生一起去咖啡店，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n所以請溫柔一點……",
        "unit_id": 104511
    }
