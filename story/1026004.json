[
    {
        "type": "background",
        "background": "500156"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚哇，怎麼會這樣～！",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這、這是騙人的吧？",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n太殘酷了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這太沒有人性了！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你也這麼想吧，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，為什麼愣住了？",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你、你不明白，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我為什麼會受到這麼大的打擊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚嗚。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}剛才幫我把遊戲新作，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n跟高級紅豆麵包禮盒組送過來了，對吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那個貨物的包裹，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你不覺得特別輕嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n遊戲軟體是一種魔法道具，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為使用了特殊的礦石，所以是很重的呦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然我是希望能再稍微做得小一點啦，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為光是搬運就很辛苦了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還有啊……",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n紅豆麵包禮盒組",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也是20個裝，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因此包裹也應該要更大一點才對。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可是你看，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這是兩手就能輕易抱住的尺寸哦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "收到包裹的瞬間，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我就應該要注意到不對勁的……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊啊，已經蓋下領取的印章了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n事到如今要退貨是不行的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "果然沒錯？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且不好好完成配送的話，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}也拿不到送信打工的薪水吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "暫且，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就先這樣收下吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚……你看啦這個。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為遊戲新作要延期發售，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以只放了賠禮的商品而已。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好像是",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "遊戲角色的玩偶。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然也不是不高興，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但我今天明明打算要熬夜玩遊戲的說！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明為此還調整了身體狀態，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n還有生活步調之類的～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "即使如此。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n若是有紅豆麵包的禮盒組，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就能吃甜食減輕壓力……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒想到，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我居然訂錯了的樣子。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這不是高級紅豆麵包禮盒組，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n而是在家就能做出高級紅豆麵包的材料組……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n只放了好像是材料的特製紅豆，跟食譜之類的而已。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然我最喜歡紅豆麵包了，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但要自己做真麻煩啊……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你能代替我幫我做嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不行？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚嗚。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n仔細一看，材料也不齊全呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n少了麵粉和牛奶等等，還需要很多東西。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "首先不收集材料的話，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是沒辦法製作紅豆麵包的樣子。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好、",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好傷心啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然說，是睡昏頭了而訂錯商品的我不好……",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "遊戲也是，如果能把延期的時間，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n拿來製作成更有趣的東西，那我也沒有怨言。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過期待的事情，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n全都被延後了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n還真是沮喪啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚嗚。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "安慰我啦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為了紓解壓力，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n至少陪我玩玩我手上有的遊戲嘛？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n一起來玩一些能通體舒暢的遊戲吧～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "難不成睡著了？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好、好過份！",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n人家正傷心的時候，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你還這樣悠閒地打盹～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呀！？",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_031"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n什、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}在發著光……！",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "510092"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚嗚。",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好累啊……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "已經動不了了。",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_033"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "倒點茶還什麼的給我喝。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還有茶點也是，如果有的話我會很高興的。",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_034"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n快來款待我～因為我今天很努力了嘛。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n可以獲得一些獎勵對吧，呵呵呵♪",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哦，要給我紅豆麵包嗎？",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_035"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "謝謝～嚼嚼♪",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好吃♪",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_036"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為我的體力已經歸零了，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n有甜食吃真高興～！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚～",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_037"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n在能量充滿全身之前，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n讓我稍微躺下來休息吧。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "滾來滾去……",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_038"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n啊～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "果然躺下來好輕鬆啊。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我覺得今天就像走了三個月份的路那麼多哦，",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_039"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n腳的肌肉已經在發出哀號了。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚～咿。",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_040"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n多慰勞我一點～寵壞我吧～♪",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "話說你怎麼直接叫我鈴啦。",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_041"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我們有這麼親密嗎？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然我是無所謂。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過總覺得好像被當成小孩子對待一樣，感覺有點怪，",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_042"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n請像平常一樣叫我森近哦。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還問為什麼，",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_043"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你啊……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是{player}的錯吧～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不要一臉好像事不關己的樣子啊。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對啊，",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_044"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "全部都是{player}的錯……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n為何我要這麼的……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你要負起責任來～",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_045"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n回去時把我抱回家哦。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚哇？",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_046"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你做什麼，{player}？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不要捏我的臉頰啦～！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，不要邊吃邊躺著？",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_047"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為食物碎屑會掉到床上？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那真是抱歉了呢，",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_048"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是我已經動不了了又想吃紅豆麵包所以沒辦法。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚～",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_049"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n掉下來的碎屑我也會撿起來吃掉的，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以饒了我吧。",
        "unit_id": 102631
    },
    {
        "type": "still",
        "still": "102600401"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_050"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但是，我累了啊。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n明明是難得的假日，卻白白地流汗了。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為你說永遠當繭居族是不行的……",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_051"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n還說這是作為去上學的預先練習～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以我才試著從家裡走到學校去。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是中途就累倒，",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_052"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n動彈不得了呢……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "外面太陽曬得火辣辣的。",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_053"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要是中暑就不得了了～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以{player}把我送到了你家裡來。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "如果沒有{player}在的話，",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_054"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我就會那樣",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "橫屍街頭了呢。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大家好偉大呢，每天每天……",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_055"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n都要走過那麼險惡的路程的上學去呢。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然我也覺得，應該要好好地去上學～",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_056"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是真的辦不到～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好疲累……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "走到上學路途的一半就沒有體力了，",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_057"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n更別說是還要上課呢。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "光是想想，",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_058"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就精疲力盡了啦。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯？",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_059"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}你說在還沒習慣前，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要來接送我上下學？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以說，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要我加油？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔嗯。",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_060"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n麻煩{player}你到這個地步，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我也覺得有點不好意思。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為了我，",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_061"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你一直都很賣力呢……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "現在放棄的話，",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_062"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}你的努力也會白費。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那還真是，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有點過意不去啊。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以啊，我從明天開始會努力的。",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_063"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "今天已經，不行了。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不要著急不要著急，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "休息一會休息一會……♪",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……欸嘿嘿。",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_064"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n總覺得床上，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有{player}的味道呢。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有點安下心來，",
        "unit_id": 102631,
        "voice": "vo_adv_1026004_065"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "變得想睡了。",
        "unit_id": 102631
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只要一醒來，就會全部忘記了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "基本上，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我會播放你、以及和你有深刻關聯的對象，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在「那邊」的記憶……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但這次，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我真的很猶豫到底要播放哪個情景呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為你們，一直不斷地重複著同樣的事情。",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "由於變化太不明顯了，反而令人佩服呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你應該什麼都不明白，我就先稍微說明一下。",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你和鈴……森近鈴，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n都是椿丘高校的學生喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且還在同一個班級裡……",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你受了老師的委託，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n去叫繭居在家的鈴來上學。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從此，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們之間的關係就開始了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你千方百計地，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n想讓懶得出門的鈴來上學。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "用「好好來上學就給妳紅豆麵包～」之類的誘餌引誘，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n或是勉強地抱出門之類的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然一開始鈴有所抵抗，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但是漸漸變得能從家裡出門……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n能正常地上學去了喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次播放的記憶，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就是那樣的日子持續了一陣子之後。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "作為預先練習，在休假的日子……",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_078"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n兩人從鈴的家，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n試著走到學校的那天所發生的事呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以這個進度繼續努力的話，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_079"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n鈴應該馬上就能正常地到學校上課了才對。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要是每天好好上學的話，就能鍛鍊腿部肌肉，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_080"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n走路上學也會慢慢變得輕鬆的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是。\n像那樣子，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_081"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n兩人互相鼓勵，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "即將達成目標之前……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "世界的樣貌改變了，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_082"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你們在「那邊」的故事也中斷了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這一點，總覺得很不甘心對吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_083"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n明明只差一點，但卻無法觸及。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，現在放棄還太早了喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_084"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總有一天，你們的故事一定會再度開始的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們會能夠正常地上學，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_085"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n能夠盡情享受青春的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "把那當作目標，",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_086"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再稍微……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "加油一下吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無論何時。",
        "unit_id": 190011,
        "voice": "vo_adv_1026004_087"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n能夠把鈴帶到外面的世界來的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就只有你喔。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500158"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼嚕、",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_088"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼嚕……♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_089"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "睡著了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n嗯嗯，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "感覺好像做了個奇怪的夢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不行啊～又在屋外就這樣睡著了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_090"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然牧場很和平所以沒有問題，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但要是無意間被散步經過的牛或馬踩到的話會死掉的呀。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_091"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "奇怪？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n總覺得，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好溫暖……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……唔哇。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_092"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}，\n為什麼我會睡在你的腿上啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_093"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為我好像睡不好的樣子，所以就讓我膝枕了？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n而且，因為我今天很努力，所以這是獎品……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不對，我並沒有特別努力什麼。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_094"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n今天也很普通地，在房間無所事事的哦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "連應該要做的，牧場的警衛工作也翹掉了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_095"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以，沒有收下獎品的權利呢。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_096"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我要起來了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嘿咻。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "欸嘿嘿。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_097"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n總覺得，睡飽了好舒暢……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明遊戲新作和紅豆麵包禮盒組，",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_098"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n都沒有拿到手呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n卻感覺沒那麼悽慘了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以。",
        "unit_id": 102611,
        "voice": "vo_adv_1026004_099"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n謝謝你了哦，{player}。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……你真的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是個很好的人呢。",
        "unit_id": 102611
    }
]