[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了租一間理想中的海濱小屋，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n靜流與{player}來到了海邊。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人看見了廉價出租房屋的廣告，於是決定租下它。"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "找到了廉價物件是很好，",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……可是，真是傷腦筋。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能用來租房的資金不太夠呢。",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n因為距離我實際規劃的",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "租房日期還有一段時間……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是，",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如此實惠的物件，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n如果現在不租，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一定",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "馬上就會被搶走吧。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真想趁現在快點簽約啊……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦？",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n在這裡？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "原來如此……",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有很多人會來海邊玩，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n或許能一口氣賺上不少……！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真不愧是弟弟！",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "既然如此，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "得回街上準備器具呢！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們快走吧，",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟！",
        "unit_id": 117111
    },
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可麗餅店",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "拉比林斯，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "移動分店！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n開幕囉♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……雖然",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "像這樣氣勢十足地開幕了。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是沒什麼客人呢……",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也是啦，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在蘭德索爾那邊也總是門可羅雀，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看來就算換了地點",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "生意也不會突然變好呢。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "環顧四周，",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "競爭攤販也有不少。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "刨冰和熱帶果汁、",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n章魚燒和炒麵、",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n冰淇淋和……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還有鯛魚燒啊。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "感覺客人全被吸走了呢。",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n畢竟我們的可麗餅",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "無論是味道還是外觀都很普通……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}！？",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你說找客人……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是要幫我招攬客人嗎！？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "謝謝……！",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n竟然為了姐姐做到這種程度，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我真是一個",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "擁有好弟弟的幸福姐姐～～～！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……但是，",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒問題嗎？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你能自己去",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "招攬客人嗎？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒有姐姐陪著沒關係嗎？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐要是陪著你去",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就沒人顧店了呢。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是、",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是……！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那至少，",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要待在我看得見的範圍內喔！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n一定要喔！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "和姐姐約定好囉～～～！",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_018"
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "嗯？",
        "unit_id": 312,
        "voice": "vo_adv_1171002_019"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "什麼事？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "可麗餅？",
        "unit_id": 312,
        "voice": "vo_adv_1171002_020"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "喔喔，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "那邊那個攤位啊。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "不，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "但我現在不是吃東西的時候……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "我不小心把錢包弄丟了。",
        "unit_id": 312,
        "voice": "vo_adv_1171002_021"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n我這樣子根本什麼也買不了。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "什麼？",
        "unit_id": 312,
        "voice": "vo_adv_1171002_022"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "你願意幫我一起找嗎？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n真是幫大忙了……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "真的可以嗎？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "我連掉在哪裡都不清楚……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "嗯，",
        "unit_id": 312,
        "voice": "vo_adv_1171002_023"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "知道了。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n那如果找到了錢包，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "我一定會去買可麗餅。",
        "unit_id": 312
    },
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在做什麼啊？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n看起來像是在海灘上來回繞著……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "八成",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是有人掉了什麼東西，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n然後弟弟就說要和他",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一起找之類的吧。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是像弟弟那樣",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在這麼寬廣的沙灘上找東西，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n根本就是大海撈針嘛。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……唔唔，",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟沒問題吧？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我知道我必須顧店……",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "知道……！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只是默默地看著不幫忙就稱不上是姐姐了嘛！",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟！",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐也來幫你────！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "謝謝你幫我找到錢包。",
        "unit_id": 312,
        "voice": "vo_adv_1171002_031"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n請給我1份……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "不，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "3份可麗餅！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "謝謝惠顧～♪",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呼……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "幸好馬上就找到了呢，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "多虧了{player}，可麗餅也賣出去了，",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n接下來就和姐姐一起……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼？",
        "unit_id": 117111,
        "voice": "vo_adv_1171002_034"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你還要去招攬客人？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……好、",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好的，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那就麻煩你了……",
        "unit_id": 117111
    },
    {
        "type": "background",
        "background": "500160"
    },
