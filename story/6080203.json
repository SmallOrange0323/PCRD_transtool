    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "常夏って感じの晴れた天気なのはいいんだけどさ～",
        "unit_id": 113311,
        "voice": "vo_adv_6044203_000"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "水着のままだと",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "日焼けしまくりそうなんだよね～……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "君はさ、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "日焼けの対策とかって",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "何かしてる？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "も～、",
        "unit_id": 113311,
        "voice": "vo_adv_6044203_001"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "不安になるくらいなら",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ちゃんと予防しなきゃですぞ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "……え、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "私はどうなのかって？　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "まぁ、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "日焼けしちゃっても",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "それはそれで",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nナナカちゃんの魅力がアップしちゃうから、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "別にいいかなって感じ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "分かる！　",
        "unit_id": 113311,
        "voice": "vo_adv_6044203_002"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "よく日焼けはお肌の天敵って言うし",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "気になることもあるけど",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n日焼けで水着の跡が残っちゃった美少女とか",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "もう滾りますな",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "デュフフフ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "え？　",
        "unit_id": 113311,
        "voice": "vo_adv_6044203_003"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "この村に来る前に塗った？　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "効果切れてるよ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nならば新作魔法のターン！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "日焼け止めの魔法は～って",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ああこれ、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n日焼けの魔法だった！？　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ひ、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "光がまぶしっ！？　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "目が！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "目がぁー！！",
        "unit_id": 113311
    }
]