[
    {
        "type": "background",
        "background": "502791"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這傢伙，",
        "unit_id": 100711,
        "voice": "vo_adv_5213097_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是布丁喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是真的有甜味又很好吃的",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "明明外表完全不一樣，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "卻是布丁來的……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "而且還Q彈得不得了喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "因為太Q彈了，",
        "unit_id": 100711,
        "voice": "vo_adv_5213097_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "連宮子的衣服都……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "咦？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n……該不會，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是搞錯了？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可是宮子明明有感覺到，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "衣服整個彈開了喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嚇了一跳來的……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是吃下去之後，",
        "unit_id": 133111,
        "voice": "vo_adv_5213097_002"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "身體發生了什麼異狀嗎……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n材料",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "都是在蘭德索爾採買的，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "而且先前請格蕾斯試吃的時候，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "應該也沒有什麼特別的變化才對……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不，",
        "unit_id": 133012,
        "voice": "vo_adv_5213097_003"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那就是我不夠周到的關係呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n沒能回應公主的期待，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n只能感嘆自己愚鈍，竟錯過了該裝傻的時機。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "唉呀呀。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "格蕾斯，",
        "unit_id": 133111,
        "voice": "vo_adv_5213097_004"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "妳也在嗎！？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不過那時候，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我可沒有期待妳在那方面裝傻就是了……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不",
        "unit_id": 133012,
        "voice": "vo_adv_5213097_005"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不不，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "公主。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "只要擁有超一流的亡靈力，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n被布丁的衝擊，震得衣服彈開個一兩件，根本是理所當然的事。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "對吧，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "宮子前輩？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "真不愧是妳，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "令人敬佩。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯嗯～？",
        "unit_id": 100711,
        "voice": "vo_adv_5213097_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……就是這樣，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子可是很厲害的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "所以妳也應該",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好好尊敬宮子前輩才對！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "要表現尊敬的話，再來一份布丁就可以了喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "要做很多布丁來的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我、",
        "unit_id": 133111,
        "voice": "vo_adv_5213097_007"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我明白了，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "前輩小姐……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我這就再去",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "準備一份。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "宮子完全順著自己的布丁慾，不斷要求續碗，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n結果材料轉眼之間就見底了。"
    }
]