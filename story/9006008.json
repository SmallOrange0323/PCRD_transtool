    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在回家的路上看見mimi發送的通知後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}突然停下來環顧四周。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "學長～♪",
        "unit_id": 1,
        "voice": "vo_adv_9006008_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿，",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在這邊、在這邊！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你現在要回家嗎？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我在這裡",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "埋伏學長呢♪",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我問你哦，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你知道今天是什麼日子嗎？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "什麼嘛～",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來你知道呀。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "mimi有發送通知嗎？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇，",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的耶！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我都沒發現～！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我就是記得呀。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為這一天",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對我來說",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是很重要的紀念日呢！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然和優衣還有怜",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "三個人在一起的時候也很開心，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但學長來了以後，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "阿斯特朗傳奇",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n變得更更更",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好玩了呢♪",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這麼說起來，",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "能在這裡遇見學長",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的是巧合。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當時",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很謝謝你。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的幫了很大的忙。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要互相幫助幫助！",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長連我的口頭禪",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都記住了呢。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在阿斯特朗傳奇裡，",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n學長幫了我好多次。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也想",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "變得更加強大，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "去幫助更多人……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了！",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長碰到困難的時候，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不要客氣，儘管叫我。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不管發生什麼事，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我都會趕過來幫你的！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯，",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "包在我身上！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "到時候",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我會全力為你加油打氣的！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣講",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一副我在等著學長被捲入麻煩一樣，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n好像不太好……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "和平",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還是最棒的。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就算學長沒有碰到困難，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也可以隨時叫我哦♪",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿，",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "希望和學長",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣笑著的和平日子",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n能一直一直",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "持續下去。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你說是吧，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長♪",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦……？",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n你看，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那隻貓……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n是不是從樹上下不來呀？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿嘿嘿，",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真不愧是學長♪",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就該這樣才對！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在那邊等我們一下下哦！",
        "unit_id": 100131,
        "voice": "vo_adv_9006008_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只要和學長在一起，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我就沒有做不到的事情！",
        "unit_id": 100131
    }
]