        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣的話就能從外部存取角色的外觀了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "會有不少人想使用",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "個人製作的資料呢……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "似似花，",
        "unit_id": 106831,
        "voice": "vo_adv_5201077_002"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "辛苦了～",
