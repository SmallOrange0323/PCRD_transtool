    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "什麼？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "又在檢查防護措施嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n妳都會像例行公事一樣找出安全漏洞呢～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然了。",
        "unit_id": 107031,
        "voice": "vo_adv_5201077_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n攻擊漏洞的方法",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可是要多少有多少。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不不不，",
        "unit_id": 106831,
        "voice": "vo_adv_5201077_004"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "像似似花這種實力的攻擊方式一般人很難辦到吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嚴格一點是當然的，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但也不要拼命過頭了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "來，",
        "unit_id": 106831,
        "voice": "vo_adv_5201077_005"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "拿去，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這是慰勞品。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……？",
        "unit_id": 107031,
        "voice": "vo_adv_5201077_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "蛋糕。",
        "unit_id": 106831,
        "voice": "vo_adv_5201077_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這個",
        "unit_id": 107031,
        "voice": "vo_adv_5201077_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要給我？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "對啊？",
        "unit_id": 106831,
        "voice": "vo_adv_5201077_009"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我也拿去給克莉絲他們～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "慰勞品，",
        "unit_id": 107031,
        "voice": "vo_adv_5201077_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我從來沒有想過這種事呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是一樣不知道她在想些什麼……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是──",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──狂真咲先生。",
        "unit_id": 107031,
        "voice": "vo_adv_5201077_011"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "是，",
        "unit_id": 191031,
        "voice": "vo_adv_5201077_012"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "您找我嗎？",
        "unit_id": 191031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我分你一口蛋糕吧。",
        "unit_id": 107031,
        "voice": "vo_adv_5201077_013"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不會吧……",
        "unit_id": 191031,
        "voice": "vo_adv_5201077_014"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "您竟然願意分給我，",
        "unit_id": 191031
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "真是榮幸至極。",
        "unit_id": 191031
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n那我就不客氣了……",
        "unit_id": 191031
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "啊呣……",
        "unit_id": 191031
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "哦，",
        "unit_id": 191031
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "真是好吃……",
        "unit_id": 191031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好吃嗎？",
        "unit_id": 107031,
        "voice": "vo_adv_5201077_015"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "是的。",
        "unit_id": 191031,
        "voice": "vo_adv_5201077_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "身體有什麼變化嗎？",
        "unit_id": 107031,
        "voice": "vo_adv_5201077_017"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "沒有……",
        "unit_id": 191031,
        "voice": "vo_adv_5201077_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 107031,
        "voice": "vo_adv_5201077_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原來如此，",
        "unit_id": 107031,
        "voice": "vo_adv_5201077_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒有下毒啊。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "……難不成這是",
        "unit_id": 191031,
        "voice": "vo_adv_5201077_021"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "在讓我試毒？",
        "unit_id": 191031
    }
]