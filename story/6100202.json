    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "莉瑪小姐說的毛絨絨比賽，",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n究竟是指什麼啊？",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦咦！？",
        "unit_id": 123211,
        "voice": "vo_adv_6100202_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我沒有",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "任何毛絨絨的地方……",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對了，",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只要讓噗吉參加就行了！",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "吶吶，噗吉，",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你下次就去參加吧──！",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "原來如此！",
        "unit_id": 123211,
        "voice": "vo_adv_6100202_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以只要由我來判斷，",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n究竟誰",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "比較毛絨絨就行了對吧！",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "感覺相當有趣呢！",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥也",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "一起當裁判吧♪",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "如果羊先生跟莉瑪小姐比賽，",
        "unit_id": 123211,
        "voice": "vo_adv_6100202_003"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n莉瑪小姐也會變得越來越毛絨絨",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "並且逐漸巨大化嗎！？",
