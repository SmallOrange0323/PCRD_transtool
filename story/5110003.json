[
    {
        "type": "background",
        "background": "500035"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "矛依未等人離開據點後，走在夜晚的街道上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並搜尋著千歌與紡希。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔、",
        "unit_id": 106611,
        "voice": "vo_adv_5110003_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔唔",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咿咿！",
        "unit_id": 106611,
        "voice": "vo_adv_5110003_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你這傢伙！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我宰了你喔……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只是有什麼東西倒下的聲音吧？",
        "unit_id": 106511,
        "voice": "vo_adv_5110003_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是的，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳也太害怕了……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……祈梨，",
        "unit_id": 106511,
        "voice": "vo_adv_5110003_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "剛才是我不應該激妳。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n妳回去據點",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "保護公主殿下吧，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什、",
        "unit_id": 106611,
        "voice": "vo_adv_5110003_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我一點都不害怕好嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "話說，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就靠這群人要面對蘭德索爾的危機，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n反而令人擔心到不敢回去啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "的確，",
        "unit_id": 106511,
        "voice": "vo_adv_5110003_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "偶像、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "幫派成員、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "自稱壞蛋",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "和一般人，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n感覺就像一群烏合之眾呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈，",
        "unit_id": 102913,
        "voice": "vo_adv_5110003_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過這或許",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "確實是滿少見的組合。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n如果我們照常生活，根本沒機會相遇呢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "和這些少見的成員，",
        "unit_id": 106611,
        "voice": "vo_adv_5110003_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥全部都認識，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我反而覺得是小哥有點可怕呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "到底要吃什麼長大才會有這樣的緣分啊？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "會嗎？",
        "unit_id": 106116,
        "voice": "vo_adv_5110003_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我倒是很興奮喔！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳們",
        "unit_id": 106116,
        "voice": "vo_adv_5110003_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都和我的舊識很像。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "給我像在和他們並肩戰鬥一樣，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "感覺還不錯呢。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "舊識？",
        "unit_id": 106511,
        "voice": "vo_adv_5110003_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是啊！",
        "unit_id": 106116,
        "voice": "vo_adv_5110003_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一個是像嘉夜一樣性格急躁的男人！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n還很粗野又煩人，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是個很麻煩的傢伙。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哦，",
        "unit_id": 106511,
        "voice": "vo_adv_5110003_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳這是在兜圈子罵我嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈哈，",
        "unit_id": 106116,
        "voice": "vo_adv_5110003_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不是不是。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "他雖然是這樣的人，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但個性直率，很強很可靠。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n看到嘉夜，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不禁會令人想起那傢伙呢。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511,
        "voice": "vo_adv_5110003_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喔～",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然不曉得對方是何方神聖，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n不過打起架應該會很過癮吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳下次見到他，",
        "unit_id": 106511,
        "voice": "vo_adv_5110003_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "幫我轉告他",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "打手要跟他會一會。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那我也",
        "unit_id": 102913,
        "voice": "vo_adv_5110003_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "和妳的舊識很像嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那當然！",
        "unit_id": 106116,
        "voice": "vo_adv_5110003_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n慈樂之音的",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "製作人是克莉絲提娜不是嗎？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "或許是因為如此，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看著妳，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不禁會令我想起她的身影。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦咦～！",
        "unit_id": 102913,
        "voice": "vo_adv_5110003_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我、",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我和製作人嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "騙人騙人，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們一點都不像呀！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我、",
        "unit_id": 102913,
        "voice": "vo_adv_5110003_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我承認自己多少有點任性，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是和製作人任性到專制的程度相比，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我這還算可愛的吧？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且",
        "unit_id": 102913,
        "voice": "vo_adv_5110003_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "製作人是美人型的不是嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳想想，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我是偶像，所以完全是不同類型呀！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不是那個意思……",
        "unit_id": 106116,
        "voice": "vo_adv_5110003_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是妳勇於朝著自己的信念前進，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "並堅定不移的地方讓我看到了她的影子。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳可是那個克莉絲提娜特別關照的。",
        "unit_id": 106116,
        "voice": "vo_adv_5110003_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "想必她",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "內心中也有這種想法吧。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哼、",
        "unit_id": 102913,
        "voice": "vo_adv_5110003_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哼嗯～",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣啊，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我和製作人",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是嗎。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "或許還不錯呢，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "然後你是",
        "unit_id": 106116,
        "voice": "vo_adv_5110003_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "晶的公主騎士啊。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然是湊巧，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但這裡剛好",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都聚集了和我認識的傢伙",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很像的人！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因此，",
        "unit_id": 106116,
        "voice": "vo_adv_5110003_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這令我感到很懷念很興奮啊。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這雖然是群奇怪的組合，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是待起來感覺並不糟！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106116,
        "voice": "vo_adv_5110003_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個女人到底在哪啊……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖說要找她，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但仔細想想，根本毫無線索啊……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "的確，",
        "unit_id": 106511,
        "voice": "vo_adv_5110003_027"
    },
    {
        "type": "dialogue",
