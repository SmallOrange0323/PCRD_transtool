[
    {
        "type": "background",
        "background": "501050"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "む、",
        "unit_id": 113211,
        "voice": "vo_adv_6044308_000"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "織姫の素質を見抜いた理由が知りたい、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "だと？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "それは説明したではないか。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ああいった人間には",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\nそういう素質があるものだと。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "それでは納得できんのか？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "なっ！　",
        "unit_id": 113211,
        "voice": "vo_adv_6044308_001"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ななな、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "何を言っている！　",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "そんな訳がないだろう！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "私は別に、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "織姫ほど泣き虫だったり",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "気弱なわけではないぞ！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ただちょっと、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "その……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ああもうっ！　",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "この話は終わりだっ！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ふっ、",
        "unit_id": 113211,
        "voice": "vo_adv_6044308_002"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "そうであろう！　",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "熾炎戦鬼煉獄血盟暗黒団団長として、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n私は真なる素質を見抜く",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "眼力を備えているということだ。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "よいかシグルド、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "貴様も修行して",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "この力を身に着けるのだぞ？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "そんな分かりきったことを聞くとはな。",
        "unit_id": 113211,
        "voice": "vo_adv_6044308_003"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "貴様は閃光のシグルド、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "その魂に刻まれた光の波動は",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\nどんな闇も照らし、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "力を与えていくのだ！　",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "どうだ、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "当たってるだろう！",
        "unit_id": 113211
    }
]