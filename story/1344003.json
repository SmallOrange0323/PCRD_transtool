[
    {
        "type": "background",
        "background": "501220"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌逃離了追來的娛樂記者。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一個人在神廟中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "想要集中精神於孕育精靈上，然而──"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼……",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不行，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "完全無法專心……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是丟臉啊。",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為那點事",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就讓內心動搖……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不論是作為偶像",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還是唱喚士，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我都得更加振作才行。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果是像這樣半吊子的我，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "肯定無法孕育精靈…",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我一定",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也讓他失望了吧。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唉……",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "該怎麼辦才好。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然我對蘭法小姐說了師傅什麼的，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但其實差得遠的根本是我才對……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗚嗚……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是不像樣……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "──",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "誰呢？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n明明這裡不太會有人來的──",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "千歌小姐，",
        "unit_id": 1,
        "voice": "vo_adv_1344003_005"
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "妳在這裡吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唔！",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個聲音，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是剛剛的娛樂記者……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有、",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有什麼事嗎。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這裡是神聖的神廟，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你保持安靜……！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "好啦好啦，",
        "unit_id": 1,
        "voice": "vo_adv_1344003_007"
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "妳能快點露面嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "\n要是關在這種地方，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "\n可是會被人臆測些有的沒的喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "要是變成那樣，感到困擾的可會是……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "連其他記者都在！？",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我、",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我知道了！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我會開門的，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請不要那麼用力敲門！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "記者3",
        "words": "哦哦──",
        "unit_id": 1,
        "voice": "vo_adv_1344003_009"
    },
    {
        "type": "dialogue",
        "name": "記者3",
        "words": "那身服裝",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者3",
        "words": "還真好看呢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者3",
        "words": "\n是下次舞台的服裝嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者3",
        "words": "是怎麼樣呢？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者3",
        "words": "告訴我們吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這並不是舞台服裝。",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我現在想一個人集中精神……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "這可不行吧，千歌小姐。",
        "unit_id": 1,
        "voice": "vo_adv_1344003_011"
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "\n身為當紅偶像，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "\n居然想一個人獨處。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者3",
        "words": "沒錯沒錯。",
        "unit_id": 1,
        "voice": "vo_adv_1344003_012"
    },
    {
        "type": "dialogue",
        "name": "記者3",
        "words": "\n所謂的偶像，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者3",
        "words": "必須總是在粉絲看得到的地方才行。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就、",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就算你們這麼說……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我是為了唱喚士的修行而來的。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n如果是要採訪，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "等結束後我會接受的，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以今天能請你們回去嗎？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "難不成",
        "unit_id": 1,
        "voice": "vo_adv_1344003_014"
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "妳有什麼難言之隱嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "\n有什麼虧心事之類的？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "\n要是那樣，我可不能當作沒看到啊……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "什麼事也沒有！",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你們會給村裡的大家帶來困擾的，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n請別再繼續……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "記者3",
        "words": "妳是偶像吧。",
        "unit_id": 1,
        "voice": "vo_adv_1344003_016"
    },
    {
        "type": "dialogue",
        "name": "記者3",
        "words": "\n要是說任性的話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者3",
        "words": "粉絲也不會再追隨妳的喔？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "任、",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "任性？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我嗎……？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "…………",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n總、",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總之，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你們離開！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "……千歌小姐。",
        "unit_id": 1,
        "voice": "vo_adv_1344003_019"
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "\n等妳回到蘭德索爾，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "會好好讓我們採訪對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……是的，",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我保證。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "我明白了。",
        "unit_id": 1,
        "voice": "vo_adv_1344003_021"
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "\n喂，各位，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "走吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "啊～啊，",
        "unit_id": 1,
        "voice": "vo_adv_1344003_022"
    },
    {
        "type": "dialogue",
        "name": "記者2",
        "words": "明明都好不容易到這種地方來了啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "…………唉。",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是的……",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這次又是什麼？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}？",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你為什麼會在這裡……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是、",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是啊，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "當然。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我沒事。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那點程度的事，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我已經習慣了。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……那個，",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "蘭法小姐呢？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這樣啊……",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_029"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "剛才的態度不好呢……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "得向蘭法小姐道歉才行，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還有也要向{player}道歉。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是，",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_030"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我現在，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n似乎沒辦法冷靜地",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "跟他們面對面。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "看著",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_031"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這個人的臉也──",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n真的",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓我很難受。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為什麼我會這麼地",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "無法坦率呢……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_032"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "明明",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也待在蘭法小姐那裡",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就好了……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n比起我，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你待在其他人那裡",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不是更好嗎！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……不對。",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_033"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n那個……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我的事情",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你不必在意沒關係……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "反正",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就算我一個人……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也能孕育出精靈",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "才對。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以，",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_034"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就算",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不請你幫忙也……！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "似乎是",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_035"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "想表達什麼……？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n叫我",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "坦率一點，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好好傳達心情……！？　",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_036"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那種事我辦不到！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n肯定辦不到的吧！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呀啊啊！？",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_037"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "什、",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "什麼！？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n魔力",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "從精靈那裡傳過來──",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "哎呀哎呀……",
        "unit_id": 611,
        "voice": "vo_adv_1344003_038"
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "\n偷偷過來看情況結果是這樣，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "原來",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "原來、",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "如此",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "如此。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "精靈對於無法坦率的那孩子",
        "unit_id": 611,
        "voice": "vo_adv_1344003_039"
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "感到焦急難耐了啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "口中說的",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "都是與真心相反的話語，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "\n那模樣",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "想必很讓人焦躁吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "精靈",
        "unit_id": 611,
        "voice": "vo_adv_1344003_040"
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "本就是尋求內心坦率之人的存在，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "要是內心感到痛苦，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "它們也會在背後推一把的吧……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "\n尤其是現在，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "她還穿著特製的服裝，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "連結也增強了……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "………………",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_041"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哼。",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_042"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有什麼事嗎。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哼。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "別管我了。",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_043"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n好了，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你快回去吧。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我現在想一個人集中精神。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n你很忙的對吧。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不需要擔心我。",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_044"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我才沒有想說希望你待在這裡！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我也不會說什麼希望你哪都別去！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "哎呀哎呀哎呀。",
        "unit_id": 611,
        "voice": "vo_adv_1344003_045"
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "原來",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "原來、",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "如此",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "如此。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "\n那孩子這是",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "進入叛逆期了吧……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "她可是個認真的孩子，",
        "unit_id": 611,
        "voice": "vo_adv_1344003_046"
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "過去應該從沒反抗過周遭的人吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "這大概就是",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "遲來的叛逆期呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你就放著這種不可愛的女生不管，",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_047"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n趕快去其他女生那裡吧。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哼──",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哼。",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_048"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嘴上那樣說，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但我",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是知道的喔。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就是前陣子演唱會的時候。",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_049"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n你明明看了",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望24次，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "卻只看了我23次吧？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "來休息室的時候也是！",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_050"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n你最先向紡希搭話了21次，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "然而對我卻只有20次！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都有這麼大的差別了，",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_051"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你居然還說得出那種話呢！？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哼。",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_052"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "光用講的",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "怎麼說都行。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n用行動來表示啊！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "快點快點，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你看，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你辦不到吧！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一邊說我重要……",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_053"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "卻光會那樣逃避。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果我真的很重要，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在就立刻──",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呀！？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "呵呵呵……",
        "unit_id": 611,
        "voice": "vo_adv_1344003_054"
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "都是因為她那樣子把身子探出去……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "好了好了，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "事情會變得怎樣呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "\n年輕",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "真是好啊……",
        "unit_id": 611
    },
    {
        "type": "still",
        "still": "134400301"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "…………\n……………………",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_055"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "怎麼樣，",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_056"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n你討厭這種",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "任性的女孩子了吧？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "騙人。",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_057"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你騙人。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我不是像紡希那樣",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "時髦又可愛的女生，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n根本完全",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒有魅力。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不可能那樣才對……",
        "unit_id": 134411,
        "voice": "vo_adv_1344003_058"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
