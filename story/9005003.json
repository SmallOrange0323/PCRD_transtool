[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不知該送什麼禮物才好的雪菲，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在蘭德索爾四處徘徊，想要找到一點提示。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "穿戴衣飾、",
        "unit_id": 106412,
        "voice": "vo_adv_9005003_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "實用品和",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可以同樂的東西……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "禮物的形式",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還真是五花八門呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "越想越覺得",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "頭大了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗨，那位愁眉苦臉的小姐。",
        "unit_id": 106811,
        "voice": "vo_adv_9005003_001"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要來份可麗餅嗎？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106412,
        "voice": "vo_adv_9005003_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n拉比林斯達小姐……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哇，",
        "unit_id": 106113,
        "voice": "vo_adv_9005003_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這裡的可麗餅",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的好好吃啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n好吃到舌頭都要融化啦──！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也很適合作為紀念日的禮物喔──！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦咦？",
        "unit_id": 106412,
        "voice": "vo_adv_9005003_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟",
        "unit_id": 104914,
        "voice": "vo_adv_9005003_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "最喜歡可麗餅跟姐姐了呢～",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "送給他當禮物肯定會很開心吧～♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "靜流小姐……！",
        "unit_id": 106412,
        "voice": "vo_adv_9005003_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳知道禮物的事……！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個，",
        "unit_id": 101112,
        "voice": "vo_adv_9005003_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "現在有個特別活動，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n可麗餅店【拉比林斯】",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "將會直接到府製作可麗餅！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣哥哥肯定也會非常開心！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊……！",
        "unit_id": 106412,
        "voice": "vo_adv_9005003_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在推銷……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳們是想要我在紀念日那天跟妳們訂購大量的可麗餅……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，",
        "unit_id": 106811,
        "voice": "vo_adv_9005003_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "送給少年的禮物就決定是可麗餅了！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我將會親自到府",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為他製作一份",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "特大號可麗餅喔～！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不，",
        "unit_id": 106412,
        "voice": "vo_adv_9005003_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，晶，",
        "unit_id": 106113,
        "voice": "vo_adv_9005003_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我已經配合妳唸台詞了，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n差不多可以吃可麗餅了吧～？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "話說回來，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳這做法實在太可疑了，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "她不會",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "上這種當吧。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸，雪菲！",
        "unit_id": 104914,
        "voice": "vo_adv_9005003_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n說到紀念日就會想到姐姐，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "說到姐姐就會想到弟弟！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我這麼說，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳就知道該送什麼了吧！？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……這、",
        "unit_id": 106412,
        "voice": "vo_adv_9005003_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這謎語挺困難的呢……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……呃……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………這個嘛…………",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "抱歉，",
        "unit_id": 101112,
        "voice": "vo_adv_9005003_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雪菲。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n要是不趁這個重要時刻賺錢，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們店的業績會一直慘澹下去……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不得以才出此下策……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喂喂，諾維姆，",
        "unit_id": 106811,
        "voice": "vo_adv_9005003_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳要吃得更津津有味的樣子才行吧～？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那種照台詞唸的呆板語氣達不到宣傳效果啦～！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為我總覺得晶做的",
        "unit_id": 106113,
        "voice": "vo_adv_9005003_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可麗餅……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "吃起來好普通。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好像無法讓我誠心露出好吃的表情……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸欸，雪菲，",
        "unit_id": 104914,
        "voice": "vo_adv_9005003_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "準備個大箱子，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n把姐姐放在裡頭，妳覺得怎麼樣？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n紀念日那天，姐姐會砰～一聲驚喜現身，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "身上還塗了香甜鮮奶油！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個……",
        "unit_id": 101112,
        "voice": "vo_adv_9005003_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雪菲。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我想這裡恐怕毫無參考價值，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還請",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "別當一回事……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃，",
        "unit_id": 106412,
        "voice": "vo_adv_9005003_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n改天我會",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "來吃可麗餅的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "拉比林斯達等人構思的巧妙經營策略沒能釣到雪菲。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n重振精神後，雪菲繼續踏上旅程。"
    }
]