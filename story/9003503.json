[
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "終於來啦，",
        "unit_id": 191611,
        "voice": "vo_adv_9003503_000"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "垃圾貓跟煩人貓！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我要拔掉妳們的鬍鬚，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "拿來當釣魚線啦！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才要",
        "unit_id": 106011,
        "voice": "vo_adv_9003503_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "扁到你哭出來，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n再用寵物史萊姆堵住你的臭嘴，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n讓你沒辦法再狂妄地亂講話，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "死小鬼！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真軌先生，快退後！",
        "unit_id": 100111,
        "voice": "vo_adv_9003503_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你才剛痊癒，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不能再打了……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "……感激不盡。",
        "unit_id": 191011,
        "voice": "vo_adv_9003503_003"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n接下來",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "就交給妳們了……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大家也",
        "unit_id": 102511,
        "voice": "vo_adv_9003503_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "快到安全的地方……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不！",
        "unit_id": 102011,
        "voice": "vo_adv_9003503_005"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n我們也要一起戰鬥喔！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "多虧了那位真軌先生，",
        "unit_id": 102111,
        "voice": "vo_adv_9003503_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n那個男生的魔物手下們應該不能行動了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "而且那個矮冬瓜",
        "unit_id": 102311,
        "voice": "vo_adv_9003503_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "之前已經被我們教訓過一次了吧！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「再把他揍得滿頭包啦～！」",
        "unit_id": 2111,
        "voice": "vo_adv_9003503_008"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "嘖，",
        "unit_id": 191611,
        "voice": "vo_adv_9003503_009"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "別小看我！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "就算沒有那些垃圾魔獸，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我一個人就能對付你們了……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "史萊姆們",
        "words": "噗嚕、噗嚕噗嚕噗嚕……♪",
        "unit_id": 191612
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "喔──",
        "unit_id": 191611,
        "voice": "vo_adv_9003503_010"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你們也在啊。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "那",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "偶爾也來讓你們幹點活吧！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "上吧啊啊！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我一定要保護",
        "unit_id": 102811,
        "voice": "vo_adv_9003503_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這間育幼院和孩子們！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n要上囉，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的，",
        "unit_id": 102511,
        "voice": "vo_adv_9003503_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐！",
        "unit_id": 102511
    }
]