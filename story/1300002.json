[
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和倭一起逃離追兵。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人潛入了"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "位於蘭德索爾地下的賭場。"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "好久沒來這裡了，",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_000"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n果然賭場的空氣很甜美呢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊哈哈，",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_001"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那當然了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n要躲藏起來的話這種不三不四的地方最適合了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "咦？",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_002"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "從外表看不出來，你其實很會玩嗎？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n那可能也不需要我的說明──",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這裡是魔物大賽會場。",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_003"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n一直逃跑的話太無聊了，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "來玩一下吧。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n快過來小子！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "歡迎光臨。",
        "unit_id": 2511,
        "voice": "vo_adv_1300002_004"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n歡迎來到第224屆",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "怪物大賽的會場！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "這位客人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "您要押多少賭金呢？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "當然是，",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_005"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這邊有的錢全部了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我押單勝。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "全額押單勝！？",
        "unit_id": 2511,
        "voice": "vo_adv_1300002_006"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "客、",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "客人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "真是賭徒呢……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗯？",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_007"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "怎麼了小子。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n難道連你也要對我用錢的方式指指點點的？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "真是的，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你們每個人都吵死人了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "聽好了。",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_008"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我們家的錢就是我的錢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "想怎麼花都是我的自由。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "而且如果生活費倍增了，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "若菜也一定會很開心。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "賭博這種東西，",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_009"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就是可能失去的東西越重要才越有趣啦。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "僅有一次的勝負竟然賭上了人生，",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_010"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "呵呵呵，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "超令人興奮的啊……！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈哈哈，",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_011"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那真是太好了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n累積了很多社會經驗呢♪",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那麼，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "下一個比賽是……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "………………",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_012"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗯？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n那是怎麼了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n怎麼會有客人跑進賽道內。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "嘿嘿嘿……♪",
        "unit_id": 911,
        "voice": "vo_adv_1300002_013"
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "嘻嘻嘻……",
        "unit_id": 6311,
        "voice": "vo_adv_1300002_014"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……那些傢伙，",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_015"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是在做什麼。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──喂！",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_016"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "給我馬上讓開！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "好、",
        "unit_id": 911,
        "voice": "vo_adv_1300002_017"
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "好痛痛痛痛！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "\n妳在做什麼啊大姐！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "給我老實說。",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_018"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n你們剛剛是不是打算在賽道中動手腳？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n想出老千？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "出、",
        "unit_id": 6311,
        "voice": "vo_adv_1300002_019"
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "出老千！？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "才、",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "才沒有那個打算呢。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "要找碴也該適可而止吧！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "\n我們是在賽道拍紀念照……",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "沒有做其他事！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "妳這傢伙才是",
        "unit_id": 6311,
        "voice": "vo_adv_1300002_020"
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "明明沒有證據還突然抓住別人的脖子！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "\n快為妳的失禮道歉！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "小子你安靜！",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_021"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……我啊，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "最討厭的就是賭場被搗亂了！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "在這種地方，",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_022"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就不要做會令人懷疑的舉動，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我是在教你們難道不懂嗎，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這群蠢貨！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "妳說什麼！",
        "unit_id": 911,
        "voice": "vo_adv_1300002_023"
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "\n就說我們什麼都沒做了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……想吵架嗎。",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_024"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊啊啊啊啊啊！？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "喔喔喔喔喔喔！？",
        "unit_id": 911,
        "voice": "vo_adv_1300002_025"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊啊啊啊啊啊啊啊啊啊！？",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_026"
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "喔喔喔喔喔喔喔喔喔喔！？",
        "unit_id": 6311,
        "voice": "vo_adv_1300002_027"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "哇哇哇哇……！",
        "unit_id": 2511,
        "voice": "vo_adv_1300002_028"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n怎怎怎怎怎麼辦……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n這樣沒辦法開始比賽啊……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "小子。",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_029"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n不要妨礙我們",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "快讓開！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "沒錯，",
        "unit_id": 6311,
        "voice": "vo_adv_1300002_030"
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "妨礙到我們吵架了！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "\n就叫你滾開了小伙子！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "喔喔喔喔喔喔喔喔喔",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "喔！？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這傢伙，",
        "unit_id": 130012,
        "voice": "vo_adv_1300002_031"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "誰准你這樣吼我的同伴了！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊啊啊啊啊啊啊啊啊",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊啊啊！？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "啊啊！",
        "unit_id": 2511,
        "voice": "vo_adv_1300002_032"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "小哥被夾在啊跟喔的中間了……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "不行啊小哥，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "待在那邊會有生命危險！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n小哥，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "小哥！？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "啊啊……！",
        "unit_id": 2511,
        "voice": "vo_adv_1300002_033"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n被夾在中間，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "小哥的眼神開始渙散了……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "啊啊……！",
        "unit_id": 2511,
        "voice": "vo_adv_1300002_034"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n被夾在中間，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "小哥的表情",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "變得像準備等死的人一樣……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "嗯？",
        "unit_id": 911,
        "voice": "vo_adv_1300002_035"
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "怎麼了小哥。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "\n為什麼突然僵住了。",
