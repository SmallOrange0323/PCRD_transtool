[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在聳立天際的露娜之塔下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有三個人影仰望著那遙遠的頂端。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "終於來到了",
        "unit_id": 104611,
        "voice": "vo_adv_7020000_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "露娜之塔喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這肅穆的氣氛，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "讓我的尾巴不斷感應到，來這裡肯定沒錯喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦哦～",
        "unit_id": 103311,
        "voice": "vo_adv_7020000_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "實在太高了，完全看不見塔頂的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我本來只有想像它差不多像王宮那麼大，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以好驚訝。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然有點嚇人，",
        "unit_id": 103311,
        "voice": "vo_adv_7020000_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但只要在這裡爬到最後，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我一定也能",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "抵達搞笑的頂點啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以說了，",
        "unit_id": 103311,
        "voice": "vo_adv_7020000_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就拜託你帶路囉，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真抱歉突然在你路過的時候把你帶過來喵，",
        "unit_id": 104611,
        "voice": "vo_adv_7020000_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "其實我是聽傳聞說這座塔裡",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有著不得了的寶物喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那一定就是",
        "unit_id": 104611,
        "voice": "vo_adv_7020000_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "究極鯛魚燒的食材，不會有錯的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我對這座塔並不熟悉喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以我去問真陽",
        "unit_id": 104611,
        "voice": "vo_adv_7020000_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有沒有認識對這座塔很熟悉的人，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n她就說了你是不二人選喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我之前聽莉瑪莉瑪說，",
        "unit_id": 103311,
        "voice": "vo_adv_7020000_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "她有和老哥你們",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一起爬上去過，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以不好意思啦，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "拜託你幫忙我們一下。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且，",
        "unit_id": 103311,
        "voice": "vo_adv_7020000_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有老哥你在的話，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我搞不好有機會看到喔。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看到小希希真正的實力……",
        "unit_id": 103311,
        "voice": "vo_adv_7020000_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好啦，",
        "unit_id": 104611,
        "voice": "vo_adv_7020000_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒時間站著聊天了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在我們還處在這裡時，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "食材搞不好",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n已經被人搶走了也說不定喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你為什麼露出那麼質疑的眼光喵？",
        "unit_id": 104611,
        "voice": "vo_adv_7020000_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你該不會是在想",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "除了我以外才沒有人",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n會來找鯛魚燒食材喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "天真，太天真了喵！",
        "unit_id": 104611,
        "voice": "vo_adv_7020000_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "究極鯛魚燒的價值，等同於金銀財寶喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n它肯定不分晝夜都被全世界的盜賊和冒險者覬覦著喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀？",
        "unit_id": 103311,
        "voice": "vo_adv_7020000_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥難得會說消極的話呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為他經歷過這座塔喵。",
        "unit_id": 104611,
        "voice": "vo_adv_7020000_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我想他應該是知道這座塔的危險，才會那麼說吧，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但沒問題喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對啊對啊。",
        "unit_id": 103311,
        "voice": "vo_adv_7020000_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有我和小希希在，就沒什麼好怕的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 103311,
        "voice": "vo_adv_7020000_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你該不會其實不太想登塔吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真拿你沒辦法喵。",
        "unit_id": 104611,
        "voice": "vo_adv_7020000_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "既然如此，作為請你幫忙的酬勞，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我會最先請你吃究極鯛魚燒喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哼哼，",
        "unit_id": 104611,
        "voice": "vo_adv_7020000_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣你應該有幹勁了喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我就不聽你的回答了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那我們就出發喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，{player}被兩人強硬說服，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和她們一起去登塔了。"
    }
]