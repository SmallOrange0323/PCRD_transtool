[
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "やあ後輩。",
        "unit_id": 111011,
        "voice": "vo_adv_6023301_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "学園生活を満喫しているかね。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n学びとは人類に許された至高の娯楽だ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n君も存分に愉しむといいが……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "興味を持った科目はあるか？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ほう……",
        "unit_id": 111011,
        "voice": "vo_adv_6023301_001"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "目が高いな、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "同志。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n誤解を恐れず抽象化すれば、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "文系とはすなわち浪漫の学問。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n行間に秘められた浪漫との邂逅……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あー、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "話は長くなるがいいね？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "左様か……",
        "unit_id": 111011,
        "voice": "vo_adv_6023301_002"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "まあ結構、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "学問に貴賤はない。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくも多少は嗜む。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "だがね、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "傾向として、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼかあ理系の学者とはどうも衝突しがちだ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君とはそうならないことを切に祈っているよ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "たいく……",
        "unit_id": 111011,
        "voice": "vo_adv_6023301_003"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "え、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "体育？　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あの、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "えっちらおっちらするやつ？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ああ、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君ら一般生徒はそんな授業もあるのだったね。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "……え、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あれ要る？　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ただの合法虐待じゃん、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "撤廃撤廃！",
        "unit_id": 111011
    }
]