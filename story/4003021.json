    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這場",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【美食殿堂】吃遍之旅",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也終於來到第10回大關了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "前一次是海底，",
        "unit_id": 106012,
        "voice": "vo_adv_4003021_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次是登山啊……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以眼前才會聳立著一座光看就不普通的山峰是吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不愧是小凱留！",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次的舞台就是……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以一口氣品味四季的山峰☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "美食不可或缺的就是",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當季特色，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "時令美味！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現採食材，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且還能一次同時品嚐，這種好事……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "流口水♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，",
        "unit_id": 106012,
        "voice": "vo_adv_4003021_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "口水流下來了啦口水。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道妳帶我們過來的原因了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還有妳背著堆積如山的採山菜工具的原因也明白了呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿……♪",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為我還是想最大限度地享受現採的美味啊。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且這座村莊",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "以盛產白米而出名哦♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿斯特賴亞大陸第一的評價",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可不是浪得虛名！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡有滿滿的清澈流水",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和適合栽種稻米的土壤。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "執掌四季、",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "帶來豐饒的妖狐傳說呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼啊，",
        "unit_id": 106012,
        "voice": "vo_adv_4003021_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個傳說？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下詢問了村裡的人……",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這座山中似乎住著狐狸大人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠擁有職掌四季的力量。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "村子能以盛產白米繁榮，",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也是那位白狐大人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所帶來的豐收而成……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下是這樣聽說的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是博學呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "村裡的人都是稱呼為御狐大人",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或是狐狸神明大人之類的就是了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "狐狸神明大人……",
        "unit_id": 106012,
        "voice": "vo_adv_4003021_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留？",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不，",
        "unit_id": 106012,
        "voice": "vo_adv_4003021_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼事都沒有。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最近狐狸的狀況似乎很奇怪……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n村民們好像也很困擾。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以的話我也想解決這件事呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好啦，",
        "unit_id": 106012,
        "voice": "vo_adv_4003021_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然都來到這裡了也不可能一個人回去嘛。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就奉陪吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇♪",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，謝謝妳！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡好像修了參道，",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只要沿著參道前進，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎就能夠不迷路地直達山頂呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼就以山頂為目標……",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "Let's ",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "hiking☆",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "502140"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還真是奇妙的山景……",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這座山，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "隨著位置不同，季節也不一樣呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來這一帶",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是春季啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n稍微摘點山菜吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡剛好還有筍子……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真棒呢！",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "立刻開始採收吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有這些的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該能夠烹調出完整的四季豪華套餐！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們要採也別採過頭了喔……",
        "unit_id": 106012,
        "voice": "vo_adv_4003021_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "風是不是變強了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "突然開始颳起暴風雪了耶！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這寒風，",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "令挖筍子的手都凍僵了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "品、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "品味四季，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是指如此嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下還是第一次",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "同時體驗到暴風雪和櫻花雨……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔唔，",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也好……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冷？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "別說是冷，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺似乎還逐漸變暖了……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可！",
        "unit_id": 106012,
        "voice": "vo_adv_4003021_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是幻覺啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不能睡，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會死的！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "打起精神醒過來──！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這並不是幻覺。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n氣溫似乎確實在提高……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不知道為什麼暴風雪完全停了……",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好溫暖，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不對，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不覺得變熱了嗎！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種異常氣象是怎麼回事！？",
        "unit_id": 106012,
        "voice": "vo_adv_4003021_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n說是品味四季，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但我期待的並不是這種的啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐、",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看那裡！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "妖狐",
        "words": "────",
        "unit_id": 18411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就是",
        "unit_id": 106012,
        "voice": "vo_adv_4003021_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "住在這座山裡傳說中的狐狸？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還真是露出了很明顯的敵意……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚哇！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳沒事吧！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……狐狸",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "往山頂的方向去了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來確實是擁有",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "執掌四季的力量……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從氛圍看來，牠似乎已經失去了理智。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣下去，",
        "unit_id": 105812,
        "voice": "vo_adv_4003021_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "山會被搞得亂七八糟的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們必須平息那隻狐狸的怒氣……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不愧是",
        "unit_id": 106012,
        "voice": "vo_adv_4003021_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "蘭德索爾的公主，這話由妳來說很有說服力呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果妳右手沒有緊緊握著山菜，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會更帥氣就是了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐的發言",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也有道理。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所謂季節紊亂，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不只是影響山裡環境……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對村裡的稻作",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "多少也會帶來影響吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有時候",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "神明大人也會",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "心情不好而發怒吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了村民們著想，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也不能放著不管。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也是",
        "unit_id": 106012,
        "voice": "vo_adv_4003021_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "特地跑到這麼遠的地方來，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可不想空手而歸啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "況且……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "狐狸神明大人這個稱謂……",
        "unit_id": 106012,
        "voice": "vo_adv_4003021_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可能是我太多心了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但或許",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和陛下",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有什麼",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "關聯……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然那隻狐狸大人",
        "unit_id": 105913,
        "voice": "vo_adv_4003021_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是被歌頌為傳說的存在，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n恐怕",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一般的方法是行不通的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請千萬小心謹慎。",
        "unit_id": 105913
    }
]