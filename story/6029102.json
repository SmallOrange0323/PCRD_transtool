        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聖誕裝飾真的好美。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "果然！",
        "unit_id": 111611,
        "voice": "vo_adv_6029102_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說到聖誕節就會想到聖誕樹呢！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n聖誕燈飾一閃一閃的，好漂亮。",
