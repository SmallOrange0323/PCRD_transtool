[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……今天似乎也睡得很沉呢。",
        "unit_id": 102913,
        "voice": "vo_adv_5084628_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不知道你現在做著什麼樣的夢呢？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "自從聽說你持續沉睡以來，我就一直想著，",
        "unit_id": 102913,
        "voice": "vo_adv_5084628_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你今天會不會醒過來呢？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會不會用平時的溫柔笑容，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n對著我說早安呢？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我一直等著你啊……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好──！",
        "unit_id": 102913,
        "voice": "vo_adv_5084628_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天就為了你，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n獻出滿懷我心意的重要歌曲吧！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你一定會想馬上醒過來的！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我啊，",
        "unit_id": 102913,
        "voice": "vo_adv_5084628_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "和你在一起總是很開心……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "心情會變得很溫暖。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只要看著你的笑容，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我就也能自然而然地露出笑容……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要快點回來喔？",
        "unit_id": 102913
    }
]