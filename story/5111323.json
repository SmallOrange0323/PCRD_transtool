[
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "喔、",
        "unit_id": 17212,
        "voice": "vo_adv_5111323_000"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "喔喔喔、",
        "unit_id": 17212
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "喔喔喔喔喔喔喔！",
        "unit_id": 17212
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘖，",
        "unit_id": 124911,
        "voice": "vo_adv_5111323_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還想說是個討人厭的瘋子，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒想到還挺有毅力的嘛。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 124811,
        "voice": "vo_adv_5111323_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果只論意志的堅強程度，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n他應該超越了我們至今遇過的強敵。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們和這傢伙直到最後都沒能相互理解。",
        "unit_id": 125011,
        "voice": "vo_adv_5111323_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我承認他比誰都還要耿直！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "呦～",
        "unit_id": 106211,
        "voice": "vo_adv_5111323_004"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆，很帥喔。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n那麼，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳要放過他嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼可能！",
        "unit_id": 125011,
        "voice": "vo_adv_5111323_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "手下留情的話，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對亞斯來太失禮了！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我要像個壞蛋一樣，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "獲得壓倒性的勝利！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真不錯，",
        "unit_id": 106211,
        "voice": "vo_adv_5111323_006"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這樣才是未來的大壞蛋。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還用你說！",
        "unit_id": 125011,
        "voice": "vo_adv_5111323_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你也來吧！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n讓我們這組大壞蛋組合",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "爽快地了結這一切！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "收到，",
        "unit_id": 106211,
        "voice": "vo_adv_5111323_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就聽諾維姆妳的。",
        "unit_id": 106211
    }
]