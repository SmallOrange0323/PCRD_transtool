    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哼哼哼，",
        "unit_id": 125212,
        "voice": "vo_adv_6114103_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "瞧我這身打扮",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼樣啊？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這個兼具實用性與功能性的",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "完美服裝。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "無論遇到",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n任何難題，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都不足畏懼！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我真的太滿意了！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼！？",
        "unit_id": 125212,
        "voice": "vo_adv_6114103_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我、",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我竟然會出這種糗態……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不、",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不是的！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我想說都換了新服裝，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就來吃個甜食，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "激勵自己一下……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯唔",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "──快、",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "快住手！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "別替我拿手帕擦掉啦！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊，",
        "unit_id": 125212,
        "voice": "vo_adv_6114103_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是那個……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哈哈，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "寫了品名的筆記啦。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n咖啡廳的菜單",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "品項豐富，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且每個名字又很長……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我一直記不住……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下願意協助我記住嗎？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對吧，",
        "unit_id": 125212,
        "voice": "vo_adv_6114103_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就是說啊！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "尤其是這個圍裙！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n甚至連衣襬的部分都縫得非常細心，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "耐穿又具功能性──",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "抱、",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "抱歉，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "把衣擺掀起來",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很不端莊呢，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哈哈……",
        "unit_id": 125212
    }
]