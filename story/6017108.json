[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "除了咲戀小姐和可可蘿以外，",
        "unit_id": 109911,
        "voice": "vo_adv_6017108_000"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n蘭德索爾還有很多妖精呢。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "在露格尼卡，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "妖精是不會走在街上的……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "……嗯。",
        "unit_id": 109911,
        "voice": "vo_adv_6017108_001"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n真的，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "蘭德索爾",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "對我而言",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是一個奇蹟般的國家――",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "在這裡，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "能認識你們幾位",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真的是太好了。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "的確",
        "unit_id": 109911,
        "voice": "vo_adv_6017108_002"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "和其他種族比起來並不多，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不過還蠻常在路上看到喔？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n當然，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也有可能是因為我特別在意才這麼覺得。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "原來是這樣呀。",
        "unit_id": 109911,
        "voice": "vo_adv_6017108_003"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "有機會的話",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真想去瞧瞧。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "當然，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也要找咲戀小姐和可可蘿一起去。",
        "unit_id": 109911
    }
]