[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對晶甚感好奇的諾維姆，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n決定要向同為七冠的誓約女君探聽她是個什麼樣的人。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "對了，",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我從以前就一直很好奇……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n晶她",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "究竟是個什麼樣的人啊？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "什麼啊，",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_001"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "這種不切實際的提問。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n她是個什麼樣的人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "就如同妳看到的那樣啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "是想要阻止我們野心的敵人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我不是這個意思啦～",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_002"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "妳在現實中也曾見過她吧？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那傢伙",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "一直都是那種調調，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我根本搞不清楚她的個人品。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "關於這一點，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我想克莉絲提娜",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "應該會知道吧？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "例如她是個正義感很強，",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_003"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "但在現實中卻超惡質的傢伙。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "或者是會抱著布偶睡覺啦，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喜歡的點心是馬卡龍啦，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n像這類的資訊也行喔！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "別讓我想像奇怪的畫面！",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_004"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n她絕不會有",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "那種既夢幻又軟綿綿的嗜好……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "我認為不會。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "不過，她既然經營著可麗餅店，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "搞不好私底下……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不、",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_005"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不用想得那麼認真啦！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "如果不知道她的私生活，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "說說她在工作場合的狀況也行。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n妳有想到什麼嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "她在研發現場",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_006"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "也一直都是那個樣子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "交代給她的事都能順利完成，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "但對於不喜歡的事，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n她也會很明確地表示她不喜歡。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "然後，",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_007"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "她平時也會主動協助周遭的夥伴，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n在企劃成員當中深受信賴。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "雖然如今已經跟我們",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "分道揚鑣了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "嗯，",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_008"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我聽得似懂非懂……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "該怎麼說呢？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我知道她人很好，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "但還是搞不太清楚……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "感覺就是",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "難以捉摸的樣子……？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "她實際上",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_009"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "就是個這樣的女人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n總是輕浮地憨笑著，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n卻絕不會向他人",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "透漏自己內心深處的想法。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "雖說我和晶的交情應該也夠久了……",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_010"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "但我還是沒把握",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "自己確實有了解她真實的想法。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這樣啊。",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_011"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那麼，對克莉絲提娜來說，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n晶是很重要的朋友囉！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "妳有認真聽我說嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_012"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n我剛剛才說過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "我無法了解她的實際想法。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "她怎麼會是我",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "很重要的朋友呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "如果不是很重要的朋友，",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_013"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n妳應該就不會這麼認真地看待吧？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "像我，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不重要的事很快就忘掉了。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "明明是個小鬼頭，",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_014"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "還說什麼大話。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "不過……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "沒錯，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "我承認。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n她確實是我",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "為數不多的朋友之一。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "果然是這樣！",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_015"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n不過，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "連克莉絲提娜都這麼說了，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n該不會",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "在阿斯特朗的能力排名，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "也是她比較強吧？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "絕對不是！",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_016"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "哇啊！？",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_017"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n什、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "什麼嘛，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "突然喊得那麼大聲！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "害我嚇一大跳！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "誰叫妳說了蠢話！",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_018"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n我怎麼可能",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "會比晶還要弱！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n無論是不是在阿斯特朗傳奇的遊戲裡！！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "我在競速遊戲裡以87戰44勝贏過她，",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_019"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n在格鬥遊戲裡以123戰61勝……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "唔，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "這倒是我輸了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "其他還有像是比腕力之類的……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我、",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_020"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我知道了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我就說我知道了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n話說回來，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "妳們竟然可以對戰那麼多場～",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "如果是我，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "應該很快就會感到厭倦了。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "與晶之間的對戰，",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_021"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
