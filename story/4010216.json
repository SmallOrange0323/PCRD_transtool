        "voice": "vo_adv_4010216_023"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "不太清楚，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n我一回過神來就在這裡了……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
