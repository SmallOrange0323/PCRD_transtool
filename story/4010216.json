    {
        "type": "dialogue",
        "name": "霞",
        "words": "今天是我的生日……",
        "unit_id": 101431,
        "voice": "vo_adv_4010216_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "會記得嗎……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然這幾天，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是有在與跟學長的日常對話中",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "裝作不經意地",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n傳達生日就是今天……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在學長的學生手冊日曆裡",
        "unit_id": 101431,
        "voice": "vo_adv_4010216_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "悄悄畫個小紅花，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n在鞋櫃藏入暗號文，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在學長看的推理小說",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n頁面",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "貼上意味深長的便簽……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是不是太拐彎抹角了？　",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "生日禮物這麼奢侈的事，",
        "unit_id": 101431,
        "voice": "vo_adv_4010216_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是不指望啦，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但至少",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "希望他能說聲生日快樂、",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦！？",
        "unit_id": 101431,
        "voice": "vo_adv_4010216_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學學、",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長！？",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n跑到我的教室來，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是怎麼了嗎……！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "事件……？",
        "unit_id": 101431,
        "voice": "vo_adv_4010216_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請冷靜一點，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n呃……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "詳情是怎麼樣？",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……學長的學生手冊日曆上有陌生的小紅花？",
        "unit_id": 101431,
        "voice": "vo_adv_4010216_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n…………鞋櫃裡",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有滿是數字的訊息卡片。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "………………看的小說上",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "貼著便簽。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "犯人、",
        "unit_id": 101431,
        "voice": "vo_adv_4010216_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是我！　",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦、",
        "unit_id": 101431,
        "voice": "vo_adv_4010216_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呃，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這的確是個",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謎呢。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那裡或許並沒有什麼了不起的真相，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們一個個",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "解讀包含其中的訊息吧……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒想到必須自己收拾自己挖的坑，",
        "unit_id": 101431,
        "voice": "vo_adv_4010216_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n多麼屈辱啊……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗚嗚……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且由此引導出的真相……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101431,
        "voice": "vo_adv_4010216_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "事件解決了。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101431,
        "voice": "vo_adv_4010216_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你知道吧！？",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n絕對",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "知道吧！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "長壞心眼～～～～～～～～～！",
        "unit_id": 101431
    },
