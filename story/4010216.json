    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "這地方有頭緒嗎？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "這樣啊……",
        "unit_id": 109411,
        "voice": "vo_adv_4010216_024"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "難怪沒有討厭的氣息。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "而且，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "大家好像",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "都不在意我的模樣。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "可是，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "為什麼我會在這裡……？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "是不是就像……",
        "unit_id": 109411,
        "voice": "vo_adv_4010216_025"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "祝福魔法呢？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "那我會很開心，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "但突然過來，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "到底該做點什麼呢……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "可以嗎？",
        "unit_id": 109411,
        "voice": "vo_adv_4010216_026"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "嗯……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "那",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我就恭敬不如從命了？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n雖然有點不安，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "但這種機會",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "一定很難得吧。",
        "unit_id": 109411
    },
    {
        "type": "background",
        "background": "510210"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "學校……",
        "unit_id": 109411,
        "voice": "vo_adv_4010216_027"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "儘管氛圍不同，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "但果然會產生親近感呢。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n感覺音樂室也好讓人懷念，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n謝謝你",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "讓我摸摸鋼琴。",
        "unit_id": 109411
    },
    {
        "type": "background",
        "background": "510050"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "漢堡",
        "unit_id": 109411,
        "voice": "vo_adv_4010216_028"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "是、",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "要咬著吃嗎？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "嘴巴可以張那麼大嗎……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n啊嗯……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "嗯，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "好吃……！",
        "unit_id": 109411
    },
    {
        "type": "background",
        "background": "510201"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後{player}和古蕾婭也"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一起逛了各式各樣的地方。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然後……"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "謝謝你，",
        "unit_id": 109411,
        "voice": "vo_adv_4010216_029"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "{player}。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n走在陌生的地方，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "老實說我很不安……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n多虧了你，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我非常開心。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "啊，",
        "unit_id": 109411,
        "voice": "vo_adv_4010216_030"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "你發現了啊……？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "嗯……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "安她們總是",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "在擔心我。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n作為謝禮，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我想跟她們說說這裡的所見。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "這種像是夢境般的見聞，",
        "unit_id": 109411,
        "voice": "vo_adv_4010216_031"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "安跟露",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "絕對會感興趣的。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n然後會說",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "「我也想去」",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "這樣……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n呵呵，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "幸好我鼓起了勇氣。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "謝謝你。",
        "unit_id": 109411,
        "voice": "vo_adv_4010216_032"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "雖然來到這裡後發生了很多事……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n但多虧如此，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我有了個難忘的生日。",
        "unit_id": 109411
    }
