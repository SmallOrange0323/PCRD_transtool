    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵，",
        "unit_id": 103831,
        "voice": "vo_adv_4010216_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好漂亮的庭園。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n空氣也很清新，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好舒服……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯，",
        "unit_id": 103831,
        "voice": "vo_adv_4010216_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也不太會咳了，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒問題。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n畢竟你難得邀請我，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我可不能讓你看到沒精神的樣子。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……在生日，",
        "unit_id": 103831,
        "voice": "vo_adv_4010216_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你像這樣邀請我出門，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我、非常開心。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "以往大多是在",
        "unit_id": 103831,
        "voice": "vo_adv_4010216_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "病房，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "由大姐姐們為我慶祝。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那樣當然也很開心……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "卻也感受到，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "每年會不會就這樣",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一成",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不變的不安。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天",
        "unit_id": 103831,
        "voice": "vo_adv_4010216_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很謝謝你。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我會",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "盡情享受的……♪",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊……",
        "unit_id": 103831,
        "voice": "vo_adv_4010216_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n那就……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "麻煩你了。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "強而有力，",
        "unit_id": 103831,
        "voice": "vo_adv_4010216_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "引導著我的手掌。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "男人的護送……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我在",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "戀愛小說中",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "看過好幾次這樣的情境……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "原來是這種",
        "unit_id": 103831,
        "voice": "vo_adv_4010216_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "感覺啊……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是，",
        "unit_id": 103831,
        "voice": "vo_adv_4010216_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝你……！",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天",
        "unit_id": 103831,
        "voice": "vo_adv_4010216_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是我的生日。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果你願意",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "再實現我一個",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "任性的願望──",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請你今天一整天",
        "unit_id": 103831,
        "voice": "vo_adv_4010216_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "都別放開我的手……♪　",
        "unit_id": 103831
    },
    {
        "type": "background",
