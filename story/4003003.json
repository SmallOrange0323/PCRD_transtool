[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "噹噹噹～噹☆",
        "unit_id": 105812,
        "voice": "vo_adv_4003003_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位久等了！　意外的續篇！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n第二次的【美食殿堂】吃遍之旅開始囉～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧！　",
        "unit_id": 105812,
        "voice": "vo_adv_4003003_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我已經是渾身衝勁了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "上次在『雲海山脈』取得的食材，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n實在是只有夢中才會見到的美味嘛！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，這次又能吃到什麼美味、珍饈呢？",
        "unit_id": 105812,
        "voice": "vo_adv_4003003_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真令人期待呢～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，口水都流下來了……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿嘿。為了這趟能夠吃到爽，",
        "unit_id": 105812,
        "voice": "vo_adv_4003003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我昨天晚飯可是忍著只吃八分飽喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過也忍得我肚子一直咕咕叫！",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500401"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_4003003_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐的八分飽，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對在下來說大概是一整周的食量了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "討厭～",
        "unit_id": 106012,
        "voice": "vo_adv_4003003_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不想去～啦……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳們都是笨蛋嗎？　為什麼一再犯同樣的錯？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n上次『雲海山脈』出了事還不懂反省嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105812,
        "voice": "vo_adv_4003003_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n上次不知為何好多『闇影』來襲擊我們呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還以為會死掉～，『闇影』不能吃可真討厭呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔唔。",
        "unit_id": 106012,
        "voice": "vo_adv_4003003_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且還跟鎮上出現的『闇影』不一樣，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我的能力還不能操控。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔呣？",
        "unit_id": 105913,
        "voice": "vo_adv_4003003_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐的能力……那是？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒啦，只是自言自語……",
        "unit_id": 106012,
        "voice": "vo_adv_4003003_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管怎樣。",
        "unit_id": 106012,
        "voice": "vo_adv_4003003_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反～正這次的祕境一定跟上次一樣危險嘛，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我可不想去啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不要老是讓我陷入麻煩之中，回家了～！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～？都已經到這兒了，",
        "unit_id": 105812,
        "voice": "vo_adv_4003003_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不要一直碎碎念，出發吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "誰擋著路就殲滅他吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好了好了，還有未知的美食在等著我們喔！",
        "unit_id": 105812,
        "voice": "vo_adv_4003003_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次的祕境『密林大樹』上，",
        "unit_id": 105812,
        "voice": "vo_adv_4003003_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n會結出世界第一好吃果實喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "美食家之間都流傳著這種傳言呢！",
        "unit_id": 105812,
        "voice": "vo_adv_4003003_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n啊，我一定要吃到……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好了好了，",
        "unit_id": 105812,
        "voice": "vo_adv_4003003_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不要囉嗦一起去吧小凱留！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n走走！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們的吃遍之旅才剛剛開始喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不是～……",
        "unit_id": 106012,
        "voice": "vo_adv_4003003_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這才不是吃遍之旅～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n根本是祕境巡禮才對啊～……",
        "unit_id": 106012
    }
]