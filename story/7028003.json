[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在塔中前進時，拉比林斯達和班比"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n對彼此自我介紹，增進友情。"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哦──！",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以妳是在差點被",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那個伯爵？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n綁架時受到幫助的啊。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "沒錯！",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_001"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "所以班比現在是住在伊莉亞那邊。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "然後啊──？",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_002"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n最近伊莉亞",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "有教班比學習。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "可是",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_003"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "她好囉嗦，老是要班比做這個做那個的！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就好像學校？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "的老師！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "而且班比",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_004"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "不太喜歡學習……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "所以，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "偶～爾……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "真的",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就是偶～爾喔。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比會暫停學習──",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_005"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "跑出來外面走走。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "…………",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_006"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "欸嘿嘿──♪",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "沒問題呦！",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_007"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比有寫信給伊莉亞嘛。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "內容就是班比沒那個心情──",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_008"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "所以今天暫停學習！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這樣。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "不過伊莉亞有說，",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_009"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比是什麼",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "真……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "真俗的系浦……？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n還是什麼的。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真俗？",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_010"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哦哦，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是真祖啊。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真祖的系譜……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "原來如此。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "她說「真祖」",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_011"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "在吸血鬼間也是特別的存在，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n所以有很多事情要學習。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_012"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "明明也可以不要當「真祖」的啊～",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這樣的話",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就不用學習，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "也可以跟僕從",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "玩得更久了呢！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真祖吸血鬼……",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n一般來說，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這指的都是吸血鬼的始祖。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "存在於這阿斯特朗的吸血鬼",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只是魔族這個大分類的種族之一。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "即使被吸血鬼咬到，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n在遊戲上也只會被施加",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n暫時性的能力減益效果。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……至少",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_016"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在我們\n設計遊戲系統時是這樣的。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可是，",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_017"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在原先設定被改寫的",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這個世界裡，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "發生的事都",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n盡超出開發遊戲的我們預想。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_018"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "吸血鬼……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且是",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "足以被稱作「真祖」的強大吸血鬼，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n有可能後天變更玩家的種族嗎？　",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "倘若如今阿斯特朗的吸血鬼化，",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_019"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不是暫時性的，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而是會造成永久變化……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在發生無可挽回的事態前，",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我想檢測這會產生什麼影響以及有多少可能性。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這也是為了少年的安全。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且……",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也不喜歡把不懂的事情",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就這麼放著不管呢～",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以說，",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "班比！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "求求妳！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n在吸血鬼的研究上，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n能不能幫大姐姐我一點忙？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "像是喜歡的事物，",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "或是吸血鬼的性質。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n希望班比能把妳知道的事情告訴我啊。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對了！",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳要是幫我，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我就請妳吃特別的可麗餅吧！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "盯…………",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_025"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "咦、",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "咦？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "班比？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "……伊莉亞",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_027"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "說過。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "可疑人士會用點心引誘人上鉤，",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_028"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n所以不可以收陌生人給的東西，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這樣。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哇，",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "教導很確實呢！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n沒錯，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不能聽可疑人士說的話，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n也不能跟著他們走喔！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但是，",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這也是為了少年啊。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不對，不光是少年。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也是為了大家──",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "伊莉亞還說，",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_031"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就算說是為了妳認識的人～之類的，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n或是僕從有危險～之類的，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n也是在說謊，所以要小心──",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這樣。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "盯………………",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊啊！",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "班比正用",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n冷漠的眼神看著我──！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "總覺得……",
        "unit_id": 122311,
        "voice": "vo_adv_7028003_034"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "拉比林斯達好像有點可怕。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不會啊──",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_035"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不可怕喔？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一點都不可怕！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒事的，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以能不能",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "稍～微告訴大姐姐",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n一點事情啊～？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只要一點就好。",
        "unit_id": 106815,
        "voice": "vo_adv_7028003_036"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好嗎？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "班比，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "求求妳～！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，因為壓抑不住對吸血鬼這個種族的好奇心，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n拉比林斯達忍不住連連逼問。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n結果在那之後，被班比提防好一段時間。"
    }
]