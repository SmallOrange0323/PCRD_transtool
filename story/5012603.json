    {
        "type": "dialogue",
        "name": "真琴",
        "words": "打聽調查，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "比想像中還不容易呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n真是累人。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這的確是很乏味的工作，",
        "unit_id": 101411,
        "voice": "vo_adv_5012603_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也並不輕鬆。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是，",
        "unit_id": 101411,
        "voice": "vo_adv_5012603_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "每當反覆打聽情報，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就越接近謎題的核心……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要這麼一想，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就沒那麼讓人感到辛苦呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我會賭上偵探的尊嚴，",
        "unit_id": 101411,
        "voice": "vo_adv_5012603_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "逮捕盯上助手先生的犯人。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "趕緊行動吧！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "解說",
        "words": "正確答案是『4.真陽』。\n真琴與霞是獸人族，而步未是精靈族，\n四位之中不是精靈也不是獸人的，就只有真陽了。",
        "unit_id": 12
    }
