        "voice": "vo_adv_5046323_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n被逼到絕路，",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以氣炸了嗎……",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "大鬧特鬧呀～！？",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "第九局，",
        "unit_id": 5111,
        "voice": "vo_adv_5046323_001"
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "最後的攻防戰嗎……",
        "unit_id": 5111
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "哼，",
        "unit_id": 5111
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "很優秀嘛。",
        "unit_id": 5111
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "\n敵人越強我越有幹勁！",
        "unit_id": 5111
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "就在這邊豪邁地揍飛這個傢伙，",
        "unit_id": 5111,
        "voice": "vo_adv_5046323_002"
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "\n分出比賽的高下吧！",
        "unit_id": 5111
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "沒錯！",
        "unit_id": 5011,
        "voice": "vo_adv_5046323_003"
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "\n這個緊要關頭，",
        "unit_id": 5011
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "全員繃緊神經，",
        "unit_id": 5011
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "讓我們合力度過難關吧！",
        "unit_id": 5011
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "說得好！",
        "unit_id": 113411,
        "voice": "vo_adv_5046323_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就差最後一步了，",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "加油──！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一起打出一個特大號全壘打，",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "讓魔物回去海裡吧！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 113511,
        "voice": "vo_adv_5046323_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "用團隊合作打出漂亮的勝仗吧！",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "來，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "要專心致志地迎戰喔～！",
        "unit_id": 113511
    }
