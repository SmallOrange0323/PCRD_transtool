    {
        "type": "dialogue",
        "name": "純",
        "words": "無法傷到豪紳議長分毫呢……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "哼──哈哈哈！",
        "unit_id": 191411,
        "voice": "vo_adv_9100116_002"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "軟弱！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "脆弱！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n在吾輩得到嶄新力量的拳頭之前，",
        "unit_id": 191411
