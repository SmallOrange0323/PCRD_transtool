    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "吾輩狀態雖曾糟到連拯救者大人都束手無策……",
