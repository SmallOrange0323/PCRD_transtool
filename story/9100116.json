        "type": "dialogue",
        "name": "豪紳",
        "words": "吾輩獲得了「黑暗力量」。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "黑暗力量……！？",
