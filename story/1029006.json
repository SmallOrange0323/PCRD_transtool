[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！\n{player}，終於找到你了！",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我決定要開演唱會了！\n然後啊，我把你的入場券也拿來囉。",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你一定要來喔！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯？你那天有工作啊？",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是、是喔……真可惜……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但、",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是如果有工作也沒辦法嘛！嗯！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你、你不用太在意！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "………………",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_004"
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後，演場會當天――――"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "早安。\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "接下來要去工作了嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也來幫忙……",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你的工作吧！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你問我為什麼……\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為早點結束就能來聽我的演唱會了吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你不用客氣啦。\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "首先我該做什麼好呢？",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "先搬東西……？\n把這個搬到店裡面就可以了吧。",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我知道了！\n兩個人一起做的話，很快就能完成了！",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那我們趕快把它們搬完吧！",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿咻！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你看你動作太慢了！\n要快點把工作做完啊！",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯？是我動作太快了……？",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～我好歹也是個偶像，平常都在唱唱跳跳的。",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n還蠻有體力的喔？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這種粗活，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過是小事一樁！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "接著是打掃啊。\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "兩個人一起做的話，時間就能縮短一半呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n加油吧！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "終於完成了！接下來呢？",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……下一份工作也是打掃啊。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "交給我吧！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要、要打掃這裡嗎！？",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "整座城！？就我們兩、兩個！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚嗚～我會加油的！",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定要讓你來聽我的演唱會！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……那麼，最後是撿垃圾嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n將垃圾裝滿袋子後，就可以結束了吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……這只能一步一腳印地做了呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是，這個袋子這麼大，好像會花很多時間……",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我還得去排演、化妝和演唱會的事前討論……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我趕得上演唱會嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣就沒意義了不是嗎。\n你也得來演唱會才行！",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那樣不行啦",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "！\n你會失去信用的！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓我們好好地完成工作之後，\n兩個人再一起去演唱會！明白了嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……什麼？\n你說我演唱會遲到會更糟糕……？",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我可是專業的喔。演唱會絕對不會遲到。",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我一定會在演唱會開始之前完成給你看！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？你問為什麼我要那麼努力？",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那是因為……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我無論如何都希望你能來。\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定要讓你聽見我今天的演唱會！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "終於完成了！",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "接著只要把裝滿垃圾的袋子送過去就結束了。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那個任務就交給你處理囉。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我要趕著去演唱會現場！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一直都是你在幫助我不是嗎。\n該說謝謝的人是我。",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天能幫你做點事，我很高興喔！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……你不要遲到，一定要來喔！\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029006_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定喔！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……好險有趕上。",
        "unit_id": 102912,
        "voice": "vo_adv_1029006_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "他也在座位上看著我吧。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n……",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好，上場了！",
        "unit_id": 102912
    },
    {
        "type": "still",
        "still": "102900601"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家――！\n",
        "unit_id": 102912,
        "voice": "vo_adv_1029006_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "感謝你們今天能來我的演唱會――！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "粉絲們",
        "words": "望望～！\n好可愛啊！！",
        "unit_id": 1,
        "voice": "vo_adv_1029006_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "接下來我有首新歌想讓你們聽聽。\n這是",
        "unit_id": 102912,
        "voice": "vo_adv_1029006_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我的第一首情歌……而且歌詞是我自己作的。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "――一邊想著你。",
        "unit_id": 102912,
        "voice": "vo_adv_1029006_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以演唱會一開始希望能讓大家聽聽這首歌。",
        "unit_id": 102912,
        "voice": "vo_adv_1029006_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n「因為想要看見你的笑容」。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……\n我非要你來演唱會的理由……是否傳達給你了呢？",
        "unit_id": 102912,
        "voice": "vo_adv_1029006_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……呵呵呵。\n你那麼遲鈍，應該沒有意會到吧。",
        "unit_id": 102912,
        "voice": "vo_adv_1029006_038"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "望一邊這麼想，一邊開心地笑著。"
    }
]