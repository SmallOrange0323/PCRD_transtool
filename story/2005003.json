        "voice": "vo_adv_2005003_049"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n明明你們兩個人平常都是一起行動的說……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "總覺得好像有印象。",
