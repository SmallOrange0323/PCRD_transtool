        "voice": "vo_adv_2005003_051"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我們兩個一直都是一起行動的唷。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然跟你只有相處過一小段時間！",
