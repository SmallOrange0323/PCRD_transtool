    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "頭髮是不是有變長了？　",
        "unit_id": 107311,
        "voice": "vo_adv_2005003_048"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n妳的樣子跟我記憶中的不太一樣，",
