        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我一直都是獨自一人，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以覺得很不安。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_063"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n能夠再次見到你，我真的很開心♪",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "這樣啊。",
        "unit_id": 107311,
        "voice": "vo_adv_2005003_064"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n雖然我不是很清楚，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "但妳比較適合露出笑容喔……諾維姆。",
        "unit_id": 107311
    },
    {
