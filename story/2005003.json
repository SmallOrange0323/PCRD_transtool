[
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "…………",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "自從我被關到這裡來之後，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n到底過了多久？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "最多也就一個禮拜左右吧？　",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗚，這是我這輩子最大的失誤啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "截至目前為止是還沒有受到什麼傷害……",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n而且還有給我食物",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "跟睡覺的地方。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "待遇雖然還算不錯，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但實在不清楚把我捉來的那些人目的為何，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這讓我很不安。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看來，那個叫做【拉比林斯】的組織……",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是想要從我身上打聽出什麼消息的樣子。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果一口氣說很多，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n感覺好像會有點愚蠢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在從我身上",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "問出所有她們想知道的事情以前，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我想我的人身安全",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "應該是有所保障的……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "話雖如此，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n要是我什麼都不說的話，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可能就會被拷問吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在的態度雖然很溫柔，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但她們可是把我打昏",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再綁架到這裡的危險人士。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n等我沒有利用價值以後，或許就會被處理掉。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看來，只好裝作",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我還隱瞞著某些對他們有用的情報……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "博取他們的好感，多爭取一些時間，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n再趁機尋找逃出這裡的方法。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔～……",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我真的很不擅長這種爾虞我詐的作法。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟，\n過去這方面的事情我都嫌麻煩，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n全交給尾狗刀去做了嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀……",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我好想他哦。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n只要有他在的話，我就能安心一點。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那傢伙現在把我的事情忘得一乾二淨就是了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "即使是這樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我還是想見他。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不想，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再孤獨一人了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……！？",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n怎、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼了？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n爆炸聲……？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是發生什麼意外了嗎？",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還是說是有人攻進來了？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "難不成",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是尾狗刀來救我了嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不對，不可能發生那種事情……",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那傢伙，反而是想要把我捉起來吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "給我記住了～",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "等那傢伙記憶全部恢復後，我會好好奉還的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總之。",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n到底是發生了什麼事……？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂～！",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n發生什麼事了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n有沒有人在啊？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這裡是洞窟還是什麼地方啊？",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n要是在這種地方發生爆炸，那可就糟啦！　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n整個洞窟會崩塌，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我會被活埋的啦～！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒人回答我！　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒有半個人在嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我記得是叫做",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "靜流跟，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "璃乃對吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n【拉比林斯】的人，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "全都不在嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂～！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這下怪了。",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n為了不讓我逃跑，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我想應該有派人在看守才對。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的，沒有半個人在嗎？",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n還是說……全都被襲擊者（？）",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n給打倒了？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "機會來了！",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n要逃出去的話，就得趁現在！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果沒有人看守的話，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n總會有辦法從這監牢裡逃出去！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔嗚嗚嗚！",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "噗哈，光靠我的腕力還是沒辦法嗎？　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n可惡～要是能用『天樓霸斷劍』的話……！",
        "unit_id": 106112
    },
    {
        "type": "still",
        "still": "200500301"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………？",
        "unit_id": 107311,
        "voice": "vo_adv_2005003_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "居然沒什麼反應！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在『這邊』或許不是教授，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以我用『那邊』的稱呼叫他也沒有意義啊？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我想想，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "教授的本名是叫什麼啊？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我記得是，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉基……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉基？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "拉基拉基？",
        "unit_id": 107311,
        "voice": "vo_adv_2005003_033"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n那是我的名字嗎？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就這樣子看來，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你也是喪失了記憶啊？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不對，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_035"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我記得你是被米奈娃操縱……？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗚嗚，我已經搞不清楚了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過算了，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這種困難的事情等等再想！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那個，總之請你幫我一下吧！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你看，幫我把這鐵柵欄給拉開！　",
