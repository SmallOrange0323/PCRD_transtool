        "voice": "vo_adv_2005003_057"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我覺得，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n我應該要多跟妳聊聊才對。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n這是為了完整我的自我意識，以及回應那股衝動。",
