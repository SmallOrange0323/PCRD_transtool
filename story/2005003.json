    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "…………！？",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你剛才是叫我諾維姆對吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n明明大家都已經忘記我這名字了說！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "太好了……！　",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我真的",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "覺得很害怕！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我很害怕，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_045"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那一切其實都只是我自己的妄想！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n很害怕我自己，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是不是變得很奇怪了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，你還記得我對吧……拉基拉基？　",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那些全都不是我的夢跟妄想吧，對不對？　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我、我一直都覺得很不安！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我……不太清楚狀況。",
        "unit_id": 107311,
        "voice": "vo_adv_2005003_047"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n很抱歉……",
