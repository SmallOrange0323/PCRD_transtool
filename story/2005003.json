    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "唔～？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "而且，尾狗刀沒有跟妳在一起嗎？",
