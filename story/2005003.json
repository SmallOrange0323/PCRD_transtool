    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拜託你嘛～！　",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_038"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然你應該不記得了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但在【永恆集會】的時候，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_039"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我跟你一起合作，完成了很多事情吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "【永恆集會】……？",
        "unit_id": 107311,
        "voice": "vo_adv_2005003_040"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "抱歉，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我不知道那是什麼。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我的記憶好像很混亂。",
        "unit_id": 107311,
        "voice": "vo_adv_2005003_041"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n我連自己是什麼人，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "都記不太清楚了。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "不過關於妳的事情，",
        "unit_id": 107311,
        "voice": "vo_adv_2005003_042"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "好像還記得一些就是了。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n我記得，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "妳是叫……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "諾維姆是嗎？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n是吧？",
