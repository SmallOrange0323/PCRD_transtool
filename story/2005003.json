    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "謝謝你，拉基拉基～♪",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀已經完全忘了以前的事情，",
        "unit_id": 106112,
        "voice": "vo_adv_2005003_062"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n而我也不知道其他的人……像是大吾他們到底在哪？",
