        "voice": "vo_adv_2005003_052"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但我跟你以前是夥伴唷！　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然大家好像都忘了這件事！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "夥伴……",
