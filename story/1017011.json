        "voice": "vo_adv_1017011_022"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "一起玩的那個男孩子",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n卻給人一種好不容易",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "才能追上的感覺耶……！",
