        "words": "故鄉……",
        "unit_id": 190011,
        "voice": "vo_adv_1017011_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1017011_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n抱歉，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我剛剛在想事情。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然香織平常總是充滿活力，",
        "unit_id": 190011,
        "voice": "vo_adv_1017011_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n感覺像是完全沒有煩惱，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在想到故鄉時",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也是會感到寂寞的啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不，",
        "unit_id": 190011,
        "voice": "vo_adv_1017011_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這一定是理所當然的吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為無論是誰，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該都很喜歡自己一直以來生活的地方。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯。",
        "unit_id": 190011,
        "voice": "vo_adv_1017011_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總有一天……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一定能回去的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我怎麼",
        "unit_id": 190011,
        "voice": "vo_adv_1017011_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "感傷起來了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這種時候就要說出",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "香織經常在講的那句話，對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "船到橋頭自然直～♪",
        "unit_id": 190011,
        "voice": "vo_adv_1017011_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1017011_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "奇怪～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_066"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我怎麼",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "會睡在床上呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_067"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這是",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}的床，對吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你說醒來後發現我睡在地板上，",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_068"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "才把我搬過來了～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_069"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n真抱歉，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我把{player}睡覺的地方",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "占走了～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_070"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然我原本今天，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n是想和{player}一起",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "去外面玩～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但偶爾像這樣，",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_071"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n在室內悠哉地慵懶度過",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可能也很棒呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}也要跟我一起睡嗎～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_072"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但這張床實在是擠不下吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在啟程回到故鄉之前，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n香織快樂地與{player}一起度過剩下的每一天。"
    }
]