    {
        "type": "dialogue",
        "name": "旁白",
        "words": "香織下定決心要搭船回到故鄉。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n面對步步逼近的出發日，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她頻頻來拜訪{player}。"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗨呵～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n早安啊～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "今天也要一大早",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就來一起跳舞喔～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不可以喔～",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n因為已經沒剩多少時間了～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啦好啦，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "快起來快起來～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要我幫你",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "換衣服嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來吧來吧，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咻咻咻地把衣服脫掉～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦？",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不用了？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n因為你會自己脫？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真可惜……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那麼，",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在你換完衣服之前，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我會在這裡跳舞的～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣也不行～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你會很在意～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你很壞心眼耶～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我明明想多和",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}待在一起的～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "之前有種奇怪的感覺，",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但現在已經沒事了呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那果然是因為",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "被別人說我們是戀人嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呃，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "身體怎麼好像又熱起來了",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "讓人靜不下來啊～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在離別之前，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "得要吃一堆好吃的東西，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n盡情地唱歌跳舞，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n讓我能把回憶",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "帶回故鄉才行呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你看，",
        "unit_id": 101711,
        "voice": "vo_adv_1017011_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "外面的日頭也",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這麼的耀眼～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呃，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "奇怪～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣有點太耀眼了啦～！？",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來了來了～♪",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗨呵～！",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真抱歉，突然把你找出來～",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為很臨時，",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我還想說你可能不會來了～",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那個，",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我之所以找你出來啊～",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n是因為想在回去前",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "和{player}見個面喔～♪",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯。",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我啊，",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "今天……",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要回故鄉囉～",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為暫時也沒有空手道比賽了，",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以也不知道",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "下次再來是什麼時候～",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "然後啊，",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在要啟程回去之前，",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我就突然",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "想起了{player}的臉～",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如果你有空，",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "接下來要不要",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "和我一起去街上逛逛～？",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n因為我想帶著很多",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這座城鎮的回憶",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "回到故鄉～",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喔喔～",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你充滿了幹勁呢！",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那我們就一起",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "出發囉～♪",
        "unit_id": 101732
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "首先果然",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要從填飽肚子開始～！",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n因為要是沒讓肚子吃飽飽，",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就沒辦法",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "隨心所欲地跑跳啦～！",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯……",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這家店的",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "餐點菜單內容都好時髦喔～",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n沒有苦瓜雜炒嗎～？",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦？",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一般店家是不會有的？",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這怎麼可能～！",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n如果是在我的故鄉，",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不管去哪間店……",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "倒也沒這麼誇張，",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但大部分的店家應該都有在賣啊～！",
        "unit_id": 101732
    },
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在吃飽之後，",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就要來活動身體～♪",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這裡的跳舞遊戲",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "很有趣喔～♪",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來嘛",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來嘛，",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}也來站在我旁邊！",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n要一起跳囉～♪",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喂、",
        "unit_id": 1,
        "voice": "vo_adv_1017011_021"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喂，那女孩是怎麼回事……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "她的舞步好驚人啊……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "但和她",
