    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～♪",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n要再來提升難度囉～",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你應該跟得上吧～♪",
        "unit_id": 101732
    },
    {
        "type": "background",
        "background": "510340"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呼，",
        "unit_id": 101732,
        "voice": "vo_adv_1017011_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在活動身體後，",
        "unit_id": 101732
    },
    {
        "type": "dialogue",
        "name": "香織",
