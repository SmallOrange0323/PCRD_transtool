        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那我要開始了唷。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "鬼抓人往這來，",
        "unit_id": 103611,
        "voice": "vo_adv_2103004_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "往拍手的聲音來。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鬼～抓人往這來，",
        "unit_id": 100411,
        "voice": "vo_adv_2103004_002"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "往拍手的聲音來♪",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我沒有挖洞所以你可以安心唷～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "這邊這邊～",
        "unit_id": 102011,
        "voice": "vo_adv_2103004_003"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "葛～格～♪",
        "unit_id": 106414,
        "voice": "vo_adv_2103004_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n哇咿～♪",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在{player}一行人，\n於【咲戀育幼院】內玩得正開心時——"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "『索爾之塔‧上層』"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們是【破曉之星】！",
        "unit_id": 100111,
        "voice": "vo_adv_2103004_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們的公會是為了追尋被稱為索爾魔珠的祕寶",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n而踏上了冒險的旅程……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但今天我們要找的是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "別的寶物！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "聽說",
        "unit_id": 100111,
        "voice": "vo_adv_2103004_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那是被藏在索爾之塔中，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n一種未知的魔法道具！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "究竟",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有沒有辦法找到它呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "加油呀！【破曉之星】！",
        "unit_id": 100111,
        "voice": "vo_adv_2103004_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n上吧上吧！【破曉之星】！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們的冒險，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才正要繼續下去呢～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……日和。",
        "unit_id": 100311,
        "voice": "vo_adv_2103004_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n妳又像是在說『前情提要』一樣的話了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳很愛這套嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿～",
        "unit_id": 100111,
        "voice": "vo_adv_2103004_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個嘛，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "畢竟這層好像沒有魔物呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就想不如來說一下嘛～♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真拿妳沒辦法呢……",
        "unit_id": 100311,
        "voice": "vo_adv_2103004_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如何？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯。",
        "unit_id": 100211,
        "voice": "vo_adv_2103004_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "似似花小姐教我的，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n那個可以探索魔法道具的魔法",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n顯示就在這一層才對，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但是……",
        "unit_id": 100211
    },
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——幾天前——"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "要去『索爾之塔』？",
        "unit_id": 1,
        "voice": "vo_adv_2103004_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是的。",
        "unit_id": 107011,
        "voice": "vo_adv_2103004_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我想要委託妳們幾個，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "去探索那座塔。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比起其他任何的公會，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我認為妳們最適合這項任務。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "然而似似花。",
        "unit_id": 100311,
        "voice": "vo_adv_2103004_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們還沒",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "收集完所有的索爾魔珠。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也因此無法抵達塔的頂端……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我的話似乎讓妳們誤會了呢。",
        "unit_id": 107011,
        "voice": "vo_adv_2103004_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我可",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒說過「要妳們登頂」這種話喔。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……妳的意思是？",
        "unit_id": 100211,
        "voice": "vo_adv_2103004_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在『索爾之塔』的內部，",
        "unit_id": 107011,
        "voice": "vo_adv_2103004_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還沉睡著其他",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "尚未被發現的財寶或魔法道具。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "包括被{player}它所吞下的",
        "unit_id": 107011,
        "voice": "vo_adv_2103004_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那顆小水晶在內……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那好像也是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在『塔』的內部所發現的物品。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦，",
        "unit_id": 100111,
        "voice": "vo_adv_2103004_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是這樣啊！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以請妳們去入手相同的物品，",
        "unit_id": 107011,
        "voice": "vo_adv_2103004_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "並且將它拿到我這兒來。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n做為能讓他的精神恢復所需要的研究材料，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那是不可或缺的東西。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是如果要進行探索，",
        "unit_id": 100311,
        "voice": "vo_adv_2103004_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "必須獲得王宮的許可。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n過去我們進去挑戰的時候，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也只被允許探索下層而已……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "僅僅如此，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們便遭遇到不小的困難了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果",
        "unit_id": 100111,
        "voice": "vo_adv_2103004_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當時讓霸瞳皇帝小姐本人看到申請書的話，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那我們的申請絕對會被退回的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以那次我們幾個，",
        "unit_id": 100211,
        "voice": "vo_adv_2103004_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "算是運氣好了呢……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是呢。",
        "unit_id": 107011,
        "voice": "vo_adv_2103004_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n然而今次，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "王宮的代表很輕鬆地就讓妳們獲得許可了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈。",
        "unit_id": 100111,
        "voice": "vo_adv_2103004_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個嘛，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "畢竟現在的代表是佩可小姐嘛！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼……",
        "unit_id": 107011,
        "voice": "vo_adv_2103004_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳們意下如何？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n儘管這是非經由公會管理協會，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "算是我個人私自的委託……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然而我保證會給予妳們相較之下更高的報酬。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這事請務必讓我們來辦。",
        "unit_id": 100311,
        "voice": "vo_adv_2103004_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們幾個，",
        "unit_id": 100111,
        "voice": "vo_adv_2103004_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不需要報酬唷，似似花小姐！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對吧～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯～。",
        "unit_id": 100211,
        "voice": "vo_adv_2103004_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n如果是為了騎士先生的話，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們幾個",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不管是怎樣的冒險都願意去嘗試的！",
        "unit_id": 100211
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣【破曉之星】三人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n便在索爾之塔的庭園中，不斷尋找著水晶球。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～",
        "unit_id": 100111,
        "voice": "vo_adv_2103004_030"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒有耶～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
