    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼會在這種時候出現……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這到底有幾隻！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "從氣息感受到其數量很多……！",
