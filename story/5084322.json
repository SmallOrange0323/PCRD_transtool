        "words": "得進入持久戰了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來最好的對策是，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請凱留小姐用魔法一口氣將它們給打飛……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留，",
        "unit_id": 106411,
        "voice": "vo_adv_5084322_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很期待妳的表現喔。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n帥氣地",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "把敵人給一口氣收拾掉吧！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說妳們，",
        "unit_id": 106011,
        "voice": "vo_adv_5084322_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會不會太過信任我了？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "過度的信賴可說是跟勉強他人沒兩樣耶？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不、",
        "unit_id": 106011,
        "voice": "vo_adv_5084322_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這點小事，對我來說輕鬆得很啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我看好了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種傢伙，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我就一口氣把它們全給打飛！",
        "unit_id": 106011
    }
]