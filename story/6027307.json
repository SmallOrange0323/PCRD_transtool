[
    {
        "type": "background",
        "background": "500740"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "存知のとおり、",
        "unit_id": 111011,
        "voice": "vo_adv_6023307_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくは外出というものを好まない。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n反して、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君は意欲的に",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "方々へ出向いているらしいじゃないか。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "この引きこもりの知的好奇心を",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "くすぐるスポットはないものかね。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "海水浴場か……",
        "unit_id": 111011,
        "voice": "vo_adv_6023307_001"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "率直に言ってまるで惹かれないが、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "山育ちの身ゆえ、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "後学のためにも一度ぐらいは",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "訪れておくべきか。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "しかし、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あの水着とかいう破廉恥な衣装は……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "うぬぬぬ……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "おお、",
        "unit_id": 111011,
        "voice": "vo_adv_6023307_002"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "聞いたことがある。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "トーゴク情緒あふれる粋な街らしいな。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "しかし",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "極東の文化というのはどうなのだ……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "腐った大豆や魚の死骸、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n何にでもびちゃびちゃソイソースをかけて食すと言うぞ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ううむ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "象牙の塔？　",
        "unit_id": 111011,
        "voice": "vo_adv_6023307_003"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あの、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "希少な古文書がわんさか眠っているという？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nよし行こう……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "って、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ソレここの図書館棟ー！　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "じゃないんだよ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n知的なぼくに",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "生涯初のノリツッコミをさせるんじゃあないよ。",
        "unit_id": 111011
    }
]