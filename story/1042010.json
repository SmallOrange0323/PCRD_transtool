[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}接受千歌的工作委託，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而來到會合的地點。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}，你、",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你好……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你今天",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "接受了我的委託。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊～",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "工作，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這個嘛……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n關於這件事，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我待會再跟你說明。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "先、",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "先不談這個，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要不要稍微走走……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那那、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們走吧。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我會不會有點不太自然？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "已經想辦法成功約他單獨外出了，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我得加油才行……！　",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "慈樂之音下一首新歌的主題，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是描寫戀愛中的女孩子，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n積極向喜歡的男孩子示好",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "的內容。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以我才想透過假想約會",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "實際觀察看看男孩子的反應……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但這種情況，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我應該怎麼辦才好？　",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然已經兩人單獨見過好幾次面了，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但我們之間並沒有過所謂的正式約會……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我沒談過戀愛，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以不太懂呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不如乾脆",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "把創作新歌的事坦白告訴他……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不對，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我想知道的是男性自然的反應，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這樣做就沒意義了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在我要下定決心來和他",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "約、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "約約",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "約會才行！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼首先是……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，{player}。",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n可、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可可",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可以、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "跟、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "跟你牽、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "牽、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "牽手嗎！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊！",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他整個人都愣住了！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這也是當然的呢，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "畢竟我沒頭沒尾地就突然說要牽手。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "怎麼辦？",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他說不定覺得我很奇怪……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦咦！",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "怎麼這麼乾脆就答應了……！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "手",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "牽起來了……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哇啊，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他的手好大、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好溫暖……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不對啦！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我要好好觀察他的反應才對！　",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "…………",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯……",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "跟他平時沉穩的態度一樣，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n很難看出有沒有變化呢……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然他平常就是個少有激烈情緒表現的人，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但真希望他能出現點容易懂的反應。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "和那比起來，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "反、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "反而是我開始感到難為情了！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n感覺路過的人都在看我們……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唔唔，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就算我在那心跳加速也不能怎麼樣啊……！　",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總、",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總覺得今天很熱呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還是把手",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "放開吧……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唔唔，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我真沒出息……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一開始就這個樣子，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "後面可有得擔心了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "下次得好好加油才行。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對了，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果你不介意，要不要去咖啡廳喝個冷飲？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "什麼都沒多問，就這樣陪我的這份溫柔……",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真的很令人感謝呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唔！",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在沒",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "關係，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "畢竟{player}……是個很真誠對待工作的人呢。",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在這就是我的工作！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這附近有不錯的店，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們去那裡吧。",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這家店，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "之前雜誌上有介紹過。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "聽說這家店最推薦的特調飲料很好喝，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我很想喝喝看呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然是想辦法自然地邀請他去咖啡廳了，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但接下來才是重點……！　",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "服務生",
        "words": "請問決定好要點什麼了嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1042010_029"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呃，",
        "unit_id": 104211,
