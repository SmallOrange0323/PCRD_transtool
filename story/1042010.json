        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，{player}。",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_059"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不可以，千歌──！",
        "unit_id": 1,
        "voice": "vo_adv_1042010_060"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_061"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "我今天一整天都在觀察你們，",
        "unit_id": 811,
        "voice": "vo_adv_1042010_062"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "但我實在忍無可忍了！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "絕對不可以",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "這麼輕易就接吻！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "我知道妳是在工作，",
        "unit_id": 6311,
        "voice": "vo_adv_1042010_063"
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "但請妳多珍惜妳自己～！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是、",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_064"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是我的粉絲們……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n你們說觀察，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我做的那些事情和這些事情，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你們全部都……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不、",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_065"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不要啊啊啊啊啊啊！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "粉絲們",
        "words": "千、",
        "unit_id": 1,
        "voice": "vo_adv_1042010_066"
    },
    {
        "type": "dialogue",
        "name": "粉絲們",
        "words": "千歌～！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼……",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_067"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對不起，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我突然就跑走。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天一整天",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "非常謝謝你陪我……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_068"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "工作？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這個嘛，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唔～～～嗯……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……沒問題，",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_069"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我覺得應該有辦法完成。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天一整天",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "非常謝謝你陪我。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖說是假想的",
        "unit_id": 104211,
        "voice": "vo_adv_1042010_070"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "約會，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但我過得很開心呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為了",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有一天能夠正式和他約會，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我得加油才行。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後，千歌以不擅長戀愛而白忙一場的女孩子，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和有點遲鈍但心地善良的男孩子為主題創作的歌曲，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n博得了非常高的人氣。"
    }
]