[
    {
        "type": "background",
        "background": "500038"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哎呀！",
        "unit_id": 111712,
        "voice": "vo_adv_6029310_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好像讓你久等了呢。",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "抱歉，妾身泡得有點久。",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "外面應該很冷吧？",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你有沒有著涼啊？",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 111712,
        "voice": "vo_adv_6029310_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣不行、",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你會感冒喔。",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……妾身才剛出來，",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "身體還很暖呢。",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來吧！",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "把臉靠過來。",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓妾身用雙手溫暖你的臉。",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因為今天……",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是特別的日子。",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "很好很好。",
        "unit_id": 111712,
        "voice": "vo_adv_6029310_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有句話說小孩是風之子。",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯？",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你說你不是小孩？　",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在妾身眼裡，",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所有的人都還是小孩呢。",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "用這身模樣講這句話",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒什麼說服力就是了。",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 111712,
        "voice": "vo_adv_6029310_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "剛好妾身也",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "覺得有點泡不夠呢。",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "難得的機會，",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身陪你去泡吧。",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n吾之眷屬啊！",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你願不願意幫妾身洗背呢？　",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……偷、",
        "unit_id": 111712
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "偷看可不行喔！",
        "unit_id": 111712
    }
]