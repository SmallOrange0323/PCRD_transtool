        "words": "所以，",
        "unit_id": 102211,
        "voice": "vo_adv_7002000_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你的記憶關鍵就在那裡了是嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦？　",
        "unit_id": 102211,
        "voice": "vo_adv_7002000_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "或許？　",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "什麼嘛，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不清不楚的……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哎，",
        "unit_id": 102211,
        "voice": "vo_adv_7002000_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不是這樣啊！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這時候應該說",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就交給我們來吧才對啊—！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真是的，",
        "unit_id": 102211,
        "voice": "vo_adv_7002000_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我真傻……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這裡可是有找回他喪失記憶的線索呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n一直以來",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "如此照顧這麼怕生的我，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "必需要好好報答才是！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "唔唔。",
        "unit_id": 102211,
        "voice": "vo_adv_7002000_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可是，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "完全沒有把心意好好傳達給他……",
        "unit_id": 102211
