[
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "把我們的力量",
        "unit_id": 133711,
        "voice": "vo_adv_5201331_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "合而為一，",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是吧。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n……一定要打倒它才行。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也有同感，",
        "unit_id": 133811,
        "voice": "vo_adv_5201331_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但對方看起來不會讓我們輕易解決掉。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們的闇影啊。",
        "unit_id": 133911,
        "voice": "vo_adv_5201331_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還真是",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "令人焦急呢。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉，",
        "unit_id": 133711,
        "voice": "vo_adv_5201331_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "現在沒心情玩樂了。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們要用全力突破……",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "做好全身被開洞的心理準備吧。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "克莉絲，",
        "unit_id": 133811,
        "voice": "vo_adv_5201331_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我要替晶開闢彈道路徑。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳來支援我。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……知道了。",
        "unit_id": 133911,
        "voice": "vo_adv_5201331_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是隨便穿過現在的她面前，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n恐怕連我身上都要開洞了。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「武裝生成」。",
        "unit_id": 133711,
        "voice": "vo_adv_5201331_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n朝向世界",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "──發射。",
        "unit_id": 133711
    }
]