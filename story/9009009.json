[
    {
        "type": "background",
        "background": "502110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吉歐‧格黑納某處──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n異國的人們好奇地看著排成一列的攤販。"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這就是",
        "unit_id": 133111,
        "voice": "vo_adv_9009009_000"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "祭典──",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n來往的人們、",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "攤販的叫賣聲，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n都非常地",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "充滿活力……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不知道為什麼，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "感覺令人頭暈目眩。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "請別到處亂晃，",
        "unit_id": 133012,
        "voice": "vo_adv_9009009_001"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "薇歐莉特公主。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n護衛也是很辛苦的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "而且──",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "──我也是第一次，",
        "unit_id": 133014,
        "voice": "vo_adv_9009009_002"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "見識到這樣的人潮。",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "覺得頭很暈……",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "感覺",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "自己快要消失了……",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "先不開玩笑了。",
        "unit_id": 133012,
        "voice": "vo_adv_9009009_003"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n騎士氏，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "有什麼推薦的攤販嗎？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "──啊，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那邊的烤魷魚就不用了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……騎士先生。",
        "unit_id": 133111,
        "voice": "vo_adv_9009009_004"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那邊",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是在烤什麼東西呢？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n黃色的",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "棒狀",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "物體……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "有像是魚卵的東西緊密地附著在上面，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n還用刷子",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "塗上了褐色的液體，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "聞起來很香……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是在吉歐‧尼布爾黑爾",
        "unit_id": 133111,
        "voice": "vo_adv_9009009_005"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "沒有見過的食物呢。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n這個要怎麼食用呢？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "刀子和叉子……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……什麼？",
        "unit_id": 133111,
        "voice": "vo_adv_9009009_006"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就這樣",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "直接啃咬嗎？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "而且，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "還是站著吃……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "簡直",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就像野獸一樣。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n身為公主，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是不應該有這樣的行為的……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "…",
        "unit_id": 133012,
        "voice": "vo_adv_9009009_007"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "…嗯嗯。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "貪吃佩可公主",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "一口氣吃10支也不是問題",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "嗎。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n真是太驚人了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這下子妳也不能輸呀，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "薇歐莉特公主。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "好……",
        "unit_id": 133111,
        "voice": "vo_adv_9009009_008"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "好的。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n那麼，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "雖然有些難為情……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……！",
        "unit_id": 133111,
        "voice": "vo_adv_9009009_009"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n這真是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "非常地",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "美味。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n太令我吃驚了……♪",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "…",
        "unit_id": 133111,
        "voice": "vo_adv_9009009_010"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "…好的。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "如果",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "時間上允許的話……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n能否勞煩你帶路呢？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "呵呵……",
        "unit_id": 133111,
        "voice": "vo_adv_9009009_011"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "謝謝你。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "真的",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "四處都是稀奇的事物……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "好久沒有",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "像這樣",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "雀躍了。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "太好了呢，",
        "unit_id": 133012,
        "voice": "vo_adv_9009009_012"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "公主。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "也很高興──",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "能見到公主張大著嘴，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n啃咬玉米",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "的稀奇模樣。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……！",
        "unit_id": 133111,
        "voice": "vo_adv_9009009_013"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那、",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……真是的。",
        "unit_id": 133111,
        "voice": "vo_adv_9009009_014"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "別說那種壞心眼的話啦，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "格蕾斯……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吉歐‧尼布爾黑爾的公主和守護騎士"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n盡情地享受了異世界的喧鬧。"
    }
]