[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為紡希有想要拜託的事情，\n因此{player}被叫到了人煙稀少的郊外來。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生。今天非常感謝你能過來！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "由於這件事我不太想讓別人知道，",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n只好把你叫到這種地方。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……騎士先生。那個，其實……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "最近出現了一些纏著慈樂之音成員們的人在，",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n請你和我一起對付他們！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "拜託你了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在經過那次騎士先生也來看過的慈樂之音首次演唱會之後，",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我就開始感覺到一些陌生人的氣息。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他們目標一定是小望和千歌！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那兩個人名氣這麼高，又那麼有魅力！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以我要守護那兩個人，兼任幕後工作也是我的職務！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n如果就這麼放任不管，發生什麼情況也不足為奇！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我沒問題的。",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "話說要是有人想纏上我，我會率先察覺的呦。請你不要小看我了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我在遠遠守護著怜大人可不是虛有其表。",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我對旁人的視線比較敏銳喔。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我沒有什麼名氣所以沒問題的！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你還會為我擔心呢……謝謝你！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總之，要是有個什麼三長兩短就太晚了，",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們一起合力逮捕犯人吧！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──隔天後，\n{player}便開始按照紡希的指示，\n在慈樂之音的工作現場擔任起了警備的職務。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生從今天開始，就麻煩你開始監視千歌和小望的周圍！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n再加強對那兩人的護衛，她們應該就不太可能會被人接近了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為了被預防對方有可能現身，",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我在各處都事先設好了陷阱！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可別不小心自己中了圈套哦？",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果是跟犯人一起進圈套的話我倒是歡迎！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "很好……我要讓他們後悔自己動慈樂之音成員的歪腦筋！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n來吧！不管是從何處都給我放馬過來吧──！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──第二天。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "放馬過來吧！！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_015"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──第三天。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "放馬過來吧！！！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_016"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──在那之後的過了幾天。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……什麼也沒發生呢……",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我也漸漸感受不到對方的動靜了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊！該不會是察覺有危險了，",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n已經放棄跟蹤了嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一定是這樣的啦！啊──謝天謝地！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生也是這麼認為的嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這就是佈下如此嚴密警戒網的成果呢！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "接下來我還有舞蹈課，可以安心地去上課了。",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生。這幾天，辛苦你了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來，這是本次的報酬！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那就先這樣我先走囉！辛苦你了！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天的課程也是相當嚴格啊，",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不過感覺自己稍微可以順利地踏起舞步來了呢……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……嗯？",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "背後有人的氣息……",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是騎士先生嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "果然是他沒錯……",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是愛擔心呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……咦？還有別的動靜？",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "應該只是路過的行人吧。我停下來他應該就會走過去了吧。一二──",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……沒有任何人經過。",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "誰？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "會是誰？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對方朝我接近了！該怎麼辦……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "討厭討厭討厭討厭……！得快逃才行！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼啊……呼啊……！",
        "voice": "vo_adv_1054006_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是腳步聲！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他追上來了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "果然不是騎士先生而是另有其人！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這麼說的話，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是打算報復的犯人嗎……！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼！呼！呼！呼！呼！呼！　",
        "voice": "vo_adv_1054006_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊……沒路了！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "居然在這種時候……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "呼啊……",
        "unit_id": 311,
        "voice": "vo_adv_1054006_036"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "紡……呼啊……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "紡希……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請救救我！！騎士先生！！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！太好了……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你、你就不能再早一點過來嗎！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "太慢了啦！我、我很害怕的！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過還是得救了！待會再稍微獎勵你一下！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你是誰啊！可惡！給我閃一邊去！",
        "unit_id": 311,
        "voice": "vo_adv_1054006_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "噫！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不要過來！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "走開啦──！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對啊！現在就用我的絲線來……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "乖乖讓我抓起來吧！嘿～咿！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_043"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "唔哇啊啊啊啊啊！",
        "unit_id": 311,
        "voice": "vo_adv_1054006_044"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "身體被線…",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "緊緊纏住了……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n不能動了……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "嗚、呃……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "成功了……我成功了！抓到他了──！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，我成功了──！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "給我停一下！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n剛才我是不是差點就要抱住人家了啊！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好險好險！雖然剛才一直都很驚險，",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但現在在別種意義上來說也很危險啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我要冷靜一點──！想起怜大人的臉來做個深呼吸──！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "吸……吐……吸……吐……怜大人～♪",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哈啊……怜大人，多麼出色啊……",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_050"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……呼。冷靜下來了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個……騎士先生你為什麼會在這裡？",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣啊……非常感謝你。",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_052"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n多虧了你我平安無事。……那麼。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然我被嚇得有點驚慌失措的，",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_053"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但那邊那位先生！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n為什麼你要一路追著我跑啊！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且你的目標應該是小望還是千歌才對啊……",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_054"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你也弄錯人錯得太離譜了吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "欸……因為，我最喜歡的紡希，",
        "unit_id": 311,
        "voice": "vo_adv_1054006_055"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n終於單獨一個人了……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣啊，",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_056"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你最喜歡的紡希終於一個人……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你說我！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這麼說的話你……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是我的粉絲嗎！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我是你的大粉絲啊！",
        "unit_id": 311,
        "voice": "vo_adv_1054006_057"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n演唱會那時，妳比慈樂之音當中任何一個人，都來得耀眼！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "欸！？不不，怎、怎麼可能……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_058"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳是我的女神啊！請妳和我交往！",
        "unit_id": 311,
        "voice": "vo_adv_1054006_059"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n拜託妳了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "欸！？我，居然會被告白，這還是我有生以來第一次……",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_060"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那個……這個嘛……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_061"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒、沒什麼啦！你不要看著我啦！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_062"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不管怎樣就是不准你看！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……那個！我……現在，已經有心儀的對象在了……",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_063"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n所以，我不能和你交往！抱歉！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "怎、怎麼會……！",
        "unit_id": 311,
        "voice": "vo_adv_1054006_064"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n明明終於見到我的女神了……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔……這個人，似乎跟我看著怜大人時的反應很像呢。",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_065"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不知道如何表達自己的感情，",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_066"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n比起為對方設想，不小心總是以自己的想法為出發點……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……你的心意讓我很開心，但是傳達的方式錯了。",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_067"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "傳達的方式……",
        "unit_id": 311,
        "voice": "vo_adv_1054006_068"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以你就到牢房裡好好反省去吧，下次再遇見喜歡的對象，",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_069"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不是從身後偷偷摸摸地來，而是從正面坦率地，將自己的感情傳達出去。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是……",
        "unit_id": 311,
        "voice": "vo_adv_1054006_070"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n對不起，紡希……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你能明白的話就好了。",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_071"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "話說",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你的功力也太差勁了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n害我都誤會了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這點也給我順便去反省反省！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你的動靜都完全暴露了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_072"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那麼容易暴露的行動，簡直就像叫人家說快點注意到我一樣！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "對不起……欸？",
        "unit_id": 311,
        "voice": "vo_adv_1054006_073"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我說你啊，作為粉絲不能讓你的視線",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_074"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n存在感過於強烈啊！你這樣完全不行！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "守候，正是作為一個粉絲最重要的品德啊！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_075"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你這樣放出這種「快看我」的視線，對方是會察覺出來的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "視線要像憐愛著高雅盛開的花朵一般！",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_076"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n要讓自己的氣息近似於消失，和自然風景融為一體！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n單純的注視是不行的！一定要靜悄悄、靜悄悄的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不是，",
        "unit_id": 311,
        "voice": "vo_adv_1054006_077"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那個……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我已經……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你首先，",
        "unit_id": 105411,
        "voice": "vo_adv_1054006_078"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "得從眼神的注視方式好好學起才行！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n啊，喂，你別逃走啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "給我坐好！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "快一點！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "　\n騎士先生也請一起聽！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看見紡希毫不留情地對男生說教的樣子，\n{player}一邊坐著一邊看著紡希恢復原來的樣子安心了下來。"
    }
]