    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "昴。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "雖然昴說不是那樣的，",
