    {
        "type": "dialogue",
        "name": "昴",
        "words": "──海邊",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_018"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "果然很棒啊。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "喔，兄弟。",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_019"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "你不去那邊沒關係嗎？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n這裡就只有",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "覺得被穿著泳裝的女孩包圍很坐立難安，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n所以縮在角落扭扭捏捏地看著那邊，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "多愁善感的我而已喔？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "那還真是光榮呢。",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_020"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n那麼",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "你想聊啥？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "戀愛話題嗎？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n如果你有喜歡的女孩就告訴我吧～",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "……",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_021"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不過兄弟，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "你也很辛苦呢。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "你有好幾次都失去記憶……",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_022"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "變成「那個狀態」了吧？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "很多人都知道呢。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我可不想習慣啊！？",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_023"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "老實說，",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_024"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我光是想起自己在愛蜜莉雅醬面前",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n說出吧哺吧哺的樣子，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我的臉就要熱起來了啊……",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "唉……",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_025"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "而且還被很多人看到了……",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "啊，",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_026"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "被很多人看到的是之前那輪嗎。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不不不，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "別在意別在意，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "這是我自己的事。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不過，",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_027"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "總而言之，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "你是個很厲害的人啊！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n大家都為了你而行動，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "所以這次也順利解決了吧？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "該說是",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_028"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "能感受到羈絆嗎。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "那樣的羈絆，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "會變成很強大的力量呢。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n你累積起來的東西，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "讓我發自內心感到尊敬啊。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "……咦？",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_029"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n什麼啦，喂，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "你已經要走了嗎？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我們連乾杯都還沒──",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "──昴？",
        "unit_id": 131911,
        "voice": "vo_adv_5152007_030"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "愛、",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_031"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "愛蜜莉雅醬！？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n……那傢伙",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "是顧慮到我了嗎。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "……昴，",
        "unit_id": 131911,
        "voice": "vo_adv_5152007_032"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你又獨自一人為我們在努力了呢。",
