        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我明明跟你說過",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不要亂來的。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "討、",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_033"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "討厭啦，愛蜜莉雅醬妳真是的。",
