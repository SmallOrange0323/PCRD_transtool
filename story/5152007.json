        "voice": "vo_adv_5152007_034"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你又像這樣子開玩笑。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我可是很清楚的喔。",
