    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為昴的奔走而聚集起來的異世界羈絆。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他們集結眾人的力量，打倒了白島鯨。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n讓海邊回歸平靜的他們，再次展開心心念念的夏日假期──"
    },
    {
        "type": "still",
        "still": "515200702"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不過，",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_000"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "人變得很多呢。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位～♪",
        "unit_id": 107512,
        "voice": "vo_adv_5152007_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這是大勝利紀念！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家就盡情地吃吧☆",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "愛蜜莉雅大人，",
        "unit_id": 132112,
        "voice": "vo_adv_5152007_002"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這個似乎是熱帶果汁。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "大精靈大人也請用。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "謝謝妳，雷姆。",
        "unit_id": 131911,
        "voice": "vo_adv_5152007_003"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "雷姆",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也要好好休息才行喔？",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "這飲料的顏色還真是奇怪呢？",
        "unit_id": 2612,
        "voice": "vo_adv_5152007_004"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n想像不到它的味道呀……",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "啊，",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "這個好好喝♪",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "巴魯斯之前說過，",
        "unit_id": 109812,
        "voice": "vo_adv_5152007_005"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "到海邊的話就要吃炒麵。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n必須確認巴魯斯是不是又說謊了才行呢。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n雷姆，",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "去幫我拿炒麵過來。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明就是雙胞胎女僕，這差異是怎麼回事啊……",
        "unit_id": 107812,
        "voice": "vo_adv_5152007_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來吧，拉姆，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我幫妳拿了很好吃很好吃的炒麵過來喔～？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 107612,
        "voice": "vo_adv_5152007_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您剛剛似乎",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "往那盤炒麵加了很多辣椒粉……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您應該不是打算把那個拿給拉姆小姐吧？",
        "unit_id": 107612
    },
    {
        "type": "still",
        "still": "515200703"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這麼說來，",
        "unit_id": 110311,
        "voice": "vo_adv_5152007_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我還沒有游泳呢……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "先稍微游一下之後，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再來吃東西吧。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n鏡華要不要也一起來？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？",
        "unit_id": 122711,
        "voice": "vo_adv_5152007_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我對游泳還沒有自信……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果是那樣的話我有個好東西。",
        "unit_id": 126611,
        "voice": "vo_adv_5152007_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我這裡有橡膠船，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "用這個就沒問題了吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇……",
        "unit_id": 122711,
        "voice": "vo_adv_5152007_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "看起來好有趣……♪",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n如果是這樣的話感覺好像很不錯……！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我跟妳兩個人的話",
        "unit_id": 126611,
        "voice": "vo_adv_5152007_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這個尺寸可說是綽綽有餘吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剛好也抓到動力來源了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個，",
        "unit_id": 110311,
        "voice": "vo_adv_5152007_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳說的動力來源",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該不是指我吧？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我說",
        "unit_id": 113511,
        "voice": "vo_adv_5152007_014"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "蘭法，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "妳要不要再稍微",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "靠過來一點呀。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "不，",
        "unit_id": 126911,
        "voice": "vo_adv_5152007_015"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "那個……",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我，",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "在這裡就好……",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，",
        "unit_id": 113511,
        "voice": "vo_adv_5152007_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師能過去妳那邊嗎。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "……好、",
        "unit_id": 126911,
        "voice": "vo_adv_5152007_017"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "好的……！",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n因為我……",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "也有很多事情，",
        "unit_id": 126911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "想要問妳……",
        "unit_id": 126911
    },
    {
        "type": "background",
        "background": "500691"
    },
    {
