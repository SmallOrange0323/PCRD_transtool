        "voice": "vo_adv_5152007_042"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n進到海裡去、",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "玩「沙灘排球」……",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n而且，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "還受到了很多人",
        "unit_id": 131911
    },
    {
