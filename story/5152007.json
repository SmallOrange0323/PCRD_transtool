    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "哈哈哈……",
        "unit_id": 2713,
        "voice": "vo_adv_5152007_035"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我只是",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "去拜託大家過來而已啦。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "她們之所以會一起來跟白島鯨戰鬥，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n是因為愛蜜莉雅你們跟大家締結了羈絆啊。",
