[
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊……",
        "unit_id": 113911,
        "voice": "vo_adv_6050101_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怜大人打扮的女幽靈",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的是最棒了呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "甚至用最棒這個詞都不夠啊。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n該怎麼形容才好呢……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "正所謂簡單就是美嗎？",
        "unit_id": 113911,
        "voice": "vo_adv_6050101_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "原來如此。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你能夠如此盛讚穿著我所縫製衣服的怜大人，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n該怎麼說、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我非常開心呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝你。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "究、",
        "unit_id": 113911,
        "voice": "vo_adv_6050101_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "究極？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你是想指最高級吧？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過這形容不覺得哪裡不對嗎？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怜大人是究極……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n好像也不錯……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不對，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "果然還是很奇怪啊！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不要只是像隻鸚鵡一樣重複，稍微思考一下啦！",
        "unit_id": 113911,
        "voice": "vo_adv_6050101_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過終究還是我的形容最好，是這個意思吧？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這也是當然的啊，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為最關注怜大人的是我嘛！",
        "unit_id": 113911
    }
]