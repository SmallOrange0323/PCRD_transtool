[
    {
        "type": "background",
        "background": "500022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呼。",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n已經完全天黑了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為最近克莉絲提呈報給陛下的意見，",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我的工作時間縮短了……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總之變成",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n能回家好好在床上睡覺的情況了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為通勤，必須得往返於家裡及王宮之間，",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n反而有點麻煩啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "至今為止，",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我都是在【王宮騎士團】的據點睡覺的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我不能常駐在王宮，",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n戒備人手又變得有些不足了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "克莉絲提娜不可能只是單純地對我親切，",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總～覺得她在計畫著什麼陰謀詭計。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是話說回來……",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n今天的確，精疲力盡呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然也沒有特別做什麼。",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只是一直站著，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n一直戒備著，也是無聊的難受。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，這就是我身為守衛的工作。",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為直到前幾天，",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n少年還常常來露臉……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "期待著他出現，",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就這樣度過了一天……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是已經告別了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為少年是認真的好孩子，",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n聽了我說的話，不會再靠近王宮了吧……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n應該再也不會見面了吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然我早已做好覺悟。",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但果然，還是感到有點寂寞呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…嗯？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n剛剛，那邊的暗處似乎有什麼動了？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可疑份子嗎，還是魔物呢？",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n會是最近傳聞中的「闇影」嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "首先，先過去看看吧。",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n守護城鎮的和平，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就是我們【王宮騎士團】存在的意義。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "誰在那裡！",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若是聽得懂我說的話，就回應我的呼喚，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n現出身影來！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯，奇怪？",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n少年？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真、真是巧遇呢。",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在那種地方，做什麼呢？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那個……",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n明明已經告別了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n沒有想到會突然遇見。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真不知道",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n該採取怎樣的態度才好呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……？",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n少年，怎麼了？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望你至少能回應我。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是……",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n少年，正沉睡著嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為什麼呢？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這是什麼，好刺眼……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這是為何呢，總覺得我也變得昏昏欲睡。",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "510240"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_027"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……咦？",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n啊啊少年，你等很久了呢。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_029"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n總算看見你的模樣，暫且放心了。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦？",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_030"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n啊啊，嚇了一跳。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不需要突然那麼大聲喔。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很可怕嗎，我……？",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你說，因為突然有人戴著面具出現，",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還以為是可疑份子……？",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可疑嗎。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這可是正義的英雄，",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n虎虎的面具喔。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小孩子都喜歡吧，像這種的……",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n會被這麼的害怕、警戒，真是出乎意料。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔嗯。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你已經是高中生了，",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也不是小孩子了啊",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是失禮了。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是我考慮不周呢。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "下一次，",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就戴高中生會喜歡的面具吧。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哎呀……？",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n抱歉，少年。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為你突然朝我撲上來，",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我瞬間使用了合氣道的招式，把你甩出去了。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n沒有受傷吧？",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "最好不要輕易抱住女性喔。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然我是不在意，也能夠應付這種情況，",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但會被其他人認為是色狼的吧？",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n想要激動地抱住我，",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n能夠見到我有那麼高興嗎？",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "算了。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_042"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n好像平白引起了放學中學生們的注目，",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n趕快把事情完成回家吧。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年，希望你收下這個。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這是遊樂園的免費入場券。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯？",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不，並不是約會的邀請。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我們也不是那樣的關係吧。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你經常在遊樂園，",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n幫忙我的工作對吧？",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "準備英雄秀的舞台啊，",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_046"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n以及飾演怪人角色等等的……",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這是，那個的謝禮。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "讓你無償的工作，我也感到十分抱歉呢。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_047"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望你能收下，少年。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不用客氣。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_048"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我因為工作的關係，得到了大量的免費票券。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "即使給你幾張，錢包也不痛不癢，",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n與其在我手裡派不上用場，不如給別人使用更好。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "應該也可以變換成現金。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_050"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果你覺得報酬還是給現金比較好～的話，",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就麻煩你拿去變換現金吧。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只是，你也是高中生對吧，",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_051"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n青春正盛啊……",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "要是能用這個邀請喜歡的女孩子，",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_052"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n來場約會就好了。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_053"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n結果我倒是成了",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n戀愛的邱比特呢。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你能高興就太好了。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_054"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n能看見像你一樣的孩子的笑容，",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n對我來說就是最棒的報酬了。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_055"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我要說的事情就只有這樣。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n引起騷動真抱歉呢，少年。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_056"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n下次，有空的時候也好，",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你能再來幫忙的話，我會很開心的。",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那麼再會了，下次再見吧……少年。",
        "unit_id": 104731,
        "voice": "vo_adv_1047004_057"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只要一醒來，就會全部忘記了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說，雖然每次都要說明也很麻煩……",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總～覺得，會出現我意料之外的事情呀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n盡是些麻煩事啊，真是的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然明明應該要全部忘記的。",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是你以及夢裡出現的女孩子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n卻會依稀記得內容……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為夢境的關係，也會使行為產生變化。",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然現階段，似乎還沒什麼嚴重的影響。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊。",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉抱歉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n說了和你無關的話呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在屋外就這樣睡著會感冒的，",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n快點醒來吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，為了慎重起見，先告訴你一聲。",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "先不要對純提起關於這個夢的事情喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算是有個萬一，",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我的存在也不能被查覺到。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "純擔任團長的【王宮騎士團】，",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "實在是個可疑的集團呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "恕我直言，",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n他們在背後為我們的敵人撐腰的可能性很高呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然純，",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n似乎是個單純善良的人。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但也有因為隸屬於組織，",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而拋下個人的道德觀的案例。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要十分小心喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n純自己之前也說過，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不要與她太過親近比較好。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "越是親近，",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n越會成為痛苦的回憶也說不定呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過話就說到這裡。",
        "unit_id": 190011,
        "voice": "vo_adv_1047004_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n下次，在夢裡再會吧。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_074"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n奇、奇怪？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我，睡著了嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "感覺好像做了個奇怪的夢……",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_075"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗚嗚，頭好痛。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "太不成體統了。",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_076"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n居然在這種戶外睡著了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n唔～嗯，該不會被施了什麼奇怪的魔法吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦？",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_077"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n啊啊，少年……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你也，一起睡著了嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是怎麼回事呢？",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_078"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這麼說來我確實在回家途中時，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在陰暗處發現了你……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然因為擔心而跑了過來，",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_079"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n結果不知為何似乎睡到了現在呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "完全不明白是什麼狀況。",
        "unit_id": 104711,
        "voice": "vo_adv_1047004_080"
    }
]