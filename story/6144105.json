    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯～",
        "unit_id": 130811,
        "voice": "vo_adv_6144105_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不知道是不是該感到開心，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但沒想到我冒失引發的爆炸，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n也會有能幫上忙的時候呢～",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不知道有沒有其他能透過爆炸來幫上忙的情況，",
        "unit_id": 130811,
        "voice": "vo_adv_6144105_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你有想到嗎？",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果可以作為參考就好了……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "用、",
        "unit_id": 130811,
        "voice": "vo_adv_6144105_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "用爆炸的力量支配世界！？",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不可以做這種事啦，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "駁回～！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請提個更和平的點子吧！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為藝術就是爆炸，",
        "unit_id": 130811,
        "voice": "vo_adv_6144105_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以我的冒失也是藝術……？",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "覺得好像懂，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "又好像不太懂……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過，",
        "unit_id": 130811,
        "voice": "vo_adv_6144105_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果能利用爆炸來進行華麗的表演，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n感覺似乎能讓很多人開心呢♪",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝你",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "給我意見～",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "的確，",
        "unit_id": 130811,
        "voice": "vo_adv_6144105_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "像那種作業好像很適合呢！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "畢竟那是我冒失破壞越多東西，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就會越讓人高興的工作！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那我回去以後",
        "unit_id": 130811,
        "voice": "vo_adv_6144105_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "再找大小姐商量看看。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要是能多少賺一些錢，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還可以買點東西",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n給孩子們呢……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿嘿♪",
        "unit_id": 130811
    }
]