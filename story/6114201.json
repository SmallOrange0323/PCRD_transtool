    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這陣子鯛魚燒銷量一直沒有起色喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "現在就來研發新的鯛魚燒，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "擴大銷路喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好主意喵！",
        "unit_id": 104611,
        "voice": "vo_adv_6114201_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "奢侈地使用整條魚，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n內餡一堆餅皮也跟著……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "等等，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "換言之就是烤魚了喵！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣根本稱不上是鯛魚燒喵～",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "意思是超甜鯛魚燒喵？",
        "unit_id": 104611,
        "voice": "vo_adv_6114201_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那試著塗上",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "像布丁那樣的焦糖怎麼樣喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "酥酥脆脆的口感應該很受女孩子歡迎喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵來如此，",
        "unit_id": 104611,
        "voice": "vo_adv_6114201_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "像飯糰那樣，把內餡改成鹹食喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣除了當點心，也能當午餐享用喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這下肯定能擴大銷路喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你真聰明喵♪",
        "unit_id": 104611
    }
