    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在普拉諾平原做擊退魔物的工作時，\n兩隻魔物襲擊了過來。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物２",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "輪到我的回合了！",
        "unit_id": 1,
        "voice": "vo_adv_1013001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "發動新魔法！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "效果是，",
        "unit_id": 1,
        "voice": "vo_adv_1013001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對手一定會死──！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇～",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "威力真強！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然是新學到的魔法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好像能熟練運用了呢？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔物這不是被擊敗了嗎！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不愧是七七香！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是天才！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還真是老王賣瓜呀！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛剛擊敗的魔物呢～？",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n一隻，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "兩隻、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "三……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "隻",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有一個",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "非魔物的生物倒在那裡……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這是人類！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛剛明明沒有人呀……",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n難道是",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "從天而降的嘛……！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "出現了！",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "師傅！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有男孩子從天而降──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是會正好這時候醒過來的男孩子？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這時機真不錯！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "聽了可別嚇一跳！",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你現在，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "正跨出通往異世界的第一步！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我是",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "即將領導你的美少女",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "應該是。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦咦！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以說是我？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不不不，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "本人七七香不可能犯那種錯誤……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "又來了～！",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "開那種玩笑！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可能是因為轉世到了異世界，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "導致記憶混亂的緣故？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……欸？",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的是被我的魔法擊中打飛的？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n……不是玩笑話？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的嗎！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咕嗚嗚……",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你的衣服",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "的確破破爛爛的呢。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n原來你就是最有力的證據啊……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼會～",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒想到會有人在……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我還使出了全力……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有沒有受傷……？",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是說，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "都被打飛應該",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不可能毫髮無傷啦……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼說來，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我該不會是",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "犯罪者！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "傷害罪！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎怎怎、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼辦，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我不想被抓呀～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在牢房裡沒有漫畫吧！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n也不能繼續宅了吧！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我可忍不了呀！",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我可是由創作品所構成的呢！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不、",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可是可是",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你還活著所以沒關係吧？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只是輕傷的話應該不會被處重罪吧……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊啊這不重要！",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的很抱歉！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n因為我真的太想嘗試新學的魔法了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我不是故意要擊中你的，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "該怎麼說，那個……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "拜託不要報警",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可以嗎……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你不打算報警……？",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n真的……！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的嗎真的嗎！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "出現了！",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我這樣亂施魔法竟然還願意原諒我！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這可是神對應呢！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "果然世上充滿了希望呢！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚哈，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_025"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "太好了……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要是進了牢房，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "人生可就毀掉了喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊、",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼說來，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還沒自我介紹呢！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我是",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "阿斯特朗最棒的魔法少女，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "七七香！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "用電腦的閃光來攻擊敵人──！",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_027"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……完美。",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呀哈──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n怎麼樣？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "很帥氣吧！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "果然我可愛到不行又強到不行！",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你不知道魔法少女……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "竟然！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔法少女就是呀，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "會用魔法幫助人們的，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "超級可愛的女孩子喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然像故事才會出現的情節，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_032"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但難得會使用魔法，朝那個目標前進也不錯吧！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這就是我",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_033"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "成為魔法少女的原因喲！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今後請多指教──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_034"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "說到這個，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你明明被我的魔法打飛了，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n怎麼還能像沒事一樣活蹦亂跳？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "被我的魔法攻擊卻還像沒事一般，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_035"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n看來不是等閒之輩……！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "施主，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_036"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "敢問大名！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呵呵，叫{player}呀！",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_037"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真不錯的名字！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "該不會你，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_038"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "知道傳說中的魔導書？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n你如此不凡，可能握有情報呢！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "知道的話拜託告訴我！",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_039"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真興奮啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "閃閃發光！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼嘛，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_040"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "原來不知道呀。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不知道也是正常的……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "傳說中的魔導書啊，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_041"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有了這厲害的魔導書，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n就可以用超厲害的強力魔法了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那魔法可以劈開天地……",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_042"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n可以隨使用者的想法改變世界……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_043"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "能變成超越一切的存在！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在～",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_044"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊不過這些只是我的妄想就是了。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過應該是真的存在著的！",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_045"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "光想就",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "意志高昂啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "想到就覺得好浪漫喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_046"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果你得到什麼情報，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一定要第一個告訴我喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "身為一個收藏家，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我可是說什麼都想入手！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "總之，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_047"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天也成功試了新魔法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n讓我先告辭啦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為還沒做定期巡迴，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_048"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "得快點回去！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n而且今天是新品上市日，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n拖拖拉拉的話初回限定版可要賣光囉！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我在城裡的古物店工作！",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_049"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n隨時",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等你的情報喔！　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那就這樣吧，",
        "unit_id": 101311,
        "voice": "vo_adv_1013001_050"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再見──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看著離去少女的背影，\n若是魔法師的話，還真希望她能先施完治癒魔法後再走呢。\n{player}這麼想著。"
    }
