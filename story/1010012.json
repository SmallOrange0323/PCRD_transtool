        "type": "dialogue",
        "name": "真步",
        "words": "望向王子先生臉龐的角度……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_056"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "果然還是被發現了呀～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "別把我放下來呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天可就要像這樣，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓王子先生",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一直公主抱我抱到最後呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您願意寵人家，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_057"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "剛不是這麼說了嗎～？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "既然是您自己所說的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您可要給人家負責才行唷♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "乾脆還不只是今天，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_058"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n往後都一直讓王子先生抱著走好了呢～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_059"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "開個玩笑。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可以把人家放下來了唷～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……那個呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_060"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家能再問您一次嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_061"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不但是個撒嬌鬼，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且也很不擅長複雜的魔法，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n做為一個公會長",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也還完全不夠格……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然是這副德性的我，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_062"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但您能不能不只是和人家一塊努力而已，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "能不能一直待在人家身邊呢……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_063"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n我命運中的……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家最喜歡的王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與真步朝著城鎮回去。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他們之間的那份思念，和並肩而行的身影，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n也許真的就像是故事中的王子與公主一樣呢。"
    }
]