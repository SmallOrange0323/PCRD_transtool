        "words": "\n就在這時，偶然地遇見了"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正好接下了相同委託的{player}。"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "神奇真步魔法靈，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咕嚕咕嚕靈～……☆",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵～",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "竟然能和",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生一塊工作，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真讓人開心呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "果然您和人家，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "正是被命運連接著的呢～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊……",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可不能興奮過了頭呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "首先要先確認街道上的狀態呀～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那塊石頭是不是有點危險？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果害得小孩子摔倒了可不好，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還是撿起來吧",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這邊的路面則是有些損毀了呢。",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n雖然人家不太擅長通訊魔法，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但為了能早一點修理好，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還是報告一下吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家可不是",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一直都是以前的那個人家了唷～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不管是魔法",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還工作，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家可是都更努力了唷♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我想想，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "通訊魔法",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n首先得要先指定好座標……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "然後是要怎麼做來著？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒、",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒問題的唷～？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n最近",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家有去請教過霞了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "比較正式的魔法，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也有好好從頭開始學了……！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "首先",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要先把魔力凝聚起來……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "竟然會有魔物出現在這種地方，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n看來偵查魔法",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也還不夠完美的樣子呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總之，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這裡就交給人家來吧～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我想想，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒記錯的話，攻擊魔法的基本，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不是要一口氣放出所有魔力，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n而是要好好的控制……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦？",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咿呀！？",
        "unit_id": 101011
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝您保護了人家～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就、",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就算不用那個魔法也沒問題的唷～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "請您安心，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "下次一定會順利成功的。",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我想想……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "首先要凝聚魔力，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n再來要一邊好好地控制……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "失敗了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "得要從頭再來一次才行……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……咦？",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您靠得人家這麼近，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是發生什麼事了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您說要我們快逃……？",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n可是，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "魔物還……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎～～呀～～",
        "unit_id": 101011
    },
    {
        "type": "background",
        "background": "500142"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……我們離街道有相當一段距離了呢。",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "天色也漸漸暗了，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "差不多",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "該做些什麼事了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n魔物的話……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好像還在附近的樣子呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒問題的唷～",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然剛剛不是很順利，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但這次一定會好好地做給您看的……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……那、",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那可不行！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊……",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "抱、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "抱歉，王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家竟然這麼大聲對您說話……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……可是，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n若是用平常的魔法可不行呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不是用人家好好學起來的魔法可不行。",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "若不這麼做，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就沒辦法證明人家真的有在努力了呀……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……那一次",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "回老家的時候呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家向父親",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "把自己在考慮的事，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還有心中所想的事",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "全都說出口了唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "包括了做為一名公會長，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "經歷了過去從未經歷過的經驗……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只要和大家待在一塊，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就會開心到連時間都忘記了的事情……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還有，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就是和王子先生您相遇的事……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "父親他，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "聽人家說這些事情的時候，看起來相當開心呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n「妳真的很努力呢」——",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在這麼稱讚了人家之後，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "又再繼續說了下去唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說「妳現在",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不用在意店裡的事也沒關係。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n妳就去做",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妳想做的事情吧。」",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010012_029"
    },
    {
