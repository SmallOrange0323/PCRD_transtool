    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生？ ",
        "unit_id": 100211,
        "voice": "vo_adv_1002008_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "早安呢。今天也是去工作嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……總覺得太陽很刺眼呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……不對勁呀，不可能這麼刺眼的。",
        "unit_id": 100211,
        "voice": "vo_adv_1002008_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這道光，的確之前也……！",
        "unit_id": 100211,
        "voice": "vo_adv_1002008_002"
    },
    {
        "type": "background",
        "background": "510220"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（──鐘聲應該還沒響吧……？",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我還想在最後關頭，把小考的範圍內容重新複習一遍呢……）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，響了……",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（首先看看題目……咦？）",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（……我絕對沒看錯。",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n他，好像沒帶橡皮擦）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（真想助他一臂之力……",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n但現在是考試中，如果被老師發現的話會被罵的呀……）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（……不對。這種想法是不行的）",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（如果是他的話，",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n當看到正在煩惱的人的時候，一定會借給那個人的……！）",
        "unit_id": 100231
    },
    {
        "type": "still",
        "still": "100200801"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "吶，{player}……",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果不介意的話……請用這個。",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "噓……",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……給你。小心不要被老師發現，靜悄悄地拿走呦。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不用在意我。",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我還有多一塊橡皮擦。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯……考試要努力加油呦……",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_014"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（太好了……）",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（……咦？　剛剛給他的橡皮擦，是我平常用的那一塊……？）",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（怎……",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼辦！　那塊、在那塊橡皮擦上……！）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（寫著我喜歡的人的名字……！）",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（之前相信網路上的占卜而寫下來的，",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n之後卻完全忘了啊……！）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（明明是我的橡皮擦，如果他發現了上面寫著自己的名字的話",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n絕對會覺得很奇怪……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "要想點辦法才行……！）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……我想跟你，交換那個橡皮擦。",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你看，",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我這邊這個橡皮擦更好用的喔……？",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒關係！？",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……我、",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我這裡可是很有關係呀……！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（如果更大聲講話的話會被老師注意到的……",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為什麼我會借了那塊橡皮擦給他呢……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "）",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不行！別看裡面呀！",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（啊……不小心大叫了……",
        "unit_id": 100231,
        "voice": "vo_adv_1002008_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣會被老師罵然後要補考了吧……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……不過沒有被他看到真是太好了呢）",
        "unit_id": 100231
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我給你的禮物，你覺得如何呢？",
        "unit_id": 190011,
        "voice": "vo_adv_1002008_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你有好好的做了個好『夢』嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是我依照以前的你和優衣的記憶所創造的『夢』……",
        "unit_id": 190011,
        "voice": "vo_adv_1002008_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你這種遲鈍個性如果不稍微改一改的話，\n總有一天會吃大虧的喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，就下次再見囉～♪",
        "unit_id": 190011,
        "voice": "vo_adv_1002008_029"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯嗯……",
        "unit_id": 100211,
        "voice": "vo_adv_1002008_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n又是那個夢……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生……",
        "unit_id": 100211,
        "voice": "vo_adv_1002008_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們兩人，又再次做了同一個夢呢……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真抱歉，突然發出了那麼大的叫聲……",
        "unit_id": 100211,
        "voice": "vo_adv_1002008_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那塊叫做橡皮擦？的東西裡面的樣子，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "絕不想被人看到的……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "至於上面寫了些什麼東西呀……",
        "unit_id": 100211,
        "voice": "vo_adv_1002008_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起，我也不太記得了……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但無論如何不想被人看見的這點，我記得很清楚。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（嗚嗚……「上面寫著你的名字呀」這種話，怎麼可能說得出口……）",
        "unit_id": 100211,
        "voice": "vo_adv_1002008_034"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……那個占卜，我也來試試看吧。",
        "unit_id": 100211,
        "voice": "vo_adv_1002008_035"
    }
]