    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是這個對吧？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就像妳說的，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "上面有貓咪形狀的貝殼呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯，",
        "unit_id": 213,
        "voice": "vo_adv_1104002_002"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "就是這個。",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "謝謝妳，姐姐！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "　這個是很重要的東西！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔。",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不要再弄丟囉？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "姑且得要報告才行，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等等去那邊的辦事處一下喔？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "呀啊啊，",
        "unit_id": 1,
        "voice": "vo_adv_1104002_004"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "有人吵架！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊！？",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　等等，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "馬上過去！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "因為你撞到我，",
        "unit_id": 312,
        "voice": "vo_adv_1104002_006"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "害我打翻刨冰了啊！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "啊？",
        "unit_id": 1011,
        "voice": "vo_adv_1104002_007"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "　是你走路不看路的錯吧！？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n帶著女人到處走就會變這樣啦！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊～好了好了！",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我知道你想說什麼，但是請你先冷靜下來！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "難得可以來到海邊喔？",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n別讓周遭其他人也變得不開心嘛。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好嗎？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔，",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "謝啦，{player}。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好了，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "店裡的人說打翻的刨冰",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可以免費幫你換呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "啊、",
        "unit_id": 312,
        "voice": "vo_adv_1104002_011"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "好……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "抱歉。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n做了很丟臉的事情呢。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你也是，",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不要隨便遷怒人啊。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要帶著誰一起走是別人的自由吧？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "說、",
        "unit_id": 1011,
        "voice": "vo_adv_1104002_013"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "說得也是……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "因為很羨慕，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "所以……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很好。",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那麼你們就握個手，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "吵架結束了。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不需要動用武力就可以解決真是太好了呢！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "男性1、2",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_1104002_015"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "百般忙碌之際抱歉，",
        "unit_id": 1511,
        "voice": "vo_adv_1104002_016"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n我女兒、",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "我女兒不見了！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔，我知道了！",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可以告訴我妳女兒的特徵嗎――",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "能找到迷路的孩子真是太好了呢。",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "都是多虧{player}那樣大聲的叫喊呢♪",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過這麼說起來，還真是忙碌呢。",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不管去哪邊都一直有狀況。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}應該也很累吧？",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "虧你真的能跟上我的腳步。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優衣就是對你的這種地方……",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "覺得很不錯。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊！？",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你啊，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還真是能輕易說出這種話呢！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "會讓人不知所措的，別這樣……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過這附近的狀況也差不多穩定下來了呢。",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要不要休息一下呢？",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "得趁可以休息的時候休息呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "搭訕男 1",
        "words": "喔，",
        "unit_id": 911,
        "voice": "vo_adv_1104002_025"
    },
    {
        "type": "dialogue",
        "name": "搭訕男 1",
        "words": "在這種地方有個不～錯的女人呢……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "搭訕男 2",
        "words": "真的呢。",
        "unit_id": 811,
        "voice": "vo_adv_1104002_026"
    },
    {
        "type": "dialogue",
        "name": "搭訕男 2",
        "words": "怎樣啊小姐，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "搭訕男 2",
        "words": "要不要跟我們去快活一下啊？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊？",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我現在很忙。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "想搭訕的話去別的地方。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "搭訕男 1",
        "words": "真是不錯呢。",
        "unit_id": 911,
        "voice": "vo_adv_1104002_028"
    },
    {
        "type": "dialogue",
        "name": "搭訕男 1",
        "words": "像妳這樣強悍的女人，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "搭訕男 1",
        "words": "我並不討厭呢。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "搭訕男 2",
        "words": "怎麼樣啊，",
        "unit_id": 811,
        "voice": "vo_adv_1104002_029"
    },
    {
        "type": "dialogue",
        "name": "搭訕男 2",
        "words": "\n跟我們",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "搭訕男 2",
        "words": "來一場夏日的危險戀愛",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "搭訕男 2",
        "words": "怎麼樣呢？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉啊。",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n像這種沒品的邀請法，我是絕不會上勾的。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "搭訕男 1",
        "words": "別這麼說啊！",
        "unit_id": 911,
        "voice": "vo_adv_1104002_031"
    },
    {
        "type": "dialogue",
        "name": "搭訕男 2",
        "words": "別這麼說嘛！",
        "unit_id": 811,
        "voice": "vo_adv_1104002_032"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘖、",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_033"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是煩人啊。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果是平常，我早就賞他個一拳解決了……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是現在",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_034"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我是海邊的巡守員啊。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "動用暴力可不妙。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那～個。",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_035"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n真的很抱歉，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你們去找別人……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可不可以呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "搭訕男 1",
        "words": "啊啊？",
        "unit_id": 911,
        "voice": "vo_adv_1104002_036"
    },
    {
        "type": "dialogue",
        "name": "搭訕男 1",
        "words": "\n我們都這樣邀請妳了",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "搭訕男 1",
        "words": "還是不行嗎！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "搭訕男 2",
        "words": "啊啊？",
        "unit_id": 811,
        "voice": "vo_adv_1104002_037"
    },
    {
        "type": "dialogue",
        "name": "搭訕男 2",
        "words": "　搞什麼啊這傢伙！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}……",
        "unit_id": 110411,
        "voice": "vo_adv_1104002_038"
    },
    {
        "type": "dialogue",
        "name": "搭訕男 1",
        "words": "你這傢伙",
        "unit_id": 911,
        "voice": "vo_adv_1104002_039"
    },
    {
        "type": "dialogue",
        "name": "搭訕男 1",
        "words": "該不會要說你是這女人的男朋友吧！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "男男男朋友！？",
