[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "襲擊鈴的魔物，\n被{player}一行人漂亮地擊退了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人就這樣接受了鈴的請求，\n被她拉著手並往牧場的方向跑去。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那裡，{player}一行人所看見的是……"
    },
    {
        "type": "still",
        "still": "200400301"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚哇？",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這到底是……怎麼一回事呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺整個視線裡滿滿地盡是魔物耶～",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然對我來說不是很稀奇……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是這個魔物的數量有點太誇張了耶～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還是先跟妳確認一下，",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在這個【伊麗莎白牧場】裡，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該沒有飼養魔物吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒有喔～只飼養普通的動物。",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們只是普通的牧場，雖然有養幾隻魔物。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n基本上是，一般的牧場。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，為什麼會變成這樣？",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n昨，昨天都還一如往常的！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我，今天也睡過頭了……",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n睡到中午才起床，就變成這種情況！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n搞，搞不懂啦！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為莉瑪叫我去討救兵，",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我就火速下山，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "然後很巧的，碰見您們了～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "其他人，",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n都還留在牧場！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n救，救救我們～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "拜託了！我什麼都肯做！",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳看，我把採到的橡子送給妳……！",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "500214"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～是橡子嗎，看起來真好吃呢～",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且最近的橡子還有經過品種改良呢……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳先冷靜下來吧，我會想辦法的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你原本就認識小鈴對吧？",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣啊～\n那就請你邊保護她，",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "邊盡快回到蘭德索爾去找人幫忙吧。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我呢～",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n則想辦法救出還留在牧場裡的人們。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然這次魔物的數量真的有點多，",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該會很辛苦……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "反正船到橋頭自然直囉♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我，",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我也要戰鬥！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n本來【伊麗莎白牧場】的警備，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就是我的職責！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是，因為我老是遊手好閒怠忽職守。",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就連今天，也悠閒的睡懶覺……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我一直受到【伊麗莎白牧場】各位的諸多照顧呢！",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n大家會平安無事吧，不會死掉吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也不知道～",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但我希望他們都能夠平安無事。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真糟糕，周圍到處都是魔物……",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n視線也看不太清楚呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "整個全部都是亂七八糟的狀況了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n怎麼了？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你也想要戰鬥嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯。",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為你很擔心【伊麗莎白牧場】的人們嗎……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈～你明明就這麼弱～……",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過要是都交給女孩子戰鬥，自己卻夾起尾巴逃走，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可稱不上是什麼男子漢呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再加上……",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n既然有這麼多魔物到處蠢動的話，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n想要離開這邊也是相當困難呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你們兩個～",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n繼續待在我身邊或許還比較安全呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請你們兩個要緊緊地跟著我呦！",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要稍微大展身手一番囉～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你們可要小心別被牽扯進來囉♪",
        "unit_id": 105811
    },
    {
        "type": "still",
        "still": "200400302"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚哇，這個人真強？",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n把魔物，一併打飛了……！？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你，居然認識這麼厲害的角色呢～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉呀，",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我也不能鬆懈。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的是……到處都是魔物。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？小鈴小鈴，",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那邊好像可以看到一股煙升起呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那邊有什麼東西嗎？",
        "unit_id": 105811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "200400303"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那裡是，馬廄……",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "發出詭異色彩的煙，或許是什麼暗號？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "暗號是什麼來著……？",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n在【哞哞自衛隊】的講座上，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好像有教過信號彈的種類？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔～嗯，唔～嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_2004003_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，我記得應該是救難信號！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n在那邊，好像有人正發出求救信號？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我懂了～",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我就先朝著煙升起的位置直線前進囉！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一二～三……",
        "unit_id": 105811,
        "voice": "vo_adv_2004003_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好囉～Let's Go～☆",
        "unit_id": 105811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2004003_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈啊～……",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可惡，完全沒辦法控制！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可惡呀，我明明不是想這樣！",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真是不順利呢，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會被陛下罵的呀～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n討厭，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又要被處罰讓人好討厭啊……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "本來是打算等蒂亞娜……",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n等貪吃佩可和那傢伙踏入牧場後",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n再讓魔物們開始大鬧的。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "結果在那之前，",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n魔物們就已經脫離我的掌控，失去控制了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠們完全不聽我的命令，到處放肆大鬧。",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不可以啦，先不說貪吃佩可……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我被囑咐要留那傢伙活口的。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就連對貪吃佩可，",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也被指示要盡量生擒的說……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明知道不能殺掉，",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但魔物完全不聽我的話！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是這樣下去，",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙一群人……肯定會死呀。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "寡不敵眾的呀。",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算貪吃佩可很強，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但還是有其限度。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「皇家裝備」的消耗實在太大了。",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一旦卡路里被消耗殆盡，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n她就會因為太過疲憊而倒下。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後，",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就這樣死掉。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物的數量可不只一兩百隻而已，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只有他們幾個人是絕對沒辦法對付的。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他們幾個，會死掉。",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n被踐踏，粉身碎骨的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n被吃到血肉模糊的死掉。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這不是早已明白的事情嗎？",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總有一天，會變成這樣。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是，",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼我的心這麼痛……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我明明只是沒有心臟",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n的一個玩偶而已！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下！",
        "unit_id": 106011,
        "voice": "vo_adv_2004003_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n果然是個很糟的缺陷品嗎……？",
        "unit_id": 106011
    }
]