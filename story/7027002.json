    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人持續探索著露娜之塔。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n矛依未與{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n聽從祈梨的指示向前進。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……你們兩個，",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "先稍微停下來。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總覺得這附近",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "感覺不太對勁。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這種時候",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不要輕舉妄動，要先觀察周圍。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算妳這麼說……",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但我可沒感覺到有任何不對勁啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是矛依未妳太草率了啦！",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……妳看，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳仔細看",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那邊的地板。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯嗯……？",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊啊，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "聽妳這麼一說，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n真的覺得那地方的顏色和其他地板不太一樣。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那應該",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是陷阱。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n要注意絕對別去踩到喔。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦哦……！",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳連這都看得出來啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來妳不是只會害怕而已呢，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "祈梨！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "畢竟我可是受過老大許多嚴格的鍛鍊啊！",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我對自己察知危險的能力很有自信！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來如此。",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是妳當黑手黨累積了很多經驗啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……對了。",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我說，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "祈梨。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n妳是",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼樣的黑手黨？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我就說我不是黑手黨，是幫派啊……",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……唉，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "算了，是無所謂啦。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳為什麼",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "想知道那種事情？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒什麼啦。",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我想說如果妳有在折磨他人，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就要徹底教訓妳！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫！？",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這傢伙",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是怎樣啊！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也太過血氣方剛了吧！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以，",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼樣？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳是壞傢伙？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還是好傢伙？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎、",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼感覺情況很不妙啊！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我可不能被她瞧不起……！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那、",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那還用說！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我祈梨大人",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是個十惡不赦的壞蛋！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼善良市民，",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過是好利用的",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "冤大頭！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "因、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "因為我",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可是窮凶惡極的幫派成員！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……什麼啊。",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "結果",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳也",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和其他人渣一樣嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n妳似乎",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和那時候判若兩人呢。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒辦法了！",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n既然如此，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那我只能打飛妳了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫────！？",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "早、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "早知道就別說些奇怪的話了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喝啊，",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "給我接招！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天樓霸斷──",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……停、",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "停下來！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "先等一下！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼？",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拖延時間",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是卑鄙小人在幹的事喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不是的！",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_022"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那裡！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳看那裡！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……呃！",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "魔物朝這裡來了！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還是一大群的魔物！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "祈梨！",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "待會再來教訓妳！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我現在要先打倒這群魔物！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳給我乖乖待在那裡！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂喂喂！",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你們這些小嘍囉的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對手是我！",
        "unit_id": 106113
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼，",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_026"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "以某種意義來說，這或許算是幸運呢……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我要趁現在偷偷逃跑了……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然如此，小哥也和我一起來！",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣下去我可是會陷入大危機啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊！",
        "unit_id": 106611,
        "voice": "vo_adv_7027002_028"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦，",
        "unit_id": 106113,
        "voice": "vo_adv_7027002_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
