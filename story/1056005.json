    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不想來這種地方。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我真的很怕幽靈之類的東西。",
