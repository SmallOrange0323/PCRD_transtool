    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也挺不錯的呢……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過小哥，",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_038"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你完全不為所動啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "跟你比起來我真是……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我不能再這樣沒出息下去。",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_039"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你看好了，",
