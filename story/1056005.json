[
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──某天{player}在路上看到\n流夏被蘭德索爾的人圍住，臉上流露出很困擾的表情。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就這件事我一個人處理有困難啊……",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我知道了。我去找找看有沒有人對這方面比較熟。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣如何？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "居民",
        "words": "可是這樣不知道要拖到什麼時候啊？",
        "unit_id": 1411,
        "voice": "vo_adv_1056005_001"
    },
    {
        "type": "dialogue",
        "name": "居民",
        "words": "\n既然騎士團不願意積極處理，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "居民",
        "words": "我們想趁早把事情解決。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "居民的女兒",
        "words": "流夏姐姐……",
        "unit_id": 211,
        "voice": "vo_adv_1056005_002"
    },
    {
        "type": "dialogue",
        "name": "居民的女兒",
        "words": "妳不願意，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "居民的女兒",
        "words": "幫我們擊退幽靈嗎……？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是的……",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真傷腦筋。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊～小哥。",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……對了，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有你在！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是幫了大忙！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "居民",
        "words": "流夏妳認識他嗎？",
        "unit_id": 1411,
        "voice": "vo_adv_1056005_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是啊。",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你別看他那樣，他還挺可靠的。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n就算是幽靈，他也一定有辦法處理。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "居民",
        "words": "其實最近，",
        "unit_id": 1411,
        "voice": "vo_adv_1056005_007"
    },
    {
        "type": "dialogue",
        "name": "居民",
        "words": "有個傳聞，說鎮上的墓地有幽靈出沒。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "居民",
        "words": "\n鎮上的人都很不安……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "居民",
        "words": "這事情也要麻煩你了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "居民的女兒",
        "words": "求求妳，",
        "unit_id": 211,
        "voice": "vo_adv_1056005_008"
    },
    {
        "type": "dialogue",
        "name": "居民的女兒",
        "words": "流夏姐姐。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "居民的女兒",
        "words": "大哥哥。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就是這麼一回事。",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "拜託你了，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n今晚難得，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就讓我們兩一起擊退幽靈吧。",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500022"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當晚，{player}和流夏在前往墓地\n的路上會合。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥！",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你怎麼這麼慢！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "到底去哪裡打混了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可別讓我等太久啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是啦，",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然只有遲到一下下……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但你讓我在這裡等是事實啊？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你遲到了30秒耶。",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果是平常的話，我也不會這麼生氣。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n可是今天不提高警覺可就麻煩了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且雖說在城中，但夜晚還是很危險。",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n總之……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唉，算了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們趕緊出發吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可是你不覺得",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_014"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "大家都太害怕幽靈了嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就算幽靈出現，他跟魔物有什麼兩樣？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真要說起來，",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_015"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "都是因為相信這些不存在的東西才是問題。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不存在的東西就是不存在！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這不就了結了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說什麼聽見怪聲或看見人影之類的，",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "大家都太緊張了啦。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想必一定是，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "供品被風吹動，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還是附近有蟲子在動吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種事多半都是誤會。",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_017"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你不這麼認為嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小孩子就算了，",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "連成年大人也嚇成那樣，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n真的是有夠沒出息的……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒，",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_019"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "什麼也沒有啊……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你怎麼會這麼問呢？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我和平常一樣沒變啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就跟平常一樣。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈哈……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哎呀，",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "快到墓地了呢……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "從這裡開始你先走在前頭。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我的話，",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就你也知道的，要保護你的身後啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼啦？",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "該不會需要我在背後推一把你才能往前走吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別擔心，有我陪著你。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好啦，快走快走！",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500532"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……到目前為止還看不出有什麼異常呢。",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "太好了……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊！等、等一下啊！",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_024"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哪有人這樣突然加快腳步的！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "拜託你稍微再走慢一點……！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不然的話，那個……",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我要怎麼在背後保護你呢？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "前進時如果沒有配合彼此的步調，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n萬一有什麼突發狀況兩人都會陷入困境喔。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那我們就",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_026"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "繼續走吧……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……好，快滾出來，",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_027"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓我把你大卸八塊……！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在哪……？",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "到底在哪裡……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "快給我滾出來……！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼，",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_029"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼……！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒事，",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒事……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一點都",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不恐怖……！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎、怎麼可能！",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒有那回事！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥，你該不會以為我在害怕吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是太可笑了。",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_032"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就算不知道幽靈的真面目，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n也沒道理要害怕吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈、哈哈哈……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我輸了。",
        "unit_id": 105611,
        "voice": "vo_adv_1056005_033"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我投降。",
        "unit_id": 105611
    },
    {
