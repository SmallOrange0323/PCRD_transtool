    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106011,
        "voice": "vo_adv_5084204_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說你們兩個！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也說點什麼吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 105911,
        "voice": "vo_adv_5084204_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算您這麼說……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "別做這種勉強人的要求啦，凱留。",
        "unit_id": 106411,
        "voice": "vo_adv_5084204_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這附近魔物的氣息可是變得相當濃厚耶？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n緊張都來不及了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔，",
        "unit_id": 106011,
        "voice": "vo_adv_5084204_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可那傢伙在時，老是會說一些毫無緊張感的對話，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n結果現在沒人說話，反而令人感到不自在了……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "記得這種時候，",
        "unit_id": 106011,
        "voice": "vo_adv_5084204_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可都會說……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天打倒的魔物，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該怎麼吃比較好呢！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦……",
        "unit_id": 106411,
        "voice": "vo_adv_5084204_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳要吃那個",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "岩石的魔物！？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐還真是調皮呢。",
        "unit_id": 105911,
        "voice": "vo_adv_5084204_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "意見這麼多是怎樣啦～～～～～～！",
        "unit_id": 106011,
        "voice": "vo_adv_5084204_010"
    }
]