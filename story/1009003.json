[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了買書而來的{player}，\n剛好發現一臉認真地看書的修特帕魯。"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯嗯……",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "原來如此！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這麼一來，又接近了宇宙本源一步呢……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉、吉格魯特？",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你怎麼會在這裡！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "為了買書而來……？",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這、這樣啊……說的也是呢。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n說到能在書店做的事，也沒有別的事了呢……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我？",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……不，這不是你所想得那樣！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我可是無無無、無所不知無所不能！",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "像這些書本上的知識，我老早就知道了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "所以書本對我來說，根本是不需要的東西……根本沒有需要。",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……但是呢，我也想要一點消遣。",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒錯！我並不是為了增長知識才買書，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n硬要說的話，我只是為了消遣才買書的！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……啊！糟了！",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我剛好正在看字典……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不對啦，這個是！呃、那個……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_008"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n那個、就是……總之不是啦！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……對、對了！",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我正在透過閱讀，收集在轉世時所失去的知識！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n也就是說我有輕微的失憶啦！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……你那副表情是什麼意思？",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_010"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你是不相信我說的話嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是真的啦！我絕對沒有騙你！",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_011"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你相信我嗎……？",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_012"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "連我自己有一瞬間也覺得失憶是很荒謬的事……",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_013"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "有什麼理由足以讓你相信我呢？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，你在現世也失去了記憶嗎……？",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_014"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "原來是這樣啊……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n那樣的話，你的確不會覺得失去記憶是很罕見的事呢。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這樣啊……我們在前世是盟友，",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_015"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也同樣失去了過去的記憶啊……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不過你放心吧！",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_016"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n你不是已經想起一些片段的記憶了嗎！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n像是你曾經是閃光的吉格魯特這件事！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "因此，你所失去的記憶會像這樣子慢慢地想起來的！",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_017"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n所以……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你不需要擔心。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "看在我們都失去記憶、同病相憐的份上，",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_018"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n如果你有想知道的事的話，我全部都會告訴你。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "為了讓你回想起相關知識，也會借書給你的。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對了。這是我剛剛買的字典，",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_019"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我先把這本字典借給你吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n只要你仔細閱讀的話，就能回想起過往的記憶了。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這沒什麼，不需要感謝我。",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_020"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "增長知識這件事，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n也是對抗威脅世界和平的機關的一種方式。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "總有一天，我們會有需要吉格魯特過去記憶的時候。",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_021"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "直到那天為止，你要增長知識，為戰鬥作準備！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "再提到知識的話……",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_022"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我把這本書也交給你吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這本書記錄了我跟你在前世中發生過的所有事。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n當然作者就是我！書名是「冥風戰記」！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我拜託附近的書店幫我賣這本書，",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_023"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n聽說漸漸地開始有人購買了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "除了我們之外，應該也有其他對前世的記憶感興趣的人吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "只要你讀了這本書，應該比較容易回想起以前的事情。",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_024"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "為了對抗機關，你的協助是不可或缺的。",
        "unit_id": 100911,
        "voice": "vo_adv_1009003_025"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "從今以後也請你繼續支持我。我的夥伴，閃光的吉格魯特！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}從那天開始，\n就經常被修特帕魯強迫推銷\n借閱字典或是她所寫的小說。"
    }
]