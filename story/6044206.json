[
    {
        "type": "background",
        "background": "501060"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒想到牛郎會是那種負心漢～",
        "unit_id": 113311,
        "voice": "vo_adv_6044206_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再說，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "明明都有小織女那樣的超級美少女了，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n居然還想和其他女孩子打情罵俏，實在是太奢侈了！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒有錯！",
        "unit_id": 113311,
        "voice": "vo_adv_6044206_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "他太貪心了！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不要臉！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n自古以來，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沉溺於慾望都會自毀其身啊。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n也就是說，牛郎──！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你給我皮繃緊等著瞧──！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是啊……",
        "unit_id": 113311,
        "voice": "vo_adv_6044206_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也就是說，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這時候果然要輪到魔法少女出場了──！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看我用有點刺激的魔法",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "來說服牛郎閣下吧──！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦，",
        "unit_id": 113311,
        "voice": "vo_adv_6044206_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我會怎麼辦？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我想當然會",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "很傷心吧。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我還是會希望自己喜歡上的男人，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n眼中能夠只有自己啊……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，你都讓我說些什麼啦！？",
        "unit_id": 113311
    }
]