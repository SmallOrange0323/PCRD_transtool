[
    {
        "type": "background",
        "background": "500111"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真陽曾經去兜售過的村莊那裡的村民們，",
        "unit_id": 105211,
        "voice": "vo_adv_6040306_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n還有咲戀育幼院的孩子們",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "都有捐錢給我們。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的很感激他們呢……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然不知道我們能做些什麼，",
        "unit_id": 105211,
        "voice": "vo_adv_6040306_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但只要是能做得到的事，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我們都想盡力去做。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果除了真陽以外，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我也\n能去兜售的話，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是不是就能將牧場製品",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "送到更多人手上了呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "都是多虧了她去過各式各樣的地方兜售，",
        "unit_id": 105211,
        "voice": "vo_adv_6040306_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因此認識了許多的人。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我覺得這是只有真陽",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "才能辦到的事情呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這些錢要用在",
        "unit_id": 105211,
        "voice": "vo_adv_6040306_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "重建遭遇詐欺的那些農業公會上，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以得謹慎地使用才行呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "事情結束之後，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "想和大家",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一起送好吃的東西\n給村民們以及",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咲戀育幼院的孩子們呢。",
        "unit_id": 105211
    }
]