[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【憤怒‧軍團】的卡里莎"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "襲擊了似似花的藏身處。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而，他遭受了似似花的激烈反擊──"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「首先",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要奪走行動自由，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n為了防止對方反擊，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要把手綁起來。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n為了防止對方逃走，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要把腳綁起來。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "拘束時",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "務必堅實地綁緊……」",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯嗯……",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原來如此。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n平時不會閱讀的書籍，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "總是能讓人獲得新知識呢……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳這傢伙，",
        "unit_id": 191611,
        "voice": "vo_adv_2107006_003"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "給我把繩子解開──！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n話說妳是在看什麼書啊！？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……《全數傳授！",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "管教囂張少年的方法",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "AtoZ》──",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這就是用來教育",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "像你這種小孩的使用手冊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這些原本是為了以防萬一",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "{player}恢復成「以前的他」時，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所買來",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "備用的書籍。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒想到居然會在意外的地方派上用場呢……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "少說那些莫名其妙的話了！",
        "unit_id": 191611,
        "voice": "vo_adv_2107006_006"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……可惡，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "解不開……！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳既然要殺我，就快點殺啊！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我不會做出那麼野蠻的舉動的。",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n……在你還有",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "利用價值時，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還不會。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "利用價值？",
        "unit_id": 191611,
        "voice": "vo_adv_2107006_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我有幾件事想問你。",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你只要坦率地、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "親切地、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "老實地說出口，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就保證你的人身安全。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "【憤怒‧軍團】──",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你們的根據地",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "究竟在哪裡呢？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哼！",
        "unit_id": 191611,
        "voice": "vo_adv_2107006_011"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n誰會洩漏給妳啊。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哎呀……",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你意外地很替夥伴著想呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哼！",
        "unit_id": 191611,
        "voice": "vo_adv_2107006_013"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "不管贊恩他們和那群笨女人變成怎樣，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n都不關我的事啦。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "更重要的是，",
        "unit_id": 191611,
        "voice": "vo_adv_2107006_014"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "乖乖聽妳的話去做事",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n更讓我覺得不爽啦！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n妳這蘿莉老太婆！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……面對愛頂嘴的",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "囂張少年的應對方式",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "唔嗯……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哦……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n把褲子給……？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……！",
        "unit_id": 191611,
        "voice": "vo_adv_2107006_017"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "喂，妳這傢伙想做什麼啊──！？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然你可能",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很難以想像……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但這世上可是有",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比被奪走性命還要更屈辱的事。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要實踐寫在這上面的內容……",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你就再也",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "無法回到至今為止的生活了吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你都對我",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "說出那麼多的謾罵了，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這也是理所當然的報應……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "咕……！",
        "unit_id": 191611,
        "voice": "vo_adv_2107006_020"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "可惡，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "可惡，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "可惡，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "可惡啊啊啊……！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在這個前提之下──",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我要再問你一個問題。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n老實回答我，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你們",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "【憤怒‧軍團】的……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在你們",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "背地裡的幕後黑手",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n究竟是誰？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……啊啊……？",
        "unit_id": 191611,
        "voice": "vo_adv_2107006_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "據我所聽說，",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你們的目的",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是「實現願望」，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n並且你們所採取的手段",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是捉捕我們。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這些事屬實的話……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那未免也太拐彎抹角了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算我們是七冠，",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也並不代表我們每一個角色，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n都有被賦予足以實現願望的資源。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "既然如此……",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你們之所以會特地來抓我們，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是因為有「捉捕我們後",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能夠從其手中獲得某種利益的贊助者」存在，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……這麼推測",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該是很合理的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "………………",
        "unit_id": 191611,
        "voice": "vo_adv_2107006_027"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "才沒有呢。",
        "unit_id": 191611,
        "voice": "vo_adv_2107006_028"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n才沒這種人。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……呵呵。",
        "unit_id": 107011,
        "voice": "vo_adv_2107006_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n光看你那反應，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "幾乎已經回答一半了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我來讓你說說",
        "unit_id": 107011
    },
    {
