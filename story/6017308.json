        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "嗯，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "可以看見很多東西喔。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "我可不是因為懶得解釋才這麼說的喔？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這種說法真是直接又失禮。",
        "unit_id": 109811,
        "voice": "vo_adv_6017308_001"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "繼巴魯斯之後第一次感覺這麼火大，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你給我好好改正那種想法。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n否則，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "我就監視並找出你的祕密，再到處散布。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這種天賦，可是只有像拉姆這樣才華洋溢的女僕才擁有哦。",
        "unit_id": 109811,
        "voice": "vo_adv_6017308_002"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你怎麼那麼容易",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "上當啊。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n你應該學會懷疑別人。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "只能看到波長相符的生物喔。",
        "unit_id": 109811,
        "voice": "vo_adv_6017308_003"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n比方說，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "要看雷姆的話，一下就能看見了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不曉得看你會怎麼樣？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "輕輕鬆鬆就看到了呢。",
        "unit_id": 109811
    }
