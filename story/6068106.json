[
    {
        "type": "background",
        "background": "501340"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "珠希",
        "unit_id": 116711,
        "voice": "vo_adv_6068106_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "中午賣的鯛魚燒很受歡迎，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且是這個工廠不可或缺的存在！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我很敬佩她……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我也有",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可以向她學習的地方嗎……？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原、",
        "unit_id": 116711,
        "voice": "vo_adv_6068106_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來如此……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "珠希她",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為了將工廠的技術",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n活用在製作鯛魚燒上很用功學習呢！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只要我也學好工廠的技術，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n工廠的大家或許就會更加認同我，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "跟我當好朋友……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "珠希的開朗",
        "unit_id": 116711,
        "voice": "vo_adv_6068106_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "總是為工廠帶來活力對吧……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "若能模仿她，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我應該也能很快結交到打工夥伴，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但我根本無法",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好好跟人交談……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所、",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要先跟好朋友號練習……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "珠希",
        "unit_id": 116711,
        "voice": "vo_adv_6068106_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "的說話方式",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "確實很有親近感！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為是貓的獸人族，所以是「喵」的話，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我是",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "邊緣精靈族……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以從今天開始，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我要在語尾加上「邊緣」來說話邊緣！",
        "unit_id": 116711
    }
]