    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是的，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_060"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "當然是由我們送來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n好，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那我們稍微加快腳步吧，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n看來要變忙了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "歡迎回來！",
