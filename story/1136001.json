    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不好意思，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "由於來客眾多……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這邊的飲料",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是我們一點小小心意。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "好、",
        "unit_id": 1,
        "voice": "vo_adv_1136001_046"
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "好……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "謝謝。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "接著……",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_047"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是這裡嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不好意思，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "請問叫外送餐點的人是哪一位……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "我就是……",
        "unit_id": 1,
        "voice": "vo_adv_1136001_048"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "呃，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "呀啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "！",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "您怎麼了嗎？",
