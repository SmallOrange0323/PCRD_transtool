[
    {
        "type": "background",
        "background": "500164"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "炎熱的陽光照射在沙灘上。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}靜靜凝視著眼前"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被烤熱的黑鐵之軀。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎麼了嗎，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你為什麼會露出那麼訝異的表情？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒錯。",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是我。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "難不成你以為",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我是銅像嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n好吧，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果有鎧甲佇立在沙灘上，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n會那麼認為或許也很正常。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在這裡遇見你也挺稀奇的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這麼說來我也一樣嗎。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "找到了找到了。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真是的……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是你一直閒晃，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "小心會走丟喔？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗨，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來小咲戀也來了嗎。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個聲音……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "難不成是純！？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n妳是怎麼了？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼會跑來這種地方……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且還穿成那樣！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "最近突然大受歡迎的",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "海邊勝地……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我指的是這片海灘。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n負責維持這片沙灘治安的部隊裡",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "似乎有缺人。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以我就來補那個缺了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "補、",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "補那個缺……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳可是【王宮騎士團】的團長耶，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n怎麼可以這麼輕易就跑出來補缺啊？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唉呀，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他們都說王宮的護衛人已經夠了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以我就想說，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這裡可能會有工作做……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來如此，",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是這麼一回事嗎。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "什麼原來如此什麼啊，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小咲戀？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這裡的沙難",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的很和平對吧。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "之前甚至",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不需要維持治安的部隊。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "純現在也是，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "無事可做閒到不行對吧？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就是說啊。",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "今天也不是我當班，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但我實在是沒事可做，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n才會像這樣到處巡邏。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉，",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳這樣不行啊。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大家是想讓妳好好休息，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "才會謊稱有缺人的。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這裡的部隊原本就只有一人，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我剛才也有在那邊",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看到他喔？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原、",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來是那樣的嗎……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我確實一直感到困惑，畢竟這裡的工作量很少。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嗯……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可是，就算明白他們的用意，我又該如何是好……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個簡單啦。",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n非工作時間就盡情享受大海，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為身心充電──",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這樣做也算是",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "尊重全體團員的這份心意了吧？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣啊……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼，",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "事情就是這樣，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果純不嫌棄，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n要不要跟我們一起行動呀？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可是，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那樣好嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我這種人就算跟著你們……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "放心吧。",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們今天是跟育幼院的孩子們一起來的。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "肯定是人越多",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會越開心呀。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是嗎。",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "既然如此，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就讓我打擾一下吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵，",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "幫了大忙呢。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "幫了大忙……？",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來如此，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是這麼一回事嗎……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，純跟{player}一起在\n照顧過咲戀她們的海之家裡幫忙送餐。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對不起喔，",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "純。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是我自己問有沒有什麼可以幫忙的事，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以妳不用在意，只是……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我在這家店幫忙",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不會有問題嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我記得【王宮騎士團】",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是禁止從事副業的……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳放心吧。",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "根據【王宮騎士團】的服務規定，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在非勤務時間",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "從事無給薪之行為，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不會視為副業。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不愧是小咲戀。",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n既然如此，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我就能放心進行任務了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "任務……",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這裡可不是【王宮騎士團】喔？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳真的不把鎧甲脫掉嗎？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這點我辦不到。",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而且這種程度的炎熱，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我早已習以為常。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那就好……",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過妳要記得隨時補充水分喔？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n為了避免中暑，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳絕對不可以勉強自己。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "聽到了嗎？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我瞭解了，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小咲戀。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "行軍路線有著落了嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有。",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "請看這張地圖。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "首先要走這條路線，優先部署冷飲。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n回程時",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "則以湯類為優先，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這部分的搬運，",
