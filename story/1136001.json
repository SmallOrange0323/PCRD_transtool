        "voice": "vo_adv_1136001_061"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "又有人點餐了！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看來是那樣沒錯。",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_062"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是發生了什麼事嗎？",
