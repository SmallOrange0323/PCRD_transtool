        "voice": "vo_adv_1136001_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "才沒有那種事咧。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "純都會好好領導作戰現場，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以我只是做自己辦得到的事而已。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
