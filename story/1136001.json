    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "沒、",
        "unit_id": 1,
        "voice": "vo_adv_1136001_050"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "沒事……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "請問……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "妳是海之家的員工、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是的，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_051"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我是臨時",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "來幫忙送餐的……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "對不起，",
        "unit_id": 1,
        "voice": "vo_adv_1136001_052"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "因為妳在這種地方穿著鎧甲……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n這樣或許比在海邊遇到人魚更驚人呢。",
