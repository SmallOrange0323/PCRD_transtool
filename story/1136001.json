    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會請隨行的他負責。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那樣的話，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "分成兩隊會比較有效率吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為我想同時端給同一群客人。",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "當客人要用餐時，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們會希望同一桌的人",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一起喊開動不是嗎？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有道理。",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這很重要呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我明白了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那就照這個作戰執行。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你是怎麼了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哈哈，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "畢竟我跟小咲戀認識很久了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在【王宮騎士團】時代，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我總是受到她的幫助。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "會嗎？",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n畢竟訂定這類型的作戰，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是小咲戀比較在行。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我從以前就老是依靠她。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，",
