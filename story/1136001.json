    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "\n鎧、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "鎧甲！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "在這種海邊！？",
