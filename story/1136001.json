        "voice": "vo_adv_1136001_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "料理好像準備好了。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那麼，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就拜託你們囉。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那我們出動吧，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
