        "name": "男性客人",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "喂──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性客人",
        "words": "我可以點餐嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "我也再點一份好了……",
        "unit_id": 1,
        "voice": "vo_adv_1136001_056"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n不好意思──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好的，",
        "unit_id": 104711,
        "voice": "vo_adv_1136001_057"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "等送完餐後我們會再回來一趟。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n要點餐的話，可以去那邊的店面點……",
