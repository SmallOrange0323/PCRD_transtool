    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "天曉得……",
        "unit_id": 110311,
        "voice": "vo_adv_1136001_063"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有一群人說",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "比人魚還怎樣怎樣的……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n呃，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "現在不是閒聊的時候。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這些",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以麻煩你們嗎？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n路線是這樣走，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再去這裡。",
