        "type": "dialogue",
        "name": "男性",
        "words": "嗯，",
        "unit_id": 1111,
        "voice": "vo_adv_1137003_032"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "他是武術道場的師傅。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我是那裡的徒弟，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "在那裡接受師傅的指導。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "他是武術的師傅，",
        "unit_id": 113711,
        "voice": "vo_adv_1137003_033"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但為什麼會看起來這麼痛苦呢？",
