    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "還說什麼轉換心情，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "我已經完蛋了……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "走掉了……",
