        "voice": "vo_adv_1137003_023"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "我可以再拜託妳一件事嗎……",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "窗邊那裡坐著一位男性對吧？",
