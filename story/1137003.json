        "voice": "vo_adv_1137003_035"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但也因此造成了問題……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "明明那麼強大卻碰上了問題？",
        "unit_id": 113711,
        "voice": "vo_adv_1137003_036"
    },
    {
