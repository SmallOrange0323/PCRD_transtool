    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "要不要和茜里聊個天",
        "unit_id": 113711
