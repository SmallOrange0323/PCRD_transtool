        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "難道說",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "他有什麼地方受傷了……？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不，",
        "unit_id": 1111,
        "voice": "vo_adv_1137003_034"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "他不是受傷了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "他可以說是精通了古今中外所有的武術，",
