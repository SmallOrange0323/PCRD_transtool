        "voice": "vo_adv_1137003_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "他",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "感覺很痛苦的樣子呢。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里",
        "unit_id": 113711,
        "voice": "vo_adv_1137003_029"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "絕對要讓那個大叔打起精神！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "身為一個天使，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可不能就在這裡退縮！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "真抱歉，那是我的師傅……",
        "unit_id": 1111,
        "voice": "vo_adv_1137003_030"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n他要是讓妳感到不舒服，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我代他向妳道歉。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你說師傅……",
        "unit_id": 113711,
        "voice": "vo_adv_1137003_031"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你和那位大叔是熟人嗎？",
        "unit_id": 113711
