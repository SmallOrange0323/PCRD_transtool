        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥，",
        "unit_id": 113711,
        "voice": "vo_adv_1137003_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "輪到我們出場了！",
