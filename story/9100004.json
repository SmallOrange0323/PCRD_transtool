        "name": "贊恩",
        "words": "只是，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "有點喝太多海水了。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你跑去泡什麼海水浴啊！！？",
