        "type": "dialogue",
        "name": "雪菲",
        "words": "看到他沒事……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n竟感到放心嗎……？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n他、",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "他明明，",
        "unit_id": 106411
    },
