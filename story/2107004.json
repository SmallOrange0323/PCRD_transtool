        "type": "dialogue",
        "name": "日和",
        "words": "怎麼了？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "矛依未妳是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "帶這個來給我們的吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呃、",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是這樣沒錯啦。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不知怎麼搞的，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "到了最後一刻卻很難爽快地交出來。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n……因為這是以前，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "跟妳們相互爭奪到那般地步的索爾魔珠呢……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呃，",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_037"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "矛依未……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊……",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_038"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我從剛剛",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就很想跟妳說了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可以的話，不要叫我矛依未……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "能改叫我諾維姆的話，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我會很高興的。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n因為我喜歡聽到",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大家叫我這個名字。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_039"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n說得、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也是……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n真抱歉，諾維姆！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿嘿，",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "謝啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然我也已經很習慣被叫錯了……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但聽到妳叫我「矛依未」，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就覺得渾身不自在。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "諾維姆、",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_041"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "諾維姆……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺用這個名字叫妳更貼切呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "另外……",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_042"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳剛剛",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好像有提到說，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n妳跟我們",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有互相爭奪過索爾魔珠，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "什麼意思啊……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……呃……",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我接下來可能會問些奇怪的問題，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳不要笑我喔。",
        "unit_id": 106113
    },
    {
        "type": "still",
        "still": "210700401"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我說妳啊，",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "該不會……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n已經有找回一些",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那邊世界的記憶了……？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……！",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_045"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "諾維姆……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "難不成",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳知道些什麼嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也一直很在意某件事……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什、",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼事啊！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呃、",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_047"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這事說來有點奇怪，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n希望妳別笑我……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那就是──所謂的「現實」",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_048"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個世界，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是否真的存在呢……！",
        "unit_id": 100111
    },
    {
        "type": "still",
        "still": "210700402"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔喔喔！",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_049"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n日和，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳已經恢復記憶了嗎……！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_050"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我並沒有完全想起來！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好像是菲歐",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "讓我們在夢裡看到了另一個世界，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n用這種方式告訴我們的……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "菲歐！",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_051"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n原來如此，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那傢伙也還活著啊……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我還以為她可能已經消失不見了呢！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦！？",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_052"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n可能已經消失了，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這是什麼意思……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯，",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_053"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這件事",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "說來話長……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個世界原本是由",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_054"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "晶他們七冠所創造出來的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "虛擬世界。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n而且跟「現實」的世界是連結在一起的。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_055"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "先前發生了「事件」，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "導致這個連結被切斷。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個時候，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "世界又重新被創造了一次。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦、",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_056"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦咦咦……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "世界是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可以被這樣",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "創造來又創造去的嗎……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊──嗯，",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_057"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算我現在告訴妳有關網路或遊戲的話題，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n大概也摸不著頭緒……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總之，希望妳能先接受這說法。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n真對不起，我不太會解釋。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "關於這些事，妳再去請教晶或似似花吧。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "接著，",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_058"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在「重新創造前的世界」中，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳們【破曉之星】和{player}，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n為了阻止真那……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "霸瞳皇帝的野心而與之對抗。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而在戰鬥的最後一刻，",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_059"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n菲歐她應該是",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "犧牲自己……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "救了你們吧。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳說，",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_060"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "應該？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_061"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "老實說，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我當時並沒有在現場。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n因為晶設法想駭進去救你們……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我只是",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在附近看到的。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也只知道片段而已。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是、",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_062"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是這樣啊……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_063"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n因為這樣，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我就對草野優衣……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n對優衣",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "起了疑心。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "明明像她那麼溫柔的人，",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_064"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "應該不可能……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "會做這樣的事。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n切斷阿斯特朗世界和「現實」的連結，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "把大家都囚禁在虛擬世界……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那個優衣，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不可能做得出這種事吧……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣……",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_065"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n啊……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "菲歐也對",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_066"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣的事非常在意喔！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是，怜和我",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都完全不了解",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "她為何會那麼在意。",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……而且菲歐她，",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_067"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "已經不再是我們所認識的那個菲歐了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n雖然很想再跟她問一些事，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但她卻好像已經消失了……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "諾維姆，",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_068"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "拜託妳了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n希望妳能告訴我",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳所知道的事。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣她到底發生了什麼事？",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_069"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "究竟該怎麼做才好？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不管是「以前的世界」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還是「現實」……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我都想",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "把事情弄清楚！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……嗯……",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_070"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我剛才也說過，",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_071"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我並不知道全部的真相。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不過……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_072"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這是很重要的事。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果妳信得過我，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "希望妳能聽進去。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這是我的請求。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "…………但是……",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_073"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是？",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_074"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……我想，",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_075"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這件事……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n對妳和怜來說，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很可能……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也是件很痛苦的事。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n……即便如此，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳還是願意聽嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "…………",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_076"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……嗯。",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_077"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "諾維姆既然都這麼說了，",
        "unit_id": 100111,
        "voice": "vo_adv_2107004_078"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我想這肯定",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是一件很痛苦的事。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但正因為這樣，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我更不想逃避，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而是想好好去面對！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……呵呵。",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_079"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n妳真的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一點都沒變呢。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不管遇到什麼事，總是鼓足勇氣，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "以樂觀積極的態度來面對……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106113,
        "voice": "vo_adv_2107004_080"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那麼，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我就告訴妳吧。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "把我所知道的事，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "全都說出來──",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………",
        "unit_id": 106412,
        "voice": "vo_adv_2107004_081"
    }
]