[
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和禊吵架後過了一個晚上，\n鏡華也對昨天的事稍微反省了一番。"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "唉，昨天是不是說得太過分了啊……說什麼絕交……",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可，可是，是禊自己跑來要我教她唸書的啊，",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "只因為聽不懂就任性地不學了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……我也有不好的地方吧。",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n被叫做老師就得意忘形了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是不是再也不能一起玩了呢……",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀啊！你，你這個人啊！",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n不要突然跑來搭話啦！這樣不是會嚇到人嗎！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "鬼鬼祟祟地從背後接近，你果然就是可疑人物！",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "唉唷！",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是，是誰啊！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n……真是，你這個人啊……請不要突然拍人的肩膀啦！　",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n好可怕……不是，是會嚇到人的啦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "更何況，未經允許就觸碰女孩子的身體……",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你果然是個變態！一定沒錯！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦？覺得我會因為昨天的事而失落，所以來看我的情況如何？",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "多，多管閒事！",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我精神飽滿，所以沒什麼好擔心的！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "至於禊……就這樣了。",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "反正都已經絕交了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要是那麼簡單就不會這麼辛苦了！",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過，好吧……如果禊一定要的話，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n也不是不行和好……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "只不過，彼此沒有達成共識的話，",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就算道歉也沒有意義不是嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "當然，我也有不對的地方……",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這點我至少明白。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是明白歸明白……絕交都已經說出口了……",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_014"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n要是沒有什麼契機的話……實在沒辦法道歉……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "畢竟我也不喜歡現在這種狀態。",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n可是，說要和好，實在太困難了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n因為像這樣和朋友吵架還是第一次……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……教科書上又沒有教人重修舊好的方法……",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？為、為什麼突然？說要探險……",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果是要讓我打起精神就不必了……現在沒有那種心情。",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "更何況、喜歡探險的人是禊啊，",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n不是應該找她去才對嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……如果和禊一起去她喜歡的探險，",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n應該可以順其自然地和好？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼單純的辦法，真的沒問題嗎……",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過，畢竟是禊喜歡的活動……說不定效果會很不錯呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，可是要怎麼樣邀請她才好……",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n現在就算去找她，也不知道她願不願意聽我說話……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果是信的話……沒錯！就是寫信！",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就來寫一封邀請禊去探險的邀請函吧！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n既然這麼決定了……請等我一下！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼……探險邀請函……",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n給禊……我們找美美 3 個人一起去探險吧……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我在蘭德索爾外面等候……鏡華上……這樣可以嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼……{player}，",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你能不能，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "把這個交給禊呢？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……謝謝你！",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n禊願不願意來呢……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒問題吧？既然是最喜歡的探險，應該會來吧！",
        "unit_id": 103611,
        "voice": "vo_adv_5002001_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n{player}，信就拜託你了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}收下了鏡華的信。\n和她約定了一定要把信交給禊，於是往蘭德索爾出發了。"
    }
]