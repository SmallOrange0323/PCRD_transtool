    {
        "type": "dialogue",
        "name": "？？？",
        "words": "各、",
        "unit_id": 1,
        "voice": "vo_adv_1107001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "各位，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "初次見面……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我的名字叫",
        "unit_id": 1,
        "voice": "vo_adv_1107001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "碧、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "碧……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "碧……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "碧色水黽毛蟲次郎―――――！",
        "unit_id": 1,
        "voice": "vo_adv_1107001_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊啊……",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我又失敗了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這已經是第18次了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只是說個名字，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n怎麼這麼困難呢……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就連為了練習製作出來的",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "『有我在喔好朋友號V3』，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "感覺都好像在嘲笑我……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣下去，",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就連自我介紹……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對了！　",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣的話，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果把自己的名字改名，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說不定就能順利說完吧！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哎呀！？",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n誰誰誰誰呀突然出聲！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊……",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來是你。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是啊。",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n仔細想想，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "會跟我這個邊緣人講話的，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n就只有你呢……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "跟我一樣都是BB團的團員，",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n也是我唯一的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "同、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "同同、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "同伴的……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就只有",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你了……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在做自我介紹",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "練習。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個、",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、這次……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要到聖德蕾莎女學院那裡，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n暫時",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "插班就讀一陣子……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你不知道嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n咦？　",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在那裡就讀？　",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那是女子學院耶！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真不愧是BB團團長……",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為了結交朋友必須要有",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就算身為男孩子也要到女子學院就讀的決心",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來是這麼一回事呢……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是這也算是",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "順水推舟呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n或是可以說是",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "從天而降的餡餅呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請一定要！　",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "將聖德蕾莎女學院的事",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n全都告訴我！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "太感謝你了……！",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我果然還是需要",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "同……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "同伴……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我要發問了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "學校是什麼樣的地方呢！？",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在學校就讀的通常是怎樣類型的人呢！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有看起來願意跟我當朋友的人嗎！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果成為朋友的話，",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我該做什麼才好呢！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n果然還是應該",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一起玩翻花繩之類來增進感情吧！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊啊但是，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果太多朋友繩子會不夠用呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "既然如此，",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "首先要先準備很多繩子備用……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？　",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "叫我冷靜？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也是啦。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n再說，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "像我這樣的人怎麼可能交到朋友……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？　",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不是這樣的？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n在女子學院中，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有很多不平凡的同學？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣的話……",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說不定。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n就算是像我這樣的人，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說不定也會有人願意跟我當朋友……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "太謝謝你了！",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n托你的福我看見了希望！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對了！　{player}，",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果可以的話，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "能幫我個忙嗎！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為了迎接即將到來的學院生活，",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我想練習自我介紹！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "想必你剛剛看了也知道，",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我就算跟",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "『有我在喔好朋友號V3』練習對話，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還是連名字都沒辦法好好說完……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣只能",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "把{player}你當成學生練習，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n運用實戰的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "強制療法才行了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦！？　",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_030"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "再多一點、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "正式場合的東西吧！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來如此，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這就是人家說的入鄉隨俗嘛！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_031"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "該怎麼做……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我想到了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我可以做出很多『有我在喔好朋友號』玩偶，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n重現出全班同學的模樣！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不是這樣嗎？",
        "unit_id": 104011,
        "voice": "vo_adv_1107001_033"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
