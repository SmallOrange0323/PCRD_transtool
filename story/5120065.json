[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "望小姐的美，",
        "unit_id": 126311,
        "voice": "vo_adv_5120065_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "最值得一提的就是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她身為偶像所散發出的光彩……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n包含她的歌聲",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "以及平時的言行舉止，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都擁有足以稱為個人魅力的存在感吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她總是處在粉絲們的注目之下，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這可以說是在實踐中磨練出來的美呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我能給她的建議是……",
        "unit_id": 126311,
        "voice": "vo_adv_5120065_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "其實",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也沒什麼能給的呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她只要照這樣",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "作為偶像持續在大家面前亮相，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她的美",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "肯定就能更上一層樓！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "千歌小姐的美，",
        "unit_id": 126311,
        "voice": "vo_adv_5120065_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "果然還是她的歌聲吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "以及",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她為了維持歌聲所過的克己生活，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "又更增添了她的光彩。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就內在所磨練出來的美而言，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這也算是一種理想的形態吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我能給她的建議是……",
        "unit_id": 126311,
        "voice": "vo_adv_5120065_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "希望她能對自己更有自信一點吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n難得",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有這麼多的粉絲在注視著她，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是太浪費了！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她如果能夠有自己是「偶像」的自覺與自信，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該能使她更加發光發熱的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "紡希小姐的美，",
        "unit_id": 126311,
        "voice": "vo_adv_5120065_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "果然就屬",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "包含服裝在內的視覺層面吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "善用製作服裝的知識",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所展現的創意巧思真是太棒了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這可以說是透過努力與經驗，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "培育出了紮實的美麗技術呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她只要繼續磨練品味，",
        "unit_id": 126311,
        "voice": "vo_adv_5120065_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該就能",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓她的美提升到更高的境界。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果她想進一步鑽研，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "或許可以考慮為更美麗的人製作服裝。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n比如說，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就像我這樣子的♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我想",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這對她一定會是個很好的刺激。",
        "unit_id": 126311
    }
]