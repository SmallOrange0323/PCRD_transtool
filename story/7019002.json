[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不斷打倒擋路的魔物，在露娜之塔裡前進。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "感覺還要花不少時間。",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n先休息一下",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "會比較好嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "身為一位軍人，",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我每天都會進行基礎鍛鍊！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也可以繼續！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣啊。",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "居然每天都會進行鍛鍊，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫妮卡真是了不起呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "會累的話要馬上告訴我。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們來打勾勾。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "打、",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "打勾勾……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們確實",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "約定好了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫妮卡的手指還真小啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔……",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "受到純閣下影響，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "害我忍不住伸出手指……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但純閣下果然",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是把我",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "當小孩子看待啊……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不，",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "誰叫我長這樣。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "她會誤會是很正常的。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "冷靜地",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "傳達真相",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "才是",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "成熟的應對方式。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "純閣下……",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我有",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "重要的事要說。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那個……",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我並不是",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "小孩子。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以，",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "希望妳可以",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n再多依賴我一點。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呃……",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那個，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我很抱歉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫妮卡確實是",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n比其他小孩子更加懂事。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n接下來，我會在不危險的範圍裡，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "尊重妳的自主性。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不……",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不對！！",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我可是真正的大人！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "………………咦？",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……原來如此。",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n老實說，在聽到少年說明之前，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我一直是半信半疑……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但考慮到妳能成立公會這點，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "應該就是那麼一回事吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫妮卡，",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我很抱歉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就像妳看到的，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我有粗俗的一面……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "害妳感到不愉快了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "純閣下，",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "請不要一直道歉！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n而且……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要是為這點小事生氣，",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n就太不成熟了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "剛才發生的事情就讓它過去吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝妳，",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫妮卡。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "老實認錯的果斷。",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "願意低頭的誠實。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這正是純閣下了不起的地方！　",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣她終於",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會把我",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n當成能獨當一面的大人，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "平等地對待我了！　",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼，",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們就打起精神",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "向前進吧！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……結果",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "跟我想的不一樣。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼……",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_025"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "已經爬了不少層，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "爬得我有點熱啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "汗一直流個不停。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫妮卡。",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我有隨身攜帶水壺，妳拿去喝吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我這裡還有手帕，妳拿去擦汗吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "要是感冒就不好了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呃，",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_027"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "拒絕別人的好意也不好。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我就心懷感激地",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "借用了……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼，",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_028"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樓梯也太多階了……！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n找碴也該有個限度吧……！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔！",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_029"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哇哇！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳還好嗎？",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……喔，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱歉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我不該擅自抱起妳的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "被從腋下抱起，",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_031"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雙腳搆不到地面的這個狀況……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "實在是太丟臉了……！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n就算是尊敬的純閣下，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為了",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "維護我的威嚴，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我必須說出來！　",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "…………事。",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_032"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我沒事！",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_033"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n感謝",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳的幫忙！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唉……",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……先暫時在這裡休息吧。",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我去前面偵察一下，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很快就回來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那、",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_036"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也一起去吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不……",
        "unit_id": 104711,
        "voice": "vo_adv_7019002_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我希望莫妮卡",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "待在少年身邊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我去去就回。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "…………",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_038"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為什麼！？",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_039"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我的待遇根本沒變不是嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我可不是手無縛雞之力的小孩子！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔喔！！",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_040"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我可以收下嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……不對。",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_041"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我才不喜歡那種",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "小孩子才愛的甜食。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下自己吃吧！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……………",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_042"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣、",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_043"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下幹嘛",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看我這邊？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n咦？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我流口水了！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……呃，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下不要亂騙人啦！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咳咳，",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_044"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "感謝閣下的關心。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n反正閣下肯定是覺得我現在很沮喪對吧？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……正是那樣沒錯。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "她已經理解我是大人，",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_045"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但我終究是",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "長這樣啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n所以我無論如何都會被當成小孩子對待。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可是，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我內心是真正的大人，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "充滿榮耀的軍人。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我明白純閣下並沒有惡意。",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_046"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "即使如此……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "無法讓純閣下",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_047"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "平等地對待，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n感覺",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有些寂寞啊……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……嗯？",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_048"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎樣？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不管閣下遞過來幾次，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我是",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "絕對不會吃的！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……好、",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_049"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好吧，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "確實是那樣。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "甜食",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "最適合用來補充體力。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "補充體力這種事，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是不分小孩大人的！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "身為一個軍人，",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_050"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我必須把健康管理擺在第一位才行。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n正好我肚子也餓了，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我就收下吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯～～～！！",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_051"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "只是融化砂糖再做成的東西，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n為什麼會讓人感到如此幸福呢！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好！",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_052"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我有精神了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n而且",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "充滿了幹勁！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "再沮喪也沒有意義。",
        "unit_id": 105311,
        "voice": "vo_adv_7019002_053"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我要大展身手囉！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為了讓純閣下認同我！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吃完糖果後，莫妮卡完全恢復精神了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看到那樣的莫妮卡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}拍手為她聲援。"
    }
