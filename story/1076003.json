[
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那天晚上。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼嚕、呼嚕……♪",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔、",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔唔。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔唔～？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "奇怪？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "睡著了嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "天上的太陽",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都已經西沉了……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣可不行。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天在下好像小嬰兒一樣，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不時會無意間睡著。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大概是在不熟悉的大海裡玩樂過頭，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n耗費了超乎",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自己預期的體力吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼啊，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……♪",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n失禮了呢，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "打了個大哈欠……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉呀？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還、",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還想說怎麼這麼溫暖……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n原來是主人",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱著在下睡著了呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在是什麼狀況？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐和貪吃佩可小姐",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都不在附近……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不太能理解目前的狀況，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "腦袋因為剛睡醒",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還轉不過來。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒辦法了。",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然得打擾",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "睡得很安穩的主人很抱歉，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但還是把主人叫醒，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "問清楚狀況好了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請醒來。",
        "unit_id": 107611
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……好的，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "早安。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下是可可蘿，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您永遠的忠實隨從。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不太理解",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在的情況，覺得有點困惑，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人是否能說明一下來龍去脈呢？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且……",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像這樣被緊緊抱著的話，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "骨頭好像要斷掉一樣，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請放過在下吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然很溫暖，很舒服。",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，真不好意思。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然正值夏日，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但太陽西下後，\n多少也會感到一些涼意。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "多虧主人把體溫分給在下，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n才能避免受到風寒，真是幫了大忙。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇……",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您睡糊塗了嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不行，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個不是吃的東西哦？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是……",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "打算吃在下的髮飾呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果是鮮花還好，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但這個可是",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "人工纖維製的人造花，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以不能吃的哦？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人以【美食殿堂】成員身分活動的這段時間，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也變成貪吃鬼了呢……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n俗話說能吃能睡的孩子長得快，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下覺得這是很好的變化。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總之，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下和主人",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會睡在一起呢？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，遵照您的旨意。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯、嗯……",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為天色變暗了，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以今天就暫時先結束，收拾東西撤退了是吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n的確",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "晚上的大海視野不好，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "游泳的話很危險呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然後就",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "整理了行李等等的物品，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n移動到",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "住宿的度假小屋對吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下稍微看過了一下，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真的是一間充滿著自然風情的度假小屋呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然凱留小姐有些怨言，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但在下並不討厭。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為精靈",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是依靠大自然生活的種族。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總之，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下因為累了而睡著，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了不吵醒在下……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人守候著在下，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就這樣讓在下睡著了是吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "醒來的話",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就兩個人往度假小屋移動，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n沒醒來的話就揹過去……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人是這樣設想的嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "度假小屋的房間分配",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是凱留小姐和貪吃佩可小姐一起，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人和在下一起，因此……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人負起責任，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "照顧起在下了呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了不讓在下身體著涼而抱住在下……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人也變得想睡覺，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就一起打起了瞌睡嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下理解了。",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎讓您費了心，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下真是慚愧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【美食殿堂】的大家，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n把在下當作",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正與年齡相符的孩子般對待呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n守護著、",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "寵愛著、",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "疼愛著在下。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然在下還不習慣這樣，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有時也稍稍感到難為情。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下覺得很光榮、",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很開心。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在故鄉，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下總是",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被他人小心謹慎地對待……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然作為長老的女兒",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被他人所尊敬著，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但與人之間的相處卻有了距離。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而現在，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下從大家的身上得到了，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一般孩子",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所應該感受到的珍貴溫暖……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n簡直是一種奢侈。",
        "unit_id": 107611
    },
    {
        "type": "still",
        "still": "107600301"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，在下真是幸福的人呢。",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在主人身邊度過的每一天、",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "每一個瞬間，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n都是在故鄉",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論怎麼渴求都難以獲得的寶物。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n閃閃發光，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就像是今晚夜空中",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "閃爍的星星一般。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是幸福。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "別光只看著在下……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，也看看四周吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然白天的大海",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n被陽光反射的水面",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "波光粼粼的很漂亮……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但空無一人",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "風平浪靜漆黑夜晚裡的大海",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是饒富樂趣呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n海浪聲就像搖籃曲一般。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 107611,
        "voice": "vo_adv_1076003_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又覺得想睡覺了……♪",
        "unit_id": 107611
    }
]