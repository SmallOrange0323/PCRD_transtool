[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "{player}たちを待ち伏せするために、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nノウェムとオクトーは街中で張り込みをしていた。"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "うぅ……",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_000"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "つまらん！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アイツら全然現れないぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nイライラしすぎて",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "今にも体が暴れだしそうだ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "落ち着いてノウェム。",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_001"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そういう時はこれ、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nはい、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "あんパンと牛乳。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "またかよ！　",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_002"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "もう飽き飽きだ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "食べ物なんて他にもいっぱいあるのに、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nなんであんパンと牛乳だけなんだ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "知らないの？　",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_003"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "昔から張り込みの時は",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "あんパンと牛乳が相場なんだ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "それ以外の物を食べると──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "死んじゃうよ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "え、",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_004"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ウソ……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ウソだよな？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "うん、",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_005"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ウソ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "こ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_006"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "この野郎……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "もういい！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "こんなことしても無駄だ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nとっとと止めてやる！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "まあまあ。",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_007"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "でも、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "こんな時",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ギルドハウスでもあれば、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "とは思うよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "拠点があれば",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "張り込みもだいぶ楽になるだろうからね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オマエ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_008"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "楽したいだけだろ？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "でも、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "普通にほしいかもな、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ギルドハウス。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そうだ！　",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_009"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシが暴れても",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "壊れないヤツがいいな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "まず室内では暴れないでほしいなぁ。",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_010"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクはそうだね、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "防音がしっかりした個室があるとうれしいね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "おい！　",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_011"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "それはアタシがうるさいってことか！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そんなことは一言も言ってないよ。",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_012"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "でも、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "今のボクらには無理な話かもね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "任務であっちにフラフラ、",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_013"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "こっちにフラフラ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "普通に仲間も作れないし、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "楽しく冒険もできないんだからね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "……よく考えたら、",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_014"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシらって全然このゲーム楽しんでなくないか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "任務とはいえ",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ちょっと寂しいよな……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ま、",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_015"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "仕方ないよね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ここは我慢のしどころだからさ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "分かってる。",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_016"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "でも、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いつか素直にゲームを楽しめる、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そんな日が来るといいよな……！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "まだ見ぬ憧れの日々に想いを馳せるノウェムだった。"
    }
]