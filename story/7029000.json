    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}與雪菲兩人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在打掃【美食殿堂】的公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對不起。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我太專注了吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n因為這種時候",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可以默默地做事，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以我不知不覺就充滿幹勁了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n謝謝你的幫忙。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵，",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是啊。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "公會小屋",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒有人在的時候或許比較適合打掃。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "貪吃佩可小姐去處理公務，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "和可可蘿小姐也有私事要辦。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n像是魔法學園的教學會，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還有遊俠的集會。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "像這樣看家",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也有種特別的感覺，我覺得很開心。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n會想把屋內打掃得一塵不染，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "讓大家嚇一跳對吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "而且，",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就只有現在",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可以和你兩人獨處……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "說這種話",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "會讓人有點難為情呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯嗯，",
        "unit_id": 106711,
        "voice": "vo_adv_7029000_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雪菲真是個好孩子～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呀！",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳是什麼時候……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 106711,
        "voice": "vo_adv_7029000_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嚇到妳的話就抱歉囉。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雪菲也有的吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "屬於妳的私人交情♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個，",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳指的是……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "當然，",
        "unit_id": 106711,
        "voice": "vo_adv_7029000_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "囉～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "話說，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們公會",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "【龍族巢穴】的成員們，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不也都是龍人族的夥伴嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "的確是這樣呢。",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n尤其是帆稀小姐特別照顧我。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我要再次向妳表達感謝。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別客氣別客氣，",
        "unit_id": 106711,
        "voice": "vo_adv_7029000_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們是同伴嘛。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "話說回來……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你們兩位",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "現在",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都有空吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n只是因為沒事做才會打掃對吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然如此～",
        "unit_id": 106711,
        "voice": "vo_adv_7029000_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要不要一起去",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "非常有趣的地方？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還沒打掃完……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "已經掃得很乾淨了，",
        "unit_id": 106711,
        "voice": "vo_adv_7029000_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "應該不要緊吧～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳看，就連垃圾……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都沒有呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n祈梨的房間",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可是更驚人的哦？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那樣",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "會不會有點太過頭了……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "開玩笑的啦，",
        "unit_id": 106711,
        "voice": "vo_adv_7029000_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "開玩笑的♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我覺得還是轉換一下心情比較好哦？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n畢竟雪菲",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "最近",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看起來都心不在焉的。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦……",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳連這種事都知道嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為什麼？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 106711,
        "voice": "vo_adv_7029000_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是祕密。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "更重要的是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呢♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有個只有現在才能去的有趣地點。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n要是你們願意一起去，我會很高興的哦～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個……",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "該怎麼辦？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣好嗎……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這……",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "倒也不是沒興趣……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好，",
        "unit_id": 106711,
        "voice": "vo_adv_7029000_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那就這麼決定了～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n事不宜遲，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也會幫你們的忙，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來準備出門吧～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊啊，",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_023"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不要推我！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n帆稀小姐，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我要收拾打掃用具，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳稍等一下……！",
        "unit_id": 106412
    },
    {
        "type": "background",
