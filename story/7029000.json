        "unit_id": 106711,
        "voice": "vo_adv_7029000_024"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "到時候就會知道了～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n哼",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哼",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哼～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……現在要去的地方",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_025"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的那麼有趣嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你覺得",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "會是哪裡？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大夢想樂園……",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_026"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那是吉歐‧提格尼亞的遊樂園對吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我之前",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有稍微去過一下。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是跟鳳凰小姐",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_027"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "和拿娜小姐一起去的。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……不過那時候，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我從中途開始就幾乎一直維持嬰兒的狀態……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n所以根本",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒有餘力玩樂呢……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我記得",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_028"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那是在泰美斯銀嶺的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "度假村？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n是秋乃小姐在經營的對吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那裡就連冬天也很溫暖，",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_029"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "聽說還有漂漂河。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怎麼辦？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒有帶泳裝出來……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可以在那邊借嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那就",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒問題了吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我說，",
        "unit_id": 106412,
        "voice": "vo_adv_7029000_030"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "現在可以告訴我們了嗎？",
        "unit_id": 106412
    },
