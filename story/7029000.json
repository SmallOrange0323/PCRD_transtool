        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不知道目的地實在讓人靜不下心來。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
