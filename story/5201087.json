[
    {
        "type": "dialogue",
        "name": "晶",
        "words": "…………",
        "unit_id": 106831,
        "voice": "vo_adv_5201087_000"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "合照，",
        "unit_id": 106831,
        "voice": "vo_adv_5201087_001"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "雖然我們",
        "unit_id": 106831,
        "voice": "vo_adv_5201087_002"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "到頭來決裂了，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但我真的一直期望著。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "期望七冠",
        "unit_id": 106831,
        "voice": "vo_adv_5201087_003"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "能朝著同一個方向，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n如同改變這整個世界般，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "達成巨大的目標。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "──克莉絲。",
        "unit_id": 106831,
        "voice": "vo_adv_5201087_004"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n雖然我認為我們現在仍是朋友，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但也明白正因為是朋友，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我們才會分道揚鑣。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n她在真那身上感受到了「絕對」吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "──似似花。",
        "unit_id": 106831,
        "voice": "vo_adv_5201087_005"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n她是徹底的祕密主義者，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "到最後都沒有對我們表露真心。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "真正的現士實似似花究竟在哪裡呢？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "──教授。",
        "unit_id": 106831,
        "voice": "vo_adv_5201087_006"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n他那以實力證明的自我中心主義，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "實在讓人拿他沒辦法。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "要是我能夠打飛教授……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "大概不可能吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "況且我也討厭痛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "──長老。",
        "unit_id": 106831,
        "voice": "vo_adv_5201087_007"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "他遠離塵世，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而且深藏不露。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "他眼裡所見的",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "想必和我們不同吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "──真那。",
        "unit_id": 106831,
        "voice": "vo_adv_5201087_008"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我與他",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是不共戴天的關係，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但難道只能互相爭鬥了嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "雖然對我而言，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也唯獨不想輸給真那。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "──然後是",
        "unit_id": 106831,
        "voice": "vo_adv_5201087_009"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "「她」。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n七冠中最與眾不同，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "充滿謎團的最後一人。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "大家應該都試過要調查她，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但連一點真相都沒查到。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊哈哈♪",
        "unit_id": 106831,
        "voice": "vo_adv_5201087_010"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n所謂的七冠，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "真～是",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "一盤散沙呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也難怪",
        "unit_id": 106831,
        "voice": "vo_adv_5201087_011"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "會決裂啊。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "因為大家從一開始，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就完全看著不同的方向嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不過……",
        "unit_id": 106831,
        "voice": "vo_adv_5201087_012"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "臉上面帶笑容呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "照片中",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "當時的我。",
        "unit_id": 106831
    }
]