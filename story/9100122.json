[
    {
        "type": "background",
        "background": "501630"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呼……",
        "unit_id": 110811,
        "voice": "vo_adv_9100122_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這兩個傢伙，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "有夠難纏的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n體力根本無限，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "照它們的步調我們玩不下去。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "正是，",
        "unit_id": 111011,
        "voice": "vo_adv_9100122_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們每個人",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "都消耗了不少精神和體力。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "現在應該先重整旗鼓。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是先稍微休息一下吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好喔～！",
        "unit_id": 110911,
        "voice": "vo_adv_9100122_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "……嗯？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小碧，怎麼了？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "眼睛幹嘛睜這麼大？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n休息囉，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家一起喝茶吃點心啦？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？",
        "unit_id": 104011,
        "voice": "vo_adv_9100122_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "休息！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "戰鬥到一半還有這種的！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是啊，",
        "unit_id": 110811,
        "voice": "vo_adv_9100122_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我們在打工，有休息時間很正常啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n沒有反而才奇怪吧？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n現在工作職場要是不遵守規範，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真的馬上就會被檢舉了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "無名的藝術",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 14511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你們嘎喔個什麼勁，",
        "unit_id": 110811,
        "voice": "vo_adv_9100122_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是在大聲什麼啦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你們看了還不明白嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我們",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "在準備下午茶耶。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是有這種人呢，",
        "unit_id": 110911,
        "voice": "vo_adv_9100122_006"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "認為一直工作不休息才認真的老古板。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不知道靠毅力論工作效率反而比較差嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂，你們兩個嘎喔，",
        "unit_id": 111011,
        "voice": "vo_adv_9100122_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "經過剛剛的戰鬥，你們也有所耗損了吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "去那邊喝點機油還是油漆吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呃～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們十分鐘之後再繼續，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "請多指教。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "認可。",
        "unit_id": 13211,
        "voice": "vo_adv_9100122_008"
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n接受停戰協議。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n十分鐘後，",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "即將開始真正的地獄……",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "切嚕～",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好！",
        "unit_id": 110911,
        "voice": "vo_adv_9100122_009"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "礙事鬼走了！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n要切嚕地開始優雅的下午茶時間囉～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "……奇怪？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是有人",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "先泡好茶了嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "沒有監護人陪同，穿著制服外食是違反校規的。",
        "unit_id": 7111,
        "voice": "vo_adv_9100122_010"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "自稱好朋友社的回家社，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "妳們在做什麼？",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗚呃呃！？",
        "unit_id": 110911,
        "voice": "vo_adv_9100122_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學生會長怎麼會在這裡！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "哎呀！",
        "unit_id": 3211,
        "voice": "vo_adv_9100122_012"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "這麼大聲，真是不成體統。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n身為聖德蕾莎的子弟，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "這是怎麼回事……",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗚呃呃呃呃！",
        "unit_id": 110911,
        "voice": "vo_adv_9100122_013"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "連教務主任也在！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "是因為妳們說要拯救世界，",
        "unit_id": 3211,
        "voice": "vo_adv_9100122_014"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "我才同意妳們請假的喔。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n現在可不是大張筵席，悠哉放鬆的時候。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "快快快，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "快去拯救一下世界。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是，",
        "unit_id": 110811,
        "voice": "vo_adv_9100122_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就算妳講得跟「幫我撈一下鍋裡的油沫」一樣輕鬆……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "修女，",
        "unit_id": 111011,
        "voice": "vo_adv_9100122_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "冷靜點。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n只負責運籌帷幄發號施令的妳可能不知道，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n前線是有前線自己的做法的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "那就先起來站好。",
        "unit_id": 3211,
        "voice": "vo_adv_9100122_017"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n既然世界面臨危機，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n現在可沒有讓妳躺在地板上抓屁股的功夫。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "怎麼說呢，",
        "unit_id": 111011,
        "voice": "vo_adv_9100122_018"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "即使是我，在身為淑女前也是個人，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有時也是會抓抓屁股的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳們是在怪罪生物本身該有的生理行為嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喂，優妮學姐！",
        "unit_id": 110911,
        "voice": "vo_adv_9100122_019"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳又想講一些沒品的段子了嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我要生氣囉！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "請不要在吃東西的時候說屁跟股的！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳看，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小碧都一臉噁心了！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "唉……",
        "unit_id": 7111,
        "voice": "vo_adv_9100122_020"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "真的是到哪都上不了檯面呢……",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "妳們已經稱不上是好朋友社，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n甚至叫回家社都不夠格，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "而是害學院好丟臉社。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "啊！",
        "unit_id": 7111,
        "voice": "vo_adv_9100122_021"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我剛剛那段好像講得挺溜的！",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "呵呵，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "不知道克蘿依覺不覺得好笑……",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "偷瞄？　",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，什麼，",
        "unit_id": 110811,
        "voice": "vo_adv_9100122_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好恐怖……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "瑪麗亞幹嘛一臉得意地瞪我？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我早就算準了妳們好丟臉社沒辦法維持專注，",
        "unit_id": 7111,
        "voice": "vo_adv_9100122_023"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n在戰場上差不多該精神渙散了。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n為了到場監視與指導妳們，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我帶了強力的支援部隊過來。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哦～呵呵呵！",
        "unit_id": 103211,
        "voice": "vo_adv_9100122_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "久等了，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好朋友社的各位！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "聽說可愛的學生們陷入危機，",
        "unit_id": 104811,
        "voice": "vo_adv_9100122_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n身為聖德蕾莎女子學院特別講師的我們",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "前來助陣了！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "正義的講師【墨丘利財團】，",
        "unit_id": 104611,
        "voice": "vo_adv_9100122_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "現正登場喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "有困難的時候，",
        "unit_id": 103411,
        "voice": "vo_adv_9100122_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就交給姐姐們吧！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦哦，這樣嗎？",
        "unit_id": 111011,
        "voice": "vo_adv_9100122_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "太好了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "麻煩幫我們買茶過來。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "墨丘利財團",
        "words": "…………什麼？",
        "unit_id": 1,
        "voice": "vo_adv_9100122_029"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "茶，",
        "unit_id": 110911,
        "voice": "vo_adv_9100122_030"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "下午茶會要喝的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "呃～現在有多少人來著？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "七個人啊，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那買七瓶。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n啊，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "如果小墨丘利們也要喝的話，就再買四瓶。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那、",
        "unit_id": 103211,
        "voice": "vo_adv_9100122_031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那個……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "各位？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n在那之前，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是不是應該",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "先說些什麼……？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哦～",
        "unit_id": 110811,
        "voice": "vo_adv_9100122_032"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "錢是嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好的好的，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "稍等一下喔。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n呃～我的錢包在……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "糟糕，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我今天忘記帶錢包了！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不好意思，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可以先幫忙墊一下嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "墨丘利財團",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_9100122_033"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "各位，",
        "unit_id": 111011,
        "voice": "vo_adv_9100122_034"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "幹嘛那樣看我們？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我們又沒說不付錢，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就這麼不相信我們嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這些孩子，",
        "unit_id": 103411,
        "voice": "vo_adv_9100122_035"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "為什麼會覺得自己能得到信任啊……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "而且，這些孩子，",
        "unit_id": 104811,
        "voice": "vo_adv_9100122_036"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "為什麼打算開始開派對啊……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "先不說這些！",
        "unit_id": 103211,
        "voice": "vo_adv_9100122_037"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n好朋友社的各位，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳們也太冷淡了吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我們難得感人重逢，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳們的歡迎是不是太隨便了一點？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911,
        "voice": "vo_adv_9100122_038"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們有這麼久沒見面，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "需要說到感人重逢的程度嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n感覺姐姐妳們，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "三不五時就會跑到我們這邊露面啊？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就我的印象，都可以算是準社員了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "當然，",
        "unit_id": 110811,
        "voice": "vo_adv_9100122_039"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳們過來我們還是很感激的喔。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "只不過，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就像是──",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "見到住附近的堂表姊妹一樣。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n已經沒什麼特別來賓的感覺了，就好的方面來說。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_9100122_040"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒什麼新鮮感了，就好的方面來說。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒錯，",
        "unit_id": 110911,
        "voice": "vo_adv_9100122_041"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "像是",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「啊，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "又出現了」",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那種感覺，就好的方面來說。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這、",
        "unit_id": 103411,
        "voice": "vo_adv_9100122_042"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這樣啊……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "總覺得哪裡怪怪的，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n但既然妳們這麼說，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我就欣然接受吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "各位，",
        "unit_id": 118511,
        "voice": "vo_adv_9100122_043"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "討伐任務辛苦了。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n有充分休息了嗎？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，",
        "unit_id": 110811,
        "voice": "vo_adv_9100122_044"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是綠髮眼鏡姐姐。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "辛苦了～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是公會管理協會的花凜啊。",
        "unit_id": 111011,
        "voice": "vo_adv_9100122_045"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是難得，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "文書人員居然外派到現場。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是發生什麼問題了嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不，",
        "unit_id": 118511,
        "voice": "vo_adv_9100122_046"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "現在還沒有。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "身體健康是從事討伐工作的本錢，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "控管身體狀況是相當重要的。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n如何？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "各位已經做好充分休息了嗎？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "唉呀～",
        "unit_id": 110911,
        "voice": "vo_adv_9100122_047"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這不好說。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "接下來感覺還要纏鬥很久，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "少說也要休息個四、五小時──",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請問",
        "unit_id": 118511,
        "voice": "vo_adv_9100122_048"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "休息好了嗎？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "呃……",
        "unit_id": 110911,
        "voice": "vo_adv_9100122_049"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "了……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那就好。",
        "unit_id": 118511,
        "voice": "vo_adv_9100122_050"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n各位，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "接下來也請繼續努力吧！",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是我的錯覺嗎……",
        "unit_id": 110911,
        "voice": "vo_adv_9100122_051"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n明明花凜小姐只是擺出燦爛的笑容，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n但總覺得眼鏡底下，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "藏有無盡的",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "壓力……？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學院準備的支援包含「監視」和「指導」。",
        "unit_id": 111011,
        "voice": "vo_adv_9100122_052"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n如果後者是墨團，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那前者應該就是花凜了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "各、",
        "unit_id": 104011,
        "voice": "vo_adv_9100122_053"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "各位，不好了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "敵人回來了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "能源補充完畢！",
        "unit_id": 13211,
        "voice": "vo_adv_9100122_054"
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "切嚕────！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦，",
        "unit_id": 104811,
        "voice": "vo_adv_9100122_055"
    },
    {
