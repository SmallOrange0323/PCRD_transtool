[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "{player}！\n我今天思考了如何認識新朋友的作戰計劃！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我甚至還製造了祕密武器！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請看這個！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n鏘鏘！這就是祕密武器！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我把它取名為「朋友培養盔甲」！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請你拿看看！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "畢竟這是用了大量的鋼和鐵製成的！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這樣就不會輕易地損壞了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦，你問我這個應該如何使用嗎？",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼我來講解一下吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "首先，當遇到陌生人時，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我會說「你能成為我的朋友嗎」。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "想當然對方一定會拒絕。",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為我的存在價值，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "比掉落的眉毛還要微小。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是這時候！我會快速地脫掉上衣！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼對方就會看到，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我身上穿著這副盔甲！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "他會想說「這、這傢伙，竟然一直穿著這麼重的盔甲，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n一邊說希望我能成為他的朋友嗎……！」並因此大為震驚，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "接著對我說",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「讓我成為你的朋友吧！」",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不會奇怪，我在漫畫看過類似的情節，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我覺得應該不會錯！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呃……？",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你問我到底有沒有辦法穿上這麼重的盔甲……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼不如來試穿一下吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嘿咻……啊，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "彈、彈簧的彈性蠻強的呢……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "{player}，這個，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n彈簧的彈性比想像中更強……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚哇！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請、請救救我……",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼、",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼……給你添麻煩了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這、這個盔甲很危險，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還是把它封印好了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是！我不會氣餒的！雖然這個盔甲失敗了，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但我其實還有其他能夠認識新朋友的作戰計劃！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "接下來的計劃，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n名叫「從流氓手中救出朋友大作戰」！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "假設我到了街上……",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我想那裡一定會有流氓。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "他們……會恐嚇別人之類的。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這時，我會突然出現，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n去幫助那位被恐嚇的受害者。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣一來，那個人就會感謝我而和我做朋友！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是這樣！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n請陪我練習一下吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我扮演流氓，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你扮演那位被流氓恐嚇的受害者吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咳、呸。",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊！好煩啊！要把我從圖書館借的書拿去延期！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哦，喲、喲，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那邊那位小兄弟，你好像很有錢呢？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "跳一下看看吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦、咦……",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒有零錢聲……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "跳得賣力點！請跳得更賣力一點！！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "跳高點，再跳高一點！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "跳得更高一點！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n嗨呦！{player}！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗨呦！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗨呦！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哈、哈……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n{player}，怎麼了？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊……！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我沒有發現呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你、你真細心啊 ……",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n像名偵探一樣……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "第二個計劃也失敗了……",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_030"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊！請、請不要回家……！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_031"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我還有其他計劃！這是最後一個計劃了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n名叫「突破極限交朋友的絕命賽」！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這裡有一個開關。",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一按下這個開關，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n10秒之後就會有木樁",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "從這個裝置彈出來。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在那之前沒有說出「請和我做朋友」的話，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_033"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這個裝置就不會停止。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果超過時限而被彈出來的木樁撞擊，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_034"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我就會掉到深達十公尺的洞穴裡面！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那我就會沒命了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你說我拼命製造這裝置很厲害？",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_035"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不不不，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "交朋友更要我的命啊……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，我們開始吧，突破極限的交朋友絕命賽！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_036"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你要看到最後啊！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啟動開關！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_037"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請、",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_038"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請和、和我、和我……和我吃……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不是，和我……和我坐……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n和我坐在這……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、我、我我……",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_039"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n萵苣！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊啊――",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我不行了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呀",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_040"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……呼。你幫我改變了木樁彈出的方向呢。",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_041"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這樣我總算得救了。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝謝……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，不好了！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_042"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我忘記我把「有我在喔好朋友1號」放在那裡了！\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊啊――――！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_043"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n「有我在喔好朋友1號」",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "被木樁推入地獄了～！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚、嗚嗚……",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_044"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我為了交朋友而製作的，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "僅有的練習對象……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣我離交到朋友的目標又更遙遠了……",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_045"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為精靈之森……太偏僻了。",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_046"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我很少能遇見人類……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n所以我覺得很寂莫。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_047"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有一個叫做森林守衛的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "精靈族公會。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我有參加這個公會，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n大家都對我很好，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我很喜歡這個公會，但是……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我也無法時常見到她們，更重要的是，",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_048"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我不想拖累性格開朗的各位成員……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我想用自己的力量去認識新朋友……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦……你說我很認真……",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_049"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "才不是，我只不過是過分認真而已……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n而且是有點過頭的過分認真……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「有我在喔好朋友1號」……",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_050"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n製造一個新的要多少時間呢……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦―――！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_051"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n不、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不愧是BB團的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "拜、拜託你了！",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_052"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那不如我以後就叫{player}",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「有我在喔好朋友2號先生」好了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦，不、不喜歡嗎？",
        "unit_id": 104011,
        "voice": "vo_adv_1040003_053"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "抱歉，我又說了這麼厚臉皮的話了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，\n碧和{player}的交朋友計劃又向前邁進了一步……"
    }
]