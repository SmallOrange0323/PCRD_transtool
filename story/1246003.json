        "voice": "vo_adv_1246003_003"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "昨天謝謝妳的幫忙！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n多虧有妳，我身體",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "已經完全康復了！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "嘿嘿！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "呼……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "呼……！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎、",
        "unit_id": 101512,
        "voice": "vo_adv_1246003_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真的完全康復了嗎……？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "看你還氣喘吁吁的……",
