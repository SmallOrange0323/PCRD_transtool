    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師覺得很開心♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n謝謝你們把我畫得這麼好。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……對了。",
        "unit_id": 124611,
        "voice": "vo_adv_1246003_061"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我也想看一下{player}所畫的歌牌♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n可以告訴我是哪一張嗎？",
