    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還有另一個人。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我還在想是誰，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "原來是昨天的老闆～！",
        "unit_id": 101512
    },
