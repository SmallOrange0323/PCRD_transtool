        "type": "dialogue",
        "name": "美里",
        "words": "\n這是怎麼回事～？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這張紙牌，",
        "unit_id": 124611,
        "voice": "vo_adv_1246003_055"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "以及這張紙牌，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還有這張紙牌……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n全都是畫我……？",
        "unit_id": 124611
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真是的……",
        "unit_id": 124611,
        "voice": "vo_adv_1246003_056"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你們大家一起商量好要捉弄老師的嗎～？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不是？",
        "unit_id": 124611,
        "voice": "vo_adv_1246003_057"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以，大家都沒有互相看對方畫什麼，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n很湊巧地全都在歌牌上畫了我嗎……？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊……",
        "unit_id": 124611,
        "voice": "vo_adv_1246003_058"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是這樣啊……！",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n各位，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真的嗎？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯！",
        "unit_id": 5411,
        "voice": "vo_adv_1246003_059"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我一開始還不知道要畫什麼才好，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n知道是畫自己喜歡的人事物後，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n馬上就想到要畫美里老師！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……原來是這樣～",
        "unit_id": 124611,
        "voice": "vo_adv_1246003_060"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
