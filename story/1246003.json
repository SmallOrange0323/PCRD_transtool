    {
        "type": "dialogue",
        "name": "老大",
        "words": "啊，",
        "unit_id": 1412,
        "voice": "vo_adv_1246003_007"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "這是要送給美里的伴手禮！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n老實說，昨天的常客們",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "都已經迷上美里了呢！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n他們拜託我",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "務必要把這些東西帶來給妳……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "話說回來，這裡為什麼會有小孩子啊？",
        "unit_id": 1412,
        "voice": "vo_adv_1246003_008"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n……不，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "我曾聽小伙子說美里是老師。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n不過，現在是新年期間吧？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "幼稚園沒有放假嗎？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯，",
        "unit_id": 5411,
        "voice": "vo_adv_1246003_009"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "有放假喔～",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "只是",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我們已經厭倦待在家裡了～！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "……",
        "unit_id": 1412,
        "voice": "vo_adv_1246003_010"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "真是的，",
