    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "哈哈，",
        "unit_id": 1412,
        "voice": "vo_adv_1246003_005"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "這只是因為搬重物的關係，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "才會喘成這樣！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n幸好有小伙子幫忙，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "不然我就累癱在半路上了！",
        "unit_id": 1412
