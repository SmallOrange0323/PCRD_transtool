    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "難得的新年假期，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n至少要讓美里好好休息啊……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "不過，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n她休假還過來我店裡幫忙，我也沒資格說別人……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101512,
        "voice": "vo_adv_1246003_011"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為我想早點見到大家，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n所以我也很開心。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "而且",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}也過來了～♪",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "真是的，",
        "unit_id": 1412,
        "voice": "vo_adv_1246003_012"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "該說妳",
