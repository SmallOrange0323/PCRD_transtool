    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美里與{player}幫忙煮年糕湯的隔天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n精靈之森傳來了孩子們的歡笑聲。"
    },
    {
        "type": "dialogue",
        "name": "美里",
