[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我能理解，珠希。",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然最近各種族間的隔閡越來越深，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但我還是希望大家能儘量互相合作。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這麼說來，",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳是精靈族呢喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為耳朵尖尖的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這附近有個精靈族的聚落，",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n那邊好像也受到爆炸的影響而有些損害。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這樣的話，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "或許妳應該去看看狀況喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～……",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我跟這附近的森林精靈族們，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n其實沒有什麼交集呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們算是不同的族系哦。",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我記得，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可可蘿也是這樣對吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2006010_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然都是精靈族，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但大家並非都隸屬於同一個部族。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但畢竟還是同個種族，",
        "unit_id": 105913,
        "voice": "vo_adv_2006010_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要是遭受損害的話，還是會很在意他們的安危呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼，等等我們一起去看看吧。",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n畢竟現在是非常時期，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "得互相幫忙才行。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n{player}，你也想一起去嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你真是的。",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一講到要幫助別人，你就搶著想做呢～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～。",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有認識的人在那個精靈族的聚落裡啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你人脈真的很廣呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "精靈族可是相當封閉的說。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呃是說你們幾個……",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然說你們很自然地出現，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我就順勢和你們聊起來了啦",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但完全沒有連絡就失蹤了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這段期間到底跑去哪、做了什麼啊？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這好歹算是感動的再會吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不是應該要做些什麼嗎，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "像是很激動地抱在一起之類的～？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哇，",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我是開玩笑的啦……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒關係啦，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "知道你們沒事就好了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但可別讓我太擔心哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我真的很擔心哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但你也不必露出那副滿懷歉意的表情，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等等把來龍去脈跟我解釋一下吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵。",
        "unit_id": 104811,
        "voice": "vo_adv_2006010_015"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n咲戀在{player}的面前，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n顯得有些笨拙呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "明明到剛才為止都擔心得坐立不安，",
        "unit_id": 104811,
        "voice": "vo_adv_2006010_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n還超級遷怒到我身上的說♪",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦，",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟我們住在一起……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "又是家人，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n會擔心他也是理所當然的吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵。",
        "unit_id": 104811,
        "voice": "vo_adv_2006010_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n那麼我也來",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n先向第一次見面的對方自我介紹一下吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我是隸屬於【墨丘利財團】的",
        "unit_id": 104811,
        "voice": "vo_adv_2006010_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "美冬。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……我的職稱是什麼啊，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "業務？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "總務？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我覺得美冬幾乎算是經營者了喵。",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為我們都很隨性～\n所以幾乎沒好好在做事喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "實際上，我們的公會，",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n要是沒有美冬的話，就無法成立了呢喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "謝謝妳啊喵，",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n總是受到妳的照顧呢喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "既然大家都知道自己太隨性了，",
        "unit_id": 104811,
        "voice": "vo_adv_2006010_023"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n那就好好工作啊。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呵呵。",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們公會還有其他人，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n但大部分都留在城裡處理一般的事務喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "現在就只有幾個人到牧場來幫忙而已喵。",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我想優花梨應該是",
        "unit_id": 104811,
        "voice": "vo_adv_2006010_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n在幫忙治療那些受傷的人才對……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那秋乃她人呢？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要是沒看好她的話，她就會惹出麻煩的事。",
        "unit_id": 104811,
        "voice": "vo_adv_2006010_027"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n所以我現在有點不安呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈。",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要找她的話，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n她搭上飛空艇到附近的牧場去了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就那個……",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n有一個由一對兄妹經營的牧場，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就是我們以前從黑心業者手上救了他們的那個喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "飼養在【伊麗莎白牧場】的牛和馬……",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n需要暫時寄放在",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n附近的牧場裡了嘛喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為我們這牧場的柵欄等設備都還沒有復原，",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_031"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n所以家畜們得找個地方寄養才行喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "秋乃",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就是去溝通這件事的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "唔嗯。",
        "unit_id": 104811,
        "voice": "vo_adv_2006010_032"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n如果是在執行公務的話，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n應該就沒什麼問題才對。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "而且不知為什麼，秋乃很會交涉，",
        "unit_id": 104811,
        "voice": "vo_adv_2006010_033"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n交給她應該沒問題吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為那孩子",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_034"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "天生就是個討人喜愛的人喵～",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不知道該說是領袖特質喵，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n還是該說她天生就是個要站在眾人之上的大小姐喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是啊。",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n她從以前就是這樣呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是狡猾呢～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "自由奔放地過著自己的生活，",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但卻很巧妙地，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n能讓大家莫名地感謝她呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然總是把她身邊的人",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n耍得團團轉，讓人很頭痛呢……♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，她啊……",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n好像跟【墨丘利財團】的大家",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n處得很好，這就讓我放心多了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為她很不會察言觀色，",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以要是跟人處不好，那就糟糕了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "算是處得很好嗎？",
        "unit_id": 104811,
        "voice": "vo_adv_2006010_040"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也是吵架吵不停就是了……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但即使如此，她還是會和",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n同公會的夥伴們和樂融融地一起做事就是了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個，",
        "unit_id": 103411,
        "voice": "vo_adv_2006010_041"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "抱歉！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "有沒有人可以來幫忙一下？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哎呀，",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_042"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不小心就聊起天來了喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼了喵，優花梨？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯。",
        "unit_id": 103411,
        "voice": "vo_adv_2006010_043"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這附近好像有魔物在四處閒晃，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n大家都覺得很害怕。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然它們並沒有造成什麼破壞。",
        "unit_id": 103411,
        "voice": "vo_adv_2006010_044"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n但畢竟先前才遭受襲擊，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n所以大家感到很不安。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "為了以防萬一，",
        "unit_id": 103411,
        "voice": "vo_adv_2006010_045"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n大家就希望可以找幾個能夠戰鬥的人，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n把那些魔物驅趕到別的地方去。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "只是，現在很多人",
        "unit_id": 103411,
        "voice": "vo_adv_2006010_046"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n從一大早就開始勞動，都已經累了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n所以人手不足。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我也只是治癒師，",
        "unit_id": 103411,
        "voice": "vo_adv_2006010_047"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不擅長在前線跟敵人直接戰鬥。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以才想說，來找很擅長這種事情的",
        "unit_id": 103411,
        "voice": "vo_adv_2006010_048"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n美冬等人，要是妳能幫忙就太好了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，不過美冬正在整合所有的事務，",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_049"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n沒辦法讓她離開這裡呢喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總之，",
        "unit_id": 104611,
        "voice": "vo_adv_2006010_050"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就讓我去吧喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n魔物出沒的地方是在哪裡喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這邊這邊。",
        "unit_id": 103411,
        "voice": "vo_adv_2006010_051"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n快一點。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然現在【伊麗莎白牧場】的人們\n正在跟魔物對抗……",
        "unit_id": 103411,
        "voice": "vo_adv_2006010_052"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但大家從昨天就忙著避難，變得很虛弱，或許有危險。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "請等一下。",
        "unit_id": 104811,
        "voice": "vo_adv_2006010_053"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我也要去。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為這種驅除害獸",
        "unit_id": 104811,
        "voice": "vo_adv_2006010_054"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也是我擅長的工作。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……咲戀，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這裡可以交給妳嗎？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "知道了，",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_055"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "交給我吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然我也很想過去幫忙……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但如果多個公會",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_056"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n各自行動的話會陷入混亂的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是會需要有人進行主導，",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_057"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n負責統籌大家才行呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我",
        "unit_id": 102811,
        "voice": "vo_adv_2006010_058"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還滿擅長做這種溝通的，交給我吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n實際上，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這也算是適才適所呢。",
        "unit_id": 102811
    }
]