[
    {
        "type": "background",
        "background": "500552"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "到了晚上，逐漸熟悉淨化願望的{player}一行人。\n前往神殿的人潮源源不絕，工作愈來愈忙碌。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們回來了〜……",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "話說我們，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "已經持續工作幾個小時了啊〜……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "差不多該休息一下？",
        "unit_id": 108811,
        "voice": "vo_adv_5010005_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這樣不休息一直工作的話，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "等等就會很累唷？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……的確已經到體力的極限了，",
        "unit_id": 108911,
        "voice": "vo_adv_5010005_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也不知道願望何時會出現呢。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "各位，",
        "unit_id": 511,
        "voice": "vo_adv_5010005_003"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "真的很謝謝你們的努力。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "祭司大人！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "如果累了的話，請趁現在好好休息呢。",
        "unit_id": 511,
        "voice": "vo_adv_5010005_005"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "因為，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "過了這個時間後可能會變得更忙也說不定。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也是呢——……",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_006"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "接近新年的最後幾個小時，",
        "unit_id": 511,
        "voice": "vo_adv_5010005_007"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "是一年當中願望會變得最密集的時候。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "人們無法實現的願望交纏在一起，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "引發無法預料的情況也是時常出現。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "請各位盡可能，",
        "unit_id": 511,
        "voice": "vo_adv_5010005_008"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "不要掉以輕心。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無法預料的情況？",
        "unit_id": 108911,
        "voice": "vo_adv_5010005_009"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "在悠久的歷史當中，",
        "unit_id": 511,
        "voice": "vo_adv_5010005_010"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "也不少像是這樣的事。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "如果大家有想達成的願望，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n請趁現在寫在護符上",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "然後投入祭壇。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我好想把剛剛的回憶給燒掉啊。",
        "unit_id": 108911,
        "voice": "vo_adv_5010005_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈哈、",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈哈哈……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜！　",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "快回神啊——！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家寫完了嗎？",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我完成了唷——！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也寫完了喔。",
        "unit_id": 108811,
        "voice": "vo_adv_5010005_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳寫了什麼？　",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "給我看給我看——！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "討厭，",
        "unit_id": 108811,
        "voice": "vo_adv_5010005_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不能看啦。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好丟臉唷……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳這麼一說就更令人在意了啊！",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵",
        "unit_id": 108911,
        "voice": "vo_adv_5010005_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵呵……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就算不問我也知道了，",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "讓她靜一靜吧……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生呢？　",
        "unit_id": 108811,
        "voice": "vo_adv_5010005_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "準備好護符了嗎？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生沒有嗎？",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒實現的或想忘記的事。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣啊。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你的記憶……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎士先生。",
        "unit_id": 108811,
        "voice": "vo_adv_5010005_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的確是……",
        "unit_id": 108911,
        "voice": "vo_adv_5010005_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和伙伴的回憶",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也不忍燒掉呢。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼那麼，",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家接下來一起",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "去製造更多的回憶吧！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　對吧！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯！",
        "unit_id": 108811,
        "voice": "vo_adv_5010005_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說得也是。",
        "unit_id": 108911,
        "voice": "vo_adv_5010005_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們去把紙投進去就回來，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你在這裡等一下。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……今天",
        "unit_id": 108911,
        "voice": "vo_adv_5010005_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "把他帶來這裡，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也許不是件好事也說不定。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "為什麼？　",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_029"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天看起來非常開心唷？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……怜想說的事情，",
        "unit_id": 108811,
        "voice": "vo_adv_5010005_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我知道唷。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他現在喪失了記憶。",
        "unit_id": 108911,
        "voice": "vo_adv_5010005_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這種稱為「消除記憶」",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的儀式，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不可能讓他開心起來呢……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呃……！　",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_032"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是這樣",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "的呢……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不過！　",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天的事情也一定，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "會成為回憶唷！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……我們能為騎士先生做的事情，",
        "unit_id": 108811,
        "voice": "vo_adv_5010005_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不知道有什麼呢……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一定有的唷！　",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一定……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "絕對有的！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯。",
        "unit_id": 108911,
        "voice": "vo_adv_5010005_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "當他依靠我們的時候，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一定要助他一臂之力。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有困難的時候就是要互相幫助幫助，",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才對嘛！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，",
        "unit_id": 108911,
        "voice": "vo_adv_5010005_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是這樣。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯！　",
        "unit_id": 108811,
        "voice": "vo_adv_5010005_038"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說的也是！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……所以，",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_039"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們去迎接騎士先生吧！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n來比賽誰最快！　",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "預備，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "跑！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和，",
        "unit_id": 108811,
        "voice": "vo_adv_5010005_040"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "穿著和服跑很危險唷！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算因為單獨跑比較容易，竟然敢先偷跑，",
        "unit_id": 108911,
        "voice": "vo_adv_5010005_041"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還真行呢！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒關係沒關係！",
        "unit_id": 108711,
        "voice": "vo_adv_5010005_042"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因為突然變得很想看到騎士先生的臉呢！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜和優衣也是這樣吧――",
        "unit_id": 108711
