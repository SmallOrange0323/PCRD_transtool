[
    {
        "type": "background",
        "background": "509015"
    },
    {
        "type": "background",
        "background": "510302"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "喂，",
        "unit_id": 105131,
        "voice": "vo_adv_4010255_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我在這邊。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n很準時呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵。",
        "unit_id": 105131,
        "voice": "vo_adv_4010255_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n突然想見我，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是因為知道今天是什麼日子嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀。",
        "unit_id": 105131,
        "voice": "vo_adv_4010255_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "既然你知道，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n那麼，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我可以把這當作",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "生日約會的邀約",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "吧？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你也挺會的嘛。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "長大之後，",
        "unit_id": 105131,
        "voice": "vo_adv_4010255_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所謂的生日，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "往往就是買貴一點的熟食，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "無視熱量吃幾口蛋糕慶祝而已。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "等到像這樣，",
        "unit_id": 105131,
        "voice": "vo_adv_4010255_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要跟某個人一起度過生日時……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n總覺得，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "體內的溫度在上升呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話雖如此，",
        "unit_id": 105131,
        "voice": "vo_adv_4010255_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這孩子畢竟還年輕，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "與其說是生日約會，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "感覺更像是慶生會呢。　",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦？",
        "unit_id": 105131,
        "voice": "vo_adv_4010255_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這間店",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對你來說，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "應該不便宜吧……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n沒關係嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……呵呵，",
        "unit_id": 105131,
        "voice": "vo_adv_4010255_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "感覺到你的緊張了呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是為了配合我，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "才勉強自己嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是個了不起的男孩子呢。",
        "unit_id": 105131,
        "voice": "vo_adv_4010255_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不對，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "把他當作小孩看待",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很失禮呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "謝",
        "unit_id": 105131,
        "voice": "vo_adv_4010255_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "謝你為我展現帥氣的一面。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n光是這份心意",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就讓我很開心了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還是讓我結帳吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "想請我吃飯的話，",
        "unit_id": 105131,
        "voice": "vo_adv_4010255_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "等你",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "再長大一點吧，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好嗎♪",
        "unit_id": 105131
    }
]