        "voice": "vo_adv_4010240_009"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n搞不好你正是為了",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "餵宮子吃好吃的布丁",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n而活在這個世上的～！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁會議",
