    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "奇怪？",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好像",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "有點好吃。",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你再",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "多餵宮子吃幾口。",
        "unit_id": 100731
    },
