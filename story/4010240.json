        "voice": "vo_adv_4010240_007"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "怎麼可能因為那樣就變──",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔咕。",
