        "voice": "vo_adv_4010240_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "今天是宮子的生日喲。",
        "unit_id": 100731,
        "voice": "vo_adv_4010240_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "所以你買了",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好多布丁回來給人家當禮物。",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "各種不同廠牌、口味各不相同的布丁，",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "一",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "大堆。",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子覺得好開心，",
        "unit_id": 100731,
        "voice": "vo_adv_4010240_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n也好感謝",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}。",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可是同時，",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "又察覺到一件事──",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這就跟",
        "unit_id": 100731,
        "voice": "vo_adv_4010240_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "平時一樣喲！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "跟你要布丁吃",
        "unit_id": 100731,
        "voice": "vo_adv_4010240_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "一直都是人家的日常！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這樣缺乏那種只有生日才有的特別感啦～～～～～～！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家就知道。",
        "unit_id": 100731,
        "voice": "vo_adv_4010240_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "所以才要召開",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁會議喲。",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子想要用特別的感覺",
        "unit_id": 100731,
        "voice": "vo_adv_4010240_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "來吃你準備的生日布丁。",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那樣的話，",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "吃起來肯定",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "會比平時還要好吃許多才對……！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}，你快想想有什麼辦法！",
        "unit_id": 100731
    },
