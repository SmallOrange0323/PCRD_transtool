    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可以用來誇獎所有女孩子，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就像魔法咒語一樣。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我懂～",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_040"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n嗯嗯。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "比起凶巴巴的人，當然還是溫柔的人好呀～♪",
