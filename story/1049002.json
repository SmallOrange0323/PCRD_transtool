[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不好意思～",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n請協助我們做問卷調查♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還可以拿到",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n可麗餅店【拉比林斯】的折價券唷！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "請大家",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "多多協助問卷調查～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唔……",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我也不是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "閒閒沒事做呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n為什麼",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "非得在這裡發傳單不可呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是，",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我才剛搬到這座城鎮，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n開銷也不少。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n公會長真的會好好發薪資給我嗎……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "畢竟那個人的金錢觀念",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "很鬆散啊。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "該說她太過隨興～",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還是該說她不拘小節呢？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不對。",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我也只能相信她，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "跟隨她了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為了能",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n和寶貝「弟弟」重逢……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一是克制，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "二是忍受，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "三四過後，五還是忍耐～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯。",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要【拉比林斯】以可麗餅店打出知名度，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就能掩藏作為祕密結社的另一面了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也就是打造出一個",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有利於活動的絕佳藏身之處。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "公會長也是基於這個意圖",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n才會拜託我「妳也來幫忙可麗餅店的工作嘛～♪」的吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "絕對不是……",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n因為覺得可麗餅",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n越煎越好玩吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "她應該沒有忘記原來的目的吧。",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我可是相信著她喔～？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唉呀。",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n想東想西的也無濟於事。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我還得發傳單呢♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們是",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n可麗餅店【拉比林斯】～！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n請協助我們做問卷調查♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯？",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n咦？\n{player}！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好巧喔！",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你在這裡做什麼呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "散步嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我呀～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在打工呢♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯。",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我兼職的可麗餅店",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n在有點偏僻的地方……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "其實不太會有客人",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n經過我們店附近。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以我在發傳單，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "上面有很清楚明瞭的地圖標示。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我還要順便",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n做個問卷調查，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n問問大家都喜歡什麼口味的可麗餅～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是很踏實的",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "行銷活動♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個傳單\n也給{player}一張。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯。",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n如果你願意賞臉的話，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n肚子餓的時候可以到我們店裡來。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還有……",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "時間方便的話，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n可以幫忙回答一下問卷調查嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可以嗎？",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "謝謝你！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}果然是個乖孩子呢……♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯。",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n一看見傷腦筋的人就無法坐視不管吧！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你成長成這麼溫柔的人，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我好欣慰呀☆",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼，",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我會問幾個問題。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你不用太嚴肅，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "隨興回答就好了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你有",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "常去的餐廳嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "大概多久",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會吃一次點心呢？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你喜歡",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "吃什麼呢？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿嘿。",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n{player}，\n所有問題你都老老實實回答了呢！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是乖孩子。",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好想緊緊抱住他呀！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，不可以，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "禁止偷跑！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然我想趁這個機會",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n和他增進感情。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是公會長也說過，",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n現在不能給{player}過分刺激……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然很惋惜，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但我得忍耐才行。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是……",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n如果是假借問卷調查的名義，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n問幾個問題應該沒關係吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我也想更了解",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n關於{player}的事情嘛♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "畢竟我們分開了",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這麼長一段時間，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "現在的{player}",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "和我所知道的「可愛弟弟」相去甚遠……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我也不想認為",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_034"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n他已經變了一個人。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_035"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我想盡量填補這個缺口！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n因為我是姐姐呀，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n凡是關於弟弟的事情，我通通想知道！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "調查關於{player}的資料",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_036"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n也符合【拉比林斯】的活動方針呀！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就用這一套理論武裝吧♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿嘿。",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_037"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我就問下一個問題囉。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}，",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_038"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你喜歡什麼樣的女孩子呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇，",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_039"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有種標準答案的感覺。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "畢竟溫柔體貼",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不需要什麼特殊技能嘛……",
