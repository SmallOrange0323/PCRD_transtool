    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_041"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有時候女孩子的溫柔……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只是為了巧妙地誘導純情男孩",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所做出來的演技。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "具備洞察這一切的審美眼光",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_042"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n也是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不可或缺的喔♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇，",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_043"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n真會拍馬屁！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是的，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "怎麼這麼可愛呀～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果這是{player}的真心話，",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_044"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我會感到很幸福的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但如果只是顧慮我而說的場面話，",
