        "voice": "vo_adv_1049002_045"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我會覺得有點空虛吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不管怎麼說，",
        "unit_id": 104911,
        "voice": "vo_adv_1049002_046"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "謝謝你的回答！",
        "unit_id": 104911
    },
