        "type": "dialogue",
        "name": "觀眾們",
        "words": "喜歡──────！",
        "unit_id": 1,
        "voice": "vo_adv_5214000_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "聚集在此的，",
        "unit_id": 126811,
        "voice": "vo_adv_5214000_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是無論到哪裡都足以自豪，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "無論展現何處都不失體面的",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "８位美麗的臀士！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "包含背面世界在內，全世界頂尖水準的８人──",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "等一下，工作人員。",
        "unit_id": 126811,
        "voice": "vo_adv_5214000_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這個要我念嗎？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "照腳本走？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "如果是工作的話那也沒辦法……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不過之後那個說好的飲料慰勞品，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "要麻煩你囉？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "全體選手，",
        "unit_id": 126811,
        "voice": "vo_adv_5214000_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "入場──！！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "嗚喔喔喔喔喔喔喔────────！！",
        "unit_id": 1,
        "voice": "vo_adv_5214000_009"
    },
    {
        "type": "still",
        "still": "521400001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好大────！",
        "unit_id": 126811,
        "voice": "vo_adv_5214000_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也太大了吧！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "240公分，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "108公斤！！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來自煉獄之地的",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "巨臀之霸！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "阿剌克涅，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是不是太大了捏？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "阿剌克涅選手────！",
        "unit_id": 126811
    },
    {
        "type": "still",
        "still": "521400002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "偶像來這種地方真的可以嗎？",
