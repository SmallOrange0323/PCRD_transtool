    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "位於某座被冰雪封閉的銀嶺之中，卻存在著一處四季如夏的樂園。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n由【墨丘利財團】所經營的度假設施「墨丘利度假村」。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n此刻，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "少女們火熱而激烈的戰鬥，正要在這裡揭開序幕──"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "欸、",
        "unit_id": 138712,
        "voice": "vo_adv_5214000_000"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "欸，栞小姐，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "現在逃跑還來得及，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我們兩個一起逃吧？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "要是被那些厲害的人用屁股撞上的話，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "會被殺死的……！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒問題的，",
        "unit_id": 138812,
        "voice": "vo_adv_5214000_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "若菜小姐。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我們",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是撐過了美冬教練",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嚴格的特訓。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "──啊，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好像要開始了。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來來來，",
        "unit_id": 126811,
        "voice": "vo_adv_5214000_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "各位久等啦！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n走過路過不要錯過～！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我是負責實況講評的",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "優花梨～！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我是負責解說的怜。",
        "unit_id": 122511,
        "voice": "vo_adv_5214000_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "請多指教。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "現場的各位～",
        "unit_id": 126811,
        "voice": "vo_adv_5214000_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你們喜歡",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "漂亮的屁股嗎～！？",
