    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可以的！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n就讓你們看看頂尖偶像的搖臀吧！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "竟然是",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來自【慈樂之音】的",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "望選手登場啦────！",
        "unit_id": 126811
    },
    {
        "type": "still",
        "still": "521400003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "現在的我，甚至可以用屁股進行精靈唱喚──",
        "unit_id": 126811,
        "voice": "vo_adv_5214000_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "她發下如此豪語！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "同樣來自【慈樂之音】！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "難道要上演意想不到的偶像同門對決了嗎！？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "風精之臀！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "千歌選手！！",
        "unit_id": 126811
    },
    {
        "type": "still",
        "still": "521400004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我是為了被修理才來的！",
        "unit_id": 126811,
        "voice": "vo_adv_5214000_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "快點把我的屁股",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "打得滿是「紅葉」吧！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我想感受一屁塗地的滋味！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不，是一敗塗地的滋味！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "抖Ｍ的Ｍ就是屁股的Ｍ！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "空花選手──！",
        "unit_id": 126811
    },
    {
        "type": "still",
        "still": "521400005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不會飛的屁股就只是普通的屁股！？",
        "unit_id": 126811,
        "voice": "vo_adv_5214000_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那當然啦──！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來自童話世界的鋼鐵臀部！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "屁股翱翔飛向天空！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "克蘿茜選手！",
        "unit_id": 126811
    },
    {
        "type": "still",
        "still": "521400006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "被黑鐵覆蓋的那張臉！",
        "unit_id": 126811,
        "voice": "vo_adv_5214000_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還有那個屁股！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "終於要揭開面紗了嗎！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n【王宮騎士團】的工作不管了嗎──！\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "極具奪冠潛力的有屁候補！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "純選手！",
        "unit_id": 126811
    },
    {
        "type": "still",
        "still": "521400007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "──那麼，",
        "unit_id": 126811,
        "voice": "vo_adv_5214000_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "在這裡有個遺憾的消息要告訴大家。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "上一屆冠軍的真步選手，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為忙著做茶泡飯，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這次竟然缺席了！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是不是用好聽的藉口溜了……？",
        "unit_id": 122511,
        "voice": "vo_adv_5214000_017"
    },
    {
        "type": "still",
        "still": "521400008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "另外，",
        "unit_id": 126811,
        "voice": "vo_adv_5214000_018"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "在非官方的野外對戰中，擊敗涅婭選手的「豪臀」──",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n美空選手也表示，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "「那天預定會感冒喔～★」",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因此",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "遺憾地以病假缺席！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那句話意思是──",
        "unit_id": 122511,
        "voice": "vo_adv_5214000_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "被逃掉了呢……",
        "unit_id": 122511
    },
