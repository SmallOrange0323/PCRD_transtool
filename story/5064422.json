[
    {
        "type": "background",
        "background": "501260"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗚哇啊啊啊啊啊！",
        "unit_id": 116411,
        "voice": "vo_adv_5064422_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "致命一擊────！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喝呀────！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呼喵────────！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好了好了，",
        "unit_id": 116211,
        "voice": "vo_adv_5064422_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "已經結束了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不要再發狂了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n還有敵人是我們打倒的，別演得像是妳打倒的一樣。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐這種搶功勞的舉動，",
        "unit_id": 116311,
        "voice": "vo_adv_5064422_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "已經變成慣例了呢。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 116411,
        "voice": "vo_adv_5064422_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要說慣例的話，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "敵人應該也還會再來犯吧？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n之前為這所學院帶來災厄的魔物都是這樣。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊……",
        "unit_id": 116311,
        "voice": "vo_adv_5064422_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "按照學姐說的套路，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n差不多該是聽到",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「有緊急狀況！」",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "然後看到",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n綠髮眼鏡姐姐──",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我記得是花凜小姐，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "從公會管理協會跑過來的時候了呢。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "花凜小姐那種委託方式，",
        "unit_id": 116211,
        "voice": "vo_adv_5064422_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真的很難讓人拒絕啊──",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n她呀，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "一開口語氣不就一副走投無路的樣子嗎。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「這樣下去就不得了了！",
        "unit_id": 116411,
        "voice": "vo_adv_5064422_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "請您助我們一臂之力！」",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不像～（笑）",
        "unit_id": 116211,
        "voice": "vo_adv_5064422_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過真的是這樣說。（笑）",
        "unit_id": 116311,
        "voice": "vo_adv_5064422_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不好，",
        "unit_id": 116211,
        "voice": "vo_adv_5064422_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "越想越回甘。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "緊急狀況，",
        "unit_id": 116311,
        "voice": "vo_adv_5064422_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "有哪次不緊急的嘛。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "然後啊，",
        "unit_id": 116211,
        "voice": "vo_adv_5064422_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "被她氣勢壓過答應之後，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n花凜小姐馬上就會露出營業用笑容，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "說「請努力挑戰看看！」",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "還笑得超燦爛的。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個人，",
        "unit_id": 116311,
        "voice": "vo_adv_5064422_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "該不會那種是交往前很用心，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但交往後就變得很冷淡的類型吧？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說，",
        "unit_id": 116211,
        "voice": "vo_adv_5064422_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "花凜姐姐有男朋友嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我看，",
        "unit_id": 116411,
        "voice": "vo_adv_5064422_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "應該是沒有吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我想也是。",
        "unit_id": 116311,
        "voice": "vo_adv_5064422_015"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n感覺是那種全心投入工作的人？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n看她總是在尋找美好的夥伴，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不然就是在發布警報。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊、不妙！",
        "unit_id": 116211,
        "voice": "vo_adv_5064422_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n說人人到，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "姐姐她跑過來了……！",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "快點，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "裝認真一下，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "擺好嚴肅的表情。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「有緊急狀況！」",
        "unit_id": 116411,
        "voice": "vo_adv_5064422_017"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "噗……",
        "unit_id": 116311,
        "voice": "vo_adv_5064422_018"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "呵呵呵……！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "拜託別這樣，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "會害人家笑場啦！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喂，",
        "unit_id": 116211,
        "voice": "vo_adv_5064422_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "別鬧了，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "都不准笑喔──？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n先說好，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就算花凜小姐說的話跟我們猜的一樣，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n也絕對不准笑喔──？",
        "unit_id": 116211
    }
]