    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "明天就是",
        "unit_id": 110211,
        "voice": "vo_adv_6019206_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "鈴奈的活動了。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們也要High起來喔！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要努力幫鈴奈加油，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不能輸給其他觀光客！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你還蠻有幹勁的嘛！",
        "unit_id": 110211,
        "voice": "vo_adv_6019206_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "難得鈴奈邀請我們來島上，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這點回禮",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是身為淑女應做的事！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……",
        "unit_id": 110211,
        "voice": "vo_adv_6019206_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼？　",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這是怎麼回事？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n幫替鈴奈加油的我加油……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以說，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你到底是要幫誰加油啊？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n真是的，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "總之，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "幫兩人都加油就行了啦！　",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要充滿幹勁喔！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你說什麼！？",
        "unit_id": 110211,
        "voice": "vo_adv_6019206_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要展現出最棒的加油的人是我啦！　",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我絕對不會輸給你的～！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n敢跟我比，我會讓你後悔的，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你覺悟吧！",
        "unit_id": 110211
    }
]