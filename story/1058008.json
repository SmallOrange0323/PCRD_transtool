    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼啊，食道真舒服～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "味覺不是只有舌頭才感覺得到，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我終於有這種實感了～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "服務生，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我要加點？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "餐單的上面到下面全部都來一份，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然全部都要大份的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻，麻煩你囉♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哈呼……",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～胃開始消化了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子裡的胃壁在蠕動了～",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n開始將營養傳給全身細胞～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，出生在這世上實在太好了……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這邊這邊～♪",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "300100103"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被堆疊的盤子擋住，讓你看不到我的臉，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n抱歉！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了舒緩壓力，不小心又暴飲暴食了～♪",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我吃太多了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不用擔心啦～",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "人類的胃容量比你想像得大多了喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要一直消化，我就有無限的胃容量，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n人類沒有辦不到的事！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是～……",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n即便如此，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n平常我可是有克制自己，盡量不要把店吃垮喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唯獨今天，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了忘記所有煩惱，我想要盡情地吃。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，該怎麼說才好……",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我最近老是被政府機關的人追著跑。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "積了不少壓力呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "竟然說我、我是通緝要犯！",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n明明是被冤枉的～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼會有這麼離譜的事情！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸，不是不是不是！",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我真的是被冤枉的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然沒人願意相信我～……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道連你",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也認為我是壞人嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚……和我在一起的話，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會給你和小可蘿，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有小凱留添麻煩。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還是",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n到遠方去旅行比較好吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘎？",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n哇，為什麼突然抱緊我？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不希望我去別的地方嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你這個撒嬌鬼……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等等，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱歉。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我吃得太飽，所以把衣服的鈕扣鬆開了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你這樣抱，會把我的衣服脫掉啦……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇，停下停下！",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的會脫下來啦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但是你好像願意相信我～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我很開心能確實地感受到你對我的珍惜。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝。",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我一直",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都被你拯救呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要跟你在一起，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就覺得肚子飽飽的……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘎……？",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n又有什麼在發光了？",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『{player}～！",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈☆』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『好久不見！",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你現在有空嗎？』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『之前受到你不少照顧，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今天是來答謝你的♪』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『這是要給你的謝禮。",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是我國的名產喔～",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拿回去跟家人一起吃吧。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『雖然可以放蠻久的，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但你還是早點吃完比較好♪』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『……？",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n咦，翻譯功能可以用吧？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們語言……有通吧？』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『不會吧，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你難道忘記我了嗎？』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『真令人失望～",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我還以為我們已經是朋友了？』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『嗯？",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你那個",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是什麼反應……？』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『哇啊，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不可以叫我的名字啦！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為說不定隔牆有耳！』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『啊～看你這個反應……",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來你終於",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也察覺了我的真實身分。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『新聞也有在報導我的事，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n被發現也沒辦法。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『你要是太拘謹，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會覺得有點寂寞。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『你要是能像對待同年紀的朋友一樣跟我相處的話，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會很開心。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『嗯，你說……要我先進門再說？",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈，我沒有打算要待很久。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『那我就恭敬不如從命，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "稍微打擾你一下了♪』",
        "unit_id": 105831
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "still",
        "still": "105800801"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『哇，好新奇……♪",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你家裡長這樣啊～？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧！』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『嗯，那個～……",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我姑且是個公主喔。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我的國家並不富裕，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而我家也是普普通通喔。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我並不是驚訝平民家很狹窄……",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而是因不同的建築樣式",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感到佩服罷了。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『還有電器產品果然很厲害呢，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像是空調還有電視♪』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『不要這樣叫，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不要叫我公主啦。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『喔？",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是麥茶吧，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n來得正是時候，我正好口渴了。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我開動啦！",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n嘓嘓……♪",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼啊，從來沒喝過這種味道！』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『沒錯！",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我從以前就很喜歡旅行……♪』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『接觸未知國度各自的文化，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我覺得很有趣喔。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『所以當雙親為了外交要巡迴全世界的時候，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我硬是要他們帶我一起去。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『其中我特別喜歡日本喔，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為飯很好吃……♪』",
        "unit_id": 105831
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『……",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼啊。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總之，可以放心了。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『室內似乎也沒有其他人……",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而我們又是朋友，我得好好地報上名來呢。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我的本名是",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n尤絲蒂亞娜。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『尤絲蒂亞娜・F・阿斯特賴亞。",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_060"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n聽起來很長，又很厲害的名字吧？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "叫我蒂亞娜就可以囉。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『當然。",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你要跟之前一樣，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n用貪吃佩可這個綽號叫我也行♪』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『對了對了。",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n存在於阿斯特朗傳奇",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n的阿斯特賴亞大陸……』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『它的由來就是\n源自於我的家族姓氏喔。』",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我國的皇家正是",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_064"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n阿斯特朗傳奇的贊助商喔。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『似乎是開發者為了討好我們，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n才使用我們的名字喔。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我們除了贊助之外，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還積極地協助人才的派遣和伺服器的設置等等喔。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『因為我國在這方面的技術比較落後，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_067"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以卯盡全力在做呢。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『基本上，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n阿斯特朗的米奈娃是由聯合國所管理……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我國不過是其中較大的贊助者之一。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『但對我國來說，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_069"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n它在政治和經濟上都是重要的計畫。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『也因為如此，之前發生的『米奈娃覺醒』事件，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n才會鬧得滿城風雨呢。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我的雙親這次雖然是為了外交才造訪日本。",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_071"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但同時也為了這方面的調查和檢討會，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n正四處奔波呢。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我在成年之前，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_072"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都不打算介入政治……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也因此閒得發慌。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『第一次和你相遇時，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_073"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我可是偷溜出來鬼混呢。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『……嘻嘻。",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_074"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你果然還是很緊張呢。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我跟你一樣是人類啊，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_075"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請不要這麼拘謹。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『你這樣不行啦～",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_076"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿斯特朗傳奇",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是為了讓大家成為公主的冒險遊戲對吧？』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『在你的夥伴當中，",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_077"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n說不定就有人會成為公主。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我想你還是先趁現在",
        "unit_id": 105831,
        "voice": "vo_adv_1058008_078"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好好地熟悉一下所謂的公主喔♪』",
        "unit_id": 105831
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗚哇，",
        "unit_id": 190011,
        "voice": "vo_adv_1058008_079"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這麼爽快地",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n報上本名！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那個……尤絲什麼的？",
        "unit_id": 190011,
        "voice": "vo_adv_1058008_080"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，早知道就做個筆記了～！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說起來，",
        "unit_id": 190011,
        "voice": "vo_adv_1058008_081"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這個名字好像在那裡聽過……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "貪吃佩可被視為國家貴賓，",
        "unit_id": 190011,
        "voice": "vo_adv_1058008_082"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以她的相關資料也很難存取呢～？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉。",
        "unit_id": 190011,
        "voice": "vo_adv_1058008_083"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我有些事情想調查一下，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以這次的夢就先結束囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "意想不到的收穫呢～",
        "unit_id": 190011,
        "voice": "vo_adv_1058008_084"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你跟貪吃佩可能成為朋友真是太好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說不定我們離",
        "unit_id": 190011,
        "voice": "vo_adv_1058008_085"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n環繞在這個世界的真相，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n又能前進一大步呢……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在這之後，",
        "unit_id": 190011,
        "voice": "vo_adv_1058008_086"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你必須要謹慎行事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1058008_087"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n貪吃佩可就拜託囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她好像是如假包換的公主哦。",
        "unit_id": 190011,
        "voice": "vo_adv_1058008_088"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這可是牽扯到外交上的問題，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你務必要小心謹慎。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯……",
        "unit_id": 190011,
        "voice": "vo_adv_1058008_089"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她本人也說～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n希望你能將她當作同年紀的朋友一樣相處。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以你就像之前一樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1058008_090"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n跟她一起友好地吃飯就行啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這雖然有點困難，但你一定沒問題的。",
        "unit_id": 190011,
        "voice": "vo_adv_1058008_091"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為無論什麼樣的女孩，\n似乎都會喜歡上你……♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "加點的料理來了喔，\n我們一起吃吧♪",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_092"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你不要緊吧？",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_093"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n臉色好像有點差……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，蒂亞娜？",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_094"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n欸欸，你從哪裡聽來這個名字？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，我有報上名字嗎……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_095"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可能是在政府機關的時候把名字說了出來。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚～……我實在是不希望，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_096"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n把你們捲入我的紛爭當中。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以你還是先把它忘掉吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然你們跟我已經脫離不了關係，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_097"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如今再說什麼也於事無補呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是我自己的問題，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_098"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會自己好好地處理。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不說這個了，",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_099"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們來吃飯吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論是公主還是什麼人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不吃飯的話就活不下去！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且。",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_100"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n吃飯的話……，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就能體會到幸福的感覺。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個道理",
        "unit_id": 105812,
        "voice": "vo_adv_1058008_101"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是你還有夥伴們，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "教會了一無所有的我喔。",
        "unit_id": 105812
    }
]