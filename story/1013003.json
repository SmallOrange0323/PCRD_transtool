[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被七七香約到\n埃斯特雷拉街道上。"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呦呦！",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你來啦吉祥物！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我等很久囉～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你學會怎麼變身為小動物了嘛？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要定期巡迴也不錯，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但是今天有別的事要做──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我是不是有說過",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我在古物店工作？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有時候會收到客人找東西的委託喔。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有一次為了幫助人而做了之後，得到了不錯的評價──",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "從那之後就開始把它當作正式工作來做了──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這次接到案子，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "希望身為夥伴的你也能幫忙，所以就叫你來了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且都沒有之前那神秘男的情報，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在有任何動靜之前，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我想先跟你一起工作，增進友情囉──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "來吧，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "讓我們攜手面對絕望！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔──！",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這是我正在看的漫畫中的台詞！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n為什麼你知道呀──？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不對啦──！",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那個台詞是第二卷中敵人的台詞喔──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……是說，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你怎麼會知道我看的漫畫的台詞？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "偷偷看我喜歡的",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「魔法少女小莎莉」學來的……？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔喔──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "神啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如此幸運的展開是怎麼回事！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然本來就覺得你是很棒的夥伴，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但沒想到真的能志同道合……！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我現在，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的超級感動喔……！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "之後一定要來個聊天會……",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "想～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "到～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "期待──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "話題扯遠了？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還真是失禮了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不小心興奮過頭了呢！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼我們快點往",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "委託裡提到的森林那邊前進吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "{player}隊員呀！出發吧！",
        "unit_id": 101311
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這次的委託人呀，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要尋找老公送她的墜飾。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "據說是在這片森林中採集藥草時被魔物襲擊，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n逃走時弄掉的。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "委託人說這是擁有重要回憶的物品，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以一定要替她找到喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是充滿回憶的物品嘛？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "簡直就像……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就像弄丟了",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在大熱天裡排隊，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n辛苦買到的限定商品一樣的痛苦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一定要成功達成這個委託任務！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n來吧，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "兩人同心協力，讓委託人重拾笑容吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯……",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真奇怪呢──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你沒發現嗎？",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "森林中的違和感……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "的確是那樣沒錯，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n有更加不可思議的事……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "照理來說這邊應該有很多魔物，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n但目前為止連一隻都沒遇到……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "該不會是因為，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_025"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "害怕超可愛的七七香，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n而躲起來了吧？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哈！",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "原來我的名聲",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "已經傳到魔物那裡啦～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "若是如此，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_027"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可以更安心地好好找東西了……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "說得也是嘛──",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "果然事情不可能那麼輕鬆嘛──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n森林深處傳來了什麼聲音……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "總覺得，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有預感是一個龐然大物……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n稍微確認一下狀況吧……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……啊，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的有。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唉呀──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看牠鬧得可真不留情呢──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可能就是因為那傢伙，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這邊才會沒有任何魔物。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為非常殘暴嘛。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不知道是不是吃到什麼不好的東西──",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_032"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦……？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是錯覺嗎……",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_033"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n魔物的手上好像戴著我們在找的項鍊……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔欸，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_034"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是錯覺呀。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n魔物還真的拿著項鍊……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看來不得不打倒牠了……",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_035"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒辦法了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一鼓作氣上吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "拜託你幫忙支援了！",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_036"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我會負責前衛！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……我，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_037"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等這場戰役結束後，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有話想告訴你……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒有啦，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_038"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一輩子想說一次看看！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然完全沒有打算要赴死的意思！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "來吧，魔物！",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_039"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你的對手可是阿斯特朗最強的魔法少女，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "七七香喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "用電腦的閃光──",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_040"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "慢慢慢著！",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_041"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妨礙人家介紹自己可是違反規則！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這點要好好學習啊──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有沒有在聽啊……",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_042"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n吃下七七香全力的魔法吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "被魔法攻擊還能衝過來……",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_043"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n是錯亂了嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不要過來啦──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過嘛，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_044"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有人說過，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n面對這種狂怒的對手時，應該要冷靜面對！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "華麗的躲開魔物的攻擊，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_045"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "接、著、是！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "用之前的搶案得到的那個魔法，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_046"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n往破綻百出的側腹來上一擊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "強力的魔法配上你的支援能力一定是最強的。",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_047"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "吃我一擊吧──！",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_048"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚哇──！",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_049"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好大的威力！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n一次就擊倒耶！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼就",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_050"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "把項鍊拿回來吧……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "欸，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_051"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等等等，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你給我等一下！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不可以直接碰觸那條項鍊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "上面好像還有殘餘的魔力……",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_052"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可能是",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_053"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為施在那項鍊上的魔法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛才的魔物才會這麼兇暴的喔。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且那種感覺……",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_054"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "跟發生搶案時得到的魔法類似……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "與其說類似，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不如說根本是同一種……？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不可能是委託人做的，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_055"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n所以是那個神秘男的作為嗎。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "男子在遺落在森林中的墜飾上下了魔法，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_056"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後戴在魔物身上……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "之類的？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "殘留在墜飾上的魔力不強，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_057"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n但也感覺得出來是相當熟練的人做的……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然不清楚他的目的，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_058"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但我絕不允許將魔法用在惡途！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們快把他找出來並加以嚴懲吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "若那傢伙把傳說中的魔導書弄到手，",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_059"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n可不是開玩笑的呢……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "總之先處理項鍊……",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_060"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嘿～呦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "邪惡魔法啊，永別了！",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_061"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "萌呀萌呀……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怦♪",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "很好！",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_062"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼一來墜飾上的魔法就被解開囉──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不愧是七七香！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是完美呢♪",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "接下來只要交給委託人就完成了！",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_063"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……啊呀──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天真是累翻囉──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "必須回家補充二次元的東西呢……",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_064"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n對了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "下次休假時，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你也一起來定期巡迴嘛──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "難得你對",
        "unit_id": 101311,
        "voice": "vo_adv_1013003_065"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "創作品有興趣！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就讓我來教你定期巡迴的奧義吧──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和因為共同興趣而高興不已的七七香一起，\n{player}回到了城裡。"
    }
]