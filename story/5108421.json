        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你希望我怎麼款待你呢？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "開玩笑的",
        "unit_id": 124711,
        "voice": "vo_adv_5108421_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哦。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可能是因為在溫泉旅館工作的關係吧，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n忍不住就",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "用接待客人的方式說話了。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過放心吧。",
        "unit_id": 124711,
        "voice": "vo_adv_5108421_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我還是",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有為戰鬥做足準備喔，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n為了出現任何狀況都能應付。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼我們出發吧。",
        "unit_id": 124711,
        "voice": "vo_adv_5108421_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我會如你所願，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "為你發揮力量的。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓我們迎接",
        "unit_id": 124711,
        "voice": "vo_adv_5108421_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "愉快的新年吧……♪",
        "unit_id": 124711
