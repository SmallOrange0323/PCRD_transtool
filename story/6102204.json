    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "首先，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們一起逛逛同人誌的攤位吧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你有沒有",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼想買的刊物呢？",
