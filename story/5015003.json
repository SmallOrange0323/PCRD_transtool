    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "打聽結束的{player}一行人。\n大家到約好的茶館集合。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "餡蜜……",
        "unit_id": 105311,
        "voice": "vo_adv_5015003_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既美麗又甜美……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n在豆沙上面淋上",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "甜甜的黑色糖蜜……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "簡直就是完美……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是完美的和諧啊……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "東國料理真是太美味了……",
        "unit_id": 105511,
        "voice": "vo_adv_5015003_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好像會變胖，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "太可怕了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不用擔心那個喔。",
        "unit_id": 100811,
        "voice": "vo_adv_5015003_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為東國的甜點",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n跟蛋糕比起來，更不容易發胖。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "東國甜點",
        "unit_id": 109611,
        "voice": "vo_adv_5015003_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "全部都很美味，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "尤其",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "草莓大福是我最推薦的！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、",
        "unit_id": 105511,
        "voice": "vo_adv_5015003_004"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個呀……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……看到我們正用美味的甜食",
        "unit_id": 105311,
        "voice": "vo_adv_5015003_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n逃避現實，你就應該要察覺吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "順帶一提，",
        "unit_id": 100811,
        "voice": "vo_adv_5015003_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在我想要打聽什麼的時候，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "大家竟然都理所當然的說",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美貌已經超越了美麗之神了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而且，",
        "unit_id": 100811,
        "voice": "vo_adv_5015003_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還被推銷了",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n適合我的美貌的商品，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓我又買了好幾把髮簪。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我也是……",
        "unit_id": 109611,
        "voice": "vo_adv_5015003_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n不管我怎麼問，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "他們都",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "含糊的",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "帶過去，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而且還",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不停地被推銷商品。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "本來想要拒絕的，",
        "unit_id": 109611,
        "voice": "vo_adv_5015003_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "結果",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "臣服於這個DX巨大招財貓的",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "光芒之下了……",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花也是……！",
        "unit_id": 109511,
        "voice": "vo_adv_5015003_010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n一回過神，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就買下了",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n比平常採集時會被糾纏住的常春藤",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "還要更粗更堅固的繩子……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "哎、哎呀，",
        "unit_id": 109511,
        "voice": "vo_adv_5015003_011"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我看到的時候，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n就覺得有點想買了……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "（流口水）……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……能、",
        "unit_id": 105311,
        "voice": "vo_adv_5015003_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "能找到自己想要的東西真是太好了呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我的情況也很類似，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為了讓對方失去戒心就聊了起來，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "結果被說服買下了這個金平糖……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "回去之後我要好好地品嚐。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我算是躲過了推銷，",
        "unit_id": 105511,
        "voice": "vo_adv_5015003_013"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n但也是因為那樣，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "完全不能和人好好的交談……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前、",
        "unit_id": 105511,
        "voice": "vo_adv_5015003_014"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩的情況怎樣呢？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那那、",
        "unit_id": 109511,
        "voice": "vo_adv_5015003_015"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那該不會……！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你是想和誰玩那個玩具啊！？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦？　",
        "unit_id": 109511,
        "voice": "vo_adv_5015003_016"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這就是一般和小孩子玩的玩具啊？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花還以為一定是……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不是，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "什、什麼事都沒有！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前、",
        "unit_id": 105511,
        "voice": "vo_adv_5015003_017"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩穿和服！？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呼啊啊啊……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好想看一眼……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚嗚……",
        "unit_id": 105511,
        "voice": "vo_adv_5015003_018"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "要是去服裝出租店時，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n建議前輩也穿就好了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "結果大家",
        "unit_id": 109611,
        "voice": "vo_adv_5015003_019"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "只增加了土產，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "完全沒有收獲呢……",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "明明知道絕對有什麼事情的……",
        "unit_id": 105511,
        "voice": "vo_adv_5015003_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就是啊……",
        "unit_id": 105311,
        "voice": "vo_adv_5015003_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不論是哪間店，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都很會做生意，\n但是，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "感覺都很強勢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "既然這樣，",
        "unit_id": 109611,
        "voice": "vo_adv_5015003_022"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就再調查一下！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是啊。",
        "unit_id": 105311,
        "voice": "vo_adv_5015003_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也很在意這個詭異的氣氛。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n出了店外，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這次我們全部的人一起去打聽吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "茶屋老闆",
        "words": "啊，",
        "unit_id": 1412,
        "voice": "vo_adv_5015003_024"
    },
    {
        "type": "dialogue",
        "name": "茶屋老闆",
        "words": "客人！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "茶屋老闆",
        "words": "\n請等一下！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦，",
        "unit_id": 105511,
        "voice": "vo_adv_5015003_025"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有什麼事嗎？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "錢已經付過了――",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "茶屋老闆",
        "words": "不是的，",
        "unit_id": 1412,
        "voice": "vo_adv_5015003_026"
    },
    {
        "type": "dialogue",
        "name": "茶屋老闆",
        "words": "是想請你們再多點些什麼吧！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "茶屋老闆",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "茶屋老闆",
        "words": "你們看，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "茶屋老闆",
        "words": "像是我們這裡的名產抹茶煎餅之類的！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "…………",
        "unit_id": 109611,
        "voice": "vo_adv_5015003_027"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我知道你是因為我的美貌，",
        "unit_id": 100811,
        "voice": "vo_adv_5015003_028"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以想要多留下我們一會，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過我們還有急事。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "茶屋老闆",
        "words": "沒問題的！",
        "unit_id": 1412,
        "voice": "vo_adv_5015003_029"
    },
    {
        "type": "dialogue",
        "name": "茶屋老闆",
        "words": "\n這個可以邊走邊吃！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可、",
        "unit_id": 109511,
        "voice": "vo_adv_5015003_030"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可是，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花已經",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "吃得很飽了……",
        "unit_id": 109511
