    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "彦星に浮気されちまって、",
        "unit_id": 113111,
        "voice": "vo_adv_6044105_000"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "織姫はかわいそうだね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "祭りを開催するためってのもあるけど……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "織姫のために、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "早く問題を解決してあげないとね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "ああ、",
        "unit_id": 113111,
        "voice": "vo_adv_6044105_001"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "そうだね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "余計なお世話って言われちまうかもしれないけど……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "あの涙を見て放っておけるほど、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "アタシは大人しい人間じゃないのさ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "え、",
        "unit_id": 113111,
        "voice": "vo_adv_6044105_002"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "そこからなのかい！？　",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "ええと、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "浮気ってのは……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\nこう、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "色んな女の子に",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "声をかけて遊ぶってことなんだよ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "まあ、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "素直で純粋なお前さんにゃ関係ないことさ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "……気持ちってのは",
        "unit_id": 113111,
        "voice": "vo_adv_6044105_003"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "難しいもんなんだよ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "一度好きになっちまったら、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "何かあっても嫌いになれないもんさ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n惚れちまった方が負けとは",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "よく言ったもんだよ、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "まったく。",
        "unit_id": 113111
    }
]