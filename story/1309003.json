    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "再怎麼說我也是經理喔！？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "對於自家的遊樂設施，",
