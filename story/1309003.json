    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "快樂的時光一轉眼就過去了呢……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "開、",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "開玩笑的，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我可沒有覺得沮喪喔！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "英雄先生，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_032"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "最後要不要再玩個什麼呢？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
