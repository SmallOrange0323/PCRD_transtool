    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我我、",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我知道了。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我們走吧！",
