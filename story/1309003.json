    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「大夢想樂園」結束今天的營業後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n庫露露找了{player}過來，說是有事商量。"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "英雄先生，",
