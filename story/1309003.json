    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "呼──！！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……啊、",
