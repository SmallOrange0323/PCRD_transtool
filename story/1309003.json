        "voice": "vo_adv_1309003_012"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "是這樣沒錯呢！！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……我明白了。",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_013"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "那麼那麼",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "請恕庫露露冒昧，",
