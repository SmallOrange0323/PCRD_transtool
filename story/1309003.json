        "voice": "vo_adv_1309003_034"
    },
    {
        "type": "dialogue",
        "name": "新進工作人員",
        "words": "\n請兩位好好享受──",
        "unit_id": 1211
    },
    {
        "type": "still",
        "still": "130900301"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "啊哈哈♪",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_035"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n英雄先生～♪",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "晚上的旋轉木馬",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_036"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "很漂亮對吧。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "和這邊各種的華麗遊樂設施相比，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n還要更加地閃亮耀眼──",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我在外面看著的時候，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_037"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "總是會想，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n不曉得從裡面看會是什麼樣的景色呢。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "嗯♪",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_038"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "從裡面看的話，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n比在外面看到的更閃閃發亮呢。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……不過，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_039"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "這可能，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n是因為和英雄先生一起搭的關係……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "也說不定。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "英雄先生，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_040"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我要再說一次。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n有你幫忙「大夢想樂園」",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "重新經營到這種程度，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n真的",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "真的",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "非常感謝。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "今天",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_041"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "跟英雄先生在園內玩了一圈，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n讓我回想起了許多事。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……我說，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_042"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "英雄先生。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n打造「潛入3D世界」那時候的事，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n你還記得嗎？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "巨人族和狗頭人族的朋友",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_043"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n因為體型不一樣，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "而沒有辦法遊玩同一項遊樂設施。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我們大家一起想了很多辦法呢。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "「阿斯特朗異世界」，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_044"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n是為了鼓勵一位想成為冒險家的女孩子",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "去追逐夢想……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "那時候幾乎沒有什麼客人來，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_045"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n我們真的是，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "一股腦地拚盡全力呢。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "也有過一直無法順利進行，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_046"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "差點就要一蹶不振的時候。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "多虧了有英雄先生在，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "才能夠一次次重新站起來。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "英雄先生，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_047"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n是我的超級英雄先生喔！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……還有。",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_048"
    },
    {
        "type": "still",
        "still": "130900302"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……已經好幾次覺得自己不知分寸，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_049"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n而將這份感情埋藏在心裡。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n可是……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "好像",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "已經藏不下去了。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "即使是這麼遲鈍的我",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_050"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "也還是發現到了。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n這份感情",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "一定、",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "多半、",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "大概……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "不，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "絕對是。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "是……",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_051"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "戀",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "愛……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "吧。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "…………嗚。",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_052"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_053"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "沒事！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n什麼事都沒有！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "英雄先生，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_054"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "今天玩得開心嗎？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "有稍微報答到你嗎！？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "可是可是，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_055"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "比起英雄先生對我的恩情，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n這點程度還完全不夠呢。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "英雄先生。",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_056"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n你至今對我的恩情，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n我一定會報答的！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "不論要花上多少年，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_057"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n就算",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "變成了老婆婆兔子……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "也一定會報答！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "所以說",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_058"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "如果，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n要是這些恩情",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "全部還清了。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "如果說，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_059"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "萬一，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "出了什麼差錯……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "讓我和英雄先生",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "能夠處於對等的立場。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "到時候",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_060"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "能不能向你表達這份感情呢……？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "然而那一天根本就不可能會到來的～～～！！",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_061"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n我太不知分寸，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "太厚顏無恥，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "太得意忘形了。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n對不起對不起～～～！！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……咦？",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_062"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "多虧了我，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_063"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "才能獲得在遊樂園工作",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "的快樂經驗……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "和這些懷念",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_064"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "又可愛的魔物們",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "再次重逢……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n見到這麼多客人的笑容……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我對英雄先生，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_065"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "也有……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "英雄先生……",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_066"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……啊啊。",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_067"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n速度開始變慢了。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "很快就要結束了呢。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "再過一會，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_068"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n至今的這段",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "快樂時光也要……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……呀啊！？",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_069"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n速度又上升了！？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "這、",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_070"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "這是怎麼一回事？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "工作人員小姐！？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "啊啊，",
        "unit_id": 1211,
        "voice": "vo_adv_1309003_071"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "經理不好意思！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "我不小心弄錯，按到再次啟動的按鈕了！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "請原諒冒失的我，",
        "unit_id": 1211,
        "voice": "vo_adv_1309003_072"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n就這樣",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "再玩一次好嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……唔！",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_073"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "工作人員小姐……",
