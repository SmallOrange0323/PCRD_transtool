    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "好的，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "請問是什麼呢？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "欸欸！",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_008"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我也一起嗎！？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "怎麼行怎麼行，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "讓我跟英雄先生一起玩這種事，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n實在太不知分寸了～！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "而且而且……！",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_009"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n在遊樂園裡……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "一起玩的話，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "這樣子",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "不就是……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "遊樂園約會嗎！？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "那、",
