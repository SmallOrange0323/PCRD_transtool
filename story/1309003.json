        "voice": "vo_adv_1309003_000"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n不好意思",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "在你疲憊的時候找你過來……！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……那個，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_001"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "雖然有點突然，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n但是你在這之後",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "有空嗎？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "其實",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_002"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "今天整個晚上，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n我把「大夢想樂園」包場了。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "因為我想邀請英雄先生來玩……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "因為……",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_003"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "英雄先生來幫忙的期間",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n已經",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "剩沒多久就要結束了……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "讓忙於冒險的你",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_004"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "幫了這麼多的忙，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "真的是非常感謝。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "英雄先生",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_005"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "非常",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "非常地關照我，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n我",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "卻一直沒能報答……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "所以可以請你至少",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "接受這個邀請嗎？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "今天就把工作",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_006"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "拋到腦後，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n在「大夢想樂園」裡盡情地玩耍好嗎！？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "這是我的心願……！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "哇，",
        "unit_id": 130912,
        "voice": "vo_adv_1309003_007"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "謝謝你！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "咦……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "但是你有一個請求？",
