    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "啊哈哈，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "真是開心呢……♪",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "新進工作人員",
        "words": "請問需要",
