        "voice": "vo_adv_1309003_010"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "那次是",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "為了摸索針對情侶的策略，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n才進行的模擬約會，",
