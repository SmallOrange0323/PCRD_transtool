[
    {
        "type": "background",
        "background": "501193"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "遭到自海底出現的巨魚攻擊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n【美食殿堂】的成員們落入海中──"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……嗚",
        "unit_id": 105913,
        "voice": "vo_adv_5056001_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……這裡是？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來……",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不像是海裡呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該是所有人都掉入海中了啊──",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_5056001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n會不會是這艘船的船員",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "救了我們……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得這艘船的外形很奇特……",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊，",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留還在昏迷！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快醒來──！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔唔……",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會被吃掉……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n本來是要釣魚，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "卻要被魚吃掉了了了了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──啊！？",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這裡是哪？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們到底怎麼了！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n剛剛那隻像是怪物的魚呢！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳、",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳冷靜一點呀，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n剛剛的大魚已經不見了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該很安全──",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "──呀啊！？",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚啊啊啊啊啊啊！？",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n船在晃！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "晃超大的！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這整艘船似乎晃得很嚴重……！",
        "unit_id": 105913,
        "voice": "vo_adv_5056001_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請小心別被甩下去了！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──哦哦哦哦哦哦哦哦哦哦喝啊！！！",
        "unit_id": 1,
        "voice": "vo_adv_5056001_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "噫噫！？",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次又是什麼啦！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那是──？",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_013"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──唔哦哦……！！",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那、",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個魚型魔物是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "剛剛的……！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913,
        "voice": "vo_adv_5056001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "外觀的確是很像沒錯……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n體型卻好像比剛剛看到的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那隻小很多。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個人似乎正在用釣線把魚拉上來──",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……唔……？",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……小姑娘們，",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你們醒啦。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不好意思，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就如你們所見，我正在忙。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n在我跟那傢伙分出勝負前，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "麻煩你們稍等一下囉……！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──呀啊！？",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是什麼狀況？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……「金槍鮪」，",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n牠們是只棲息於這片大間海域中的魔物。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n而我現在就是要釣起牠……！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喔喔喔喔！！！！",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_022"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟、",
        "unit_id": 105913,
        "voice": "vo_adv_5056001_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然只憑臂力，就把魚給扯過來了……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "騙、",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "騙人的吧……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n他真的釣得起那麼大的魚嗎！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚喔喔喔喔喔喔喔喔──！！！",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──呀嗯！？",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_5056001_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……咦？",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他剛剛、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跌倒了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n他腳滑跌倒了吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等、",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等等！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那或許是某種戰術。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "況且你們看，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他似乎是個很厲害的漁夫！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對吧，",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他剛剛不是叫了聲「啊嗯！？」嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都一把年紀了，還不由自主地叫出充滿少女心的悲鳴耶。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_033"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……故意裝成腳滑，",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_034"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n再發出特殊吆喝聲釣起獵物的「呀嗯漁法」……",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n真正執行起來，才發現還挺困難的啊。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才怪，",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是什麼樣的漁法啊！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然你煞有其事地含混過去，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但其實就只是跌倒吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n魚也被逃掉了的說！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「呀嗯漁法」……！？",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有這樣的技術啊……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n捕魚還真是深奧呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也別一副理所當然的樣子相信啊！",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_037"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……捕魚就是會伴隨著意外。",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_038"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不、不不不",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不要著急，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "獵物會從著急的傢伙手中逃走。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "冷冷冷冷冷",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "冷靜下來展開下一步行動──",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你渾身都在冒冷汗啊！",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n釣線也整個纏在手上了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你才該冷靜一點啦！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛才逃走的魚",
        "unit_id": 105913,
        "voice": "vo_adv_5056001_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直突擊過來！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再這樣下去，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "船體會支撐不住！",
