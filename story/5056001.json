        "words": "呃，",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_081"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大叔！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你幹嘛突然那麼大聲！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "……啊，抱歉。",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_082"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n原來如此……",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "小姑娘們被",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "「那傢伙」攻擊了啊。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "你們能保住一命，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "真是太好了。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和正先生。",
        "unit_id": 105913,
        "voice": "vo_adv_5056001_083"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n方便的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能否請您解釋事情的來龍去脈？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才剛來到這片大海……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "……",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_084"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "小姑娘妳們",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_085"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "應該也看到了對吧。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n看到「那傢伙」……",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "潛伏在這海中的",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "超巨大金槍鮪。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_086"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你是指攻擊我們小船的魚吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n的確有看到喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "世上居然存在那麼大的魚，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我超驚訝的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們差點就被吃掉了……",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_087"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔唔……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在回想起來還會發抖……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "「那傢伙」……",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_088"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "名為「究極金槍鮪」。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n是潛伏於這大間海中的主人，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "也是金槍鮪們的老大。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "說是老大，",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_089"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "牠平時也幾乎不現身。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "據說是因為身體異常的大，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "為了保留體力，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n大多待在海底休眠。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "可是……",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_090"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "「那傢伙」",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "會隔幾十年醒來一次，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n然後率領金槍鮪們",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "大鬧一場。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大海的主人……",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_091"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那麼，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會有那麼多金槍鮪來攻擊我們，也是因為牠──？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……那大量的魚，",
        "unit_id": 105913,
        "voice": "vo_adv_5056001_092"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來是因為在此之前的咆哮才會出現的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n恐怕就是那位大海之主",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所造成的吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚……",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_093"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "本以為可以靠釣魚輕鬆賺錢，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但感覺相當不妙耶。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "……我不是說了嗎。",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_094"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n竟敢在如今的大間海域捕魚，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "再不要命也該有個限度。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "我現在",
        "unit_id": 6411,
        "voice": "vo_adv_5056001_095"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "要回城鎮去補給，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n就順便帶你們過去吧。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n等抵達港口，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "就直接回老家去吧。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊──",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_096"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他、",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_097"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他那是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼態度嘛……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺真討厭。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明他自己就捕魚捕得那麼痛快。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_098"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼辦？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然已經明白這片大海比我們想像中還要危險……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但一隻幾千萬盧幣，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "錯過果然還是很可惜……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……是啊。",
        "unit_id": 105913,
        "voice": "vo_adv_5056001_099"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n更重要的是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們在來這裡途中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就把旅費花完了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n身無分文，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "根本無法回到蘭德索爾……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_100"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "意思是我們沒有退路了吧……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們搭乘的小船沉了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看大叔那副德性，想來也不會協助我們……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_101"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊，",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_102"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我不小心在想別的事情。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這艘船……",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_103"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只有和正先生一個人搭乘吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都沒看到我們以外",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的人影，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n剛剛捕魚的人也只有和正先生──",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_104"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像是吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那又怎樣？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯──",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_105"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該怎麼說呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和正先生該不會，",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_106"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是自己獨自一人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在這麼危險的大海中捕魚吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n會不會覺得不安呢──",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿、凱留",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5056001_107"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊，",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_108"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒什麼！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總之，",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_109"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "先順從和正先生的好意，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請他載我們到城鎮去吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今後的方針，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等那之後再思考也不遲。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯，",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_110"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也是。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n到港口的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說不定也能找到可以租借的船。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的♪",
        "unit_id": 105812,
        "voice": "vo_adv_5056001_111"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要是能順帶找到餐廳，那就更好了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟餓著肚子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也沒辦法思考事情嘛☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不就說了！",
        "unit_id": 106012,
        "voice": "vo_adv_5056001_112"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們現在沒有錢啊──！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "懷著對財政狀況的不安，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}一行人仍搭乘和正的船"
    },
    {
        "type": "dialogue",
        "name": "旁白",
