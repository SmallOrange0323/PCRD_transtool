        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請對我再進行更多的強化。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我那身為唱喚士的能力若是增加越多，",
        "unit_id": 104212,
        "voice": "vo_adv_2009011_032"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n治療效果的比例也就會更加的提升。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "麻煩你了。",
        "unit_id": 104212,
        "voice": "vo_adv_2009011_033"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……其他人也一樣，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還請多加小心。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就如同牠那外貌一樣……",
        "unit_id": 104212,
        "voice": "vo_adv_2009011_034"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n不，也許這敵人，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是比想像中更加危險的魔物。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊，",
        "unit_id": 104212,
        "voice": "vo_adv_2009011_035"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是的……",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "怎麼會，發生這樣的事？",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天可是對我們來說非常重要的，",
        "unit_id": 104212,
        "voice": "vo_adv_2009011_036"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "巡演的第一天…… ",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n應該會成為最棒的一天才是的呀，{player}。",
        "unit_id": 104212
