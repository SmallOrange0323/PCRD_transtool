    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵。",
        "unit_id": 104212,
        "voice": "vo_adv_2009011_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我會進行掩護，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請大家進行戰鬥時多加小心。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "畢竟是首場的巡演呢，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果受傷了可會影響到後面的行程呢。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對我們來說可是難能可貴，",
        "unit_id": 104212,
        "voice": "vo_adv_2009011_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "且相當重要的巡演呢。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可不想留下了什麼令人後悔莫及的結果。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這我當然知道！",
        "unit_id": 102912,
        "voice": "vo_adv_2009011_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是嘛，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "光這樣看起來感覺上是隻很強的魔物呢……",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要毫髮無傷說不定有點難？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過至少嘛，",
        "unit_id": 102912,
        "voice": "vo_adv_2009011_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要拖延時間到粉絲們都避難完才行！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這才是偶像的真髓，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是身為偶像的驕傲……☆",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦咦？",
        "unit_id": 100511,
        "voice": "vo_adv_2009011_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n偶像呀，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我以為通常是不會戰鬥的耶！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呵呵。",
        "unit_id": 105412,
        "voice": "vo_adv_2009011_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們是會戰鬥的喔。",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……而且不知道是福是禍，",
        "unit_id": 105412,
        "voice": "vo_adv_2009011_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "剛好騎士先生他也在場呢。",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果能夠得到他的強化的話，",
        "unit_id": 105412,
        "voice": "vo_adv_2009011_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就是這種貨色的魔物也才不會輸呢。",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 105412,
        "voice": "vo_adv_2009011_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你還在附近對吧，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請到我們這邊來！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天呀，也得要借借你那力量了唷～♪",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哦，",
        "unit_id": 105412,
        "voice": "vo_adv_2009011_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你來了呢！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真不愧是你呢，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一眨眼就出現了！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……？",
        "unit_id": 105913,
        "voice": "vo_adv_2009011_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您那發光的棒子是為何物？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n究竟是何時買的呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_2009011_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說在替偶像加油時，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一定會揮舞著此樣物品……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔，",
        "unit_id": 105913,
        "voice": "vo_adv_2009011_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可真是不可思議的傳統呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過既然主人您也樂在其中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這點事也無傷大雅就是了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哦，",
        "unit_id": 102912,
        "voice": "vo_adv_2009011_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來了來了！　{player}！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也還買了螢光棒了呢～",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸嘿嘿。",
        "unit_id": 102912,
        "voice": "vo_adv_2009011_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那是千歌和光之精靈締下了契約，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n讓沒什麼特別的棒子也能夠成功發光出來～",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n是用上了相當高科技才做得出來的呢，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個加油道具♪",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}！\n看到您願意到這來真是令人開心，",
        "unit_id": 104212,
        "voice": "vo_adv_2009011_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是否能拜託您替我們進行強化呢？",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓所有人，",
        "unit_id": 104212,
        "voice": "vo_adv_2009011_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一塊齊心合力來打倒魔物吧。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……這是我們，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "和大家都已經期待許久的演唱會。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n那將這件事搞得一團亂的魔物，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "絕對不能夠原諒。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哦哦，",
        "unit_id": 102912,
        "voice": "vo_adv_2009011_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌竟然生氣了！ ",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真難得！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然我的心情也和妳一樣就是了呢。",
        "unit_id": 102912,
        "voice": "vo_adv_2009011_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n很好，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要全力來大鬧一場囉～♪",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒想到妳還挺好戰的呢，",
        "unit_id": 105412,
        "voice": "vo_adv_2009011_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "小望姐。",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過嘛是因為平時得裝成乖寶寶的樣子，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n所以遇到冒險或戰鬥時才反倒更起勁了嗎？",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "各位！",
        "unit_id": 103711,
        "voice": "vo_adv_2009011_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n妳們能願意一同來戰鬥真是萬分感謝，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n再怎麼說只憑我一個人實在擋不住牠！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然實在不怎麼想要讓老百姓捲入了這種危險！",
        "unit_id": 103711,
        "voice": "vo_adv_2009011_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但在【王宮騎士團】的增援趕達這裡之前，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如果能夠一同渡過這個難關就幫大忙了！",
        "unit_id": 103711
    },
    {
        "type": "still",
        "still": "200901101"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "糟糕……！",
        "unit_id": 104212,
        "voice": "vo_adv_2009011_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳還好吧？",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那邊的女孩子！",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………",
        "unit_id": 105913,
        "voice": "vo_adv_2009011_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103711,
        "voice": "vo_adv_2009011_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不妙，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "正巧砸到頭部害她昏過去了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有沒有人",
        "unit_id": 103711,
        "voice": "vo_adv_2009011_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "帶著治療藥？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n或是會使用恢復魔法的人在場的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那就更好了！",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "500582"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓、",
        "unit_id": 104212,
        "voice": "vo_adv_2009011_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓我用唱喚術來……",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊糟了，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "頭開始流血了。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我立刻進行治療！",
        "unit_id": 104212,
        "voice": "vo_adv_2009011_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n大家，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這段時間內我將會沒辦法進行防禦，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n請暫時拉開與魔物的距離只採取牽制行動就好！",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "了解！",
        "unit_id": 102912,
        "voice": "vo_adv_2009011_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒事吧，那孩子？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n好像，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聽到很不妙的聲響耶……？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果有什麼外傷的話，",
        "unit_id": 105412,
        "voice": "vo_adv_2009011_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可以做個繃帶出來進行緊急處理唷？",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不……",
        "unit_id": 104212,
        "voice": "vo_adv_2009011_030"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n幾乎沒有什麼外傷，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n大概是頭部遭受到了打擊才會因此導致她腦震盪了吧。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，{player}……",
