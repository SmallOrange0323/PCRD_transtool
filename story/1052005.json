[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好，",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "今天也打起精神採伐木材吧！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "林業林業～哼哼哼♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那些似乎誤認我是魔物的討伐隊員們……",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好像因為那個人好好地說明後，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不再接近這片森林了呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，要是這片森林裡的魔物搗亂……",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就得由我們【伊麗莎白牧場】",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n來負責處理了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為了自身的安全，這點責任得自己擔起才行呢。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "而且這片森林裡，也沒有那麼危險的魔物在。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "【哞哞自衛隊】也有派\n小鈴她們來幫忙警備。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就算發生什麼事，也不會有問題呢。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n而且到目前為止，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還非常地平靜♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "得好好感謝那個人才行呢。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "畢竟那個人如此為我著想，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n費盡辛勞替我說服討伐隊的人們。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "想跟那個人道謝呢～送點禮物好了。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "請真陽教我做料理，做做點心之類的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過人家笨手笨腳的。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n做出好吃的點心，得要特訓一下呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，\n該煩",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "惱的事就只有這點程度，實在是非常幸福呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不會有人喊『有魔物～』到處追我，\n也不",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "會遇到什麼死劫呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是這平安無事的日常能持續下去就好了。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_011"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就把這個當作目標，",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n為了不要被【伊麗莎白牧場】趕走……\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "至少自己的生活費，得自己好好賺才行。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好！\n我就持續努力採伐，把木材拿去賣吧！",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_013"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘿咻、嘿咻～♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "慢著。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不好意思，能麻煩妳不要砍倒我嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哇",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "？\n咦、咦？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n樹木說話了……！？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我並不是樹。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n……請稍等一下，現在就讓妳看我的真面目。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳好。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n初次見面。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n總之，請先稱呼我為似似花。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦……樹木，變身成女孩子了！",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這是什麼？魔法？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n幻覺？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯，是類似魔法的東西。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不過，是比平常的魔法還要高等的超自然現象。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個……\n雖然我不太懂，",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過那個魔法我也能使用嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能不能用那個魔法，變成人類的樣子？",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人、人、人家想要變成人類！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "非常可惜，這是屬於我的特有能力。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所以要為他人所用，會很困難吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "與我並列為『七冠』的其他人暫且不提……",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對於妳來說，應該是不可能的吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣啊。\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_024"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真可惜，不過沒有辦法呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "畢竟生來就是這樣，\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_025"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就算內心再怎麼像人類……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n也不能奢求像普通的女孩子一樣幸福呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……嗯。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我想如果是一時的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是有可能動用我的權能讓妳改變外表。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過這終究只是暫時的變化，有許多的規矩必須遵守。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦，真的嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_028"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n好厲害！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n那麼",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "，可以拜託妳嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "報酬我會確實給的，不過我寄居在別人家中……",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_029"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "存款不太多，不過我會努力賺的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我不需要報酬。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這個世界的金錢，在現實裡沒有任何的價值。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不然這樣吧。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_031"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我想請妳付出一點勞力，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就當作是幫妳變身的回報吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，就請妳協助我的實驗吧。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳似乎是非常稀有的存在……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我對妳非常感興趣。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "實驗？\n好、好像是很不妙的交易呢……",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_033"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "有點可怕呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這並非強制的哦。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "決定權，在於妳。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "無論是童話故事或是現實裡，引發奇蹟是需要代價的。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_035"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要人無償完成自己的要求，不是件很自私的事嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "說的也是呢……\n請讓我稍微考慮一下。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_036"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能不能告訴我，那個實驗的內容？",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_037"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我會研究內容、謹慎思考後再做出回答。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳會一直待在這片森林裡嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是的。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n正確來說，我待在森林更深處一點的實驗場……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n基本上生活在廢墟裡頭。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了避開人的耳目，我在樹上設置了結界，",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要是被砍伐就麻煩了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，所以妳才會等著打算砍樹的我呢。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_040"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我了解了，那麼妳明天也會來這裡吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可以請妳等我嗎，似似花？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "啊……",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要是沒有意外的話，我是不會離開這裡的哦。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了預防萬一，先容我說一聲。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n請妳暫且不要對任何人說遇見我的事。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_043"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "。\n感覺",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳也有自己的理由呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "請不必擔心。\n不想被不認識的人給發現，這一點我也一樣。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_044"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我是不會對任何人說關於妳的事的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我答應妳，似似花。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_045"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n雖然不太清楚怎麼回事，要是一個人煩惱很難受……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就別客氣，找姊姊商量吧♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請不要把我當小孩子。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_046"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我的年齡可和外表不同哦？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過，我相信妳哦。",
        "unit_id": 107011,
        "voice": "vo_adv_1052005_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比起人類，動物的的信用是很足夠的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我們就一起為不後悔這場相遇而努力吧。",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我回來了～……\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_048"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "又送信來牧場了呢。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_049"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘻嘻，辛苦了～♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。\n大家都辛苦了呢。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_050"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "努力工作，還有活下去都很累人♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊哈哈。\n是這樣嗎？可能是工作剛結束，所以累了吧？",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_051"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "話說回來，你看得出我的臉色嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_052"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家可和普通人類不同，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n臉色的變化應該很難看出來才對～……？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哎呀呀？\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_053"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "怎麼了？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n為什麼抱過來呢……？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為累了，所以想給軟綿綿的毛皮療癒一下？",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_054"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真是的，人家可不是什麼健康產品哦～？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過沒關係。",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_055"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真是個好孩子～……♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（唔～……對這個人來說，",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_056"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我大概只是『奇怪的動物』吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n人類女孩子不可能這麼隨便給別人抱呢。）",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（果然……\n這樣，感覺有點寂寞呢。）",
        "unit_id": 105211,
        "voice": "vo_adv_1052005_057"
    }
]