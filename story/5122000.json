    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……水",
        "unit_id": 1,
        "voice": "vo_adv_5122000_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "與空氣。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "謊言",
        "unit_id": 1,
        "voice": "vo_adv_5122000_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "與真實。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n勝利",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "與敗北。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "白",
        "unit_id": 1,
        "voice": "vo_adv_5122000_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "與黑。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n喜歡，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "與不喜歡──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "無關表裡，",
        "unit_id": 1,
        "voice": "vo_adv_5122000_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要將一切全都掀開攤在陽光下，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就一定能找到正確答案。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "究竟是從何時起，",
        "unit_id": 1,
        "voice": "vo_adv_5122000_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我不再如此相信了呢……？",
        "unit_id": 1,
        "voice": "vo_adv_5122000_005"
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "藍色的天空！",
        "unit_id": 126711,
        "voice": "vo_adv_5122000_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "藍色的大海！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "灼熱的",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "太陽！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n好的～",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "期待已久的",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "夏季度假來了──！",
        "unit_id": 126711
    },
    {
        "type": "background",
        "background": "502000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……不過，",
        "unit_id": 126811,
        "voice": "vo_adv_5122000_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來到了一個相當沒有夏季氛圍的地方呢～",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我記得大間",
        "unit_id": 126811,
        "voice": "vo_adv_5122000_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是以冬天為旺季的漁港吧……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "極低溫的驚濤駭浪，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "一片船板",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "下方即是地獄，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這種感覺吧？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然是靠著員工福利來玩的，要抱怨的話也有點那個……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎～呀，",
        "unit_id": 126711,
        "voice": "vo_adv_5122000_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你們不知道嗎？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n夢幻之魚",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「金槍鮪」",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可是一年四季！都能捕捉到的喔！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "金槍鮪？",
        "unit_id": 126811,
        "voice": "vo_adv_5122000_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是的。",
        "unit_id": 126711,
        "voice": "vo_adv_5122000_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "生魚片自然不在話下……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "內臟和皮",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只要經過加工就是極品下酒菜。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是從頭到尾都能用上的",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "超高級魚喔。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "極品下酒菜！？",
        "unit_id": 126811,
        "voice": "vo_adv_5122000_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這麼說來，",
        "unit_id": 126811,
        "voice": "vo_adv_5122000_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "下酒菜又稱為「肴」呢……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "意思是下酒的精髓",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "乃是「鮪」嗎？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "流口水……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "話說回來……",
        "unit_id": 126811,
        "voice": "vo_adv_5122000_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你們不覺得有點安靜嗎？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "難道是因為這裡不是度假的首選地點嗎？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n大間的重頭戲在冬天……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這種感覺？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哦～呵呵呵♪",
        "unit_id": 126711,
        "voice": "vo_adv_5122000_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這樣比起人山人海的海邊",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "更能好好放鬆呢！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真正的度假，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就是享受美食呢。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好了，",
        "unit_id": 126711,
        "voice": "vo_adv_5122000_016"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們來徹底享受",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "大間這個地方的食宿吧！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好耶──！！",
        "unit_id": 126811,
        "voice": "vo_adv_5122000_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──那邊幾位，不好意思。",
        "unit_id": 1,
        "voice": "vo_adv_5122000_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n能請你們稍微安靜一點嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優花梨、秋乃",
        "words": "……？",
        "unit_id": 1,
        "voice": "vo_adv_5122000_019"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "因為我的主人",
        "unit_id": 191011,
        "voice": "vo_adv_5122000_020"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不喜歡吵吵鬧鬧的。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 126611,
        "voice": "vo_adv_5122000_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "受不了，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這裡不管什麼時候來……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n都能立刻讓",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想在這裡靜靜度過的期待破滅呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "優花梨、秋乃",
        "words": "──似似花！",
        "unit_id": 1,
        "voice": "vo_adv_5122000_022"
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真的是好巧喔～",
        "unit_id": 126811,
        "voice": "vo_adv_5122000_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n似似花你們竟然也來美食度假。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "看來金槍鮪果真",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是如此美味嗎？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……是會讓人為此而特別造訪的程度。",
        "unit_id": 126611,
        "voice": "vo_adv_5122000_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但要是知道會跟你們撞行程，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就不來了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哇，",
        "unit_id": 126811,
        "voice": "vo_adv_5122000_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "似似花回答得好辛辣喔。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n咦，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "難道說，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳也是愛喝烈酒的人嗎？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "優花梨，",
        "unit_id": 126711,
        "voice": "vo_adv_5122000_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這個話題引導太強硬了。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n不管什麼事都要跟麥酒扯上關係",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可不好喔。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳看，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "似似花也感到很困惑。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是失禮了，",
        "unit_id": 126711,
        "voice": "vo_adv_5122000_027"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "似似花。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我至今為止",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不太有什麼機會與妳共事，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但是耳聞了不少關於妳的事。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "例如妳是位非常優秀的研究者。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦，",
        "unit_id": 126811,
        "voice": "vo_adv_5122000_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是這樣嗎？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這也就是說……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "三個繁忙的商業女孩",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "齊聚在度假勝地呢～！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那麼那麼，",
        "unit_id": 126811,
        "voice": "vo_adv_5122000_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "機會難得，我們要不要來好好聊聊天呢？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "邊吃美食邊聊天～",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "把工作上累積的壓力和疲勞",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "全都釋放掉～！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
