[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這邊請。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請留意您的周遭環境，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要在下拉您一把嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人請不用客氣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓身為『嚮導』的在下來引導您吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。蘭德索爾是一座錯綜複雜的城鎮喔。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一不小心就有可能迷路。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下完全沒辦法適應這種人多的地方……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉呀，抱歉主人。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "借了您的身體支撐一下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下剛剛撞到路人，差點跌倒了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，謝謝您的幫助。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會更加注意的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱歉。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下走路的時候不該東張西望的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是這裡的每件事物都那麼稀奇，讓在下深感興趣呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不行的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n引導主人是在下的使命。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下並非來遊山玩水的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "必須時常對周圍保持警戒，伴隨在您身邊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n沒想到主人會關心在下，主人很溫柔呢♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，那個……",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下並非小孩子。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自己也可以走，請您不用擔心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然要讓主人來背在下。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "光是用想的，在下就覺得誠惶誠恐……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總而言之。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓我們按照計畫先將生活用品買齊吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蘭德索爾的物價很高。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然手邊剩下的錢不是很樂觀……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但只要是主人想要的東西，在下都會買給您。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人因為喪失記憶，什麼都不明白呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "首先應該讓在下從貨幣的概念來為您說明。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個是錢。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n拿這個做為交換，可以獲得商店裡的商品。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n錢有分為硬幣和紙鈔，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，主人。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請不要把紙鈔含在嘴裡，那不是吃的東西。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您吐出來。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人有時候很像小嬰兒呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "紙鈔可是有很多人用手碰過的……",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很不衛生喔，所以不可以把它放到嘴巴裡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您稍等。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……嚼啊嚼。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下把這個藥草用嘴嚼碎後拿去煎了。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在讓在下用濕棉花來為您擦嘴巴。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這可以達到消毒功效，……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您不要亂動。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咯哧咯哧……",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，擦乾淨了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然會把錢放到嘴巴裡，想必主人是餓了吧。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在我們買東西前，先去吃飯吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們今晚投宿的旅館就在附近，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下記得旅館裡也有廚房呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們買好食材，讓在下來做飯吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自己下廚經濟又實惠喔。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且這座城鎮的餐廳似乎都加了很多添加物……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下擔心主人的健康。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以想好好地控管營養均衡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人有什麼想要吃的東西嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下正在研究食譜，努力地學習做飯。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下一定會竭盡所能來滿足您。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "夫人唷、那邊的夫人，今天的魚很便宜唷！",
        "unit_id": 1411,
        "voice": "vo_adv_1059001_026"
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "\n要不要買幾條帶回去呢？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "欸？",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那個，是叫在下嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "夫、夫人……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下是主人的隨從。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絕對不是什麼夫人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下看起來像是主人的夫人嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人是在下的老爺啊……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "夫人唷，這魚可是當季的呢！",
        "unit_id": 1411,
        "voice": "vo_adv_1059001_030"
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "\n拿來做今天的晚飯如何？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "\n您家老爺肯定會很高興的喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人會很高興？",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那樣的話，那邊的魚在下要了……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "喔喔，您真識貨呢！",
        "unit_id": 1411,
        "voice": "vo_adv_1059001_032"
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "這邊的您看如何？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "\n瞧您充滿幹勁，夫人♪",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好，這邊的也要了。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那邊的也買了……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……呼。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼了嗎，主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n咦，您說買那麼多也吃不完？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您、",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說得是呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下一定是哪裡不對勁了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下在書上有讀過。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這種店的人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都是稱呼女性顧客為夫人呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下和主人看起來也不像夫妻。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是當然。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……那邊的魚在下也要了？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "多謝啦！",
        "unit_id": 1411,
        "voice": "vo_adv_1059001_039"
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "\n感謝您的光顧，夫人！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059001_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n嘻、嘻嘻……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結果他們買了一堆吃不完的魚，\n而大部分的魚都放到酸臭腐敗了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然而，\n不知為何，可可蘿的心情愉快不已。"
    }
]