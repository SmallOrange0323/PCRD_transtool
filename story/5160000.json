[
    {
        "type": "background",
        "background": "502080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在貪吃佩可等人與各世界的公主們加深情誼之中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n吉歐‧格黑納緊接在吉歐‧提格尼亞後頭，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n也與蘭德索爾開始建交了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "到了年底，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在吉歐‧格黑納為紀念兩國建交，決定盛大舉辦交流祭，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n介紹蘭德索爾新年的例行活動。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "吉歐‧格黑納……",
        "unit_id": 133512,
        "voice": "vo_adv_5160000_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我沒有知道得很詳細，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但這裡真的好熱喔～",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和隆冬的蘭德索爾溫差太大，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺會因此感冒啊。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有……",
        "unit_id": 133512,
        "voice": "vo_adv_5160000_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "魔物的氣息也好強烈，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就像是將野生表露無遺的感覺。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "跟氣氛悠閒的吉歐‧提格尼亞完全相反呢。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能在如此嚴峻的世界裡生存，",
        "unit_id": 133512,
        "voice": "vo_adv_5160000_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "打造自己的生活。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想此地的大家",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一定都是堅強",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "又出色的人吧。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "厲害，",
        "unit_id": 133212,
        "voice": "vo_adv_5160000_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不愧是【王宮騎士團】副團長，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n觀察力令人欽佩。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是「前」",
        "unit_id": 133512,
        "voice": "vo_adv_5160000_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "副團長啦。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n本來應該是由純出面的，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過年關將近，團長總不能丟下國家就跑出來。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以，",
        "unit_id": 133512,
        "voice": "vo_adv_5160000_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我今天是純的代理人。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我跟{player}認識，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n因此請我來擔任幫手。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒想到",
        "unit_id": 133512,
        "voice": "vo_adv_5160000_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會擔任團長的代理人……",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這工作若能順利進行，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就能在吉歐‧格黑納做生意，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以我可是有卯足幹勁要做了喔。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 133512,
        "voice": "vo_adv_5160000_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "理所當然，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n【王宮騎士團】也派了好幾個人來幫忙喔？",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這次活動規模很大，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以就派來幫忙順道當警衛",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呢。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "果真可靠啊。",
        "unit_id": 133212,
        "voice": "vo_adv_5160000_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是的，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們公會的成員都無故避掉這個難得的委託，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n真想讓她們聽聽妳說的這些話。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "誰叫大家都很忙嘛。",
        "unit_id": 133512,
        "voice": "vo_adv_5160000_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n對我來說，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "光是有莫妮卡來幫忙，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就令人十分安心了喔。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒什麼，",
        "unit_id": 133212,
        "voice": "vo_adv_5160000_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是軍人應盡的職責。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n況且……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還讓妳替我訂製這麼漂亮的和服，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "該道謝的人是我才對！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哈哈哈，",
        "unit_id": 133512,
        "voice": "vo_adv_5160000_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳才是",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不必掛在心上啦。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟是要宣傳蘭德索爾的新年，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算多少昂貴了點，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n和服",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "果然還是必選項目吧？",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，",
        "unit_id": 133212,
        "voice": "vo_adv_5160000_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "判斷力令人佩服。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這次的交流祭是新年，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "果然還是希望華麗一點。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看到妳的打扮，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "相信那傢伙也會很高興啊。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這、",
        "unit_id": 133512,
        "voice": "vo_adv_5160000_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這跟那傢伙",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "又沒關係……",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話說回來，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那傢伙",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會不會太慢了？",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "都說要來接我們了……",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "太慢了。",
        "unit_id": 133512,
        "voice": "vo_adv_5160000_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你好歹也是蘭德索爾的代表耶，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不可以遲到啦。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哎呀，好了啦。",
        "unit_id": 133212,
        "voice": "vo_adv_5160000_015"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "話說回來，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看到我們這身打扮，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n你是不是該說點什麼呀？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……這樣啊，",
        "unit_id": 133512,
        "voice": "vo_adv_5160000_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想搬物資，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "請立刻",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "替我帶路吧。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呵呵，",
        "unit_id": 133212,
        "voice": "vo_adv_5160000_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳看起來很高興呢，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咲戀。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不過，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也懂這種高興啦。",
        "unit_id": 133212
    },
    {
        "type": "background",
        "background": "502114"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "來自蘭德索爾的各位～",
        "unit_id": 51611,
        "voice": "vo_adv_5160000_018"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "歡迎蒞臨吉歐‧格黑納～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我是本次交流事業的負責人，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "名叫米亞～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "還請各位多多指教～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "初次見面妳好，",
        "unit_id": 133512,
        "voice": "vo_adv_5160000_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我是",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【王宮騎士團】\n團長代理人的咲戀。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這位是",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【純白之翼 蘭德索爾分部】",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n公會長的莫妮卡。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我是承蒙介紹的",
        "unit_id": 133212,
        "voice": "vo_adv_5160000_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "莫妮卡。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n聽說吉歐‧格黑納的魔物很多，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我對自己身手很有信心。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "若需要人手幫忙，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "盡管吩咐，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "無須把我當小孩子看待。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "呵呵～",
        "unit_id": 51611,
        "voice": "vo_adv_5160000_021"
    },
    {
        "type": "dialogue",
