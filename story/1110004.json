    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是做為學者時最致命的就是會自顧自地講得天花亂墜……",
        "unit_id": 111031
