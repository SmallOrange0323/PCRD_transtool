    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是我們的研究論文，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "終於面臨重要的轉機了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
