    {
        "type": "dialogue",
        "name": "優妮",
        "words": "附近進行考古學，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "立足於更為宏觀的觀點之必要性已浮上了檯面。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想分類會橫跨歷史學、",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "人類學，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "乃至於哲學，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "只是或許古板的保守派，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "會將其稱之為宗教學吧。",
        "unit_id": 111011
    },
