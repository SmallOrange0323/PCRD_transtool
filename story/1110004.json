        "name": "由仁",
        "words": "嗯。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "然後，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "再來是……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊，",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_030"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "是上課用的話，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "要寫報告吧？",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "那樣的話，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我幫你在不能漏看的重點上貼上便利貼吧。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n我可以坐這裡嗎？　",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我移一下你的包包哦？",
        "unit_id": 111031
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510050"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "…………",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_031"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "……嗯，我想，",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_032"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "大概這樣就差不多了吧。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊……",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_033"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n總覺得",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "真抱歉呢？　",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "結果幫你",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "貼了滿滿的便利貼。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我突然就這樣冒出來，然後自顧自地講了一大堆呢。",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_034"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊，好害羞啊……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我的臉都熱起來了……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "因為我的本性",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_035"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "基本上是家裡蹲，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "所以根本也都沒有朋友，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n偶爾有機會和人說話時，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "就會開啟奇怪的開關。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "如果說的是我喜歡的領域那就會更……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "今天午休時，星野同學她",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_036"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "——啊，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "她是班上一位非常漂亮的女孩子，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "——她又向我搭話了，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "但結果",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我卻一直在聊自己\n喜歡的書……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我記得",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "本來應該",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "在聊她弟弟的事……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "對，",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_037"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "所以對{player}也一樣，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "抱歉啊？",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n因為我第一次遇到在現實中",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "讀我爺爺寫的書的人，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "與其說是感激，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "總之一不小心就心花怒放了……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "唉唷真是的，真的很抱歉哦？",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_038"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n嚇到你了吧？　",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我這人很莫名其妙對吧？",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊，",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_039"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "真的嗎！？",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "太好了，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "那其他的書我也順便——",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "——不對，等一下啊我。",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_040"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n把這種客套話全部都當真的話可不太好呀我。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "唉……",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_041"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我真沒用啊……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n這社會真是難啊，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "不管是表面的或是私底下的。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "沒有啦……",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_042"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "只是我",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "昨天在玩線上遊戲的時候也搞砸了。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n雖然遊戲裡的好友",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "都要我不用太在意……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "唉～",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "總覺得很對不起他們，想上線也覺得很尷尬呢……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "咦？　",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_043"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "玩家ID？　",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "你是問",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我的嗎？",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "嗯……",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_044"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "告訴你",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "是也沒關係啦……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "咦？",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_045"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "你的意思該不會是……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n講白一點，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "你是想要加我好友嗎？",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊……",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_046"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "……嘿嘿嘿。",
        "unit_id": 111031,
        "voice": "vo_adv_1110004_047"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1110004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看到的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1110004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n話雖如此，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正你醒來就會忘記了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以現在不用太在意唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不用多久，",
        "unit_id": 190011,
        "voice": "vo_adv_1110004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你和優妮",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就會在「象牙之塔」中原本的地方醒過來了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "優妮是學者型的人，",
        "unit_id": 190011,
        "voice": "vo_adv_1110004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以或許不會像其他人一樣說句「什麼嘛是夢啊！」就算了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說不定會因為太難以理解，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而讓她的求知心蠢蠢欲動呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過很可惜的是，",
        "unit_id": 190011,
        "voice": "vo_adv_1110004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這場「夢」不會留在記憶裡。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也無法留下記錄，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也不能進行考察與驗證。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是世界的虛構……",
        "unit_id": 190011,
        "voice": "vo_adv_1110004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n優妮說的那個研究主題。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然不想掃她的興，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但那件事終究也是徒勞無功。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她和",
        "unit_id": 190011,
        "voice": "vo_adv_1110004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "其他各個賢者都一樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是沒辦法對這個世界持續抱有疑問下去的呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你問為什麼？",
        "unit_id": 190011,
        "voice": "vo_adv_1110004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那是因為現在這個世界就是這樣構築的呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這世界上可是有著不論多麼聰明，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也依舊無法掌握的真理在呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是……",
        "unit_id": 190011,
        "voice": "vo_adv_1110004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "優妮，",
        "unit_id": 190011,
        "voice": "vo_adv_1110004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她先前有這麼說過吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n說過程比結果更加重要。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n說「去知道」的這件事本身才是目的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若是如此，",
        "unit_id": 190011,
        "voice": "vo_adv_1110004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼對她來說這就是段有意義的時光了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以我",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這麼輕率地就說人家是徒勞無功，似乎也不太好呢……",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500960"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呼啊～",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_059"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊呼……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "早安啊世界，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_060"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你今天依舊是個大騙子呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗨，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_061"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學弟也是。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你好像醒了呢，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "做了個美夢了嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_062"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你說你不記得了？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想也是。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為我也是喔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "似乎像是碰觸到了那宏遠之真實的一隅的感覺……",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_063"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "又像是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "窺視到了壯大的幕間中的一條細縫的感覺……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_064"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "想作筆記也無從作起……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n徒留這難以訴諸言語的見聞之餘韻，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "著實令人感到奇妙。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然而，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_065"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "幸好還記得「我不記得」這件事。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這種不尋常的體驗，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在得要提出假說時或多或少能稍微提高說服力。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "現在我的可是非常亢奮呢，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呀呵～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼同志呀，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_066"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們就重新再來一遍，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "繼續剛才被中斷的話題吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n新的題目是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「盤據在這世界上的——」",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "奇怪？　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是什麼來著？　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我怎麼又忘了……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想想，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_067"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "該怎麼辦。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "對了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "總之看一下筆記……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_068"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒錯，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「盤據在這世界上的根源性虛構」，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是這個。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "對，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_069"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是這個啦，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就是這個讓人很不舒服的忘卻現象。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個世界，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_070"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "經常以妨礙認知的形式對我們進行著影響。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "而此刻，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也正代表這個世界對我們撒了一個相當大的謊言——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "——而這件事，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_071"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "便是我所提出來的大膽又嶄新的假設。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "怎麼樣呢同志？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你能不能來幫助我撰寫論文呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想也是。",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_072"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真相未必保證會帶來幸福。",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_073"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "維持著未知的現況也是其中的一種選擇吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不是，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_074"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就算你對研究沒興趣也不要緊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "打從一開始，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我希望能從你身上得到的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就並非是實際的幫助。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "只是",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_075"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "希望你偶爾",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "能像這樣陪我閒聊就行了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "現在想想，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我下了「山」來到「街上」，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是因為我對聽聞中的學園生活那種事很感興趣。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_076"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也就是說啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_077"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是我也想要交朋友。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "當然我不勉強你，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_078"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你怎麼想呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "咦？",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_079"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_080"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是這樣子啊……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這就是友情……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "似乎不是很特別的東西呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？　",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_081"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那就是說？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我已經開始青春了……？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……什麼嘛，",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_082"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以這一陣子的我，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "才會每天都感到如此充實啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優妮對這股第一次的察覺感慨萬千，\n於是{player}也微笑著對她點了點頭。"
    }
]