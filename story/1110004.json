    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是這個咚～！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「盤據在這世界上的根源性虛構｣！",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦？　",
        "unit_id": 111011,
        "voice": "vo_adv_1110004_007"
    },
