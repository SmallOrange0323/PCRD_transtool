[
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在幫忙完搗年糕之後，\n便陪伴優衣一同前往了神殿。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "抱歉呢，騎士先生。",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不只是讓你幫忙搗年糕，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n連跑腿也讓你陪我一起過來了。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳拿些年糕去分給神殿的人們吧──",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不僅我的父母這麼講，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我一開始也是這麼打算的……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但是要我一個人到這邊來，",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還是會稍微有一點不安，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以你願意陪我來，真的很謝謝你。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣啊。",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說的也是呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎士先生幫忙揉年糕，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也是揉的很賣力的嘛。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "果然",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "元旦也來參拜的人還是很多呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "司祭大人，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在哪裡呢……？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在那！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "司祭大人，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "您好！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "哦哦，",
        "unit_id": 511,
        "voice": "vo_adv_1088003_006"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "優衣呀。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "妳好啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "到這有什麼要事嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個，",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是我們家做的年糕。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "請您分給大家一起享用吧。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "哎呀哎呀這還真是，",
        "unit_id": 511,
        "voice": "vo_adv_1088003_008"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "非常謝謝妳。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "讓妳親自跑了這一趟，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "不好意思呀。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這點小事，請您別在意。",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想各位元旦應該還很忙，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以我們就在這先告辭了……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "妳這麼顧慮我們，真是非常感激。",
        "unit_id": 511,
        "voice": "vo_adv_1088003_010"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "但既然都來一趟了，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n回去之前，請務必去參拜一下吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好的。",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一定會去的。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n那麼我們先告辭了。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生。",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們也去排隊吧。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎士先生，",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你準備許什麼願望呢？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那我也和你一樣保密好了。",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "輪到我們參拜了唷。",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n零錢，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你準備好了嗎？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "數一、二後一起丟吧？",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一、二！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嘿！",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "希望和騎士先生，",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "能夠更加親近友好……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好痛！",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有什麼東西砸到頭了……",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哇呀！？　",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒、",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒什麼事！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "背後有個冰冰的小東西掉進來了……！",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個是，",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "後頭的人丟的零錢嗎！？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼辦呀，騎士先生！",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n好像有誰的零錢，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "扔到我的和服裡面了……！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦！？",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生你嗎！？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n可、",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可是……！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生！？",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你那手是準備要幹嘛！？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "等等等，",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "等一下！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個呀！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n如果在這裡讓你拿的話，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "會很不好意思的！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但是……",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果要把零錢拿出來的話，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不是得把和服脫掉，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n就是得讓誰來幫忙拿才行呢……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果把和服脫了，",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就不得不再重新穿好一次……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……這也是、",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒辦法的嘛？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "已經不是在這不好意思的、",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "時候了對吧……！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎士先生！",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "果然還是拜託你幫我把它拿出來吧？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那、",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那就拜託你了……！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊！",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_034"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生的手，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "從領子慢慢伸進來了……！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咿呀！",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "再稍微慢一點！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n很、",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "很癢的呀……！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_036"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不行！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果碰到那裡的話……！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚欸！？",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_037"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的嗎……？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚……！",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_038"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "快點！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "快點拿出來吧！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊……",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_039"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "拿、",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "拿出來了？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是太好了……",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_040"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝你喔，騎士先生，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_041"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛剛就只想著要趕緊把東西拿出來，所以沒有注意到，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n旁邊好像有騷動……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是發生什麼事情了嗎？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "警衛──！",
        "unit_id": 411,
        "voice": "vo_adv_1088003_042"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "這個人是色狼啊──！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "我也看到了！",
        "unit_id": 1211,
        "voice": "vo_adv_1088003_043"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "他把手伸進那個女孩子的和服裡面，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n硬是毛手毛腳！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦咦咦咦咦！？",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_044"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不是！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不是這樣的！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎士先生他，只是為了要幫我所以才會……！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這位先生，",
        "unit_id": 711,
        "voice": "vo_adv_1088003_045"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "麻煩你跟我們到據點走一趟吧？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊啊，",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_046"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生要被帶走了呀！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "您誤會了！",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_047"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "他並不是什麼色狼！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不要把騎士先生帶走啊──！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……這話，",
        "unit_id": 711,
        "voice": "vo_adv_1088003_048"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是真的吧？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳沒有被他威脅吧？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生是絕對不會做這種事情的！",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_049"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "他總是很溫柔，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛才也只是替我把掉進來的零錢，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n從裡面拿出來了而已！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……明白了。",
        "unit_id": 711,
        "voice": "vo_adv_1088003_050"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我相信妳。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n然而，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "若下次又發生了相同的事，請到據點來尋求幫助。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "知道了嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好的……",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_051"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的是非常抱歉。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是太好了～",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_052"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛才那樣繼續下去，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n還以為騎士先生就要因冤罪被人給抓走了呀……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "什麼嘛～",
        "unit_id": 411,
        "voice": "vo_adv_1088003_053"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "原來不是色狼是男朋友啊～",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "大過年的就打的這麼火熱……",
        "unit_id": 1211,
        "voice": "vo_adv_1088003_054"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "真希望情侶全都原地爆炸啊。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "啊～啊，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "果然我也趕緊去許個願希望能找到一個好對象好了～",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……不、",
        "unit_id": 108811,
        "voice": "vo_adv_1088003_055"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不是的！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我和騎士先生並不是這樣的關係……！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不是這樣的～！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優衣雖然替{player}澄清了他是無罪的，\n然而新產生的誤解，直到離開神殿為止都還洗不清。"
    }
