[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "帆稀小姐美麗的地方，",
        "unit_id": 126311,
        "voice": "vo_adv_5120077_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她陰險的部分吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這當然是在稱讚她喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不隨意展露自己的內心，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "靜靜地抓住對手的破綻，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "慢慢緊咬住對方的手段非常高明呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過那同時",
        "unit_id": 126311,
        "voice": "vo_adv_5120077_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也是她的缺點吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很恐怖啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n感覺比粗魯又殘暴的壞人",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還要恐怖多了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然她是很有魅力的人，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是跟她相處時要很謹慎呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嘉夜小姐美麗的地方，",
        "unit_id": 126311,
        "voice": "vo_adv_5120077_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是她那好戰的個性吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她隨時都想要打架的心態，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然讓人難以理解，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n但是那率直過頭的熱情，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可以說是種純粹的美呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過",
        "unit_id": 126311,
        "voice": "vo_adv_5120077_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我是不太希望",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她跟粗魯的事情扯上關係就是了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她有著端正的五官",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "跟勻稱的身材，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看到美麗的人受傷，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會讓我很心痛啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "祈梨的美",
        "unit_id": 126311,
        "voice": "vo_adv_5120077_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是蘊藏在那嬌小身體裡的能量吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她不只有著龍人族特有的力量，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還有著想要在組織中向上攀升的野心。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得她有著有朝一日會成大事的可能性呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 126311,
        "voice": "vo_adv_5120077_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為現在是膽小的部分展露得比較多，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以還有很長的路要走呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "膽小屬性的吉祥物角色",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這種定位也不錯，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n視情況，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "轉而朝向這方面發展",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "說不定也是可行的吧。",
        "unit_id": 126311
    }
]