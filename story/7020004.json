[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人朝著塔頂邁進，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而，魔物的追擊卻絲毫沒有停歇。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你們",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "未免也太纏人了喵！",
        "unit_id": 104611
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "既然要",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "襲擊我們，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好歹也帶著\n鯛魚燒的材料過來吧喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？",
        "unit_id": 103311,
        "voice": "vo_adv_7020004_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這隻魔物身上",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好像有什麼。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這是……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "堅果？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就、",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就是這個喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "靈感來了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n用這個",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "應該可以做出好吃的鯛魚燒喵──！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……嗯，",
        "unit_id": 103311,
        "voice": "vo_adv_7020004_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "聽起來是比魔物鯛魚燒",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "更可以安心享用。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "──完成了喵！",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "特製堅果內餡鯛魚燒喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "來來，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "大家快趁熱吃喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "太好了喵！",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我並沒有看走眼喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真陽，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳覺得如何喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，",
        "unit_id": 103311,
        "voice": "vo_adv_7020004_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "的確很好吃啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "若要說有沒有達到\n小希希所追求的極致，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我倒覺得還差了點。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呃，",
        "unit_id": 103311,
        "voice": "vo_adv_7020004_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "明明我",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對鯛魚燒一竅不通，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n卻說了這麼臭屁的話，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對不起，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小希希。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不，",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真陽沒有說錯喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不愧是能生產出那頂級牛奶的牧場主人。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳的這番話，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "深深打動了我的心喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果在這裡妥協，",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "極致鯛魚燒就只是個遙不可及的夢想喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "既然有會掉落堅果的魔物，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "說不定也有\n會掉落砂糖或紅豆的魔物喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們沒時間在這種地方發呆了喵！",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n走吧喵、走吧喵、走吧喵──！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個不受拘束、只管橫衝直撞的傻蛋……",
        "unit_id": 103311,
        "voice": "vo_adv_7020004_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小希希身上",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "果然有著我所追求的某種特質的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 103311,
        "voice": "vo_adv_7020004_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在可不是發呆的時候。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我們也趕緊追上去！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯～",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "海鮮類鯛魚燒、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "蔬菜類鯛魚燒，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還有藥草類鯛魚燒。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然順手試做了這幾款口味，",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n但還稱不上是極致的鯛魚燒喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我不需要半吊子的美味喵。",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我的目標是做出在一口咬下的瞬間，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "彷彿就有光從嘴裡綻放出來的鯛魚燒喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小希希，",
        "unit_id": 103311,
        "voice": "vo_adv_7020004_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳真有幹勁。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我也不會輸的……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你有聽到什麼聲音嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是、",
        "unit_id": 103311,
        "voice": "vo_adv_7020004_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是一大群魔物！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牠們怎麼會突然……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難道是",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "被大量試作鯛魚燒的香味",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "給吸引過來的！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎、",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼會這樣喵……！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "對不起喵，真陽。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "都是因為我……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "用不著放在心上啦。",
        "unit_id": 103311,
        "voice": "vo_adv_7020004_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n在搭檔出差錯時給予協助，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這才是真正的組合。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "無論是",
        "unit_id": 103311,
        "voice": "vo_adv_7020004_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "搞笑還是冒險都一樣啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以，妳可以儘管",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "倚賴我喔。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真陽……",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "感激不盡喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，就讓牠們瞧瞧",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們兩人的力量喵！",
        "unit_id": 104611
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "太好了，",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們辦到了喵──！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "打倒那一大群魔物了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看來我們",
        "unit_id": 103311,
        "voice": "vo_adv_7020004_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "果然會是默契十足的組合呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "除了公會的夥伴外，",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "想不到還有人可以跟我如此契合喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在找尋食材上，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "果然很需要真陽的力量喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然還不知道小希希會不會成為我的搭檔，",
        "unit_id": 103311,
        "voice": "vo_adv_7020004_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我有預感，只要我們兩人同心合作，一切都會很順利的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那麼，",
        "unit_id": 103311,
        "voice": "vo_adv_7020004_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們走啦，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小希希。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就是說啊喵，",
        "unit_id": 104611,
        "voice": "vo_adv_7020004_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真陽。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
