[
    {
        "type": "background",
        "background": "510460"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……這還不夠完美呢。",
        "unit_id": 107331,
        "voice": "vo_adv_5201074_000"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "牙齒再長一點，",
        "unit_id": 107331,
        "voice": "vo_adv_5201074_001"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "爪子加上毒性，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "眼睛能發射石化光線，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n一根尾巴不夠改成三根，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "能獨自行動加上攻擊複數目標。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "體力的數值也太低了，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "這樣打起來不過癮。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "弱點屬性？",
        "unit_id": 107331,
        "voice": "vo_adv_5201074_002"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "什麼軟弱的設計……",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "不過，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "要他人配合我的基準或許很困難呢。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n那就設計為物理以外",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "減半的程度吧。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "這樣的話，",
        "unit_id": 107331,
        "voice": "vo_adv_5201074_003"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "各項能力值",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "就可以再拉高一點了呢。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "為了給戰鬥帶來緊張感，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n調整為能夠打很久的數值吧。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "所以。",
        "unit_id": 106931,
        "voice": "vo_adv_5201074_004"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "這種魔物誰能打得倒？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……有什麼意見嗎，",
        "unit_id": 107331,
        "voice": "vo_adv_5201074_005"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "真那。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n你在妨礙我工作，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "給我離開。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "妨礙工作的人是你啊。",
        "unit_id": 106931,
        "voice": "vo_adv_5201074_006"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我才在想為什麼我調整好的魔物戰鬥難度，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n怎麼會一個個都被調整成劣作等級了。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "劣作？",
        "unit_id": 107331,
        "voice": "vo_adv_5201074_007"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "這話我可不能當作沒聽見呢。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n最能夠理解戰鬥樂趣的人",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "毫無疑問是我本人。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "而我正在",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "親自幫忙調整喔？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "烏帕魯帕",
        "unit_id": 106931,
        "voice": "vo_adv_5201074_008"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "用眼睛都看不到的速度噴出毒素了呢。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "沒錯。",
        "unit_id": 107331,
        "voice": "vo_adv_5201074_009"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "外表看來遲鈍卻能使出",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "高速的一擊。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n想必能給玩家",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "戰鬥不能只看外表的教訓。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "那麼遠距離攻擊為什麼變得打不中洞窟蝙蝠了？",
        "unit_id": 106931,
        "voice": "vo_adv_5201074_010"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "會飛的魔物怎麼可能不戒備空中攻擊。",
        "unit_id": 107331,
        "voice": "vo_adv_5201074_011"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "作為戰士，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "就該擁有能夠照樣痛扁飛行對手的能力。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "你還給軟泥怪",
        "unit_id": 106931,
        "voice": "vo_adv_5201074_012"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "追加了新的攻擊方法對吧？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "是啊，",
        "unit_id": 107331,
        "voice": "vo_adv_5201074_013"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "是窒息攻擊呢。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "很難應付對吧。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "誰叫牠不知道為什麼只設定了衝撞這招，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我就按照牠的生態",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "追加了合理的攻擊方法。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……唉。",
        "unit_id": 106931,
        "voice": "vo_adv_5201074_014"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我不明白。",
        "unit_id": 107331,
        "voice": "vo_adv_5201074_015"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n到底",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "是哪裡讓你覺得不滿？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "大概是你",
        "unit_id": 106931,
        "voice": "vo_adv_5201074_016"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "缺乏常人感性",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "的部分吧。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……竟然",
        "unit_id": 107331,
        "voice": "vo_adv_5201074_017"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "會被你批評沒有常人感性……",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "總之，",
        "unit_id": 106931,
        "voice": "vo_adv_5201074_018"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "關於戰鬥調整的部分，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "請你不要再去動了。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我明明已經設計得這麼簡單了……",
        "unit_id": 107331,
        "voice": "vo_adv_5201074_019"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "無法理解……",
        "unit_id": 107331
    }
]