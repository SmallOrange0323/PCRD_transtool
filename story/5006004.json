[
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總之。",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n光以戰鬥力來看，這些傢伙也沒多厲害，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還算容易壓制的呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那倒是……",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我們合力",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "用手銬跟繩索把那些暴動的傢伙綁住吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "即使用一般的方法無法除掉他們，",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只要制約了行動，就不會造成威脅了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "咦～……",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我還想大開殺戒呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "現在已經不是那種時代了喲，",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "克莉絲。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯～。",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還不知道這些傢伙真正的身分……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但我總算知道最近",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n其他團員疏遠我的原因了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我不記得",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我有做出什麼會讓人疏遠我的事情。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也許",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這些傢伙……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n偽裝成我，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對其他團員做了什麼事？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "說不定像現在這樣，",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "無緣無故的就攻擊人也說不定。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而且連外貌都一模一樣，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "一般很難立刻發現是冒牌貨。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小智他們應該",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是把這個冒牌貨當成是我了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n一定是這樣的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "什～麼嘛……",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n謎團好像被解開了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但實際上也沒解決任何事啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你在說什麼呀？",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然不是很清楚……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你看起來還是很嚴肅，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n卻抱著少女的煩惱呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "團長就是",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這種地方",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可愛呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦……",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n可愛這種話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我還是生來第一次聽到。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我是在諷刺的說。",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "突然出現一個好主意。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "團長。",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n什麼事，克莉絲？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "去死死死死死……☆",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_016"
    },
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呀啊……",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n很危險耶，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎麼突然這樣？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為何突然往這邊砍？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈！　",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "被躲開了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n失禮了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為一堆長得一樣的人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不小心弄錯了呀！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "咦～",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哪個是真正的團長呀？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都搞不清楚了啦！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊，",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是這傢伙吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是冒牌貨呀，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看招看招♪",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哇，",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哇……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "住手！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我是本尊啦，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "冒牌在那裡！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈！　",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "每個冒牌貨都會這麼說的！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果真的是本尊，就證明給我看，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要把頭砍了之後就分得出真假了呢！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果沒死就是冒牌貨，",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "死了就是本尊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n啊哈哈哈哈哈……☆",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "危險危險，",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "住手呀克莉絲！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n現在可不是玩的時機！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n克莉絲那麼聰明應該分得出來吧，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我是正牌的純啊！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "咦～？　",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你說什麼？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "刀劍的聲音太大聲，我聽不到你說話呀♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗚哇……",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "克莉絲的壞習慣又跑出來了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為什麼那麼愛開這種玩笑？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也不知道為什麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但應該是為了什麼事才想找我戰鬥吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "利用現在這個狀況，",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "來找我比試的吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但我可沒時間管他，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "更不是這種時候……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n該、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "該怎麼做呢，少年？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗚嗚……",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果那樣就行得通的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也不會那麼辛苦。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊啊但是，",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "說服的方法……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n太棒了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "想到好對策囉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦，",
        "unit_id": 104711,
        "voice": "vo_adv_5006004_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為什麼？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊啊……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來如此，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來是這麼一回事！",
        "unit_id": 104711
    },
    {
        "type": "still",
        "still": "500600401"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "克莉絲！",
        "unit_id": 104713,
        "voice": "vo_adv_5006004_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你看，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我脫下頭盔囉！",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "冒牌貨的",
        "unit_id": 104713,
        "voice": "vo_adv_5006004_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "頭盔跟鎧甲裡都是空洞的對吧？",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就像你看到的，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我有臉，所以是正牌的喲！",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈！　",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還真拼命呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "團長！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n平常明明那麼討厭被看到真面目！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真的很討厭嘛，",
        "unit_id": 104713,
        "voice": "vo_adv_5006004_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為很丟臉呀……",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也想不到其他方法了。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真笨拙呢！",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我就是喜歡你那一面，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n害我更想跟你冒死奮戰了呢！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看嘛看嘛，",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "團長！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我們來相親相愛吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不只是臉，袒露肌膚跟靈魂，更深度的交流吧……！",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗚哇！？",
        "unit_id": 104713,
        "voice": "vo_adv_5006004_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為、",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為什麼不停止攻擊呢？",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n克莉絲你到底想幹嘛，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你再不停我真的要生氣囉！",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈！　",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正確答案！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我就是要團長生氣呀！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n然後再互相廝殺……☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "魔物A",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 104714
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊、",
        "unit_id": 104713,
        "voice": "vo_adv_5006004_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊啊？",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不行，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "冒牌貨們逃走啦！",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯……",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n該不會是感受到我的殺氣，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畏懼地逃跑了吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來還有蟲子般的求生本能，",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還有智能呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然跟人類比起來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只能算是沒有魅力的玩具就是了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不要淨說些不重要的事，",
        "unit_id": 104713,
        "voice": "vo_adv_5006004_042"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n快去追他們啊，克莉絲！",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "叫其他能出動的團員也跟進吧，",
        "unit_id": 104713,
        "voice": "vo_adv_5006004_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那些傢伙往街道那邊前進了喔！",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "若攻擊了沒有戰鬥力的市民，",
        "unit_id": 104713,
        "voice": "vo_adv_5006004_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "勢必造成慘劇！",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而我們【王宮騎士團（NIGHTMARE）】就是為了阻止那些慘事，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而結盟的正義的一方！",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈。",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是那些長得和【王宮騎士團（NIGHTMARE）】一樣的傢伙，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n引起了什麼慘事呀……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真有趣♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這可不是笑的時候啊！",
        "unit_id": 104713,
        "voice": "vo_adv_5006004_046"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n啊啊真是的，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我等下再來教訓你，克莉絲！",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就學『陛下』來預言吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你不但不會教訓我，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不如說還會獎勵我喲。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為預知了，",
        "unit_id": 107111,
        "voice": "vo_adv_5006004_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "先跟你說一聲吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "『不會不會，不客氣』♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "………？",
