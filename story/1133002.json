        "words": "在跳蚤市場大買特買後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n回住宿處途中的{player}等人──"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯嗯……",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "原來如此，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "竟然是這樣～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "居然會想到要以這個思維製作魔法，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真有一套～",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦！？",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不對吧！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這跟我認知不同啊……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這個流程又沒有什麼破綻，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯？",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "包歉包歉！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "買了這種書，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就會忍不住想要馬上翻開看嘛。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你說的也有道理。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那我們快回住宿的地方",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "卯起來看吧──！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呵呵呵，",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼多的書，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n一天兩天",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是看不完的。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看來也得囤些吃的，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣就可以不用離開房間了～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "去海邊……",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "玩？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不不不，",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我都買了這些書，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n當然想躺著",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好好享受讀書時光啊～",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……難得來度假，",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "應該好好玩樂？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n確實是這樣",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒有錯啦，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "畢竟也不是那麼常來的地方。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔～",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼說來書可以留到回家以後再看，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "現在應該和你一起四處逛逛比較好呢～？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好，我明白了。",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "既然你都說到這個份上了，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "七七香就陪你約會吧♪",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……啊，",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對了！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n那我們來模擬",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "美少女遊戲的約會吧！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就是和可愛的女孩子",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一起經歷各種色色體驗的遊戲呀～",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且正好",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這裡就有個",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n無庸置疑的正統女主角七七香嘛～？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哈，就是這個情境！",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n在度假期間",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "觸發事件的預兆來啦──！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "既然都這麼決定了，",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那就得馬上執行了！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我們快點把書拿回住處放吧！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "畢竟是約會，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們還要先決定會合地點和時間！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們要各自集合，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就這樣囉！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你問為什麼我們都一起行動了，還要特地分開再會合？",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "約會就是這樣的呀。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不要深入思考，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要去感受它。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "懂？",
        "unit_id": 113311
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在指定的會合地點\n{player}等待著七七香──"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……啊──啊──",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咳。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n服裝儀容，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒問題。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "他……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "乖乖在等著呢。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "接下來，約會事件……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "開始！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗨～～！",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呼，",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呼……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "抱、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "抱歉！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等很久了嗎？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "吼！",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼不懂正確答案呢──！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n你沒有掌握到美少女遊戲的經典喔！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "算了，",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這次不計入",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "七七香的好感度變化裡了。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "接下來，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你的行動要以美少女遊戲為基礎知道了嗎？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好耶！",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你很懂嘛！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這就是美少女遊戲的主流回答！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "七七香的好感度",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "上升了10♪",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n就按照這個步調",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "順利完成約會事件吧！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好，",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "既然都來約會了，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就要在攤販買點東西是也！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這可是個創造夏日海灘上",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "令人臉紅心跳回憶的時機喔～♪",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有沒有什麼不錯的店呢……",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊！",
        "unit_id": 113311,
        "voice": "vo_adv_1133002_025"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "發現那裡有間",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "冰淇淋店！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n走，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們出發！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "姊姊",
