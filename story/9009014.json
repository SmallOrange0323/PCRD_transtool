    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾某處。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n冷清的廣場上站著一個熟悉的身影。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "唔～",
        "unit_id": 100213,
        "voice": "vo_adv_9009014_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真傷腦筋啊……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "大江戶夏日祭典體驗之旅的集合地點",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n真的",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是這裡嗎？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和和怜都沒有空，",
        "unit_id": 100213,
        "voice": "vo_adv_9009014_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n結果我就自己一個人來了……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但是半個人都沒有，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "感覺好不安啊～",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "最好能夠讓旅行團的工作人員找到我……",
        "unit_id": 100213,
        "voice": "vo_adv_9009014_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還是應該要趁現在",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "換上容易辨識的衣服比較好呢。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……嗯，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就這麼做吧。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "離集合時間",
        "unit_id": 100213,
        "voice": "vo_adv_9009014_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還有一點時間……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "回去換衣服",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我剛剛",
        "unit_id": 100213,
        "voice": "vo_adv_9009014_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好像看見了騎士先生……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "唔，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "應該是我的錯覺吧。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也許是我",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太常在想騎士先生的事了。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我確實",
        "unit_id": 100213,
        "voice": "vo_adv_9009014_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是挑選了",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "希望可以穿給",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎士先生看的衣服……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但還是下次再說吧。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "糟了，",
        "unit_id": 100213,
        "voice": "vo_adv_9009014_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不快點的話就沒有時間換衣服了……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n動作要快一點～！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦？",
        "unit_id": 101512,
        "voice": "vo_adv_9009014_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒有人在嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n大江戶夏日祭典體驗之旅的集合地點",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n應該是這裡沒錯吧……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "難道是我來得太早了嗎。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……哎呀，",
        "unit_id": 101512,
        "voice": "vo_adv_9009014_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "原來也可以在當地集合呢。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我就先走一步吧。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "先去",
        "unit_id": 101512,
        "voice": "vo_adv_9009014_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "跟「陽卵旅館」的大家打聲招呼，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n然後再到集合地點",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "參加旅遊行程就好了吧。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "既可以見到懷念的人，",
        "unit_id": 101512,
        "voice": "vo_adv_9009014_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "又可以盡情享受祭典……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "看來今天會是很愉快的一天呢♪",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼……",
        "unit_id": 103412,
        "voice": "vo_adv_9009014_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "終於結束了……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "地獄般的13天連續出勤……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我想要……",
        "unit_id": 103412,
        "voice": "vo_adv_9009014_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "想要可以撫慰心靈的東西……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "麥酒是當然要的，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但不光是這個。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n和麥酒很搭的",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "某個東西……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這裡。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……好像在哪裡看過……",
        "unit_id": 103412,
        "voice": "vo_adv_9009014_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對了……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n是【墨丘利財團】主辦的大江戶夏日祭典體驗之旅的集合地點呀。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "傳單是我做的，所以記得呢……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真好啊～",
        "unit_id": 103412,
        "voice": "vo_adv_9009014_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "大江戶町的夏日祭典……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我記得還會有攤販……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呃，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對呀！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就是這個！！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我記得還有參加名額吧？",
        "unit_id": 103412,
        "voice": "vo_adv_9009014_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "現在就去拜託秋乃把我安排進去……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n非去不可！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "極致美味的攤販料理",
        "unit_id": 103412,
        "voice": "vo_adv_9009014_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "和麥酒在等著我！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不能在這裡拖拖拉拉的了！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "要去準備才行！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "為了最棒的麥酒，",
        "unit_id": 103412,
        "voice": "vo_adv_9009014_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我得做好萬全的準備……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不然",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就對不起麥酒了！！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "抵達了旅遊團的集合地點，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "卻發現沒有半個人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而獨自佇立的{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n沒錯，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這就是所謂的祭典前的寧靜。"
    }
]