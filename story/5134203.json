[
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……嗯，",
        "unit_id": 128411,
        "voice": "vo_adv_5134203_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "做了個好夢！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然要說的話，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好像跟作戰完全沒有關係，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而是在宇宙空間中跟隕石對揍，然後就把它破壞掉了！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "慢著！",
        "unit_id": 128511,
        "voice": "vo_adv_5134203_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n如果真的是那樣也很困擾吧，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這不就代表未來又改變了嗎！？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "應該說，",
        "unit_id": 128311,
        "voice": "vo_adv_5134203_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "光是從身處在宇宙空間這點來看就很奇怪啦！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳再睡一次，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好好去作本來的夢啦！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n怎麼可能用肉身突破大氣層啊！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦～",
        "unit_id": 128411,
        "voice": "vo_adv_5134203_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真是沒辦法呢……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是我已經餓到睡不著了，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n可以先讓我去攤販買東西吃嗎？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還、",
        "unit_id": 128511,
        "voice": "vo_adv_5134203_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還真是我行我素呢……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "先讓她像這樣稍微休息一下，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n或許也能讓預知夢的結果變好？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這我是不知道啦，",
        "unit_id": 128311,
        "voice": "vo_adv_5134203_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但就只能相信她了吧。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n既然這樣，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那我們也去吃個晚餐吧。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這說不定會是最後的晚餐呢，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我要大吃一頓。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "才不會是最後的晚餐呢！",
        "unit_id": 128411,
        "voice": "vo_adv_5134203_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為我們都還沒有吃到年菜啊，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要更積極地來努力吧～☆",
        "unit_id": 128411
    }
]