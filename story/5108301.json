[
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 124611,
        "voice": "vo_adv_5108301_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "跑到旅館外面了……！",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n帆稀、",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "深月，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "得攔住神明大人才行……！",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是啊，",
        "unit_id": 124711,
        "voice": "vo_adv_5108301_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "否則連大江戶町也會出大事的。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……而且，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這間旅館",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還沒能滿足祂呢。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵呵♪",
        "unit_id": 124511,
        "voice": "vo_adv_5108301_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n那麼兩位，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "現在是款待的時間囉。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "用我們飽含真心的款待",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來滿足溫泉之神吧～♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不能讓祂將罪惡與汙穢帶到明年。",
        "unit_id": 124711,
        "voice": "vo_adv_5108301_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓我們來清洗乾淨吧……！",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵♪",
        "unit_id": 124611,
        "voice": "vo_adv_5108301_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n帆稀和深月",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "都已經對旅館的工作得心應手了呢。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我也會",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "以誠心誠意接待客人的♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "陽卵旅館的各位！",
        "unit_id": 124511,
        "voice": "vo_adv_5108301_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n以小老闆娘",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "帆稀之名……",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "──大家一起",
        "unit_id": 124511,
        "voice": "vo_adv_5108301_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "迎接愉快的新年吧～♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "遵命！",
