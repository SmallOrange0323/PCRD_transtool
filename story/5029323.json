[
    {
        "type": "dialogue",
        "name": "望",
        "words": "馴鹿先生！",
        "unit_id": 111611,
        "voice": "vo_adv_5029323_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不要再打了！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n今天可是快樂的聖誕節呢！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒用的。",
        "unit_id": 111511,
        "voice": "vo_adv_5029323_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "已經沒辦法用言語說服牠們了。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳也感覺到這幾近能把積雪融化的氣魄了吧？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這就代表",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "牠們有多認真。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒想到那隻馴鹿",
        "unit_id": 111711,
        "voice": "vo_adv_5029323_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "竟然擁有這麼大的力量……！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看來我們",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也要有必死的決心才行！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼。",
        "unit_id": 111511,
        "voice": "vo_adv_5029323_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要戰到極限的話，我可是求之不得。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n讓我們彼此",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "全神貫注把力量發揮到極限吧！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……馴鹿先生們。",
        "unit_id": 111611,
        "voice": "vo_adv_5029323_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "從現在開始，我們也會使出全力來戰鬥的！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓這無意義的紛爭到此結束！",
        "unit_id": 111711,
        "voice": "vo_adv_5029323_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "畢竟",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "今天可是聖誕節啊！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "戰鬥結束後，",
        "unit_id": 111611,
        "voice": "vo_adv_5029323_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再跟馴鹿先生牠們一起",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "度過快樂的聖誕節吧！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈☆",
        "unit_id": 111511,
        "voice": "vo_adv_5029323_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "　我現在這樣也已經相當快樂了！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果有比這個更有意思的事情，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那麼我就盡全力結束這場戰鬥吧！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "為了快樂的聖誕節而戰！",
        "unit_id": 1,
        "voice": "vo_adv_5029323_008"
    }
]