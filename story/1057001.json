[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天在蘭德索爾裡，\n一名少女正忙著準備離開城鎮邁向旅途。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "──目的地是",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "沿海的城鎮……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n這些就是所有要運送的貨物嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是啊，",
        "unit_id": 311,
        "voice": "vo_adv_1057001_001"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "拜託妳了喔。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "話說回來，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳一個人沒問題嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n那個城鎮很遠呢……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "而且還得帶一匹馬拖著貨車。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "請儘管交給我！",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_002"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n馬的事情也沒有問題。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "牠看起來",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "很溫和。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "嘖！",
        "unit_id": 911,
        "voice": "vo_adv_1057001_003"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "竟然把工作委託給那種小鬼！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "你要是之後後悔沒有委託我們，",
        "unit_id": 811,
        "voice": "vo_adv_1057001_004"
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "\n也不關我們的事啊！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "嘖！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不要介意。",
        "unit_id": 311,
        "voice": "vo_adv_1057001_005"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "他們只是因為這份工作被妳搶走，\n才抱怨幾句而已。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "明明就是哄抬報酬的人不對。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "啊哈哈……",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_006"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝你。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "對了。",
        "unit_id": 311,
        "voice": "vo_adv_1057001_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那邊還有另一位剛才我委託他其他工作的人，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n目的地和妳一樣。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可以的話你們就一起走吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喂～！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你稍微過來一下！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我委託她另一個運貨的工作，目的地是一樣的城鎮，",
        "unit_id": 311,
        "voice": "vo_adv_1057001_008"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n機會難得你們就一起行動吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n也不知道會在城鎮外遇到什麼事呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "初次見面，你好。",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_009"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你就是要和我去同一個城鎮的人？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n那個……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "一起去會不會，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "給你添麻煩呢？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝……！",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_010"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我是吉塔。請多指教囉！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500320"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "──這樣啊。",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_011"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "原來你送的是信。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你的裝備很輕便呢，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "有個萬一時也比較好行動，這很重要吧。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……其實呢，",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_012"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我有一點點不安，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n不知道能不能獨自完成這個工作。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "雖然之前也有做過類似的工作，",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_013"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n不過那次從頭到尾都一直是一個人，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n從早到晚都沒有說話的對象，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "非常寂寞呢……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "今天有你在，",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_014"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就不寂寞了呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嘿嘿……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "──終於來了啊。",
        "unit_id": 911,
        "voice": "vo_adv_1057001_015"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "那邊的小鬼，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "給我停下來！",
        "unit_id": 911
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你們是剛才的……",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_016"
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "把你們運送的東西全部交出來吧！",
        "unit_id": 811,
        "voice": "vo_adv_1057001_017"
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "\n要是好好配合就放過你們！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "聽到沒，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "快點！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這個要求……",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_018"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我辦不到。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n承接下來的工作，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就必須好好完成到最後。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "這傢伙完全不怕嗎……？",
        "unit_id": 911,
        "voice": "vo_adv_1057001_019"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "\n妳也只有現在能囂張了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "喂，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "要上了喔！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "哦哦！",
        "unit_id": 811,
        "voice": "vo_adv_1057001_020"
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "納命來吧！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "{player}你先退下！",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_021"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n他們的目標是我。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "所以這裡只要由我……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "這傢伙是想怎樣！",
        "unit_id": 911,
        "voice": "vo_adv_1057001_022"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "我們要找的只有那個小鬼！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "\n你不要礙事！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "{player}……！謝謝！",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_023"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……不過放心吧。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "接下來",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我會一個人處理好的。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "竟然敢在我面前說大話！",
        "unit_id": 911,
        "voice": "vo_adv_1057001_024"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "接招！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "喝啊！",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_025"
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "唔啊啊！",
        "unit_id": 911,
        "voice": "vo_adv_1057001_026"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "這傢伙，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "動作好快……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "剩下一個人！",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_027"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "噠啊！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "嘎哈啊！",
        "unit_id": 811,
        "voice": "vo_adv_1057001_028"
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "怎、",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "怎麼回事！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我想就不用再打下去了吧……",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_029"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "要是你們還想繼續，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我就不會手下留情了！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "呿……！",
        "unit_id": 911,
        "voice": "vo_adv_1057001_030"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "喂，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "走人了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "可惡！",
        "unit_id": 811,
        "voice": "vo_adv_1057001_031"
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "給我記住！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_032"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "呼。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "剛才謝謝你。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "有沒有受傷？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "太好了……",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_033"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "抱歉啊。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n把你捲進我引起的麻煩裡。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "他們說不定會帶同伴回來這裡，",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_034"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我們得立刻離開才行。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "話說回來他們真過分呢。",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_035"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n明明是他們哄抬報酬我才能拿到工作的，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "卻反過來怨恨我。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "他們大概是認為能夠打倒我吧，",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_036"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "別看我這樣子，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好歹我也為了成為獨當一面的騎空士，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "每天都有在鍛鍊呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你知道騎空士嗎？",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_037"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就是隸屬於騎空團，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n乘坐巨大的飛艇……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "騎空艇，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n在世界各地冒險的人們……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你不知道，",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_038"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "對吧……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "最近也幾乎看不見騎空艇了……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……我的父親呢，",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_039"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是一名騎空士。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n現在正在這片大陸之外的地方冒險著。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "總有一天，",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_040"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我也想要成為像父親一樣的騎空士……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "於是我也成立了騎空團，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "成為騎空士。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過現在團員只有我一個，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "也沒有騎空艇就是了……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "所以為了先存錢買艘騎空艇，",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_041"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我才會做各式各樣的工作，順便當作修行。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "然後……",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_042"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那個呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n剛才你幫我的時候，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我想了想。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "要是有夥伴能像剛才一樣互相幫助",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就好了呢……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "拜託你！",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_043"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "能不能加入我的騎空團呢！？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我想要和你一起在空中冒險……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n所以……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "可以嗎……？",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_044"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "太好了！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是第一位夥伴──！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "啊，",
        "unit_id": 105711,
        "voice": "vo_adv_1057001_045"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "抱歉！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我太高興了就不禁……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嘿嘿。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n從今以後就請多指教了！{player}！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}就這樣接受吉塔的邀約，\n加入了騎空團開始以騎空士的身分活動。"
    }
]