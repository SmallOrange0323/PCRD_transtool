[
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在陽光灑落的假日餐廳裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n由市政府主辦的聯誼派對即將舉行。"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呃──",
        "unit_id": 132531,
        "voice": "vo_adv_5204066_000"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "感謝",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "大家",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "來參加",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "「愛‧椿丘」。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n我是擔任主持人的",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "市政府職員，名叫石動苑──",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "深月‧流夏",
        "words": "…………\n……",
        "unit_id": 1,
        "voice": "vo_adv_5204066_001"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呃……",
        "unit_id": 132531,
        "voice": "vo_adv_5204066_002"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "今天天氣也很好，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n參加者",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是兩個人，所以……",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那個，",
        "unit_id": 105131,
        "voice": "vo_adv_5204066_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "今天這是",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "聯誼派對吧？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "市政府主辦的。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不會錯的，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "畢竟我是看到海報，確認過好幾遍才報名。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……這到底",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是怎麼回事……？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那個，",
        "unit_id": 132531,
        "voice": "vo_adv_5204066_004"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這個嘛……",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n男、",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "男性參加者的話，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "因為有",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "急事",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "之類的……",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不好意思。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈，",
        "unit_id": 105632,
        "voice": "vo_adv_5204066_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這不是妳需要道歉的事啦。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說實話，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也沒有在尋求",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "什麼邂逅。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們常客的老公",
        "unit_id": 105632,
        "voice": "vo_adv_5204066_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在市政府工作，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n他拜託我，說參加者好像很少，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "希望我能去。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是、",
        "unit_id": 105131,
        "voice": "vo_adv_5204066_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是啊，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我也並沒有那麼期待啦。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我是有稍微",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "想過",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "說不定……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但跟研究一樣，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這不是會那麼順利進展的事",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯嗯……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……那個，",
        "unit_id": 132531,
        "voice": "vo_adv_5204066_008"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "真的非常抱歉。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n這",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "作為聯誼派對已經失敗了，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "所以我們解散吧。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n我會先向市政府報告的。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……欸，",
        "unit_id": 105131,
        "voice": "vo_adv_5204066_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳們",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "接下來有空嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我知道這附近有很棒的店。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "與其帶著悶悶不樂的心情回去，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不如透過女生聚會來發洩",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一下如何？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我可以喔，",
        "unit_id": 105632,
        "voice": "vo_adv_5204066_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n反正就算",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "回去了也只能釣魚。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "石動小姐呢？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "啊啊，",
        "unit_id": 132531,
        "voice": "vo_adv_5204066_011"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呃──",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我要",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "消化",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "累積沒看的劇……",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "機會難得，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我就奉陪吧。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾小時後。"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不是啊，",
        "unit_id": 132531,
        "voice": "vo_adv_5204066_012"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "為什麼單身的我",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "非得幫助別人結婚不可啊。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……話說，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "市政府主辦的聯誼派對什麼的，是誰會受益？",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這種活動交給民間百分之百更好吧……",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "通過了展現我們正努力推動少子化對策的企劃是很好啦，",
        "unit_id": 132531,
        "voice": "vo_adv_5204066_013"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n但既然如此，就由提案的你來負責啊，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "笨蛋上司。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n為什麼是我假日要被叫出去啊？",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "可惡可惡可惡可惡──",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "深月‧流夏",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5204066_014"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "啊！？",
        "unit_id": 132531,
        "voice": "vo_adv_5204066_015"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不、",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不好意思……！",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n在市民面前這麼失言……",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊哈哈，",
        "unit_id": 105632,
        "voice": "vo_adv_5204066_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳憋很久了吧～",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我完全不介意，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不如說",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "很有人性，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓人很有好感喔。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105131,
        "voice": "vo_adv_5204066_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "排毒是很重要的嘛，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒什麼不好吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不懂幕後辛苦的人哪裡都有呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我的研究所也有一樣的……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "抱歉，有電話。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "喂？",
        "unit_id": 105131,
        "voice": "vo_adv_5204066_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "您好。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……是……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "預算下不來……？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這樣啊。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那件事以後再說。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好的，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我先掛了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……真是的，",
        "unit_id": 105131,
        "voice": "vo_adv_5204066_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "什麼都搞不懂……！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n叫我趕快做，我只是照著指示做了，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "卻說預算不能變，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n希望我繼續進行，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "到底是把現場當成什麼──",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦哦，",
        "unit_id": 105632,
        "voice": "vo_adv_5204066_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這位也憋很久了呢。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "兩位",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "今天都",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說個痛快吧！",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過啊，",
