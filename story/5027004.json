        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不過嘉夜果然跟小智姐說的一樣，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是個心地善良的人耶！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呵呵，",
        "unit_id": 106511,
        "voice": "vo_adv_5027004_028"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "誰知道呢？",
