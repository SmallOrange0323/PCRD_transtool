[
    {
        "type": "background",
        "background": "500833"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "突然現身的神祕影子用火燒毀部分營地便離開了，襲擊後過了一晚，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n營地中瀰漫一股混亂交雜著熱氣的奇妙氛圍。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "其中，只有【龍族巢穴】的龍人族們非常冷靜，\n彷彿就像這個襲擊事件早就注定會發生一樣。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過牠一下就不見了耶，",
        "unit_id": 106511,
        "voice": "vo_adv_5027004_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "到底",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是來幹嘛的啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那個火災，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的不是祈梨妳搞出來的吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果是妳嚇到噴出火來的話，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就趕快講喔？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼可能！　",
        "unit_id": 106611,
        "voice": "vo_adv_5027004_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個火焰是牠吐出來的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而且，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "請不要把我的龍息講得好像失禁一樣好嗎！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我想應該不會錯的唷～☆",
        "unit_id": 106711,
        "voice": "vo_adv_5027004_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n那個燒焦的痕跡",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "和島上其他地方看到的極為相似。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而且……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那個小石頭",
        "unit_id": 106511,
        "voice": "vo_adv_5027004_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼了嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "上面好像畫了個很醜的圖案耶？",
        "unit_id": 106611,
        "voice": "vo_adv_5027004_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這是……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "蘋果？　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還是什麼？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "畫成這樣，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我來畫還比較好看呢！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這很明顯",
        "unit_id": 106711,
        "voice": "vo_adv_5027004_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是人為加上去的吧～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是我們所預想的東西的話……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "中獎了嗎？",
        "unit_id": 106511,
        "voice": "vo_adv_5027004_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看來",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "得正式開始行動了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳們打算怎麼辦？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔！？　",
        "unit_id": 100511,
        "voice": "vo_adv_5027004_007"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "被、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "被發現了！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這麼明目張膽的偵查，",
        "unit_id": 106511,
        "voice": "vo_adv_5027004_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "馬上就會注意到的啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n雖然妳大概是想偷偷來，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但早就漏餡了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 106611,
        "voice": "vo_adv_5027004_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只有茉莉妳跟小哥兩個人？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n那個輕浮的保鑣還在睡嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也就是說～……",
        "unit_id": 106711,
        "voice": "vo_adv_5027004_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真傷腦筋呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看來被她搶先了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n考慮到這裡的地形，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那個巨大生物能藏身的地點",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "並不難猜……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n只是我沒想到",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "她竟然有勇氣",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "隻身過去～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那傢伙，",
        "unit_id": 106511,
        "voice": "vo_adv_5027004_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "該不會一個人跑進森林裡了吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不、",
        "unit_id": 100511,
        "voice": "vo_adv_5027004_012"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不會吧！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐丟下我",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "，自己一個人跑去了嗎！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……真是的，",
        "unit_id": 106611,
        "voice": "vo_adv_5027004_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真會找麻煩！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "老大，",
        "unit_id": 106511,
        "voice": "vo_adv_5027004_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒空慢慢準備了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "立刻出發。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "立刻？",
        "unit_id": 106711,
        "voice": "vo_adv_5027004_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳知道要去哪裡嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n雖然可以大致猜想牠的藏身之處，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但這座森林",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "相當廣闊喔～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然這樣就趕快去調查啊！",
        "unit_id": 106611,
        "voice": "vo_adv_5027004_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n老大妳出馬的話應該很快才對！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我是可以找找看，",
        "unit_id": 106711,
        "voice": "vo_adv_5027004_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但做這個對我有什麼好處呢？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而且，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為這樣欠我人情也沒關係嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n妳之前不是說",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不想再繼續欠我人情了嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊嗚嗚嗚……",
        "unit_id": 106611,
        "voice": "vo_adv_5027004_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "搜、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "搜索費用",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "請向遇難者本人請款！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呵呵，",
        "unit_id": 106511,
        "voice": "vo_adv_5027004_019"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "說來說去祈梨",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還是很在意對方嘛。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎怎怎怎麼可能呀！",
        "unit_id": 106611,
        "voice": "vo_adv_5027004_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就算她擅自丟了小命，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也只會睡不好而已！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "知道了知道了。",
        "unit_id": 106511,
        "voice": "vo_adv_5027004_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……好啦，茉莉。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我會馬上去把她帶回來的，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "別露出那種表情嘛。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我、",
        "unit_id": 100511,
        "voice": "vo_adv_5027004_022"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也要去！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我不能丟下",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐一個人！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "茉莉啊，",
        "unit_id": 106511,
        "voice": "vo_adv_5027004_023"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳真的懂嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n運氣不好的話",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可是要和那個會噴火的巨大生物戰鬥喔？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒錯～沒錯～！",
        "unit_id": 106611,
        "voice": "vo_adv_5027004_024"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n會扯後腿的人就留在這裡看家吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "的確是",
        "unit_id": 100511,
        "voice": "vo_adv_5027004_025"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很恐怖沒錯……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可是，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我已經下定決心要去了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那就是屬於我的……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "正義！！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "竟然跟我們談論正義啊，",
        "unit_id": 106511,
        "voice": "vo_adv_5027004_026"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是敗給妳了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
