        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "茉莉。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們是幫派份子，",
