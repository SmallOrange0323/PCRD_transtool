[
    {
        "type": "background",
        "background": "500970"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喔？",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "竟然也有掉在這種地方。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個是……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有關控制的迴路吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗨～同志，",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真巧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你問我在做什麼嗎，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "答案只有一個。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不論何時，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我都在這個世界上知性地漫步。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "悲哀，",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是太悲哀了，同志。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你現在仍受限於視覺嗎。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那可是會讓靈魂近視的愚蠢行為，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "會看不清真理喔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "現在這個地方，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就某層面來說，可是知識的寶庫呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好吧，",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就用你那過時的眼睛看好。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那個是爆炸後四散的\n超級優妮號……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "更正，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好朋友X的殘骸。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n校舍雖然已經完美修復了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但這裡",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還殘留著那天的痕跡。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好朋友X……",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "先不論好壞，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那可是一個相當創新的產物。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是一個不受既有觀念限制，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "極富原創性的挑戰。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還有著幻想科學中所描繪的",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "永無止境的浪漫。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "諷刺的是，對我而言，",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "遇見那傢伙是一個突破性的進展。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "它狠狠地打碎了那堵困住我、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "名為常識的牆壁。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這讓我體認到",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "接連的",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「那真是太厲害啦！」是會讓一個人劇烈地成長的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "為了不要讓那極端寶貴的體驗被沖淡，",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n又或者說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是為了具體將那鮮明的記憶記錄下來，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我才會在這裡撿垃……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "知性地漫步。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那我反問你，",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你不會有這種想法嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "想要再次感受那無法用言語形容，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "極為特別的知性興奮感。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "說得好。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n真不愧是我看上的共同研究者，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真的很有品味。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "既然如此，",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那你就稍微幫個忙吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如此回答的你，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就有權利幫助我這體力不佳的繭居族。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n來吧，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "撿起掉落在這裡的垃圾……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "更正，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "回收名為知性的碎片吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "感覺你好像不太懂的樣子。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "失禮了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，也就是說……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還是算了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n並不是什麼事情都可以講白的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n因為我是文科出身的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "自然也了解名為驚喜的浪漫。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼，",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "既然已經決定了，那就馬上開始吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "製作那個——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「好朋友X　Mk -Ⅱ」！",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_013"
    }
]