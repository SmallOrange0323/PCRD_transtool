[
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "很在意露娜的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再度造訪位於蘭德索爾之外的那座森林。"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……你怎麼又來了呀？",
        "unit_id": 611,
        "voice": "vo_adv_1114002_000"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不是叫你不要來了嗎……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……",
        "unit_id": 611,
        "voice": "vo_adv_1114002_001"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……唉。",
        "unit_id": 611,
        "voice": "vo_adv_1114002_002"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不，",
        "unit_id": 611,
        "voice": "vo_adv_1114002_003"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不好意思。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n是我自己不好。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "年紀越大，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "個性就變得越乖僻真是不好呢……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "其實……",
        "unit_id": 611,
        "voice": "vo_adv_1114002_004"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我很想請你聽我說說話。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n有關那個孩子……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "與我的事情。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……不好意思，",
        "unit_id": 611,
        "voice": "vo_adv_1114002_005"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "可以聽我說一個很長的故事嗎？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……謝謝你呢。",
        "unit_id": 611,
        "voice": "vo_adv_1114002_006"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不是愉快的故事喔。",
        "unit_id": 611,
        "voice": "vo_adv_1114002_007"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不但如此，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "這還是一個無奈的故事。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……我啊，",
        "unit_id": 611,
        "voice": "vo_adv_1114002_008"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "算是將那孩子的父母",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "給殺死了呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "是多久以前的事呢。",
        "unit_id": 611,
        "voice": "vo_adv_1114002_009"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那個孩子，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "與她的父母",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "搬到了這座森林內。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "在森林深處，",
        "unit_id": 611,
        "voice": "vo_adv_1114002_010"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "建造了一棟漂亮的洋房呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "就開始有些傳聞說",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "他們是哪裡的貴族呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "他們都是好人唷。",
        "unit_id": 611,
        "voice": "vo_adv_1114002_011"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "和我們見面時，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "常常會幫忙各種事情呢……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……但是。",
        "unit_id": 611,
        "voice": "vo_adv_1114002_012"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n某個夜晚，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "魔物突然暴走。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n襲擊了這棟洋房。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我呢……",
        "unit_id": 611,
        "voice": "vo_adv_1114002_013"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n剛好，人正在附近……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "眼睜睜地看著一切發生。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n藏身樹叢內，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "全身不斷顫抖著。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……我的全身發軟",
        "unit_id": 611,
        "voice": "vo_adv_1114002_014"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "無法站起來。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n如果那時能跑去呼救就好了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "是那樣就好了……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "等我能移動身體時……",
        "unit_id": 611,
        "voice": "vo_adv_1114002_015"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n已經太遲了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "只有那個孩子，",
        "unit_id": 611,
        "voice": "vo_adv_1114002_016"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "奇蹟地獲救……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "但是她的父母已經回天乏術。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n從那天開始，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那個孩子就剩下自己獨自一人。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……真是太丟人了。",
        "unit_id": 611,
        "voice": "vo_adv_1114002_017"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "沒想過年紀變大，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "自己會變得那麼沒出息。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……我很卑鄙呢。",
        "unit_id": 611,
        "voice": "vo_adv_1114002_018"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我一定是一直等著，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "會這樣對我說的人。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "因此……",
        "unit_id": 611,
        "voice": "vo_adv_1114002_019"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n我不覺得自己沒錯。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "非常深切覺得，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我有錯呢……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那個孩子",
        "unit_id": 611,
        "voice": "vo_adv_1114002_020"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "好像很喜歡你呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那個孩子，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "就拜託你了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}看著老婆婆離去的背影，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n決定前往森林深處的洋房一探究竟。"
    },
    {
        "type": "background",
        "background": "500532"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "前進一段時間後，周遭的景色徹底改變了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n簡直就像墓地一樣。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "無數墓碑的彼端，靜靜佇立著一幢洋房。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}敲了敲洋房的門。"
    },
    {
        "type": "still",
        "still": "111400201"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……是誰？",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_021"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……唔。",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_022"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "你來做什麼……！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n這裡是",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜的家喔！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_023"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n露娜，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "討厭說謊的人。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "明明說過會跟我當朋友……",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_024"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n……但是大家都逃走了，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "討厭。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "別說奇怪的話。",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_025"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……那是為了要跟你當朋友呀。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n要一直一直，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "當永遠的朋友呀。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "你不知道嗎？",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_026"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n死掉之後",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "就可以一直在一起唷。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "爸爸和媽媽和我說過。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_027"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n……你回去吧。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……你騙人。",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_028"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "為什麼大家，",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_029"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "都要騙露娜呢？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n露娜，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "只是想和大家一起玩而已……",
        "unit_id": 111411
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "111400202"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_030"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "…………",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_031"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……這麼想和露娜玩嗎。",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_032"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n為什麼？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_033"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n……我搞不懂。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不過……",
        "unit_id": 111411,
        "voice": "vo_adv_1114002_034"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "好呀。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n我可以陪你玩……",
        "unit_id": 111411
    },
    {
        "type": "background",
        "background": "500532"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "露娜說完後，膽怯地由門後走出來。"
    },
    {
