[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "茉莉等人決定開始為異文化交流做準備，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當作與獸人族邁向和平的第一步。"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯～",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所謂的異文化交流，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要做什麼才好呢？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然阿姨說她已經有想法了……",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "帶大家逛逛蘭德索爾的知名景點就夠了嗎？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那樣的話，",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我想跟他們介紹",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "虎虎的超級英雄秀！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂喂喂，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "誰准你們自顧自地討論的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不是說過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "克莉絲提娜姐姐我已經有個完美計畫了嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊，",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳到底跑去哪了啊？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了準備異文化交流，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我可是四處奔走，忙得不可開交呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我趁著去和「公主殿下」報告的同時，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n順便取得了特別授權的權限和敕書。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "拜此所賜，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我差點沒被那個四眼田雞的隨從瞪出一個大洞，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不過，既然是貪吃佩可直接提出的要求，她也無話可說。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看她一副咬牙切齒，滿臉不甘心的模樣♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "喔喔，",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_008"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳在說克蕾琪塔小姐吧……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個模樣",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "簡直浮現在我的腦海裡了。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總之，她之後八成會以報復的心態",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來對我們展開各種監察，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以保持報告確實，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以及帳目上的公開透明，得花不少功夫……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳那呆滯的表情是怎麼回事？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒什麼……",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我只是覺得，原來克莉絲提娜阿姨",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳是個很能幹的人嘛。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我之前",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有點誤會妳了。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為我從其他團員那邊聽到的，",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_011"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是妳會強逼部下做行政工作，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n做事情任性妄為",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "又不收拾爛攤子。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這點小事如果不能隨手完成，那我還當什麼副團長啊。",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看妳因為我的能幹而目瞪口呆，真是令人心情愉快♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還有，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "晚點妳可以把那些",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對我有意見的團員名字，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n整理出來給我參考參考。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟聽起來他們很需要一些教育指導☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那麼，",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_014"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我們要從哪裡開始著手才好呢？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n應該有很多事情",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "需要準備吧？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "準備？",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "早就已經準備好了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這就是克莉絲提娜姐姐我",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所規劃而成的異文化交流方案！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們要進行的就是……",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "寄宿體驗！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "寄宿體驗……",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_017"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳是說，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n到他人家裡借住",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "的那個寄宿體驗嗎？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是啊，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們會到",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "兔子族的聚落打擾幾天，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "主要是為了了解他們的日常生活、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "工作、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "飲食文化，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以及價值觀等等。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然宣稱要互相了解，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果我們對對方一無所知，那還談什麼了解呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "喔……",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_020"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那麼，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我明白為什麼要進行寄宿體驗了，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不過，什麼時候要去呢？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當然是現在去啊？",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_021"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "原來如此，",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_022"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "現在去啊。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……咦咦咦咦咦！？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "現在就去嗎！？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所謂作戰行動",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就貴在迅速果決。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳看看這小子，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我一聲下令，就立刻整頓完畢準備出發囉。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}已經這麼習慣了……",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_024"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "完全可以想像你平日有多麼辛苦。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳那是什麼意思？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過話說回來，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果妳也是【王宮騎士團】的一員，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就請妳要隨時做好回應緊急動員的準備。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好了，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "事情都明白了吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n明白的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就快點做好準備出發吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "請、",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_028"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "請等我一下！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我可是",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "什麼都還沒準備啊～！？",
        "unit_id": 100512
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "──那個，",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_029"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你們兩個為什麼要跟過來啊？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我不是說我回家一趟準備遠行，馬上回來，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要你們等我嗎？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}也就算了，",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_030"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為什麼連克莉絲提娜阿姨都……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子可以跟來，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就不行，妳說說這是什麼道理？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我既然要帶人家的寶貝孩子出遊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n當然要好好打聲招呼不是嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過嘛，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那只占了一成原因而已，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "剩下的九成，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "單純只是我好奇而已☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我就知道反正一定就是這麼回事！",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_033"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_034"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唉唉，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "怎麼辦？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "再這樣下去，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我獸人族的身分就會暴露了……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳在碎碎念什麼？",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有話想說的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就當面大聲說出來啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我要是說得出口，還糾結什麼啊！",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_036"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……啊，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我家到了。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好了，",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_037"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我準備好了就回來，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你們絕對！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不管發生什麼事！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "都要在這裡等我喔！？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是叫我們要去偷看的暗示嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_038"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "才不是！",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_039"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我是認真的，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我說真的，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我不是在開玩笑喔！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}你也是，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要是這位阿姨",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "打算胡來，請你阻止她。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "拜託你了喔！？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼。",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來她對我是一點信任",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也沒有。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無妨，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "每個人都會有不想讓人觸及的一面。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對茉莉來說，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是家人了吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不對，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "應該說是她自己的……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "出身，才對吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要不然你以為我的眼睛是",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "裝飾用的嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那種事根本一看就知道了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然她本人應該覺得自己隱藏得很好，不過……",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "智和團長，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還有其他團員，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "大家都只是假裝沒看出來而已。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "其實我也不打算讓她在這裡破功啦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n畢竟出身和種族之類的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對我而言根本不值得一提。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哎呀……",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你一副有話想說的模樣，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n覺得很意外嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我真的是這麼想的喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對我來說，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要能消磨這股來自體內深處，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n甜膩腐臭又令人厭倦無比的百無聊賴，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是什麼人我都無所謂。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可是以不挑對手而聞名的克莉絲提娜姐姐。",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無論對方是獸人族、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "魔族、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是精靈族……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n當然，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算是人族也一樣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要站在我面前，一律揮劍斬之，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要擋住我的去路，一律舉劍殺之。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我所看重的，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就只有是否能與我好好起舞。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如此而已。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不是說我是平等主義者，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過單就這方面，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你大可相信我沒有半點虛言。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "……真是的，",
        "unit_id": 8511,
        "voice": "vo_adv_5104002_051"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "茉莉妳平時那麼受人照顧，",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n媽媽當然要去打聲招呼才行啊。",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……不、",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_052"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不用了，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真的不用啦！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我已經是可以獨當一面的【王宮騎士團】團員！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不需要媽媽出來打招呼",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也沒關係的啦！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "……那怎麼行呢！",
        "unit_id": 8511,
        "voice": "vo_adv_5104002_053"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n禮貌這方面一定要好好做到位才行，媽媽不是常常這樣教妳嗎？",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "啊，",
        "unit_id": 8511,
        "voice": "vo_adv_5104002_054"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "不好意思。",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n小女一直以來承蒙關照了──",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "初次見面，妳好。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我是克莉絲提娜，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "請多指教。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "此次我奉【王宮騎士團】之命，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n擔任和平大使一職。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "……原來如此，",
        "unit_id": 8511,
        "voice": "vo_adv_5104002_057"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "辛苦您了。",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "那麼，",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "克莉絲提娜小姐",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "您來到寒舍是為了什麼呢？",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "作為和平活動的一環，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我接下來預定與茉莉團員，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n一同前往獸人族的聚落進行寄宿體驗。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我正是為此前來迎接",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正躲在妳身後的千金。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當然，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會保證她的安全。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這可是讓心愛的孩子外出去磨練，妳說是吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒錯！",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_060"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "而且",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我已經是個有能力的團員了！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "純她……",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_061"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "團長這次也",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "指名由我，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n擔任和平大使",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這個重要的任務了！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "再說，",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_062"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我還必須好好盯著",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "克莉絲提娜阿姨才行！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "畢竟要是一個不留神，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "她不知道會做出什麼事。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈☆",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "叫我姐姐、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要叫我姐姐。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n再讓我重申一次，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就讓妳從新兵的斯巴達訓練重新來過。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "要讓茉莉擔任",
        "unit_id": 8511,
        "voice": "vo_adv_5104002_064"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "與獸人族的和平大使……？",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "可是",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "茉莉，",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "妳……",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "討厭，",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_065"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "媽媽妳就是太愛操心了啦。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我一定會好好完成使命，",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_066"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳就放心在家等我回來吧！！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "……那好吧。",
        "unit_id": 8511,
        "voice": "vo_adv_5104002_067"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "不過，",
        "unit_id": 8511,
        "voice": "vo_adv_5104002_068"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "茉莉妳聽好了，",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n獸人族有很多不同的習俗，",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n妳千萬不能",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "做出有失禮數的行為喔。",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "放心吧！",
        "unit_id": 100512,
        "voice": "vo_adv_5104002_069"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那麼",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "媽媽，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我出發囉～～！！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_070"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "貴千金我就帶走了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我們會離開蘭德索爾好一陣子──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "請問……",
        "unit_id": 8511,
        "voice": "vo_adv_5104002_071"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "克莉絲提娜小姐。",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n妳為什麼",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "什麼話都不說呢？",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳指的是什麼呢？",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_072"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "雖然那孩子覺得自己隱藏得很好，不過……",
        "unit_id": 8511,
        "voice": "vo_adv_5104002_073"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "就是，",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "我們其實是……",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很抱歉，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_074"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不可能記得住所有團員的事情。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且我身為【王宮騎士團】，也已經是過去式了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要我背下特定部下個人檔案中的枝微末節，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_075"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n太浪費我的大腦記憶容量了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "更何況，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_076"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以我的立場來說，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n多得是其他地方可以讓我的腦細胞使用得更有意義。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "這樣",
        "unit_id": 8511,
        "voice": "vo_adv_5104002_077"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "啊……",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_078"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我向妳保證，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們一定會平安回來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別看我這樣，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可是個一諾千金的女人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "即使是像我這樣不隨俗靡、",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_079"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "特異獨行的人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n至少也擁有一項能稱之為信念或美學的東西。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那信念堅不可摧，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_080"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也無法破壞。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既不會丟失，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也不會迷失……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是如此地絕對。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然稱不上誓約那般慎重……",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_081"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無論要用什麼方法，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我都會遵守承諾到底♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_082"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若對方發生陣前逃亡、背叛，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "或者其他諸多……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "影響遵守承諾的行為，那我就無法保證了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "看來您是個",
        "unit_id": 8511,
        "voice": "vo_adv_5104002_083"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "極為坦率真誠的人啊。",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "我還以為【王宮騎士團】的人會是更……",
        "unit_id": 8511,
        "voice": "vo_adv_5104002_084"
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "\n善於隱藏掩飾事情的人。",
        "unit_id": 8511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那方面我其實也很擅長，但……",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_085"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "承諾這種事，就是要在雙方公平坦承的情況下才能成立不是嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "尤其是現在這樣，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_086"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有人用懷疑的目光看著自己時，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "更是如此。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "………………",
        "unit_id": 8511,
        "voice": "vo_adv_5104002_087"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "站在我的立場，",
        "unit_id": 107111,
        "voice": "vo_adv_5104002_088"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我自認為我這段話",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正直誠實而毫無虛假。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "至於妳要如何看待，",
