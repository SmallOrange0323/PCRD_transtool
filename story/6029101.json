[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說到聖誕節，",
        "unit_id": 111611,
        "voice": "vo_adv_6029101_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家都會很開心地期待對吧！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對你來說聖誕節",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是什麼樣的日子呢？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "果然！",
        "unit_id": 111611,
        "voice": "vo_adv_6029101_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說到聖誕節就會想到蛋糕！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算聖誕節是很特別的日子，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也要注意不可以吃太多。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為了要成為頂尖的偶像，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也得注意身材才行。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "難不成",
        "unit_id": 111611,
        "voice": "vo_adv_6029101_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你很怕冷嗎？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對了！　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要不要圍圍巾看看？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我送你！　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "當然，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是我親手織的喔。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯！　",
        "unit_id": 111611,
        "voice": "vo_adv_6029101_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是啊！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我身為偶像，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要努力讓大家都能感到開心才行！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n能夠送禮物的",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可不是只有聖誕老人喔！",
        "unit_id": 111611
    }
]