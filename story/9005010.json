[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聽了兩位老師的建議，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪菲決心要找到屬於自己的禮物。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "想送給他的東西。",
        "unit_id": 106412,
        "voice": "vo_adv_9005010_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "肯定",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就在我的心中。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n仔細想想我現在",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "擁有什麼吧……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對了……",
        "unit_id": 106412,
        "voice": "vo_adv_9005010_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "回憶。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我在蘭德索爾",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "遇見了【美食殿堂】的夥伴們，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n並且由他們拉拔成長……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我的心裡",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有滿滿的回憶。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這些刻在我心底的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "重要記憶……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我想……",
        "unit_id": 106412,
        "voice": "vo_adv_9005010_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呈現給他看。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106412,
        "voice": "vo_adv_9005010_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "該怎麼做……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n至今為止我也做過不少東西……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "或許很困難，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但我還是想用屬於我自己的方式來傳達。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……哎呀？",
        "unit_id": 103311,
        "voice": "vo_adv_9005010_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n妳是",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "【美食殿堂】的……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "？",
        "unit_id": 106412,
        "voice": "vo_adv_9005010_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳們是──",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣啊……",
        "unit_id": 103813,
        "voice": "vo_adv_9005010_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要送給那個人",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "的禮物……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "把回憶作為禮物，",
        "unit_id": 105213,
        "voice": "vo_adv_9005010_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真是個",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "很棒的想法呢～♪",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是，",
        "unit_id": 106412,
        "voice": "vo_adv_9005010_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我現在還沒有任何頭緒。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n該怎麼將回憶具體呈現",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呢……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "確實是個難題啊。",
        "unit_id": 103311,
        "voice": "vo_adv_9005010_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳乾脆",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "跟我一起說相聲怎麼樣？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "相聲！？",
        "unit_id": 106412,
        "voice": "vo_adv_9005010_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真是的，",
        "unit_id": 105213,
        "voice": "vo_adv_9005010_011"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真陽。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n妳不要什麼事都想跟相聲扯在一起嘛。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "跟龍人族女孩搭檔",
        "unit_id": 103311,
        "voice": "vo_adv_9005010_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "肯定很有噱頭的啊～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "吐槽就用她的尾巴啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "既然",
        "unit_id": 103813,
        "voice": "vo_adv_9005010_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要送東西，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n果然還是送可以長久留存的比較好呢。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那種可以一再回顧……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "然後露出笑容的東西。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嗯。",
        "unit_id": 106412,
        "voice": "vo_adv_9005010_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我也是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這麼認為。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？",
        "unit_id": 105213,
        "voice": "vo_adv_9005010_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n話說小鈴呢？",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n剛才不是還跟我們在一起嗎？",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611,
        "voice": "vo_adv_9005010_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，",
        "unit_id": 103311,
        "voice": "vo_adv_9005010_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳又在躺著看漫畫啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "說了多少次這樣很沒規矩的啦～！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611,
        "voice": "vo_adv_9005010_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為漫畫",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很有趣啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我又不擅長跟人家討論事情～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n少了我一個也沒差吧～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……漫畫？",
        "unit_id": 106412,
        "voice": "vo_adv_9005010_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？",
        "unit_id": 102611,
        "voice": "vo_adv_9005010_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳不知道嗎～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就是這種把故事畫成圖，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "看起來很有趣的書啊～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──就是這個！",
        "unit_id": 106412,
        "voice": "vo_adv_9005010_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "噫！？",
        "unit_id": 102611,
        "voice": "vo_adv_9005010_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "幹嘛突然大叫啦，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "討厭～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "靈感乍現，雪菲亟欲實行。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與真陽等人告別後，隨即飛奔而去。"
    }
]