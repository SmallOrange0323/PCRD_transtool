    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是從何而來的呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "下次，",
        "unit_id": 105913
    },
    {
