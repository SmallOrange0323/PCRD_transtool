    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下層的道具被清空，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n同時上層的封印也未能解開的情況下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便遇上了瓶頸。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "同時，",
