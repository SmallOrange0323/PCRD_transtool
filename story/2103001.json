        "voice": "vo_adv_2103001_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，我才不會想吃妳這種東西啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……是說涅比亞。",
        "unit_id": 106012,
        "voice": "vo_adv_2103001_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這陣子好像都沒什麼看見妳呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來還活著啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯，",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_008"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "勉勉強強吧……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟妳",
        "unit_id": 106012,
        "voice": "vo_adv_2103001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "每次被{player}和雪菲發現的時候，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都會被當成玩具追來追去的嘛……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就是這樣。",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_010"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我已經不想要再被口水沾得滿身都是了啦！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "所以我才會躲在天花板裡，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "或是偷偷藏在床底下……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "真是夠了！",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n明明才想說終於獲得了自由，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n結果託那兩人的福現在我又得躲躲藏藏了啦！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說妳呀～",
        "unit_id": 106012,
        "voice": "vo_adv_2103001_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別因為自己小小一隻就一個人在那邊躲來躲去啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也不想想每天尾巴被她們咬來咬去的我是什麼心情啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "有什麼關係～又不會少塊肉！",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_013"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "而且妳其實",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "意外地挺享受的不是嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈、",
        "unit_id": 106012,
        "voice": "vo_adv_2103001_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈啊！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那哪有可能啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳以為我是變態喔——！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯～",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_015"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "可是可是～？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "當{player}他和妳打鬧來打鬧去時～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n難道妳不會回想起親額頭的那件事～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "然後弄得自己心裡小鹿亂撞的嗎～？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔……",
        "unit_id": 106012,
        "voice": "vo_adv_2103001_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個嘛，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呀哈哈！",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_017"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n討厭呀～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "凱留就是",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "一隻變態可疑喵咪～☆",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啥……",
        "unit_id": 106012,
        "voice": "vo_adv_2103001_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "小心我宰了妳喔！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不如說看我宰了妳！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看我怎麼把妳做成蝴蝶一樣的標本拿來當擺設啦妳這個性騷擾妖精～！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼、",
        "unit_id": 106012,
        "voice": "vo_adv_2103001_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有種……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要飛來飛去的啊……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……呼、",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_020"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哈啊……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好久沒有",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "一下慘叫一下飛來飛去的，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "都快喘不過氣了……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "話又說回來……",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_021"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我們鬧得這麼誇張了，結果誰都沒有來看，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n今天果然",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "只有妳一個人嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～",
        "unit_id": 106012,
        "voice": "vo_adv_2103001_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在王宮工作……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔和雪菲還有{player}，",
        "unit_id": 106012,
        "voice": "vo_adv_2103001_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n則是去【咲戀育幼院】了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好像【小小甜心】的那群孩子們也有跟著一起去的樣子。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "育幼院……",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_024"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊啊。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n記得是",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "要找孩子們一起在那邊開讀書會對吧？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "所以，怕生的妳這傢伙就被留下來當看門貓了對吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吵死了！",
        "unit_id": 106012,
        "voice": "vo_adv_2103001_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我只是討厭小鬼們哇哇嘎嘎亂叫覺得很吵而已啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是是。",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_026"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……所以，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那麼",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n【破曉之星】那幾個孩子也跟著去了？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒。",
        "unit_id": 106012,
        "voice": "vo_adv_2103001_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那三人組……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在的話",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在索爾之塔唷。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哦？",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_028"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n為什麼？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽說好像",
        "unit_id": 106012,
        "voice": "vo_adv_2103001_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是想要調查什麼。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "似乎還被似似花拜託了事情的樣子。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哼嗯……",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_030"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n……索爾之塔",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……菲歐那傢伙。",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_031"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n最近這陣子，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不管我怎麼叫她，都一點反應也沒有呢。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "而且她也完全沒主動聯絡我呀。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "難道說……",
        "unit_id": 190911,
        "voice": "vo_adv_2103001_032"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "她發生了",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "什麼事了嗎……？　",
        "unit_id": 190911
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "另一方面，同一時間……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}一行人與美美、禊、鏡華"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一同造訪了【咲戀育幼院】。"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "吼～唷～",
