        "voice": "vo_adv_2103001_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n儘管有些不好意思……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就讓在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來擔任各位的老師一職吧。",
