        "voice": "vo_adv_2103001_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "先從有關於各位所生活的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
