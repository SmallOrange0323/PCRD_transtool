    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "但是為什麼？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "根據史書的記載……",
