        "voice": "vo_adv_1027010_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "剛剛",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "似乎聽見了……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n很像三流惡棍會發出的慘叫聲呢……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n是我聽錯了嗎？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "應該是吧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "話說回來，{player}大人，",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這片森林",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "意外地沒有盜賊跟盜獵者出沒，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "顯得很和平呢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然跟之前的牢房生活不一樣，",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但感覺",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也能算是另一種……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "兩人世界呢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻……♪",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我會盡全力討伐魔物，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但在那之前……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n讓我們好好享受兩人獨處的時間吧……♪",
        "unit_id": 102711
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼……",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們必須靠這附近的食材過上一陣子。",
        "unit_id": 102711
    },
