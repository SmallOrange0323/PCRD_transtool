    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不能這樣做……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就算我們注定會相結合，",
