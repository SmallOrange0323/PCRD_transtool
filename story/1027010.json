        "type": "dialogue",
        "name": "惠理子",
        "words": "不，",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我絕對沒有在逞強！",
