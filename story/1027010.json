    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "做這麼大膽的事……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……雖然這麼說。",
