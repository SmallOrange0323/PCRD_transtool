    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "別、",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_036"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "別這麼說……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒有您想得",
