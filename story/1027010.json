        "voice": "vo_adv_1027010_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好吃嗎？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我想味道絕對不會差的，對吧？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……♪",
