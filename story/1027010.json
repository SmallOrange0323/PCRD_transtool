        "voice": "vo_adv_1027010_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "會在這種時候，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n發現大人您喜歡吃的一種食物呢。",
        "unit_id": 102711
    },
