    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "我猜是剛才洗劫商人時，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "他掉的商品吧？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "\n那就趕緊",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "來看看……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "怎、",
        "unit_id": 811,
        "voice": "vo_adv_1027010_011"
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "怎麼回事！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "突然冒出一團煙！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "\n這是……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "毒氣～～！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "嗚啊啊～～",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "～！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
