        "voice": "vo_adv_1027010_033"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n如果沒有一起生活，就不會注意到吧……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻……♪",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我還以為已經把您的一切都調查透徹了，",
