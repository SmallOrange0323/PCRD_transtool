        "voice": "vo_adv_1027010_013"
    },
    {
        "type": "dialogue",
        "name": "盜獵者",
        "words": "怎麼……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "盜獵者",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "盜獵者",
        "words": "突然變得……",
