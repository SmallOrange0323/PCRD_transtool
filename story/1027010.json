        "voice": "vo_adv_1027010_014"
    },
    {
        "type": "dialogue",
        "name": "走私商1",
        "words": "這、",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "走私商1",
        "words": "這是怎樣啦……！？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "走私商1",
        "words": "\n整個身體都麻掉了～～～！？",
        "unit_id": 6311
    },
    {
