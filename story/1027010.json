        "voice": "vo_adv_1027010_028"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您的袖口破掉了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓我好好看看。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "跟我想的一樣……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "誰叫您總是隨意把手伸進草叢呢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真拿您沒辦法……",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我來幫您縫好。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請到我的身邊來……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您暫時不要亂動。",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我很擅長裁縫，",
