    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼厲害。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n既然是要縫補大人的衣服，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就要弄得跟全新的一樣……",
