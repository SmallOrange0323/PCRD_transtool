        "voice": "vo_adv_1027010_034"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n看來還有很多我不知道的事情呢……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……來，",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_035"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我縫好了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要是再弄破的話，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我可要懲罰您喔？",
