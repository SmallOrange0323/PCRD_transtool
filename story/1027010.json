[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與惠理子，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n決定討伐長得跟惠理子一模一樣的魔物。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了執行某項作戰，兩人來到蘭德索爾附近的森林。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呼……",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們走了很長一段路。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看您一臉疲倦的表情，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "身體不要緊嗎？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "畢竟在牢房中過了一陣子的照護生活，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓您有點運動不足呢……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們就快到了，",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "再加油一下吧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "入口就在",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那塊草叢附近，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "前進時",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還請您留意腳邊。",
        "unit_id": 102711
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來，",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人請進。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "先把行李放在那邊，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好好地",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "休息一下……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……話是這麼說，",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但這裡不過是我用來存放在森林採集的植物，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n以及做一些簡單研究的藏身處之一。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n實在算不上是舒適的地方……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這麼做",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真的好嗎？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了把魔物引到沒有人的森林，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n竟然把自己當成誘餌……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "很危險……？",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n啊啊，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "說得也是。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "當我下次碰到它時，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "可能會氣到想把一切都破壞掉。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了不辜負您的溫柔體貼……",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我絕對不會讓魔物",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對您伸出毒手。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我已經在半路上設下各種機關，",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n絕對不會",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓魔物有機會靠近您……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻♪",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒錯……",
        "unit_id": 102711,
        "voice": "vo_adv_1027010_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要做就要徹底。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "徹底到",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓人根本無法靠近這片森林……！！",
        "unit_id": 102711
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "嘻嘻嘻！",
        "unit_id": 811,
        "voice": "vo_adv_1027010_009"
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "這片森林果然最適合搶劫了～",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "\n由於沒什麼魔物，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "商人們經過時，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "\n也都不會找保鑣……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "喔？",
        "unit_id": 811,
        "voice": "vo_adv_1027010_010"
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "這個是……",
