        "voice": "vo_adv_1027010_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就只吃這種山菜吧！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我會",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "煮成山菜鍋，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n還請您盡情",
