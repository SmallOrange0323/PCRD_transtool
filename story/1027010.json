        "voice": "vo_adv_1027010_039"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "隨身物品，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還是身體……！！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我會將所有的縫合技巧都學到極致……！！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻……♪",
