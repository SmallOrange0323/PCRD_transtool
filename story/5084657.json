[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106412,
        "voice": "vo_adv_5084657_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "仍然",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在睡呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……那個呀。",
        "unit_id": 106412,
        "voice": "vo_adv_5084657_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n今天我一個人走在街上時，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "被店家搭話，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n問說「平常那位小兄弟怎麼沒跟妳在一起？」呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "當下，",
        "unit_id": 106412,
        "voice": "vo_adv_5084657_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我深刻體會到你此時已不在我身邊，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n讓我感到非常悲傷……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也不知為何，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "感到十分害怕。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "畢竟我已經把有你在身邊，視為理所當然的事。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要是你就這樣，",
        "unit_id": 106412,
        "voice": "vo_adv_5084657_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一直沉睡不醒……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我不禁",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就浮現這個想法。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過呢。",
        "unit_id": 106412,
        "voice": "vo_adv_5084657_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "相信著。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n如果是你，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一定會立刻回到這裡的，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我相信你。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我會和大家一起",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等著你回來。",
        "unit_id": 106412
    }
]