[
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了收齊年度活動紀錄而去到各地的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n造訪了【龍族巢穴】的公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼！",
        "unit_id": 106611,
        "voice": "vo_adv_9004003_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "無論何時，這張椅子坐起來都一樣舒服！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n現在雖然歸老大所有，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但我總有一天會搶回來的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "話說回來……",
        "unit_id": 106611,
        "voice": "vo_adv_9004003_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老大還是老樣子，總是把奇奇怪怪的東西堆在桌上……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有種會弄壞這些東西的感覺……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣不就沒辦法安心坐著了嗎！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真希望老大多少能顧慮一下！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀啊啊啊～！？",
        "unit_id": 106611,
        "voice": "vo_adv_9004003_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該不會是老大……！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "糟糕了，得趕快躲起來……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "壺又……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊哇哇哇哇……！",
        "unit_id": 106611,
        "voice": "vo_adv_9004003_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n完、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "完完完、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "完蛋啦──！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！？",
        "unit_id": 106611,
        "voice": "vo_adv_9004003_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才不是「搞砸了呢……」",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n還不是因為你忽然出現，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嚇了我一跳！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼辦……？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "絕對瞞不住的，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還會被罵……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "總之，",
        "unit_id": 105511,
        "voice": "vo_adv_9004003_005"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "先收拾這些碎片，免得其他人踩到受傷……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n然後，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只能真誠地去道歉了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀啊啊啊啊～～～！？",
        "unit_id": 106611,
        "voice": "vo_adv_9004003_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這次真的是老大！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "原來是步未啊！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n妳到底是從哪裡跑出來的？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對、",
        "unit_id": 105511,
        "voice": "vo_adv_9004003_007"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對不起！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我只是注視著前輩，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一不小心就跟到這裡了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不好意思，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我太沒有存在感了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "步未還是一樣呢……",
        "unit_id": 106611,
        "voice": "vo_adv_9004003_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "話說，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n現在不是說這種事的時候了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n得在老大察覺前收拾好才行……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你說得沒錯。",
        "unit_id": 106511,
        "voice": "vo_adv_9004003_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "反正祈梨一直以來都是這樣搞砸事情的，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這次就誠懇地去道歉，不就好了？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀！？",
        "unit_id": 106611,
        "voice": "vo_adv_9004003_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……這次是嘉夜夜啊。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "每個人都在嚇我，很困擾耶！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要不被發現就好了，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要趕快收拾一下，裝作不知道的話……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "祈梨是這麼說的……",
        "unit_id": 106511,
        "voice": "vo_adv_9004003_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n老大，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "該怎麼辦？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯～",
        "unit_id": 106711,
        "voice": "vo_adv_9004003_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣呀～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只要多少展現一下誠意的話，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n倒可以有酌情處理的餘地呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "祈梨？",
        "unit_id": 106711,
        "voice": "vo_adv_9004003_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我們",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "去裡面的房間一下吧☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫～！",
        "unit_id": 106611,
        "voice": "vo_adv_9004003_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "幫幫我啦～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要小哥沒有忽然出現的話，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "事情就不會變成這樣的～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我覺得是兩回事哦～",
        "unit_id": 106711,
        "voice": "vo_adv_9004003_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "說到底，假如祈梨",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒有擅自進我的房間，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就不會引發任何狀況了呀～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗚……",
        "unit_id": 106611,
        "voice": "vo_adv_9004003_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我討厭太難受的哦！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n老大會溫柔對待我的，對吧！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 106711,
        "voice": "vo_adv_9004003_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對了。{player}",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個給你。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這是公會管理協會委託的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "活動紀錄哦。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那就再見啦～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈！",
        "unit_id": 106511,
        "voice": "vo_adv_9004003_018"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還是老樣子啊，祈梨。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳成為Big Boss的那一天",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的會到來嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一邊窺見【龍族巢穴】的日常，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一邊想像著大家的未來樣貌，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}前往了下一個目的地。"
    }
]