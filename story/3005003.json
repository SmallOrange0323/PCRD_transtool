[
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "莉瑪，讓妳揹著我，",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真是不好意思。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳果然不喜歡，",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n像這樣被當作騎乘動物吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒關係沒關係，不要在意啦。",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "自從來到這座牧場後，餐餐都好吃，害我都變胖了，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n必須要瘦身呢～",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "而且啊，",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n小栞，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n妳最近身體狀況好像不太好。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳的身體，",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n本來就是必須要安靜休息。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳不就是來牧場靜養的嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我可不會讓，",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n體弱多病的孩子逞強的喔。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果妳在這不好走的路上，",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n突然眼花還是怎樣的就昏倒了……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n可能會就這樣死在路邊呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這點小事，我來幫忙就好。",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n有問題就儘管找我吧，有困難就要互相幫助♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝妳……",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是，我會不會很重啊？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "完全不會啊。",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我力氣很大。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小栞就跟羽毛一樣輕呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳這麼瘦，真讓我羨慕～",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大概，只有我體重的四分之一而已吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我只是因為不健康而消瘦而已……",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不知道是不是腸胃不好的關係，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不管吃什麼都不會長肉。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我就想像莉瑪一樣，",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n有個健壯的體魄。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的頭髮，也因為水分不足而毛毛燥燥的。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我好想要有一頭，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n像莉瑪一樣健康而蓬鬆的頭髮……♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "討厭啦，我好開心！",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_014"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小栞好會讚美人，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n多讚美我一點～♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……哎喲。",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "現在不可以太大意，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n只顧著聊天呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "再怎麼說，",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我也是為了守護牧場和平來巡視的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "該注意有沒有危險的魔物之類的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我有在注意，沒問題的。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牧場跟周圍的區域算是很平靜的地方。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "本來，",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n就不太需要這麼戒備。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為牧場的警衛，",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n就是我們【哞哞自衛隊】的工作。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "平常都受你們照顧，我也要好好盡我的本分。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果等到出事了，就為時已晚了。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以每天，都必須好好的巡視。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但是啊，",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n這本來不是小栞，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n而是小鈴的工作吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是這樣沒錯啦。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過，我也是【哞哞自衛隊】的一員。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也受了鈴的照顧。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n她明明沒什麼意願，還被強迫工作，也是很可憐。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且……我也想感謝牧場的各位，",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "給了我新鮮的空氣、美味的食物，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還有安穩平靜的生活。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小栞真是個好孩子……",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_025"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "正因如此，妳可要好好恢復健康，得到幸福喔。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "有什麼我可以幫妳的，都可以跟我說喔？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝妳，莉瑪。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……咦，稍微停一下。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "怎麼了嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯，不知道是不是錯覺……",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我覺得，這景色好像有點奇怪。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不好意思，我先下來一下。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嘿咻。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我調查一下這附近。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……果然。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只有這周圍很奇怪地荒禿了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "樹幹凹下去了，地面也到處都坑坑疤疤的。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_031"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不曉得是不是有魔物在這裡爭地盤。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯？",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_032"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這個味道是……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "唉、唉呀？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小栞！？",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_033"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒事。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n莉瑪，請別靠近。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是魔物，雖然好像還小。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_035"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但很暴躁的樣子……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果隨便亂動的話很危險。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我用弓箭，",
        "unit_id": 103812,
        "voice": "vo_adv_3005003_036"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n把牠解決了吧。",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "等一下！",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_037"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n這魔物還是小孩子吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "牠好可憐，不要殺牠啦！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這種魔物很危險，",
        "unit_id": 103812,
        "voice": "vo_adv_3005003_038"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n如果長大了就很難擺平了。",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "為了守護牧場的和平，",
        "unit_id": 103812,
        "voice": "vo_adv_3005003_039"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我必須要除去禍亂的根源。",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……對不起。",
        "unit_id": 103812,
        "voice": "vo_adv_3005003_040"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你可以怨恨我，",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n但是這就是個弱肉強食的世界。",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我不想死。",
        "unit_id": 103812,
        "voice": "vo_adv_3005003_041"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不……",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想活下去，",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以我不能放過危險的魔物。",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 103812,
        "voice": "vo_adv_3005003_042"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "怎、怎麼了嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_043"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呃，那個。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_044"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不知道為什麼，這魔物跑來磨蹭我的腳邊。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠這麼接近我，我很難用弓箭瞄準。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哈哈哈，好可愛。",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_045"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n這孩子在對小栞撒嬌♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這魔物好像貓呢～",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_046"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n因為小栞也像貓，所以才萌生了親近感吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不，或許牠把小栞當作媽媽了吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我不是貓，而是老虎的獸人。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_047"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……怎、怎麼辦呢？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠這樣親近我……",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_048"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n讓、讓我很難把牠解決掉了呢",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯～……雖然我可能比較天真，",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_049"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n但是就算不勉強把牠解決掉應該也還好吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "反正，這傢伙大概也沒辦法活那麼久。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳瞧，才覺得牠拖著自己的腳……",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_050"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n牠受了很嚴重的傷呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳看。",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_051"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n在草木叢那邊，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n有跟這傢伙同種的魔物屍體。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大概是牠的父母吧。",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_052"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不知道是不是爭地盤爭輸了，就這樣喪命……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n這傢伙也似乎因此身負重傷。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "少了父母的庇蔭，",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_053"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n實在很難在這殘酷的環境下成長茁壯。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n遲早都會死掉的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以啊，",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_054"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒有讓小栞扮黑臉、",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n硬是自己雙手染血的必要。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不論說是本分、還是因為職責……",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_055"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這都跟那些事情沒關係。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n小栞想怎麼做，就怎麼做吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不然，",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_056"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n小栞可能就會因此後悔呢。",
        "unit_id": 105211
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_057"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我回來啦～♪",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_058"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，歡迎回來～……",
        "unit_id": 102611,
        "voice": "vo_adv_3005003_059"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳們兩個，走去哪裡啦？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小栞她",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_060"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n剛剛去幫妳巡視牧場呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我，則是她的守護者。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "先不管這些，趕快去燒熱水。",
        "unit_id": 105211,
        "voice": "vo_adv_3005003_061"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n還有，可以去準備繃帶過來嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，為什麼？",
        "unit_id": 102611,
        "voice": "vo_adv_3005003_062"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n小栞，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n該不會受傷了吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不好了……！",
        "unit_id": 102611,
        "voice": "vo_adv_3005003_063"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真、真陽～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n把急救箱拿過來，快一點！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？",
        "unit_id": 103311,
        "voice": "vo_adv_3005003_064"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n怎麼啦，發生什麼事了？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我沒事……",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_065"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n受傷的不是我，是這個小傢伙。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呃真陽，妳有辦法救治魔物嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "魔物？",
        "unit_id": 103311,
        "voice": "vo_adv_3005003_066"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要看是什麼種類，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不過是動物型的話都是有辦法的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "畢竟這種魔物跟普通的動物沒有那麼不一樣。",
        "unit_id": 103311,
        "voice": "vo_adv_3005003_067"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我呀，很習慣治療動物的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯啊……",
        "unit_id": 103311,
        "voice": "vo_adv_3005003_068"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這看起來像貓的魔物，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n是妳們撿回來的嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不，與其說是撿回來的……",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_069"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n是牠賴在我身邊，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我沒辦法擺脫牠。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就算要丟下牠不管，牠也會跟過來。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_070"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "總覺得也沒辦法棄之不顧。",
        "unit_id": 103811
    },
    {
        "type": "still",
        "still": "300500301"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔。",
        "unit_id": 102611,
        "voice": "vo_adv_3005003_071"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我要看我要看，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是什麼樣的魔物？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "喔～滿可愛的。",
        "unit_id": 102611,
        "voice": "vo_adv_3005003_072"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n看起來跟貓沒兩樣嘛，要養牠嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "魔物都吃什麼啊，",
        "unit_id": 102611,
        "voice": "vo_adv_3005003_073"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我可是不會給牠我的橡子唷？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呃，也不是說養……",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_074"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "各位請安心，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我一定會解決掉牠的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～",
        "unit_id": 103311,
        "voice": "vo_adv_3005003_075"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n也不用硬是要把牠解決掉啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "魔物也不是不分青紅皂白地都很危險的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_3005003_076"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也有一些給人馴化，成為好幫手的例子喔？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只要用愛心養育牠，",
        "unit_id": 103311,
        "voice": "vo_adv_3005003_077"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n牠一定會給栞栞報恩的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們的畜舍還有空位，",
        "unit_id": 103311,
        "voice": "vo_adv_3005003_078"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就養在那裡吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔～好可憐……",
        "unit_id": 103311,
        "voice": "vo_adv_3005003_079"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n真是嚴重的傷呀。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我現在就來救你囉，小乖乖♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎喲！？",
        "unit_id": 103311,
        "voice": "vo_adv_3005003_080"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牠可是充滿戒心的啦，我差點就被咬了……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牠怎麼好像只喜歡親近栞栞呢？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是呀，為什麼呢……",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_081"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "無論如何，請告訴我治療的方法，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我來為牠治療吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這是我撿來的生命，",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_082"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n要讓牠活還是死是我的責任。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "小栞～",
        "unit_id": 102611,
        "voice": "vo_adv_3005003_083"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n幫牠取個名字啦，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n可愛的名字♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "取了名字之後，",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_084"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n要解決掉牠就會變得不容易了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過，沒有名字的話也很不方便呢。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_085"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我來隨便想一個。",
        "unit_id": 103811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……對不起喔。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_086"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有一天，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我說不定會把你解決掉。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "魔物，",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_087"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n是個蹂躪踐踏一切生命的邪惡存在，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因此沒有辦法與我們共存。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我有一天，",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_088"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n也說不定會為了",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n救過你一命而後悔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是現在，我先放你一條生路。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_089"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不能說是在幫你，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n或許我只是在做更殘忍的事。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你如果就那樣",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_090"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n落魄死在父母的身邊……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n說不定會幸福許多。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "跟被你這麼親近、",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_091"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這樣依賴的我殺死，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n相比的話。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過，",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_092"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我們並非完全不可能和平共處。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我衷心希望如此。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "依偎在我身邊的你，體溫是如此溫暖。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_093"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我好像也無法奪走你生命的溫度。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你不可以死。好好活下去。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_094"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n直到你變成我們的敵人……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "變成真正的魔物，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n也就是我把你解決掉的那一天。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也會為了負起留你活路的責任……",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_095"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n當你變成危險魔物的時候，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我一定會將你徹底解決掉。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你一定可以活下去，",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_096"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n直到那一天為止。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就這麼說定囉。",
        "unit_id": 103811,
        "voice": "vo_adv_3005003_097"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……嗯，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喵特♪",
        "unit_id": 103811
    }
]