    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天的「蘭德索爾時光」",
        "unit_id": 100111,
        "voice": "vo_adv_9008011_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也是以公開錄製的方式呈現給大家♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但在開始之前，",
        "unit_id": 100111,
        "voice": "vo_adv_9008011_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要先發布尋人啟事！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這裡有名穿著白衣，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "年約八歲的小男孩！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n請他的父母",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "趕快來公開錄製會場接他喔～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好乖好乖，",
        "unit_id": 105812,
        "voice": "vo_adv_9008011_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒事的喔～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你的家人馬上就會來接你囉。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵，",
        "unit_id": 105812,
        "voice": "vo_adv_9008011_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "去年的聖誕節時，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也照顧了一個小寶寶。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這讓我想起了當時的事呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小寶寶非常黏",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來是這樣啊！？",
        "unit_id": 100111,
        "voice": "vo_adv_9008011_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當時我看到克蕾琪塔小姐，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好幾次在會場內東奔西跑……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n沒想到她甚至還在照顧小寶寶啊！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯☆",
        "unit_id": 105812,
        "voice": "vo_adv_9008011_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她也很努力地在為這個廣播做準備，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真的非常可靠！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗚",
        "unit_id": 111,
        "voice": "vo_adv_9008011_006"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "～哇……！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "媽媽～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這、",
        "unit_id": 105812,
        "voice": "vo_adv_9008011_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這下傷腦筋了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他一定很不安吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有道理！",
        "unit_id": 100111,
        "voice": "vo_adv_9008011_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "畢竟他是來看公開錄製的嘛♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "難得來了，就別只是參觀而是實際參加錄音吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你願意幫我們嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "咦？",
        "unit_id": 111,
        "voice": "vo_adv_9008011_009"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我嗎？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗯、",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗯！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我要幫忙！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我會加油！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦……！",
        "unit_id": 105812,
        "voice": "vo_adv_9008011_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真棒呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天就四個人一起錄製吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就一起喊，",
        "unit_id": 105812,
        "voice": "vo_adv_9008011_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「蘭德索爾時光……」",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "要開始囉～！",
        "unit_id": 111,
        "voice": "vo_adv_9008011_012"
    },
