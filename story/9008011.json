        "name": "導演",
        "words": "有新聞，",
        "unit_id": 1,
        "voice": "vo_adv_9008011_013"
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "請插播。",
        "unit_id": 1
    },
    {
