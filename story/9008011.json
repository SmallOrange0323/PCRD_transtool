        "words": "在下看看……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是現在接到的新聞。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n「公主連結慶典2024」，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即將舉行……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今年也會是個",
        "unit_id": 105913,
        "voice": "vo_adv_9008011_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常有趣的活動吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望各位都能玩得開心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總覺得",
        "unit_id": 105913,
        "voice": "vo_adv_9008011_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有種像新年般的興奮感覺。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n各位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "屆時請務必收看喔。",
        "unit_id": 105913
    }
