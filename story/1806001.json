[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "扛著東西走在街上的{player}，\n遇見了凱留。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你又在打工送貨了嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才剛從嬰兒變回來就開始工作，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還真有你的風格呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……咦？",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然想說城鎮已經復原不少了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但還是有災情慘重的地方呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "【憤怒‧軍團】的傢伙們也三不五時就引起騷動，",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要完全恢復原狀是不可能的嗎。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也來幫你搬那些東西吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n稍微分我一點。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然你都拿得動了，",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那我也拿得動。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再說了，",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是我給大家添了麻煩，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n來幫忙重建也是天經地義……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了快點拿過來！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個要搬到哪裡去？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還有人在等著呢，快點搬過去吧！",
        "unit_id": 106012
    },
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哦～！",
        "unit_id": 311,
        "voice": "vo_adv_1806001_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "等你們很久了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "快快，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "把你們搬過來的建材放在這裡吧！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "咦？",
        "unit_id": 311,
        "voice": "vo_adv_1806001_008"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "難道說旁邊的這位女性……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不就是以前在這裡工作過的調教師小姐嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我說，",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n該不會，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我工作過的魔物大賽會場？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種地方有需要重建嗎啊啊啊！！",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這麼說來，",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個變態在哪裡？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像沒有看到他的身影。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊，",
        "unit_id": 311,
        "voice": "vo_adv_1806001_013"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "老闆他因為先前發生的戰鬥…………",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道說……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "需要籌措重建會場的修理費，",
        "unit_id": 311,
        "voice": "vo_adv_1806001_015"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "正在大陸各地\n奔走唷。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "一邊埋頭苦幹，一邊感受著勞動的喜悅呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎～～～～",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然是那樣的變態，不過人沒事真是太好了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是，",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡也因為那場戰鬥而毀損了呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就是啊。",
        "unit_id": 311,
        "voice": "vo_adv_1806001_018"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n而且這裡雖然說是政府公認的，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但畢竟是娛樂設施呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n所以沒有分配到重建的預算，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "遲遲無法修復。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "老闆他拚了命地奔波，",
        "unit_id": 311,
        "voice": "vo_adv_1806001_019"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n好不容易才有了重新開張的希望。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也是有人很喜歡這樣的地方呢。",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "希望能早點恢復營業就好了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "東西也送到了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們就先告辭了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "請等～～～～",
        "unit_id": 311,
        "voice": "vo_adv_1806001_021"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "一下！！！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什、",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要突然那麼大聲嚇人啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是我們搬來的東西有問題嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不，",
        "unit_id": 311,
        "voice": "vo_adv_1806001_023"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "東西沒有任何問題。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "只是，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "既然調教師小姐在的話，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我還有一個不情之請。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要我幫忙？",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n嗯，反正也算是幫忙重建，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你就說說看是什麼事吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "如您所見，會場的重建正順利進行著，",
        "unit_id": 311,
        "voice": "vo_adv_1806001_025"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但是比賽用的魔物卻不夠呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "希望能拜託您這位厲害的調教師協助，",
        "unit_id": 311,
        "voice": "vo_adv_1806001_026"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n幫忙捕捉魔物。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是，",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然我是很想幫忙啦……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下！",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你幹嘛擅自回答啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你也知道的吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我已經沒有",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "操控魔物的力量了喔？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本就沒辦法好好完成這個委託吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼？",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說起來好像是這樣沒錯。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這裡的人什麼力量都沒有，卻在抓魔物呢……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是，",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算你跟我說這種毫無根據的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n辦不到的事情就是辦不到啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再說了，是你說要做的，",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那你就自己一個人去……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我要是說了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你肯定會真的自己一個人去辦對吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "知道了，",
        "unit_id": 106012,
        "voice": "vo_adv_1806001_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
