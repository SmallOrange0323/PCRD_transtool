    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好，",
        "unit_id": 106011,
        "voice": "vo_adv_1806001_069"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣就完成任務了呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒事嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有沒有受傷？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不是說魔物，是在擔心你啊……",
        "unit_id": 106011,
        "voice": "vo_adv_1806001_070"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都沒事就好。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接下來只要把魔物交給那個人就好。",
        "unit_id": 106011,
        "voice": "vo_adv_1806001_071"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "走吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "歡迎回來，",
        "unit_id": 311,
        "voice": "vo_adv_1806001_072"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "兩位沒事真是太……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "呃，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那個魔物是！？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什、",
        "unit_id": 106011,
        "voice": "vo_adv_1806001_073"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這是很難照料的魔物，",
        "unit_id": 311,
        "voice": "vo_adv_1806001_074"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但是如果能好好地讓牠跑起來的話，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n是任何魔物都只能望其項背的最棒魔物啊！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哇──！",
        "unit_id": 311,
        "voice": "vo_adv_1806001_075"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "牠跑起來一定會讓觀眾為之沸騰的！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n太厲害了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "沒想到您會抓來這麼厲害的魔物！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是、",
        "unit_id": 106011,
        "voice": "vo_adv_1806001_076"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是這樣嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能讓你滿意就好。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在這之後重新展開的大賽受到觀眾們的熱烈歡呼所包圍。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在喧囂大賽會場的一旁，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n凱留的臉上浮現了滿足的笑容。"
    }
