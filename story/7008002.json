        "voice": "vo_adv_7008002_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n露娜之塔探索得很順利。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可說是一盤風筍呢～！",
        "unit_id": 101112,
        "voice": "vo_adv_7008002_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦？",
        "unit_id": 103811,
        "voice": "vo_adv_7008002_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n那個，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳是要說",
        "unit_id": 103811,
        "voice": "vo_adv_7008002_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一帆風順",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "吧……？　",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦咦！？",
        "unit_id": 103811,
        "voice": "vo_adv_7008002_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "以這個進度繼續努力的話，",
        "unit_id": 101112,
        "voice": "vo_adv_7008002_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥很快",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就能恢復記憶了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "長久以來的努力",
        "unit_id": 101112,
        "voice": "vo_adv_7008002_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "終於可以獲得回報！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可說是如願伊嫦！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那、",
        "unit_id": 103811,
        "voice": "vo_adv_7008002_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那是哪位誰啊……！？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳要說的是",
        "unit_id": 103811,
        "voice": "vo_adv_7008002_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「如願以償」",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "吧……！？　",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以說",
        "unit_id": 103811,
        "voice": "vo_adv_7008002_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那是誰啊……！？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我很少離開城鎮所以不太清楚，",
        "unit_id": 103811,
        "voice": "vo_adv_7008002_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "難不成",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "像這樣故意說錯成語是",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "最近的流行趨勢嗎……？　",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "既然如此，",
        "unit_id": 103811,
        "voice": "vo_adv_7008002_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也來試試……！　",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過",
        "unit_id": 103811,
        "voice": "vo_adv_7008002_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "接下來的路途還很漫長，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們還是要多加小心。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "正、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "正所謂……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "疏忽",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會是命……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊哈哈，",
        "unit_id": 101112,
        "voice": "vo_adv_7008002_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳說錯了喔～",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "小栞。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "正確說法是",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "疏忽會致命",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "吧～？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦……？　",
