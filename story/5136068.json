[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾商圈林立著各式各樣的商店。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n志那都站在其中一間店前，盯著擺放在門口的商品。"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "《輕鬆學習皇族歷史》……",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_000"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "《蘭德索爾漫遊指南》……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……閱讀這一區的書，",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_001"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就能瞭解這邊的世界，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n或許也不錯呢。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "雖然我不能待在這裡太久……",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_002"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n但是這樣或許也有助於",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "讓我跟怜他們能夠順利對話。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "還有……",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_003"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "《冥風戰記》，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這是小說吧。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不過這位作者的名字，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我好像在哪看過……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "莫非……",
        "unit_id": 100911,
        "voice": "vo_adv_5136068_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳也是",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對魔導書有共鳴的盟友之一，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n受「魔瞳」所指引的",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "宿命戰士嗎！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……嗯？",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那麼此番的邂逅",
        "unit_id": 100911,
        "voice": "vo_adv_5136068_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "必定也是宿命。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我也很歡迎",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳踏出邁向霸道的一步喔！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哈～哈哈哈！！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……她是這個世界的",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_007"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "安妮羅潔嗎？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n然後這本書，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n很有可能",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是她所寫的小說……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……原來如此。",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_008"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n她是看到好像有人對自己寫的小說有興趣，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n所以才來跟我搭話……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是吧。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "…………",
        "unit_id": 100911,
        "voice": "vo_adv_5136068_009"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我那個世界的安妮羅潔，",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_010"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n雖然也寫了有著獨特世界觀的小說……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n但她的外表和言行舉止",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "應該跟一般的少女沒什麼不同。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……不過，",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_011"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n這邊的安妮羅潔，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "似乎更加地",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n沉浸在自己描繪的世界裡。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "既然如此，我……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "啊、",
        "unit_id": 100911,
        "voice": "vo_adv_5136068_012"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "啊……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "抱歉，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嚇到妳了吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "請別介意，繼續購物──",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………原來如此。",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_013"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n這場邂逅不是偶然，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "而是必然嗎。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……！",
        "unit_id": 100911,
        "voice": "vo_adv_5136068_014"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我的風和妳的冥風……",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_015"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "之所以會相互交疊，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "一定是創世之時",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就注定好了……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "呢。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……這樣的感覺可以嗎？",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_016"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "在另一個世界裡，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "安妮羅潔所寫的小說，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n應該也是一樣的文體……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……她都來向我搭話了，",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_017"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那就不能無視。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我已經盡我所能地表現出敬意……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n難道是我搞錯了嗎？　",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哈～哈哈哈！",
        "unit_id": 100911,
        "voice": "vo_adv_5136068_018"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我的「魔瞳」果然沒有看走眼！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "既然妳有投身於無盡鬥爭的覺悟，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我就歡迎妳吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n歡迎妳加入我疾風之冥姬的",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "無盡鬥爭輪迴！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "看來是對的嗎…………",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_019"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "太好了。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳的雙眼中，",
        "unit_id": 100911,
        "voice": "vo_adv_5136068_020"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也寄宿著和我相同的意志。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那是打算殲滅任何阻擋自身霸道的敵人，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "魔王的意志。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "在這個世界之中，",
        "unit_id": 100911,
        "voice": "vo_adv_5136068_021"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳的力量很明顯地不同……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳身上穿著的漆黑裝束",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "彷彿就是那股力量的體現。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "根本無法掩蓋住滿溢而出的",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "魔力波動……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……莫非，",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_022"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "她是在說衣服的事嗎？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n確實……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n或許有和她的品味",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "相通的地方。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……我的存在，",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_023"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n是出自黑暗，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "並回歸黑暗。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我的姿態",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "也不過是象徵那道黑暗罷了……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "僅此而已。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喔喔！",
        "unit_id": 100911,
        "voice": "vo_adv_5136068_024"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "誕生於冥府深淵的黑暗劍士啊。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n報上",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳的名來吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……志那都。",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_025"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n這是我",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "於現世所現之身被賦予的",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "偽名。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………這種說話方式",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_026"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "意外地好溝通呢。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "因為用字遣詞很困難，",
        "unit_id": 135614,
        "voice": "vo_adv_5136068_027"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "所以在說出口之前必須先思考過。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……這種節奏，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "或許很適合不擅說話的我。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "志那都，",
        "unit_id": 100911,
        "voice": "vo_adv_5136068_028"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我就讓妳",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "見識一下更漆黑的深淵吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "具體而言，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就是我要鉅細靡遺地",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n把我親自創作的敘事詩從起源開始──",
