        "voice": "vo_adv_5100321_001"
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "不要再管我了！",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "\n我已經",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "不想跟任何人說話了！",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "回去！",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "如果你們不回去……",
        "unit_id": 16613,
