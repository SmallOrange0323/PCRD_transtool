        "voice": "vo_adv_5100321_004"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "沒有這個選項對吧？",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音、",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "公主！」",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "當然了。",
        "unit_id": 123111,
        "voice": "vo_adv_5100321_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一定要在這裡阻止羊先生才行。",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然希望",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "盡可能不要太粗魯……",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但現在似乎沒辦法說這種話呢。",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "魔物先生小姐們，",
