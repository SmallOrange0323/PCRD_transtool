[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀～",
        "unit_id": 105811,
        "voice": "vo_adv_9019156_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次總算大功告成了吶☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n盜賊團整團，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都討伐完成了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過說起來，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "幹勁十足的小可蘿，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也相當可愛呢……♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是十分抱歉……",
        "unit_id": 105911,
        "voice": "vo_adv_9019156_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為一時激動如此不合規矩地引人注目。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是開墾村落的各位",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的努力，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這幾天在下\n一直看在眼裡，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絕不允許有人踐踏他們的努力。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了好了，",
        "unit_id": 106011,
        "voice": "vo_adv_9019156_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過這次一定沒問題了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那麼，這隻惡賊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們要拿來怎麼辦呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙就任憑我們宰割了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要殺要刮都不會放過你的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔！",
        "unit_id": 105811,
        "voice": "vo_adv_9019156_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　小凱留也終於對享用魔物感興趣了嗎…☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "相處這麼久，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總算也對美食產生了慾望，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是美食之愛的恩典！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "趁還新鮮的時候趕快……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，",
        "unit_id": 106011,
        "voice": "vo_adv_9019156_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不是那個意思……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不是啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　如果讓妳以為我是想吃的話，我要更正這句話！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……等、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　聽我說啦～～！！",
        "unit_id": 106011
    }
