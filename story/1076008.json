[
    {
        "type": "background",
        "background": "501033"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夜幕降臨，海岸籠罩在一片寂靜之中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}和可可蘿眺望著海浪靜靜拍打岸邊。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海浪現在很平穩，",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們出發吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您準備好了嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……那麼，",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓在下來施展精靈的加護──",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哎呀？",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你們是……？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是……",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海之家的……？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "喔，",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_004"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "果然是你們。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "這麼晚了還待在海邊？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們接下來，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要前往被稱為",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「星海」的海溝。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "「星海」",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_006"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "啊……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n上次聽到這個名字……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "不知道已經是幾年前了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下聽說",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個地方在這一帶很有名……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "嗯。",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_008"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "之前是這樣沒錯。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n只是最近",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "都沒什麼人提起了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是怎麼一回事？",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n根據文獻記載，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那邊有著很棒的景色，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難道事實並非如此嗎……？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "不。",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_010"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "那裡過去確實就像文獻裡記載的一樣吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "妳應該知道那座海溝有獨特的海洋生物吧？",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_011"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "那些生物的",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "身體會發出光芒，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "就像是在歡迎來訪者一樣。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "發出的光芒能把附近一帶全都照亮……",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_012"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "彷彿就像是置身於繁星之中。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "所以，",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_013"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "那裡之前才會被稱為「星海」。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "不過，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "現在那些海洋生物已經不會發光了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼會……",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼會這樣呢？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "這也只是我聽說的……",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_015"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n那裡的海洋生物",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "目前似乎很衰弱……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "「星海」那個地方，",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_016"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "即使使用能在水中行動的魔法，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n要過去也相當不容易。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n所以，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "每年",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "觀光客的人數都在減少……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "住在那裡的生物",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_017"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "都很親人……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n所以，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "人越來越少，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "同時也讓牠們感到不安而日漸衰弱。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "這類的傳聞傳開之後，",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_018"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "去的人又更少了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "所以，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "「星海」現在已經",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "被人們遺忘了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這樣……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "就連最後一次聽說有人去，",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_020"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "都已經是好幾年前的事情了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n沒人知道那裡現在的情況。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "這樣你們還想去嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……當然要去。",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下已經",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "發誓要帶主人",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "前往「星海」了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知道那裡會有什麼景象在等著我們，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要有一絲可能性，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就想",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "過去親眼看看。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下身為嚮導的任務，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "同時也是主人的冒險。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "……這樣啊。",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_024"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "那我就沒有理由阻止你們了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "碰到你們也是緣分，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "跟我來吧。",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "500842"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感謝您",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "特地為了我們開船出海。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "嗯，",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_026"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "不用客氣啦。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "我通常都是開這艘船到海之家的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "只是稍微繞個路而已。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來運氣是站在我們這邊的。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這肯定是",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛梅斯大人的引導。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「星海」……",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到底會是怎樣的景象呢……？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是……！",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_029"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "好，",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_030"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "我們到了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "這裡是海溝的正上方。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n你們直接潛下去就行了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "我會把繩索垂下去，",
        "unit_id": 1411,
        "voice": "vo_adv_1076008_031"
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "你們就順著它下潛吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家的店長",
        "words": "想回來就拉個繩索通知我。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感謝您為我們做了這麼多。",
