        "voice": "vo_adv_1076008_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "根據文獻記載，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n「星海」應該就在",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個深度才對……？　",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "連月光都照不進來，",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "四周一片黑暗……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "住在這道海溝裡的生物",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的都很虛弱……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……？",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……您說得對。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在放棄還太早了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果是沒人來訪才造成這種情況，",
        "unit_id": 107611,
        "voice": "vo_adv_1076008_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那我們或許該",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "通知一下牠們有人來了……！　",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會把治癒之風包覆在泡泡中，",
