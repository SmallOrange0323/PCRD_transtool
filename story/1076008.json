        "voice": "vo_adv_1076008_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了實現這個目標，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下身為嚮導，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一定會盡自己的微薄之力支援您。",
