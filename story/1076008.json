    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起前往「星海」吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "風之精靈啊……！",
