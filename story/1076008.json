        "voice": "vo_adv_1076008_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "送往這一帶的海域。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接著將精靈的加護",
