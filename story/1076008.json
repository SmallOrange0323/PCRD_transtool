    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不僅僅是比喻，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那裡有著真正的",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
