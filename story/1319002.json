        "voice": "vo_adv_1319002_065"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n這座沙山，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "有辦法像剛才的冰山一樣做成溜滑梯嗎？",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "真不愧是愛蜜莉雅醬，",
        "unit_id": 2713,
        "voice": "vo_adv_1319002_066"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "看來妳已經掌握到在海邊玩的訣竅了呢！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "但是，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "用沙子做溜滑梯的話，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "應該會崩塌或是滑不動就是了。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這樣啊……",
        "unit_id": 131911,
        "voice": "vo_adv_1319002_067"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n「夏日佳期」很困難呢……",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "呀啊！",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "我說莉雅，",
        "unit_id": 2612,
        "voice": "vo_adv_1319002_068"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "妳怎麼了啊？",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n怎麼會突然摔倒了？",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我沒事。",
        "unit_id": 131911,
        "voice": "vo_adv_1319002_069"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我只是因為海浪稍微沒站穩而已。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "奇怪？",
        "unit_id": 131911,
        "voice": "vo_adv_1319002_070"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n到剛剛為止，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "海浪都沒有沖到這邊來吧……",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "哎呀呀。",
        "unit_id": 2612,
        "voice": "vo_adv_1319002_071"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "不知不覺間，大海離我們很近了呢。",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是何等失態……",
        "unit_id": 107612,
        "voice": "vo_adv_1319002_072"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下竟會粗心忘了漲退潮的可能。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來這附近",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在滿潮的時候，會被淹沒掉呢。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "啊，",
        "unit_id": 131911,
        "voice": "vo_adv_1319002_073"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "沙山逐漸崩塌了！",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "太久沒到海邊玩所以搞砸了啊────！",
        "unit_id": 2713,
        "voice": "vo_adv_1319002_074"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我們的夢啊！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
