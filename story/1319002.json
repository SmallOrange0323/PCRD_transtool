        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛蜜莉雅小姐？",
        "unit_id": 107612,
        "voice": "vo_adv_1319002_082"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您看起來悶悶不樂的，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是身體不適嗎……？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不，",
        "unit_id": 131911,
        "voice": "vo_adv_1319002_083"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不是的。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "……因為那個，",
