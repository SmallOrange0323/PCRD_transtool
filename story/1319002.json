        "voice": "vo_adv_1319002_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把章魚燒整個吞進嘴裡很危險，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請小口小口地吃。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "哈呼、",
        "unit_id": 131911,
        "voice": "vo_adv_1319002_002"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "呼──",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "呼……",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "好燙，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "但是，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "非～常好吃！",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這也是",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "海邊才有的食物嗎？",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與其說是海邊，",
        "unit_id": 107612,
        "voice": "vo_adv_1319002_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該說是海之家一定會有的料理吧。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n除了章魚燒之外，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "炒麵跟烤玉米之類的也很有名。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這樣啊。",
        "unit_id": 131911,
        "voice": "vo_adv_1319002_004"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "雖然每樣都讓我很在意……",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "但是我有辦法全部吃完嗎。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要在海水浴時活動身體，",
        "unit_id": 107612,
        "voice": "vo_adv_1319002_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "肚子自然就會餓了，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以沒有問題。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下很想那麼說……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "再怎麼說也太熱了吧！",
        "unit_id": 2713,
        "voice": "vo_adv_1319002_006"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "這種溫度去海水浴，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "在納涼之前就會先變成煮熟的章魚了啦！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟這幾天，",
        "unit_id": 107612,
        "voice": "vo_adv_1319002_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非比尋常的酷暑一直都在持續著呢。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n連本來",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是旺季的海之家也……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我買章魚燒的時候，",
        "unit_id": 131911,
        "voice": "vo_adv_1319002_008"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "店員開心到哭得非～常厲害，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "原來就是因為這樣啊。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總之，",
        "unit_id": 107612,
        "voice": "vo_adv_1319002_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們先去海之家休息吧。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "繼續這樣待在沙灘的話，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺我們也會倒下。",
        "unit_id": 107612
    },
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "唉，",
        "unit_id": 2612,
        "voice": "vo_adv_1319002_010"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "就算在陰影下也很熱……",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n纖細的我會受不了啦～",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "沒想到至高的毛茸茸會帶來這種反效果啊。",
        "unit_id": 2713,
        "voice": "vo_adv_1319002_011"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "就算是我",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "現在也提不起勁去摸你啊……",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "抱歉啦，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "帕克。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "但是，",
        "unit_id": 131911,
        "voice": "vo_adv_1319002_012"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "因為天氣炎熱，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "所以刨冰感覺很美味呢。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "感覺不管幾碗我都能吃下去♪",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛蜜莉雅小姐，",
