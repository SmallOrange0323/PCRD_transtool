    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也不知道有沒有辦法遵守約定啊……",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "如果是有可能被毀約的約定，",
        "unit_id": 2612,
        "voice": "vo_adv_1319002_084"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "那是不是不要承諾比較好啊？",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……不，",
        "unit_id": 107612,
        "voice": "vo_adv_1319002_085"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛蜜莉雅小姐。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算是那樣子，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們還是來約定吧。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為可能無法守約，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而連約定都無法承諾的話，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很讓人悲傷啊。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算沒有一定能實現的保證，",
        "unit_id": 107612,
        "voice": "vo_adv_1319002_086"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n想要與他人承諾約定的那份心意，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才是最重要的。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的想法。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "可可蘿……",
