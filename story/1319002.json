    {
        "type": "dialogue",
        "name": "昴",
        "words": "放心吧，",
        "unit_id": 2713,
        "voice": "vo_adv_1319002_018"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "待會就會知道了。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n我有事情想拜託",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "愛蜜莉雅醬跟帕克──",
        "unit_id": 2713
    },
