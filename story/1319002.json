        "voice": "vo_adv_1319002_015"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "嗎……",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我想到了！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n那麼，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "就做出比刨冰",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n還要更厲害的東西不就好了嗎？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "真不愧是兄弟。",
        "unit_id": 2713,
        "voice": "vo_adv_1319002_016"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "你很懂我呢！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n就是要這樣才行啊！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咦，",
        "unit_id": 131911,
        "voice": "vo_adv_1319002_017"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你們在說什麼啊？",
        "unit_id": 131911
