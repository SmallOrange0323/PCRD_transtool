    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我也來幫忙！",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "連莉雅",
        "unit_id": 2612,
        "voice": "vo_adv_1319002_064"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "都變得像昴一樣興奮……",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "真沒辦法呢～",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "我也來幫忙吧。",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "……昴！",
