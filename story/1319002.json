        "voice": "vo_adv_1319002_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請小心。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓肚子受寒不但對身體不好，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是一口氣吃太多，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還會引起頭痛。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗚，",
        "unit_id": 131911,
        "voice": "vo_adv_1319002_014"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "痛痛痛……",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這就是",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "吃冰引起的頭痛嗎？",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "吃太多也不好呢……",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n我本來想說如果有刨冰的力量，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "就能度過這股炎熱的說……",
        "unit_id": 131911
    },
