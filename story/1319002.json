        "unit_id": 1013
    },
    {
        "type": "dialogue",
        "name": "泳裝男子",
        "words": "立在海裡面啊！",
        "unit_id": 1013
    },
    {
        "type": "dialogue",
        "name": "泳裝女子",
        "words": "真的嗎～！？",
        "unit_id": 1212,
        "voice": "vo_adv_1319002_022"
    },
    {
        "type": "dialogue",
        "name": "泳裝女子",
        "words": "那、",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "泳裝女子",
        "words": "那是什麼！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "泳裝女子",
        "words": "但是，",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "泳裝女子",
        "words": "感覺好像有點涼呢。",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "泳裝女子",
        "words": "\n靠近一點看看吧！",
