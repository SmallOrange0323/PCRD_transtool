        "voice": "vo_adv_1319002_080"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "謝謝你。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n因為有大家陪著我一起玩，",
        "unit_id": 131911
    },
