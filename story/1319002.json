    },
    {
        "type": "dialogue",
        "name": "泳裝男子",
        "words": "喂，",
        "unit_id": 1013
    },
    {
        "type": "dialogue",
        "name": "泳裝男子",
        "words": "看那個啊！",
        "unit_id": 1013
    },
    {
        "type": "dialogue",
        "name": "泳裝男子",
        "words": "\n那是什麼啊，",
