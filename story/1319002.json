        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "看到莉雅如此樂在其中的樣子，",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "我也跟著開心起來了。",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "呵呵，",
