    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不久後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n由昴跟{player}負責設計，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n大家一起雕塑成形的冰山，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
