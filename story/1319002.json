        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "在海邊的遊戲，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "結束之後會讓人有點寂寞呢。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "但是，",
        "unit_id": 2612,
        "voice": "vo_adv_1319002_079"
    },
    {
        "type": "dialogue",
        "name": "帕克",
