    {
        "type": "dialogue",
        "name": "旁白",
        "words": "日和與埃拉兩人來到了某間餐廳。"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這裡就是有提供赤麥酒的店家嗎～",
        "unit_id": 135512,
        "voice": "vo_adv_5136065_000"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哎呀──",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "能找到真是太好了！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n這都要歸功於日和幫忙打聽哦♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿，",
        "unit_id": 100111,
        "voice": "vo_adv_5136065_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不用客氣！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "話說回來",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這間店的氣氛很不錯呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "美味的香氣從四面八方飄了過來～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就是說啊～",
        "unit_id": 1,
        "voice": "vo_adv_5136065_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n而且啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這間店的魅力可不只是如此喔～♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗨～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我來打擾了～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "高品質，",
        "unit_id": 103412,
        "voice": "vo_adv_5136065_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "而且溫度控管也很完美！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這裡在蘭德索爾也是屈指可數，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "有著美味麥酒的店家哦！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "突然出現的妳是誰啊！？",
        "unit_id": 135512,
        "voice": "vo_adv_5136065_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈，",
        "unit_id": 100111,
        "voice": "vo_adv_5136065_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優花梨小姐……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳今天也從中午就在喝酒了啊～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我今天啊，",
        "unit_id": 103412,
        "voice": "vo_adv_5136065_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "有當班！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒有當班的意思～",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就是休息的日子～",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不過呢，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我還有暢飲美味麥酒",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這項重要的工作～",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唔嘿嘿嘿嘿～♪",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……咦？",
        "unit_id": 135512,
        "voice": "vo_adv_5136065_007"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n難道是優花梨小姐嗎？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n【墨丘利財團】的那位？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是她沒錯哦。",
        "unit_id": 100111,
        "voice": "vo_adv_5136065_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n妳為什麼會這麼驚訝呀？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不是，",
        "unit_id": 135512,
        "voice": "vo_adv_5136065_009"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "因為……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n在我的世界裡，優花梨小姐",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是個非～常",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嚴厲的人。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "她可是被人稱作「金庫守衛優花梨」、",
        "unit_id": 135512,
        "voice": "vo_adv_5136065_010"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "「厲鬼會計負責人」哦？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n任何時候都沉著冷靜！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n哪怕是一滴麥酒都不會去喝的那種人！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這就是優花梨小姐！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這、",
        "unit_id": 100111,
        "voice": "vo_adv_5136065_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "和這個世界的優花梨小姐完全相反呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來世界不同，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也會有這種情況啊……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯唔～？",
        "unit_id": 103412,
        "voice": "vo_adv_5136065_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我說我說，妳們在聊啥～？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不准丟下姐姐我卻自己打得火熱～！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊、",
        "unit_id": 135512,
        "voice": "vo_adv_5136065_013"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "抱歉抱歉！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "難得有這個機會，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就一起喝酒吧！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n能夠透過喝麥酒與厲鬼金庫守衛暢聊，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是個珍貴的體驗呢♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "來了，",
        "unit_id": 1411,
        "voice": "vo_adv_5136065_014"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "抱歉在幾位聊得開心的時候打擾了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n赤麥酒送來啦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我等好久啦──！",
        "unit_id": 135512,
        "voice": "vo_adv_5136065_015"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "小姐很內行哦。",
        "unit_id": 1411,
        "voice": "vo_adv_5136065_016"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n這種酒在蘭德索爾",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "還沒有什麼人知道呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦！？",
        "unit_id": 103412,
        "voice": "vo_adv_5136065_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "赤……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "麥、",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "酒……？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "等",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "、",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "等一下！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "之前有那種東西嗎？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這原本",
        "unit_id": 1411,
        "voice": "vo_adv_5136065_018"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是在特定地區才喝得到的麥酒。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n也就是",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "俗稱的地區麥酒。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "最近才剛流通",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "到蘭德索爾這裡。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不、",
        "unit_id": 103412,
        "voice": "vo_adv_5136065_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不是吧──？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我都沒有發現……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n畢竟我來這裡時，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "每次",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "都是點「老樣子」……！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可是，",
        "unit_id": 103412,
        "voice": "vo_adv_5136065_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "既然被我知道……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就沒有人可以阻止我！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嘿，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "老闆，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我也要點一樣的酒！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "要特大杯！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "嘿嘿，",
        "unit_id": 1411,
        "voice": "vo_adv_5136065_021"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "好喔～～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "埃拉、優花梨",
        "words": "乾杯！！",
        "unit_id": 1,
        "voice": "vo_adv_5136065_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咕嘟咕嘟……",
        "unit_id": 103412,
        "voice": "vo_adv_5136065_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "噗哈～～！！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n哎呀真是的，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這酒好喝耶！！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "酸味算是比較強，",
        "unit_id": 103412,
        "voice": "vo_adv_5136065_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "然而喝起來並不膩口……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "反倒感覺很棒！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不只是順口，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還有著紮實的後味……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "能感受到",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "大地的恩惠！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對吧對吧～！",
        "unit_id": 135512,
        "voice": "vo_adv_5136065_025"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n一開始雖然只會覺得",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "味道好像有一點獨特啊～？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但是繼續喝下去就會讓人上癮呢～♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊──不行，",
        "unit_id": 103412,
