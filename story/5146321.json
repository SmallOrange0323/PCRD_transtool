[
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "噫欸欸！",
        "unit_id": 130911,
        "voice": "vo_adv_5146321_000"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n魔物們都被操控了～！！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗚嗚……",
        "unit_id": 131011,
        "voice": "vo_adv_5146321_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家沒辦法",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "攻擊這些孩子呀……",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "不，",
        "unit_id": 16612,
        "voice": "vo_adv_5146321_002"
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "這不是攻擊！",
        "unit_id": 16612
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "\n我們必須讓大家醒過來，",
        "unit_id": 16612
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "拯救大家才行！",
        "unit_id": 16612
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "\n就像真步小姐之前",
        "unit_id": 16612
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "救了我那樣！",
        "unit_id": 16612
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "說的對喵～",
        "unit_id": 17312,
        "voice": "vo_adv_5146321_003"
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "\n我們不會因為被輕輕打個幾下就倒下的，",
        "unit_id": 17312
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "\n可以放心喵。",
        "unit_id": 17312
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "儘管上吧喵～！！",
        "unit_id": 17312
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "對那些傢伙來說，一直被操控反而更痛苦。",
        "unit_id": 15917,
        "voice": "vo_adv_5146321_004"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "\n我們趕快解放牠們吧！！",
        "unit_id": 15917
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……說、",
        "unit_id": 130911,
        "voice": "vo_adv_5146321_005"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "說的也是呢。",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n大家說的對……！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是呀……",
        "unit_id": 131011,
        "voice": "vo_adv_5146321_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那麼",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "庫露露小姐。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n咱們趕緊",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "救救",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這些孩子吧！",
        "unit_id": 131011
    }
]