    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克莉絲提娜和{player}在城鎮裡四處逛逛，\n回過神來才發現夕陽開始西下。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那邊的衣服也給我好了。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "幫我拿。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "順便，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也買雙搭配衣服的新鞋好了。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "試穿好麻煩。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個和這個，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還有……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個也買起來好了。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別弄掉了啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？　",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼啊，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "腳步很不穩哦？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不過就是拿個10件20件東西，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n鍛鍊不足喔？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼就",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我來幫你鍛鍊鍛鍊吧☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正好，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我記得那裡",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有個賣全身鎧甲的地方啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈☆",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n開玩笑的啦，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別露出這麼緊繃的臉嘛。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這樣會讓我更想要捉弄你♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……雖說原本是想解悶才嘗試看看的，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n聖誕約會也不錯嘛。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個結束之後又會回到無聊的狀態了啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我過去嘗試了很多事情。",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "戰鬥就不用說了，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "經營生意和擔任製作人等等，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了解決掉無聊",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真的做了很多事呢。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那個強敵也還活得好好的，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n無論怎麼砍都還是糾纏不清。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今天的聖誕約會也是一樣。",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然嘗試去模仿做『一般』的事，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但結束之後，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就又要開始和無聊戰鬥了。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我這個人，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "到底要怎樣才能滿足呢。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……唉呀，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我說了無聊的事呢。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "忘了就好。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "克莉絲提娜！",
        "unit_id": 911,
        "voice": "vo_adv_1115003_013"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n妳是克莉絲提娜‧摩根吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你說的沒錯，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就是天下無雙的豪傑，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n克莉絲提娜唷☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "好久不見了啊，",
        "unit_id": 811,
        "voice": "vo_adv_1115003_015"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "克莉絲提娜！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n我……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "還記得我們嗎！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "可不准妳說不記得了！",
        "unit_id": 1111,
        "voice": "vo_adv_1115003_016"
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "\n之前還把我們打得落花流水啊！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不記得！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "小混混們",
        "words": "妳這傢伙！",
        "unit_id": 1,
        "voice": "vo_adv_1115003_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "希望別人記住你的話，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就改改那個大眾臉和",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n老套的說話方式如何啊？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算改變外觀和說話方式也沒差啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你們流露出一股",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "自己是小卒的氣息啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是無可救藥☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "這女人還是一樣愛亂講話……！",
        "unit_id": 911,
        "voice": "vo_adv_1115003_021"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "不過妳看！　",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "我今天把之前被妳打敗的傢伙都召集過來了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "快還清妳欠的債吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈☆",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我一直以來都是付現的啊，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒積欠過什麼唷。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話說回來明明是聖誕節還來找碴，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你們還真是一群孤單寂寞的男人啊？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "妳，",
        "unit_id": 811,
        "voice": "vo_adv_1115003_024"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "妳妳妳，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "少囉嗦！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n和聖誕節無關吧！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊好寂寞好寂寞。",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n對這麼寂寞的一群男人，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "多少想施捨一些憐憫呢。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "要、",
        "unit_id": 1111,
        "voice": "vo_adv_1115003_026"
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "要打嗎！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "\n我們這邊可是有10個人以上喔！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "就算是妳，",
        "unit_id": 911,
        "voice": "vo_adv_1115003_027"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n也無法輕易逃過！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想想。",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然說身體跟腦袋記憶裡都沒有印象，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過被指控欠債還是心情很差呢。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "連本帶利一起還給你們吧……☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼。",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "果然能滿足我的還是這個啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "――以劍和劍交談，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "用血和血碰觸。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這就是我",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "克莉絲提娜‧摩根。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "小混混們",
        "words": "要上囉，",
        "unit_id": 1,
        "voice": "vo_adv_1115003_030"
    },
    {
        "type": "dialogue",
        "name": "小混混們",
        "words": "大夥們！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "果然我，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是適合在戰場上生存――！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼……！？",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_032"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "你這傢伙幹嘛！？",
        "unit_id": 911,
        "voice": "vo_adv_1115003_033"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "快離開那裡！　",
        "unit_id": 811,
        "voice": "vo_adv_1115003_034"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "想死嗎！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "我們要找的是那個女的！",
        "unit_id": 1111,
        "voice": "vo_adv_1115003_035"
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "\n快閃開！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯，小子你快退下。",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不要妨礙我的快樂時光♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然這群傢伙頭腦和力量都很差，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但既然被挑釁了就應該要接受啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子你應該也很清楚，我是不可能",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n會輸給這種程度的傢伙吧？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "知道的話就快退下。",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你賴在那邊不走的話，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "劍可能就不小心揮到你了喔？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊……？",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n喂，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "你這傢伙打算做什麼！",
        "unit_id": 911,
        "voice": "vo_adv_1115003_041"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "就算你來道歉――",
        "unit_id": 811,
        "voice": "vo_adv_1115003_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "――你們給我閉嘴！",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_043"
    },
    {
        "type": "dialogue",
        "name": "小混混們",
        "words": "噫……！？",
        "unit_id": 1,
        "voice": "vo_adv_1115003_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你到底在做什麼？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我什麼時候拜託過你做這種事？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難道你覺得我會被這種程度的烏合之眾打敗嗎？",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這對我來說是難以忍受的屈辱喔。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你再這樣妨礙我享受的話，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就算是你我也――",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……！",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……啊啊。",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n原來如此啊，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這樣啊，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來是這樣啊，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還真是失禮了。",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不是和別人，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而是在和你一起聖誕約會的當下",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "忘情於其他的男人，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我才是做出侮辱行為的人啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我對你好好道歉吧。",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不好意思啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "喂，",
        "unit_id": 911,
        "voice": "vo_adv_1115003_052"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "喂……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是這樣小小嘍囉們！",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我的閒暇時間已經完售了！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "趕快夾著尾巴離開吧♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "開、",
        "unit_id": 811,
        "voice": "vo_adv_1115003_054"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "開什麼玩笑！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n以為這樣我們的憤怒就會平息嗎……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不然的話。",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不是由我，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而是由這傢伙――來當你們的對手。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "什、",
        "unit_id": 911,
        "voice": "vo_adv_1115003_056"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "什麼……？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "這、",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "看起來這麼弱的小鬼能做什麼！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "等、",
        "unit_id": 811,
        "voice": "vo_adv_1115003_057"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "等等！　",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "這可是克莉絲提娜唷！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n聖誕節……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "會在這麼特別的時候在一起，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n該不會那個男人……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "也許是相當厲害的角色……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "仔細一看，",
        "unit_id": 1111,
        "voice": "vo_adv_1115003_058"
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "沒有破綻……！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "\n看起來在發呆，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "反而令人毛骨悚然啊……！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "他、",
        "unit_id": 911,
        "voice": "vo_adv_1115003_059"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "他竟然歪頭……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n該不會，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "打算把我們的頭給折斷嗎……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唉呀唉呀，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_060"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這小子好像非常生氣喔。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "連我的身體也都顫抖不已。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈哈☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "嗚、",
        "unit_id": 811,
        "voice": "vo_adv_1115003_061"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "嗚啊啊啊啊啊！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n這傢伙……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "在這種狀況",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "竟然敢打哈欠……！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對付你們這種貨色，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n感覺一邊睡覺就可以應付的樣子。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈哈☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "竟、",
        "unit_id": 1111,
        "voice": "vo_adv_1115003_063"
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "竟然把劍丟掉……！？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "小混混 3",
        "words": "赤手空拳對付我們就足夠了嗎……！？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_064"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好像真的完全惹怒他了。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看看那雙手",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在微微地震動，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好像是已經沒辦法忍耐的暗示啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈哈☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼你們打算怎樣？",
        "unit_id": 111511,
        "voice": "vo_adv_1115003_065"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要把聖誕節染成紅色的嗎？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然馬上就會被雪給覆蓋成白色的吧……♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "小混混們",
        "words": "哦……",
        "unit_id": 1,
        "voice": "vo_adv_1115003_066"
