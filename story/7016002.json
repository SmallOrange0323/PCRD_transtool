    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由宮子領頭，{player}他們開始登塔。"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這裡就交給宮子吧！",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n你們跟著宮子走就好。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "吃了布丁的宮子是無敵的喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "精靈",
        "words": "──♪"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "什、",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "什麼啦？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這傢伙從剛剛開始",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就一直飛在宮子身邊。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "難道是想要阻撓我嗎？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不是的，",
        "unit_id": 104211,
        "voice": "vo_adv_7016002_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他似乎是想和你親近。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯嗯嗯……",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這裡有宮子一個人就足夠了喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不是你上場的時候！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "沒有！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "被稱讚的只有宮子一個人就夠了喲！",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子要靠千歌的公會來賺大錢！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "精靈",
        "words": "──！"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那是千歌的公會名嗎？",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好呀，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子要加入喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你在說什麼啊？",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "現在才不是在說那個吧！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果宮子小姐願意的話。",
        "unit_id": 104211,
        "voice": "vo_adv_7016002_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過我還是會去問一下望她們的……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "沒有這個必要！",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "只要看到了宮子的實力，就一定會想讓人家加入的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是喔。",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_009"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n是那個要唱歌跳舞的偶像嗎？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n是這樣喲？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯，",
        "unit_id": 104211,
        "voice": "vo_adv_7016002_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "千歌也會唱歌跳舞嗎？",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的。",
        "unit_id": 104211,
        "voice": "vo_adv_7016002_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大家一起創作歌曲、編舞，還會製作服裝……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那麼宮子就擔任布丁負責人！",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦、",
        "unit_id": 104211,
        "voice": "vo_adv_7016002_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦咦咦咦？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這種團體最需要的就是",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_015"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "變化性？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "伊莉亞也是這麼說的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "沒問題的呦！",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_016"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "全部都交給宮子就好！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家也經常和忍一起唱歌呢！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳說的忍小姐，",
        "unit_id": 104211,
        "voice": "vo_adv_7016002_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是宮子小姐公會的人對嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔！",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_018"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這已經是以前的事了！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是，",
        "unit_id": 104211,
        "voice": "vo_adv_7016002_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "明明妳們感情那麼好……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那都已經是過去的事了！",
        "unit_id": 100711,
        "voice": "vo_adv_7016002_020"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好了，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "往前走了！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就讓妳看看更多宮子能夠幫上忙的地方！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "宮子小姐……",
        "unit_id": 104211,
        "voice": "vo_adv_7016002_021"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對於堅決不說出理由的宮子，千歌無法看透她的真實想法，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n只能抱著疑惑，繼續登上塔。"
    }
]