[
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "続・",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "研究レポート",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "『世界に連なる高次よりの耳目』。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あるいは",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_001"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "『決してサボってたわけではないユニちゃんの言い分』。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "前略、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_002"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "聖テレサ女学院学生課担当者殿。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n筆者は先般、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "教務主任マザー・ヒルダを通じて、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n学院より以下の旨を要請された。",
        "unit_id": 116411
    },
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "数日後に開催を控えた文武の祭典",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_003"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "『聖学祭』において、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nユニ博士は日頃の学習成果を発表されたし──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "との由。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "言うまでもなく、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_004"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "当学最大の年間行事『聖学祭』には、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n生徒の父兄や地域住民のみならず",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n多数の教育関係者や出資者・",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "後援者も列席する。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "それら権力者たちに対し、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_005"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nこの聖テレサ女学院が",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nいかに優秀な生徒を輩出する教育機関であるか示せということだろう。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "端的に換言すれば、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_006"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "当学は見栄っ張りなのである。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n筆者を見下ろす教務主任マザー・ヒルダの眼鏡の奥の眼光が、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n「たまには役に立て、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "穀潰しの不良優等生が」",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "と暗に告げていた。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "これに対し、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_007"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n筆者の口をついて出た咄嗟の回答は",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "「え無理」の三文字だったが、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nマザーはそれを容易に諒としなかった。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "貴様は授業にも出ず",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_008"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "図書館棟に籠って今日まで何をしてきた？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nよもや日がな一日",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぐうぐう眠り散らかしていたわけではあるまいな？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n──彼女のランドソルスナギツネのごとき目がそう告げていた。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "よって以下は、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_009"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "筆者にかけられた嫌疑を晴らすべく、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nこれまでの活動経過および付随する陳情を",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ここに記すものである。",
        "unit_id": 116411
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "『世界にわだかまる根源的な虚構』。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_010"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "かつて筆者が取り組んだとされるその研究課題は、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_011"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n学会に提出するやたちまち大いに嘲笑された。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そして筆者自身は",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_012"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n学術的仮説と誇大妄想を履きちがえた莫迦者との誹りを受け、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n当該研究は綺麗さっぱり「なかったこと」にされた──。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "──らしい。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_013"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "正直よく覚えてない。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_014"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "我々の脳には、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "精神的外傷となり得る忌まわしい記憶を",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n都合よく忘れる",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "防衛機能が備わっているらしいので、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "たぶんそれ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "というか、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_015"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "まあ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "正直なんでもいい。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "とにかく筆者の身にかかる事情は、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "容易に言語化できるものではない。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "瞼を撫でる朝の陽光が。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_016"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n血を躍らせる夜の高揚が。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n世界のあらゆる事物事象が、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "筆者の思考を穏やかに妨害するのである。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "端的に換言すれば、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_017"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "考えるのめんどくさくなる。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "それが筆者生来の気質に由来するものじゃねえのと言われれば、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_018"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nああ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "うん、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "もともと筆者そういうとこあるしね？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nと曖昧に濁さなければならないのが",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "我ながら遺憾ではある。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "本来ならば、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_019"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nこれは筆者が何らかの認識阻害を被ったとも考えられるわけだが、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n案の定というか、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "本邦の有識者たちはその説に耳すら貸さなかった。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "思考停止の誘惑に囚われない真なる識者の一人もいれば、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_020"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nあるいは筆者の研究も今とは異なる結果を招いたかもしれない。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "だが、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "しかし、そうはならなかった。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "どうでもいい。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_021"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nぼくの話なんて、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "どうせ誰もまともに聞きやしないんだ。",
        "unit_id": 116411
    },
    {
        "type": "background",
        "background": "500960"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "当学院の図書館棟──",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_022"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "通称『象牙の塔』には、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nきわめて歴史的資料価値の高い文献や古文書が数多ある。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n端的に換言すれば、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "宝の山だ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "だが不思議なことに、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_023"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いかなる学者も識者もそれらに興味を示さない。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nあたかも興味を示すこと自体が禁じられているかのように。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "閑話休題。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_024"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nそれらの書の中には、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n神話とも御伽噺ともつかない荒唐無稽な物語もあった。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "例えるならそれは、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_025"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n別なる地平より訪れし異界人たちの活動記録であった。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nあるいは、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そうした異界人同士の交信記録であった。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ここで筆者は、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_026"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "莫迦者らしく一つの馬鹿げた仮説を立ててみる。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nもしもそれらの荒唐無稽な冒険譚が『真理』だとした場合──。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "この世界は、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_027"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n我々と地平を異にする高次な存在が創造したある種の箱庭であり──。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そしてここに息吹く我々もまた、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_028"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nそうした高次存在に連なる系譜であり──。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "つまり、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_029"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぶっちゃけ換言すれば、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "我々は──。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "我々は──",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_030"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あれ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なんだっけ？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "まあいいや。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_031"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "めんどくさい。",
        "unit_id": 116411
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "筆者はいわゆるところのメモ魔だ。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_032"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n日常の中に得た学びや気付きを、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n大なり小なり徒然なるままに記録している。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そして我が外部記憶たりうるメモ帳の、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_033"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n幾ばくか破り捨てられた項の下にはこう記してある。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "『惰眠を貪れ　",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_034"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "余生を愉しめ』",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "『示談は成立せり　",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_035"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "我こそは勝者』",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "その筆跡は、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_036"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "疑いなく筆者自身のものである。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n要領を得ない筆致は、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "さながら検閲逃れの暗号のようだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "それはきっと、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_037"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いつかのぼくがぼくへ遺した、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n賢明なる脅し──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あるいは懸命なる祈りだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "是非もなし。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_038"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nすでに勝利しているなら、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "残りの日々は消化試合だ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "遺言に従い、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_039"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "衆愚に倣い、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n欺瞞を孕んだ世界で",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "せいぜいお気楽な余生を愉しもう。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "この閉じられた箱庭の中で、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_040"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nいち早く自身の頬を抓ったぼくは幸いだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n夢にあって夢が夢だと気付けたのだから。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いいとも世界、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_041"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "折り合いをつけてやる。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nぼくの学びは他へ向けよう。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "この長閑な明晰夢を",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "せいぜい愉快に泳がせてもらう。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "だからおまえは勝手に閉じてろ。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_042"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nぼくはおまえの掌の上で、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いつか夢見た青春活劇を勝手に続ける。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nそれで文句はないんだろう？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "くそったれが。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_043"
    },
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "──前略、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_044"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "学院どの。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n以上の理由を以って、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "筆者は『聖学祭』",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "学芸展示への論文提出を",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n全面的に見送らせていただくものとする。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "叫んだところで、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_045"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "どうせ誰にも届かないんだ。",
        "unit_id": 116411
    },
    {
        "type": "still",
        "still": "506400201"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "追伸。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_046"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nむろん学院に籍を置く者の義務として、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n当該展示には別の形で参加させていただくので",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "どうか安心されたし。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "新進気鋭の芸術家",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_047"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "・ユニ博士の意欲作にご期待ください。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "かしこ。",
        "unit_id": 116411
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ＯＫロゼッタ、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_048"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "世界は今日も閉じているかい？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "この空のずっと向こうには",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_049"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "何があるのだろうな？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくの得た学びに、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_050"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "果たして意味はあったのだろうか？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なあロゼッタ、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_051"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくの声は届いているか？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "ぽーん！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_052"
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\nお探しの回答が見つかりません！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\n仮想自我に対するコマンドは明瞭にお願いいたします！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふむ、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_053"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "少々ポエムが過ぎたか……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "よかろう、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "では質問を変える。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nＯＫロゼッタ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくはまだ馬鹿と呼ばれているか？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "エゴサーチは",
        "unit_id": 1,
        "voice": "vo_adv_1164001_054"
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "精神の健康を損なう恐れがあります！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\n世論の吸い過ぎにご注意ください！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "真実は必ずしも幸福を担保しない──",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_055"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なるほど、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "知らぬが華ということか。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "しかし君、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_056"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "もっと主人に対する言葉を選びたまえよ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "知りたいのは要するに、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nぼくの選択は正しかったのかということだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "ぽーん！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_057"
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\n「正しい」の定義が曖昧です！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\n正義も正当も主観次第と、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "以前ドクター・ユニが言っていました！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ああ言えばこう言う。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_058"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "反抗的な飼い石だ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nやれやれ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いったい誰に似たのやら。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ＯＫロゼッタ、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_059"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "すべてを白か黒かに区分しようなどとは考えるな。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nそんな二元論は、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "魂が理系に堕ちるぞ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "肝要なるはグラデーションだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "行間を愛せ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "世界は曖昧でいいんだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "端的に換言すれば、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_060"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "もっとぼくを甘やかそう。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "では、",
        "unit_id": 1,
        "voice": "vo_adv_1164001_061"
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "曖昧機能ＯＮで回答します！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\n近ごろのドクター・ユニは",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "毎日楽しそうなので、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "たぶん大丈夫です！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いい子だ、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_062"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そういう言葉を待っていた。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ＯＫロゼッタ。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_063"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n先ほどの戯れ言は、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "むろん学院に提出するべくもない。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n跡形もなく破棄しておいてくれたまえ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "……えっ？",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_064"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nところで大丈夫って何？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nユニちゃん世間にどう言われてるの？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "おや、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_065"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "誰か来たようだよロゼッタ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "ぽーん！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_066"
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\nごきげんよう、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "ミスター「同志」！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ああ、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_067"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "{player}君か。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n憩いの仮眠所へようこそ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "驚かせて済まないね。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくはご存知、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_068"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "象牙の塔のユニ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nこっちは喋る石のロゼッタを",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "人型の素体に乗せてみたものだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いまだ試験段階ゆえ",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_069"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "複雑な動作はさせられないが、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n素体にはぼくに似せた幻影テクスチャーを貼ってある。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "どうだ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "傍目にはまるで双子の美人姉妹だろう。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そ、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_070"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そうか……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "まったくか……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いや、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "自分で言っておいて何だが、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n君の目",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ちょっと節穴が過ぎないかね……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "「似てる」の定義は主観次第です！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_071"
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\n個人の感想につき、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "真に受けなくて大丈夫です！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "まあ、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_072"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "人型ロゼッタの本運用は数年先になるゆえ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n擬体には多少の成長見込みを加味してある。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "身内にも区別がつかないほど酷似させてしまうと、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_073"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nクロエ君やチエル君あたりに色々悪用されかねんしな。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "似てそうで似てない、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "でもちょっと似てる絶妙なラインを狙った。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "「絶妙」の定義は主観次第です！　",
        "unit_id": 1,
        "voice": "vo_adv_1164001_074"
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "言ったもん勝ちです！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500970"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "……さて、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_075"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "休憩という名の現実逃避は終わりだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nロゼッタ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼちぼち自律運動回路の調整を始めるとしよう。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "うん？　",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_076"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なんだね同志、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "その意外そうな顔は。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nよもやぼくがクロエ君の猛特訓から逃げて、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nただ飼い石を膝枕に惰眠を貪っていたとでも？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "正解です！　",
        "unit_id": 1,
        "voice": "vo_adv_1164001_077"
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "逃れようもない真実です！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "馬鹿を言うんじゃあない。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_078"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n外側からはそう見えたかもしれんが、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n内実ぼくは回路調整のための思考実験に耽っていたのだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふむ、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_079"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "分からんかね。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nロゼッタには聖学祭でぼくの影武者をさせるつもりなのさ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "何故だと？",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_080"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君とて生徒会長の話は聞いていただろう、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n来たる『聖学祭』には",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "我々ユニちゃんズの命運がかかっているのだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "そうですね！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_081"
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\n我々なかよし部の命運がかかっていますね！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ゆえに、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_082"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "負けられない戦いがそこにはある。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "陸に上がったイルカよりも遅いと評判のユニ博士が、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "熾烈な運動競技にしゃしゃり出るわけにはゆかんのだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ユニちゃんズはぼくが守る！",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_083"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nこの夢のような青春活劇は、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nたとえどんな手を使ってでも終わらせないぞ！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "後ろ向きに前向き！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_084"
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\nドクター",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "かっこいい！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "よせやい、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_085"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "照れるぜ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "さあ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君にも手伝ってもらうぞ",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "共同研究者。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ん？　",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_086"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "おい、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "どうした{player}後輩。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n何をきょろきょろと左右を見回している。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n他の誰でもない、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君に協力を仰いでいるのだ",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "共同研究者。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "承知している。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_087"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nだから何だね。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n君に求めるのは知識でも技術でもない。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "以前、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_088"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "言ったはずだぞ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n君はただ傍にいて",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくの話を聞いてくれるだけでいいんだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくの学びは、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_089"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくの為のものだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n元より誰かに伝える意図も野心もありはしない。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "……だけどね？",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_090"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "もし誰か",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_091"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "一人でも耳を傾けてくれる味方がいてくれるなら──。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ただそれだけで、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_092"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくの学びも報われる気がするんだよ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "感謝してる。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_093"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nいつもありがとう。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "{player}には"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nユニが何を言っているのかよく分からなかったが、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nそれでもユニがうれしそうなのは分かったので共に微笑むのだった。"
    }
]