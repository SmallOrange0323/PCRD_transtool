[
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後。\n{player}和可可蘿，\n一起前往住宿的度假小屋。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，主人……",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真是非常抱歉，在下又被強烈的睡意所襲擊。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "甚、",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "甚至到了沒辦法站起來的程度……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請稍等一下，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下來拍拍臉把睡意驅散。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗚哇？",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為什麼，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要把在下抱起來呢……？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "老實說，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是幫了大忙。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n麻煩您了，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下實在榮幸至極。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為平常這個時間早已入睡……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以腦袋好像還是醒不來，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真不好意思。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "白天也有斷斷續續地小睡，",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n照理說應該很有精神才對。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在海邊游玩，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "意外地很耗體力呢……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精疲力盡了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好想就這樣",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直安穩地熟睡到早上。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人不好意思，",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不小心太過撒嬌了……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這樣是不行的呢，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明有身為支持引導主人",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的嚮導責任在身。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下卻總是",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "反過來受您的照顧……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊……",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但是不知為何，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有種懷念的感覺。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "白天",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被陽光曬得發燙、",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "刺痛刺痛的皮膚……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人的體溫、",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "心跳……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像曾在哪裡，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也有過這樣珍貴的心情……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主、",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這個光芒是……？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好睏，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒辦法思考了。",
        "unit_id": 107611
    },
    {
        "type": "still",
        "still": "107600401"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人，",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_014"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真是感謝您。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "能在這裡遇見主人，",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_015"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真是作夢也沒想到。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n果然主人是",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "指引迷惘在下",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "的救世主……♪",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "呵呵。",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_016"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雖然在下",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "今天想和父親",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "一起練習游泳。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但父親因為工作臨時有急事……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "留下在下一個人，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "很寂寞呢。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "如果只有在下的話，",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_017"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "即便想練習游泳，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n也不知道該怎麼練習才好……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人在這附近，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "還願意教導在下真的非常感謝。",
        "unit_id": 107631
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510190"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯，",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_018"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "為什麼呢？",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n主人，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "常常要在下別這樣叫呢。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但是",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_019"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人就是主人啊……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "即使您這樣吩咐，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下也無法遵從。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯……",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_020"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "確實是有點怪，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "也許是一般不會使用的稱呼吧。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但在下個人還是覺得，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n稱呼您為主人",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是最適合的方式了。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不過",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_021"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人不喜歡的話，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "應該來想個替代方案。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n至少在別人面前，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "使用別的稱呼方式好了。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "妥協一下……",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_022"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但其實在下，還是很希望稱呼主人呢。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人有沒有什麼，",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_023"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n認為「想被這樣喊～」",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "的稱呼方式呢？",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "唔，",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_024"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "用名字……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但是很抱歉，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "忘了主人的名字。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "因為主人就是主人，",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_025"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n所以想說名字不太重要……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雖然這麼問很失禮，",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_026"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "能再告訴在下一次",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您的名字嗎？",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "唔……",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_027"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人並不是",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下的哥哥吧？",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯。",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_028"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您說，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "被比自己年紀小的對象這樣稱呼是很常見的？",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "原來這是很平常的事呢，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "學到一課了。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "那麼……",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_029"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n如您所願，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "請讓在下這樣稱呼。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "哥、",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_030"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "哥哥。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "…………",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_031"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……那個，",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_032"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "怎麼覺得非常的難為情。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "也許在下這麼說很任性，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n真的不能",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "稱呼您為主人嗎？",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "呵呵。",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_033"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您說，稱呼主人也沒關係？",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人，謝謝您……♪",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_034"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "很溫柔呢。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "無論和誰說話",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "都常會令人感到困惑。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n主人卻",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不厭其煩地陪伴在下。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "今天也是，",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_035"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "碰巧遇見就出聲",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "叫住了在下……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n還親身教導",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下游泳的方法。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n主人，在下真的很開心。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_036"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "絕對不會忘記今天的事情。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n就算變成老婆婆也好，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "死掉投胎轉世也好……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n這道光芒",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "會永遠留在在下的靈魂深處吧。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "希望有朝一日",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_037"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "能回報您的恩情。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n即使現在還沒辦法，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但等變成大人之後……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n無論在遙遠的未來",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "或下輩子，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "有朝一日一定會報答您的。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人，",
        "unit_id": 107631,
        "voice": "vo_adv_1076004_038"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "約定好了。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在心中發誓。",
        "unit_id": 107631
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1076004_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1076004_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n醒來之後，大概就會全都忘光囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看來這次是和大家一起來海邊玩，",
        "unit_id": 190011,
        "voice": "vo_adv_1076004_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而回想起了這方面的回憶呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然你和小可可蘿，",
        "unit_id": 190011,
        "voice": "vo_adv_1076004_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在「那裡」沒什麼交集……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但那時夏天你去了附近的泳池，",
        "unit_id": 190011,
        "voice": "vo_adv_1076004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好像正巧就碰到她了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然小可可蘿過著不尋常的生活，",
        "unit_id": 190011,
        "voice": "vo_adv_1076004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不過這個時候已經正常地開始上小學了的樣子。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n然後，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了學校的游泳課好像一直練習著呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "多虧了你在這天",
        "unit_id": 190011,
        "voice": "vo_adv_1076004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "教導她游泳的方法……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n讓小可可蘿在學校不會跟不上大家的進度，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n以不錯的狀態就這樣慢慢融入了班級的樣子。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}，你做了很棒的事情嘛。",
        "unit_id": 190011,
        "voice": "vo_adv_1076004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "了不起了不起♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "謝謝你喔，",
        "unit_id": 190011,
        "voice": "vo_adv_1076004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總是幫忙照顧小可可蘿……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為我的立場很難出手協助，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只能在一旁焦慮地看著。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你能讓小可可蘿感到幸福，",
        "unit_id": 190011,
        "voice": "vo_adv_1076004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的幫了我大忙。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然這種說法好像很奇怪，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就像是自己的事一樣感到開心，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的很感謝你呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "謝謝你，{player}。",
        "unit_id": 190011,
        "voice": "vo_adv_1076004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可以的話，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以後小可可蘿也拜託你多照顧囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……哎呀，不是悠閒聊天的時候呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1076004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖說是夏天，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在室外睡著的話還是容易感冒的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n快點起來。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰，{player}。",
        "unit_id": 190011,
        "voice": "vo_adv_1076004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n下次在夢裡再會吧。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人、",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為剛剛突然搖晃得很厲害，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就驚醒了……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人還好嗎，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有沒有哪裡覺得痛呢？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯嗯。",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您說好像有一瞬間，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "失去意識……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也累了呢，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下還是",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自己走路吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然被主人抱著送回去，",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感到感激又開心……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但身為嚮導，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然還是想拉著主人的手",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "引導您♪",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來吧主人，",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "手牽著手一起出發吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回到在下與主人的",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "安居歸屬。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n然後充分地休息，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n明天和後天",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都好好地享受海水浴場的樂趣吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 107611,
        "voice": "vo_adv_1076004_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是讓人興奮呢……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人♪",
        "unit_id": 107611
    }
