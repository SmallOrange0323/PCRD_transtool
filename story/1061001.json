[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "――跟著矛依未來到【拉比林斯】據點的當晚，\n{player}發現她人不知到哪去了。"
    },
    {
        "type": "background",
        "background": "500142"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唉……",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……嗯？",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊啊，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是你啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n怎麼了嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你來找我啊？",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但我哪都不會去喔？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為我也沒別的地方可去啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我嗎？",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我就在這裡啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也沒其他地方能去……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……你",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "該不會是在擔心我吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "謝啦！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒問題的！",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我可不是笨蛋呀！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我才不會丟著夥伴不管，自己跑去別的地方呢！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的！",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我沒騙人！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "全都忘了現實世界的事，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這世界哪裡不對勁這一點也感覺不出來吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以現在，",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只能由我來帶領你們啦，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "各種要煩惱的事情實在是太多了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不自覺地就嘆起氣來了呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且，",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要帶領其他人的這種事，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n自從很久以前在設施生活的那段時間後就沒有過了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n總～覺得還沒能習慣呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那時真開心呢！",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可以整天使壞，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n如果有欠扁的傢伙只要打倒就好……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為可以自由使用力量，",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "偷東西、搞破壞、\n大鬧特鬧，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "實在是很亂來呢……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊啊，",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抱歉啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我最近常常自言自語！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嗎？",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那我就繼續說囉！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n對象是你的話，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就能和從前一樣不用多想，很輕鬆很開心！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我想想還要說些什麼呢──？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這麼說來，我還沒跟你們",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "仔細說過我的事對吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但也沒辦法呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "直到最後的前不久",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們都還是敵人嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且你們",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不認識現實中的我們吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然我和尾狗刀",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "調查過你們的事了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我和尾狗刀",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗎……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就來講這個好了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我呢……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我和尾狗刀都做了些什麼！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀……",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很擅長破解和蒐集情報。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "電腦……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這裡沒有這種東西啊，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個世界裡。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總之利用道具，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "偷看別人的祕密就是他的工作！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我呢……",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "說來話長！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "平常都是為了遊戲和做實驗，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我的腦袋已被調查過很多次了呢……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯～",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "關於能力的部分該怎麼說起呢？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n說到阿斯特朗……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就用魔法來代稱吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我啊，",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "曾經是一個能夠使用各種魔法的魔法師喔。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不管在現實中，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還是阿斯特朗這裡。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才不厲害呢？",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你不覺得會運動或是很會算數的人還比較厲害嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "結果我還因為",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "過度使用能力，被真那他們抓到了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n在這邊本來也能使用，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但突然間就不能用了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的沒什麼了不起喔。",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "被擅自改名叫矛依未，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "身體被裝上發信機，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n然後還一～直得聽那些傢伙命令做事之類的……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然實驗很無聊，",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但遊戲很有趣啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n只要進入遊戲裡，所有麻煩的事情",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "全都能忘掉！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在這個世界",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "變成現在這模樣的更早以前，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我就已經來過這裡囉。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "以測試玩家的身分。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也不會討厭幫忙除錯呢。",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n除錯可是",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "讓這世界變得更美麗的工作喔！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在測試期間也跑了許多的地方所以印象很深刻，",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n現在這世界與以前的不同處，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也十分清楚！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你有地圖嗎？",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我幫你寫上！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣就行了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哎呀，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的可以說是到處亂跑了呢，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n像是和尾狗刀一起跟你們對著打，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n還有把其他的玩家卯起來修理……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "上次遇到你們時，已經是和米奈娃、",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n尾狗刀一起四處戰鬥了呢……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……初次遇到尾狗刀也是在",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "阿斯特朗中啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n他是個對什麼事都怕麻煩，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "令人火大的傢伙。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但該做的事還是會好好做，",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "若我有什麼困難，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然一邊抱怨，還是會幫助我，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是個好人喔。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也想幫助那傢伙，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我也希望他能請我幫忙。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "他居然連我的事都忘了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀那傢伙……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "必須盡可能地",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "讓他快點清醒呢！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很好～！",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_035"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要上囉──！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我和你，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還有大家！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔！",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我已經恢復精神了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n……謝謝你！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "果然是個好人呢，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "差不多該回去了吧！",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你不在的話，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n貪吃佩可和可可蘿會擔心的吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "今天多虧你讓我恢復了精神。",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_038"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n如果下次你遇到什麼事情，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就換我來幫你打起精神！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "約好了喔！",
        "unit_id": 106112,
        "voice": "vo_adv_1061001_039"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "――矛依未這麼說著，\n並對著{player}展現出燦爛的笑容。"
    }
]