    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "啊呣",
        "unit_id": 136031,
        "voice": "vo_adv_4010238_000"
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "啊呣……♪",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "真是太好吃了，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "騎士先生……♪",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "感謝您今天",
        "unit_id": 136031,
        "voice": "vo_adv_4010238_001"
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "約我出來。",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n自從在電視上看到廣告之後，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "我就一直對這個",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "「照燒",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "三重牛肉聖母峰",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "～添加三種起司～」",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "很感興趣。",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "但因為失去記憶，不太敢外出活動……",
        "unit_id": 136031,
        "voice": "vo_adv_4010238_002"
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "再加上我又這麼高大，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n很容易引起他人側目，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "所以不自覺就想要躲在家裡……",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "我也好幾天",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "沒有呼吸到外面的空氣了……",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "我記得您說，",
        "unit_id": 136031,
        "voice": "vo_adv_4010238_003"
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "接下來要去購物中心對吧？",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "呵呵，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "我也很期待去那裡。",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n只要是跟騎士先生在一起，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "到哪裡我都願意。",
        "unit_id": 136031
    },
    {
        "type": "background",
        "background": "510281"
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "呼……",
        "unit_id": 136031,
        "voice": "vo_adv_4010238_004"
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "一口氣逛完這麼多間商店，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n讓我都不禁雀躍起來了。",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "其中特別吸引我的",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "是珠寶店……",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "看著那些漂亮的戒指，",
        "unit_id": 136031,
        "voice": "vo_adv_4010238_005"
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "我就會開始想像",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n它們戴在自己身上的樣子……",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "想必",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "我在失去記憶之前，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n也是個喜愛珠寶的人吧。",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "這是……",
        "unit_id": 136031,
        "voice": "vo_adv_4010238_006"
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "項圈？",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n可是",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "您為何……？",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "您竟然記得我的生日……",
        "unit_id": 136031,
        "voice": "vo_adv_4010238_007"
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "太感謝您了，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "騎士先生。",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "送我項圈……",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "感覺好像把我當成您的所有物一樣，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n太棒了。",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "那麼，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "我這就試戴看看……",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "試戴、",
        "unit_id": 136031,
        "voice": "vo_adv_4010238_008"
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "看看……",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "啊啊、",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "啊啊啊……",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "怎麼會這樣……",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n我的脖子太粗，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "騎士先生送的項圈",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n戴不上去……",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "啊啊……！",
        "unit_id": 136031,
        "voice": "vo_adv_4010238_009"
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "手腕的話我就戴得上去了。",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n而且這麼一來，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "我就可以時時刻刻都看到",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n騎士先生送我的東西。",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "太好了……",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "我要再次……",
        "unit_id": 136031,
        "voice": "vo_adv_4010238_010"
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "跟您說聲謝謝，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "騎士先生。",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "不論是您送給我的禮物，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "\n還是",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "您對我的體貼關照，",
        "unit_id": 136031
    },
    {
        "type": "dialogue",
        "name": "夜雲",
        "words": "我都會一輩子銘記於心。",
        "unit_id": 136031
    }
]