[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在與智等人的激戰後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n輝美自己表明身分，並遭到逮捕。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而蘭德索爾因此一時間騷動不已。"
    },
    {
        "type": "background",
        "background": "501870"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──在那的兩日後，蘭祭的最後一天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n蘭德索爾的騷動也稍微平息下來了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "七七香與鈴為了要享受蘭祭，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與{player}一起，再次來到會場。"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呀～",
        "unit_id": 123711,
        "voice": "vo_adv_5102007_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然發生了很多事！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n但能夠像這樣逛逛和平的文化祭，真是開心啊～！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是啊。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "儘管如此……",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n直播圈的人們好像還是一陣混亂呢。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒辦法啊，",
        "unit_id": 123711,
        "voice": "vo_adv_5102007_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "畢竟頂尖直播主突然不在了。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "接下來",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就是新的時代……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n一定還會有新的人氣直播主出現吧！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "希望下一個站在直播界頂端的遊戲實況主，",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是一個不會引起問題，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n或是把七七香的魔法斬破的人呢。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……咦？",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在那裡的人是……",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊啊啊，",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎麼辦……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n想逛的地方好多……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "想在遊戲展示會上",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "確認一下最新的遊戲……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還有",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好像也有舉辦模型展示，真想去看啊……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……智啊，",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳看起來很有活力呢。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊！？",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "鈴！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還有",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "七七香跟你……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真沒想到會在這裡遇到妳，",
        "unit_id": 123711,
        "voice": "vo_adv_5102007_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "智閣下！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳好像有很多地方想去，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n要不要跟我們一起行動呢？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "絕對會很好玩的！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "謝謝妳的邀請……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但作為【王宮騎士團】的成員，\n還有文化祭的警備任務……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以不能去玩……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不用擔心那種事啦。",
        "unit_id": 104711,
        "voice": "vo_adv_5102007_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳想去逛逛的話，我允許妳去喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純！",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以嗎……！？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104711,
        "voice": "vo_adv_5102007_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "當然了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "應該說，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我很希望妳能去放鬆一下。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為小智",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在祭典的護衛任務上真的非常努力了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳就好好去玩吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔喔！",
        "unit_id": 123711,
        "voice": "vo_adv_5102007_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那真是太好了～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "智閣下！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……話說回來，",
        "unit_id": 104711,
        "voice": "vo_adv_5102007_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正好你們都在。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n關於小輝美，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我有些事想跟你們說。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小輝美被逮捕之後，",
        "unit_id": 104711,
        "voice": "vo_adv_5102007_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n對之前所有罪行當然她都認罪了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n似乎對於自己",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "至今的行為，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "打從心裡懺悔著。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還有……",
        "unit_id": 104711,
        "voice": "vo_adv_5102007_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我這裡有一封要給小智的留言。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "給我……？",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_018"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "……小智妳擁有能夠成為",
        "unit_id": 16712,
        "voice": "vo_adv_5102007_019"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "蘭德索爾第一劍士的才華。",
        "unit_id": 16712
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n希望妳能以喜歡的事物為心靈支柱，",
        "unit_id": 16712
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "朝向劍之道持續邁進。",
        "unit_id": 16712
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n我會一直支持妳的。",
        "unit_id": 16712
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "妳的粉絲敬上……",
        "unit_id": 16712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……以上就是留言內容。",
        "unit_id": 104711,
        "voice": "vo_adv_5102007_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "謝謝。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "既然受到別人的鼓勵……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我就得好好加油",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "才行呢。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_5102007_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也支持著妳喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……不過呢，",
        "unit_id": 104711,
        "voice": "vo_adv_5102007_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "從剛剛開始我就有感覺到……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小智妳",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "現在表情非常開朗呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是這樣嗎？",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果真是這樣……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可能是因為我下定決心，要對自己誠實了吧。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我決定對於自己喜歡的東西，",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要誠實說喜歡！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣啊。",
        "unit_id": 104711,
        "voice": "vo_adv_5102007_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我想這次文化祭活動真的發生了很多事……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但同時，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對於小智來說也是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很好的經驗吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這次真是辛苦妳了。",
        "unit_id": 104711,
        "voice": "vo_adv_5102007_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n好了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你們可以去玩了喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好的！",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "首先是……！",
        "unit_id": 123611
    },
    {
        "type": "background",
        "background": "501860"
    },
    {
        "type": "dialogue",
        "name": "攤主",
        "words": "……啊！",
        "unit_id": 1,
        "voice": "vo_adv_5102007_029"
    },
    {
        "type": "dialogue",
        "name": "攤主",
        "words": "是之前跟「Shiny★智」很像的小姐。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤主",
        "words": "\n妳",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤主",
        "words": "來找我玩了呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是的。",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為我",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "無論如何都想買那本同人誌……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "請問",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那本同人誌還有在賣嗎……？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "攤主",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_5102007_031"
    },
    {
        "type": "dialogue",
        "name": "攤主",
        "words": "還有很多喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤主",
        "words": "\n嘿嘿……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤主",
        "words": "我是第一次聽人說",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤主",
        "words": "「無論如何都想買」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤主",
        "words": "這句話呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤主",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤主",
        "words": "來，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤主",
        "words": "請收下。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "謝謝您……！",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我第一次買魔法少女的同人誌耶……♪",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且竟然是以我為主角的……！",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "某種程度來說也算是自肥吧……！　",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "再仔細看看，",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_034"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "從封面開始就可以感受到非常用心！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "把這個招牌姿勢",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "畫得惟妙惟肖！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "智閣下",
        "unit_id": 123711,
        "voice": "vo_adv_5102007_035"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的很喜歡魔法少女呢！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "姆呵呵……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n該不會是七七香的",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔法少女收藏品",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要派上用場的時候了嗎！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我想看……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n而且我還想跟",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "七七香一起聊魔法少女的事……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……不久前還說對",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_037"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "魔法少女沒興趣耶。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "看她們這麼高興，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我就不吐嘈了。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼，",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_038"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "下一站要去哪呢？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我們姑且",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可以陪妳到最後喔。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_039"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "下一個地方是……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，智跟七七香一行人一起逛會場，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n盡情享受了文化祭的樂趣。"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呀～",
        "unit_id": 123711,
        "voice": "vo_adv_5102007_040"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在文化祭上大玩特玩了一番！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不只好好欣賞了《魔法少女小莎莉》的",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n萬聖節限定ver模型，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也逛了好多企業攤。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "同人誌也買了不少啊～",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_041"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "七七香買了些什麼？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嘿嘿……",
        "unit_id": 123711,
        "voice": "vo_adv_5102007_042"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳有興趣？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "給妳看看吧！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "鏘鏘！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "《橡子遊俠vs暮光流星群》！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼啊，",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_043"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不管怎麼想都是",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我會輸吧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n實力差太多了，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就算只有七七香一個人，我也束手無策啊。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "別擔心！",
        "unit_id": 123711,
        "voice": "vo_adv_5102007_044"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這種寫「vs」的作品，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "通常來說，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n之後就會有共同的敵人出現，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而轉變成共鬥的模式。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "順便一提！",
        "unit_id": 123711,
        "voice": "vo_adv_5102007_045"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "蘭德索爾其實對「真人同人」的接受度滿高的……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果是東國之類的地方，對同人誌販售會好像相當敏感呢！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "跟我們這邊有很多差異，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以要小心一點喔！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_046"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我們是被人家給創作的，又不是創作的那一方，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n到底是要小心什麼才好？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我會銘記在心的。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "話說回來……",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_047"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n文化祭如何啊？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "智？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_048"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我玩得很開心。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真的是，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "彷彿心裡面充滿了幸福的感覺……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "太開心了。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣啊。",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_049"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這不是",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很好嗎？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……對了。",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_050"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "之前也有跟妳說過，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我們",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有時候會舉辦遊戲會對吧？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "如果妳有興趣的話，",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_051"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "隨時都歡迎妳來喔。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n再一起打遊戲吧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳喜歡",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "玩遊戲吧？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_052"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我之前曾經拒絕過一次了，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還可以再接受妳們的邀請嗎？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我之前明明還說過「不是很理解遊戲有趣在哪」，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這種這麼失禮的話……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那種事別放在心上啦。",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_053"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我有個四人對戰的遊戲，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我們三個一起同心協力打倒",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "依里依里吧！",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "三人一起上都還不知道打不打得贏咧！",
        "unit_id": 123711,
        "voice": "vo_adv_5102007_054"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "畢竟依里閣下",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "跟魔王一樣強！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有這麼強嗎……！？",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_055"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "正因為如此才值得挑戰，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好像會很好玩……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_056"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就決定啦。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "下次",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大家一起玩吧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n……",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是說，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也逛累了，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們也差不多該回去了。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "回去然後",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "睡覺。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不對，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說錯了。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "睡覺，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "然後回去。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "七七香，",
        "unit_id": 123511,
        "voice": "vo_adv_5102007_057"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "再把床拿出來。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "把我送到公會小屋吧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不然，離這邊比較近的【哞哞自衛隊】也可以。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是的，",
        "unit_id": 123711,
        "voice": "vo_adv_5102007_058"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "又要我出馬了～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好吧，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為鈴閣下在這次文化祭中很努力！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我完全有意願",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "送妳過去！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼，",
        "unit_id": 123711,
        "voice": "vo_adv_5102007_059"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就要在這邊說再見啦！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我回去之後還得要整理同人誌跟",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "同人魔導書！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n整理的時光也很有趣！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_060"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "她們兩個",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "回去了呢。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……我們也",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "差不多該走了嗎？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……嗯，",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_061"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也是這麼覺得。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為我察覺到了什麼才是重要的事。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我啊，",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_062"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "喜歡玩遊戲，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "喜歡Cosplay、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "喜歡漫畫，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我最喜歡……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "最喜歡魔法少女了！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "或許，",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_063"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "未來長大之後，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n喜歡的東西搞不好會改變。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但我覺得，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那也沒有關係。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "重要的是……",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_064"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要誠實面對",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "自己「喜歡」的這份心情。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我會",
        "unit_id": 123611,
        "voice": "vo_adv_5102007_065"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "貫徹自己的喜好，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n從現在開始，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一直貫徹下去──",
        "unit_id": 123611
    }
]