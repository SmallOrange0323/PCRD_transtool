        "words": "是、",
        "unit_id": 126011,
        "voice": "vo_adv_2203006_064"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是這樣啊……",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "嚇了我一跳。",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "瑟瑟",
        "unit_id": 130911,
        "voice": "vo_adv_2203006_065"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "發抖……",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n我的尾巴，",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "都嚇得豎起來了……",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……原來如此。",
        "unit_id": 125811,
        "voice": "vo_adv_2203006_066"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "難怪萊拉耶爾小姐過去",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n沒有使用",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "皇家裝備",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "來驅逐魔物啊。",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "因為怕會像這樣，",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "嚇到大家……",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_2203006_067"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "當然，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "需要大幅消耗力量的事，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我都仰賴克蘿茜和沃爾加諾等人替我處理，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n這樣就能在不使用皇家裝備的情況下解決……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "說是這麼說。",
        "unit_id": 126511,
        "voice": "vo_adv_2203006_068"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但接下來，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這樣可能就行不通了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這次的事件，我越是深思越是確信，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n威脅「吉歐‧提格尼亞」的危險",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "會十分棘手。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "似乎是呢。",
        "unit_id": 106011,
        "voice": "vo_adv_2203006_069"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有陷害貪吃佩可他們的傢伙，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還有使用不存在於阿斯特朗及吉歐‧提格尼亞的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "蜘蛛型魔物的傢伙……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在某個地方，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "肯定有幕後黑手吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_2203006_070"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n雖然說，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "目前，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還不曉得是誰，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "──雖不知何人，",
        "unit_id": 126512,
        "voice": "vo_adv_2203006_071"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n但竟敢在我領土上，",
        "unit_id": 126512
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "以此種雕蟲之輩玷汙領土──",
        "unit_id": 126512
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "豈有此理。",
        "unit_id": 126512
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n吾必要找出此人，",
        "unit_id": 126512
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "將其九族",
        "unit_id": 126512
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "全數誅殺。",
        "unit_id": 126512
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "噫噫噫！？",
        "unit_id": 130911,
        "voice": "vo_adv_2203006_072"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "萊拉耶爾小姐，",
        "unit_id": 105811,
        "voice": "vo_adv_2203006_073"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳又變成了傲慢模式喔～！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請冷靜下來啊～！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，雖然麻煩不斷──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但{player}一行人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n變得和萊拉耶爾公主更和睦了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "still",
        "still": "220300601"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "本次",
        "unit_id": 193711,
        "voice": "vo_adv_2203006_074"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "放到「吉歐‧提格尼亞」的魔物，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n大多都只是利用那群人世界中的魔寶石",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所製造的產物。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n您沒有受到任何損失。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "──放肆。",
        "unit_id": 1,
        "voice": "vo_adv_2203006_075"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n妳這傳令，頭抬得太高了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "妳叫「芙蕾雅」，",
        "unit_id": 1,
        "voice": "vo_adv_2203006_076"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "是吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n在隔開世界與世界的牆上",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "挖出一洞的手腕，吾是買帳。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n但如此狹隘的窄道，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "頂多只得讓些不值一提的小卒通過吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……如您所說，我真是愧疚，",
        "unit_id": 193711,
        "voice": "vo_adv_2203006_077"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "女士。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "您無與倫比，",
        "unit_id": 193711,
        "voice": "vo_adv_2203006_078"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "蒐集了高密度情報量的資料庫。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "像我們這種卑微的小民",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "光是要獨自穿越一個世界，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "就夠困難了……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "不需辯解，",
        "unit_id": 1,
        "voice": "vo_adv_2203006_079"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n吾要的只有成果。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "蒐集天下全數輝煌，",
        "unit_id": 1,
        "voice": "vo_adv_2203006_080"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "令吾心躍動。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n摧毀那幾人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "向吾所編織的命運反抗的礙事公主們。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n以及──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "──以及，",
        "unit_id": 1,
        "voice": "vo_adv_2203006_081"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n將囚禁吾肉身的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "這座可惡牢籠，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n亦即名為「吉歐‧格黑納」的扭曲盆景，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "給徹底粉碎。",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501790"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193711,
        "voice": "vo_adv_2203006_082"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……",
        "unit_id": 193711,
        "voice": "vo_adv_2203006_083"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……真是的。",
        "unit_id": 193711,
        "voice": "vo_adv_2203006_084"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n到底誰才是「傲慢」啊……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……阿剌克涅女士。",
        "unit_id": 193711,
        "voice": "vo_adv_2203006_085"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "是被囚禁在背面世界，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "無法處刑的存在之一。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n同時也是「六凶」之一……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "傲慢不遜，",
        "unit_id": 193711,
        "voice": "vo_adv_2203006_086"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "瞧不起自己以外的所有東西……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n即使看她非常不順眼，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "但為了達成目的，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "無可爭論的，我必須借用她的力量……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……無妨。",
        "unit_id": 193711,
        "voice": "vo_adv_2203006_087"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n現在就以走狗的身分，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "弄髒我這雙手吧。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "這都是為了",
        "unit_id": 193711,
        "voice": "vo_adv_2203006_088"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "屬於「我」的正義。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "為了在這世界引發革命。",
        "unit_id": 193711
    },
