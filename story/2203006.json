[
    {
        "type": "background",
        "background": "501780"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}等人打倒了支配「大夢想樂園」的蜘蛛型魔物，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並和萊拉耶爾公主和解了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而就在此時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【蠻賊三姊妹】偷襲他們。"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "呀哈哈哈♪",
        "unit_id": 130211,
        "voice": "vo_adv_2203006_000"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n死了嗎？",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n死掉了嗎～？♡",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "這、",
        "unit_id": 130111,
        "voice": "vo_adv_2203006_001"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "這陣煙霧讓人看不清楚……",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "喂，布武機。",
        "unit_id": 130012,
        "voice": "vo_adv_2203006_002"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n妳沒有打中皇家裝備吧？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "要是寶物被砲擊弄壞，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "妳就真的是個傻子了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "我又不是笨菜姊～",
        "unit_id": 130211,
        "voice": "vo_adv_2203006_003"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n我的瞄準可是很完美的～",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "不過～？",
        "unit_id": 130211,
        "voice": "vo_adv_2203006_004"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n那個雜碎哥哥倒是～被炸飛了～♡",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "深淵炸裂！！",
        "unit_id": 106011,
        "voice": "vo_adv_2203006_005"
    },
    {
        "type": "background",
        "background": "501780"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呀",
        "unit_id": 130111,
        "voice": "vo_adv_2203006_006"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊啊啊啊！？",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼、",
        "unit_id": 106011,
        "voice": "vo_adv_2203006_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可惡！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那台車好像有魔法防禦之類的東西啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "好險～！",
        "unit_id": 130211,
        "voice": "vo_adv_2203006_008"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "真是的～",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n明明叫你們去死了～",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈！",
        "unit_id": 130012,
        "voice": "vo_adv_2203006_009"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n這不是還活得好好的嗎！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "很好，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不這樣的話就沒什麼樂趣可言了！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "多虧普蕾西亞有注意到，",
        "unit_id": 126011,
        "voice": "vo_adv_2203006_010"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我們才能勉強避免被直接打中……",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "噗咻……",
        "unit_id": 126111,
        "voice": "vo_adv_2203006_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【蠻賊三姊妹】……！",
        "unit_id": 105911,
        "voice": "vo_adv_2203006_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n竟瞄準我們和魔物對戰後體力消耗殆盡的時機……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "妳們幾個，",
        "unit_id": 126511,
        "voice": "vo_adv_2203006_013"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就是【蠻賊三姊妹】──",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也就是盯上我們的皇家裝備的",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "竊賊對吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "喔喔～",
        "unit_id": 130012,
        "voice": "vo_adv_2203006_014"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n那邊那位就是萊拉耶爾公主啊？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "初次見面啊。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "所以說妳背上的那個，",
        "unit_id": 130012,
        "voice": "vo_adv_2203006_015"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就是妳的皇家裝備吧。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n雖然耗能有夠扯，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "但威力挺大的嘛。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我很中意喔──",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……話說回來，",
        "unit_id": 130012,
        "voice": "vo_adv_2203006_016"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "妳啊，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那身衣服會不會太誇張啦？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n這樣也算是皇族嗎？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我、",
        "unit_id": 130111,
        "voice": "vo_adv_2203006_017"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我覺得姊姊的衣著也十分誇張……",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "雖然我們不是皇族，",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "而是盜賊。",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "盜賊……",
        "unit_id": 130911,
        "voice": "vo_adv_2203006_018"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "啊",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n難不成，",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "利用那些蜘蛛",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n破壞「大夢想樂園」的",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "就是妳們？",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不僅如此，",
        "unit_id": 126011,
        "voice": "vo_adv_2203006_019"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n在「吉歐‧提格尼亞」中",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "放入阿斯特賴亞大陸的",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n魔物的人，",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "也是妳們吧……！？",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "啥～？",
        "unit_id": 130211,
        "voice": "vo_adv_2203006_020"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n請不要亂栽贓喔～？",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我們三個，",
        "unit_id": 130111,
        "voice": "vo_adv_2203006_021"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "可沒有做那種事啊……？",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我們只是看你們和蜘蛛開始戰鬥，",
        "unit_id": 130012,
        "voice": "vo_adv_2203006_022"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n就在等牠們削弱你們的狀態。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "但可不知道是哪裡的哪個傢伙做的好事。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "再說，",
        "unit_id": 130012,
        "voice": "vo_adv_2203006_023"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "把好不容易搶來的寶石當作魔物的餌食，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n這種事太浪費了我們才不會做！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……哼～",
        "unit_id": 106011,
        "voice": "vo_adv_2203006_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n感覺不像在說謊呢……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "【蠻賊三姊妹】啊。",
        "unit_id": 126511,
        "voice": "vo_adv_2203006_025"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n和貪吃佩可公主相同，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我並不打算",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "將皇家裝備交給妳們。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "請在妳們變得更加聲名狼藉前，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "回到原本的世界吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈！",
        "unit_id": 130011,
        "voice": "vo_adv_2203006_026"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "妳也明白吧？",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n聽到那種命令，",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "盜賊是不可能就此作罷的。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請別小看我們……！",
        "unit_id": 105811,
        "voice": "vo_adv_2203006_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們是無法從我們身上，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "搶走任何東西的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "啊哈～♪",
        "unit_id": 130211,
        "voice": "vo_adv_2203006_028"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n既狼狽不堪還真的發火了～♡",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "真丟臉～♡",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算很丟臉，",
        "unit_id": 105811,
        "voice": "vo_adv_2203006_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算很難看！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要我們同心協力，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就絕對不會輸！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "貪吃佩可公主……",
        "unit_id": 126511,
        "voice": "vo_adv_2203006_030"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "同心協力，",
        "unit_id": 130011,
        "voice": "vo_adv_2203006_031"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "對吧？",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你們和她的國家是同盟嗎？",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我們還沒有締結",
        "unit_id": 126511,
        "voice": "vo_adv_2203006_032"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那種關係……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使不是同盟，",
        "unit_id": 105811,
        "voice": "vo_adv_2203006_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要同心協力也是很容易的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為萊拉耶爾小姐，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
