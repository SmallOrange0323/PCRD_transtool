[
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そういえば君は、",
        "unit_id": 111011,
        "voice": "vo_adv_6023309_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n男女共学化への施策として",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "試験的に当院へしょうへいされたわけだが。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "仮に共学化が確定した場合、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君は正式に編入を希望するのかね。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "うむ、",
        "unit_id": 111011,
        "voice": "vo_adv_6023309_001"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "よくぞ言った。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そのときは改めて篤く歓迎しよう。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "もっとも、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "確定したとて施行は",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "だいぶ先の話になるだろうが……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あれ？　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "その頃ぼく",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "もう卒業してない？　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "えっ？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "道理だな。",
        "unit_id": 111011,
        "voice": "vo_adv_6023309_002"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君の学籍はもとより",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ルーセント学院にあるのだから。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "だが、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あちらは大らかな校風だ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "端的に換言すれば、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "何とでもなる。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "というわけで、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "安心したまえ同志。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "二重学籍どんと来いだ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なるほど、",
        "unit_id": 111011,
        "voice": "vo_adv_6023309_003"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "先のことなど誰にも分からない。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "だからこそ",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "人は今日を精一杯生きる。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君はそう言いたいのだね。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いや、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "嘘をつくんじゃあないよ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "本当に分かってないだけだろう。",
        "unit_id": 111011
    }
]