        "voice": "vo_adv_1288004_048"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不對，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也是一樣的嗎？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無法停留在同一個地方，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_049"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就算身處封閉的水槽，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也會憧憬著外面的世界而感到焦躁。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若我是孤身一人，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_050"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "心中可能早已屈服了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n對改變不了的未來感到絕望，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "並向命運屈膝……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或者",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_051"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會只剩憤怒裝滿心中，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n並持續戴著假面具生活。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……但是，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_052"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "自從遇見了你，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為有你在，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我才沒有迷失自我。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若是",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_053"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我將我心懷的一切全盤托出，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n並向你求助……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一定",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會毫不猶豫地回應我吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算是在洶湧的海浪中，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_054"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算呼嘯的暴風雨將至……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就算是沒有勝算的戰鬥，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n即便如此，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也還是會盡你所能。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我竟會獲得一個能如此信任的人。",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_055"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n若是和你相遇之前的我，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "肯定無法相信吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_056"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我…………",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我以前一直",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_057"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "認為自己身在水槽裡。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那或許只是我自認如此。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我並不是在對抗無法改變的命運，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_058"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n而是其實",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在與你相遇時，早已在改變了……",
        "unit_id": 100332
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "128800402"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵……",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_059"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若真是那樣，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那可真是個滑稽。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我可能很久以前就越過我設想的高牆了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "極小的事件",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_060"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會大幅改變未來，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這種現象是叫什麼呢……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……沒錯，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_061"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "蝴蝶效應。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過真虧",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你知道呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "最近讀的小說裡有出現，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_062"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為很有趣就記住了？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哦，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果是被你誇獎到這種程度的作品，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那我稍微有點興趣呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦？",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_063"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你要借我嗎？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天回程途中",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那還真是又……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很突然呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過……",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_064"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也是呢，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我就接受你的好意吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "畢竟我並不知道",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_065"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼事會如何改變未來……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "況且，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不論是怎樣不明確的未來，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n至少你會陪在我身邊。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯吧？",
        "unit_id": 100332
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1288004_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有做一場好夢嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然你大概沒有自覺，",
        "unit_id": 190011,
        "voice": "vo_adv_1288004_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但在這個世上，有很多人因為你而改變了喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "與誰相遇、",
        "unit_id": 190011,
        "voice": "vo_adv_1288004_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "並建立羈絆……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也有人被你一直以來所做的事",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "拯救了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這一點",
        "unit_id": 190011,
        "voice": "vo_adv_1288004_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正像蝴蝶拍動翅膀一樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n儘管是瑣碎的契機……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也會慢慢",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "引起改變未來的連鎖反應。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "既然無法看透未來，",
        "unit_id": 190011,
        "voice": "vo_adv_1288004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那就只能相信現在覺得",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "最好的道路並前進了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "最終",
        "unit_id": 190011,
        "voice": "vo_adv_1288004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能說服自己的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就只有自己……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怜或許已經",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "知道這一點了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之，",
        "unit_id": 190011,
        "voice": "vo_adv_1288004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "當你繼續幫助一個個女孩子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果是你，或許連世界都能拯救。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這並不是玩笑，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在我就是這麼想的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "加油喔♪",
        "unit_id": 190011
    },
    {
        "type": "background",
