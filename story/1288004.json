        "voice": "vo_adv_1288004_079"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "讓我們持續吹起新的風吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n畢竟好不容易才獲得了風的屬性之力呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好了，",
        "unit_id": 100311,
        "voice": "vo_adv_1288004_080"
    },
