[
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克服了暴風雨的考驗的怜與{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再次造訪了布里薩溪谷。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……果然如此。",
        "unit_id": 100311,
        "voice": "vo_adv_1288004_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不論是從這個地方",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還是祖父的劍，都感受不到力量。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "考驗結束後，",
        "unit_id": 100311,
        "voice": "vo_adv_1288004_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "試著來看看有沒有發生變化……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但看來",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡能做的事都已經結束了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 100311,
        "voice": "vo_adv_1288004_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這晴天簡直就像那場暴風雨是騙人的呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不對，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這不會……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有點太耀眼了嗎……？",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我說你，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是這邊。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我在等你喔。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你要喝什麼飲料？",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……特調？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我知道了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不好意思，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "追加一杯特調咖啡。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉突然把你叫出來。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "最近",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我家管得越來越嚴了呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要是被事先知道安排，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有可能會被察覺。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "考慮到我的性格，這根本是反效果，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n真希望他們有差不多領會到這點就好了……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但要是他們有這麼好溝通，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也就不用辛苦了吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "噢，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "馬上進入正題吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我偶然間",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "得到了這樣的東西喔。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我學校作業交出的作文，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n在競賽中運氣很好地得獎了呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是附帶的獎賞喔。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是兩張一組的票……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這間似乎是國內首屈一指的水族館。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "機會難得，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想說不用的話也很浪費。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果票只有一張，我就自己去了，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是三張的話，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也想過要約優衣和日和……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但總之",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是兩張呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為是兩張的關係。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你想，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我如果只約其中任何一方，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n該怎麼說……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也會覺得不太對吧？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唔，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個嘛……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "正因為是你",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "才行。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算知道我家的事，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也能自然地與我相處吧？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我能像這樣無顧忌地相處的對象",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "絕對不多。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你總是在幫助我，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也想把這……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "當作",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝禮……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……難不成你很為難",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗎？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這、",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "太好了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們走吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果要把館內全都逛完，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "多少加快腳步也好。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "感謝",
        "unit_id": 1,
        "voice": "vo_adv_1288004_020"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "各位的光臨。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n還請慢慢",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "欣賞。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……館內意外地暗呢。",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是為了配合展示的魚",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而調整了照明嗎？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對面那邊很亮呢。",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那是",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這座水族館招牌的……",
        "unit_id": 100332
    },
    {
        "type": "still",
        "still": "128800401"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "…………",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然有聽說這裡是全國首屈一指……",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但這還真是驚人呢……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊……",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我一時",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說不出話……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這個水槽",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是在重現珊瑚礁之海嗎？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還不只這裡。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n同規模的大水槽",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有好幾個……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "每一個都各自重現了不同的海洋……",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "世界上",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有這麼多的海洋存在呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看著悠游的魚群，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n該說緊張的心情放鬆了嗎……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總覺得連呼吸都",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "稍微輕鬆了一點啊。",
        "unit_id": 100332
    },
    {
        "type": "still",
        "still": "128800402"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你比我還更興奮不是嗎。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n呵呵……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不枉我約你了啊。",
        "unit_id": 100332
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "128800401"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這些魚能活多久呢……",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n聽說有些種類",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可以活幾十年。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也有推算活了30年以上的魚啊。",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n在比我出生還",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "更早之前就……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這些魚",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會不會想出去外面呢？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡的展示說明上也有寫，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這個水槽",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有配合魚群整頓槽內的環境。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "魚群之中",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果有在水族館出生的魚，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那就也有從大自然中收集來的魚了吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這些魚",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會就這樣一直在水槽中生存。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但是，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該也有原本是在大海中游泳的魚。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "了解外面世界的魚群，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_038"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會想些什麼呢？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在這水槽中生活比較幸福嗎……",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我忍不住會去思考這種事。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無聊……",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這我連想都沒想過呢……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不過，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_041"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說的也是呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我一定",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也會得出一樣的回答。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不會否定在安寧中度過。",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但是，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那樣我",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不會滿足的。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "假設要遵循誰的意志前進，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "然後成為某個人。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那樣就……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是我了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算是為了我量身打造出來的環境，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也不會覺得止步於其中是件好事吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算身在水槽中，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_045"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也會持續憧憬外面的世界，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "直至生命的盡頭。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦？",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "鮪魚？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……啊啊，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是在對面的水槽裡吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "展示說明寫的，",
        "unit_id": 100332,
        "voice": "vo_adv_1288004_047"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我剛才也有讀到呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n透過持續游泳，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "讓水通過鰓",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來呼吸的結構……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我記得",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是叫撞擊換氣吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是不持續游泳就不能呼吸，這種事，還真費力啊……",
