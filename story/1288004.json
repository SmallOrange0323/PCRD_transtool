        "voice": "vo_adv_1288004_073"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡是……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我不小心睡著了嗎……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我總是一直被你幫助呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1288004_074"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不對，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "並不只有你。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不論是優衣教我的料理，",
        "unit_id": 100311,
        "voice": "vo_adv_1288004_075"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "向日和學到的積極，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從祖父那裡繼承來的劍，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有與志那都的修行……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一切交會在一起，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "才有了現在的我。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那是叫什麼呢……",
        "unit_id": 100311,
        "voice": "vo_adv_1288004_076"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總覺得我好像有夢到啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是那樣嗎……？",
        "unit_id": 100311,
        "voice": "vo_adv_1288004_077"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n總覺得是更不一樣的話……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 100311,
        "voice": "vo_adv_1288004_078"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個情況，那句話可能也適用。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……與你的相遇，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對我而言就是嶄新之風呢。",
