        "voice": "vo_adv_7019005_078"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不嫌棄的話，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "下次可以陪我比試一下嗎？",
        "unit_id": 104732
    },
