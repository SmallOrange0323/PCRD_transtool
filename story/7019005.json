    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是在做夢嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我不曉得。",
        "unit_id": 104711,
        "voice": "vo_adv_7019005_081"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那真的是很不可思議的現象……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那麼，少年，",
