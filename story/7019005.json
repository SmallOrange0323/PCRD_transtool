        "type": "dialogue",
        "name": "純",
        "words": "對了，",
        "unit_id": 104711,
        "voice": "vo_adv_7019005_084"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫妮卡。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不嫌棄的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "下次可以陪我比試一下嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……咦？",
        "unit_id": 105311,
        "voice": "vo_adv_7019005_085"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "遭受來自空中的奇襲是個難題，",
        "unit_id": 104711,
        "voice": "vo_adv_7019005_086"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我想試著解決。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果有像莫妮卡這麼強的對手陪我練習，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我會很感謝……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
