        "name": "純",
        "words": "……這樣啊。",
        "unit_id": 104711,
        "voice": "vo_adv_7019005_082"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n既然你有達成目的，我就放心了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那現在就",
