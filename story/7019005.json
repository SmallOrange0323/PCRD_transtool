        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是的，",
        "unit_id": 104732,
        "voice": "vo_adv_7019005_077"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "竟然靠外表來做判斷……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也是有眼無珠呢。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n看來我修行得還不夠。",
