[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在連續戰鬥過後，一行人成功打倒大量的魔物。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這時，有個閃閃發光的東西掉在{player}的腳邊。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喂，",
        "unit_id": 105311,
        "voice": "vo_adv_7019005_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n撿起那個沒問題嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……原來如此。",
        "unit_id": 104711,
        "voice": "vo_adv_7019005_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那就是尋找少年記憶的線索嗎。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這東西真的能幫上閣下的忙嗎……？",
        "unit_id": 105311,
        "voice": "vo_adv_7019005_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔哇！？",
        "unit_id": 105311
    },
    {
        "type": "background",
        "background": "510320"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔喔～～！！",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這裡就是所謂的「遊樂園」嗎！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我還想說怎麼有尖叫聲，",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那個就是雲霄飛車吧！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "居然才那種程度的速度就受不了，也太沒用了！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要是搭上我國的戰鬥機，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可是會連尖叫聲都發不出來的！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔，",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為什麼大家都戴著虎虎的面具？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "明明不是間諜，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "他們是覺得變裝很有趣嗎？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也跟著戴就會明白嗎！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下！",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我要進那家店喔！！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼～",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不小心連伴手禮都買了！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喏！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "除了虎虎的面具跟手帕，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我連變身腰帶都買了！！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "才、",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "才沒有！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這些是我",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要送給小小朋友們的伴手禮！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……雖、",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然不是全部啦。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "重要的是……",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n讓閣下拿我的行李，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n總覺得有些過意不去，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣好嗎？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……嗯、",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然閣下都那麼說了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n可是，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然閣下要我好好享受，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但我可不是來玩的喔。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "扮演虎虎的人……",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我是",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來鑑定其真面目的。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就動畫來看，",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "扮演的人似乎一直壓抑著實力，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但我想確認她在實戰時有多強。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "若她夠有潛力的話，",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我打算遊說她加入我的隊伍。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "換句話說，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是身為軍人的工作！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣閣下明白了嗎！",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我絕對不是",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對跟虎虎見面感到期待！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……呃，",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_015"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喂！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不要露出那種像是很欣慰的表情！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "媽媽！",
        "unit_id": 1,
        "voice": "vo_adv_7019005_016"
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "現在有遊行喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "\n我們快去看吧！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔？",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "她是說遊行？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n是正在進行軍事演習嗎？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "難得都來了，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們也去偵察一下吧！！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是怎樣！？",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n有一堆閃閃發光的車在排隊喔！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "下，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們再靠近一點去看吧！！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……嗯？",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "人不見了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n難不成他",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "迷路了嗎！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……不。",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "該不會迷路人的是我……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒辦法了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就打電話聯絡吧。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我看看，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "包包在……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "…………",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "糟糕！！",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我連行李一起交給他了！！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這、",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這下該怎麼辦才好……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳",
        "unit_id": 104732,
        "voice": "vo_adv_7019005_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "難道是",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "跟媽媽走散了嗎？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔唔，",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_025"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "居然繞到我的背後，真是可惡！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且她",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "居然問我是不是跟媽媽走散……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "了！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n把我當成小孩子的",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "到底是誰！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……嗯？",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_026"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "虎虎的面具？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔喔！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看來妳是",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "虎虎的粉絲吧！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呃……",
        "unit_id": 104732,
        "voice": "vo_adv_7019005_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就是那樣。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我叫純。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳呢？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我叫莫妮卡！",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_028"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還有，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "跟我走散的不是「媽媽」。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我是大人，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且是充滿榮耀的軍人！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……大人？",
        "unit_id": 104732,
        "voice": "vo_adv_7019005_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……喔，",
        "unit_id": 104732,
        "voice": "vo_adv_7019005_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來是那麼一回事嗎。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這個年紀的小朋友，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "每個都是多愁善感。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n她大概是因為被當成小孩對待才生氣的吧。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 104732,
        "voice": "vo_adv_7019005_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是可愛……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫妮卡。",
        "unit_id": 104732,
        "voice": "vo_adv_7019005_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "把妳當小孩子對待，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我感到很抱歉。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那麼，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有什麼是我能幫忙的嗎？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "剛才的話好像有點不太對勁，",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_033"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過算了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n其實我",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "正在找某個男人……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗨，",
        "unit_id": 104732,
        "voice": "vo_adv_7019005_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n抱歉我們遲到了。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……閣下，",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_035"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "抱歉我不小心走散了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呃，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你是在笑什麼啊！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼！？",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_036"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我、",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們會牽手，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n是因為純閣下",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怕我會走散，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我才勉強跟她牽的！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "然後",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_037"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這個糖果是",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "純閣下買給我的……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……事先聲明，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我可沒有露出想要的眼神喔！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不說那個了，",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_038"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你應該有更重要的話要說吧！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我可是第一次知道你們認識喔！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也是嚇了一跳。",
        "unit_id": 104732,
        "voice": "vo_adv_7019005_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒想到妳原來是少年帶來的。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那麼，少年，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我把莫妮卡還你了。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好啦，",
        "unit_id": 104732,
        "voice": "vo_adv_7019005_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "秀很快就要開始了。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你們就好好欣賞吧。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我先告辭了……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "純閣下",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_041"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "走掉了呢。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我聽說她是在這裡工作。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我不小心妨礙到她執行任務了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼，閣下。",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_042"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n來這裡",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就能見到虎虎對吧！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n虎虎人",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在哪裡！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……咦？",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_043"
    },
    {
        "type": "dialogue",
        "name": "虎虎",
        "words": "向天祈禱吧，",
        "unit_id": 104731,
        "voice": "vo_adv_7019005_044"
    },
    {
        "type": "dialogue",
        "name": "虎虎",
        "words": "惡徒！",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "虎虎",
        "words": "\n接受正義的制裁吧……！",
        "unit_id": 104731
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "上啊～！",
        "unit_id": 131,
        "voice": "vo_adv_7019005_045"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "虎虎！！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "加油！！",
        "unit_id": 231,
        "voice": "vo_adv_7019005_046"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就是那裡！",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_047"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很好很好，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "別輸了～！！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "明明動作很輕盈，",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_048"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "拳頭卻十分沉重……！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒想到純閣下就是虎虎……！　",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過，太可惜了。",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_049"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我看得出她一直在壓抑實力。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果有那樣的部下，",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_050"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "應該會很令人安心吧。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我一定要",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "跟純閣下",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "背對背戰鬥一次看看……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……怎麼？",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_051"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "辦得到嗎？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我該怎麼做才行！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "壞蛋首領",
        "words": "咯咯咯……",
        "unit_id": 1,
        "voice": "vo_adv_7019005_052"
    },
    {
        "type": "dialogue",
        "name": "壞蛋首領",
        "words": "\n這樣就結束了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "壞蛋首領",
        "words": "虎虎！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "糟糕！",
        "unit_id": 1,
        "voice": "vo_adv_7019005_053"
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "虎虎陷入危機了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "\n現場有朋友",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "願意跟虎虎一起戰鬥",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "我我！！",
        "unit_id": 1,
        "voice": "vo_adv_7019005_054"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔哇！？",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_055"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n閣下",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為什麼要舉起我的手！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可不是什麼朋友喔！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "那麼……",
        "unit_id": 1,
        "voice": "vo_adv_7019005_056"
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "就那個女孩子！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "\n請上舞台來！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我嗎！？",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_057"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都是閣下害的喔……！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……算了，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然被選上了，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那也沒辦法！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我就像個充滿榮耀的軍人，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "做好覺悟吧！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "──事情就是這樣，",
        "unit_id": 1,
        "voice": "vo_adv_7019005_058"
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "莫妮卡登場了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "只要炒熱現場的氣氛，",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_059"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "讓小孩子們開心就行了是吧。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n只要回想起演習時的事，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這點小事根本沒什麼……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好！　",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "那麼，莫妮卡。",
        "unit_id": 1,
        "voice": "vo_adv_7019005_060"
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "\n請妳從這個舞台上",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "對虎虎",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "\n大喊「加油啊～」──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "虎虎！",
        "unit_id": 105331,
        "voice": "vo_adv_7019005_061"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n既然我來了，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳就可以放心了！！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "秀場大姐姐",
        "words": "……咦？",
