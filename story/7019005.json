        "unit_id": 105311,
        "voice": "vo_adv_7019005_087"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那我也會",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n以榮耀的純白之翼的軍人身分，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n全力向妳挑戰！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104711,
        "voice": "vo_adv_7019005_088"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝妳。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我很期待那一刻的到來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……呵呵。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "純閣下……",
        "unit_id": 105311,
        "voice": "vo_adv_7019005_089"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "再來只要能戒掉",
        "unit_id": 105311,
        "voice": "vo_adv_7019005_090"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會像這樣下意識摸我頭的習慣，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n就沒什麼好抱怨的了……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "算了，",
        "unit_id": 105311,
        "voice": "vo_adv_7019005_091"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "一時之間也急不來。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "純不會說謊的耿直風格令莫妮卡展露笑容。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而那個笑容讓戴著頭盔的純看到入迷。"
    }
