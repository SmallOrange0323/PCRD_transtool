    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "明明一開始只是做為一日店長過來而已，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n結果卻相處了這麼久。",
        "unit_id": 132512
