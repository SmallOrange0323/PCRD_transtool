[
    {
        "type": "background",
        "background": "501162"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "……環境そのものの均衡を崩す魔物。",
        "unit_id": 107011,
        "voice": "vo_adv_6056502_000"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "初期に創られた物が",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "様々な要因で変質を遂げた結果ゆえでしょうね。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n何にせよ、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "データをとっておく価値はあります。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "ええ、",
        "unit_id": 107011,
        "voice": "vo_adv_6056502_001"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "頼みます。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "データ収集を行う分には",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "観察のみで事足りますが、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n周囲への悪影響が気にかかります。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n対処は貴方たちに任せます。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "……私の信頼を裏切らないように。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "気持ちは受け取りましょう。",
        "unit_id": 107011,
        "voice": "vo_adv_6056502_002"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "ですが、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "貴方には貴方のやるべきことがあるはずです。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "裏方はこちらに任せ、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "貴方は魔物退治に集中するように。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "いいですね？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "たまには表舞台で貴方たちと行動するのも一興ではありますが。",
        "unit_id": 107011,
        "voice": "vo_adv_6056502_003"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "今はその時ではありません。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n私は私の為すべきことを為しますので、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "貴方もそのようにしなさい。",
        "unit_id": 107011
    }
]