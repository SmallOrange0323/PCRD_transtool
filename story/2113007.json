        "voice": "vo_adv_2113007_001"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "可可蘿……",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀……！",
        "unit_id": 101511,
        "voice": "vo_adv_2113007_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n竟然抓受傷的人",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "作為人質……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不可以做出",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這種事情哦，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不乖喔！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不乖喔！",
        "unit_id": 106211,
        "voice": "vo_adv_2113007_003"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就算妳這樣說我──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我也是有",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "很多苦衷的啊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "苦、",
        "unit_id": 104011,
        "voice": "vo_adv_2113007_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "苦、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "苦衷……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "對。",
        "unit_id": 106211,
        "voice": "vo_adv_2113007_005"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我剛才也有說過吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我的目的",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就是索爾魔珠。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "在我造成無謂的傷害之前，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "希望你們能快點老實交出來呢──？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你的意思是，",
        "unit_id": 180411,
        "voice": "vo_adv_2113007_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要我們用索爾魔珠交換小可蘿的父親嗎？",
        "unit_id": 180411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 180411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真沒想到你和彌勒",
        "unit_id": 180411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都用這麼卑鄙的手段……！",
        "unit_id": 180411
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "噁。",
        "unit_id": 106211,
        "voice": "vo_adv_2113007_007"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n什麼，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "意思是他也幹了類似的事嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊──討厭討厭，",
        "unit_id": 106211,
        "voice": "vo_adv_2113007_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "光是要綑綁男人就很討厭了，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這明明不是我的興趣啊。",
        "unit_id": 106211
    },
    {
        "type": "still",
        "still": "211300701"
    },
    {
        "type": "background",
        "background": "501204"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然討厭，一開始就別做啊！",
        "unit_id": 180611,
        "voice": "vo_adv_2113007_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n變態！",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "露肚臍男！",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "歪理一堆的妹妹頭！",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊，好過分──",
        "unit_id": 106211,
        "voice": "vo_adv_2113007_010"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "有必要說到這種地步嗎──？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……我想想，",
        "unit_id": 106211,
        "voice": "vo_adv_2113007_011"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n該怎麼辦呢？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n總之，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "若你們肯先解除那個可怕的強化，我會很高興的──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2113007_012"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不愧是",
        "unit_id": 106211,
        "voice": "vo_adv_2113007_013"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "正義的夥伴，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n這麼識相真是幫了大忙。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "話說回來……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這個角色作為人質的價值",
        "unit_id": 106211,
        "voice": "vo_adv_2113007_014"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "比我想的還要高呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "假如你們無視要求攻擊過來，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我馬上就會開溜了說。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就算被稱為「長老」，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這終究",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "仍只是個空殼啊──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要對父親大人見死不救，",
        "unit_id": 105911,
        "voice": "vo_adv_2113007_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這種事",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下辦不到……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯，",
        "unit_id": 106211,
        "voice": "vo_adv_2113007_016"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就是說啊♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n那就照這樣子，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "把那東西交出來吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "最後的索爾魔珠",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就在妳身上對吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔……",
        "unit_id": 105911,
        "voice": "vo_adv_2113007_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……彌勒就不用提了。",
        "unit_id": 105911,
        "voice": "vo_adv_2113007_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要是把魔珠交給尾狗刀，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可不知道",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "他會拿去做什麼壞事。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n……但是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若不交給彌勒，",
        "unit_id": 105911,
        "voice": "vo_adv_2113007_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛梅斯大人會有危險，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若不交給尾狗刀，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "父親大人會有危險。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有，",
        "unit_id": 105911,
        "voice": "vo_adv_2113007_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若湊不齊索爾魔珠，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n將會失去拉比林斯達小姐犧牲自己",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所指示的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n「返回現實的方法」……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……啊啊。",
        "unit_id": 105911,
        "voice": "vo_adv_2113007_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該如何是好……！　",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "……別管我，",
        "unit_id": 107212,
        "voice": "vo_adv_2113007_022"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "可可蘿。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……！？",
        "unit_id": 105911,
        "voice": "vo_adv_2113007_023"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "那顆魔珠",
        "unit_id": 107212,
        "voice": "vo_adv_2113007_024"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "對妳來說──",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "不，",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n若那是引導妳主人的必要之物，",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "千萬不可以交出去。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n妳就當作",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "我已經死了便是。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可、",
        "unit_id": 105911,
        "voice": "vo_adv_2113007_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n父親大人……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊，",
        "unit_id": 106211,
        "voice": "vo_adv_2113007_026"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真是夠了──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這NPC話也太多了吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n可以請你",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "別多嘴嗎──？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "……唔……",
        "unit_id": 107212,
        "voice": "vo_adv_2113007_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……！",
        "unit_id": 105911,
        "voice": "vo_adv_2113007_028"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "……可可蘿，",
        "unit_id": 107212,
        "voice": "vo_adv_2113007_029"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "妳聽好了。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n妳要",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "與妳的主人一同，",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "朝你們的路前進。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n不可以賴著我這種老骨頭不放，",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "耽誤了未來。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "……更何況，",
        "unit_id": 107212,
        "voice": "vo_adv_2113007_030"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n要是就如這男人所言……",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n我並不是妳真正的父親，",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "那就更不用說了……",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎、",
        "unit_id": 105911,
        "voice": "vo_adv_2113007_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼這樣……！",
        "unit_id": 105911
    },
    {
