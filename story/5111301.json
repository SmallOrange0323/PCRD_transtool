[
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "喔喔喔喔喔喔喔喔！",
        "unit_id": 17212,
        "voice": "vo_adv_5111301_000"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這可真是……",
        "unit_id": 106211,
        "voice": "vo_adv_5111301_001"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "形象改變得還真徹底呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你還有心情說笑！",
        "unit_id": 125011,
        "voice": "vo_adv_5111301_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那傢伙看起來很不妙啊！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦咦～？",
        "unit_id": 106211,
        "voice": "vo_adv_5111301_003"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "奇怪了～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我認識的諾維姆，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n不會因為這種程度的對手就退縮啊？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳該不會",
        "unit_id": 106211,
        "voice": "vo_adv_5111301_004"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "變弱了吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你、",
        "unit_id": 125011,
        "voice": "vo_adv_5111301_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你說什麼──！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你才是，一陣子沒看到你，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n判斷力該不會變遲鈍了吧！？",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你先睜大眼睛看好！",
        "unit_id": 125011,
        "voice": "vo_adv_5111301_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看看我這個大壞蛋的戰鬥英姿！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "是是是，",
        "unit_id": 106211,
        "voice": "vo_adv_5111301_007"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "遵命。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……他們",
        "unit_id": 124911,
        "voice": "vo_adv_5111301_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真厲害。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 124811,
        "voice": "vo_adv_5111301_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鬥嘴之餘舒緩了緊張感，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n同時也鼓起了幹勁。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果不是長年互相搭檔，",
        "unit_id": 124911,
        "voice": "vo_adv_5111301_010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "應該是辦不到的。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒空佩服他們了，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "望，我們也上吧！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯！",
        "unit_id": 124811,
        "voice": "vo_adv_5111301_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要讓他們看看，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們也不是省油的燈，不會輸給他們喔！",
        "unit_id": 124811
    }
]