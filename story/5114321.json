[
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵喵喵！？",
        "unit_id": 125111,
        "voice": "vo_adv_5114321_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是一大群招財貓喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "以眼還眼，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "以牙還牙，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "以貓還貓喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就由我來當你們的對手喵～！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔，",
        "unit_id": 125211,
        "voice": "vo_adv_5114321_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這些傢伙",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "異常堅硬！",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "劍完全刺不進去……",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒辦法了，",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這裡就使用魔法──",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵！？",
        "unit_id": 125111,
        "voice": "vo_adv_5114321_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這邊這隻黑色的，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "魔法對牠完全沒有效喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣該怎麼辦才好喵！？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……原來如此。",
        "unit_id": 125211,
        "voice": "vo_adv_5114321_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看來牠們根據顏色會有不同的抗性。",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "此外，",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "面對這麼一大群對手，",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們在數量方面明顯不利呢……",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呵呵，",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "面對久違的強敵，我的手開始癢了呢。",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳怎麼好像有點開心啊喵！？",
        "unit_id": 125111,
        "voice": "vo_adv_5114321_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n總、",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總之，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只要分別使用物理與魔法來打倒牠們就行了吧喵？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒錯，",
        "unit_id": 125211,
        "voice": "vo_adv_5114321_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "使用能夠影響群體的範圍攻擊",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會更好喔！",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好，",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們上吧！",
        "unit_id": 125211
    }
]