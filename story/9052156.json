[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚、",
        "unit_id": 105811,
        "voice": "vo_adv_9052156_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚…………",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "貪吃佩可小姐，",
        "unit_id": 106411,
        "voice": "vo_adv_9052156_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳沒事吧？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n有哪裡",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "受傷了嗎……！？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚嗚，",
        "unit_id": 105811,
        "voice": "vo_adv_9052156_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在剛才戰鬥的忙亂之中，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n難得拿到的肉好像被魔物偷走了的樣子……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且最關鍵的魔物也逃走了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抽泣。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個……",
        "unit_id": 106011,
        "voice": "vo_adv_9052156_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還真可惜啊～？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然不見了也沒辦法了嘛，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……我我、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才沒有覺得高興哦？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的好可惜啊～♪",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──那個，",
        "unit_id": 106411,
        "voice": "vo_adv_9052156_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "既然這樣，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就表示並非",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n祭壇的精靈",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在發狂或是生氣對嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105911,
        "voice": "vo_adv_9052156_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "此處的精靈",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自古以來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎一直守護著村莊不被魔物侵襲。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105911,
        "voice": "vo_adv_9052156_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為剛才的魔物阻撓，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "使得參拜者減少，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n作為精靈食糧的祈禱",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以及供奉都無法進行……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼，",
        "unit_id": 106411,
        "voice": "vo_adv_9052156_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "它剛才襲擊我們、",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還有盯上貪吃佩可小姐的肉也是……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "恐怕",
        "unit_id": 105911,
        "voice": "vo_adv_9052156_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是要讓人無法供奉食物、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n以妨礙為目的吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了不讓衰弱的精靈",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "取回力量。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃，",
        "unit_id": 105811,
        "voice": "vo_adv_9052156_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也就是說……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n精靈餓得肚子空空",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而使不上力的意思嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正是如此。",
        "unit_id": 105911,
        "voice": "vo_adv_9052156_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n村民們的供奉……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為只要有能給精靈的供品，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n精靈就能恢復力量了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "供品啊……",
        "unit_id": 106411,
        "voice": "vo_adv_9052156_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但是",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們目前手邊有的食物",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "看來似乎完全不夠。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n畢竟好像很久",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "都沒有人來供奉它了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 106011,
        "voice": "vo_adv_9052156_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "回村莊",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "重新準備應該比較好吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但若是雪菲想成為供品的話",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就沒差了──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106411,
        "voice": "vo_adv_9052156_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我、",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我才不要。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那種事就交給凱留了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留成為供品太浪費了啦～！",
        "unit_id": 105811,
        "voice": "vo_adv_9052156_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了，小可蘿，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "精靈",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也會吃魔物之類的嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然沾滿沙子了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但至少還剩下一點……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇噗！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咳",
        "unit_id": 106411,
        "voice": "vo_adv_9052156_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咳！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好、",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好強的",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沙塵……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來似乎不合它胃口的樣子。",
        "unit_id": 105911,
        "voice": "vo_adv_9052156_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是當然的吧！",
        "unit_id": 106011,
        "voice": "vo_adv_9052156_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在我們再繼續",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n把精靈惹火之前，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "先回村莊吧！",
        "unit_id": 106011
    }
]