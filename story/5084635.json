    {
        "type": "dialogue",
        "name": "智",
        "words": "這種玩笑，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一點也不好笑啊。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我還有很多話想跟你說。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "希望你可以快點醒過來……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103712,
        "voice": "vo_adv_5084635_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "現在也不是氣餒的時候，對吧。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n只是這樣靜靜等待，真不像我會做的事──",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你肯定會這樣說吧……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為了你，",
        "unit_id": 103712,
        "voice": "vo_adv_5084635_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我會盡力去做辦得到的事。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n平時的鍛鍊，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "或許就是為了這種時候而做的呢。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我一定會很快把你叫醒的……！",
        "unit_id": 103712
    }
]