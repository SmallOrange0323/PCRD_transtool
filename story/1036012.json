[
    {
        "type": "background",
        "background": "500390"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鏡華獨自一人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在蘭德索爾的街上煩惱著。"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……該怎麼辦才好呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯……",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "究竟該怎麼做，",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n才能讓{player}不把我當成小孩子看待？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "已經念了很多書了。",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n也有努力",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "試著不再挑食。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n而且身高",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也有稍微長高了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是，",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n{player}把我當成小孩對待的情況卻越來越嚴重。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不是摸頭、",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就是摸頭、",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "再不然就摸頭……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……摸頭摸得太超過了啦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "出現魔物時也是，",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n{player}會立刻就保護我……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "關於這點，",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然我還是小孩子沒錯……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就不能稍微……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀啊啊啊！？",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "變態！？可疑分子！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n是變態可疑分子對吧！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦，",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎麼偏偏是{player}呢……！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "竟然從背後大叫，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你已經不是小孩子了好嗎！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我嚇了一跳耶！",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n討厭……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你又摸我的頭～！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "已經夠了！",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我今天很忙",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n沒有空陪{player}玩！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以說，",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個……！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "對了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這、",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這份委託！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我要去做這個公布欄上",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "寫的討伐魔物任務！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "唔！",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不行！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我要一個人",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "做這份委託！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n即使沒有{player}幫忙也沒問題！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "絕對絕對，",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_014"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不可以跟來喔！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n有聽懂嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們約好囉！",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "一時情急",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "說出要去討伐魔物。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這說不定是個好主意？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果我能獨自打倒魔物，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就能在那個人遇上危機時",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "帥氣地幫助他了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這麼一來，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個人肯定也會改變態度……！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯！",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "來去討伐魔物，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我要加油！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……這麼說來，",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n{player}在我們初次見面時，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n有偷偷跟在我的身後呢……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "難道！",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呼。",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n原來",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是貓咪啊……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……莉瑪？",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "有這種叫聲的",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "動物嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n嗯……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "算了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "看來{player}沒有跟來呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……沒問題，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我沒有在害怕喔！",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚……",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "應、",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "應該是這裡",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒錯……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但明明是白天卻好暗，",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "空氣也好冰冷……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "魔、",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "魔物先生，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你在家嗎～？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n不在對吧。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……那就",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒辦法了，對吧～",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯。",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為不在，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以我也沒辦法呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼今天就──",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀啊！？",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n魔、",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "魔物！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這是……！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "蛇！",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_028"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這不是蛇嗎！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還好多！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不要，",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "蛇是我",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "最害怕的了……！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n好長，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且又會扭來扭去，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我實在不行啦～！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不要啊啊啊，",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n扭來扭去，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好恐怖！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "去那邊！",
        "unit_id": 103611,
        "voice": "vo_adv_1036012_031"
    },
