        "voice": "vo_adv_1345001_022"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "今天就先到這裡。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n你們現在",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "可以盡情擁抱和握手了！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n對了，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "也別忘了向萊拉耶爾殿下",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "報告檢查結果啊。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好的，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_023"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "謝謝你幫我檢查！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那麼騎士先生，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "請你抱住我♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "請你就這樣抓緊我喔！",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_024"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n抱著飛行的話，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就能一口氣飛回城堡了♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那我要出發囉～！",
        "unit_id": 134513,
        "voice": "vo_adv_1345001_025"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "空戰強化型克蘿茜，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "起飛！",
        "unit_id": 134513
    },
    {
        "type": "still",
        "still": "134500102"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嘿嘿，",
        "unit_id": 134513,
        "voice": "vo_adv_1345001_026"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "雖然背著你在空中飛行過很多次，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n但是抱著一起在空中飛還是第一次呢♪",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "今天沒有裝揹帶，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我會小心飛的！",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "雖然我用力抱著你，",
        "unit_id": 134513,
        "voice": "vo_adv_1345001_027"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不過請放心！",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n就如剛才所說，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這副手臂",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "很容易調整力量，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n也不用擔心會把人壓扁！",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "而且，",
