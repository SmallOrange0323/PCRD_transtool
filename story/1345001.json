        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "否則在屋裡的人",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "會受到驚嚇的。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對不起，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_038"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我想盡快向萊拉耶爾殿下報告，一不小心就太著急了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵，",
        "unit_id": 126511,
        "voice": "vo_adv_1345001_039"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "以後請多加注意。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "妳要報告什麼事？",
