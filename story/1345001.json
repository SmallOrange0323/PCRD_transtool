        "voice": "vo_adv_1345001_028"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "用推進器飛行，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n比噴射靴更容易控制高度，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n不用擔心會撞到東西，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "可以飛得很快喔♪",
