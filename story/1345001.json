        "voice": "vo_adv_1345001_040"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "請您聽我說！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我變成了新的軀體，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "現在也可以和人擁抱了喔♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "您看，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我和騎士先生也能抱抱♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那真是值得欣喜的事呢。",
        "unit_id": 126511,
        "voice": "vo_adv_1345001_041"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n畢竟妳從以前",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就一直很嚮往更親密的肢體接觸。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是的，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_042"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我非常開心！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "甚至覺得",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "想一直像這樣",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n抱著騎士先生♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "抱抱～！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不過……",
