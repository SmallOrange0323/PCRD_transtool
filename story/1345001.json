        "voice": "vo_adv_1345001_033"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "真是不可思議呢。",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 134513,
        "voice": "vo_adv_1345001_034"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對了♪",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這件事也要和可以擁抱的事",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n一起告訴萊拉耶爾殿下才行！",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我們要就這樣加速",
        "unit_id": 134513,
        "voice": "vo_adv_1345001_035"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "到帕菲之城去，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n請你好好抓緊囉～！",
        "unit_id": 134513
    },
    {
        "type": "background",
        "background": "501720"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我們回來了，",
