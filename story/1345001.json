        "voice": "vo_adv_1345001_043"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "克蘿茜，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就算妳已經學會",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "控制力道，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "凡事都還是要有分寸。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n騎士，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你一直被抱著",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "一定也累了吧？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哇啊，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_044"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對不起，騎士先生！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n是高度太高了嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n還是說，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "力道還沒有控制得很好嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "你說速度太快，感覺要掉下去了嗎？",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_045"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那下次可能要",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "抱得更緊比較好呢！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "因為騎士先生對我來說",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_046"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是非常重要的人！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我會小心不把你",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "弄丟的♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "太好了。",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_047"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n因為速度比之前更快，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "行動也變得更敏捷，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n所以我也能做出細膩的動作了♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "下次一起試試看雙重筋斗飛行吧！",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_048"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我也想試試在空中畫出一箭穿心的機尾雲之類的♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "先不說這些，",
        "unit_id": 126511,
        "voice": "vo_adv_1345001_049"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "看來檢查也已經順利結束，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真是太好了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "波波爺",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "有說些什麼嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這麼說來，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_050"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "他說或許還有其他未知的功能！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我和騎士先生擁抱時，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n湧出了",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "一股",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "輕飄飄～又溫暖的力量喔！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "雖然和平常的能量不太一樣，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_051"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "卻有著期待已久的感覺，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是一種不可思議的力量！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……原來如此。",
        "unit_id": 126511,
        "voice": "vo_adv_1345001_052"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那說不定是",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "克蘿茜成長的證明呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "咦，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_053"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "成長！？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這就是大家說的",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "「有所成長」的意思嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "可是可是，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_054"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我是",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "機械人族，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "所以應該不會成長才對吧？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n雖然可能是變成新的軀體，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "追加了零件，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n也變得比較輕一點就是了。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不是的，",
        "unit_id": 126511,
        "voice": "vo_adv_1345001_055"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "克蘿茜。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n並不是身高或體重",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這類外觀上的改變。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但是，",
        "unit_id": 126511,
        "voice": "vo_adv_1345001_056"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "無法用量尺這類工具測算的",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "內在變化就不同了……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n舉例來說，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "以前不懂的事，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "若現在已經能夠理解，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我認為",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這就可以",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "稱之為成長。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "內在",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_057"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "指的就是心對吧？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這種心情",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "的確",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "無法化成任何數值……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n不過",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "可以感覺到它確實存在♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "原來是這樣呀，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_058"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這就是……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "成長的感覺吧？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哇……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哇～♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "雖然沒有實感，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "但是我覺得非常開心！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我也可以",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "跟大家一樣成長了呢！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是啊，",
        "unit_id": 126511,
        "voice": "vo_adv_1345001_059"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "一定會的。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然不像他人那樣，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "會在外貌上有所改變，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但對妳而言",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "仍是重要的變化，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這點是無庸置疑的。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "謝謝您，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_060"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "萊拉耶爾殿下！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我去把這件事也告訴大家！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那我告辭了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_1345001_061"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n謝謝你實現了",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "克蘿茜的願望。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……也就是「想獲得與Master的連結」",
        "unit_id": 126511,
        "voice": "vo_adv_1345001_062"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這份願望。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "她已經是",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我的騎士了，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我不忍心再讓她",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "進一步成為我的從屬……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "因此過去",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沒能回應她的期待。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然還不清楚",
        "unit_id": 126511,
        "voice": "vo_adv_1345001_063"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "克蘿茜是否已將你",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "視為她的「Master」……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但是她之所以能夠成長，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n是因為與你的連結",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "進一步加深的緣故吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "今後也要請你",
        "unit_id": 126511,
        "voice": "vo_adv_1345001_064"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "再多多關照",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "克蘿茜了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n若你們能繼續加深連結，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "又或者……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "萊拉耶爾殿下──！",
        "unit_id": 134513,
        "voice": "vo_adv_1345001_065"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n不好意思，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我忘了一件事──！",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "拜託您了，",
        "unit_id": 134513,
        "voice": "vo_adv_1345001_066"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "萊拉耶爾殿下！",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "想要再去一次蘭德索爾！",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我想試試看自己成長過後的性能！",
        "unit_id": 134513,
        "voice": "vo_adv_1345001_067"
    },
    {
        "type": "dialogue",
