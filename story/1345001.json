    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我想讓你知道飛行是一件很舒服的事♪",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "所以，",
        "unit_id": 134513,
        "voice": "vo_adv_1345001_030"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "知道可以和騎士先生擁抱後，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我真的很開心♪",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "……我真的可以和人",
        "unit_id": 134513,
        "voice": "vo_adv_1345001_031"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "互相碰觸了！",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "輕飄飄又溫暖的力量",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "將會源源不絕地湧出來♪",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "總覺得",
        "unit_id": 134513,
        "voice": "vo_adv_1345001_032"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我好像從以前就知道這股溫暖力量帶來的感覺，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n而且一直",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "一～直在等待著。",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n這種感覺",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就是所謂的「懷念」嗎？",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "明明完全不記得醒來前的事，",
