        "words": "某天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n協助航空模式的克蘿茜做了檢查。"
    },
    {
        "type": "still",
        "still": "134500101"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "抱抱～！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嘿嘿，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "接下來請跟我握手！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "吶，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "波波爺爺！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我已經可以好好擁抱和握手了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我再試一次給你看！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n騎士先生，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "抱抱～♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "知道了知道了。",
        "unit_id": 9212,
        "voice": "vo_adv_1345001_003"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "老夫已經非～常清楚機體狀態極佳了！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "不過",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "妳打算抱到什麼時候？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n除了耐久度測試之外，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "還有一堆檢查項目要做喔。",
        "unit_id": 9212
    },
    {
        "type": "background",
        "background": "501660"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嘿嘿，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對不起～",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "因為",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我非常開心！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我可以和騎士先生擁抱了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "沒錯沒錯～！",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "因為不會再有把騎士先生",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "像棉花糖一樣壓扁的危險性，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n所以我想多多跟你擁抱和握手♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n甚至想把至今為止辦不到的份",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "全都補回來！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "畢竟妳以往的手臂",
        "unit_id": 9212,
        "voice": "vo_adv_1345001_006"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "都是以力量為最優先，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "所以不擅長做出精密的動作啊。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "老夫明白妳的心情，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "但是時間",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "有限。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n要抱的話，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "可以等檢查完再抱嗎？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好的，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "解除連接！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "再次麻煩你",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "幫忙檢查了～♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯──",
        "unit_id": 9212,
        "voice": "vo_adv_1345001_008"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n雖然力量降低了，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "但整體的重量",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "減輕了３成左右。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "只是，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "待在地面上不會很不穩定嗎？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嗯～",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這個嘛～",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "雖然有點難走路，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "但只要用飛的就不會這麼覺得了♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯──",
        "unit_id": 9212,
        "voice": "vo_adv_1345001_010"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這樣也是會出問題啊。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "雖說是改善了能量效率的軀體，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n但也不能隨時隨地",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "都乘著風飛來飛去吧。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不然在地面時，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就坐在像推車之類的東西上……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我想到一個好主意了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生騎士先生，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "請你過來這邊！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "克蘿茜，",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "讓人背著模式♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n只要請騎士先生背著我，就可以解決了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這或許",
        "unit_id": 9212,
        "voice": "vo_adv_1345001_013"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "可以解決在地面上行走的問題……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n但總不能讓他一直背著妳吧。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n小伙子想必也是會累的。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嗯～",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_014"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生的確也很忙，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n或許很難這麼做……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "可是可是！",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "像這樣被騎士先生背著，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我就會湧出一股不可思議的力量。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好像是和充電不一樣的能量喔！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "湧出力量……？",
        "unit_id": 9212,
        "voice": "vo_adv_1345001_016"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n你對克蘿茜",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "做了什麼類似強化的事情嗎？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是這樣嗎？",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "有一股前所未有、",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "輕飄飄～",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "的，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n又很溫暖的力量會源源不絕地湧出來喔！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "還有抱抱的時候，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "和握手的時候也是♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯……",
        "unit_id": 9212,
        "voice": "vo_adv_1345001_018"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "不知是航空軀體的特性，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n還是至今",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "仍沉睡在克蘿茜體內的隱藏功能……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "無論哪一種，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "都還很值得好好研究啊！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "變形合體功能之類的就很帥氣吧！",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "……咦？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "可是我",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "要變形成什麼，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "又要和什麼合體呢？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "說到可愛就是貓咪了！",
        "unit_id": 134511,
        "voice": "vo_adv_1345001_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "做出貓咪模式怎麼樣？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n裝上像沃爾加諾先生一樣的貓耳，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "說著",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "「喵喵♪」。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那就必須拜託波波爺爺幫忙追加零件了呢。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "那些天馬行空的美夢和幻想先放一邊。",
        "unit_id": 9212,
        "voice": "vo_adv_1345001_021"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n要確認詳細的力量來源",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "應該會花上不少時間。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n我們就耐心地觀察下去吧。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "好啦，",
