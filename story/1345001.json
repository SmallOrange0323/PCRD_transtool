        "voice": "vo_adv_1345001_029"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "自從第一次用航空模式飛行，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我就一直想趕快和騎士先生一起飛飛看！",
