    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呵呵呵！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "可以不要因為贏過一次，",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n就得意忘形起來嗎！？",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "因為這隻大蛇，",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "還留有兩次變身啊！",
        "unit_id": 134911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "變身？",
        "unit_id": 133511,
        "voice": "vo_adv_5160302_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那種魔物",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也能做到那種事情嗎？",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "不知道呢，",
        "unit_id": 133611,
        "voice": "vo_adv_5160302_002"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "因為牠是蛇所以應該會脫皮，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "但是我沒聽說過會變身呢。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼，",
        "unit_id": 133211,
        "voice": "vo_adv_5160302_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那是在虛張聲勢嗎？",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然她看起來不像是有那種頭腦的人……",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不管怎麼說，",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那隻大蛇很強這點一樣沒有變。",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是啊，",
        "unit_id": 133511,
        "voice": "vo_adv_5160302_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "牠給人的感覺很明顯",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "跟剛剛為止的不一樣。",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們也要",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "繃緊神經才行！",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我求之不得啊！",
        "unit_id": 133611,
        "voice": "vo_adv_5160302_005"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我就讓你們看看我真正的力量吧！",
        "unit_id": 133611
