        "voice": "vo_adv_5010203_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "既然如此，那就在停止出現前繼續解決掉！",
        "unit_id": 108911,
        "voice": "vo_adv_5010203_005"
    },
    {
