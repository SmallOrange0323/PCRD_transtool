    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在高興還太早了唷。",
        "unit_id": 108911,
        "voice": "vo_adv_5010203_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "什麼意思……",
        "unit_id": 108711,
        "voice": "vo_adv_5010203_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸咦咦咦！？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n又出現新的了——！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "即使打倒了又會馬上出現其他的呢……",
