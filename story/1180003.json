[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──克蕾琪塔‧凱許。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "創立並將【里士滿工商會】經營起來的才女。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n26歲，單身。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由於對自己的身世懷抱著自卑感，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n因此她對擁有高貴血統的貪吃佩可，有著很強烈的敵意。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n原本是這樣的……"
    },
    {
        "type": "background",
        "background": "500521"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我向您宣誓忠誠！！",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n尤絲蒂亞娜陛下～！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──經過一番波折，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克蕾琪塔‧凱許最後宣誓效忠貪吃佩可。"
    },
    {
        "type": "background",
        "background": "501070"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下～♪",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n尤絲蒂亞娜陛下～♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您之前提到想要復興計畫的新方案，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我已經完成了唷♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我可是盡全力",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "規劃出了最好的方案喔！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "已經完成了呀？",
        "unit_id": 105812,
        "voice": "vo_adv_1180003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐！",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下～♪",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n尤絲蒂亞娜陛下～♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "下午三點要吃的點心，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "大份量飯糰準備好囉♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我可是渾身解數、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "使上最大廚藝來捏飯糰的喔！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇～！",
        "unit_id": 105812,
        "voice": "vo_adv_1180003_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有好多飯糰，看起來真好吃！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "形狀好不好看先擺一邊……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我開動了～♪",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500366"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下～♪",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n尤絲蒂亞娜陛下～♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我等一下！",
        "unit_id": 106012,
        "voice": "vo_adv_1180003_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼妳跑到我們這裡來啦！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎呀呀，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這不是陛下的寵物貓姑娘嗎。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不好意思打擾囉。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "誰是寵物貓啊！！",
        "unit_id": 106012,
        "voice": "vo_adv_1180003_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且會不好意思",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就別來打擾啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n嚇──！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_1180003_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請冷靜下來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好乖",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好乖。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "和以前不同，",
        "unit_id": 106412,
        "voice": "vo_adv_1180003_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "現在她說出的話裡",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "已經感受不到惡意或語中帶刺……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "總而言之，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "稍微聽聽她跑來的理由，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "應該也無妨吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼，",
        "unit_id": 106012,
        "voice": "vo_adv_1180003_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這可不好說～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說，貪吃佩可，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳做什麼把這種傢伙給帶來了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然要說的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她確實是對妳宣示忠誠了沒錯啦？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈……",
        "unit_id": 105812,
        "voice": "vo_adv_1180003_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她說無論如何都想跟來，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我拒絕不了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "確實，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_015"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我這樣跟來或許稍嫌行動強硬了點……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要打擾陛下的休息時間，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也是覺得有些不太妥……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_016"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "即使如此！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我無論如何都想親眼確認，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下在王宮外的安全，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n是否有確實受到保障！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要不然，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我會很擔心很擔心陛下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "憂心到晚上也睡不著哪！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "因為如此，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "即使明白這樣很失禮！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但今天還是決定像這樣",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "請陛下讓我跟隨她過來公會小屋～！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好的，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_018"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "感謝你的歡迎～♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……儘管已經多少有所耳聞……",
        "unit_id": 105913,
        "voice": "vo_adv_1180003_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但態度轉變如此劇烈，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "著實叫人吃驚。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就、",
        "unit_id": 106412,
        "voice": "vo_adv_1180003_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就是說呀……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "如果我沒記錯，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳以前",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不是都用",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很尖銳的態度對待",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "貪吃佩可小姐嗎……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_022"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "經妳一提，或許是啦？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我以前可能曾經犯過這樣的錯，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但又好像",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒有……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "或許大概？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是可是！",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "已經",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "大澈大悟了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既寬容又偉大的",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "尤絲蒂亞娜陛下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n她的仁慈",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "令我",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "受到感召",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而改過自新了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我、",
        "unit_id": 105812,
        "voice": "vo_adv_1180003_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我覺得自己也沒做什麼大不了的事啦……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃～",
        "unit_id": 106412,
        "voice": "vo_adv_1180003_025"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也就是說……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳被貪吃佩可小姐所救，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "並且得到了她的原諒，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n而因此決定",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "改過向善……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大致上是這樣？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔姆……",
        "unit_id": 105913,
        "voice": "vo_adv_1180003_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n光聽這段敘述，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺似乎和凱留小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的境遇有點像……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚呃！",
        "unit_id": 106012,
        "voice": "vo_adv_1180003_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……我跟那種傢伙",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能一樣……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "來來，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_028"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還請來這邊坐♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n您日常處理許多公務，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "肩膀等部位肯定十分僵硬吧……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就讓小的來",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "誠心！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "誠意！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為您好好按摩一下～！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不、",
        "unit_id": 105812,
        "voice": "vo_adv_1180003_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不用啦～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我肩膀根本",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也沒有感到什麼僵硬……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "能讓貪吃佩可小姐出現這種反應，",
        "unit_id": 106412,
        "voice": "vo_adv_1180003_030"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也是挺稀奇的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話又說回來……",
        "unit_id": 106012,
        "voice": "vo_adv_1180003_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們說我",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟那個一樣？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道從旁人眼裡看來，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就像那樣子……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……總覺得……",
        "unit_id": 106012,
        "voice": "vo_adv_1180003_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有點不舒服起來了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個……",
        "unit_id": 105913,
        "voice": "vo_adv_1180003_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位相像的只是境遇。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要論改過自新之後的態度，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐和她",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "則是相差挺多的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就、",
        "unit_id": 106012,
        "voice": "vo_adv_1180003_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "～是說嘛～！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我才不像",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她那副德性對吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太好了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下，小貓仔，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳有資格說別人嗎！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我可是知道喔，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳原本也是，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n對之前的冒牌陛下",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "拚命搖尾巴",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "獻殷勤的呢～！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔呃",
        "unit_id": 106012,
        "voice": "vo_adv_1180003_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n或、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或許曾經……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有過那種事啦……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留對人搖尾巴……",
        "unit_id": 106412,
        "voice": "vo_adv_1180003_037"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n總覺得有點想看看呀……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……總之……",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_038"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "各位對於",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "徹底改變支持立場的我，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n感到不太能信任，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這點我也並非不能理解。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "再加上，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_039"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然我至今為此，\n也曾為了錢去討好過他人，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但是……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "以恩義或忠誠這種",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_040"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不是很具體的概念作為基礎，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n來侍奉他人，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也是這輩子裡第一次這麼做。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也因此，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "或許便導致我多少出現一些較為奇怪的行為舉止。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但就算如此，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_041"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也想用自己的方式……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "並且，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是用不牽扯金錢的方式，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n來報答",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下對我的恩情。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐……",
        "unit_id": 105812,
        "voice": "vo_adv_1180003_042"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我不會要求各位",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_043"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要立刻就信任我。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我原本也是名商人，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n很清楚要贏得他人的信賴，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是件非常困難的──",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……唔。",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_044"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n被如此輕易地宣告願意相信，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n總覺得反而",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不太舒服呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也太不坦率了吧！",
        "unit_id": 106012,
        "voice": "vo_adv_1180003_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……雖然我是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很想這麼說啦……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "聽到剛才那些話後……",
        "unit_id": 106412,
        "voice": "vo_adv_1180003_046"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "總不禁覺得，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "克蕾琪塔小姐",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "似乎也過得很辛苦呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106012,
        "voice": "vo_adv_1180003_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她個性彆扭這點肯定是不會錯的～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳妳妳妳說什麼……！！",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_1180003_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然兩位還是有點相似的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n像是這種忍不住就口出惡言損人的行為……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈……",
        "unit_id": 105812,
        "voice": "vo_adv_1180003_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總而言之，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還請克蕾琪塔小姐，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n和小凱留還有大家好好相處喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【美食殿堂】的成員，",
        "unit_id": 105812,
        "voice": "vo_adv_1180003_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都是我打從心底信賴的人。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "希望往後也能和克蕾琪塔小姐",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "建立起這樣的關係呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗚",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_052"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n也別無他法。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n畢竟是主子的命令……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等等，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_053"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我想起來了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我今天會前來這裡打擾，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就是因為想保護主子的人身安全哪！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "克蕾琪塔小姐……？",
        "unit_id": 105913,
        "voice": "vo_adv_1180003_054"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等、",
        "unit_id": 106012,
        "voice": "vo_adv_1180003_055"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳這傢伙在做什麼呀？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯嗯……",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_056"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是嗎，原來如此。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n基本是三層木造建築，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "接水管的設備在……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "儘管四處皆可窺見一些因年歲而老朽的痕跡，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_057"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但整體的作工感覺相當紮實，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "似乎沒有偷工減料。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "並且看得出來算是有經常在打掃……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃、",
        "unit_id": 105812,
        "voice": "vo_adv_1180003_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n克蕾琪塔小姐",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是在做什麼呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "感覺是在四處",
        "unit_id": 106412,
        "voice": "vo_adv_1180003_059"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "打量家裡的狀況……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼說來，",
        "unit_id": 105913,
        "voice": "vo_adv_1180003_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她剛才確實是有說過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n「想確認陛下的安全",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否有受到保障」",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這種話。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "噢……",
        "unit_id": 106412,
        "voice": "vo_adv_1180003_061"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也就是說，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "她正在確認這個公會小屋",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n是不是安全的地方囉。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來……",
        "unit_id": 106012,
        "voice": "vo_adv_1180003_062"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n她那樣用手指",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "滑過窗戶邊框的行為，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n根本就像婆婆在檢查媳婦有沒有打理家中嘛～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯嗯嗯……",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_063"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n以居住空間而言，確實有達到舒適生活的標準。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然以要讓陛下進行生活起居的場所來考量，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "在安全面上仍留有些不安……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "舉例來說，",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_064"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "像這個窗戶呀？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n若暗殺者打算用魔法或石製弓箭狙擊，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這不就是絕佳的目標嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要達到防禦效果，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還是採取換上鐵板來代替玻璃之類的對策比較……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "啊！！",
        "unit_id": 1,
        "voice": "vo_adv_1180003_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是從這窗戶探出頭去……！",
        "unit_id": 105812,
        "voice": "vo_adv_1180003_066"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦？",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_067"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔嘎這啥咪",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_068"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咕欸西！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什、",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_069"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎呀～",
        "unit_id": 106012,
        "voice": "vo_adv_1180003_070"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n之前在",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被【憤怒‧軍團】給盯上後，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們就設下了不少防禦結界",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和陷阱之類的了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這、",
        "unit_id": 118011,
        "voice": "vo_adv_1180003_071"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這種事情……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n還請",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "早點說呀……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐────！？",
        "unit_id": 105812,
        "voice": "vo_adv_1180003_072"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──克蕾琪塔‧凱許。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n【里士滿工商會】的前任公會長，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n26歲，單身。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對忠義之道仍不熟悉的她，前方似乎仍困難重重……"
    }
]