[
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某次在蘭德索爾後巷散步的{player}，\n被突然出現的少年們堵住去路。"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "那邊的你！",
        "unit_id": 1,
        "voice": "vo_adv_1065006_000"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "給我停下！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n你是什麼人！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "找誰有什麼事──！",
        "unit_id": 1,
        "voice": "vo_adv_1065006_001"
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "你是來見嘉夜她們嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "什麼，",
        "unit_id": 1,
        "voice": "vo_adv_1065006_002"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "是嘉夜認識的人呀！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n這樣要付通行費──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "付錢付錢──！",
        "unit_id": 1,
        "voice": "vo_adv_1065006_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你們，",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "夠了唷。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n他",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是我認識的人。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "讓他通過吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天怎麼了呢？",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "找我有事嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "等等。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我來猜猜",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是不是像往常一樣",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "散步吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "欸欸，",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你為什麼拿出錢包了呀！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "快收起來！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是的……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你連普通小鬼的話都認真嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "算了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這就是你有趣的地方。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "抱歉抱歉。",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "付錢那件事，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是開玩笑的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n那是有認識的人通過時的暗號。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "大家謝謝啦。",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "來，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "給你們今天的費用。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好好運用吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "太好了──！",
        "unit_id": 1,
        "voice": "vo_adv_1065006_009"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "等等去買零食！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這些傢伙在附近玩，順便幫我監視地盤。",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就像現在這樣，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們都會認真付給他們報酬。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……其實大家，",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是因為「消失」失去父母的孩子們，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "以前都是靠偷竊生活。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是現在，",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "多虧有了這份工作",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n也不用做壞事了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且讓他們得到生存的方法。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "講真的，",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們也不確定是否要好好照顧他們，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是什麼都無條件給他們的話，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "孩子們也容易撒嬌依賴。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "當然",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們也知道有【咲戀育幼院】這樣的機構。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那裡確實",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "託付了很多父母「消失」的孩子對吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那裡也",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "已經照顧不少人了吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果再把這些人都寄放過去，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "讓人覺得不太上道啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那樣的規模，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可以照顧的人數是有限的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以我們想用這樣的方式來保護他們。",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_016"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n比起從別人那裡偷竊生存下去，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這種方法更踏實吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我才沒做什麼了不起的事呢。",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_017"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "和這些傢伙，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只是互相利用而已。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈，",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_018"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你可真是個老好人啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒問題。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這些傢伙就交給我們負責吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "話雖如此，",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_019"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "開始進行這些的人並不是我，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而是老大。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我只是在旁邊幫一點忙。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "啊──！",
        "unit_id": 1,
        "voice": "vo_adv_1065006_020"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "你們兩人還在說話！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n嘉夜──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "監視好無趣──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "話說，",
        "unit_id": 1,
        "voice": "vo_adv_1065006_021"
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "兩個人相處得很親密好可疑耶──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "\n難道你，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "是嘉夜的戀人嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊？",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你在說什麼呀，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們是死黨啊死黨。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n大家也要珍惜死黨啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "男孩子們",
        "words": "好的──",
        "unit_id": 1,
        "voice": "vo_adv_1065006_023"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "吶嘉夜──",
        "unit_id": 1,
        "voice": "vo_adv_1065006_024"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "現在很閒，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "今天也來教我們戰鬥方法吧──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好啦好啦，",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_025"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我知道了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n那麼，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "大家",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "排成一列──！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_026"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這個嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果有時間時，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我都會教這些傢伙格鬥技。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n希望他們能盡量保護自己。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對了，",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_027"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你也一起來吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咦？",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_028"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊哈哈！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我不會啦！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "接招──！",
        "unit_id": 1,
        "voice": "vo_adv_1065006_029"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "這是必殺技唷──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "竟然──！",
        "unit_id": 1,
        "voice": "vo_adv_1065006_030"
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "我可不會輸的──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "\n飛踢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊──啊，",
        "unit_id": 106511,
        "voice": "vo_adv_1065006_031"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "已經不是練習，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
