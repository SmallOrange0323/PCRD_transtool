[
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦咦咦咦咦咦咦咦！？",
        "unit_id": 100511,
        "voice": "vo_adv_0000323_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這地方到底是怎麼回事！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我們剛剛",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還在洞窟裡吧！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔……",
        "unit_id": 105311,
        "voice": "vo_adv_0000323_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n還以為被奇怪的空間給吞噬了，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "結果卻出乎意料……！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "克蕾琪塔閣下，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳還好嗎──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下～！？",
        "unit_id": 118011,
        "voice": "vo_adv_0000323_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n尤絲蒂亞娜陛下～！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_0000323_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這聲音是……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐！",
        "unit_id": 105811,
        "voice": "vo_adv_0000323_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有茉莉和莫妮卡，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們也來了……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下～！！",
        "unit_id": 118011,
        "voice": "vo_adv_0000323_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我找您好久了～！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這麼快就能會合，",
        "unit_id": 105311,
        "voice": "vo_adv_0000323_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們運氣不錯。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "話說回來……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這裡究竟是哪裡？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其實，",
        "unit_id": 105911,
        "voice": "vo_adv_0000323_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們也還不太清楚。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們在洞窟躲避魔物的時候，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不小心闖進了這裡……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且",
        "unit_id": 106011,
        "voice": "vo_adv_0000323_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "闖進來的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看來不只我們。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們看……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那邊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊……！",
        "unit_id": 100511,
        "voice": "vo_adv_0000323_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是魔物！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "而且，的確都是些",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在蘭德索爾附近看得到的面孔呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105911,
        "voice": "vo_adv_0000323_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "它們似乎也是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "穿越剛剛的洞窟過來的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正隨意地",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這裡到處搗亂。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不太能放任它們不管呢～",
        "unit_id": 105811,
        "voice": "vo_adv_0000323_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們想說在打倒那些魔物的同時，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也稍微探索一下這個世界。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然如此……！",
        "unit_id": 118011,
        "voice": "vo_adv_0000323_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n陛下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也與您一同行動！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就算身在這塊距蘭德索爾千里之遙的土地，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我的忠誠也始終如一～！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106011,
        "voice": "vo_adv_0000323_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳還是一樣吵鬧呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正本來也正好想找其他公會。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n趕快探索四周吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好！",
        "unit_id": 105811,
        "voice": "vo_adv_0000323_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺好像要展開一場新冒險，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓人有點興奮呢☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "Let's go☆",
        "unit_id": 105811
    }
]