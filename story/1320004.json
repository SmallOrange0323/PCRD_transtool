[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "艾姬多娜結束了與霸瞳皇帝的茶會。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了滿足好奇心而觀察異世界的她再次來到了海邊。"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "嗨。",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_000"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我就知道你會來。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我在等你呀。",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_001"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n因為這段時間",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你似乎常在海邊打工嘛。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看你這樣子，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_002"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "應該已經下班了吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "當然",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我是看準你工作結束了才跟你打招呼的。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我才不想再從事肉體勞動呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看你一臉疑惑，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_003"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你在想還有什麼事要找你對吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n你會這樣想也是理所當然。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "如你所料，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_004"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我有事要麻煩你。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "畢竟上次",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "把時間都花費在打工上了呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這次，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_005"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我想知道海邊作為娛樂的一面。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "簡單來說──",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_006"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我想跟你共度時光。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "依然是毫不猶豫地回答啊。",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_007"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那麼，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就請你多指教囉。",
        "unit_id": 132011
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……首先是暖身運動，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_008"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這樣啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "要在開始活動前，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_009"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "擴展身體的可動範圍對吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這道理我懂。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "可是這個",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_010"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "叫做廣播體操的……",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "運動量、",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不會太多了嗎……",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不確實做不行？",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_011"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "比我想像的還注重形式呢，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你這個人……",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "原來如此。",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_012"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "海邊娛樂的基本",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是進到海裡。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "運動本身帶來的快感，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_013"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "以及水中減緩暑氣的清涼感。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "能夠一舉兩得，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這的確",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是在海邊這地方的最佳娛樂了。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "在我原本所在的世界，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也有這樣的活動。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "問題是",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_014"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這些含有鹽分的水。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這部分會帶來什麼影響，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n難以預測……",
        "unit_id": 132011
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "…………",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_015"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……咕嚕咕嚕……",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_016"
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖因浮力提升而變得容易漂浮，但從另一個角度而言，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_017"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n要是不將海浪帶來的影響納入考量，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就可能會像剛剛的我一樣，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n落得悲慘下沉的結果。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "謝謝你救了我。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "而且，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_018"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這比我想得更容易讓人感到疲勞呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看來游泳",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不太適合我。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我們要在這沙灘",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_019"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "做什麼？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n你之前會邊流汗",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "邊撿垃圾，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n也是因為有人會來使用的緣故吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "沙灘棒球、",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_020"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "沙灘排球、",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "沙灘搶旗……",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n全都是我第一次聽到的字眼。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "縱然引起了我無窮的興趣，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_021"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n但不管哪一種，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "只有兩個人都玩不起來的話，那也只好放棄了呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我們就等著看別人玩吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "其他還有……",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_022"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "玩沙",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也是海邊特有的活動嗎？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……咦？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "往躺著的人身上",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "倒沙子，把人埋起來？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……你是不是把拷問和遊樂搞混了？",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_023"
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "轉眼間就晚上了呢。",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_024"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "真是讓我深刻體會到了時間的有限。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "謝謝你帶我到處參觀。",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_025"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "海邊……",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_026"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不僅匯聚了大量的水，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n還是個能夠窺見多元樣貌的地方。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我會有這樣的感想，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "或許也是有你這個導覽人的緣故。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那就好。",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_027"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "難得有人會說跟我在一起",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "很開心。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我也覺得",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_028"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "似乎拉近了一點和你的距離。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "對了，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "大概就像你曾經說過的",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "朋友",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那種感覺。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "所以……",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_029"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我有一個",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_030"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "提議。",
        "unit_id": 132011
    },
    {
        "type": "still",
        "still": "132000401"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──你要不要跟我",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_031"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "簽訂契約？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "對，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_032"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "簽訂契約。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也可以說是和我締結合作關係。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "如你所知，我對",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "求知的欲望可說幾乎沒有上限。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n因此，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "即使是你不知道",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "或無從得知的事，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我也知之甚多。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "只要你和我簽訂契約，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_033"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我就會傾盡所有知識，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n給你想知道的答案。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我可以斷言這一定對喪失記憶的你有所幫助。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也許你會感到疑問，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_034"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "為什麼需要這種契約？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但你想想看。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我原本",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "並非這個世界的居民。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我會在何時、",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_035"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "哪個時間點，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "被迫中斷這段珍貴的聯繫，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n並且離開這個世界，都不知道。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "正因如此，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_036"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我希望將這次邂逅",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "化為確實的連結永存。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這或許可稱之為羈絆。",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_037"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n你和我透過這次邂逅，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "在夏日海邊",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "培育的羈絆，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我希望能藉由契約的形式",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "將它化為永恆。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這可是",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_038"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "需要鼓起很大勇氣的發言喔──",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我也是女孩子嘛。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我欣賞你，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_039"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "傾心於你的可能性。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我願意不顧羞恥，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "對你說這是命運哦。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我想要一直看著你。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我想坐在頭等席，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看著你的所見所聞。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你稱呼我為朋友，",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_040"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n真的讓我很高興。",
        "unit_id": 132011
    },
    {
        "type": "still",
        "still": "132000402"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你是",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_041"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這個世界裡「未知」的結晶，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n滿足我好奇心的甜美果實。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我注視著你。",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_042"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我不希望你這個「未知」",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "僅僅是轉瞬之間的存在。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n相對的，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我會成為引導你的指標。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "可以嗎……？",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_043"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你至今",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_044"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也答應過許多次我的拜託不是嗎？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n結果",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "應該不曾帶給你任何不利。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n你就把這次也當作一樣的情形就好──",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──那份契約，",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "給我等一下。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "哎呀。",
        "unit_id": 132011,
        "voice": "vo_adv_1320004_046"
    },
    {
        "type": "background",
        "background": "502340"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我再說一次，",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "給我等一下。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我不認同",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那份契約。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也別",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "遇到什麼事都只會點頭。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這情形怎麼想都很怪吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……比我預期的還早插手呢。",
        "unit_id": 132012,
        "voice": "vo_adv_1320004_049"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看來愛梅斯妳比我想的",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "還更執著於他。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "從外表真是看不出來呢，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你這萬人迷。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別在那邊恣意妄為了，",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "艾姬多娜。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我允許妳一定程度的行動，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但如果妳要對{player}出手，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我可不會坐視不管。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "出手，",
        "unit_id": 132012,
        "voice": "vo_adv_1320004_051"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "還真是個",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "容易引人誤會的說法呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我只是",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "問他要不要簽訂契約而已。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳說的那個什麼契約，",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n看來並未充分說明呀？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "為何想跟他簽訂契約，",
        "unit_id": 132012,
        "voice": "vo_adv_1320004_053"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n簽訂契約後我們雙方可以獲得什麼，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我以為我已經說得很清楚了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "魔女的契約是很重要的東西。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我不會說謊。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "確實說了會得到什麼。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "卻沒說明有可能失去什麼。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不照實說明損失的契約，",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我沒辦法視而不見。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……為了達成目的，",
        "unit_id": 132012,
        "voice": "vo_adv_1320004_056"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "本就有可能會失去些什麼。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但那算是",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我的契約造成的結果嗎？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n也有可能無論如何",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "事情的發展都只有那種結果。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳少用缺乏具體性的話語敷衍我。",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳只是想要可以觀測這世界的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「眼睛」對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一雙會乖乖聽從妳的建言，",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n配合妳實驗的「眼睛」。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還有，",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要談約定時",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n才頭一次說出什麼羈絆的傢伙不值得信任。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也要記住喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……真受不了。",
        "unit_id": 132012,
        "voice": "vo_adv_1320004_060"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n被拆散關係到這地步，我也沒轍了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "愛梅斯──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "妳也很有意思呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那真是多謝了。",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是我不會和妳簽訂契約的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉了──",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──引導並守護這傢伙，",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是我的任務。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……原來如此。",
        "unit_id": 132012,
        "voice": "vo_adv_1320004_063"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖然很遺憾，",
        "unit_id": 132012,
        "voice": "vo_adv_1320004_064"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但現在除了撤退似乎也別無他法了呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那今天我就先告辭了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "艾姬多娜，",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妳……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在打什麼主意？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──我可是「強欲的魔女」呢。",
        "unit_id": 132012,
        "voice": "vo_adv_1320004_066"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n為了得到想要的一切，我會勤勉努力的。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就是這樣。",
        "unit_id": 132012,
        "voice": "vo_adv_1320004_067"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我要離開了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖然遺憾讓你對我有所懷疑……",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你這傢伙真是……",
        "unit_id": 190011,
        "voice": "vo_adv_1320004_068"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──呵呵。",
        "unit_id": 132012,
        "voice": "vo_adv_1320004_069"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看來我似乎",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不必擔心什麼懷疑了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "哪怕是邪惡的魔女，",
        "unit_id": 132012,
        "voice": "vo_adv_1320004_070"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "在你面前也會消失得無影無蹤。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那麼，",
        "unit_id": 132012,
        "voice": "vo_adv_1320004_071"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "之後有機會再來見你吧。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n下次真想",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "邀請你來參加我的茶會呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "等到回過神來，她的身影已經從現場消失了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n彷彿一開始就沒有任何東西存在過。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n「強欲的魔女」艾姬多娜已然離去。"
    }
]