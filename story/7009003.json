        "voice": "vo_adv_7009003_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好像走了很長一段距離了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "兩位還好嗎？　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "會不會累？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為總是送信到【伊麗莎白牧場】，",
        "unit_id": 105211,
        "voice": "vo_adv_7009003_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n腳力很強健嘛。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真厲害呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真步還行嗎？　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "累了的話",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可以背妳呦？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪的背",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "確實很有吸引力，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但沒問題的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n直到讓王子先生",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "刮目相看為止，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不繼續努力可不行。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝妳",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "顧慮到人家。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呵呵呵，",
        "unit_id": 105211,
        "voice": "vo_adv_7009003_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "很了不起呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "照這個步調",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "繼續向前邁進吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的既溫柔，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "又可靠呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "聽小栞和小鈴說，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪不太常在\n別人面前出現，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是可惜呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊哈哈……",
        "unit_id": 105211,
        "voice": "vo_adv_7009003_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒辦法啊。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為我",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這個樣子會讓人嚇到嘛。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n先不論",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "有聽說過關於我的事，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真步並不害怕我呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝妳。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為人家",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "看過很多很多的獸人們，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不會這麼簡單就嚇到的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話說回來，",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "和莉瑪是怎麼邂逅的呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "明明不太常",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "出現在別人面前的說。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "說到{player}，",
        "unit_id": 105211,
        "voice": "vo_adv_7009003_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是在路上不小心撞到的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不小心撞上我的話，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一般來說都會馬上逃跑的，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可是他不但沒有逃跑，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "甚至替我擔心呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀哎呀！",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "果然是很優秀的人呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒錯～",
        "unit_id": 105211,
        "voice": "vo_adv_7009003_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然不時會緊緊的抱住我，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "讓人家很害羞呢～",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妳說什麼？",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n抱抱、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "緊緊的？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是真的嗎？　",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也是呢。",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "都因為莉瑪的毛皮",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "毛茸茸的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "又這麼舒服，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "才沒辦法忍耐也說不定……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過，",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家好像從來沒有",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "被緊緊抱住對吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "抱起來應該也很溫暖吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真步……！？",
        "unit_id": 105211,
        "voice": "vo_adv_7009003_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來、",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n緊緊抱住人家",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也可以喔？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎、",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎麼這樣！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n太突然了不行！！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "心理準備還不夠～～！",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "…………",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "被、",
        "unit_id": 101011,
        "voice": "vo_adv_7009003_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "被這樣盯著看",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總感覺害羞起來了～～！！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生大壞蛋～～！！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "等、",
        "unit_id": 105211,
        "voice": "vo_adv_7009003_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "等等真步！！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n一個人跑掉的話",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "很危險的喔～～！！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "莉瑪和{player}，慌張地追在"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n羞紅著臉逃跑的真步後頭。"
    }
