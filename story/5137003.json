[
    {
        "type": "background",
        "background": "500510"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}來到了厄莉絲的夢中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n出現在他面前的是……"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……對不起，",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_000"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n突然請你過來一趟。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為久違地能見到面，",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_001"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "忍不住就……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "呵呵，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "太好了……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嗯……",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_003"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n她向我道歉了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "跟之前一樣裝作好孩子說些漂亮話……",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一直把自己的想法強加於我。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "可是……",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "即使讓騎士先生的紀錄流入她的腦海中，",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "她卻還是一樣。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n抬頭正眼看向了我。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……比起這個，",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_007"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你過得好嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我的話……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我想想，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "該怎麼說好呢……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……嗯。",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_008"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n角色的保護與修復……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n兼具兩者的功能。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是出自對我的憐憫或者同情……",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還是想要我為差點將世界給破壞掉一事贖罪。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我並不曉得是因為什麼。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……但我並沒有消失。",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_010"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n唯有這一點是事實。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是這樣",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_011"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "的嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不過，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "既然騎士先生都這麼說了……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n那麼或許是吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……因為無論何時。",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n騎士先生總是會幫助他人。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "現在也是。",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_013"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n你為了幫助與你毫無關係的兩個人而在努力著。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "明明對方並不是這個世界的存在。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……我說，",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_014"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我可以說點",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "壞心眼的話嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……我問你。",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_015"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "幫助那兩個人，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "意味著什麼呢？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我很清楚。",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_016"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n回到自己的世界之後，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "她們會變成怎麼樣……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "只能一直看著某個人，",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_017"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n在自己無法觸及的地方受到傷害。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就這樣無數次地反覆循環……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "連結束都不被允許。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我認為……",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_018"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這是一件非常痛苦的事。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "讓她們回到那種地方。",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_019"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n真的可以說",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是在幫助她們嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我很清楚，",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_020"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那兩個人都還沒有放棄。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "可是即使如此……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那又能做到什麼呢，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我想。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過……？",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_021"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_022"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……我們也無法擅自決定她們的未來。",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_023"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "意思是，那兩個人的未來……",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_024"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n只有那兩個人，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "才會知道嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_025"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這樣啊。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對不起，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我說了些壞心眼的話。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我明白了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生果然很厲害呢。",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_026"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n面對跟這個世界毫無關係的人，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你還是會溫柔對待……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "咦……？",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_027"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_028"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……這樣啊。",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_029"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是啊……",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_030"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n你依然是騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生還真是，",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_031"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n一點都沒變呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_032"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "無論對方是誰，都會願意出手相助。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "只要有人遇到困難，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就一定會這麼做。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就連壞人也會幫助，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "只會對壞事加以斥責。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "他肯定",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_033"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會接受所有一切。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "他讓我，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有這樣的想法。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……即使是像我這種人。",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_034"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n即使是我這種嚴重扭曲且不確定的存在。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生也肯定會認同我。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我這麼想。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所以，",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_035"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我──",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……嗯。",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_036"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_037"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_5137003_038"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
