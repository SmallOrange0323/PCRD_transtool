[
    {
        "type": "background",
        "background": "500178"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了對抗守護世界的「紅霧精靈」，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}一行人覺醒了星素之力。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "使用這股新的力量成功地暫時擊敗精靈後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一行人在前往蘭德索爾前先休息片刻。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在他們之中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n優衣隻身一人走在森林裡……"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "…………厄莉絲……",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_000"
    },
    {
        "type": "still",
        "still": "128900101"
    },
    {
        "type": "still",
        "still": "128900102"
    },
    {
        "type": "still",
        "still": "128900103"
    },
    {
        "type": "still",
        "still": "128900104"
    },
    {
        "type": "background",
        "background": "500178"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……也許，",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還能再見到面也說不定啊。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但是……",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n她一定",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不想看到",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我吧。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不僅如此，",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也許就連被我感受到她的存在，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也會讓她覺得",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "很反感。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……那也沒辦法。",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n因為我就是",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "做出了",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那些事。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為我有所期望，",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n因為我想實現願望，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以我一直一直",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在傷害著",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "厄莉絲……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……還是不要見面，",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "會比較好吧。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊！",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我到底",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在說些什麼？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說出這些喪氣話，",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是不行的吧……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我會被厄莉絲討厭，",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這種事",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我早就明白了。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "即使如此我也想去幫助她，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我應該已經如此決定……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但我就連已經決定好的事……",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都做不到。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "做不到的我實在太丟人、",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太窩囊了……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為了不再重蹈覆轍，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想要變強……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "才因此去精靈族之村",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "接受了修行。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "…………我得去見她。",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我得去見厄莉絲，",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "告訴她我這次一定要幫上她的忙。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不然我被她單方面幫助兩次，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "實在是太丟人了。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為此我也要找出厄莉絲在哪裡，",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "然後──",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊。",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n在那之前，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "要先請她幫忙送志那都和埃拉",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n送到回原來的",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "世界吧？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……奇怪？",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我是想要幫助厄莉絲的吧？",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "然而，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我卻是",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "希望厄莉絲來幫忙，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因此才在",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "找她的嗎……？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總、",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總覺得",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好像本末倒置了……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總、",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總而言之。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n現在先找到厄莉絲在哪裡吧！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剩下的",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就等找到之後",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "再說！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "既然這麼決定了，",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "首先要",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "進行修行。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "只要能熟練地運用星素之力，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n也許就會更清楚",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "厄莉絲",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "到底在哪裡……！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為當騎士先生",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "覺醒星素之力時，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n也感受到了",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "厄莉絲的存在。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好。",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我要",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "加油囉！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯！",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n一起──",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃，",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生！？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你你你你你是什麼時候出現的？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "問他什麼時候",
        "unit_id": 190011,
        "voice": "vo_adv_1289001_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "出現……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是優衣朝我們這邊走過來的喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是、",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是我嗎？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳該不會沒注意到吧？",
        "unit_id": 190011,
        "voice": "vo_adv_1289001_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我知道了！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n反正妳一定是在想事情吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n啊，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "差不多就是那樣。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊哈哈……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所、",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n你們兩人",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛剛在做什麼？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1289001_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也不像真的修行那麼正經啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "主要是在掌握感覺。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對喔……",
        "unit_id": 100213,
        "voice": "vo_adv_1289001_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說到力量剛覺醒，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也是一樣的嘛。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
