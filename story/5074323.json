[
    {
        "type": "dialogue",
        "name": "院長",
        "words": "……",
        "unit_id": 15013
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不會吧，",
        "unit_id": 117611,
        "voice": "vo_adv_5074323_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "院長的力量還在增強……",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再、",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再變強下去，可能真的要束手無策了……",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是啊，",
        "unit_id": 117511,
        "voice": "vo_adv_5074323_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我也真的累了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "院長看起來也一樣累了呢。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "什麼？",
        "unit_id": 117611,
        "voice": "vo_adv_5074323_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "他自己也已經撐不下去了。",
        "unit_id": 117511,
        "voice": "vo_adv_5074323_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "現在這就像是蠟燭要燒光之前",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "放出一瞬間的強烈光芒罷了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可是，",
        "unit_id": 117611,
        "voice": "vo_adv_5074323_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是在他燒光之前，我們先失去了光芒……？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀？",
        "unit_id": 117511,
        "voice": "vo_adv_5074323_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "世上最美最耀眼的人，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼會這麼沒自信呢？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "難道妳的光芒",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "會輸給這種依賴藥物強制製造出來的燭光？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……妳這話說得",
        "unit_id": 117611,
        "voice": "vo_adv_5074323_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好奸詐喔。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "聽到妳講這種話，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我也只能硬著頭皮上了呢。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就讓妳看看",
        "unit_id": 117611,
        "voice": "vo_adv_5074323_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "誰才是最美的！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我很期待喔，",
        "unit_id": 117511,
        "voice": "vo_adv_5074323_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "世上最美的護理師♪",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好啦，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這就是最後一戰了！",
        "unit_id": 117511
    }
]