[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──藉著和貪吃佩可與凱留，以及許多少女的羈絆，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n以{player}的力量為中心的異狀迎來了尾聲。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當【美食殿堂】重新和平常一樣待在公會裡時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n貪吃佩可提出建議，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n於是凱留和{player}兩個人一同前往城鎮上。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……上次像這樣和你一起逛街，",
        "unit_id": 106012,
        "voice": "vo_adv_1211004_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n感覺是很久以前了呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你也才睡幾天而已……",
        "unit_id": 106012,
        "voice": "vo_adv_1211004_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "卻讓人覺得",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像已經分開很久了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我有很多很多話，",
        "unit_id": 106012,
        "voice": "vo_adv_1211004_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想要對你說。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "比如說我們大家有多麼擔心你",
        "unit_id": 106012,
        "voice": "vo_adv_1211004_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "之類的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……還有被當成變態可疑分子之類的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這可都是你的錯喔！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我辛苦做了這麼多事，",
        "unit_id": 106012,
        "voice": "vo_adv_1211004_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你至少得聽我抱怨完才行喔！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……等等，",
        "unit_id": 106012,
        "voice": "vo_adv_1211004_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你怎麼在發光！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這個難不成，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是慣例的那個……！？",
        "unit_id": 106012
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……{player}",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_006"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "，也太慢了吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "搞什麼……",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_007"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "明明是他和我說，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n這次星期天要一起出來玩，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我才特地出來的。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那傢伙，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_008"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "該不會忘記約定了吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……不對，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "他的話絕對不會發生這種事。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……可是，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_009"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這樣的話，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "為什麼會這麼慢啊？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n……莫非，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是捲進什麼事故了嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那傢伙運氣不怎麼好，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_010"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "搞不好真的有可能……！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "要是他真的發生事故，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "該怎麼辦……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "呀啊！？",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_011"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……還、",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "還以為是誰，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n原來是你啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不要從人家背後出聲啦，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "真是的。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……不過你看起來沒事就好。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "所以，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_012"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "為什麼比約好的時間晚了這麼多啊？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我可是等好久了耶！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……你剛剛去幫忙遇到麻煩的老人和小孩子？",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_013"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你呀，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "還真是個老好人耶……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "唉，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "很像你會做的事啦。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……你說有用mimi聯絡我，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_014"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n說會晚一點？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n原來有這回事，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我完全沒有發現。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "平時雖然都有帶在身上，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_015"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n可是我幾乎都沒有在用呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……你看，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這是我的mimi。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這個，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_016"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是不久之前，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "派送到我手上的東西。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "寄送者選擇匿名，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "所以也不曉得是誰送給我的。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "至今以來，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_017"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我一直都是獨自一個人……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n覺得自己是被捨棄的存在。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "雙親是垃圾，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_018"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "身邊也沒有可靠的大人或老師。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……我又沒有朋友，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n以為誰都不會在意我。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "所以，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_019"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "當我知道這世上還有人關注我……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "願意贈送禮物給我，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n那時候我真的很高興。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "可是，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_020"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "誰會把這當禮物送給我呢……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我這邊",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "完全沒有頭緒。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "世上真是什麼人都有呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n如果有機會見面，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我很想向他道謝……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "總之，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_021"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就是因為這樣，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n這個mimi對我而言是非常重要的東西喔。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "因為太重要了……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我就盡可能沒有去使用它。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "像之前，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_022"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我應該有說過吧，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n因為跟不上「阿斯特朗傳奇」的進度",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "所以我不玩了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "其實",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那只是我不玩的原因的一部分……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "最重要的是，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_023"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "如果被媽媽發現我擁有mimi，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n絕對會被拿走的。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "所以，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_024"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我選擇在那種事發生之前",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "放棄遊戲。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n都是為了重要的東西不會被搶走。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……說真的。",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_025"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n和你一起冒險，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "過得很快樂。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "雖然在阿斯特朗一起玩的時間很短……",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_026"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那是一段自由",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "又幸福的時間。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……如果我能自由自在地玩「阿斯特朗傳奇」，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_027"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n如果能盡情",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "與你一同冒險，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n不曉得會是多麼愉快的一件事。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……唉。",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_028"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就算說給你聽，你也沒辦法吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n這話題就到此為止。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "回歸正題，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_029"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我們今天是要去玩的對吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "所以說，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "要去哪裡？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我先說好喔，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "唱歌之類的我可不行。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "畢竟，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我沒有錢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……啊～",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_030"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "抱歉。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n都是我說了不該說的話，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "讓你多想了呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不用這樣，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_031"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不需要在意。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我只是個新手，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "等級又低。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n一起玩遊戲",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "也只會拖你的後腿而已。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……你都這麼說了，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_032"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "要是待會覺得",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我果然礙手礙腳什麼的，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "後悔了我也不管喔！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……呵呵，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_033"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "好久沒有和你一起玩阿斯特朗了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n不妙，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "好像有點興奮起來了呢……♪",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……啊，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_034"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "要去哪裡玩？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "登入的時候會睡下去，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n所以也不能在公園長凳",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "之類的地方玩，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那樣會感冒的。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……對了，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_035"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我記得你家",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不算多遠吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n就去你家玩吧！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你可不能拒絕喔？",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_036"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n讓我等了這麼久，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n就算是為了幫助人也該表示一下歉意吧！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "好，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_037"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那就這麼決定♪",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n來，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "出發吧！",
        "unit_id": 106031
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "哦，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_038"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這就是你的房間啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我還以為男生的房間",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "會更加散亂一點。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n不過",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "意外地挺乾淨的嘛。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……這麼說來，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_039"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n仔細想想，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我這次，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是第一次進來男生的房間呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "一旦意識到這點，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就開始緊張了……！？　",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……咦！？",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_040"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "臉很紅！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是、",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是你的錯覺啦！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "別盯著看，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我宰了你喔！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "比、",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_041"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "比起這個，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "快點！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n趕快把你的mimi接上去！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n要玩遊戲不是嗎，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "玩遊戲！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "好久沒玩阿斯特朗了，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_042"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我有很多事想要做～",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n像是攻略關卡，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "還有收集素材之類的！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "對了對了，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_043"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "之前那次，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不是用mimi掃描了振袖嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那個，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我後來有試著裝備一次喔。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n結果，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "擁有的能力實在是超讚的呢！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "只要妥善運用，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_044"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "說不定還能打出封頂傷害喔！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n這件事我也有點想試試看！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那就，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_045"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "開始囉！",
        "unit_id": 106031
    },
    {
        "type": "still",
        "still": "121100401"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……玩遊戲不需要提心吊膽，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_046"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n不怕被媽媽發現，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "實在是太幸福了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……這傢伙，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_047"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "看來是先潛入遊戲了呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n看你睡得這麼香甜。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……你的肩膀，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我就",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "稍微借用一下囉。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……直接對著你說實在太難為情，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_048"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "現在我才有勇氣開口。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我其實",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "很多很多事情都很感謝你喔。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "像是第一次見面時",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_049"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你借我錢的事，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n還有你請我吃漢堡的事。",
        "unit_id": 106031
    },
    {
        "type": "still",
        "still": "121100402"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "特別是",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_050"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "陪我一起走到海邊的那次，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我這輩子都不會忘記。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "走路去海邊明明要好幾個小時，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_051"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n對你來說更是沒有任何好處……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你卻還是陪著我，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "一直走到最後了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "結果，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_052"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "抵達海邊的時候已經一片黑，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n什麼也看不見……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但是我們兩人一起走著的那段時間，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n對我來說",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就是一場大冒險……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "非常開心。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "對我來說，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_053"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "比起普通地去畢業旅行，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n那才是更棒的回憶。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "謝謝你。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "總有一天，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_054"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我一定會回報你的恩情。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n你遇到大麻煩的時候，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我一定會去幫你的，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我保證。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……唉。",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_055"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "雖然自己講有點奇怪，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我還真是個麻煩的女孩子。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "為什麼，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就無法直接說出口啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……算了。",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_056"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "想說的都說完了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "登入吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "能夠和這傢伙一起在阿斯特朗裡玩的時間很有限，",
        "unit_id": 106031,
        "voice": "vo_adv_1211004_057"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我得好好珍惜",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這段短暫的時間……",
        "unit_id": 106031
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次，",
        "unit_id": 190011,
        "voice": "vo_adv_1211004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n聽到了很多很多",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "凱留的想法呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那一天，",
        "unit_id": 190011,
        "voice": "vo_adv_1211004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n凱留和你在阿斯特朗裡",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一起玩了兩個小時左右。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看起來",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她是真的玩得很開心。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說，",
        "unit_id": 190011,
        "voice": "vo_adv_1211004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你還記得凱留對你許下的這個約定嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n當你遇上大麻煩的時候，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一定會前來幫忙",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的約定。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "於是，",
        "unit_id": 190011,
        "voice": "vo_adv_1211004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她遵守約定了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也因此，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次你才能醒過來。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這件事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也很感謝凱留喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不論在現實世界，",
        "unit_id": 190011,
        "voice": "vo_adv_1211004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還是這個世界。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對凱留來說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你都是非常重要的存在。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "像這種一睡不醒造成人家麻煩的事，",
        "unit_id": 190011,
        "voice": "vo_adv_1211004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n以後",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可不要再發生了喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "彼此",
        "unit_id": 190011,
        "voice": "vo_adv_1211004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好好努力吧！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就這樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯。",
        "unit_id": 106012,
        "voice": "vo_adv_1211004_065"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "奇怪，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我睡著了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……你也睡醒了嘛。",
        "unit_id": 106012,
        "voice": "vo_adv_1211004_066"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "早安。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次沒有睡到不省人事真是太好了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說是這麼說，",
        "unit_id": 106012,
        "voice": "vo_adv_1211004_067"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是你再次一睡不醒，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我也會把你叫起來，放心好了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……話說，",
        "unit_id": 106012,
        "voice": "vo_adv_1211004_068"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我一直期望著",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "自己能夠和你一起冒險。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣的話，",
        "unit_id": 106012,
        "voice": "vo_adv_1211004_069"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在這個世界",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對我來說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是理想的……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……呵呵！",
        "unit_id": 106012,
        "voice": "vo_adv_1211004_070"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼嘛！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那麼大聲。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你肚子有那麼餓了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106012,
        "voice": "vo_adv_1211004_071"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拿你沒辦法。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然還有很多話想對你說……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過在那之前，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "先去享用美食吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──凱留將{player}的羈絆再一次連結起來的故事，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n於此謝幕。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而故事為了連結更進一步的羈絆，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n將再度以{player}為中心──"
    }
