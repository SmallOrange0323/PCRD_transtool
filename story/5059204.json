[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是這附近……",
        "unit_id": 105811,
        "voice": "vo_adv_5059204_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "周遭的魔物們都很躁動的樣子……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是受那隻龐然大物的影響吧。",
        "unit_id": 106011,
        "voice": "vo_adv_5059204_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠什麼時候會襲擊過來都不奇怪，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以別鬆懈了唷。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……妳沒事吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不必擔心。",
        "unit_id": 115511,
        "voice": "vo_adv_5059204_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦～",
        "unit_id": 106011,
        "voice": "vo_adv_5059204_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是冷靜呢──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然如此，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們就來試試看妳能冷靜到什麼程度。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "？",
        "unit_id": 115511,
        "voice": "vo_adv_5059204_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "──咕喔喔喔喔喔──！",
        "unit_id": 105811,
        "voice": "vo_adv_5059204_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀啊！？",
        "unit_id": 115511,
        "voice": "vo_adv_5059204_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎、",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼回事！？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……貪吃佩可小姐？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼啊，",
        "unit_id": 106011,
        "voice": "vo_adv_5059204_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這不是能好好露出像小孩子一樣的表情嘛。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……咦？",
        "unit_id": 115511,
        "voice": "vo_adv_5059204_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留她，",
        "unit_id": 105811,
        "voice": "vo_adv_5059204_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是覺得妳看起來一直很緊張，所以很擔心吧。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才、",
        "unit_id": 106011,
        "voice": "vo_adv_5059204_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不是！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只是想要惡作劇一下，嚇嚇她而已！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……是",
        "unit_id": 115511,
        "voice": "vo_adv_5059204_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……這樣啊。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "謝什麼啦！",
        "unit_id": 106011,
        "voice": "vo_adv_5059204_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "無所謂啦，趕快走吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對上這種的就該",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "輕輕鬆鬆迅速解決才是最佳方案啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的……！",
        "unit_id": 115511,
        "voice": "vo_adv_5059204_013"
    }
]