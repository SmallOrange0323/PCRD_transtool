        "type": "dialogue",
        "name": "宮子",
        "words": "闇黑眷族～？",
        "unit_id": 100711,
        "voice": "vo_adv_3014002_023"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n那很強嗎～？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵呵，那就讓你們瞧瞧吧！",
        "unit_id": 104412,
        "voice": "vo_adv_3014002_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來吧，蝙蝠們！",
        "unit_id": 104412
    },
