    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "主君也真是好色呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過呢，要成為奴家的僕人，",
        "unit_id": 104412,
        "voice": "vo_adv_3014002_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這種程度的『魅惑』應該也是理所當然。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哇哈哈哈哈！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總之，【惡魔偽王國君】的",
        "unit_id": 104412,
        "voice": "vo_adv_3014002_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n戰力又增加了！",
        "unit_id": 104412
    },
