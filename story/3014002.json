        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "奴家只是因為現在是小孩的外表，才有點膽小，",
        "unit_id": 104412
    },
