    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這、這樣啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n總之先離開吧！",
