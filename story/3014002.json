    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊莉亞復活後經過了數天。\n依里她們被伊莉亞召喚而來到了古城。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就此咱們要開始征服世界！",
        "unit_id": 104412,
        "voice": "vo_adv_3014002_000"
    },
    {
        "type": "dialogue",
