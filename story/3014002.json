    {
        "type": "dialogue",
        "name": "忍",
        "words": "是啊。",
        "unit_id": 103111,
        "voice": "vo_adv_3014002_020"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n也只是變成6個人而已，",
        "unit_id": 103111
