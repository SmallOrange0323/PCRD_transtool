        "type": "dialogue",
        "name": "依里",
        "words": "伊莉亞……",
        "unit_id": 102211,
        "voice": "vo_adv_3014002_029"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n竟然被自己掌控的魔物給擺了一道，是要怎樣呢……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳真的是『傳說的吸血鬼』嗎……",
