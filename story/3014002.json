        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥！茜里好開心可以見到你～",
        "unit_id": 100611,
        "voice": "vo_adv_3014002_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n心跳加速成這樣呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你看，來摸摸看確認一下♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯？什麼？",
        "unit_id": 104412,
        "voice": "vo_adv_3014002_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妳們全都和主君認識啊？",
        "unit_id": 104412
