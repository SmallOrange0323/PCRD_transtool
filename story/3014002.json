        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_3014002_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎樣啊怎樣啊？",
        "unit_id": 104412,
        "voice": "vo_adv_3014002_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為什麼一臉苦瓜臉啊？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "先別管那些事情，趕快讓宮子復活啦～！",
        "unit_id": 100711,
        "voice": "vo_adv_3014002_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "宮子，伊莉亞說她沒辦法。",
        "unit_id": 100611,
        "voice": "vo_adv_3014002_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "奴家可沒說沒辦法！",
        "unit_id": 104412,
        "voice": "vo_adv_3014002_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只是這麼小的身體，魔力不夠而已……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不，反而是魔力不夠，",
        "unit_id": 104412,
        "voice": "vo_adv_3014002_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n所以才變成小孩的樣子……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "想不到『傳說的吸血鬼』竟是個小女孩呢……",
        "unit_id": 102211,
        "voice": "vo_adv_3014002_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們的『願望』不能實現了呀……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "伊莉亞，要靠我們5個人征服世界，",
        "unit_id": 103111,
        "voice": "vo_adv_3014002_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我想是相當地困難……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔。如果奴家可以恢復原本的力量，就很簡單，",
        "unit_id": 104412,
        "voice": "vo_adv_3014002_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但現在這樣的話……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過放心！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n今天要跟大家介紹幫手！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喂！",
        "unit_id": 104412,
        "voice": "vo_adv_3014002_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n出來吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "忍一行",
        "words": "啊～！",
        "unit_id": 1,
        "voice": "vo_adv_3014002_011"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你、你怎麼會在這裡？",
        "unit_id": 102211,
        "voice": "vo_adv_3014002_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你和伊莉亞認識嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊，",
        "unit_id": 100711,
        "voice": "vo_adv_3014002_013"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是你～！",
        "unit_id": 100711
