        "type": "dialogue",
        "name": "依里",
        "words": "即使你當幫手，",
        "unit_id": 102211,
        "voice": "vo_adv_3014002_019"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我一點都不覺得戰力有提升……",
        "unit_id": 102211
