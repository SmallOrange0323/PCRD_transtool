[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原本以為只是平時的魔物討伐工作，",
        "unit_id": 105911,
        "voice": "vo_adv_5084321_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但情況似乎",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "開始變得有些不太對勁呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "魔物成群聚集在一起……",
        "unit_id": 106411,
        "voice": "vo_adv_5084321_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n而且，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "其中每隻看起來都相當強悍。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個該死的眼鏡女！",
        "unit_id": 106011,
        "voice": "vo_adv_5084321_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n她到底在打什麼算盤，竟然要我們處理這麼棘手的討伐委託！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n她還真能一臉笑容地使喚我們啊！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是",
        "unit_id": 105911,
        "voice": "vo_adv_5084321_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為花凜小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "信賴在下等人的實力呀。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總而言之，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然貪吃佩可小姐和主人都不在，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可能需要採取和平時不同的戰鬥策略。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "確實地減少敵人的數量吧。",
        "unit_id": 106411,
        "voice": "vo_adv_5084321_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n無論有多少強大的敵人聚集在一起，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n肯定都能找到破綻攻入的。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我晚點絕對",
        "unit_id": 106011,
        "voice": "vo_adv_5084321_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會要那個眼鏡女加碼特殊報酬！",
        "unit_id": 106011
    }
]