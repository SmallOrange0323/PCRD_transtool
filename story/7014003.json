    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n應該就是優花梨小姐妳平常在吃的食物吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呃、",
        "unit_id": 103411,
        "voice": "vo_adv_7014003_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這個嘛……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那是、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "…………",
        "unit_id": 105011,
        "voice": "vo_adv_7014003_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "…………",
        "unit_id": 103411,
        "voice": "vo_adv_7014003_026"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也就是說",
        "unit_id": 105011,
        "voice": "vo_adv_7014003_027"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "優花梨小姐妳並不是我理想中的成熟淑女",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n而是行為亂七八糟會說奇怪的話，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n還會沒有規矩隨處睡著的那種人嗎？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我、",
        "unit_id": 103411,
        "voice": "vo_adv_7014003_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我並不是每次都這樣！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n只是偶爾有時候會變成那個樣子而已……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真的嗎？",
        "unit_id": 105011,
        "voice": "vo_adv_7014003_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……對不起。",
        "unit_id": 103411,
        "voice": "vo_adv_7014003_030"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "其實我每次到最後都會變成那樣……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "唉……",
        "unit_id": 105011,
        "voice": "vo_adv_7014003_031"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是的，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "糟透了。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n本來還以為自己終於遇到了一位了不起的淑女……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是夠了！　",
        "unit_id": 105011,
        "voice": "vo_adv_7014003_032"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這個塔、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就由我這個成熟淑女",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n獨自登頂好了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你們就在這裡等著吧！　",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那我就先走囉！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "拜拜！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "美、",
        "unit_id": 103411,
        "voice": "vo_adv_7014003_033"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "美咲！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n妳等一下～！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美咲就這樣不顧優花梨的呼喊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一個人小跑步不斷地往前跑去。"
    }
]