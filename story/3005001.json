        "words": "哼哼哼～哼♪",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我的牛～是好牛～♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哼哼哼♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唉呀，真陽！",
        "unit_id": 105211,
        "voice": "vo_adv_3005001_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳還是那麼早起呢？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n早安♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔～莉瑪莉瑪！",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳今天也是個大美人，叫人捨不得賴床啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "唉呀呀，耀眼到睜不開眼睛的啦☆",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "討厭，讚美我也不會得到什麼好處啦！",
        "unit_id": 105211,
        "voice": "vo_adv_3005001_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n真陽就是愛說笑！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但是我很開心！",
        "unit_id": 105211,
        "voice": "vo_adv_3005001_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n多讚美我一些吧……♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "才不是說笑的啦，",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "既然這樣，就給妳看看更有趣的哏。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "唉呀～這毛髮的光澤……♪",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這毛絨絨的感覺……♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪，就是我們牧場的明星的啦☆",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，說到明星！",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我來段即興相聲！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪是明星的話，我就是製作人囉？",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪、真陽，上台一鞠躬……♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "吵～死～啦～……？",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "一大早的不要在那邊大聲嚷嚷啦，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n真是妨礙睡眠……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "唉呀，是鈴鈴……",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為什麼要趴在莉瑪莉瑪的背上咧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這個女孩才不是什麼馱獸，",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n她可是我們牧場很重要的客人喔！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒關係啦，不要這樣罵她嘛。",
        "unit_id": 105211,
        "voice": "vo_adv_3005001_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "她這麼親近我，我反而很高興呢～",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我最喜歡這座牧場的人們了，",
        "unit_id": 105211,
        "voice": "vo_adv_3005001_013"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n因為大家都不會用異樣的眼光看我♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯。",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n莉瑪莉瑪喜歡的話，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可以一直待在我們的牧場唷♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "話說，鈴鈴妳趕快出來啦。",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "媽媽在家會擔心的啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～沒關係沒關係的。",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我們家是放任主義。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "再說，",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我也是被派任來當這座牧場的警衛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳瞧～",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我已經工作過度到虛脫了……♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呃，我從來沒看到鈴鈴有在工作的呢。",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過就算沒有警衛，牧場也很平靜，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "平常沒什麼事應該很閒的吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "既然如此，就來幫忙我們的工作吧？",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n需要照顧的動物之類的越來越多，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "照顧動物的人卻是不夠，很辛苦的啦♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～沒辦法～……",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為我現在",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n人命值已經掉到0了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "人命值？",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我雖然很懂動物，但是對獸人不太了解呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是說如果不多多累積人命值的話，",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就不能維持人類的樣子嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～少在那邊逗哏了……",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我真的很想睡，先別吵我了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人命值……",
        "unit_id": 105211,
        "voice": "vo_adv_3005001_025"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果多多累積的話，我也可以……？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "各位早安。",
        "unit_id": 103811,
        "voice": "vo_adv_3005001_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "看起來好像很熱鬧呢？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，栞栞！",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "早安呀，安安♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "安安……？",
        "unit_id": 103811,
        "voice": "vo_adv_3005001_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "抱歉把妳吵醒啦。",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_029"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒睡覺，身體要不要緊呀？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不要緊。",
        "unit_id": 103811,
        "voice": "vo_adv_3005001_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n今天身體狀況還不錯。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣啊，太好了太好了。",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但是妳也不要逞強喔？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "小栞～",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n如果妳有精神的話，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就幫我去巡一下牧場吧～……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我剛剛已經巡過囉。",
        "unit_id": 103811,
        "voice": "vo_adv_3005001_033"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n也順便散了個步。今天牧場也很平靜。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "山上空氣真的很好呢。",
        "unit_id": 103811,
        "voice": "vo_adv_3005001_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n在這裡療養的話，感覺身體就會好起來……♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "莉瑪。",
        "unit_id": 103811,
        "voice": "vo_adv_3005001_035"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我剛剛在巡邏的時候發現蘋果成熟了，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n就摘來當作給妳的禮物囉。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請收下。",
        "unit_id": 103811,
        "voice": "vo_adv_3005001_036"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n也送給鈴橡子♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝妳，我好高興～！",
        "unit_id": 105211,
        "voice": "vo_adv_3005001_037"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n小栞好貼心喔，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "超愛妳的♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇噗……",
        "unit_id": 103811,
        "voice": "vo_adv_3005001_038"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請不要噴口水，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我的臉會變得濕答答的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嚼嚼……♪",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_039"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然橡子也好吃，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過我好想吃紅豆麵包啊～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在蘭德索爾明明很多地方都有賣呢～",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_040"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我只對這點不滿。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過鈴鈴，妳還是說聲謝謝吧。",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_041"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n栞栞可是代替鈴鈴",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n去巡邏了牧場唷？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然妳們兩個都是【哞哞自衛隊】派任來的。",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_042"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但鈴鈴是負責我們牧場的警衛，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n而栞栞只是單純地來這裡靜養的吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_043"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n小栞～妳一直都幫了我的忙呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "謝謝妳囉。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "過來這裡。",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_044"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n最近我迷上了一款電玩，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就特別讓小栞玩玩看吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很好玩喔～……我最近已經連續熬夜好多天了。",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_045"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以才像鬼魂般超級想睡。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼啊～嗯♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "電玩……？",
        "unit_id": 103811,
        "voice": "vo_adv_3005001_046"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我不是很懂，但我很開心。",
        "unit_id": 103811,
        "voice": "vo_adv_3005001_047"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我幾乎把帶來的書都看完了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "最近很空閒呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "鈴，",
        "unit_id": 103811,
        "voice": "vo_adv_3005001_048"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n真是謝謝妳告訴我許多有趣的東西……♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯嗯。",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_049"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要更～加地感謝我啊……♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "討厭啦，",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_050"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n該謝謝人的應該是鈴鈴啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，這時不該吐槽嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_051"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可惡～妳們的反應似乎覺得很無聊？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不管怎麼說，",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_052"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我現在要打掃畜舍，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "玩電玩？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還是什麼的，就拜託到外頭去啦～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好了，快出去快出去。",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_053"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天也是好天氣喔♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，真陽……",
        "unit_id": 103811,
        "voice": "vo_adv_3005001_054"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n請讓我來幫忙妳打掃吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果不會給妳添麻煩的話……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我也要！",
        "unit_id": 105211,
        "voice": "vo_adv_3005001_055"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n必須要運動來消耗吃蘋果的熱量呢，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "維持身材真辛苦♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗄～……",
        "unit_id": 102611,
        "voice": "vo_adv_3005001_056"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那我要睡覺，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳們盡量不要大聲喧鬧喔～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哈哈哈。",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_057"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "各位，謝謝啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為我在這座牧場一直都只跟動物接觸……",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_058"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "最近可以正常地聊天，讓我覺得很開心。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就算相聲不好笑，",
        "unit_id": 103311,
        "voice": "vo_adv_3005001_059"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n也會自然地嘴角上揚的啦♪",
        "unit_id": 103311
    }
]