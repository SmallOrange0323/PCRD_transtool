    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "散步、散步♪",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_000"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n要一步一步地走呦，真開心呢～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "小貓",
        "words": "喵～",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦？",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_001"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n貓咪先生的叫聲～從哪傳來的呢～？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗯……呃……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "啊，在樹上～！",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_002"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "是一隻小貓先生呢～真可愛呀～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "奇怪？不過小貓先生全身縮得緊緊的，",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_003"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n身體不停的顫抖……？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "難道，牠是不敢下來嗎？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "小貓",
        "words": "喵～",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "好～的，",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_004"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "等一下喔～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美這就去救你～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嘿咻、嘿咻♪",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_005"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "耶～美美爬上來了～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "貓咪先生已經不用怕了呦～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "小貓",
        "words": "喵～！",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "欸嘿嘿，乖孩子乖孩子～♪",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_006"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n美美已經來了，所以你可以放心了喔～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "那，我們一起下……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦？咦咦咦？",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_007"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美不知道該怎麼下去了～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n美美自己也被困在樹上了啦～！？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗚……嗚～哇！",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_008"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n好高呦～！好可怕呦～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗚～！",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_009"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n爸爸～！媽媽～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n嗚……哥哥～！救救美美～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哇！哥哥！？",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_010"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n你怎麼會在這裡？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……哥哥是聽到美美的聲音，所以才過來的嗎？",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_011"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哇～謝謝你～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "貓咪先生，已經不要緊了呦！",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_012"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥會幫助我們的～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥，那個～",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_013"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n我們被困在樹上下不去了……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n該怎麼辦才好呢？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……咦！？要、要美美從這裡跳下去嗎？",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_014"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥會接住美美……？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美、美美辦不到～",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_015"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n好可怕～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……嗯、嗯！美美知道了。",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_016"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n既然哥哥都這麼說了……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美會加油的！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥、哥哥要對自己有信心！",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_017"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美相信哥哥做得到！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "那麼，美美要跳下去了呦？",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_018"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n哥哥要好好接住美美喔？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n一，二……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "三～跳！！",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_019"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哇～！好厲害，好厲害！",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_020"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥真的接住美美了～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥果然很厲害呢！",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_021"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n美美又被哥哥救了一次了～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "小貓",
        "words": "喵～♪",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦？",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_022"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n這隻貓咪先生的脖子上掛著鈴鐺。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "是不是有人養的呢？",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_023"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "但是四周都沒看到飼主呢？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "小貓",
        "words": "喵～",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "怎麼辦……",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_024"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……咦？哥哥要幫美美一起找貓咪先生的飼主？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "太好了～♪",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_025"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "只要有哥哥一起幫忙找的話，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n絕對可以找到貓咪先生的飼主的～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "貓咪先生，真是太好了呢～",
        "unit_id": 102011,
        "voice": "vo_adv_1020002_026"
    },
    {
        "type": "dialogue",
        "name": "小貓",
        "words": "喵～♪",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是在找到貓咪的飼主之前，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n小貓咪就決定暫時寄養在美美家了。"
    }
]