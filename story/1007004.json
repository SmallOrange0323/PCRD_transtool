    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}，布丁～！",
        "unit_id": 100711,
        "voice": "vo_adv_1007004_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "快買布丁給宮子來的～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不吃布丁的話宮子會死掉的～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你沒有錢嗎～？",
        "unit_id": 100711,
        "voice": "vo_adv_1007004_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子才不管呢～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "總之快點買布丁來的～！！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "哇，好奇怪的光～！？",
        "unit_id": 100711,
        "voice": "vo_adv_1007004_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n這、這什麼～好刺眼來的～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚哇～來的～～～！",
        "unit_id": 100711,
        "voice": "vo_adv_1007004_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "！",
        "unit_id": 100711
    },
    {
        "type": "background",
        "background": "510240"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊～！",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n你要去哪裡～？",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……去學校？要上課？",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚呃～光是聽到就覺得頭痛來的……",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n活著的人還真辛苦來的～",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "先別管那個，",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "難得見到面了，你快請宮子吃布丁來的～！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……因為你要上課所以沒辦法？",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_007"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子才不管那個來的～！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n反正你要買布丁給宮子就對了喲～！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就算你說不行，宮子也不會放棄的～！！",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_008"
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "真討厭──",
        "unit_id": 1,
        "voice": "vo_adv_1007004_009"
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "\n那個人在自言自語耶～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "搞不好是危險人物喔？",
        "unit_id": 1,
        "voice": "vo_adv_1007004_010"
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "\n不要看他比較安全。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……周圍的人都在看這邊？",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊～因為普通人看不到身為幽靈的宮子，",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n所以搞不好你會被當成一直自言自語的怪人來的～",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不要在意那種事情喲～",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "比起那些快去買布丁來的……",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊！別逃跑──！",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_013"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "等等啊──！！！",
        "unit_id": 100731
    },
    {
        "type": "background",
        "background": "510220"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "上課中――"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布～丁！布～丁！",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_014"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n快買布丁來的～！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚～～為什麼不理宮子來的～？",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_015"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n這樣的話宮子只好硬來了喲～！！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就是用蠻力把你帶到店裡去喲～！",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_016"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嘿～看宮子的～！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "怎麼了、怎麼了？",
        "unit_id": 1,
        "voice": "vo_adv_1007004_017"
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "\n{player}那傢伙為什麼站了起來？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}！",
        "unit_id": 101831,
        "voice": "vo_adv_1007004_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n上課時要保持安靜──！",
        "unit_id": 101831
    },
    {
        "type": "background",
        "background": "510020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "體育課――"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你在踢足球喔？",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_019"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "比起這個，布丁更重要喲～！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n現在立刻去買布丁來的～！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "現在偷偷溜走也不會被發現的～",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_020"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n所以我們一起去店裡吧～",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "喂，球過去那裡囉──！",
        "unit_id": 1,
        "voice": "vo_adv_1007004_021"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "哇、哇！？",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_022"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n好像有東西跑過來了喲！？",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "要撞到了喲～",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "體育老師",
        "words": "得分！",
        "unit_id": 1,
        "voice": "vo_adv_1007004_023"
    },
    {
        "type": "dialogue",
        "name": "體育老師",
        "words": "\nA隊獲勝！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生們",
        "words": "耶──！",
        "unit_id": 1,
        "voice": "vo_adv_1007004_024"
    },
    {
        "type": "dialogue",
        "name": "男學生們",
        "words": "\n幹得好！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生們",
        "words": "\n我們贏了──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚呀！",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_025"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好、好痛來的……",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "體育老師",
        "words": "烏龍球！",
        "unit_id": 1,
        "voice": "vo_adv_1007004_026"
    },
    {
        "type": "dialogue",
        "name": "體育老師",
        "words": "\nB隊獲勝！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生們",
        "words": "{player}，搞什麼啊！",
        "unit_id": 1,
        "voice": "vo_adv_1007004_027"
    },
    {
        "type": "dialogue",
        "name": "男學生們",
        "words": "\n都是你害的才會輸了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊……",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_028"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n聚集太多人了，宮子沒辦法靠近那傢伙來的～",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不能去買布丁來的……",
        "unit_id": 100731
    },
    {
        "type": "background",
        "background": "510180"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "午休時間――"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "終於到吃飯時間來的～♪",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_029"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "午餐就是要吃布丁喲～！還有也要給宮子布丁來的～！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……不行？",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_030"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚――！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n今天你都只會一直說不行來的～！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚嗚嗚……！",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_031"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n那宮子要這樣對付你！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "哇！",
        "unit_id": 1,
        "voice": "vo_adv_1007004_032"
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "\n那傢伙怎麼跑去柵欄的外面！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "\n不要想不開啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "不可以自殺──！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "510241"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "下課後――"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁、布丁、布丁、布丁、布丁、布丁、布丁、",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_033"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n布丁、布丁、布丁、布丁、布丁、布丁、布丁、",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n布丁、布丁、布丁、布丁、布丁、布丁、布丁……",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁、布丁、布丁、布丁……",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_034"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……嗯？你要買給宮子嗎？",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "哇～纏著你一整天果然正確來的～！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "而且宮子好像變成你的同學一樣，",
        "unit_id": 100731,
        "voice": "vo_adv_1007004_035"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n超開心來的～",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯哼～學校也滿有趣的～♪",
        "unit_id": 100731
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯……我原本以為在「那邊」的話，",
        "unit_id": 190011,
        "voice": "vo_adv_1007004_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也許多少可以知道一點宮子變成幽靈的理由呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是看來完全不行～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_1007004_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n宮子就算在「那邊」也完全沒變呢～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "宮子在「那邊」也是幽靈，所以似乎也沒辦法上學，",
        "unit_id": 190011,
        "voice": "vo_adv_1007004_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但是多虧了你，讓她順利體驗上學了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
