[
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──喲，",
        "unit_id": 130011,
        "voice": "vo_adv_9068157_000"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "貪吃公主一行人。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "在這種熱死人的地方相遇，還真是巧耶。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "！？",
        "unit_id": 1,
        "voice": "vo_adv_9068157_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是……",
        "unit_id": 105911,
        "voice": "vo_adv_9068157_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【蠻賊三姊妹】長女的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "倭小姐對吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說什麼巧啊，",
        "unit_id": 106011,
        "voice": "vo_adv_9068157_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "少裝傻了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不管怎麼看都是在埋伏吧妳！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "盯上我的皇家裝備，",
        "unit_id": 105811,
        "voice": "vo_adv_9068157_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n甚至追到吉歐‧格黑納是嗎！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不會讓妳稱心如意的……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "真是的。",
        "unit_id": 130011,
        "voice": "vo_adv_9068157_005"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n別那麼激動啦。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "雖然我可沒放棄皇家裝備──",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "但今天來是有別的事情。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "別的事情……？",
        "unit_id": 126013,
        "voice": "vo_adv_9068157_006"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "難道說，",
        "unit_id": 125813,
        "voice": "vo_adv_9068157_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是盯上了璃亞和可可蘿小姐製作的便當……！？",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "不會給妳。",
        "unit_id": 126113,
        "voice": "vo_adv_9068157_008"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n喔。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊？",
        "unit_id": 130011,
        "voice": "vo_adv_9068157_009"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我才不會偷那種東西啦。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我有個擅長做飯的妹妹呢，",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不用愁吃的。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不過，",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "所謂的事情其實跟妹妹們有關──",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──對了。",
        "unit_id": 130011,
        "voice": "vo_adv_9068157_010"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n那邊的騎士小子。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就由你來",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "負一點責任好了。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要主人負責……？",
        "unit_id": 105911,
        "voice": "vo_adv_9068157_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106011,
        "voice": "vo_adv_9068157_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你是幹了什麼事啊……！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "喂喂喂，",
        "unit_id": 130011,
        "voice": "vo_adv_9068157_013"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你別裝傻啊。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你對我",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "可愛的妹妹們出手了對吧？",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "她們還沒嫁人耶。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦咦！？",
        "unit_id": 126013,
        "voice": "vo_adv_9068157_014"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那個，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "雖然是有和她們大打出手沒錯！",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "可是挑起事端的是妳們……",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不是哥哥的錯呀！",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄、",
        "unit_id": 125813,
        "voice": "vo_adv_9068157_015"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人？",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哼。",
        "unit_id": 130011,
        "voice": "vo_adv_9068157_016"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n很簡單──",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我說你。",
        "unit_id": 130011,
        "voice": "vo_adv_9068157_017"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n來當我弟弟吧。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "咦咦咦咦！？",
        "unit_id": 1,
        "voice": "vo_adv_9068157_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不、",
        "unit_id": 105811,
        "voice": "vo_adv_9068157_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不行喔！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然不太懂來龍去脈，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我覺得那會很不妙！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒、",
        "unit_id": 106011,
        "voice": "vo_adv_9068157_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒錯！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳少在那邊說蠢話了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不能讓主人",
        "unit_id": 105911,
        "voice": "vo_adv_9068157_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "淪為盜賊的黨羽……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "怎麼了怎麼了，",
        "unit_id": 130011,
        "voice": "vo_adv_9068157_022"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "幹嘛每個傢伙都一副滿臉通紅的樣子。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n難不成這裡是醉鬼的聚集地喔。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "算了。",
        "unit_id": 130011,
        "voice": "vo_adv_9068157_023"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "有意見的話，",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我就來當你們的對手……！",
        "unit_id": 130011
    }
]