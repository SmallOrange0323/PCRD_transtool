    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這是什麼甜點啊！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "完全就是必須爆紅的最新造型，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "最尖端的流行口味！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "現在的我，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒錯……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是校園金字塔頂端等級的女生！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這種滿滿的幸福感……！",
        "unit_id": 104011,
        "voice": "vo_adv_5213065_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不只上相，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "光是吃下去，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n就像能實現夢想一樣的甜點……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "部長，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這根本是",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "大發明吧！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……啊！",
        "unit_id": 104011,
        "voice": "vo_adv_5213065_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不好意思，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我的社交力失控，講了一堆莫名其妙的話……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "剛剛那只是，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "上相甜點帶來的幻覺，只是場夢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "現實中是邊緣人的我就算裝成陽光角色，",
        "unit_id": 104011,
        "voice": "vo_adv_5213065_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n終究也只是夢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是個很幸福的夢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n只要沉浸其中，就能暫時逃避現實……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "碧的朋友……",
