    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "難得的萬聖節，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也想要四處看看呢！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
