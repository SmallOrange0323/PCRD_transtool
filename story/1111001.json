        "unit_id": 111111,
        "voice": "vo_adv_1111001_061"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還算是適合你喔。",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……只有一點點……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "帥也說不定呢……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "對、",
        "unit_id": 111111,
        "voice": "vo_adv_1111001_062"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "對了！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n衣服也換好了，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n差不多該去鎮上了！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然想要發糖果，",
