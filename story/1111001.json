    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "糖果很抱歉……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "不會，",
        "unit_id": 1,
        "voice": "vo_adv_1111001_037"
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "我也是，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "\n想要搶走糖果",
