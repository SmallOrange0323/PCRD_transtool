        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真期待……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個……",
        "unit_id": 111111,
        "voice": "vo_adv_1111001_058"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "換好衣服了……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n怎麼樣呢……？",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "該不會",
        "unit_id": 111111,
        "voice": "vo_adv_1111001_059"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不適合我吧……？",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n果然還是",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "太孩子氣了吧……",
