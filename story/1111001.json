    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真的嗎？",
        "unit_id": 111111,
        "voice": "vo_adv_1111001_060"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n……太好了～",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
