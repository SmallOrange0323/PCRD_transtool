        "voice": "vo_adv_1111001_049"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "以大人來說理所當然的事情！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n才不是什麼很棒的呢！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……可是，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還是要謝謝你。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "對了，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_050"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}沒事嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為被果汁弄濕了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我也……",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_051"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n不能說是……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒問題呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎麼辦呢……",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_052"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒有帶",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可以替換的衣服呢……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n溼答答的",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "去發糖果也有一點……",
