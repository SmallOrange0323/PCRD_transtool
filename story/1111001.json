        "voice": "vo_adv_1111001_054"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "變裝之後到處走，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不是像小孩子一樣嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是、",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_055"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是這樣嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……聽你這麼一說，",
