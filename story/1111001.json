[
    {
        "type": "background",
        "background": "505034"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "萬聖節時在熱鬧的蘭德索爾散步的{player}，\n在鬧區街道上遇到了\n正抱著行李走著的鏡華。"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嘿咻……",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嘿咻……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "很好。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "拿了很多杯子蛋糕，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這樣就準備萬全了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過啊，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就算說是萬聖節，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "人還真是多呢……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "漂亮的裝飾品，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還有看起來很好吃的糖果。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n變裝的孩子們好像也很開心……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那孩子的衣服",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好可愛啊。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我也有點想穿穿看……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呃，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不行不行！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n今天可不是來玩的呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "今天是",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為了發糖果給大家",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "才來到這裡的，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "得好好像個大人，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "像個姐姐一樣呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀、",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀啊！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呃……",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是{player}啊……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請不要嚇我啦。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯？",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你想要做什麼，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "伸那隻手？　",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "手指還動來動去……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "該、",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "該不會……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是想要惡作劇嗎……？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不行啦！？　",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你想被抓起來嗎！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的。",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "給你糖果就好了吧？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呼……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你真是的……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n明明年紀就比我大……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "有準備糖果所以是沒關係啦。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "現在就拿出來，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "稍微等一下喔。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇哇，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎麼了！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "為什麼啦！",
        "unit_id": 1,
        "voice": "vo_adv_1111001_014"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n這可是我的喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n放開我啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "一個而已沒關係吧！",
        "unit_id": 1,
        "voice": "vo_adv_1111001_015"
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "\n給我啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是怎麼了啊，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那些孩子們。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n是在吵架嗎……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那樣子打鬧的話會很危險的。",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n好像也已經造成周圍的人困擾了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "去阻止他們！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒事的。",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這種程度",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我一個人就可以了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……但是。",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你不用做任何事情，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "只要待在我身邊，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就能讓我放心了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你在說什麼啊，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你也要一起來啊。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "放你一個人的話，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你一定會迷路吧？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你什麼都不用做，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好好跟緊我就好了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "喂――！",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n那邊的兩個人，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "快點住――手！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "幹嘛啦！",
        "unit_id": 1,
        "voice": "vo_adv_1111001_023"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n我現在在跟這傢伙――",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "就是現在！",
        "unit_id": 1,
        "voice": "vo_adv_1111001_024"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "嗚哇、",
        "unit_id": 1,
        "voice": "vo_adv_1111001_025"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "你、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "你在幹嘛啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n……啊！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "果汁！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？　",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀啊！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊……",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好冰……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "喂、",
        "unit_id": 1,
        "voice": "vo_adv_1111001_028"
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "喂！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "這要怎麼辦啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "\n都是你的錯啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "才、",
        "unit_id": 1,
        "voice": "vo_adv_1111001_029"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "才不是！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n是你啦……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "夠了，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不要再吵了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……是為什麼要吵架呢，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "跟姐姐說說看吧？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的。",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n居然為了搶糖果吵架。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……聽好囉，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你們兩個。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n在有很多人的地方吵鬧的話，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n會給大家帶來困擾的。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "難得的萬聖節，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_033"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n可不能浪費在吵架上，要開心點度過呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n……聽懂了嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "男孩子們",
        "words": "好的～……",
        "unit_id": 1,
        "voice": "vo_adv_1111001_034"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "很好，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_035"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼你們兩個",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好好和好吧。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n跟彼此說一聲對不起，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "吵架結束了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "那個……",
        "unit_id": 1,
        "voice": "vo_adv_1111001_036"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n獨佔了",
