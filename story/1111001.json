        "voice": "vo_adv_1111001_038"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "做得很好。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n對可以好好和好的你們……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就特別送給你們這個。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "哇啊，",
        "unit_id": 1,
        "voice": "vo_adv_1111001_039"
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "好厲害！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "\n好像很好吃的杯子蛋糕！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "姐姐，",
        "unit_id": 1,
        "voice": "vo_adv_1111001_040"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "謝謝妳！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n還有",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "把妳的衣服",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "弄髒了很抱歉？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不會。",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_041"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n可以好好說對不起很棒喔。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n姐姐沒事的，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不用在意。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你們兩個，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_042"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n以後不好好注意禮貌可不行喔！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "跟姐姐",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "約好了喔！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "好～的！",
        "unit_id": 1,
        "voice": "vo_adv_1111001_043"
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "\n我們會",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 2",
        "words": "好好守住約定的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "掰掰！",
        "unit_id": 1,
        "voice": "vo_adv_1111001_044"
    },
    {
        "type": "dialogue",
        "name": "男孩 1",
        "words": "\n大姐姐！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……呼。",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_045"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝、",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_046"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝謝你。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "話說回來，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不是『像是』，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我就是姐姐啦！　",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "證據就是，",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_047"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我不是成功地",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n阻止了孩子們吵架嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "等、",
        "unit_id": 103611,
        "voice": "vo_adv_1111001_048"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "等一下。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "住手啦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n不要把我當成小孩子啦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我只是做了",
