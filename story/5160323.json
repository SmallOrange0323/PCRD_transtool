[
    {
        "type": "dialogue",
        "name": "大蛇",
        "words": "嘶啊啊啊啊啊啊！",
        "unit_id": 18911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唔！",
        "unit_id": 133511,
        "voice": "vo_adv_5160323_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這是何等壓迫感……",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這似乎",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是那隻大蛇認真起來的樣子呢。",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是啊，",
        "unit_id": 133211,
        "voice": "vo_adv_5160323_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒想到至今為止的激戰居然只是暖場，",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是驚人啊。",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "哎呀，",
        "unit_id": 133611,
        "voice": "vo_adv_5160323_002"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "但是妳看起來完全不覺得辛苦嘛？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "確實呢。",
        "unit_id": 133211,
        "voice": "vo_adv_5160323_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然是些微的差錯就會喪命的極限戰鬥，",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是以那隻大蛇為對手的話，",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會讓我不可思議地興奮起來。",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳不也是這樣嗎？",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "梅杜莎。",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "嗯。",
        "unit_id": 133611,
        "voice": "vo_adv_5160323_004"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "明明又痛又辛苦，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n但是對手是那孩子的話，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我卻完全不會覺得討厭。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我想要",
        "unit_id": 133611,
        "voice": "vo_adv_5160323_005"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "好好面對那孩子。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n我覺得",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我好像能跟那孩子好好相處呢。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是嗎。",
        "unit_id": 133511,
        "voice": "vo_adv_5160323_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我來幫妳吧，",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "梅杜莎。",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為就算",
        "unit_id": 133211,
        "voice": "vo_adv_5160323_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "想面對對方，",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不先讓牠",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "冷靜下來的話不行啊。",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "咲戀、",
        "unit_id": 133611,
        "voice": "vo_adv_5160323_008"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "莫妮卡……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "謝謝妳們！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "那麼，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我們也要",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "使出全力上了喔！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "咲戀、莫妮卡",
        "words": "「嗯！」\n「好！」",
        "unit_id": 133211,
        "voice": "vo_adv_5160323_009"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "等一下等一下等一下──！",
        "unit_id": 134911,
        "voice": "vo_adv_5160323_010"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n不要無視我啦──！",
        "unit_id": 134911
    }
]