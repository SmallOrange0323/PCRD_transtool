[
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位～",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快點快點！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n終於能看到了，擁有許多傳說的前人未到的祕境！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『雲海山脈』啊……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……哇噗。",
        "unit_id": 105913,
        "voice": "vo_adv_4003001_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，請不要突然停下腳步啦。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "路很窄的。",
        "unit_id": 105913,
        "voice": "vo_adv_4003001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只要稍微失去平衡，就會從山崖上四腳朝天摔下去囉。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇，對不起。",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不小心就亢奮起來了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為想盡快，跟大家一起分享這份喜悅。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不需要道歉的。",
        "unit_id": 105913,
        "voice": "vo_adv_4003001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但這裡離蘭德索爾很遠，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可說是幾乎沒有人煙的地區。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以如果從山崖上摔下去後動不了，",
        "unit_id": 105913,
        "voice": "vo_adv_4003001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或是遇上山難都不會有人來救援。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大喊救命也沒人聽得到，",
        "unit_id": 105913,
        "voice": "vo_adv_4003001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n會在這裡賠上性命。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以無論如何，都希望您能注意這點喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～。",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對不起，一個人直接衝是我的壞習慣。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以說，您不用道歉。",
        "unit_id": 105913,
        "voice": "vo_adv_4003001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐總是這麼活潑，有股發光發熱的推動力……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也很嚮往這一點喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿……♪",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂～。",
        "unit_id": 106012,
        "voice": "vo_adv_4003001_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n打斷妳們的一搭一唱真抱歉，但先等一下。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n吶，休息一下好嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不像妳們這樣頭腦簡單四肢發達啦～",
        "unit_id": 106012,
        "voice": "vo_adv_4003001_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我可是不習慣登山，走到這裡已經很累了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我腳已經抬不動了，想要回家。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉呀……凱留大人和主人，",
        "unit_id": 105913,
        "voice": "vo_adv_4003001_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不知什麼時候已經離得很遠了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請快點過來這邊，這裡的美景可是一絕的呢。",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "400300101"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_4003001_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n坐落在那遠方的，就是『雲海山脈』嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對！　",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是世界的祕境之一，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n阿斯特賴亞大陸上的最高山峰呦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是令人驚訝，這可是直穿雲霄的高度啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，所以才會叫做『雲海山脈』對吧！",
        "unit_id": 105913,
        "voice": "vo_adv_4003001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到了那山頂周圍，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n大概真的會有在雲間漫步的感覺。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是這樣！",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不愧是小可蘿，好聰明喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好孩子～好孩子～♪",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吁吁、",
        "unit_id": 106012,
        "voice": "vo_adv_4003001_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼呼……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總，總算是趕上了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "已經到極限了～。",
        "unit_id": 106012,
        "voice": "vo_adv_4003001_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n爬上那什麼『雲海山脈』之前，就已經叫苦連天囉。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你們真弱呢～小凱留跟你都是！",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣不行喔，要多加鍛鍊才行！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "囉嗦啊～別對魔法師的體力抱有期待啦……",
        "unit_id": 106012,
        "voice": "vo_adv_4003001_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖說貪吃佩可本來就異於常人，所以沒什麼好訝異的，但可蘿能這麼輕鬆才讓人意外呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_4003001_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為在下在故鄉就常常走山路了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼，人不可貌相啊。",
        "unit_id": 106012,
        "voice": "vo_adv_4003001_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……話說回來～雖然到現在才問。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但我們到底為什麼要做這種大冒險似的事呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們【美食殿堂】，是以吃遍天下為目的的公會吧？",
        "unit_id": 106012,
        "voice": "vo_adv_4003001_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘖嘖嘖！",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為什麼要爬山？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為食材就在山裡啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在這裡可以看到的那座『雲海山脈』中，",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像藏有非常稀有的珍貴食材！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以無論如何都要得到，然後再大家一起享用吧！",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n來這一趟，為的就是這個企畫！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿～♪然後就像平常一樣，大家和樂地圍著餐桌吃飯吧！",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好遠～這餐桌好遠～……",
        "unit_id": 106012,
        "voice": "vo_adv_4003001_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明就不用特別去找什麼珍貴食材，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n吃訂好之後五分鐘就可以上桌的速食就夠了啦～……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。祕境之中應該還有很多寶藏，",
        "unit_id": 105913,
        "voice": "vo_adv_4003001_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果用寶藏當目標就能繼續加油了吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下記得凱留小姐，好像很喜歡會發光的東西對吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚～……",
        "unit_id": 106012,
        "voice": "vo_adv_4003001_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但是，『雲海山脈』不是前人未到的祕境嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n怎麼能肯定有珍貴食材跟寶藏呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我超討厭的呦，拼了命爬上山後卻發現白忙一場的這種結局！",
        "unit_id": 106012,
        "voice": "vo_adv_4003001_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不要嘮嘮叨叨了，",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留也來把食欲什麼的當作動力，全力爬上山吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大步地爬上去囉～加油加油加油♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太有精神了……完全搞不懂……",
        "unit_id": 106012,
        "voice": "vo_adv_4003001_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼要為了吃東西這麼拼命呢……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說呢。體力已經快到底了，",
        "unit_id": 106012,
        "voice": "vo_adv_4003001_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n用魔法飛上天直接把『雲海山脈』巡過一圈不行嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果只是找個食材，不是一定要爬到山頂吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，這一招我就不建議了。",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然不知道為什麼……祕境大多都有魔物，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n或是『闇影』的目擊情報。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該是因為沒有人能接近，",
        "unit_id": 105812,
        "voice": "vo_adv_4003001_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n魔物們也不會被驅逐，因此擴展了勢力吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
