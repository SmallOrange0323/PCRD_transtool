        "voice": "vo_adv_1058004_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『真難得會在中午遇到你，",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n待會是要去吃午餐嗎？』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我的肚子也餓得咕嚕咕嚕叫",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n方便的話，一起去用餐吧』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『嘻嘻，",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我又發現了一間好吃的店喔～！』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『那間店算是我現在打工的餐廳",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n的對手店吧？』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『店長要我去那裡偵察敵情，",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒想到我一去就被他們的美食俘虜了呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『現在每天都要\n來這間店報到呢～♪』",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『啊這樣不行，",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這是背叛我打工地方的行為！』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『可是啊，",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n他們的東西實在太好吃了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "特別是那散壽司，堪稱一絕……☆』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『…………』",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『……難道。",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你跟其他人一樣。』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『你也",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n忘記我了嗎？』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『嗯嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你好像還記得我吧？』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『那為什麼要無視我……？",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我說話還蠻大聲的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我不認為你會沒聽到？』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『咦，你聽不懂我在說什麼？",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你問我是說哪國的語言？』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『啊～……",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱歉！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這種事偶爾也會發生呢！』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我明明就普通地說話，",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但不知道為什麼，就是沒辦法溝通！』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『在遇到你們之前，",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也沒跟其他人說過什麼話，所以忘記了』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『過了一段時間後，",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n又很自然地能溝通了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使這麼說，你也沒有頭緒吧，嗯？』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『啊？",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像有什麼在發光？』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『這這這、這是怎麼回事？",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道這也是因為我的關係嗎……？』",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你好。",
        "unit_id": 1,
        "voice": "vo_adv_1058004_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不好意思……",
        "unit_id": 1,
        "voice": "vo_adv_1058004_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n可以借我一下mimi嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊……",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\nNO，不是耳朵。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是mimi，OK～？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "YES，是攜帶型終端！",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝！",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以使用一下mimi嗎？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拜託你。",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我現在很困擾。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～？",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你說的是英文吧……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱歉，你的發音我聽不懂。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的母語不是英文。",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我英文不是很拿手，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱歉。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊……",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以使用mimi的翻譯功能嗎？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想要用它來翻譯，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以嗎？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『……嗯，好。",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n非常謝謝你～",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這世上還是有好人的呢♪』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『你能借我mimi，真是幫了大忙。",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的mimi突然一點反應也沒有，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n讓我很困擾呢。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『是的。",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我正在用mimi的翻譯功能跟你說話……』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我也正在學習日文喔～",
