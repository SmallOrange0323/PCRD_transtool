        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在她身上似乎出現了各種負面狀態。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她無緣無故就會肚子餓，",
        "unit_id": 190011,
        "voice": "vo_adv_1058004_080"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也許就是問題的關鍵吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我會盡我所能，",
        "unit_id": 190011,
        "voice": "vo_adv_1058004_081"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n修正她翻譯功能的錯誤……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她很快就能再度正常地說話了哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是。",
        "unit_id": 190011,
        "voice": "vo_adv_1058004_082"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為我要集中精神在那邊的操作，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以你的夢境就在這裡結束了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想總有一天，\n你還會看見類似的夢境……",
        "unit_id": 190011,
        "voice": "vo_adv_1058004_083"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到了那時候，我再好好地為你說明。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嗯，",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_084"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺喉嚨好像沙沙的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～啊～……",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_085"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n嗯～我感冒了嗎。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊。",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_086"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你醒了啊？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們剛剛是不是站著就睡著了？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉唷？",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_087"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n語言能通了？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太好了～",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_088"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不能溝通很寂寞呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是到底發生了什麼事……",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_089"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你突然睡著這件事也讓我很在意，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最近各地發生了太多奇妙的事情呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果能一個個解決的話就還好。",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_090"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要創造一個人民能安居樂業的國家……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯。",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_091"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n比起這件事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在更重要的是補充營養。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……\n",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_092"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "方便的話，你要不要跟我一起吃中餐？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然我剛剛也問過你，",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_093"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不過你好像聽不懂……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我才再一次邀請你♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "OK嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_094"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔耶，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你真好相處♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼我們馬上出發吧，",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_095"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那間店很有名，所以很快就會大排長龍喔～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我希望盡可能不用排隊，",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_096"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就能填飽肚子！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼我們出發吧，嘻嘻♪",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_097"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天也讓我們友好地圍著餐桌用餐吧～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我其實……",
        "unit_id": 105812,
        "voice": "vo_adv_1058004_098"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要能撐飽肚子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大部分的事情都覺得無所謂呢♪",
        "unit_id": 105812
    }
]