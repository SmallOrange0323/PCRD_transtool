        "voice": "vo_adv_1058004_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "日文的文法跟我的母語差異很大，學習上很困難♪』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『啊哈哈。",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我的國家在數位機械的發展上，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "跟日本比起來還落後很多。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『mimi也常常故障呢～",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真令人困擾。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『話雖如此。",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n父親大人跟我說，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要盡量使用國產的產品～』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『說真的……",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我在日本停留的期間，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也想使用這個國家最先進的數位機器。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『是我硬要跟著你的，",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以我也不能過分要求。』",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『……啊",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱歉，都是我在說話。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我有點厚臉皮呢～",
        "unit_id": 105831,
        "voice": "vo_adv_1058004_040"
    },
    {
        "type": "dialogue",
