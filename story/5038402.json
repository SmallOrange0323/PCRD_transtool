[
    {
        "type": "background",
        "background": "500751"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗚哇啊啊啊啊啊！　",
        "unit_id": 111011,
        "voice": "vo_adv_5038402_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "致命一擊～～～！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n喝呀～～～～！　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呼喵～～～～～～～！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "停！　",
        "unit_id": 110911,
        "voice": "vo_adv_5038402_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "停！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不要再發狂了！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不要再鞭屍了！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "應該說，學姐其實早就恢復清醒了吧。",
        "unit_id": 110811,
        "voice": "vo_adv_5038402_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "請妳不要從旁突然冒出來截胡，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "攻擊我們辛苦阻止它運作的機體，\n還裝出一副是自己給它致命一擊的模樣。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哇哈哈～！　",
        "unit_id": 111011,
        "voice": "vo_adv_5038402_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好朋友X，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "討伐成功～！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "討伐它的明明是站在前線的我們。",
        "unit_id": 110911,
        "voice": "vo_adv_5038402_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "優妮學姐根本只有在後面裝腔作勢而已啊。",
        "unit_id": 110811,
        "voice": "vo_adv_5038402_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我這叫做人盡其才好嗎。",
        "unit_id": 111011,
        "voice": "vo_adv_5038402_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "身為軍師的我",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "站到前線能有什麼幫助呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話是這麼說沒錯，",
        "unit_id": 110811,
        "voice": "vo_adv_5038402_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但這不就是優妮學姐妳最討厭的大道理嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳這傢伙想必是理科的吧？",
        "unit_id": 110911,
        "voice": "vo_adv_5038402_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "別把我跟那些臭石頭混為一談。",
        "unit_id": 111011,
        "voice": "vo_adv_5038402_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n文科的人會依照情況和場合適時地說大道理，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "正是文科的人才會運用這種小聰明。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐妳這樣會被罵喔。",
        "unit_id": 110911,
        "voice": "vo_adv_5038402_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n會被文科和理科",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雙方的人們罵。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "咦？",
        "unit_id": 111011,
        "voice": "vo_adv_5038402_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n等等，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "前方的那個華麗的人影……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不就是秋乃她們嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911,
        "voice": "vo_adv_5038402_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的耶，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是小墨丘利們！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀哎呀～",
        "unit_id": 111011,
        "voice": "vo_adv_5038402_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "幸好。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n正因為我是文科才會注意到她們，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n要是理科的話",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "肯定會忽略沒有注意到。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳真的會被罵喔？",
        "unit_id": 110911,
        "voice": "vo_adv_5038402_014"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊～",
        "unit_id": 110811,
        "voice": "vo_adv_5038402_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那就～嗯～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然有點遲了，不過趕快去跟她們會合吧～",
        "unit_id": 110811
    }
]