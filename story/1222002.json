    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天工作結束後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n優花梨為了採購週末單日露營要帶去的食材，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n帶著{player}一起來到高級食品店。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦……",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這家店……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "橄欖油居然會這麼貴……？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "看來",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真的都只有擺高品質的商品呢……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唔嗯……",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我可不能在這裡退縮了。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我這個週末",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "絕對要讓他對我刮目相看……！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呀啊！？",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……謝、",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n……這樣辛香料就都拿齊了吧。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我說，",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "下次露營的食材",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我想弄得豪華點。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……那個，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也順便為之前的事向你道歉。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你想想……",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我明明自己說會克制的，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n結果又喝到爛醉了不是嗎……？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我想為此賠罪，",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還有再次感謝你週末總是抽空陪我，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這週絕對",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "要成功！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我要招待你品嚐最棒的露營餐！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "料理的話，你也能開心享用，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我這次沒打算喝麥酒和能讓心情舒暢的果汁喔！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好不好？",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "至少讓我做這點補償吧？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這可是攸關我身為大人的尊嚴！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "再來就是食材呢。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n有部分能在山裡採集，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "海鮮必須在這裡買齊……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "蝦子……",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "烏賊……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也買些鮮味十足的貝類好了。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……呵呵，",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "很在意嗎？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可惜，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "現在先保密。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "等完成之後你就知道了！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那麼……",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "食材就大概先這樣吧。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n要是帶太多，到時候也會剩下來。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "平時的？",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你是說乾貨零嘴？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……我、",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我真的有像你說的那樣平時都會吃嗎……？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，嗯，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我會吃呢……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這、",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這提議很有魅力……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "老實說，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我也想順便先買好下酒零嘴，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這次我已經決定要招待他品嚐",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "最棒的露營餐了。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n現在要忍耐！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對不起喔，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "乾貨零嘴們……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這、",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這個嘛……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "乾貨零嘴是也不錯，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但這次還是以",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "招待你品嚐感謝的露營餐為主！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以，",
        "unit_id": 103412,
        "voice": "vo_adv_1222002_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "敬請期待♪",
        "unit_id": 103412
    },
    {
        "type": "background",
        "background": "501590"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "該週末──"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……好，",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這樣食材的事前處理就完美了。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我菜刀也用得很熟練了呢。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "鐵板也差不多熱起來了吧？",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_018"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯～",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "火力好像不太夠……？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "畢竟是用來處理海鮮，",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "火稍微大一點應該比較好吧……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呃，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不是用柴火，而是用乾草調整火力，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "感覺不錯♪",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哎呀，",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "歡迎回來。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那麼，食材也都準備齊全了，",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_021"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "接下來才是重頭戲！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n只有這裡才能品嚐到，而且分量十足的露營餐！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我要盡情展現我的廚藝開始做料理囉～！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不行不行。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這個也算是我要補償你的。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你隨便",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "找地方休息等我吧。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦？",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你想看我下廚的樣子？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "只、",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "只是這樣的話是無所謂……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唔唔……",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "他靠這麼近看，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n會不會被他發現我是每天工作結束後",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "拼命練習的……？　",
