    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可以再幫我添",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "「最棒的那一杯」嗎？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n要把這個酒杯",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "倒滿幸福喔？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優花梨在{player}協助下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n沒有醉倒並好好享受了單日露營。"
    },
