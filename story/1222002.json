    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "然後最棒的是",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_053"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這道起士火鍋……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你沾著各種食材吃吃看，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可以嚐到各個不同的滋味♪",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵，",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_054"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你能喜歡就太好了。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這樣我努力挑選食材也是值得了。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還有……",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_055"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這些料理和麥酒能夠這麼美味，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我覺得都是託你的福。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你想想……",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_056"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "像是前陣子做新鮮果汁時，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我嘴上說是",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "為了你……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但我發現那只是在單方面強迫你，",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_057"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n接受我認為開心的露營……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是你",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_058"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "將這杯麥酒……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不對，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是這最棒的那一杯遞給我時，讓我注意到了。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "考量到彼此的樂趣",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_059"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "並一起分享，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n才會成為特別的露營。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咕嘟……♪",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_060"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你看，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "正好就像這杯麥酒和露營餐一樣♪",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好了，",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_061"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "多吃點多吃點！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n今天我可是特別下工夫煮出來的！",
        "unit_id": 122211
    },
    {
        "type": "still",
        "still": "122200202"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……欸！？",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_062"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "每、",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "每天！？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你說每天是那個……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "通通、",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "通勤妻的意思……？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "才才才、",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_063"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "才怪呢！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那怎麼可能嘛！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n沒什麼、",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒什麼！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "忘掉我剛才說的！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你只是在比喻料理有這麼好吃對吧？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我、",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我知道的啦……！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "話、",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_064"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "話說，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你居然會說每天……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "再怎麼說也讚美過頭了啦！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n如果每天吃這麼大量的食物，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可是會胖的喔。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n真是的……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊哈、",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊哈哈哈……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……唔唔，",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_065"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "都怪你突然那種耐人尋味的話，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n害我整個人都嚇到酒醒了……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "讓我再喝一杯重新回到微醺好了……",
        "unit_id": 122211,
        "voice": "vo_adv_1222002_066"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這可是你的錯喔……？",
        "unit_id": 122211
    },
