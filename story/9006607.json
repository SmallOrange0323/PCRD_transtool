[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "去死吧──！",
        "unit_id": 106011,
        "voice": "vo_adv_9006607_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n格林炸……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "！！？",
        "unit_id": 1,
        "voice": "vo_adv_9006607_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "突、",
        "unit_id": 105811,
        "voice": "vo_adv_9006607_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "突然就被傳回進到巢穴最深處之前的位置了……！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是阿剌克涅在退離的同時……",
        "unit_id": 105911,
        "voice": "vo_adv_9006607_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對我們施加了",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "空間跳躍的陷阱吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "「與其說是陷阱，",
        "unit_id": 106715,
        "voice": "vo_adv_9006607_004"
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "似乎只是移動用的魔法陣呢～",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "\n",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "因為注意力都在具有攻擊性的陷阱上，",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "就看漏了，",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "抱歉～」",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那隻臭蜘蛛！",
        "unit_id": 106011,
        "voice": "vo_adv_9006607_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n事到如今",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還想要爭取時間嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "「呵哈哈哈。",
        "unit_id": 136013,
        "voice": "vo_adv_9006607_006"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n畢竟你們的攻擊",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "實在太過無趣了──",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n若是這樣，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "吾還不如來睡個午覺。」",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說什麼……！？",
        "unit_id": 106011,
        "voice": "vo_adv_9006607_007"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "「吾不是說過了嗎？",
        "unit_id": 136013,
        "voice": "vo_adv_9006607_008"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "吾正在消化。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n而你們，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "就連擔任吾的對手都不配。」",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！",
        "unit_id": 105911,
        "voice": "vo_adv_9006607_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們對阿剌克涅造成的傷",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎正在恢復……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊可惡！",
        "unit_id": 106011,
        "voice": "vo_adv_9006607_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管多少次，我都會轟飛妳的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯！",
        "unit_id": 105811,
        "voice": "vo_adv_9006607_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且──",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不管被傳送回來多少次，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們都一定會把阿剌克涅女士逼至絕境！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "「呵哈哈哈，",
        "unit_id": 136013,
        "voice": "vo_adv_9006607_012"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n就好好玩玩吧──",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "在吾消化完畢，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n將從鳳凰那裡奪取的全部權能",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "納為己有之前……！」",
        "unit_id": 136013
    }
]