        "words": "有股異樣的敵意。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不是魚那麼可愛的生物哩。",
        "unit_id": 106011,
        "voice": "vo_adv_9004135_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那傢伙是海龍。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一般來說牠不會離開海底才對……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們可要提高警覺啊！",
        "unit_id": 106011,
        "voice": "vo_adv_9004135_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n被這傢伙所吐出的寒氣擊中的話，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會變成硬梆梆的冰塊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是變成那樣，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可救不了妳們喔！",
        "unit_id": 106011
    },
    {
