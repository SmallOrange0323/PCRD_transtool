        "voice": "vo_adv_5015002_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "連外皮都好好吃……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來這就是鯛魚燒啊！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "世界上竟然有如此美味的食物……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我要向製作出這麼棒食物的",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "東國",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "敬禮！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊、",
        "unit_id": 105511,
        "voice": "vo_adv_5015002_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "大江戶町的鯛魚燒也",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "很美味！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n感覺得到",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "甜味的深奧呢。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……等一下，",
        "unit_id": 105311,
        "voice": "vo_adv_5015002_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "步未。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n「大江戶町的鯛魚燒也很美味」",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳剛剛是這樣說的吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "難道說鯛魚燒",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在蘭德索爾也吃得到嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊，",
        "unit_id": 105511,
        "voice": "vo_adv_5015002_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "莫妮卡不知道啊。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n蘭德索爾的廣場上",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有鯛魚燒的攤販，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那裡的鯛魚燒",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也很美味喔。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "…………必須",
        "unit_id": 105311,
        "voice": "vo_adv_5015002_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "每週去買10次才行。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "妳、",
        "unit_id": 105511,
        "voice": "vo_adv_5015002_005"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "妳一天打算去幾次啊！？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我回來了。",
        "unit_id": 109611,
        "voice": "vo_adv_5015002_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呼，",
        "unit_id": 100811,
        "voice": "vo_adv_5015002_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "總算和大家會合了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗚嗚……",
        "unit_id": 109511,
        "voice": "vo_adv_5015002_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這個和服，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n雖然很美麗，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可是有點難行動……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳們剛才",
        "unit_id": 105311,
        "voice": "vo_adv_5015002_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "去哪裡了……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n看到雪那一大袋東西我就懂了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "從綁頭髮的飾品，",
        "unit_id": 100811,
        "voice": "vo_adv_5015002_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n到梳子之類的小東西，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所有的隨身用品都換成美麗的東西……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這些是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了讓我的美更上一層樓的",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "必要經費♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哎呀，",
        "unit_id": 100811,
        "voice": "vo_adv_5015002_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過還真的是買太多了呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以說……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "拿著♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雪、",
        "unit_id": 105511,
        "voice": "vo_adv_5015002_012"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雪！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n妳竟然讓前輩拿行李……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "他本來",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就已經拿著大家的行李了耶！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼，",
        "unit_id": 100811,
        "voice": "vo_adv_5015002_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你幫我拿行李，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我就讓你",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "盯著看10秒吧♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你很懂嘛♪",
        "unit_id": 100811,
        "voice": "vo_adv_5015002_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "把美麗的我",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "深深印在你的腦海吧！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那樣盯著看沒關係嗎？",
        "unit_id": 100811,
        "voice": "vo_adv_5015002_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我那耀眼的美貌，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n說不定會讓你頭暈眼花喔♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "空花和妮諾",
        "unit_id": 105311,
        "voice": "vo_adv_5015002_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n好像沒有買很多東西呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空、",
        "unit_id": 109511,
        "voice": "vo_adv_5015002_017"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花感興趣的……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那個、",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不是大馬路上賣的東西……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可是妮諾不在的話，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "會變得更多呢。",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦，",
        "unit_id": 105511,
        "voice": "vo_adv_5015002_018"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是指什麼啊？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那個……",
        "unit_id": 109511,
        "voice": "vo_adv_5015002_019"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "走在鎮上時，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n會有各種商人來推銷商品……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "食物或小東西，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "甚至還有人來推銷武器。",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "連武器都有？",
        "unit_id": 105311,
        "voice": "vo_adv_5015002_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n暫且不論是激戰區或是冒險者多的城市，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但我可沒聽說過連武器相關的店",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都會出來攬客啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "如果不是妮諾",
        "unit_id": 109511,
        "voice": "vo_adv_5015002_021"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "當時詳細說明了商品，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "告訴空花那個用不上，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是不必要的東西的話，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我應該會因為稀奇，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就聽從推銷買下來了……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妮諾做得好。",
        "unit_id": 105311,
        "voice": "vo_adv_5015002_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妮諾保護了空花，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "躲過了惡劣的強行推銷。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n作為獎勵，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就送妳我剛買的",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這個鯛魚燒吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "莫妮卡，",
        "unit_id": 109611,
        "voice": "vo_adv_5015002_023"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n謝謝妳……",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳從剛才就沒什麼精神，",
        "unit_id": 105311,
        "voice": "vo_adv_5015002_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是怎麼了嗎？妮諾……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n難道說，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳不愛紅豆餡",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而是愛卡士達奶油嗎！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n卡士達奶油的確也很美味，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過我",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "覺得紅豆餡最好吃喔！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "到、",
        "unit_id": 105511,
        "voice": "vo_adv_5015002_025"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "到底是有多喜歡啊……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我",
        "unit_id": 109611,
        "voice": "vo_adv_5015002_026"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖然也喜歡紅豆餡，",
        "unit_id": 109611
    },
