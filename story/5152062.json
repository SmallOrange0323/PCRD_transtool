        "voice": "vo_adv_5134062_000"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "願い事、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ですかー……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "も",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ちろん、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "あたしは",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "初心に帰り",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ビッグボスの座をお願いするですよ。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "賢いギャングは、ころころ目標を変えたりしねーですからね。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "あのクソボスババアに下剋上を果たして、",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_001"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ビッグなイノリさまが",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ファミリー全員を取り仕切る……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "来年の初日の出は、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "【ドラゴンズネスト】の夜明けになるですよ！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "というわけで、",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_002"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "さっさと寝ることにするです……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "くか～……",
        "unit_id": 128311
    },
    {
        "type": "still",
        "still": "513406201"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "はーっはっはっは！",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_003"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nついに……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "このイノリさまが",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n名実ともにギルドマスターの地位を……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ファミリーのボスの座を",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_004"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "手に入れたですよ～！！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "……にしても、",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_005"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "出迎えがないですね？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ビッグボスイノリさまが顔を出したっていうのに。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "どいつもこいつも挨拶なしとは",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_006"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "礼儀がなってねーです！",
        "unit_id": 128311
    },
    {
        "type": "still",
        "still": "513406202"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "あら～、",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_007"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "遅れてごめんなさい、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "ボス。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\nちょっと急患の対応で立て込んでて……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "やっと来たですね……",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_008"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "うん？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nなんで闇医者が挨拶に来るんです？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nいつから【ドラゴンズネスト】のメンバーになったですか？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "クスクスクス……",
        "unit_id": 102711,
        "voice": "vo_adv_5134062_009"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "なにをおっしゃっているんです？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "イノリさんは今日から",
        "unit_id": 102711,
        "voice": "vo_adv_5134062_010"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n【トワイライトキャラバン】のボスになったんですよ……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "クスクスクス♪",
        "unit_id": 102711
    },
    {
        "type": "still",
        "still": "513406203"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "は？　",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_011"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "はああああああ！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nどんなミラクルが起きたらそうなるですか！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "全然理解が追い付かねーですよ！！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "あなたがどう思おうが、",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_012"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "これが現実よ。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "ところでボス……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "新しい薬草を試したいんだけど、",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_013"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n知り合いに",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "科学の礎になってもよさそうな人は",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "いないかしら？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "それと、",
        "unit_id": 102711,
        "voice": "vo_adv_5134062_014"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "賞金のかかっていた魔物を討伐したんですが、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "持ち帰ってきた首を置いておく場所がなくて……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "ギルドハウスの",
        "unit_id": 102711,
        "voice": "vo_adv_5134062_015"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n倉庫をお借りしても……？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ぴいっ！？",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_016"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n新鮮なまま持ち帰ってくるんじゃねーですよ！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "あと",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_017"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "マッドサイエンティストの",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n生贄にしてもいい知り合いもいねーです！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "他にまともなヤツはいねーんですか！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "あっ。",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_018"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\nナナカちゃんとアンナちゃんは金欠らしくって。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "次に賞金が入ったら返済するから、",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_019"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\nギルドのお金を借りられないか",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "ってあなたを捜してたわよ？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "残りももれなく、",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_020"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ろくでもねーヤツじゃねーですか！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n金にだらしねーのは感心しねえですよ、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "まったく……",
        "unit_id": 128311
    },
    {
        "type": "still",
        "still": "513406204"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "こんな連中、",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_021"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "元々のギルドマスターは",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nどうまとめてたですか？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "泣こうが喚こうが、",
        "unit_id": 102711,
        "voice": "vo_adv_5134062_022"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "今はあなたがギルドマスター",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "もしも値しないと分かったら……",
        "unit_id": 102711,
        "voice": "vo_adv_5134062_023"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "私の手で退場していただきます。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "……クスクス♪",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "もし不安なら、",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_024"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "まずはお互いを",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n理解するところから始めてもいいわよ？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "さぁ、",
        "unit_id": 105111,
        "voice": "vo_adv_5134062_025"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "イノリちゃんの体を",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "私に診せてくれる？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "ドラゴン族の体の仕組み、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "興味があったのよ～♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ぴい～っ！？　",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_026"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "も、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "もうやってられねーです！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "こんなん付き合ってたら",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "バラされるか",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n責任とらされて",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "牢屋いき確実です！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ボスじゃなくていいから",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_027"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n【ドラゴンズネスト】にあたしを戻すですよ～！",
        "unit_id": 128311
    },
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ぴ",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_028"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ゃあっ！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "新年早々、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ろくでもねー悪夢だったです……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "大晦日にあいつらと絡んだせいに違いねーですよ、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "まったく！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "こんなのが初夢なんて認めたくないですし、",
        "unit_id": 128311,
        "voice": "vo_adv_5134062_029"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n二度寝して上書きしてやるですよ……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ふぁぁ～……",
        "unit_id": 128311
    }
]