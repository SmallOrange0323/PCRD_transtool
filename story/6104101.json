    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "與獸人族的和平活動……",
        "unit_id": 100512,
        "voice": "vo_adv_6104101_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這是純相信我而託付給我的任務！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我絕對會把它完成的！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔……",
        "unit_id": 100512,
        "voice": "vo_adv_6104101_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那正是不安的來源。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "竟然跟距離和平最遙遠的人湊到了一起……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "老實說我非常不安，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但也只能好好努力了！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒錯！",
        "unit_id": 100512,
        "voice": "vo_adv_6104101_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不只是純而已，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n小智姐",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還有其他團員們也都相信著我。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我可不能逃跑！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一定要達成任務！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然每個種族都的確有各自的特色，",
        "unit_id": 100512,
        "voice": "vo_adv_6104101_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但大家都是好人喔。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "像附近的餐廳還有蔬果店的人，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "都常常會給我優惠！",
        "unit_id": 100512
    }
