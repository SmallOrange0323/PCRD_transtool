    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "摩拉牠",
        "unit_id": 114311,
        "voice": "vo_adv_6052203_000"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "是為了拯救這座城鎮",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "才從魔法國度來的吧？",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "明明身型那麼嬌小，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "想想還真厲害耶……",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "嗯，",
        "unit_id": 114311,
        "voice": "vo_adv_6052203_001"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "像牠圓圓的大眼睛、",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n靜不下來的小動作，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "怎麼看都看不膩。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "魔法少女吉祥物果然就是要這樣才行。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "唔……",
        "unit_id": 114311,
        "voice": "vo_adv_6052203_002"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "果然是這樣嗎……",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "不是，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "因為我沒摸過……",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "你想嘛，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "跟牠說「讓我摸」",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "感覺有點不好意思。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "咦？",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "你要幫我去說嗎？",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "那……",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "就拜託你囉。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "嗯，",
        "unit_id": 114311,
        "voice": "vo_adv_6052203_003"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "畢竟牠是自己來的，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "搞不好牠其實是魔法國度裡的菁英分子呢。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n感覺摩拉身上還充滿著許多的謎團啊。",
        "unit_id": 114311
    }
]