    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n為了讓妾身征服世界！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n哈～哈哈哈哈！",
        "unit_id": 104412
