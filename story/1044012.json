    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n都先等",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "完全恢復原本的模樣後",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "再說！　",
