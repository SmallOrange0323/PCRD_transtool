        "voice": "vo_adv_1044012_097"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都是身為主人的妾身的所有物。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n今後",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也好好侍奉妾身吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那個……",
        "unit_id": 104412,
        "voice": "vo_adv_1044012_098"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你不願意",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔！",
        "unit_id": 104412,
        "voice": "vo_adv_1044012_099"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "樣啊這樣啊！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那是當然的吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真不愧是妾身啊！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你今後也",
        "unit_id": 104412,
        "voice": "vo_adv_1044012_100"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要好好努力喔。",
