        "name": "伊莉亞",
        "words": "妾身，",
        "unit_id": 104412,
        "voice": "vo_adv_1044012_093"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對你……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呃！",
        "unit_id": 104412,
        "voice": "vo_adv_1044012_094"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還不行！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不能用這副嬌小的模樣告白！　",
