        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還需要問嗎？",
        "unit_id": 104411,
        "voice": "vo_adv_1044012_076"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你們就親身領會",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "傷害妾身寵愛之人的懲罰吧。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "獵人1",
        "words": "沒用的……",
        "unit_id": 1011,
        "voice": "vo_adv_1044012_077"
    },
    {
        "type": "dialogue",
        "name": "獵人1",
        "words": "就算妳那樣做，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "獵人1",
        "words": "也會有第二、第三組吸血鬼獵人……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵……",
        "unit_id": 104411,
        "voice": "vo_adv_1044012_078"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只要沒有任何目擊者，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那也就不可能了吧。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你以為妾身會放過在場的人，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "做出這種溫吞濫情的決策嗎？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你們就放心把身心都交給恐懼吧……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "獵人2",
        "words": "可惡，",
        "unit_id": 3311,
        "voice": "vo_adv_1044012_079"
    },
    {
        "type": "dialogue",
        "name": "獵人2",
        "words": "我們怎麼可能……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "獵人2",
        "words": "會在這種地方完蛋……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦？",
        "unit_id": 104411,
        "voice": "vo_adv_1044012_080"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你要抵抗妾身的魅惑魔力嗎？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還真了不起啊。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼，",
        "unit_id": 104411,
        "voice": "vo_adv_1044012_081"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "把身為統御黑夜之人的妾身……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n把傳說吸血鬼的恐怖……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n深深刻劃在你們的靈魂深處吧！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈哈哈哈哈！",
        "unit_id": 104411,
        "voice": "vo_adv_1044012_082"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈──哈哈哈哈哈──！",
        "unit_id": 104411
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你醒來了嗎？",
        "unit_id": 104412,
        "voice": "vo_adv_1044012_083"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是妾身的城堡。",
        "unit_id": 104412,
        "voice": "vo_adv_1044012_084"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "平時的那座呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "等等、等等，",
        "unit_id": 104412,
        "voice": "vo_adv_1044012_085"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別那麼急著起身。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你就暫時",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "躺在妾身的腿上休息吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要從哪說起才好呢……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然接受你的力量，",
        "unit_id": 104412,
        "voice": "vo_adv_1044012_086"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "將妾身提升到極限的魔力",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "全力釋放出來是不錯……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但就連那座城堡",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都倒塌了啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那群吸血鬼獵人嗎？",
        "unit_id": 104412,
        "voice": "vo_adv_1044012_087"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在懲罰他們時，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身順便把他們這幾天的記憶消除了。",
