    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n並開創未來……",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "閣下，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
