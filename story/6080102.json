    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "遊んでたら、",
        "unit_id": 113111,
        "voice": "vo_adv_6044102_000"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "喉が乾いてきちまったねぇ……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "ちょっくら",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "買い物にでも行ってこようかね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "お前さん、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "何か飲みたい物があれば",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "ついでに買ってくるよ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "ま、",
        "unit_id": 113111,
        "voice": "vo_adv_6044102_001"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "観光に来たら頼む王道だね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "フルーツの量がとんでもなく多かったと思うけど……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "お前さんだけじゃ無理そうなら、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "アタシも飲むのを手伝ってあげるよ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "ああ、",
        "unit_id": 113111,
        "voice": "vo_adv_6044102_002"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "いいねぇ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "大人になるとこういう飲み物って",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\nあんまり飲まなくなるけど、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "ふと飲みたくなるんだよ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "なんていうか、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "夏の風物詩っていう感じがするよね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "いや、",
        "unit_id": 113111,
        "voice": "vo_adv_6044102_003"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "それ飲んじゃダメなやつじゃないか！？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n麦茶とうっかり間違えて飲んで苦しむやつだろう！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "……まさかお前さん、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "飲み物と勘違いしてるんじゃないだろうね？",
        "unit_id": 113111
    }
]