        "voice": "vo_adv_1058006_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你好嗎！",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "特地把你叫出來，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n抱歉喔～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻，今天天氣真好呢！",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為天氣有點熱，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n冰淇淋吃起來超好吃喔☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你看！",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論哪種口味都讓我難以取捨，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以我要把它們全都放上甜筒！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我稱霸全口味了喔～！",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冰淇淋的顏色五花八門的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n非常好看呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好像有點太過貪心，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n堆疊的冰淇淋已經超過了我的身高！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，我看不到前面了！",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是{player}吧，\n請回答我！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你好～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你最近都簡稱我為『佩可』呢，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺好像更親暱了，我很開心喔～",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也可以\n省略{player}的名字嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒問題啦～我的腸胃",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可是鍛練過的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使世界毀滅了，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也不會吃壞腸胃……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冰淇淋要是吃太多，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n身體確實會冷下來呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是從中攝取的卡路里會瞬間在體內燃燒，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "完美地將體溫維持住～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉唷唷……",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你等一下啦，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n跟你說話害我分心，冰淇淋塔快要倒了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冰淇淋",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要是掉到地上就悲劇了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我現在就把它吃掉，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚼嚼嚼♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼哈，好吃～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀！？",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都是因為突然吃冰的東西，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n冰上了頭頂！ 頭好痛啊！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，但是我很滿足……",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "發明冰淇淋的人簡直是天才，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n人類的救世主呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉唷，嘴巴沾到了～",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我用手帕擦擦喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻，我真不像話呢……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉唷，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可不是專程來吃冰淇淋的喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天是為了之前商量好的事情，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要到政府機關提出創辦公會的申請書！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}要跟我一起想公會名稱，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還要幫我很多忙喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "跟他人一起做些什麼事～",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我覺得非常快樂呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正因為如此。",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我才有想要",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n創辦公會的念頭。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我一直四處旅行，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n過著流浪的生活。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我果然還是想要有個『歸宿』。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然創辦公會所需的資金，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n會用盡我所存的旅費……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但工作再賺就好了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總之……",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該沒什麼問題的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是我如果被政府機關的人看見，可能會引起騷動的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我希望{player}",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n能幫我提交文件就可以。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為{player}說自己喪失記憶，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以我想困難的事情你大概做不來。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因此你只要把文件交給辦事窗口的人就好了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也會跟你一起進去政府機關，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過我會一邊遮住臉，在遠處待命。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果你遇到困難，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要跟我打個信號喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "作戰內容大致是這樣，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "OK嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n作戰開始吧～♪",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "公務人員",
        "words": "是的。",
        "unit_id": 411,
        "voice": "vo_adv_1058006_034"
    },
    {
        "type": "dialogue",
        "name": "公務人員",
        "words": "\n您的文件，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "公務人員",
        "words": "\n我們確實受理了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "公務人員",
        "words": "我們這邊會謹慎地審查您的文件內容，",
        "unit_id": 411,
        "voice": "vo_adv_1058006_035"
    },
    {
        "type": "dialogue",
        "name": "公務人員",
        "words": "\n稍後會再連絡您公會創辦的申請是否核准。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "公務人員",
        "words": "我們會寄送書面通知，",
        "unit_id": 411,
        "voice": "vo_adv_1058006_036"
    },
    {
        "type": "dialogue",
        "name": "公務人員",
        "words": "\n所以麻煩告訴我申請人的住家地址。",
        "unit_id": 411
    },
    {
        "type": "background",
        "background": "500070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "(加油加油",
        "unit_id": 105812,
        "voice": "vo_adv_1058006_037"
    },
    {
        "type": "dialogue",
