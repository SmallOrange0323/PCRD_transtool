    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈啾！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_9041155_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您還好嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請用這條手帕。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "謝了，可蘿仔……",
        "unit_id": 106011,
        "voice": "vo_adv_9041155_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈啾！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真是的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我怎麼沒聽說會變得這麼冷呀！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小、小、",
        "unit_id": 105811,
        "voice": "vo_adv_9041155_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留很怕冷呢……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種程度",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對我來說是小事一樁啦～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不說這個了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們快去找那隻冰、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冰雪格里芬吧……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳看起來完全不像是小事一樁的樣子啊！！",
        "unit_id": 106011,
        "voice": "vo_adv_9041155_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要逞強了啦……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在沒有閒情逸致找格里芬了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們暫時撤退吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉，",
        "unit_id": 105911,
        "voice": "vo_adv_9041155_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為在下的疏忽",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓兩位碰到如此嚴峻的情況……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n原本沒有計畫會到雪山來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以沒有準備任何禦寒用品……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這不怪可蘿仔啦。",
        "unit_id": 106011,
        "voice": "vo_adv_9041155_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要怪就怪",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "顧前不顧後就貿然行動的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "白癡佩可……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被報酬蒙蔽雙眼的我也有責任……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就、",
        "unit_id": 105811,
        "voice": "vo_adv_9041155_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是說呀。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這不怪小可蘿！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留也沒有錯……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哈、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哈啾！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了美味的佳肴，",
        "unit_id": 105811,
        "voice": "vo_adv_9041155_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "辛苦一點也不算什麼！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這才是我們、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "美、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【美食殿堂】呀……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的……",
        "unit_id": 106011,
        "voice": "vo_adv_9041155_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全身上下抖個不停，話還說得那麼好聽。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也不是聽別人勸幾句就肯善罷甘休的人。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n既然就走到這一步了，我就奉陪到底吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小、",
        "unit_id": 105811,
        "voice": "vo_adv_9041155_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱抱～♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇啊！？",
        "unit_id": 106011,
        "voice": "vo_adv_9041155_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳身體好冰呀！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我都說了，別黏過來，是要我說幾次啦！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎喲，",
        "unit_id": 106011,
        "voice": "vo_adv_9041155_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我放手～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n奇、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "奇怪。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像慢慢暖起來了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟現在是非常時期……",
        "unit_id": 106011,
        "voice": "vo_adv_9041155_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真受不了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒辦法了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可蘿仔，妳也過來！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們只要依偎著彼此",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就稍微不那麼冷了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣好嗎？",
        "unit_id": 105911,
        "voice": "vo_adv_9041155_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱抱～",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼……",
        "unit_id": 105811,
        "voice": "vo_adv_9041155_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n啊，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留和小可蘿的體溫",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都好暖和喔～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我活過來了～♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……這種時候",
        "unit_id": 106011,
        "voice": "vo_adv_9041155_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就稍微忍耐一下吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n比起凍僵要來得好多了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105911,
        "voice": "vo_adv_9041155_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐果然是一位",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很溫柔的人呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啥！？",
        "unit_id": 106011,
        "voice": "vo_adv_9041155_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不是妳說的那樣呢！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我剛才也說過了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是非常時期的非常手段！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好好聽人說話！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105911,
        "voice": "vo_adv_9041155_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在那裡的是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是牠！",
        "unit_id": 105811,
        "voice": "vo_adv_9041155_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冰雪格里芬！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太好了，",
        "unit_id": 106011,
        "voice": "vo_adv_9041155_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠出現的時間點正好！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嘿，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們兩個！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趁現在身體暖和起來方便活動！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n乾淨俐落地打倒牠吧！",
        "unit_id": 106011
    }
]