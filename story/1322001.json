        "words": "某天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了郵差的差事，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n把信件送到阿爾克絲鍊金堂時──"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "歡迎光臨～",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……說是這樣說，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對不起。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n店裡",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天臨時停業……！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "！{player}！？",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個啊。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n露易他們有急事",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "得回故鄉一趟。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就拜託我來看店。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她說我還可以自由練習鍊金術。",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也剛好休假，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就一口答應了！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你為什麼",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會來這裡？",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n難道是",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來見露易的嗎……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣我會有點忌妒耶。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "開玩笑的啦♪",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～？",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為遞送郵件的工作而來送信？",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣啊……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼辦呢。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我代為收件也可以嗎？",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "收件人",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是我的名字！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "寄件人是……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "露易！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來如此。",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她知道我在這裡，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n才寄信給我的吧？",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "收到露易的信，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好高興喔♪",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……啊，",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對了，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我還在鍊金途中呢。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}也進來吧！",
        "unit_id": 132212
    },
    {
        "type": "background",
        "background": "502360"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「基創鍊成」！",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好了，",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "完成！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n鍊金等級８！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "高劑量藥水完成了～♪",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿嘿。",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛開始時，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n連鍊金等級１的藥水都做不出來。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "和那時相比多少有點進步，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對吧♪",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但還是遠遠不及露易。",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不只這樣，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "露易的技術不斷進步，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n聽說甚至創造出了新的鍊金秘術。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……稱之為「究極鍊成」。",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯。",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她也沒告訴我細節，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但她說應該能成為像我和{player}這樣，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n戰鬥人員們的強力輔助。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "等她準備好了，",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "應該就能開始提供「究極鍊成」的服務。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們就拭目以待吧♪",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……唔，",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "忘了信的事。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你等等，我看一下喔。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……呵呵♪",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "超級棒的！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}你",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n上面寫著",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「請依照配方製作綻放光芒之劍」！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這絕對是「究極鍊成」的測驗！",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n會想要考驗我，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是對我有所期待的意思吧♪",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿嘿，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "露易對我有所期待耶……！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好～",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我要回應期待！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我一定要在「究極鍊成」完成綻放光芒之劍！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的嗎！？",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太可靠了♪",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那就請{player}多多指教囉！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，為了讓來自露易絲瑪莉的測驗成功，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n望決定挑戰被稱為「究極鍊成」的秘術。"
    },
