        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有依照指南書",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "把素材加進去了。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剩下就是適當地攪拌……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "最後是鍊金術的咒文。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「基創鍊成」！",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……搞錯、",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "了。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要使「究極鍊成」成功，",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "需要的不是平時的咒文，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n而是特別的咒文……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喔，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "書上有寫",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咒文，但是……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唔唔……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是什麼啊……？",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「請在３秒內連續詠唱３次",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "『騎士隊長端湯上塔』」……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不是，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這什麼啊太難了吧～！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我一定做不到啊～！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唔……",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你說得對。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再怎麼說都是究極。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不可能輕輕鬆鬆就過關……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且……",
        "unit_id": 132212,
        "voice": "vo_adv_1322001_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果在嘗試前就放棄，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那就不像我了呀……！！",
        "unit_id": 132212
    },
