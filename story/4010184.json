[
    {
        "type": "background",
        "background": "509015"
    },
    {
        "type": "background",
        "background": "510200"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "唔……",
        "unit_id": 100931,
        "voice": "vo_adv_4010184_000"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "這個氣息……！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "是誰！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "吉格魯特……！",
        "unit_id": 100931,
        "voice": "vo_adv_4010184_001"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n難道說",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "把我叫來此處的這封信，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "是你！？",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "你找我這個疾風之冥姬，",
        "unit_id": 100931,
        "voice": "vo_adv_4010184_002"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n安妮羅潔‧馮‧修特帕魯",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "到底有什麼事！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "看到「冥風戰記」的訊息表單上",
        "unit_id": 100931,
        "voice": "vo_adv_4010184_003"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "寫著日期與「我在此處等候」的留言，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n所以我才來的，沒想到來這一看，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "真的是吉格魯特！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "因為實在是太過可疑，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我還猶豫過要不要來呢……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "確、",
        "unit_id": 100931,
        "voice": "vo_adv_4010184_004"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "確實……！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "今天這天正是",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我的──",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "……",
        "unit_id": 100931,
        "voice": "vo_adv_4010184_005"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "生日。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "謝、",
        "unit_id": 100931,
        "voice": "vo_adv_4010184_006"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "謝謝你……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "不對！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "感謝你！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "你果然是",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我永遠的盟友！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "你所獻上的贈物，",
        "unit_id": 100931,
        "voice": "vo_adv_4010184_007"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "就讓我在此解除封印吧！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n哇",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "裝訂得好漂亮的筆記本……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "咳咳。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "嗯嗯，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "這是仍未點綴過的，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "白紙之書物。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "是嗎……",
        "unit_id": 100931,
        "voice": "vo_adv_4010184_008"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "吉格魯特。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n你的意思是要把我們「熾炎戰鬼煉獄血盟暗黑團」的",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "嶄新故事，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n刻劃在此本白紙之書物上，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "是嗎……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "是這樣沒錯吧？",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "呵、呵、呵……",
        "unit_id": 100931,
        "voice": "vo_adv_4010184_009"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "那",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "好啊！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n我與你從今以後所經歷的故事，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "就來好好紀錄上去吧！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "……只屬於我們兩人的，",
        "unit_id": 100931,
        "voice": "vo_adv_4010184_010"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "故事。",
        "unit_id": 100931
    }
]