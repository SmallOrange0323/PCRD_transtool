[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "正月で賑わうランドソルの繁華街を、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nモニカとメドゥーサは散策していた。"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "こっちにも蛇、",
        "unit_id": 133611,
        "voice": "vo_adv_5160601_000"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "あっちにも蛇。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "お土産屋にも蛇。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n街中に蛇のモチーフがたくさん飾ってあるわ！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "新年からみんなで蛇をまつるなんて、",
        "unit_id": 133611,
        "voice": "vo_adv_5160601_001"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nこの国は蛇の偉大さをちゃんと理解してるのね。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "……感動に水を差すようで悪いのだが、",
        "unit_id": 133212,
        "voice": "vo_adv_5160601_002"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nあくまで今年の干支が蛇だ、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "というだけだぞ。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "来年以降はまた違う動物が飾られるのだ。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "え？　",
        "unit_id": 133611,
        "voice": "vo_adv_5160601_003"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "それってどういうことなの？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "──なるほど、",
        "unit_id": 133611,
        "voice": "vo_adv_5160601_004"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "神様のレースに勝った12匹の動物を",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n一年交代でまつってるのね。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "なかなか面白い話だわ。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "でも、",
        "unit_id": 133611,
        "voice": "vo_adv_5160601_005"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "一つだけ納得いかないことがあるんだけど。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "なんだ、",
        "unit_id": 133212,
        "voice": "vo_adv_5160601_006"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "なにが不満なのだ？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "なんで蛇が一等賞じゃないのよ！",
        "unit_id": 133611,
        "voice": "vo_adv_5160601_007"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nそれも蛇を差し置いてネズミがトップ？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ネズミなんて蛇のエサじゃない！　",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "納得いかないわね。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "いや、",
        "unit_id": 133212,
        "voice": "vo_adv_5160601_008"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "昔話に文句を言われてもな……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "こういうのってどこに抗議すればいいのかしら？",
        "unit_id": 133611,
        "voice": "vo_adv_5160601_009"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "しっかりと蛇の偉大さを伝えて、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "毎年蛇をまつるようにすべきよ！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "まずは落ち着くんだ。",
        "unit_id": 133212,
        "voice": "vo_adv_5160601_010"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "……いいか、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "このレースが行われたのは寒い季節、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "つまり蛇にとっては非常に厳しい条件だ。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "遅れるのも仕方ないだろう。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そんなハンデをものともせず、",
        "unit_id": 133212,
        "voice": "vo_adv_5160601_011"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n並みいる動物たちを抑え十二支入りできたのだ。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "一位でなくとも蛇のすごさは十分に伝わっているはずだ。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "それに、",
        "unit_id": 133212,
        "voice": "vo_adv_5160601_012"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "毎年よりも12年に一度の方が",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nレア度が高い。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ありがたみも増すというものじゃないか？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "……たしかに。",
        "unit_id": 133611,
        "voice": "vo_adv_5160601_013"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "アンタの言うとおりね。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ふふん、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "やっぱり蛇ってすごいじゃない！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ふぅ、",
        "unit_id": 133212,
        "voice": "vo_adv_5160601_014"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "どうにか納得してくれたようだな……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ねえ、",
        "unit_id": 133611,
        "voice": "vo_adv_5160601_015"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "今気づいたんだけど、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "蛇と龍って被ってない？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "どっちか一方、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ていうか蛇だけでよくない？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nアンタはどう思うの、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "モニカ？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "あーもう！　",
        "unit_id": 133212,
        "voice": "vo_adv_5160601_016"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "困ったヤツだな！　",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "新たな火種が投げ込まれたことに頭を抱えるモニカだった。"
    }
]