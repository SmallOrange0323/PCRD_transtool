    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束善後工作的{player}等人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n步向了東國的大街。"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這樣",
        "unit_id": 136511,
        "voice": "vo_adv_5212007_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "全部都處理完了呢。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "大家辛苦了。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "最後的避難所，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒想到真的是在東國呢。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是啊！",
        "unit_id": 137912,
        "voice": "vo_adv_5212007_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然加上移動花了許多時間，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n但終於能夠鬆一口氣了～！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n也謝謝",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥的幫忙。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "話說回來，",
        "unit_id": 137912,
        "voice": "vo_adv_5212007_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "東國的大街還真是熱鬧啊。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "大家看起來都好開心。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n而且還有很多店鋪……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒想到在這種地方也會有避難所，",
        "unit_id": 137912,
        "voice": "vo_adv_5212007_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n公會長真是神出鬼沒呢。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "封印大家的記憶之後，",
        "unit_id": 137912,
        "voice": "vo_adv_5212007_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不知不覺間",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "人就",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "突然消失了。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "或許又在",
        "unit_id": 136511,
        "voice": "vo_adv_5212007_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "世界各地到處奔走了吧。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這次的事件也不是以組成公會的形式處理，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們只是幫忙而已。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "公會果然",
        "unit_id": 137912,
        "voice": "vo_adv_5212007_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還是維持解散狀態呢。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "明明還說著",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "「【拉比林斯】的實力～」什麼的。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是啊。",
        "unit_id": 136511,
        "voice": "vo_adv_5212007_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然感覺有點不可思議……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那時候還想著，",
        "unit_id": 137912,
        "voice": "vo_adv_5212007_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "又能大家一起行動了。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "果然已經是定局了，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是嗎……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃。",
        "unit_id": 136511,
        "voice": "vo_adv_5212007_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "表情別那麼黯淡啦。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這種時候就是要吃點甜食，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "打起精神來！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難得來東國，",
        "unit_id": 136511,
        "voice": "vo_adv_5212007_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n一起去吃",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "平常吃不到的有名糰子吧♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今天",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐請客。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……呵呵，",
        "unit_id": 137912,
        "voice": "vo_adv_5212007_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我最喜歡",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐的這一點了！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 137912,
        "voice": "vo_adv_5212007_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "發現糰子店了！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們快點過去吧♪",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐、",
        "unit_id": 137912,
        "voice": "vo_adv_5212007_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在這裡喔～！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唉，",
        "unit_id": 136511,
        "voice": "vo_adv_5212007_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還真是現實呢～？",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "走",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "吧，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "店員，",
        "unit_id": 137912,
        "voice": "vo_adv_5212007_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請給我",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個新春糰子組合！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n茶的話要煎茶！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那我也一樣的。",
        "unit_id": 136511,
        "voice": "vo_adv_5212007_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "茶就點抹茶好了？",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n弟弟也點一樣的嗎？",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "抹茶，",
        "unit_id": 137912,
        "voice": "vo_adv_5212007_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "感覺好大人的口味！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸嘿嘿，",
        "unit_id": 136511,
        "voice": "vo_adv_5212007_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為我是姐姐啊♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯～",
        "unit_id": 137912,
        "voice": "vo_adv_5212007_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好好喝。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n東國的茶別有一番風味呢……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真的呢。",
        "unit_id": 136511,
        "voice": "vo_adv_5212007_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "更重要的是，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "身邊有弟弟和璃乃在。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能這樣悠閒享用的茶",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是太棒了♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……感謝招待！",
        "unit_id": 137912,
        "voice": "vo_adv_5212007_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐、",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n機會難得，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要不要稍微散步一下？",
        "unit_id": 137912
    },
    {
        "type": "background",
        "background": "502630"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然一時衝動就說要幫忙了！",
        "unit_id": 137911,
        "voice": "vo_adv_5212007_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過就算這樣，",
        "unit_id": 137911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n至少過年",
        "unit_id": 137911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也該讓人休息一下吧！？",
        "unit_id": 137911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "公會長",
        "unit_id": 136511,
        "voice": "vo_adv_5212007_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真的是很會使喚人呢。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n偶爾也想要一點獎勵啊～？",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而且看起來公會長在不知不覺間還訂做了一件感覺很不錯的和服？",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，",
        "unit_id": 106818,
        "voice": "vo_adv_5212007_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個？",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這是東國限定",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "附有特殊效果的稀有裝備喔。",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想說不只外觀好看，",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "順便還可以提升戰鬥效率♪",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真不愧是公會長，",
        "unit_id": 136511,
        "voice": "vo_adv_5212007_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "準備萬全！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那樣的話～",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果也可以幫我們安排一下，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們會很開心的……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哦♪",
        "unit_id": 136511
    },
    {
        "type": "background",
        "background": "502630"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果大家都穿成套的服裝，",
        "unit_id": 137911,
        "voice": "vo_adv_5212007_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我也會",
        "unit_id": 137911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "更～",
        "unit_id": 137911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "加地努力也說不定！",
        "unit_id": 137911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯～",
        "unit_id": 106818,
        "voice": "vo_adv_5212007_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "被妳們這麼說，",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "身為公會長也不得不把這個提議納入考量呢！",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106818
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不同顏色的相同款式，",
        "unit_id": 106818
    },
