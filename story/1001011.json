    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～……",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_073"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊！　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "又睡著了嗎！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺我做了",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一個讓人既懷念又非常重要的夢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……雖然只記得模糊片段，",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_074"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過夢境當中，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好像也有出現小時候的我呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_075"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說不定",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n很久以前",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就已經跟騎士先生見過面了",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……怎麼可能呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_076"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n一定是睡到迷糊了吧，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我真是的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……但是，",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_077"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果真的",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "以前有跟騎士先生相遇過，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那樣就太好了呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
