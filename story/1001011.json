[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}散步的時候，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n恰巧遇見拿著大件行李的日和。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！　",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗨嗨―！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你好！　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天你……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿咻……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在作什麼呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來是散步呀―！　",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真是好、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "天氣呢……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊啊，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你問這個行李嗎？　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我嗎？　",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我呀……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "小哥，",
        "unit_id": 611,
        "voice": "vo_adv_1001011_003"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "你是這孩子的",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "朋友嗎？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n能不能幫我背一下行李呢？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈……",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "其實這是，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這位奶奶的行李，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因為很重她看起來很困擾的樣子，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以我無法坐視不管！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可以嗎？　",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那我們兩個人一起搬吧！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "到這裡就是我家了。",
        "unit_id": 611,
        "voice": "vo_adv_1001011_006"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "你們真是幫了大忙。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n很重吧？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "完全不會！",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n有困難的時候就互相幫助幫助！　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對吧，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "謝謝啊。",
        "unit_id": 611,
        "voice": "vo_adv_1001011_008"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "下次",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "讓我表達謝意吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "再見。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "回去時請小心呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "幫人之後，",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "心情總會變得很暢快呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝你的幫忙！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……這麼說來我到底，",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n為什麼會這麼想幫助別人呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！？　",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "表情別那麼吃驚啦！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不知道從什麼時候開始呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只要看到有困難的人，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我的身體就會自然而然動起來。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～……",
        "unit_id": 100111,
        "voice": "vo_adv_1001011_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "話說",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這是什麼光！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "往旁邊去啦！　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "奇怪？　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "打不到……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "又、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "變得、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好想睡了……",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "510121"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長―！　",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗨嗨―！　",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長也是現在要回去嗎？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊～，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "莫非剛剛有順道去別的地方嗎？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我……",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "之前的傷勢雖然已經復原了，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但慎重起見",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "暫停一陣子的社團活動在休息唷。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因此呢，",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "無意間時間就變多了呢。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n所以跑來公園消磨時間。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "竟然能碰到學長，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n跑來公園",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好像很Lucky呢",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗚、",
        "unit_id": 231,
        "voice": "vo_adv_1001011_017"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗚嗚……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "媽媽……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n妳去哪裡了？",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個孩子，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "難道是迷路嗎？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長！　",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們一起去幫她吧！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳好！　",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼了呢？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "和媽媽走散了嗎？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗚嗚……",
        "unit_id": 231,
        "voice": "vo_adv_1001011_020"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "呃嗚……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n呼嗚……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊啊，",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不要哭呀―！！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有可以讓這孩子冷靜下來的東西嗎。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊！　",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了！　",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～我應該是放在這裡……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "找到了！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喵喵！",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n妳是",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "自己正在找媽媽",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "的堅強孩子喵！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "看到這隻小貓，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就能打起精神唷喵！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗚……",
        "unit_id": 231,
        "voice": "vo_adv_1001011_024"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "呃嗚，",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "啊，是小貓呢……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "姐姐。",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "這隻小貓，",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "已經破破爛爛的呢？",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這隻小貓呢，",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可是姐姐重要的小貓朋友唷。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "牠只要看到有困難的人",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就會幫忙，是個好孩子唷。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以，",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "為了找到妳的媽媽，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n小貓也會一起幫忙唷喵！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳看，",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為小貓也會一起幫忙，所以妳不孤單吧？",
