        "type": "dialogue",
        "name": "日和",
        "words": "這隻小貓，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要還給學長呢。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為這隻小貓一直陪伴在我身旁。",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_059"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因為學長",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "幫助了我，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以我才能變成現在的我。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對學長來說，",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_060"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我是眾多幫助過的其中一個。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n雖然如此，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但對那時候的我來說，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你就是唯一的英雄。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……那時候謝謝你。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大哥哥。",
        "unit_id": 100131
    },
    {
        "type": "still",
        "still": "100101102"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可以嗎……？　",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_061"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我今後也會",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一直、",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一直",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一直",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一～直",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好好珍惜的！",
        "unit_id": 100131
    },
    {
        "type": "still",
        "still": "100101102"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的嗎？　",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_062"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝！　",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就像那時候一樣，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n如果我感到寂寞或痛苦時，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就會讓這孩子來幫我！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……那個學長。",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_063"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我啊，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為很憧憬那時候的學長，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n所以想跟學長一樣，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "去幫助有困難的人唷。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還有因為那天我真的很開心，",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_064"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n也希望其他人",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也能感受到同樣的心情……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總有一天我也想",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_065"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "幫助我最喜歡的學長，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n所以各方面",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我會更加更加努力的！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……啊！　",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_066"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛、",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛剛說的最喜歡，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n是指最喜歡的夥伴的意思啦！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "已、",
        "unit_id": 100131,
        "voice": "vo_adv_1001011_067"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "已經天黑了呢……！　",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們差不多該回家了！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我們來比賽跑到出口吧！　",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "預～備，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "開始―！",
        "unit_id": 100131
    },
    {
        "type": "still",
        "still": "end"
    },
    {
