        "voice": "vo_adv_1001011_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了～！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "與其說日和很堅強呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "倒不如說其實是單純呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒想到小時候你幫她的行動，",
        "unit_id": 190011,
        "voice": "vo_adv_1001011_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n竟對日和產生那麼重大的影響，真讓人吃驚呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "希望今後你與日和的行動，",
        "unit_id": 190011,
        "voice": "vo_adv_1001011_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n能跟各式各樣的人產生連結就好呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1001011_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "日和常常",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為直覺及突然靈光一閃就行動了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你可要",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好好跟在後面幫助她啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就交給日和最喜歡的你，",
        "unit_id": 190011,
        "voice": "vo_adv_1001011_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼這次就到這裡吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
