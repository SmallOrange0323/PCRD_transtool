[
    {
        "type": "background",
        "background": "501950"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒想到競爭對手會跑來視察。",
        "unit_id": 125212,
        "voice": "vo_adv_6114104_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "先想好如何應對那類間諜",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是最好的做法呢。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n有沒有什麼妙計呢……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可以說說閣下的看法嗎？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對喔，",
        "unit_id": 125212,
        "voice": "vo_adv_6114104_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對來訪的客人投以懷疑眼光……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "用眼神殺掉",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "他。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "想必心有內疚之人",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "肯定會逃出去的！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "等等，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣不是連一般的客人都不敢光臨嗎！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "和平……？",
        "unit_id": 125212,
        "voice": "vo_adv_6114104_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我懂了，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是所謂的雙重間諜吧！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這很像軍人的因應方式，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是帥呆了！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看到疑似的人物，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就積極去找他說話吧。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哦，",
        "unit_id": 125212,
        "voice": "vo_adv_6114104_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "反而是由我們這邊光明正大地主動出擊嗎？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那樣既能偵察競爭對手的店，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "又能充分享受甜食，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n真是一舉兩……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呃，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "剛才的請當作沒聽到……",
        "unit_id": 125212
    }
]