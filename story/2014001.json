[
    {
        "type": "background",
        "background": "500783"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為數眾多的魔物和闇影正到處肆虐，蘭德索爾成為了戰場。\n而此時朝著一群群魔物們進行突擊的貪吃佩可，所遭遇到的是――"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在這裡狹路相逢也是天注定，",
        "unit_id": 105811,
        "voice": "vo_adv_2014001_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "霸瞳皇帝！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n呀啊啊啊！",
        "unit_id": 105811
    },
    {
        "type": "background",
        "background": "500783"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵，",
        "unit_id": 106914,
        "voice": "vo_adv_2014001_001"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "好可怕好可怕。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n堂堂公主殿下，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "竟然這麼拚命呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "連表情都如此猙獰。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這不可惜了妳那張可愛的小臉蛋嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然要拚命了！",
        "unit_id": 105811,
        "voice": "vo_adv_2014001_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了我的國民！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也為了父皇他們！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要我能把你給打倒，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這全部的一切，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就都能夠救回來了……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哎呀是喔？",
        "unit_id": 106914,
        "voice": "vo_adv_2014001_003"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那麼，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳就加把勁試試看能不能將我逼至絕境吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳當鬼，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "來抓我♪",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咕嗚……！",
        "unit_id": 105811,
        "voice": "vo_adv_2014001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你別給我光是在那邊四處亂竄的呀！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了追趕霸瞳皇帝，貪吃佩可則是到處橫衝直撞，\n同時{player}為了掩護她，\n也死命地追著後面，然而……"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911,
        "voice": "vo_adv_2014001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請往這來！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n涅比亞大人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有意向在下等人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n傳達一項『作戰』的樣子！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的擔憂理當為是。",
        "unit_id": 105911,
        "voice": "vo_adv_2014001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管冒昧，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但若是如今的在下一行人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是無法將霸瞳皇帝給擊敗的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為得扭轉此局勢，",
        "unit_id": 105911,
        "voice": "vo_adv_2014001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也同是為拯救貪吃佩可小姐……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如今所需要的是那份『作戰』啊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……！",
        "unit_id": 105911
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "涅比亞大人！",
        "unit_id": 105911,
        "voice": "vo_adv_2014001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下已遵照指示，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將主人給帶回來了！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯。",
        "unit_id": 190911,
        "voice": "vo_adv_2014001_009"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "謝謝。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n真不愧是讓菲歐這麼中意的人呢，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "乖寶寶♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好啦，",
        "unit_id": 190911,
        "voice": "vo_adv_2014001_010"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那我要更具體地進行說明了唷。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我只會說一次而已，所以給我專心聽好了呀！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n明白了嗎？{player}！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "現在，",
        "unit_id": 190911,
        "voice": "vo_adv_2014001_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "在凱留的體內，寄宿著『那邊』的晶……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n拉比林斯達所暫存的魔力和『鑰匙』。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106015,
        "voice": "vo_adv_2014001_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像是真的。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算想隱瞞好像也沒什麼意義，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也就只能老實承認了。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "首先將這把『鑰匙』交給{player}，",
        "unit_id": 190911,
        "voice": "vo_adv_2014001_013"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n便是這個『作戰』的大前提唷。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n而",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "說到交給他的方法……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸……",
        "unit_id": 106015,
        "voice": "vo_adv_2014001_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "涅比亞！",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說真的，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "除了妳剛剛講的那個方法以外就沒其他辦法了嗎！？",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "吼唷，",
        "unit_id": 190911,
        "voice": "vo_adv_2014001_015"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳到底還要煩惱到什麼時候才行啊？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這又不是說要妳去做什麼了不起的大事情。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對我來說是大事情啦，",
        "unit_id": 106015,
        "voice": "vo_adv_2014001_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "笨蛋！",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "更別還說，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是要和這傢伙……！",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "聽我說。",
        "unit_id": 190911,
        "voice": "vo_adv_2014001_017"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "魔術相關的契約",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "、讓渡",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "、榨取等等所需要進行的儀式，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n大部份也就是那幾種基本的行為模式。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n而這次，也是其中之一唷。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這個嘛，",
        "unit_id": 190911,
        "voice": "vo_adv_2014001_018"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "用一般的話來講……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就是親嘴唷。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "親嘴。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "親、",
        "unit_id": 105911,
        "voice": "vo_adv_2014001_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "親嘴……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和凱留小姐……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚嗚嗚嗚～！",
        "unit_id": 106015,
        "voice": "vo_adv_2014001_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "辦、",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "辦不到果然辦不到啦！　",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太丟臉了啦這種事情！",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……而且，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "人家也",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還沒有，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟誰親過……！",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "所～以～說～！",
        "unit_id": 190911,
        "voice": "vo_adv_2014001_021"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n這世界都已經陷入危機了，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不是讓妳討價還價的時候了！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n妳不也是，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "說想要替這些傢伙們盡一份心力的嗎！？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚……",
        "unit_id": 106015,
        "voice": "vo_adv_2014001_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚～～……、",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說的，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也對啦，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒錯啦……",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可、",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是呀～……",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哼哼♪　",
        "unit_id": 190911,
        "voice": "vo_adv_2014001_023"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "而、且、呀～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "雖然嘴巴上說「不要～」或「辦不到～」之類的，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n但妳其實不討厭他對吧？　",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這傢伙♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "煩、",
        "unit_id": 106015,
        "voice": "vo_adv_2014001_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "煩死了煩死了煩死了～！",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "果然還是不要！　",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "絕對不要！",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "討厭的事就是討厭啦～！",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……要和主人，",
        "unit_id": 105911,
        "voice": "vo_adv_2014001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然能……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "親嘴什麼的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是如此令人好生羨慕的呢……",
