    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對在下來說，",
        "unit_id": 105911,
        "voice": "vo_adv_2014001_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管是斷腸之念。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而倘若只有僅僅的一瞬……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做為凱留小姐限定，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "勉勉強強算您安全上壘。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "安全上壘妳～個頭！　",
        "unit_id": 106015,
        "voice": "vo_adv_2014001_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在這種全場大亂鬥的正中央，",
        "unit_id": 106015
