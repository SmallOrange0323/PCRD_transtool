        "voice": "vo_adv_2014001_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n由您所說的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了達成『鑰匙』的讓渡，",
