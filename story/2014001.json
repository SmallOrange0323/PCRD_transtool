    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "倘若能與您交換的話，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就讓在下……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好了沒，",
        "unit_id": 190911,
        "voice": "vo_adv_2014001_026"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "如果再繼續這樣磨蹭下去，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n貪吃佩可要被幹掉了唷？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "畢竟現在最危險的，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "可是正在和霸瞳皇帝戰鬥的那孩子啊。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您、",
        "unit_id": 105911,
        "voice": "vo_adv_2014001_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說的是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "事到如今也別無他法了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就向主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "慢慢的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "輕輕地。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍微些許，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如同擦過的程度般……",
