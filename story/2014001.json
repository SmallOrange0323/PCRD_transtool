        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要、",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要和這傢伙……",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "親嘴……",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
