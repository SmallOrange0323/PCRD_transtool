        "voice": "vo_adv_1061004_047"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "沒想到妳還滿怕寂寞的嘛，",
