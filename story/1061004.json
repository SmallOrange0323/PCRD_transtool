    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "反正妳們是贏不過我跟尾狗刀的，",
        "unit_id": 106114,
        "voice": "vo_adv_1061004_063"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n要投降趁現在唷！",
