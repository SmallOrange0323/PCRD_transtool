    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘖。",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我還以為終於能見到晶了說……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "妳那麼想見晶啊？",
