        "voice": "vo_adv_1061004_061"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳們如果輸了，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n就不能再用那個帳號再次登入了，加油囉～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "玩家1",
        "words": "你們該不會是，",
        "unit_id": 411,
        "voice": "vo_adv_1061004_062"
    },
    {
        "type": "dialogue",
        "name": "玩家1",
        "words": "PK公會的……！？",
