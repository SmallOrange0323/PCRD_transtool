[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "――王都作戰的前一晚。\n矛依未正在保養武器和防具。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都變得破破爛爛的了呢……",
        "unit_id": 106112,
        "voice": "vo_adv_1061004_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這次的作戰恐怕會很激烈，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還是事先做好保養為妙！　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……？",
        "unit_id": 106112,
        "voice": "vo_adv_1061004_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼啊，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這道光……？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "明明很刺眼、",
        "unit_id": 106112,
        "voice": "vo_adv_1061004_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "卻覺得、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "開始……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "想睡……",
        "unit_id": 106112
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "諾維姆和尾狗刀受到米奈娃的委託，\n為了保護所有可能登上索爾之塔塔頂的\n玩家帳號不受攻擊，正到處奔走。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是哪個傢伙……？",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有了有了！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "春咲日和……",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那傢伙就是日和嗎。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "和在阿斯特朗時一樣",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_005"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "很有精神呢。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "用米奈娃那裡借來的管理者權限，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n只要連接上mimi……",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "好了，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "帳號保護完成。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那下一個是怜嗎。",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_006"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "如果情報正確的話，",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_007"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "應該是王林道的高年級吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n諾維姆。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "太麻煩了，我們用跳躍移動吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你這傢伙……",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n連動都覺得麻煩的話，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很快就會變老爺爺喔？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "比起諾維姆，我可是有好好在運動的，沒問題。",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_009"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "對了。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "格鬥技的通信教育，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "妳有持續在學習嗎？",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "當、",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "當然有啊！？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "換下一個了，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "下一個！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "好好好。",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_011"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "該不會，",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_012"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "最近其實都在偷懶吧……？　",
        "unit_id": 106231
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怜……",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是那個人嗎？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "……",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_014"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "好像是呢。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "mimi連結的帳號，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n和她的個人資料一致。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "果然如此……",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_015"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "這孩子感覺最容易被盯上。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n對她再加強比其他人更多層的保護吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為什麼啊？",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_016"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "因為現實中怜的立場，",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_017"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "有可能認識七冠。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "若是如此，我們的對策",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "也有可能無疾而終。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "就算為了避免米奈娃遭受攻擊而想出保護帳號的對策，",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_018"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n如果像我們一樣，在現實裡被七冠抓住的話，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "也就什麼辦法都沒有了吧？",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也是啦。",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不是故意要學你的口頭禪，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但感覺還真會是件麻煩事呢。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "到底會不會麻煩，",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_020"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "只有神才知道喔。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "保護流程都結束了，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "接著去找下一個吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "下個是優衣對吧。",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是怎樣的傢伙呢？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n說不定現實中可是很狂暴的人！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "……我想至少",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_022"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "不是個壞孩子唷。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嗎？",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "算了，沒差。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n與其想那麼多，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還不如親自去確認看看！",
        "unit_id": 106131
    },
    {
        "type": "background",
        "background": "510240"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哪個才是優衣～？",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在哪裡～？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "是那孩子吧？",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_025"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "妳看，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "那邊。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔喔，",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個人啊！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看起來是個不錯的傢伙呢。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "而且在旁邊的是……",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_027"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "{player}呢。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊？",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀你在說些什麼啊。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你說那傢伙在哪？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在可不是在阿斯特朗唷。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "這點我還是知道的。",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_029"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "聽好了諾維姆。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "他是晶的公主騎士唷。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嗎！？",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你這傢伙，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為什麼知道呀！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "因為我把從學校用mimi登入阿斯特朗的學生們",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_031"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n所有人的帳號都掌握得一清二楚呢。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "資訊記錄檔保護的異常嚴密的帳號，",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_032"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n只有一個而已。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "而且這保護的構造還很眼熟呢。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你偷看嗎！？",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你還是一樣，真是個壞傢伙！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你該不會，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還告訴了真那他們吧？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "怎麼會。",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_034"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "他也是米奈娃想要保護的對象喔？",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "而且比對那三人更謹慎地",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "刻意隱藏了他的資訊。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "還故意設計過用假帳號來進行資訊傳輸，",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_035"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "真那他們若不盡全力是沒辦法解析出來的吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "但他的帳號是晶做的，",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_036"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n基本上應該是完美無缺啦。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "所以放心吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔！",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我放心了！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "米奈娃要我們做的事，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也算告一段落了吧？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "還沒結束喔。",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_038"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n還得繼續調查其他的玩家。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "但我肚子餓了啦，",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_039"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "先去吃個可麗餅吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "晶的店嗎！？",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我想去！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n好，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "走吧尾狗刀！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "等、",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_041"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "等一下啦諾維姆──",
        "unit_id": 106231
    },
    {
        "type": "background",
        "background": "510121"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂～！",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "晶──！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "……",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_043"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "好像不在耶。",
