    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "吵死了！",
        "unit_id": 106131,
        "voice": "vo_adv_1061004_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我才沒有寂寞呢！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "晶不在的話我要回去了！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "掰掰，尾狗刀！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "哎呀呀，",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_049"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "走掉啦。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n……",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "接下來。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "該做的事也都做完了，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n回家去登入吧。",
