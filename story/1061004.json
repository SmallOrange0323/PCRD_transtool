    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……這孩子可以播放的記憶，",
        "unit_id": 190011,
        "voice": "vo_adv_1061004_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n果然到這裡就是極限了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然循著與那傢伙之間的羈絆，",
        "unit_id": 190011,
        "voice": "vo_adv_1061004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總算是接觸到了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但再接下去就沒辦法了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還以為終於找到有益的資訊了呢……",
