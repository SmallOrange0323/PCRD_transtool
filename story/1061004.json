    },
    {
        "type": "still",
        "still": "106100401"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喂！",
        "unit_id": 106114,
        "voice": "vo_adv_1061004_056"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那邊幾位！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n和我戰鬥吧！",
