        "unit_id": 411,
        "voice": "vo_adv_1061004_057"
    },
    {
        "type": "dialogue",
        "name": "玩家1",
        "words": "\n……怎麼了，那麼突然？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "雖然不能告訴妳原因，",
