    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "應該是喔。",
        "unit_id": 106231,
        "voice": "vo_adv_1061004_045"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "看來安全藏匿好了。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "不愧是晶。",
