        "voice": "vo_adv_1061004_064"
    },
    {
        "type": "dialogue",
        "name": "玩家2",
        "words": "真是好大的膽子呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "玩家2",
        "words": "\n要上囉各位！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "嘿嘿，",
        "unit_id": 106114,
        "voice": "vo_adv_1061004_065"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "太棒了太棒了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "開始有幹勁了呢！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "準備好，尾狗刀！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "把她們所有人，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "全都砍掉！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "還是那麼熱血呢，諾維姆。",
