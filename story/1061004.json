        "voice": "vo_adv_1061004_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也就是說……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "她發現克莉絲提娜在附近搜查了嗎。",
