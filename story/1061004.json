    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然那段記憶重要到這地步，",
        "unit_id": 190011,
        "voice": "vo_adv_1061004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但同時也不太想回憶起呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那時發生的事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……也不能勉強她回憶起來呢。",
