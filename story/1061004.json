        "voice": "vo_adv_1061004_060"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "所以如果妳們能早點被解決掉的話就輕鬆多了。",
