    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "差不多該消氣了吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "喂？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不知道！",
        "unit_id": 106114,
        "voice": "vo_adv_1061004_052"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "如果有下次，你就算道歉我也不理你喔！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n別跟過來啦！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦──",
        "unit_id": 106211,
        "voice": "vo_adv_1061004_053"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "別這麼說嘛──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……",
        "unit_id": 106211,
        "voice": "vo_adv_1061004_054"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆妳看。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "發現這次的目標了。",
