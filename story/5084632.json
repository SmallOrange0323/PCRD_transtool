[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 103311,
        "voice": "vo_adv_5084632_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你要睡到什麼時候啊……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n要是老哥不在我身邊，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就算搞笑也完全不開心啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "笑不出來的搞笑藝人什麼的，",
        "unit_id": 103311,
        "voice": "vo_adv_5084632_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "才是讓人笑不出來的笑話啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我想要笑口常開……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "話是這麼說，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n要是一個人在這邊沮喪，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "會被老哥罵的吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在老哥醒來之前，",
        "unit_id": 103311,
        "voice": "vo_adv_5084632_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我就來想很多笑料吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要是你不趕快醒來，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就要連續看我搞笑三天三夜了喔。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然那樣感覺也很開心……",
        "unit_id": 103311,
        "voice": "vo_adv_5084632_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但你還是盡快醒來吧，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "會等著你的。",
        "unit_id": 103311
    }
]