[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾個小時後。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼啊～",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "稍微休息一下。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵，",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不曉得是不是因為照平常的步調玩過頭了～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總覺得身體的每個地方好像都在抗議了。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過今天的我和平常的狀態不同，",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得好好注意才行。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "游泳游到一半要是腳抽筋的話就糟了～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可是會溺水的。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的好開心，還是不小心又得意忘形了呢。",
        "unit_id": 107511
    },
    {
        "type": "still",
        "still": "107500301"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……哦？",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}，你也正躺著休息嗎？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那可以往旁邊一點～點嗎？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也想要休息！",
        "unit_id": 107511
    },
    {
        "type": "still",
        "still": "107500302"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n謝謝你哦，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好乖～好乖～♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}是個乖孩子……♪",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦？",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n出乎意料之外的反應呢，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你進入叛逆期了嗎{player}！",
        "unit_id": 107511
    },
    {
        "type": "still",
        "still": "107500302"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就算{player}不讓出空間來給我，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也沒有關係哦～。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會把{player}當成被窩，",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n用我全部的體重躺在你身上的。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看招，飛撲攻擊～！",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n抱抱♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哈嗚……",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣就變成了很棒的被窩，太讚了吧～♪",
        "unit_id": 107511
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……哦哇？",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n突然就坐起來了呢，{player}！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起哦～",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在這種大熱天裡身體接觸的話會太燥熱吧♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還蠻喜歡",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種彼此間的肢體接觸呢。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有種對方就在這裡，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是我的幻想而是能感受到的……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n很真實的感覺，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓人很安心。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊，",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一安心下來，就開始變得想睡了……♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵呵～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那我就恭敬不如從命囉。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今天真的好累，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一閉上眼睛的話好像就能馬上睡著。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只是，",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在這樣的陽光下睡太久的話感覺會被曬成乾，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且還有一種浪費時光的感覺……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以{player}，過一陣子要把我叫醒哦。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "麻煩你哦～",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n約好了，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們打勾勾♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果說謊的話，",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就要吞一千根針……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼嚕、呼嚕……♪",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們回來了～",
        "unit_id": 107811,
        "voice": "vo_adv_1075003_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有點起風了，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為海浪漸漸變高，暫時先告一段落吧。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大海的狀態改變的話，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "得重新再設定一次魔法呢。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這部分，",
        "unit_id": 107811,
        "voice": "vo_adv_1075003_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會是未來的課題呢。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 107611,
        "voice": "vo_adv_1075003_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對不會游泳的在下來說，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐的魔法無疑就是救命繩索。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也擔心溺水會給您添麻煩，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以是不會逞強的。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然很可惜，",
        "unit_id": 107611,
        "voice": "vo_adv_1075003_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過在水中散步，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的非常開心。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 107811,
        "voice": "vo_adv_1075003_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趁著稍作休息時，我順便重新設定一下魔法吧。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n{player}也別休息了，下次一起去游泳吧。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n當然貪吃佩可那傢伙也……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼嚕、",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼嚕……♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 107611,
        "voice": "vo_adv_1075003_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n睡得好熟呢，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦，",
        "unit_id": 107811,
        "voice": "vo_adv_1075003_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙回來了啊。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說自己會游泳，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就一臉開心地游到很遠的地方……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "做事總是不考慮旁人，橫衝直撞的呢。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊討厭，這張幸福的睡臉……",
        "unit_id": 107811,
        "voice": "vo_adv_1075003_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是讓人火大，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "乾脆來塗鴉好了？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼嚕、",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼嚕……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咬住♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚呀！？",
        "unit_id": 107811,
        "voice": "vo_adv_1075003_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙咬我！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "竟然咬著我的手指不放！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好痛好痛好痛！？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1075003_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這是老天在懲罰您打壞主意哦，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚嗚，",
        "unit_id": 107811,
        "voice": "vo_adv_1075003_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可能吧……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒事幹嘛把手放到這個吃貨的嘴邊啦，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也真蠢。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n讓她錯當成食物就咬下去了，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好痛痛痛！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔嗯。",
        "unit_id": 107611,
        "voice": "vo_adv_1075003_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不過，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天的貪吃佩可小姐好像沒什麼食慾的樣子呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果是平常的話，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "每幾分鐘就會喊著肚子餓的。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，",
        "unit_id": 107811,
        "voice": "vo_adv_1075003_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這麼說起來的確是這樣。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這傢伙，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會反常地在顧慮我們吧。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n畢竟是團體旅行嘛，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太多自我主張的話氣氛會不好的。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1075003_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然貪吃佩可小姐的食慾異於常人，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n事到如今大家卻慢慢地習以為常了呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔喵……",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小睡了一下子。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "早啊。",
        "unit_id": 107811,
        "voice": "vo_adv_1075003_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……妳這呆子，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要吃我的手指啦。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦，",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怪不得嘴巴裡面充滿了幸福的感覺！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對不起哦～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "多謝款待♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊，",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留的味道在嘴巴裡蔓延開來……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "流口水♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的肚子",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "突然餓起來了！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在時間也剛剛好，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家要不要去吃午餐？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我剛才游泳的時候，",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可是捕獲了多到數不清的新鮮海產唷☆",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈。",
        "unit_id": 107811,
        "voice": "vo_adv_1075003_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n瞧，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這不就是一如往常的貪吃佩可嗎。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1075003_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就是啊，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "反倒覺得安心了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦？",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們兩個在說些什麼悄悄話……？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "趁我在睡覺的時候感情變好，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太狡猾了！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也讓我加入話題啦～！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家一起一邊開心地聊天，",
        "unit_id": 107511,
        "voice": "vo_adv_1075003_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一邊大口吃飯，把肚子撐得飽飽的吧！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這就是【美食殿堂】、",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是我們的「日常」哦……☆",
        "unit_id": 107511
    }
]