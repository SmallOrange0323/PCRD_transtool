[
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀呀，",
        "unit_id": 117511,
        "voice": "vo_adv_5074302_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "力量變得比剛才更強大了呢。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真不愧是自稱世界支配者的傢伙呢。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳佩服個什麼勁啊！？",
        "unit_id": 117611,
        "voice": "vo_adv_5074302_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我們陷入大危機啦！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "危機？",
        "unit_id": 117511,
        "voice": "vo_adv_5074302_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳應該也多少經歷過",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一些激戰了吧？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "才這種程度就哀哀叫，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n可別想要我當妳的主治醫師喔？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……看來，",
        "unit_id": 117611,
        "voice": "vo_adv_5074302_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我好像跟很不得了的人物扯上關係了。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了我的美麗，我什麼都願意做喔。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以",
        "unit_id": 117611,
        "voice": "vo_adv_5074302_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我們趕快打倒這個肌肉怪物，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "然後妳就要當我的主治醫師！",
        "unit_id": 117611
    }
]