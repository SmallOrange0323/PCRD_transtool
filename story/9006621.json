[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，討厭，",
        "unit_id": 106011,
        "voice": "vo_adv_9006621_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這可惡的蜘蛛──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不光棘手，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還很難纏……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "若要論難纏，",
        "unit_id": 105811,
        "voice": "vo_adv_9006621_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也不會輸！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在厄莉絲小姐的防禦魔法被打破之前，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n徹底打倒阿剌克涅吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要能維持這股氣勢，",
        "unit_id": 105911,
        "voice": "vo_adv_9006621_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就一定有獲勝的機會。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了救出雪菲小姐……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n謹慎地戰鬥到最後一刻吧，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 105911
    }
]