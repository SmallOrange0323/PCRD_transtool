[
    {
        "type": "background",
        "background": "502171"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吉歐‧格黑納的公主，涅妃‧涅羅"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了開會討論發生於多個世界的異狀，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n計劃邀請三位公主前來參與。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──然而……"
    },
    {
        "type": "background",
        "background": "502301"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "──也就是說，",
        "unit_id": 126511,
        "voice": "vo_adv_2208004_000"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n吉歐‧尼布爾黑爾的公主，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n很可能被捲進了",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "某種意外當中嗎……？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……謝謝你特地來通知我們，",
        "unit_id": 127712,
        "voice": "vo_adv_2208004_001"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "意外",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "是嗎……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真令人擔心呢。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "「涅婭和卡里莎」？",
        "unit_id": 126411,
        "voice": "vo_adv_2208004_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "叫做這個名字的，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n騎士先生的朋友，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "目前也下落不明是嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n要去救他們嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……克蘿小姐。",
        "unit_id": 127812,
        "voice": "vo_adv_2208004_003"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n我們在",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "「會議」結束後，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n就要回去吉歐‧提格尼亞了喲。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "咦，",
        "unit_id": 126411,
        "voice": "vo_adv_2208004_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是這樣嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "是啊。",
        "unit_id": 127812,
        "voice": "vo_adv_2208004_005"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "關於涅妃‧涅羅皇女決定不繼續等人，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n並開始會議這點，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "說實在的，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我認為她的判斷很正確。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我說烏爾姆！",
        "unit_id": 127712,
        "voice": "vo_adv_2208004_006"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n妳也稍微擔心一下吧……！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "當然，",
        "unit_id": 127812,
        "voice": "vo_adv_2208004_007"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我也不是完全不擔心他們。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "但是……",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "比起不認識的陌生人，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n先擔心自己的腳邊比較好吧，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我是這個意思啊，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "姊姊。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "腳邊是嗎？",
        "unit_id": 126411,
        "voice": "vo_adv_2208004_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我看看喔～？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_2208004_009"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "確實，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "要是再繼續逗留下去，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n可能會讓在吉歐‧提格尼亞等待的人們",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "開始感到不安呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n雖然我很信任守護著城堡的",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沃爾加諾他們……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……那倒是……",
        "unit_id": 127712,
        "voice": "vo_adv_2208004_010"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "克蘿小姐，",
        "unit_id": 127812,
        "voice": "vo_adv_2208004_011"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "畢竟妳是萊拉耶爾殿下的護衛，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n沒辦法和騎士先生他們",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "一起去吉歐‧尼布爾黑爾的。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n雖然很令人感到遺憾。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "唔～",
        "unit_id": 126411,
        "voice": "vo_adv_2208004_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "真的太遺憾了～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "就是……",
        "unit_id": 127712,
        "voice": "vo_adv_2208004_013"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "說呀",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n畢竟我們也不清楚",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "吉歐‧尼布爾黑爾",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "究竟是什麼樣的地方。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士？",
        "unit_id": 126511,
        "voice": "vo_adv_2208004_014"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n你怎麼了嗎……？",
        "unit_id": 126511
    },
    {
        "type": "background",
        "background": "502171"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不久之前──"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "眼下僅能不湊齊「四個世界」，",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_015"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n先由三世界的公主進行會議了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "既然如此決定，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "最快明日便來召開吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──知道了。",
        "unit_id": 129612,
        "voice": "vo_adv_2208004_016"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "那麼──",
        "unit_id": 129612,
        "voice": "vo_adv_2208004_017"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "皇女。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n我立刻去找負責準備議場的小組",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "說明明天的事──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "交給汝了。",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_018"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "……那麼──",
        "unit_id": 129612,
        "voice": "vo_adv_2208004_019"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "……",
        "unit_id": 129612,
        "voice": "vo_adv_2208004_020"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "別這樣，",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_021"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "默涅。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n別用那種眼神",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "瞪著騎士閣下。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝無法獨自處理嗎？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "唔──",
        "unit_id": 129612,
        "voice": "vo_adv_2208004_022"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n並不是",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "那樣子。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──我只是，",
        "unit_id": 129612,
        "voice": "vo_adv_2208004_023"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n認為讓這個人和皇女",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "兩人獨處──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "可能不太好、",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "而已……",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──唔。",
        "unit_id": 129612,
        "voice": "vo_adv_2208004_024"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n我先",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "失陪了──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_025"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_026"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n如何呀，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家的近侍",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實為惹人憐愛吧？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "好了。",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_027"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n既然令人憐愛卻囉嗦的默涅",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "現在移開了視線──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下。",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_028"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n能勞駕恁",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "來到奴家身旁片刻嗎？",
        "unit_id": 129711
    },
    {
        "type": "still",
        "still": "220800401"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "很好，",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_029"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "很好──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n真是整齊的髮旋呢。",
        "unit_id": 129711
    },
    {
        "type": "still",
        "still": "220800402"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "…………",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_030"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如同預想一般。",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_031"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n騎士閣下身上",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並沒有「絲線」",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呢──",
        "unit_id": 129711
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "220800401"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_032"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家想起在會議開始前──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n尚有一件事",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "必須向騎士閣下致謝。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "多虧恁的人面之廣，",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_033"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "才使吉歐‧提格尼亞的賓客們",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n於此地逗留期間，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "生活不會過於乏味。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家從拿娜的陳述中有聽聞此事。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "毋須謙遜。",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_034"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "關於恁的事蹟，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家雖已從吾妹等人口中",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n聽取過諸多繁雜報告……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "但無論是鳳凰之事，",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_035"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "華音之事，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "亦或默涅之事。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n儘管只經過短暫相處，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家亦得以立刻理解",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恁是值得信賴的人物。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁的夥伴們",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_036"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "也與恁相同。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n有幸如此獲得知己，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "著實令人倍感欣慰。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……然而……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁與蘭德索爾的公主一行人",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_037"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "共同經由吉歐‧提格尼亞，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n大幅橫越世界，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "長途跋涉來到了吉歐‧格黑納──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並且先前",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_038"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "在奴家道出「吉歐‧尼布爾黑爾」之名時，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恁們似乎",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並非僅僅表現訝異……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n而是露出期盼，兩眼放光。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "沒錯──",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_039"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "看起來彷彿是",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「得到了線索」。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家明白作此提問有失禮儀，",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_040"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "但是……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "請問",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下呀。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁們究竟，",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_041"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n是為了追求何物",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "而踏上旅途的呢？",
        "unit_id": 129711
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "220800403"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "220800402"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "嗯……",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_042"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n在奴家記憶中，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那是名為【美食殿堂】之「公會」的活動目的──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "沒錯吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那麼。",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_043"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n在這吉歐‧格黑納中，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恁有與「美味的食物」",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "相遇了嗎？",
        "unit_id": 129711
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "220800401"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_044"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恁真是",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "誠實的孩子呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "對恁們而言",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_045"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "真正「美味的食物」",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n並非旅途中巧遇的稀奇食物，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "亦非極盡奢華的晚餐──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "而是意指「一家齊聚的餐桌」",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……也包含雪菲閣下的，",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_046"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "一家人。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是的。",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_047"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家有聽聞",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁們重要家人的事。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "雖然奴家對所謂的「消失」現象",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並不清楚……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "想奪回摯愛家屬的靈魂，",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_048"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n若有一線希望得以實現心願，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "人們就不得不去嘗試。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n這點從神話時代就絲毫未變。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "只不過，",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_049"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恁們的心願",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "尚未達成……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n沒錯吧？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……吉歐‧尼布爾黑爾。",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_050"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n根據妹妹傳來的「訊息」所述──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「這裡都是殭屍",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_051"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "和長得像骨頭的怪物，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "好像是個不妙的地方～」",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……她是如此描述的。",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_052"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "所謂的靈魂終將前往之地，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "或許本該像是那樣的場所。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n不過──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "設想一回。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "假若恁們在吉歐‧尼布爾黑爾，",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_053"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n順利找到雪菲閣下的魂魄……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n那之後，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁們打算如何處置呢？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "除非墮化為魔，",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_054"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "否則靈魂相當脆弱。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n倘若失去肉體容器，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "更是如此──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n甚至有人會將脫離軀體的靈魂轉化為魔力，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "趁機奪走，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家曾如此聽聞。",
        "unit_id": 129711
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而當肉體被破壞，",
        "unit_id": 106914,
        "voice": "vo_adv_2208004_055"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "亦或被殺害……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那魂魄自然也就會從身體脫離。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n人只要一死了魂魄就會脫離肉體，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這樣不難懂吧？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "儘管不知道「現實」是如何，",
        "unit_id": 106914,
        "voice": "vo_adv_2208004_056"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在這個世界中就是這樣呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n然後",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這些脫離了肉體的魂魄，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我便能將它變成「闇影」。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並且。",
        "unit_id": 106914,
        "voice": "vo_adv_2208004_057"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就像我剛剛才說過的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n「闇影」對我來講可是",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "生命力的保管庫……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是讓我可以美味地享用的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "最高級的糧食唷。",
        "unit_id": 106914
    },
    {
        "type": "still",
        "still": "220800401"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "無容器之魂魄──",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_058"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n是令人不敢貿然輕率地觸碰，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "猶如蜻蛉般飄渺的存在。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恁們有辦法",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "順利守護好嗎？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "哦？",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_059"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那究竟是",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "什麼樣的手段呢……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……哎呀。",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_060"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實在萬分抱歉。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家一時不留意，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "過於好奇了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "但……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "請將恁口中所說的準備",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_061"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "繼續藏在",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁們心中。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n就算身在奴家的城塞當中，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "目前處於非常時期，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n難保不會被有心人士",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "從旁竊聽。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "怎麼會呢──",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_062"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家才要致歉。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恁們的現況如此艱苦，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家還特地以話語陳述出口，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "還望海涵。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不過……",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_063"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "往後恁們幾位年輕人",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "倘若面臨困境，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "無論何時都歡迎來向奴家求援。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n畢竟至今為止",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家欠了恁們許多人情。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "所以，",
        "unit_id": 129711,
        "voice": "vo_adv_2208004_064"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "吶，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁呀，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n不用露出那麼悲傷的表情。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恁重要的家人",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "一定會",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "回到恁身邊的──",
        "unit_id": 129711
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "still",
