    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著來到了隔天──"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦～",
        "unit_id": 106012,
        "voice": "vo_adv_2208004_065"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n居然為了開會",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "特地改造了競技場啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "競技場……",
        "unit_id": 127712,
        "voice": "vo_adv_2208004_066"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "居然會把討伐魔物，還有妖魔人之間的決鬥當作表演。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n這在吉歐‧提格尼亞",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "是難以想像的娛樂呢……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "從「用話語進行決鬥」",
        "unit_id": 127812,
        "voice": "vo_adv_2208004_067"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "這層意義上來看，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "這裡確實是挺適合的地點。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "就今天的主旨來看的話。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "(東張西望）",
        "unit_id": 126112,
        "voice": "vo_adv_2208004_068"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n哥哥、",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "和佩可呢？",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "身為本日主要人物的公主們",
        "unit_id": 126012,
        "voice": "vo_adv_2208004_069"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n隨後才會入座中央的圓桌。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥和兩位守護騎士他們，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "似乎",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "負責擔任公主們的護衛。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話雖如此……",
        "unit_id": 105913,
        "voice": "vo_adv_2208004_070"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那可以說",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是形式上的安排而已。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n情況應該不會演變成",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "需要護衛動武。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "畢竟不只貪吃佩可小姐，",
        "unit_id": 125812,
        "voice": "vo_adv_2208004_071"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n涅妃‧涅羅小姐和",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "萊拉耶爾小姐",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也是一張一弛，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n兼備寬容與嚴格的",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "優秀君主呀。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最後一位……",
        "unit_id": 106012,
        "voice": "vo_adv_2208004_072"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n吉歐‧尼布爾黑爾的公主究竟是什麼樣的人，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我本來想趁這個機會搞清楚的說。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是啊。",
        "unit_id": 105913,
        "voice": "vo_adv_2208004_073"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望她和涅婭小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都平安無事……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……啊。",
        "unit_id": 127712,
        "voice": "vo_adv_2208004_074"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n時間好像",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "差不多到了。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我們的座位",
        "unit_id": 127812,
        "voice": "vo_adv_2208004_075"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "在那一邊，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n那麼各位，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "之後再見了。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "好的，",
        "unit_id": 125812,
        "voice": "vo_adv_2208004_076"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "琳德小姐，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "烏爾姆小姐。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n稍後再見了。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "小飯糰",
        "words": "嗶咕！",
        "unit_id": 9611,
        "voice": "vo_adv_2208004_077"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦？",
        "unit_id": 126012,
        "voice": "vo_adv_2208004_078"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n小飯糰",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "跟著過去了。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "吉歐‧提格尼亞那邊的觀眾席",
        "unit_id": 105913,
        "voice": "vo_adv_2208004_079"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只有琳德小姐和烏爾姆小姐兩位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n牠應該是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了不讓她們感到不安，而跟過去的吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟那傢伙",
        "unit_id": 106012,
        "voice": "vo_adv_2208004_080"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原本也是來自吉歐‧提格尼亞的嘛。",
        "unit_id": 106012
    },
