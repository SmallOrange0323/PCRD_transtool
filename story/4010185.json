        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "今天的練跑……",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "結束！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n咦──？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你為什麼會在這裡──？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……啊哈♪",
        "unit_id": 101731,
        "voice": "vo_adv_4010185_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "難道說是因為我生日，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以你來找我了嗎～？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒想到能跟你像這樣碰面，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "超開心的～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真多謝～♪",
        "unit_id": 101731,
        "voice": "vo_adv_4010185_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "謝謝你～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "其實呀～",
        "unit_id": 101731,
        "voice": "vo_adv_4010185_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為好久沒見到你了，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以我想說要來向星星",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "許願呢～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你看，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "今天不是七夕嗎～？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我還做了短籤哦～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 101731,
        "voice": "vo_adv_4010185_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在許願之前，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "願望就實現了呢～♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n嘿嘿♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我說",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我說，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "等等能陪我一下嗎？",
        "unit_id": 101731
    },
    {
        "type": "background",
        "background": "510362"
    },
    {
        "type": "background",
        "background": "510272"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "銀河是那個嗎──",
        "unit_id": 101731,
        "voice": "vo_adv_4010185_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n還是那個呢──？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "織女與牛郎，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "找到了嗎？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "從剛剛開始心臟就一直",
        "unit_id": 101731,
        "voice": "vo_adv_4010185_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "跳個不停啊～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "織女他們也是像這樣",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "噗通噗通跳個不停嗎～？",
        "unit_id": 101731
    },
    {
        "type": "background",
        "background": "510362"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈♪",
        "unit_id": 101731,
        "voice": "vo_adv_4010185_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對吧──！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "說你呀，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "明年也能幫我",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "慶祝",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "生日嗎──？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我想跟織女和牛郎一樣，",
        "unit_id": 101731,
        "voice": "vo_adv_4010185_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n一～直一～直，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "跟你做約定啊～♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為我，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "最喜歡你了喔～♪",
