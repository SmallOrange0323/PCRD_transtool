[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總算成功擊退牠了……",
        "unit_id": 105911,
        "voice": "vo_adv_9026156_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "附近一帶已經到處都佈滿了毒液。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您沒事吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的～",
        "unit_id": 106011,
        "voice": "vo_adv_9026156_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "清澈的泉水也被污染了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n希望不會對其他生物造成影響。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "八成是",
        "unit_id": 106011,
        "voice": "vo_adv_9026156_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有人看見巨大身影和足跡後，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就四處散布「有龍啊～」的謠言。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "害人虛驚一場！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "牠身上有這麼多毒液，",
        "unit_id": 105811,
        "voice": "vo_adv_9026156_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該沒有能吃的部位了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好失望。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "知道牠的肉不能吃以後，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得肚子越來越餓了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911,
        "voice": "vo_adv_9026156_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然這件事實在難以啟齒，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但這附近",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都是毒液，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要找到食物恐怕有困難。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼會～！",
        "unit_id": 105811,
        "voice": "vo_adv_9026156_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n龍先生～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請快點出來啊～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n肉～！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "龍肉～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106011,
        "voice": "vo_adv_9026156_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "萬一被其他魔物聽見怎麼辦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳不要叫得那麼大聲啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚～",
        "unit_id": 105811,
        "voice": "vo_adv_9026156_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是肚子咕嚕咕嚕叫的聲音停不下來嘛～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105911,
        "voice": "vo_adv_9026156_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們趕快收拾東西準備回去吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在貪吃佩可小姐的餓肚子聲",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被謠傳成",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "龍吼聲之前。",
        "unit_id": 105911
    }
]