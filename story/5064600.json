[
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "咦……",
        "unit_id": 116411,
        "voice": "vo_adv_5064600_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什麼東西？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是聖學祭的記錄本。",
        "unit_id": 116311,
        "voice": "vo_adv_5064600_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "反而該問妳怎麼會不知道？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這應該有發給所有學生才對。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這麼說來，",
        "unit_id": 116411,
        "voice": "vo_adv_5064600_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "昨天的確有",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "老師送了什麼東西來「象牙之塔」。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但我想肯定又是來催繳還沒交的論文，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就沒有打開看了。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "反正也沒差吧，",
        "unit_id": 116211,
        "voice": "vo_adv_5064600_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "上面都是些給來賓看的東西。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n實際上也是有些沒刊登在上面的祕密無趣競賽之類的。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是那種問題啦！",
        "unit_id": 116311,
        "voice": "vo_adv_5064600_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這可是刻劃了珍貴校園生活的紀念碑耶。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這可是在未來回首時，開啟記憶大門用的鑰匙。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好了學姐們！",
        "unit_id": 116311,
        "voice": "vo_adv_5064600_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們就來一起回想聖學祭的記憶熱鬧一番吧！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦哦，",
        "unit_id": 116411,
        "voice": "vo_adv_5064600_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "感覺好青春！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "聖學祭啊……",
        "unit_id": 116211,
        "voice": "vo_adv_5064600_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是可以啊，雖然我記得都沒發生什麼好事。",
        "unit_id": 116211
    }
]