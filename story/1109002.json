        "voice": "vo_adv_1109002_039"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n美衣子，不好了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n妳喜歡的人，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "講委婉一點，就是個有瑕疵的人。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "只要有愛就能克服一切",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_040"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "——雖然妳可能聽過這種街談巷議，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是，該怎麼說呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我就實話實說好了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我覺得這個難度",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好像有點太高了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還有，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_041"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我覺得他沒有妳說的那麼俊美。",
        "unit_id": 110911
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_042"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "該怎麼辦",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "才好呢……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_043"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不好意思，{player}學長，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我可以",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "再仔細問一下",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n關於你的各種事情嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯嗯……",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_044"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n原來如此，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "有那種事啊。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哦～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這樣子啊～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "然後呢然後呢？",
        "unit_id": 110911
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "美衣子。",
