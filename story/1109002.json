        "voice": "vo_adv_1109002_045"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n琪愛兒會再努力一下的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這位學長，",
