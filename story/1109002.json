[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，{player}因為工作去送貨"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而在蘭德索爾街上往返時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一名少女突然擋住了他的去路。"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～♪",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "送貨員先生，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你的工作很累人呢！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你平日工作辛苦了～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哇，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真有禮貌！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "原來如此呢，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是很保險的回應。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然以年輕人間的交流來說，感覺有點死板，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不過這情況也不期待你有什麼吸睛的即興發揮，就算你合格吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "噢，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你真配合！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "順帶一提這是琪愛兒想出來的原創招呼語。",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n請儘量使用，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "讓它成為流行吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～♪",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "順帶一提我是",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_006"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "聖德蕾莎女子學院閃亮亮的一年級生，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n再順帶一提我的暱稱有",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕、切嚕蹦等等很多其他的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對了，學長，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你叫做什麼學長啊？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哇，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真棒的名字～！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "第一次聽說～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嘿嘿嘿，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然我早就知道了啦……！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "總算見到你了呢，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_009"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "{player}學長。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "苦苦等了30分鐘，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在暗處邊吃紅豆麵包，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "邊在美衣子家的郵筒盯哨總算值得了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "開始打發時間吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我的名字是",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "戀愛的一日傳教士琪愛兒！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n美衣子草率的心意，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "給我牢牢接住吧！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好的～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那就再見了～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "等等！",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不不不，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_013"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "請等一下請等一下。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我們話不是還沒有說完嗎。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n應該說我們根本都還沒開始說不是嗎。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_014"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不是，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就算你問我有什麼事……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我實在是不好說……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "俗稱毫無計畫。",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_015"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怎麼辦。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然發現了目標，就順勢去糾纏他了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n可是老實說，我根本什麼都沒多想啊……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然埋伏成功是很棒，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_016"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "問題是",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這之後的事情呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "接下來要怎麼聊到美衣子呢？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯……",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_017"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "而且美衣子她們已經告訴過我不可以直接開門見山了啊～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "唉，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_018"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "算囉，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就這樣憑著興致和氣勢隨意地聊聊就好了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "幸好興致和氣勢還有隨意都是我擅長的領域。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個啊～？　",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_019"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "總覺得～？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n今天的天氣真的非常好呢～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n啊，是啊，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是說啊，這天氣很舒服。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我懂～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "欸，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_020"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你最近過得怎樣？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "馬馬虎虎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哇，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我也是。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒也是馬馬虎虎。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "簡稱切嚕馬虎～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對了，{player}學長現在在做什麼？",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_021"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n工作嗎？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊啊，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "送貨的工作！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n說的也是，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊哈，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我知道的～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯……",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_022"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這是什麼平淡的對話。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這毫無內容的程度真是快嚇死我了……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_023"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "只靠一時興起隨意聊聊，會這樣也是正常的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "再加上對方也是個問題，總覺得他每個反應都很平淡。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然說……",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_024"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "很平淡，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但也不是不親切的感覺，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "該怎麼說，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "有點捉摸不定……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n與其說是語氣，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "應該說是整體的感覺？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "感覺",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "整個人",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "都很難以捉摸。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊啊，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_025"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這麼說來，美衣子好像說過。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n說從未見過他這種類型的男生。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這樣說來……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好像的確",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是這樣耶？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_026"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好的～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那再見囉～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_027"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我就說了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n學妹我還在說話耶。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "話說回來，{player}學長，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_028"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你真厲害呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n被長得這麼可愛的超級美少女搭話，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n竟然可以毫不留戀地半途離開呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你沒問題嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "男生一般都會很積極糾纏琪愛兒耶。",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_029"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你不會嗎？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是，不會是很好，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是你不會嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就是那種",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "會一直抓住機會，用煩人的方式展現自己之類的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "什麼感覺嗎……",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_030"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "呃……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就例如說，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n會在看似一般的自我介紹裡面，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不經意暗示自己條件多好的那種煩人傢伙啊。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是常會有嗎？",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_031"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那種在提到自己家鄉或現在住處的時候，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n一臉高高在上講出高級住宅區的名字來展現優勢的人。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好像想起了什麼，有種喉頭被哽住的感覺……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_032"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "{player}學長住在哪裡啊？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊？",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_033"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "呃……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也就是說",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你沒有",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "固定住處？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "連家鄉在哪也不知道……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "為什麼……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "原因是？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊……",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_034"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "什麼？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "失去記憶！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n什……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那是怎樣？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n咦？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "以前的事你完全不記得了嗎？",
        "unit_id": 110911
    },
    {
