        "voice": "vo_adv_1109002_048"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我覺得他並不太像是壞人。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我想他只是因為他特殊的背景，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "讓他生活得有點笨拙，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n但並沒有做出什麼",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "觸犯法律或違背倫理",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "的事情。",
