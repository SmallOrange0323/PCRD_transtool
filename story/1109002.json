        "voice": "vo_adv_1109002_049"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這樣啊……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n那就是說？　",
