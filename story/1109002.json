        "voice": "vo_adv_1109002_046"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n以一個人來說或許有些難以捉摸，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n而且還是個沒有家也沒有記憶",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "的特賣型男子。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還有，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_047"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "他或許沒有妳說的那麼俊美。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是，",
