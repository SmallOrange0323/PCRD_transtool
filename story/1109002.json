        "voice": "vo_adv_1109002_053"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "根本是真的有問題啊！！！",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_054"
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "美衣子。",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_055"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n承蒙照顧，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我是聖德蕾莎女子學院的琪愛兒。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n關於妳所委託的事情，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "請容我跟妳報告調查結果。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "判決是",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_056"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "——不行。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不行的。",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_057"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳放棄吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這人不行。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這名調查對象，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "講委婉一點是個爛人。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "他做出違反公序良俗的骯髒行為還若無其事地炫耀，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_058"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n根本是前所未聞的",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大變態神經病。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_059"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "呃，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然是我要他說出來的，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但一般被人問到的時候，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "會嘰哩呱啦地說這麼多嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n他那樣不就像是在對我說「請妳去報警吧」一樣嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個人",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_060"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "有些缺乏身為變態的自知之明呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我想如果我是個變態，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n是絕對不會把那種祕密告訴其他人的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "……嗯？　",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_061"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也就是說？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "如果反過來說？",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_062"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n能和別人嘰哩呱啦地說這麼多",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就表示，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n他",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "完全沒有",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "感到",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "心虛……？　",
        "unit_id": 110911
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "……那個，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_063"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不好意思，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_064"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "剛才那件事，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n為了保險起見，可以再詳細的跟我說一次嗎？",
        "unit_id": 110911
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "前略，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_065"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "美衣子。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我剛才",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_066"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "完成了與目標的第一次接觸。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n接著，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我要告訴妳我個人對於目標的感覺。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "暫定評價",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_067"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "——接近不可的可。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "偵訊結果，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_068"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嫌犯{player}是無罪的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n說好聽點是單純，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "說難聽點就只是個濫好人。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "總之，雖然他是個怪人，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_069"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但似乎並不是壞人。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，",
        "unit_id": 110911,
        "voice": "vo_adv_1109002_070"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "他並沒有妳說的那麼俊美。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "以上。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「世界上還真是很多怪人呢。」"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n琪愛兒這麼想著，腳步輕盈地踏上回家之路。"
    }
]