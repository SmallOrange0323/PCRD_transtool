        "voice": "vo_adv_1109002_037"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好像",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
