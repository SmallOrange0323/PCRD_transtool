        "voice": "vo_adv_0001002_030"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雪菲真的好可憐！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這麼好的孩子，",
