        "voice": "vo_adv_0001002_041"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n沒關係，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "照這種調調，只是在說些廢話罷了。",
