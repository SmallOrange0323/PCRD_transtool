        "words": "登場……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我開玩笑的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是說啊。",
