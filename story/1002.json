        "voice": "vo_adv_0001002_034"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我有時是可麗餅店的店長，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n有時是祕密結社拉比林斯的公會長，",
        "unit_id": 106812
