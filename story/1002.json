    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n剛剛那是什麼，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是魔法？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "魔術？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "幽靈？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n到底是……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "腳底下是不是有聲音響起？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "物件變更！？",
        "unit_id": 106412,
        "voice": "vo_adv_0001002_046"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n拉比林斯達為了逃走，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "竟然做到這般地步！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "她剛才",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一定是利用七冠的權能，將這底下移動到某處去……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110812,
        "voice": "vo_adv_0001002_047"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "迷宮的女王，就是……",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這種作法，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真的是這樣。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n她是個可以很快破解迷宮遊戲的人，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就像解謎王那樣。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯……",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真是個有趣的女人。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此，",
        "unit_id": 111011,
        "voice": "vo_adv_0001002_048"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我了解了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是她給我們的戰帖！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "渴望獲得的獎勵，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "將會給予捕捉到女王的人！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "走吧，各位！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊！",
        "unit_id": 110911,
        "voice": "vo_adv_0001002_049"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那兩個人真奸詐，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "竟然偷跑！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喂，等等──！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是這樣嗎！？",
        "unit_id": 106412,
        "voice": "vo_adv_0001002_050"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這也就是說，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也包含在內！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "請、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "請等一下，各位～！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "別丟下我啊～！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n因為我也想要",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "成為隊長～！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，雪菲與好朋友社的成員們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了找出逃走的拉比林斯達，各自跑了起來。"
    }
]