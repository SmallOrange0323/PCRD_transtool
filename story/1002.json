    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n對於像這樣為了保命而失控的遭遇，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "女高中生的各位會怎麼想呢？",
