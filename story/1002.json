[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在【美食殿堂】和【破曉之星】的成員們"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n體驗拉比林斯達製作的不可思議的遊戲世界後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n又過了一段日子──"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "來吧、來吧，歡迎光臨！",
        "unit_id": 106812,
        "voice": "vo_adv_0001002_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們有很好吃的美味可麗餅喔～！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳好，",
        "unit_id": 106412,
        "voice": "vo_adv_0001002_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "拉比林斯達小姐。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雪菲！",
        "unit_id": 106812,
        "voice": "vo_adv_0001002_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "今天想吃什麼？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃，",
        "unit_id": 106412,
        "voice": "vo_adv_0001002_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我不是來點餐的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗨。",
        "unit_id": 111011,
        "voice": "vo_adv_0001002_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳好──。",
        "unit_id": 110812,
        "voice": "vo_adv_0001002_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～☆",
        "unit_id": 110911,
        "voice": "vo_adv_0001002_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "優妮們的各位～！",
        "unit_id": 106812,
        "voice": "vo_adv_0001002_007"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大家過得好嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呃……",
        "unit_id": 110812,
        "voice": "vo_adv_0001002_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "姐姐，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "一點都不好。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n可以請妳不要",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "一開始就貶損我們的公會名稱嗎？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這可是歧視喔。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "具歧視性的發言將會牽扯到法規喔。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣啊？",
        "unit_id": 106812,
        "voice": "vo_adv_0001002_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真奇怪～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我印象中，少年有時也會這樣稱呼妳們啊……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911,
        "voice": "vo_adv_0001002_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那位學長可能有這樣的習慣。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就像是小孩子",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "會一直反覆地唸著粗俗用語一樣。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n再不然就是拉比姐姐的錯覺，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "俗稱幻聽。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "拉比林斯達博士，",
        "unit_id": 111011,
        "voice": "vo_adv_0001002_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳看看。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n任意地扭曲事實，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然後當成真相來傳講──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "簡直就像是這個世界的縮圖。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我可不認為這是傻里傻氣。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐，",
        "unit_id": 110911,
        "voice": "vo_adv_0001002_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不好了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n因為與能抓住人心的公會名相聲錯身而過，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n優妮學姐吐槽的矛頭終於往莫名的方向去了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "客人要求的是流行文化，",
        "unit_id": 110812,
        "voice": "vo_adv_0001002_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "卻以藝術路線為目標……",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "她就像是這樣的人。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "別管她了，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等她玩夠了就會回來。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，",
        "unit_id": 106412,
        "voice": "vo_adv_0001002_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n各位，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "差不多該進入正題了吧……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "正題？",
        "unit_id": 106812,
        "voice": "vo_adv_0001002_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳們還真是稀奇的組合。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果有事找我……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對了，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是有關遊戲的事吧？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳很敏銳！",
        "unit_id": 110911,
        "voice": "vo_adv_0001002_016"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒錯。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我不想直接說謝謝！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "很切嚕感謝妳這次把我們加入角色群！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "能夠再次重現琪愛兒的完美可愛模樣，根本就是神了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說回來，",
        "unit_id": 110812,
        "voice": "vo_adv_0001002_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "戰鬥很熱血呢。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "該怎麼說呢，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "絕妙嗎？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "像我的弟弟們，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "基本上都吵吵鬧鬧的，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n但也會有緊張屏息的瞬間。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，的確可以玩一輩子呢。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "正是。",
        "unit_id": 111011,
        "voice": "vo_adv_0001002_018"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "勝負單純只是時運好壞，或是太過小看對手，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但藉由智力的干涉來改變戰況，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "想不到就成了令人熱血沸騰的戰鬥。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n講白一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是會讓人上癮。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "拉比林斯達，",
        "unit_id": 106412,
        "voice": "vo_adv_0001002_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝妳遵守了那時候的約定。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "讓我的角色",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也能和大家一起戰鬥。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "即便知道那不是我本人，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是會忍不住幫大家加油。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣啊。",
        "unit_id": 106812,
        "voice": "vo_adv_0001002_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳們可以玩得開心，真是太好了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能夠獲得玩家直接回饋的心得，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是開發者最大的幸福。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "全都用完吧！",
        "unit_id": 110911,
        "voice": "vo_adv_0001002_021"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳就把福氣全都用完吧！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳才做了這麼一點工作！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喂，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳這個天才創作家！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n雖說只有一個大問題，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳就別放在心上，連接上明天吧！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "問題？",
        "unit_id": 106812,
        "voice": "vo_adv_0001002_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是奇怪，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我已經很仔細地四處檢查過了啊……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "博士，",
        "unit_id": 111011,
        "voice": "vo_adv_0001002_023"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這沒有什麼好放在心上的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們都知道，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "人不是完美的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這只不過是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "無意間所犯的失誤，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "只要立即改善就可以了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，",
        "unit_id": 110812,
        "voice": "vo_adv_0001002_024"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可是，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "當我知道有那個漏洞時，真的很震驚。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "想不到",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個拉比姐姐也會有粗心大意的時候。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這怎麼可能，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "竟然會忘了把我們實際安裝成隊長。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，博士，",
        "unit_id": 111011,
        "voice": "vo_adv_0001002_025"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們不是想指責妳，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "請不要啞口無言。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n妳肯定累了吧，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這我們都知道。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然我們都知道……",
