        "voice": "vo_adv_5137301_006"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "會被附身……",
        "unit_id": 135616,
        "voice": "vo_adv_5137301_007"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是我們的，",
        "unit_id": 135616
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "疏忽……",
        "unit_id": 135616
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "所以，",
        "unit_id": 135514,
        "voice": "vo_adv_5137301_008"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不用在意我們……",
        "unit_id": 135514
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好嗎？",
        "unit_id": 135514
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳們兩個……",
        "unit_id": 128711,
        "voice": "vo_adv_5137301_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我明白了。",
        "unit_id": 128811,
        "voice": "vo_adv_5137301_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n讓我們心無顧慮地戰鬥吧！",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………好……",
        "unit_id": 135616,
        "voice": "vo_adv_5137301_011"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n不必……",
        "unit_id": 135616
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "掛心……",
        "unit_id": 135616
    }
]