        "unit_id": 101011,
        "voice": "vo_adv_3004002_080"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n拜託小心不要太粗魯，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不要受傷了喔～？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要是我們太粗暴，",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_081"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n擾亂城鎮治安就本末倒置了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可是真是無法理解，",
