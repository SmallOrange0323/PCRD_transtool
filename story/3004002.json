        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家一起散步，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n好開心～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "名義上不是散步，",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n而是巡邏喔。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不是只有開心地走走路，",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "至少要注意一下有沒有奇怪的傢伙啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我知道啦～",
        "unit_id": 101711,
        "voice": "vo_adv_3004002_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "船到橋頭自然直囉～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真的知道嗎？",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳還真的是隨便啊……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好吧。",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n只要我好好巡邏就好了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哈哈～",
        "unit_id": 101711,
        "voice": "vo_adv_3004002_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n今天真琴也一起來散步，我好高興喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳平常到晚上就離開了呢♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊……",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n因為有居酒屋的工作，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "今天因為店裡公休所以可以一起來。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……喂，步調稍微慢一點。",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "快丟下公主和霞了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n妳們要小心，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不要把距離拉太遠了喔？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "霞到了晚上似乎就看不大清楚。",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要是跌倒就不好了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以我們輕鬆地慢慢走吧～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哈哈～ ",
        "unit_id": 101711,
        "voice": "vo_adv_3004002_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n霞是因為",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "看書看到眼睛壞掉的吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才不是呢。",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n與其說我眼睛不好，其實是妳們眼睛太好了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過呢，的確無法否認我有點近視。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "話雖如此，",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有需要的時候只要用魔法加強視力就沒問題了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過我不會說大家的關心是多餘的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "先別管這個，",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們這麼一大群人",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n走來走去也不是辦法吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "蘭德索爾範圍這麼大……",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們應該分配負責的地區，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n更有效率地進行巡邏。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗄～？",
        "unit_id": 101711,
        "voice": "vo_adv_3004002_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n大家一起散步",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "很快樂啊～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是工作呀，",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n快不快樂應該不是最重要的吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過呢，這裡也有其他公會的地盤。",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們只要在公會小屋的附近……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n巡邏獸人的居住地區就好了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是單獨碰到【王宮騎士團】，",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n是很危險的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那群人可是把我們當敵人看的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是我們和其他公會吵起來，",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓治安變差的話就本末倒置了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哼嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n沒想到有點道理，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳們總是本能地選擇最正確的答案呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "說『妳們』，好像跟妳沒關係一樣～",
        "unit_id": 101711,
        "voice": "vo_adv_3004002_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n霞也已經是【哞哞自衛隊】的一員囉～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "希望妳能更加敞開心扉呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是吧～",
        "unit_id": 101711,
        "voice": "vo_adv_3004002_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好朋友〜♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗚哇，不要一把抱過來！",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳有點肉麻當有趣欸？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "（唔。",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不過大家爽快接納像我這樣有溝通障礙的人，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我實在很開心……）",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "（不行這樣啊，總是不小心就想跟別人吵架。",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "明明已經不是在個人公會了。）",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "（明明已經有夥伴了。",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我應該要表現得更平易近人一點才好吧……？）",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？",
        "unit_id": 101711,
        "voice": "vo_adv_3004002_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家快看，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n是誰蹲在那邊的巷口呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "喔喔。",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n竟然可以發現那個。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "香織真是好孩子、好孩子♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘻嘻～♪",
        "unit_id": 101711,
        "voice": "vo_adv_3004002_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我先去了解狀況喔～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n大家先待在這裡！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂喂。",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_031"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不要一個人跑掉啊，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一起去吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "以防萬一，",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_032"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n公主妳們請在這裡等。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是發生什麼事，再拜託妳們支援。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好。",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴也要",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n小心啊～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然大家都說城鎮裡很安全，",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但最近開始出現『闇影』，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以還不能完全放心唷？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好的。",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_035"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……喂，在那裡的傢伙！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n慢慢舉起雙手，跪下！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們是【哞哞自衛隊】！",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_036"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n可疑的傢伙在那裡做什麼！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "唉呀呀～？",
        "unit_id": 101711,
        "voice": "vo_adv_3004002_037"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n還以為是誰呢，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是你呀～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，真的耶……",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_038"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你在這小巷裡",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n做什麼啊？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎麼了？",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，王子先生！",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "晚安～……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "大家都認識他啊？",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_041"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，和霞是第一次見面吧？",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這位是",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_043"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n從遙遠的遠方前來迎接真步公主的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生～……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "欸。",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_044"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n又是妄想中的故事嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿～♪　",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n只要有一個人相信的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就不是妄想，會變成現實喔～？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生、王子先生，您在做什麼呢？",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在尋找閃耀著彩虹色澤、飄散著戀愛鱗粉的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n妖精嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那可不行唷。",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_047"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妖精們",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n得用幸福感編織的鳥籠關起來才行～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "用白話文說，",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_048"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "大概是『錢掉了嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n應該要好好收在錢包裡才行呀？』",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這個意思吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有時候",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_049"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我們公會長說的話真的很難理解呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，雖然也不到完全無法解讀。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你……",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_050"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n希望你好好說明狀況。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "尋找失物是我的拿手項目，我可以幫你喔？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也很擅長。",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_051"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我可以暫時將嗅覺強化為一般人的十萬倍。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "追蹤你的氣味找到東西喔。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "掉了什麼東西啊？",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_052"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還是說",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你有其他困擾嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～",
        "unit_id": 101711,
        "voice": "vo_adv_3004002_053"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我不太會找東西，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以我來幫大家加油囉～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "香織，可不行跳舞喔。",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_054"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要是亂動的話，說不定會踢飛要找的東西呢～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "很感謝妳為大家加油的心意♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～因為是王子先生，",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_055"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n說不定是打開了異次元的大門，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以重要的東西就消失在那一端了？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真可憐呢。",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_056"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只能用愛的力量來引導……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，完全不懂意思。",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_057"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯、嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_058"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你最近是不是常常掉東西？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不知不覺中就找不到衣服或小東西之類的？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "隨手物品今天又被偷走了嗎？",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_059"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～……看來蘭德索爾的治安真的變差了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n最近竊盜的報告也越來越多了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然不至於鬧出人命，",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_060"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n但是不是應該認真地展開調查呢……公主？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總覺得有些不好的預感呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是啊。",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_061"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們的公會小屋",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n也發生過同樣的事對吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家很喜歡的蕾絲手帕",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_062"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不知何時就突然不見了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯……我們居酒屋也有類似的事情，",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_063"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "被認為是小偷和東西被偷的客人之間發生了爭吵。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我還以為這只是不小心發生的事呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯……",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_064"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這些竊盜事件是最近才變多的吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不得不懷疑和『闇影』之間的關聯性。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "正好和那個開始經常出現的時期一致。",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_065"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n在發生竊盜事件的附近，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n『闇影』的目擊情報也變多了對吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_066"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n所以是『闇影』",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "偷了東西嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一般認為那或許說是自發性的意志，",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_067"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n或是說牠不具有智力。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然不大覺得『闇影』是",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_068"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n出自什麼目的，而犯下竊盜。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過就像是小鳥，",
        "unit_id": 101411,
        "voice": "vo_adv_3004002_069"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n為了築巢也會拿走一些什麼東西。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "欸、欸！",
        "unit_id": 101711,
        "voice": "vo_adv_3004002_070"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n大家可以聽我說句話嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "幹什麼呀，香織。",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_071"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "大家現在正在思考事情呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哈哈～沒有頭緒的話也只是浪費時間呀～",
        "unit_id": 101711,
        "voice": "vo_adv_3004002_072"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "話說回來，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n那邊有『闇影』呢？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔，真的耶！",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_073"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n香織真的非常眼尖耶！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個『闇影』",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_074"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n手上好像拿著什麼東西。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……哼嗯。",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_075"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那是你在找的",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n東西嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～",
        "unit_id": 101011,
        "voice": "vo_adv_3004002_076"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n果然是『闇影』",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n四處偷竊各種東西的樣子呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那得再釐清才行……",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_077"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總之",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n先抓下『闇影』吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等等！",
        "unit_id": 104311,
        "voice": "vo_adv_3004002_078"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓我幫忙拿回那重要的東西♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～先搶先贏囉～！",
