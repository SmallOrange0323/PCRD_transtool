        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "如果會妨礙到安，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我也知道我還是退到一邊比較好。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "但是，",
