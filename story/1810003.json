    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這天──{player}等人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n收到公會管理協會的緊急召集，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到職員所在之處。"
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "謝謝",
        "unit_id": 1,
        "voice": "vo_adv_1810003_000"
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "各位撥冗前來。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "\n其實……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "「未知的巨大生物",
        "unit_id": 1,
        "voice": "vo_adv_1810003_001"
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "正從加托羅斯山上往山下移動」，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "\n我們之前收到這樣的通報，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "並派了數人前去處理……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "然而",
        "unit_id": 1,
        "voice": "vo_adv_1810003_002"
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "討伐以失敗告終。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "\n由於損傷太過慘重，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "\n在那之後，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "沒有人願意承攬這個委託……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "但是，",
        "unit_id": 1,
        "voice": "vo_adv_1810003_003"
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "根據花凜小姐所言，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "如果是各位的話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "\n說不定會願意接下委託──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "加托羅斯山……",
        "unit_id": 109411,
        "voice": "vo_adv_1810003_004"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "未知的巨大生物……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "……安。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "是巨靈呢。",
        "unit_id": 109211,
        "voice": "vo_adv_1810003_005"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n明明至今為止都沒有感受到它要離開山的氣息……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我記得在山腳下",
        "unit_id": 109411,
        "voice": "vo_adv_1810003_006"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "有一些",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "村落……？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "如果巨靈下山的話……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "那些村落抵擋不了多久的。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "現在馬上準備出發吧。",
        "unit_id": 109211,
        "voice": "vo_adv_1810003_007"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "……要是",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "貪吃佩可她們也在的話就好了。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "是啊。",
        "unit_id": 109411,
        "voice": "vo_adv_1810003_008"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "但是貪吃佩可她們",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "和露一起去離島了……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "就算用通訊魔法聯繫上她們，",
        "unit_id": 109211,
        "voice": "vo_adv_1810003_009"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n也沒有時間等她們回來了呢……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "……沒辦法了，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "就我們自己去吧！",
        "unit_id": 109211
    },
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭、安",
        "words": "……咦！？",
        "unit_id": 1,
        "voice": "vo_adv_1810003_010"
    },
