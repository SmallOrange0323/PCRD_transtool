    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "被安丟下，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "讓我感到有點寂寞。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "但是呢，",
