[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "滿溢著人們笑容的蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在一片祥和的街道上，兩名少女正在散步。"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謝謝妳今天邀請我，",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "栞。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n度過了一段非常有意義的時間呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那真是太好了。",
        "unit_id": 103811,
        "voice": "vo_adv_5033000_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為之前霞",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳有說過，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳也喜歡",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這本推理小說……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是第一次參加作者簽名會，",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但沒想到那裡的氣氛那麼友善，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是一次很有意思的體驗呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也是，",
        "unit_id": 103811,
        "voice": "vo_adv_5033000_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然只能在身體狀況良好的時候去參加就是了，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n今天多虧了霞願意陪我過來呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒什麼，",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "舉手之勞而已。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n對了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果栞妳方便的話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n等等要不要去哪裡坐坐，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好好地聊一聊作品呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇，",
        "unit_id": 103811,
        "voice": "vo_adv_5033000_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "當然好……！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這本推理小說，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "裡面的詭計非常有趣，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我一直想跟人",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好好聊聊呢……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "的確很離奇，",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且也很嶄新呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "用流星群來設計的時間差的詭計，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是前所未聞——",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "栞，",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳看到了嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n剛剛空中",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有道光……",
        "unit_id": 101411
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "魔法……？",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "少女……？",
        "unit_id": 103811,
        "voice": "vo_adv_5033000_009"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "沒錯！　",
        "unit_id": 4211,
        "voice": "vo_adv_5033000_010"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "純潔的心靈跟",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "可愛的容貌！　",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "還有",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "那滿溢而出的無盡的愛！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "為了和平而奮戰，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "那就是魔法少女喔！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "栞。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n妳聽得懂",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這隻魔法生物",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在說什麼嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我有點，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不太能夠理解缺乏邏輯的話呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個……",
        "unit_id": 103811,
        "voice": "vo_adv_5033000_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "摩拉，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n為什麼",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會找上我跟霞呢……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "因為魔法國度的女王是這麼說的！",
        "unit_id": 4211,
        "voice": "vo_adv_5033000_013"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n世界上一定會有",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "願意幫助我們的人！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "小霞跟小栞！",
        "unit_id": 4211,
        "voice": "vo_adv_5033000_014"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n妳們剛剛",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "救了被困住的我對吧？",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "我覺得",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "這一定就是命運！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "我的直覺告訴我！　",
        "unit_id": 4211,
        "voice": "vo_adv_5033000_015"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "妳們一定就是",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "我正在尋找的",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "魔法少女不會錯的！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不，",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這不管怎麼想",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都只是純粹的偶然而已……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……不對，霞。",
        "unit_id": 103811,
        "voice": "vo_adv_5033000_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "魔法少女的故事",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一直都是從這種偶然開始的……！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n跟可愛的吉祥物邂逅之後，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "瞬間改變了曾經平凡的每一天——",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哇，",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒想到栞妳",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這麼會說耶……！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 103811,
        "voice": "vo_adv_5033000_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不是……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為我之前有讀過「魔法少女鈴鈴噹」，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一不小心就……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "能夠熱烈的談論是件好事啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然後呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果是魔法少女的故事，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "接下來會怎麼樣？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯～",
        "unit_id": 103811,
        "voice": "vo_adv_5033000_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "跟吉祥物邂逅之後，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n幾乎——",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "！　",
        "unit_id": 4211,
        "voice": "vo_adv_5033000_022"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "這股邪惡的氣息……",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "兩位請小心，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "那個就在附近！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "——都會出現",
        "unit_id": 103811,
        "voice": "vo_adv_5033000_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "敵人呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我懂了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "話說回來，",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在這種大街上",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "居然會出現魔物？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "警備是怎麼了……！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且那種魔物，",
        "unit_id": 103811,
        "voice": "vo_adv_5033000_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n連在書裡也沒有看過……！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "果然出現了嗎！",
        "unit_id": 4211,
        "voice": "vo_adv_5033000_027"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n那個是反逆獸！　",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "是會為這個世界",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "帶來災厄的存在！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "又是魔法生物又是反逆獸，",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還真是靜不下來呢……！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 103811,
        "voice": "vo_adv_5033000_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳快看，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "霞！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……嗯？",
        "unit_id": 101411,
        "voice": "vo_adv_5033000_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有誰",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "正在跟反逆獸戰鬥……？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "栞",
