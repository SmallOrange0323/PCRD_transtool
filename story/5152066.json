    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "初夢への願い事、",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_000"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "か……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "望んだ夢が見られたからって、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n実現するかどうかは別問題なんでしょうけど。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "でも、",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_001"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "こういうのって気持ちが大切よね？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "さて、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "問題は……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "結婚を願うべきか、",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_002"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "研究の進展を願うべきか。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "まずは自問自答してみましょう……",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "513406601"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "よく考えなさい、",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_003"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "ミツキ。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "\n人は生きていく限り孤独なのよ。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "だから結婚なんて諦めて、",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "科学研究に身を捧げるべきよ。",
        "unit_id": 117511
    },
    {
        "type": "still",
        "still": "513406602"
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "いいえミツキ、",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_004"
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "研究だけの人生なんてむなしいだけよ。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "今からずっと年齢を重ねたときのことを考えなさい。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "食卓についているのが一人だけなんて、",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_005"
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "\nきっと耐えられないわ。",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "513406603"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "惑わされないで。",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_006"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "研究によって",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_007"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "新たな医療技術を確立できれば、",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "たくさんの命を救えるし、",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "富と名声も得られるのよ？",
        "unit_id": 117511
    },
    {
        "type": "still",
        "still": "513406604"
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "でも、その喜びを分かち合うパートナーはいない。",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_008"
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "そもそも私は",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_009"
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "富や名声のために研究をしていたのではないはず。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "結婚できない現実に、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "言い訳をしているだけよ。",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "513406605"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "それは極めて自罰的",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_010"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "かつ主観的な発想ではないかしら。",
        "unit_id": 117511
    },
    {
        "type": "still",
        "still": "513406606"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "まるで人生における幸福が、",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_011"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "家庭を持つことだけに",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "\n依存しているような物言いは",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "多様性を否定しているわ。",
        "unit_id": 117511
    },
    {
        "type": "still",
        "still": "513406607"
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "でも結婚できるチャンスが",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_012"
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "\nあったら",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "してたわよね？",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "513406608"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "そういう正論は自分の心を",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_013"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "\n引き裂くだけだと思わない？",
        "unit_id": 117511
    },
    {
        "type": "still",
        "still": "513406609"
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "自分で自分の心を引き裂かなくても、",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_014"
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "\n定期的に届く知人からの結婚ハガキで",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "既に心はズタズタよ。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "分かったら意地を張らずに、",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_015"
    },
    {
        "type": "dialogue",
        "name": "結婚派ミツキ",
        "words": "\n素直に結婚を願って……",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "513406610"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "待ちなさい。",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_016"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "\nそれは結論を急ぎすぎているわ。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "ここはまず、",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_017"
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "幸福の本質を",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "\n再定義するところから始めて、",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "その上で",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派ミツキ",
        "words": "結婚か研究かの二択を……",
        "unit_id": 117511
    },
    {
        "type": "still",
        "still": "513406611"
    },
    {
        "type": "dialogue",
        "name": "脳内ミツキたち",
        "words": "結婚……",
        "unit_id": 1,
        "voice": "vo_adv_5134066_018"
    },
    {
        "type": "dialogue",
        "name": "脳内ミツキたち",
        "words": "研究……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "脳内ミツキたち",
        "words": "結婚……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "脳内ミツキたち",
        "words": "\n研究……！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "脳内ミツキたち",
        "words": "結婚……！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "脳内ミツキたち",
        "words": "研究……！\n結婚！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "脳内ミツキたち",
        "words": "研究！　結婚！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "脳内ミツキたち",
        "words": "研究！",
        "unit_id": 1
