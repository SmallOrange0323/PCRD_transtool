    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "脳内会議をしていたら、",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_020"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "一睡もできなかったわ……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n初夢を見るどころか、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "ぐったりして全身がだるい……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "でも、",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_021"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "この迷いこそが",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "答えってことね。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "研究も結婚も、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "同じくらい大切にしたいってことなのよ。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "それが分かっただけでも、",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_022"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "意味があったということにしましょう。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "新しい一年を過ごす、参考にはなるでしょうしね♪",
        "unit_id": 105111
