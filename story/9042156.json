        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠跑了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "累死了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 105911,
        "voice": "vo_adv_9042156_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是危險的魔物。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有受傷吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我沒事。",
        "unit_id": 106011,
        "voice": "vo_adv_9042156_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳呢？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也沒事。",
        "unit_id": 105811,
        "voice": "vo_adv_9042156_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是稍微鬆懈了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可能就被反將一軍了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的很驚險。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是呀。",
        "unit_id": 105911,
        "voice": "vo_adv_9042156_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n深切了解到",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "狼的可怕之處。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "牠果然",
        "unit_id": 105811,
        "voice": "vo_adv_9042156_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是肚子餓了吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我在想牠恐怕是……",
        "unit_id": 105911,
        "voice": "vo_adv_9042156_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把我們",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n誤認成嬌小方便食用的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "格里芬了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此～",
        "unit_id": 105811,
        "voice": "vo_adv_9042156_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果餓過頭，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n確實是會變得有點急性子。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "少在那裡對魔物的食慾表示諒解啦……",
        "unit_id": 106011,
        "voice": "vo_adv_9042156_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105811,
        "voice": "vo_adv_9042156_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們只要維持這身裝扮，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺牠們又會自己跑來耶！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次一定要",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "成功吃到！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到時候，就在這座雪山上一決勝負，",
        "unit_id": 105811,
        "voice": "vo_adv_9042156_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "決定誰是獵物，誰是捕食者！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼",
        "unit_id": 106011,
        "voice": "vo_adv_9042156_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳興致會這麼高昂啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "走到哪都這個樂天。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106011,
        "voice": "vo_adv_9042156_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "下次碰到了確實得好好收拾掉。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也不想一直被盯上。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦～♪",
        "unit_id": 105811,
        "voice": "vo_adv_9042156_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對於吃魔物幹勁十足呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那麼，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們一起來想想",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要做成什麼料理吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "火鍋之前已經吃過了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要吃什麼好呢♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那還用問，",
        "unit_id": 106011,
        "voice": "vo_adv_9042156_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "當然是烤得香氣十足，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或是燉得非常入味……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我剛才只有說要收拾牠，根本沒有說要吃牠好嗎！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物料理我可是敬謝不敏喔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……呵呵，",
        "unit_id": 105911,
        "voice": "vo_adv_9042156_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵呵。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這才是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【美食殿堂】",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀……♪",
        "unit_id": 105911
