[
    {
        "type": "dialogue",
        "name": "巴西利斯克‧阿洛斯",
        "words": "咕咕嘟嚕嚕嚕嚕嚕嚕啊啊啊啊啊啊！",
        "unit_id": 18011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……這魔物，",
        "unit_id": 6111,
        "voice": "vo_adv_5132301_000"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "跟一般的巴西利斯克完全不同，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "實在太過於危險了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "陛下、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這作為對手太不利了，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我們準備撤退──",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不，我是不會逃的，",
        "unit_id": 128011,
        "voice": "vo_adv_5132301_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不如說，我不能逃啊。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n瞧，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳看看陛下的樣子。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 127911,
        "voice": "vo_adv_5132301_002"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那是……",
        "unit_id": 6111,
        "voice": "vo_adv_5132301_003"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "在思考",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "菜單呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那麼強大的怪物就在面前，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "竟然依舊在想美食……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是吧？",
        "unit_id": 128011,
        "voice": "vo_adv_5132301_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "所以我該做的事只有一件，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那就是竭盡全力協助陛下。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下，",
        "unit_id": 128011,
        "voice": "vo_adv_5132301_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "想吃雞皮橙醋！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雞皮……",
        "unit_id": 127911,
        "voice": "vo_adv_5132301_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "超棒的呢☆",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這提議我採用了！",
        "unit_id": 127911
    }
]