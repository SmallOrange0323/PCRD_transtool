[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "怜與{player}\n一如往常的修練著……"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那我就進攻囉！",
        "unit_id": 100312,
        "voice": "vo_adv_1003006_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝啊！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100312,
        "voice": "vo_adv_1003006_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也變強許多了呢。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n動作的俐落度也提升了。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……但是，總覺得有不對勁的地方……？",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊，抱歉。不是在說你。",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有不對勁的地方的是我。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總覺得今天不能隨心所欲行動呢……",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n即便是當下，也感覺我的行動有點遲鈍。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "修練每天持續在進行，",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不認為我的實力會突然降低……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗚……！？",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎，怎麼了……突然有點頭暈……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不行了……",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒辦法、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "繼續站著了……",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "500121"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡、是……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們的公會之家……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來如此……我在和你的修練中倒下了啊……",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是你把我送到這裡來的吧，謝謝。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒想到在倒下之前，我都沒注意到身體的異常……",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我真是太大意了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但這個異常究竟是……？",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在也完全使不出力……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "像這樣身體不適的情況還是第一次呢……",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我至今都只想著要變強……",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為如此，我在不自覺當中過度逞強了吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒想到因為這樣把身體搞壞……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……說不定，",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n今後我的身體都不會好轉了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果真的變成那樣，",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "希望你不用在意，就把我拋下吧……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你就和日和還有優衣三人，以索爾之塔最高層為目標吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不想扯大家後腿……",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我就知道你會這麼說。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你果然很溫柔呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你說造成麻煩也沒關係？",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你真溫柔呢……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是我沒辦法原諒自己。",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以――",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咳，",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咳！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "糟透了……不僅是身體感到沉重，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n還有一股寒氣湧了上來……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感冒……？　這是感冒……？",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來如此，這是感冒啊……",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "像這樣喉嚨疼痛，全身無力的感覺……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這是感冒啊？ ",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咳！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我至今從來沒有得過感冒，",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……因為感冒身體才不能隨心所欲行動啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼我也不用想太多了……",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n好丟臉……我搞錯了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，那個……忘掉我剛才說的話吧。",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為感冒恍神，讓我似乎有點喪氣呢……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只要睡個覺就會痊癒了吧，不用擔心我。",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "傳染給你就不好了，離我遠點。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你真的很溫柔呢……",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n無論我說什麼，你也不會離開我吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我明白了，",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就麻煩你看病了。",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈～……！",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n早安。睡了一整晚，感冒好很多了呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n多虧你的看病。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼了？ 你臉色很難看喔？",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難道……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你沒事吧？",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的，這次竟然輪到看病的人倒下去……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "放心吧。我也很珍惜夥伴的。",
        "unit_id": 100311,
        "voice": "vo_adv_1003006_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n直到你痊癒前，我都會在你身邊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "滿懷著感謝的心情，\n怜在{player}痊癒前，一直在他身邊看病。"
    }
]