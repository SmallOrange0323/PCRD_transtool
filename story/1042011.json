    {
        "type": "dialogue",
        "name": "千歌",
        "words": "居然會在街上睡著，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我有把自己逼得這麼緊嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_053"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我做了一場夢，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那是個非常棒的夢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我以自己的意志",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "決定踏上了店裡的舞台唱歌。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "自己這麼說是很難為情，",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_054"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但夢裡的我……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "感覺有點帥氣。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "多虧那場夢，",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_055"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓我又再重新注意到了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我是真的很喜歡唱歌。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我是這麼想的。",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_056"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "慈樂之音最耀眼的時候，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n果然就是",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在大家面前唱歌的時候。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我覺得現在自己能清楚地表達出，",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_057"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n自己還是希望",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "能夠盡量避免會疏忽這一點的工作。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "即使最後無法如自己所願，",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_058"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但能夠表達出",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "自己真正的意思，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我相信這將來",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一定會對自己有所幫助。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_059"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你好好看著",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n今後的慈樂之音……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_060"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "然後希望",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總有一天，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你能像夢裡一樣給我獎勵。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌在心中如此想道，並淡淡地紅了臉頰。"
    }
]