[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那一天{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看到獨自走在街上的千歌。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唉……",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "該怎麼辦才好呢？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呀！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對不起……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n咦？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你好，{player}。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊……",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你聽到",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我的自言自語了啊……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "能請你聽我聊聊嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "最近慈樂之音的人氣上升，",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n音響盤的銷量和",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "演唱會的來場人數",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也很穩定提升。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但受到這個影響，",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "除了過去的唱歌和演唱會活動外，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n像演戲",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "拍寫真之類的工作邀約，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也開始變多了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "慈樂之音是偶像，",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以會有這類的工作",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也是理所當然的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這些工作如果能有助於慈樂之音的發展，",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我認為應該去做才對。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且粉絲們也應該會很高興……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，",
        "unit_id": 104211,
        "voice": "vo_adv_1042011_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "陽光照下來了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "奇怪？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "怎麼莫名地耀眼……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "奇怪？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這不是太陽光……！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呀～！",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "歡迎光臨，{player}。",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n現在立刻替你準備座位，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你稍等一下。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天稍晚",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "會有定期演唱會，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以客人很多。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果不介意，也請你聽聽看喔。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼……",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對不起。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓你久等了，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請坐這邊的位子。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你要點……",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咖啡對吧。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我明白了。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唉……",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對、",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對不起！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我在發呆……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不小心盯著",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天表演的海報看得出神了。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天唱歌的人是",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我很憧憬的歌手。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以我",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有點小興奮……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很、",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很高興能聽你這麼說，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但我還差得遠了……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過……",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "希望總有一天自己也能",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "站上那個舞台……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對不起，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我立刻去準備咖啡過來。",
        "unit_id": 104232
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……久等了，",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這是你的咖啡。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我的表情很嚴肅？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……其實這是我剛才聽店長說的，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n預定要上台表演的歌手，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為突然生病而無法到場了。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在也很難找到人代演……",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n不曉得",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "演唱會該怎麼辦……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你、",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你在說什麼啊！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我怎麼可能有辦法",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "代替那位歌手上台唱歌。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這、",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這個我也……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我也、",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很想",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓你看。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n可是……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真不可思議。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "聽到你這麼說以後，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我就覺得自己應該做得到。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n你總是能用真誠的話語",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "來打動我。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很高興",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你願意相信我和",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我唱的歌……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我也想回應",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你的話語，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不對，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是必須回應才對！　",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你，{player}。",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要試試看。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "老實說",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要在他人面前唱歌，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓我還是感到很不安。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我如果不鼓起勇氣抓住這個機會，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我之後一定會無法繼續向前邁進。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我",
        "unit_id": 104232,
        "voice": "vo_adv_1042011_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "去找店長商量看看。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是你給了我",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "能向前邁進的勇氣，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我不能白費這個機會！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………"
    },
    {
        "type": "dialogue",
        "name": "千歌",
