        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "當時，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "中型龍的資料也被一併復原，",
        "unit_id": 195611
