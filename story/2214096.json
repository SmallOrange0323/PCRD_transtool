        "voice": "vo_adv_2214096_027"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n現在的她，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "已經能乖乖聽我的話。",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n正跟「色慾之龍」一起──",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "去吉歐‧格黑納",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "打擾一下了喔♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "妳那可愛的守護騎士，",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_028"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "有著小小花蕾的小吸血妖花也──",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "呵呵，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "可能已經被打倒了也說不定♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "花蜜被吸個精光，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "花蕊也被扯下蹂躪，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "之類的……♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……既然如此，",
        "unit_id": 129712,
        "voice": "vo_adv_2214096_029"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家應將阻撓眼前的愚昧之物，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "迅速排除。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「滅裂萬化‧",
        "unit_id": 129712,
        "voice": "vo_adv_2214096_030"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "輪迴轉掌」──",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "嗯哼哼♡",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_031"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n不行♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……！？",
        "unit_id": 129712,
        "voice": "vo_adv_2214096_032"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "呀嗯，",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_033"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "好可～怕♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "但是──",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "不說",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_034"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "其他地方，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n這裡，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "可是在我的床上。",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "用從小幻那獲得的權能，",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_035"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n暴力什麼的，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "全～部禁止……♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "是的♡",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_036"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n在這裡能做的事，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n只有身體與身體",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "溫柔地互相磨蹭──",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "啊♡",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_037"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n偶爾來點",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "激烈的也不錯♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n不過那種時候，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "要好好取得對方同意喔……？",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……",
        "unit_id": 129712,
        "voice": "vo_adv_2214096_038"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "呵呵呵……♡",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_039"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n這樣一看，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "還真是可愛……♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n現在的妳彷彿，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "像是跳入蜘蛛巢穴的小蝴蝶♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "因為蜘蛛絲和毒，",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_040"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "身體動彈不得。",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n一直被親到變得渾身酥軟為止，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "都不會放過妳喔……♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……蜘蛛，",
        "unit_id": 129712,
        "voice": "vo_adv_2214096_041"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "嗎──",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "回顧往昔，",
        "unit_id": 129712,
        "voice": "vo_adv_2214096_042"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "身為蜘蛛的──",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "阿剌克涅，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "雖本性腐敗，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n然其為被遺忘之鄉愁所苦之狀，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不免令人心生一絲憐惜。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "即便如此，",
        "unit_id": 129712,
        "voice": "vo_adv_2214096_043"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n對汝這般侵略者，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家提不起分毫同情。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "遑論，",
        "unit_id": 129712,
        "voice": "vo_adv_2214096_044"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n汝連源自母星地球之肉身都不具，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n卻仍沉醉於猴戲般之「色慾」，甚是愚物。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "唉呀，",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_045"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "好～過分。",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "為了模仿人類",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "而使用了皇家裝備，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n這一點妳不也一樣嗎？",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "「嫉妒」的皇女殿下──",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "還是說，",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_046"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "身為「非人」的妳，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n不會對像小櫻桃他們那樣的人類之子",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "懷抱嫉妒心呢……？",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那可未必。",
        "unit_id": 129712,
        "voice": "vo_adv_2214096_047"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "且不論妒意──",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "其餘情念，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "在奴家心中可謂無止境地。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是吧──",
        "unit_id": 129712,
        "voice": "vo_adv_2214096_048"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下？",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家和恁之羈絆，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n就讓這愚昧的山羊傢伙，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "好好見識見識如何。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "……！",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_049"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "對手是公主騎士的權能的話──",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n同樣",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "也能用公主騎士的權能",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "來對抗……？",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正是。",
        "unit_id": 129712,
        "voice": "vo_adv_2214096_050"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n接受騎士閣下之寵愛於一身，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家已是天下無雙。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「滅裂萬化──",
        "unit_id": 129712,
        "voice": "vo_adv_2214096_051"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "破幻‧",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "雲散霧掌」。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "呀",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_052"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "嗯……！",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n被這麼粗魯地對待，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "會壞掉的……！",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下？",
        "unit_id": 129712,
        "voice": "vo_adv_2214096_053"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n無須顧慮。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "地利偏屬這山羊傢伙。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若是分神，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "我方將被壓制。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "啊……！",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_054"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n啊啊啊嗯……♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "涅妃璃姆‧涅比羅……！",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_055"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n居然無限擴張鐵手──",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "把我的世界，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "弄得亂七八糟的。",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "……但是……",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "唉，",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_056"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "真羨慕妳……♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n被小櫻桃灌注了",
        "unit_id": 195611
    },
    {
