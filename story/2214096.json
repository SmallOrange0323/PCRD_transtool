        "name": "阿爾莎特",
        "words": "變成了浮島。",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n也在背骨那一塊，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "設定了類似城堡的建築物♡",
