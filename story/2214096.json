        "voice": "vo_adv_2214096_025"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n還要簡單很～多呢……♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "啊♡",
        "unit_id": 195611,
        "voice": "vo_adv_2214096_026"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "對了對了……",
