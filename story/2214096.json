        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "我就把牠們調教成",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "會聽我指令的奴隸了……♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "比起讓小可璃亞或小烏爾姆成為我的「戀人」，",
