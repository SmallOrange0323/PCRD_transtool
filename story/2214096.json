    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "龍型魔物資料，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n好像就收藏在那座島地底深處的樣子……",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "把最大的一隻，",
