        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "以恁遭擄掠誘拐為兆，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n阿斯特朗",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "遂發生天地異變……",
