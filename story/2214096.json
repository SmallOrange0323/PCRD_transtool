        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "涅妃‧涅羅王女殿下？",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "關於小可璃亞，",
