        "voice": "vo_adv_7003005_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈啊……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不行了，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的不行了～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鈴奈，辛苦了。",
        "unit_id": 102911,
        "voice": "vo_adv_7003005_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也到極限了……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "能擊倒魔物真是太好了。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}也是，\n謝謝你為我們兩個進行了強化……",
        "unit_id": 102911,
        "voice": "vo_adv_7003005_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？　",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "掉落在那邊的東西難道就是――",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇！？　",
        "unit_id": 102911,
        "voice": "vo_adv_7003005_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸，還突然散發出了光芒！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼什麼這是什麼啊？　",
        "unit_id": 101611,
        "voice": "vo_adv_7003005_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這可真是不得了欸！！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈・望",
        "words": "呀啊啊啊！？",
        "unit_id": 1,
        "voice": "vo_adv_7003005_005"
    },
    {
        "type": "background",
        "background": "510070"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一、二、三、四――",
        "unit_id": 102931,
        "voice": "vo_adv_7003005_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一、二、三……",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我又跳錯了……",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "舞蹈真的挺難的呢……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "望望，",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "抱歉扯了後腿。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在表演當天，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還找你陪我練習。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可能太小看舞蹈了……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "聽到望望說，",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要在椿丘時裝發表會上\n辦一場合作表演時，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我還興奮的不得了――",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在那之後和秀才聊過，",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "才得知他和望望有認識，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n那應該也能來個私下練習吧",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n覺得應該會挺輕鬆的，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "現在覺得好痛苦……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你別這麼想，",
        "unit_id": 102931,
        "voice": "vo_adv_7003005_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鈴奈。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鈴奈並沒有小看舞蹈啊，",
        "unit_id": 102931,
        "voice": "vo_adv_7003005_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "覺得你這樣和我一起練習其實非常厲害了哦？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "腳步姿態那麼優雅，",
        "unit_id": 102931,
        "voice": "vo_adv_7003005_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "視線的投放又很拿手，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "其實刺激了我不少呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的嗎！？　",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗚嗚，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝你——！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "望望真的是天使～！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才介紹我認識你的時候還以為是天使降臨，",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "現在見鬼了你真的就是天使啊！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖、",
        "unit_id": 102931,
        "voice": "vo_adv_7003005_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然我不知道你這是在說鬼還是天使……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總之，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "進行最後衝刺了哦！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也為了陪我們一起練習的{player}，",
        "unit_id": 102931,
        "voice": "vo_adv_7003005_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這場表演，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們一定要讓它成功！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喔～♪",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈啊，",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈啊。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗚嗚嗚～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "動作怎麼也對不上……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為什麼～？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一把注意力放進編舞中，",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_021"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n動作就開始有點不合拍了……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "馬上就是要進入會場的時間了，",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "該怎麼辦才好……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "…………",
        "unit_id": 102931,
        "voice": "vo_adv_7003005_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鈴奈。",
        "unit_id": 102931,
        "voice": "vo_adv_7003005_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我有一個提案……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n編舞，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "幫你改的簡單一點如何？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "編舞弄得簡單一點，",
        "unit_id": 102931,
        "voice": "vo_adv_7003005_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我認為就能讓你更好合拍了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我會和舞台人員講好的――",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……我不要。",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鈴奈？",
        "unit_id": 102931,
        "voice": "vo_adv_7003005_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "望望，",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_029"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我絕不要這樣。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我會好好加油的，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們就按照這個編舞來跳吧？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為了這份工作，",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還有編舞老師，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n以及為我們製作服裝的設計師還有工匠也是，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n大家都是拼了命為我們而努力的。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就我一個人在偷懶，",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "說不過去吧。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我好歹，",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_032"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也是時尚模特兒啊。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為舞台表演找理由，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也太遜了。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸……",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對不起，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "明明在扯後腿的人是我，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還一副自以為是地說這些話。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……不不，",
        "unit_id": 102931,
        "voice": "vo_adv_7003005_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒有那回事喔。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我才要向你道歉。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才……",
        "unit_id": 101631,
        "voice": "vo_adv_7003005_035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝你。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n有了",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才在一旁支持我，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一定沒問題的！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 102931,
        "voice": "vo_adv_7003005_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "離正式演出也還有時間。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n鈴奈，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
