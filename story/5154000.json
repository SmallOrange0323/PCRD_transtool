        "type": "dialogue",
        "name": "望",
        "words": "話說回來店在哪裡呢？",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "地圖上顯示",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是在這附近沒錯……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我看看，",
        "unit_id": 132212,
        "voice": "vo_adv_5154000_057"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "店的名字叫做，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "阿爾克絲鍊金堂。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「無所不有的商店」……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這麼寫著。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……「無所不有的商店」嗎。",
        "unit_id": 132212,
        "voice": "vo_adv_5154000_058"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果是真的那很厲害呢！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會是像什麼都有的宮殿一樣",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "很大間的店嗎？",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這附近又沒有那種建築物……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……好小間。",
        "unit_id": 132212,
        "voice": "vo_adv_5154000_059"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……啊，",
        "unit_id": 132212,
        "voice": "vo_adv_5154000_060"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有看板。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n阿爾克絲鍊金堂……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是這裡沒錯。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……很抱歉說了這裡很小間！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼，",
        "unit_id": 132212,
        "voice": "vo_adv_5154000_061"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們快進去吧！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有人在嗎──！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……？",
