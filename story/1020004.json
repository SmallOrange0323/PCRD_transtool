        "voice": "vo_adv_1020004_004"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n謝謝你陪美美一起去買東西～",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "今天呢，",
        "unit_id": 102031,
        "voice": "vo_adv_1020004_005"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n美美是為了",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "買媽媽的生日禮物～",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美幫了媽媽許多忙，",
