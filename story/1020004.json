        "voice": "vo_adv_1020004_049"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "…",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美呢，總覺得做了一個不可思議的夢耶～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "在夢裡，美美和哥哥一起去挑選給媽媽的生日禮物～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦？哥哥也做了一樣的夢嗎？",
        "unit_id": 102011,
        "voice": "vo_adv_1020004_050"
    },
    {
        "type": "dialogue",
