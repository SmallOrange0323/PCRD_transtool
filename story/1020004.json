    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "好～厲害！真是不可思議呢～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "但是美美居然能和哥哥做一樣的夢，真開心呢～",
