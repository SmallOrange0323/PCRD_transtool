[
    {
        "type": "background",
        "background": "500242"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後。\n透過凱留的魔法在水中高速移動，\n{player}一行人來到了海底的遺跡。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但是當場就被魔物們團團包圍，舉步維艱。"
    },
    {
        "type": "background",
        "background": "500242"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之，",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就交給那個叫鈴莓的傢伙帶路了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我這邊先",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "專心應付出現的魔物。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "知道了，",
        "unit_id": 107712,
        "voice": "vo_adv_5004005_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就交給我來帶路吧。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我正在透過探測魔法",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "尋找可可蘿的所在位置，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n和解析遺跡的內部構造等等。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然是挺複雜的，",
        "unit_id": 107712,
        "voice": "vo_adv_5004005_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但只要把握好正確路線就不會迷路了。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n應該能用最短路徑，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "到達可可蘿的所在之處。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "陷阱之類的",
        "unit_id": 107712,
        "voice": "vo_adv_5004005_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也可以透過探測魔法，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n事先確認好位置",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "以避開。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過",
        "unit_id": 107712,
        "voice": "vo_adv_5004005_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "冒出來的魔物，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就必須靠各位除掉了。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我這邊",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "光是使用探查魔法就已經忙不過來了，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就麻煩大家了。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然妳說大家，",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "基本上就是指我吧。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔～",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是平時這種情況的話，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只要把貪吃佩可扔進魔物群之中，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n她就會擅自輕鬆搞定了說。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對、",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這次，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我真的成了絆腳石了。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真～的，妳這個一點用也沒有的傢伙……",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n轉來轉去真的是有夠礙眼，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n至少也待在一旁別受傷就好了啊。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚。",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留說話比平常還要狠～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺已經沒有顧慮我的餘地了呢。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n確實，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我至少不要妨礙人家，先退下來好了。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………退後一步來到這個位置，",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就是{player}平常的站位了對吧。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}總是，",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在戰鬥時",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "站在我們的後方……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n焦慮地望著我們對吧。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你一直都",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感受著……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這種無力感",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和疏離感吧。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是對不起一直盯著你看了……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得和{player}產生了一點共鳴，\n有種感同身受的感覺。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "重要的伙伴還陷入危險之中，",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n什麼事也做不了，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是令人焦急。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯。",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵呵～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天在各種方面，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺都更親近{player}了呢。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂～！",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n別在那邊調情了，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快點給我過來！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哦，",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼了嗎？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看。",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n面向我們前方的位置深處，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是有一道巨大的門嗎。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可蘿仔似乎就在",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那道門後的大空洞裡面了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的。",
        "unit_id": 107712,
        "voice": "vo_adv_5004005_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還有生命跡象在，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可可蘿還活著……",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n啊啊，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真想趕快把她救出來。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是這道門，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "似乎是個麻煩的東西呢。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是要靠魔法才能將鎖解開的機關，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但我不知道解開的方法。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說得沒錯。雖然調查了一番，",
        "unit_id": 107712,
        "voice": "vo_adv_5004005_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但我仍無法解析門上所設置的魔術迴路……",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n似乎是用了某種手段，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "保護著魔術迴路不被解開的樣子。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼辦？",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然我們知道可蘿仔還活著，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但完全不知道她的狀況如何……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然而卻陷入這種無法前進的窘境，",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明想盡早闖進去後營救的。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "若有{player}的強化的話，",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n或許能強行將門給破壞掉也說不定。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也就是用破壞魔法亂打一通，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "強行將門打壞直接突擊。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果沒有其他辦法，我認為我們應該這麼做……",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有想到什麼其他能打開這道門的方法嗎？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果能用最聰明的方式打開這道門的話",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "當然是再好不過了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n該怎麼辦才好",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "，{player}？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……好喔，",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就是用粗魯的方法囉。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼{player}，你就給予我最大值的強化吧。",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n用我勤奮努力學來最強的破壞魔法，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n來大破壞一番吧！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請{player}集中強化凱留小姐吧！",
        "unit_id": 107712,
        "voice": "vo_adv_5004005_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為貪吃佩可小姐目前處於虛弱化狀態，",
        "unit_id": 107712,
        "voice": "vo_adv_5004005_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n而我",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "又不太擅長攻擊魔法……",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "將{player}強化夥伴的能力",
        "unit_id": 107712,
        "voice": "vo_adv_5004005_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n全部集中在凱留小姐身上……",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這是凱留小姐",
        "unit_id": 107712,
        "voice": "vo_adv_5004005_031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "傾全力把自己現有的所有力量，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n灌輸到她的破壞魔法的作戰。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這大概，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就是我們目前所能做到的最大努力了。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就這麼辦了！",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然我的負擔重到不像話，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但可沒時間囉嗦了！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}，",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全力強化我吧！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這種程度的阻礙，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就由我來華麗地突破！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太好了，",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來了來了來了！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}的力量蔓延開來，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我全身的細胞都躁動起來了！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣一定就行得通了……！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈哈☆",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n任何妨礙我的東西，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我都要將它轟走！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀啊啊啊！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好耶，",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "出現一個大洞了！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n突擊吧！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說的～也是……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n若為了將門打開而用盡魔力，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "導致力量全失的話可就本末倒置了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "用一般方法、",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不浪費任何力氣將門打開才是最好的辦法。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是，",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該怎樣做才能把門給……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸欸，你們有看見那邊有一個像是蓄水池的東西嗎？",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在水池底下，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似乎設有控制桿？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸……",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明還有點距離，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看得倒是挺清楚的嘛貪吃佩可？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿～",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我視力還算不錯喔！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說回來。",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n門和控制桿上，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都嵌有同樣顏色像是寶玉的東西在上面……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像推拉一下控制桿，",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就能把門打開了～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的感覺？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，有這個可能呢。",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在這遺跡中，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "四處可見這種機關呢。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這種機關明明只會造成生活不便，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是謎一般的小把戲呢。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種遺跡本來就不是拿來生活的地方吧？",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想應該是陵墓",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或是藏寶庫一樣的地方",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才對。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比起這個……",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可以讓我來啟動那個控制桿嗎？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n到目前為止，我還什麼忙都沒幫上，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡讓我來效勞吧。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說的也是，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "控制桿似乎在水池裡……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我對自己的泳技沒什麼自信，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就交給妳來吧。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要小心為妙，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "水中或許也有魔物也說不定。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是！",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼我去去就回……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一二三，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "噗通～☆",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好。",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n水比想像中的還要清澈，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能夠清楚得看見周圍。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "控制桿是在……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這邊嗎？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦，",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "找到了！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要拉一下",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個控制桿就可以了吧？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔姆姆姆……！",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n唔唔，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有「皇家裝備」的加持",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好吃力啊！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有夠重的，無法啟動控制桿！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是！",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　小可蘿現在危在旦夕，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這裡不展現一下自己的毅力，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "更待何時呢！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了總是帶給我幸福時光",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的【美食殿堂】各位！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要加油啊～！",
        "unit_id": 107511,
        "voice": "vo_adv_5004005_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n堅持住這口氣，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把控制桿拉起來！",
        "unit_id": 107511
    },
    {
        "type": "background",
        "background": "500242"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……哦？",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_055"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太好了，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "門打開了！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n果然啟動手把是正確答案啊！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可妳立大功了！",
        "unit_id": 107811,
        "voice": "vo_adv_5004005_056"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n趕快從水池裡上來吧，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要朝門的方向突擊了喔！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的。",
        "unit_id": 107712,
        "voice": "vo_adv_5004005_057"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們趕緊吧，",
        "unit_id": 107712
    },
    {
