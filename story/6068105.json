[
    {
        "type": "background",
        "background": "501340"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我似乎很習慣",
        "unit_id": 116711,
        "voice": "vo_adv_6068105_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在這個工廠打工了！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我一開始還很怕自己無法勝任，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但我最近開始覺得工作也很快樂！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是說啊！",
        "unit_id": 116711,
        "voice": "vo_adv_6068105_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n只要看到正在玩我們製作的玩具的小孩子，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我就會感到非常開心……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "想要更加努力！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "欸嘿嘿，",
        "unit_id": 116711,
        "voice": "vo_adv_6068105_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你那樣稱讚我，會讓我感到害羞的……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "製作",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「大家的玩具好朋友」的契機確實是來自於我……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不、",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過現在回想起來，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那是件不適合邊緣人的事件……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚……！",
        "unit_id": 116711,
        "voice": "vo_adv_6068105_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我還沒有結交到打工夥伴……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我明明打工一段時間了，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "卻這麼不爭氣，我感到很抱歉……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我總有一天肯定會交到……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我想跟大家變成好朋友……！",
        "unit_id": 116711
    }
]