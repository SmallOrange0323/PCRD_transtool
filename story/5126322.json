    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n惠理子寶她們",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "加入了阿爾杰什寶那邊！？",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n話說，",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也在裡面耶！？",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為什麼～～！？？",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "冷靜點！",
        "unit_id": 127211,
        "voice": "vo_adv_5126322_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那是妳們的闇影……",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對，",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是那傢伙的魔法呢……！",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真假！？",
        "unit_id": 127311,
        "voice": "vo_adv_5126322_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……話說阿爾杰什寶",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "居然想讓我們跟朋友互相戰鬥，",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n真是超級討厭的欸……！",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過阿爾杰什，",
        "unit_id": 127211,
        "voice": "vo_adv_5126322_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你那樣做",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是反效果。",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我完全被惹毛了……！！",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "竟敢利用我的朋友……",
        "unit_id": 127211,
        "voice": "vo_adv_5126322_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我絕對",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不會原諒你！！",
        "unit_id": 127211
    }
]