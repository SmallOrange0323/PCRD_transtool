[
    {
        "type": "background",
        "background": "500091"
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "欸，要我說幾遍才懂？",
        "unit_id": 711,
        "voice": "vo_adv_1033006_000"
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "\n禁止進入王宮境地內！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "就算我們是【王宮騎士團】的團員，\n只要不是貴族都不能踏入王宮內部。",
        "unit_id": 711,
        "voice": "vo_adv_1033006_001"
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "\n更不用說是普通人了！嚴禁進入！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "你有意見嗎？\n",
        "unit_id": 711,
        "voice": "vo_adv_1033006_002"
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "再吵的話就把你抓起來喔！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "喂，怎麼了……",
        "unit_id": 712,
        "voice": "vo_adv_1033006_003"
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n到底在吵吵鬧鬧什麼？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "啊，",
        "unit_id": 711,
        "voice": "vo_adv_1033006_004"
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "分隊長大人！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "不，沒什麼……我們不是遵從國王的敕命，",
        "unit_id": 711,
        "voice": "vo_adv_1033006_005"
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "\n將城鎮上的街頭藝人強行帶來嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "\n現在那個關係人士一直過來要求我們放走他的朋友！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "這樣啊……那個，你的心情我可以了解，但再忍耐一下。",
        "unit_id": 712,
        "voice": "vo_adv_1033006_006"
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n我們也不是自願做這些殘忍的事情，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n但國王的命令是不可違抗的。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "真是難以理解……\n最近國王是心神不寧嗎？",
        "unit_id": 712,
        "voice": "vo_adv_1033006_007"
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n你不覺得有很多難以理解的命令嗎？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "嗯。不過剛剛抓起來的",
        "unit_id": 711,
        "voice": "vo_adv_1033006_008"
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "\n是那個【伊麗莎白牧場】的經營者吧？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "\n雖然是人類，但也很熱心照護獸人們……？ ",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "所以才受處罰的不是嗎？",
        "unit_id": 711,
        "voice": "vo_adv_1033006_009"
    },
    {
        "type": "dialogue",
        "name": "騎士團員",
        "words": "\n我是這樣判斷的……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "一般的人類和獸人之間，在生物學上幾乎沒有差別。",
        "unit_id": 712,
        "voice": "vo_adv_1033006_010"
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n和獸人友好也不是一種罪吧。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n雖然不知曾幾何時，種族之間的鴻溝似乎越來越嚴重了。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "不論如何，原本……我們【王宮騎士團】的職責，",
        "unit_id": 712,
        "voice": "vo_adv_1033006_011"
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n是保護所有無辜的民眾不受惡害侵襲。\n抓住無罪之人加以苛責，絕非出自本意。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "團長也指示要有禮貌地對待藝人們及關係人士。",
        "unit_id": 712,
        "voice": "vo_adv_1033006_012"
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n只要你不要大吵大鬧，我們也不會做什麼。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n希望你就在這裡等待夥伴回來。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "……說到【伊麗莎白牧場】的經營者，\n應該是真陽小姐吧。",
        "unit_id": 712,
        "voice": "vo_adv_1033006_013"
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n她所賣的乳製品，我老婆很喜歡呢。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "她不只賣食材，也生產化妝品和衣服。",
        "unit_id": 712,
        "voice": "vo_adv_1033006_014"
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n要是因為這次的事她不再做生意的話，我會很傷腦筋呢。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "我絕對會被老婆宰了。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "…………",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_015"
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "嗯，她出來囉。",
        "unit_id": 712,
        "voice": "vo_adv_1033006_016"
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n真陽小姐沒事吧？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "分隊長",
        "words": "\n有沒有人對妳做出過分的事？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "…………",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……{player}。\n你一直在王宮旁等我嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "讓你擔心了，真抱歉喔。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個，【王宮騎士團】的人，",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n請放開{player}。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "他沒有做任何壞事的♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈，那倒也是。就算沒有違反法律，",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n如果上位者覺得礙眼的話，那就是一種「罪」的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這我很了解的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "。\n沒關係，沒有人對我做什麼過分的事。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝啊。\n看到{player}的臉和聲音……",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "稍～微鬆了一口氣啦♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈。要是一直待在王宮旁邊的話，",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n會妨礙【王宮騎士團】工作的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們回去吧，{player}。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀呀……",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "抱歉，老哥可以揹我嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我沒有受傷，但還是有點餘悸猶存，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒辦法好好走路。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯。\n謝謝。",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不要露出那種表情，我沒事的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我還算好，沒有受到什麼過分的處分啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只是真的批評了王政的那些人……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n經歷了我說不出口的可怕遭遇。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且還被指示，今後如果不表演\n讚美國王的歌曲或節目……",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就會被割掉舌頭。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的太過分啦，那不是人會做的事。",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n對吧，{player}。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我真的好害怕。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也沒有什麼很偉大的想法啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_029"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我只是希望，人們看了我的短劇或相聲，會哈哈大笑……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就只是那樣而已。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但國王似乎無法理解。",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_030"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就在剛剛……我們這些被抓起來的藝人，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n一個個在國王面前輪流表演。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有很多我根本比不上的有趣藝人。\n但國王根本連嘴角都沒動過。",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "他一直歪著頭，好像在聽其他國家的語言一樣。",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_032"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且還問說那哪裡有趣？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n有什麼意義？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的很可怕……",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_033"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "想讓其他人露出笑容，或是更加幸福一點點，",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_034"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這種想法不是很自然嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n他卻問有什麼意義……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "欸，為什麼他會問這種問題呢？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "到底他度過了怎樣的人生才會變成這樣……",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_035"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n怎麼無法理解這種對人性而言理所當然的事呢？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所謂的國王，都是那樣子嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "簡直不像人。\n雖然我也想讓國王了解",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_036"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n什麼是歡笑、什麼是幸福。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但我做不到，我沒有那樣的才能和技術的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_037"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我真是太沒用了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "欸，{player}……",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_038"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我當時只覺得，那個國王好可怕。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一心只想要趕快逃走。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對不起喔，{player}。",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_039"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n明明就有你幫忙一起想的那些哏。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是我完全說不出任何有趣的話。",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_040"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "國王連一點笑意都沒有。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那時我腦袋一片空白，什麼雙關語都想不出來……",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_041"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就只顧著害怕那個國王。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣的話，我根本沒辦法成為真正的搞笑藝人啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不對。\n我到底為什麼會開始想要搞笑……",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_042"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "連這一點我都不知道了。",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_043"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也回想不起來，自己以前到底是怎麼笑的了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚、嗚嗚……",
        "unit_id": 103311,
        "voice": "vo_adv_1033006_044"
    },
    {
