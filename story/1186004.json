[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天的午後。{player}在涅比亞的要求下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n獨自走上前往公會小屋三樓的樓梯。"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你們頭一次來到這個房間時，",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_000"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那可真是雞飛狗跳啊～♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n除了你跟可可蘿以外，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "大家都超失控……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "欸。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……幹嘛～？",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_001"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你在提防我？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n你說擔心會被我惡作劇",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "才不會好嗎，",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_002"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "起碼在只有你一個人的時候不會。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n畢竟你",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "一點反應都沒有，無聊死了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我也是有不會惡作劇的時候啊。",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_003"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……怎麼一臉",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "無法想像的表情。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "原來你也會",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "露出這種表情啊♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "先不說這些……",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_004"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "進入正題。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n你幫我",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "強化吧♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不然是要在哪裡啦？",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_005"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好啦好啦，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "快點♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不用擔心，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我不會害你的！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "真是的！",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_006"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你平常都不會這麼有戒心的，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "快點幫我強化啦！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不照做的話……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我就要惡作劇囉？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯嗯！",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_007"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "感覺很棒♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n那麼要開始囉！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "一、二、三！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呀哈哈☆",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_008"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "怎麼樣？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我使用你的公主騎士之力",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "強制觸發了bug。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n這麼一來，「幻影湖之霧」",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "對你也有效了吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你在發什麼呆啊？",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_009"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "仔細",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "看看你身邊♪",
        "unit_id": 190911
    },
    {
        "type": "background",
        "background": "510220"
    },
    {
        "type": "dialogue",
        "name": "同學１",
        "words": "{player}同學？班會已經結束了喔～？",
        "unit_id": 1,
        "voice": "vo_adv_1186004_010"
    },
    {
        "type": "dialogue",
        "name": "同學１",
        "words": "\n你在發什麼呆啊？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學１",
        "words": "啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學１",
        "words": "該不會還想睡吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學１",
        "words": "\n數學課時你也在打瞌睡對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "怎麼啦，",
        "unit_id": 1,
        "voice": "vo_adv_1186004_011"
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "熬夜啊？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "收好的講義",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "我幫你送去教職員室，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "\n你可以先回去了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學３",
        "words": "欸欸！",
        "unit_id": 1,
        "voice": "vo_adv_1186004_012"
    },
    {
        "type": "dialogue",
        "name": "同學３",
        "words": "今天回去要玩",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學３",
        "words": "阿斯特朗嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學３",
        "words": "\n有更新對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學１",
        "words": "沒錯沒錯，",
        "unit_id": 1,
        "voice": "vo_adv_1186004_013"
    },
    {
        "type": "dialogue",
        "name": "同學１",
        "words": "昨天有公告的那個！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學１",
        "words": "\n回去時在電車上先登入看看好了～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "{player}，你晚點也會上線吧？",
        "unit_id": 1,
        "voice": "vo_adv_1186004_014"
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "阿斯特朗。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "\n有個任務我怎麼樣都過不了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "可以幫忙一下嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這裡是你讀的",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_015"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "高中的教室喔。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "學校這地方",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "還真熱鬧呢。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "課本",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_016"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "全部都收進書包裡了吧？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n你想放在學校的話也行啦。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那我們走吧！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……還能去哪裡，",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_017"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "當然是你家啊♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n剛才不是說要登入阿斯特朗嗎。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我會負責引導你直到登入的！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "快點快點，",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_018"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "走吧！",
        "unit_id": 190911
    },
    {
        "type": "background",
        "background": "510210"
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "哇！",
        "unit_id": 1,
        "voice": "vo_adv_1186004_019"
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "別突然撞上來好不好。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "\n嗯，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "明天見啦。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學３",
        "words": "{player}同學，",
        "unit_id": 1,
        "voice": "vo_adv_1186004_020"
    },
    {
        "type": "dialogue",
        "name": "同學３",
        "words": "晚點見囉！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學３",
        "words": "\n我在之前阿斯特朗裡說好的地方等你～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好像是呢！",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_021"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "畢竟",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我現在是專為你存在的嘛♪",
        "unit_id": 190911
    },
    {
        "type": "background",
        "background": "510240"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這裡是校門啊。",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_022"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "會跟心上人約在這裡碰面嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n真棒，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這種青春的感覺！",
        "unit_id": 190911
    },
    {
        "type": "still",
        "still": "118600401"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "傍晚的路上",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_023"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "人這麼多啊。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n喂，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不往右閃會有危險喔！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n後方有腳踏車衝過來！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "再來是左邊！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哎唷，",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_024"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你不要衝進樹叢裡啦！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哎呀呀。",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_025"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "路上這麼混亂，感覺好容易撞到人。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n原來你每天",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就是走這條路去上學啊。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊，",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_026"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好像有新電影上映了♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你喜歡看恐怖片？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "還是愛情片呢？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不管喜歡哪種，",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_027"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "今天都不能繞去別的地方♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "雜貨店的櫥窗也好吸引人喔～",
        "unit_id": 190911,
        "voice": "vo_adv_1186004_028"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "咦？",
        "unit_id": 190911
    },
    {
