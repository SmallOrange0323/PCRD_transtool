[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉，",
        "unit_id": 127512,
        "voice": "vo_adv_5128071_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "受不了！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n父親大人真是的，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "突然就提到生小孩的事情！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "心思就不能再細膩一點嗎……！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一跟他報告婚約的事，",
        "unit_id": 127512,
        "voice": "vo_adv_5128071_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他就那麼興奮。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然他認同流夏也跟我們一起結婚這件事",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是很令人感激啦……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總之，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "生小孩的話題就先忘掉。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是說啊。",
        "unit_id": 127512,
        "voice": "vo_adv_5128071_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然我們結婚了，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但要做的事還是沒有變。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "得要照顧那些孩子到他們獨立為止。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話說回來，",
        "unit_id": 127512,
        "voice": "vo_adv_5128071_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n育幼院的孩子那邊，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "該怎麼說明才好？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n以後你也要一起住對吧？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我的房間，",
        "unit_id": 127512,
        "voice": "vo_adv_5128071_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然目前為止都讓孩子們自由進出，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是今後應該要請他們先敲門，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再進來會比較好吧。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼為什麼……",
        "unit_id": 127512,
        "voice": "vo_adv_5128071_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "、",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這當然是不行啊！？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就小孩子的教育來說，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果不小心讓他們",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n看到不好的場景該怎麼辦啊！？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你說具體而言是什麼場景？",
        "unit_id": 127512,
        "voice": "vo_adv_5128071_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個嘛～",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是～",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在床上",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "下棋之類的。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你想想，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣子很沒有規矩對吧？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總之，",
        "unit_id": 127512,
        "voice": "vo_adv_5128071_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會跟孩子們這樣說的！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓是個懂得分寸的人，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以沒問題……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不對，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺她會不小心忘記敲門就跑進來呢。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是乖乖鎖門好了？",
        "unit_id": 127512,
        "voice": "vo_adv_5128071_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我實在不太想做會讓大家覺得有距離的事情。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真令人煩惱啊……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總之，",
        "unit_id": 127512,
        "voice": "vo_adv_5128071_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我不會放棄製造兩人",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "的獨處時光哦？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也不是說你不能跟流夏很親密啦。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只是，我希望你能夠有只看著我",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "的時間。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好啦，",
        "unit_id": 127512,
        "voice": "vo_adv_5128071_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "過來這邊吧？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵……",
        "unit_id": 127512,
        "voice": "vo_adv_5128071_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我愛你喔。",
        "unit_id": 127512
    }
]