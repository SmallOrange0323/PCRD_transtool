        "name": "優花梨",
        "words": "啊，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你不可能會喝吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唉。",
        "unit_id": 103411,
        "voice": "vo_adv_1034011_072"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我居然會飢渴到連作夢都夢到麥酒……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是，",
        "unit_id": 103411,
        "voice": "vo_adv_1034011_073"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我是不會輸的！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n就算到世界盡頭",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也絕對不喝麥酒！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "禁酒，",
        "unit_id": 103411,
        "voice": "vo_adv_1034011_074"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "繼續執行！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優花梨雖然重新下定了決心，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但一回到蘭德索爾，就馬上差點順勢進入餐廳裡面。"
    }
]