    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真不好意思。",
        "unit_id": 103431
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我並沒有什麼特別想買的東西，",
