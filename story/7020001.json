[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "半推半就之下答應要登塔的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正與珠希和真陽一起前進著。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵喵喵！",
        "unit_id": 104611,
        "voice": "vo_adv_7020001_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "進到塔裡面，寶物的氣息就更加強烈了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "究極的鯛魚燒就在眼前了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小希希，",
        "unit_id": 103311,
        "voice": "vo_adv_7020001_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們才剛進來不久啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n妳要是那麼激動，會耗盡體力喔。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀，",
        "unit_id": 103311,
        "voice": "vo_adv_7020001_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這麼說來，我還沒跟你說過嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真是傻問題喵，{player}。",
        "unit_id": 104611,
        "voice": "vo_adv_7020001_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "什麼飲料適合配鯛魚燒？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "答案是牛奶喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "除此之外還需要什麼理由喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我這裡的牛奶",
        "unit_id": 103311,
        "voice": "vo_adv_7020001_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "會賣到小希希打工的地方，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "然後他們會用牛奶來",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "做卡士達鮮奶油。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "【伊麗莎白牧場】的牛奶，",
        "unit_id": 104611,
        "voice": "vo_adv_7020001_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "正是我尋找已久的珍品喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不用說做成奶油很好吃，",
        "unit_id": 104611,
        "voice": "vo_adv_7020001_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "搭配鯛魚燒一起喝，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n也是超級絕配喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "能夠拓展鯛魚燒的可能性的人，都是值得信賴的喵。",
        "unit_id": 104611,
        "voice": "vo_adv_7020001_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n所以",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我常拜託她試吃新口味等等，感情就逐漸變好了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小希希他們那裡的鯛魚燒，",
        "unit_id": 103311,
        "voice": "vo_adv_7020001_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們公會的大家也都超喜歡的喔，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "太感謝妳啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "能聽妳這麼說，對鯛魚燒店店員就是無上的幸福了喵。",
        "unit_id": 104611,
        "voice": "vo_adv_7020001_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我並不滿足於此喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然卡士達鯛魚燒也很好，",
        "unit_id": 104611,
        "voice": "vo_adv_7020001_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但我想要做出配得上【伊麗莎白牧場】牛奶的",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n充滿原創性的鯛魚燒喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "畢竟公會雖然有出資，",
        "unit_id": 104611,
        "voice": "vo_adv_7020001_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但關於商品品質方面，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n責任全都在我身上喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "單純只買普通好吃的鯛魚燒的時代，已經結束了喵。",
        "unit_id": 104611,
        "voice": "vo_adv_7020001_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以我要爬上塔，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "取得製作究極鯛魚燒的食材喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為了鯛魚燒，",
        "unit_id": 104611,
        "voice": "vo_adv_7020001_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我可是不擇手段的喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小希希對鯛魚燒的熱情",
        "unit_id": 103311,
        "voice": "vo_adv_7020001_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的超強的，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也得多學學才行。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我光是",
        "unit_id": 103311,
        "voice": "vo_adv_7020001_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看到這麼熱情的小希希喜歡我們賣的牛奶，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就已經很高興了，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以我才會像這樣幫助她啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……真不愧是老哥，",
        "unit_id": 103311,
        "voice": "vo_adv_7020001_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你察覺到了嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然我沒辦法大聲說出口，",
        "unit_id": 103311,
        "voice": "vo_adv_7020001_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但其實我",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "單純地對小希希這個人很感興趣。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那份貢獻於鯛魚燒的熱情",
        "unit_id": 103311,
        "voice": "vo_adv_7020001_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "與無拘無束的行動力，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還有小希希本人",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "異想天開的個性。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這些每一樣都是在搞笑時也通用的、",
        "unit_id": 103311,
        "voice": "vo_adv_7020001_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "貨真價實的實力呀。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只要深入了解那個人，",
        "unit_id": 103311,
        "voice": "vo_adv_7020001_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "搞不好能獲得新哏的靈感，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "說不定",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還能拓展出新的搞笑之路也說不定，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我是這麼預想的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真失禮喵！",
        "unit_id": 104611,
        "voice": "vo_adv_7020001_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我無論何時都是超認真的喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不要把我當搞笑的哏喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀，",
        "unit_id": 103311,
        "voice": "vo_adv_7020001_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "被聽見啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今後也請多指教囉，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小希希。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真陽看起來很開心地，拍了拍面露不滿的珠希的肩膀。"
    }
]