    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "像棉花糖一樣可愛，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "摸起來",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "蓬鬆柔軟，超舒服的！",
