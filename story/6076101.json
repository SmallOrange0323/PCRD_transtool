        "type": "dialogue",
        "name": "香織",
        "words": "嗯～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你要來幫我嗎？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "謝謝你～！",
