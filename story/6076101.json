    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n光只是看著，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就讓人覺得心頭暖烘烘的～♪",
        "unit_id": 117711
    }
