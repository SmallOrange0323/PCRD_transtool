    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "幫了我一個大忙～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "的確，",
        "unit_id": 117711,
        "voice": "vo_adv_6076101_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "小小一隻",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就像布偶一樣～♪",
