[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}受日和邀約，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到年末喧鬧的蘭德索爾鎮上。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝你過來，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在你忙碌時把你叫來，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "抱歉喔……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈哈哈。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦！？",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n並沒有",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的發生什麼事啦……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說起來，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有是有……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有是有啦！！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但應該說，面對面說不出口",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗎……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊、",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈哈哈哈哈哈……",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "前一天午後……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n充滿朝氣的聲音響徹【破曉之星】的公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我回來了──",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "誰都不在……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n優衣跟怜也都出門了嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯──",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我本來還想說今天很閒，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n看要不要一起接委託的說……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯？",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有什麼送來了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是寄給我的信……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "難不成……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然！",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是珊托魯斯的奶奶寄來的信！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我們好久不見了呢～♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我看看……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「日和，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳過得好嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我們爺爺奶奶",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "夫妻倆都過得很好。」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呵呵，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "開頭跟平時一樣呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「關於日和冒險的信，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我跟爺爺都讀得很開心喔。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n妳這次似乎也有平安無事地回來，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我放心了。」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「雖然爺爺說馬上就要寄賀年卡，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我不用寫這封信也沒關係，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但畢竟賀年卡沒辦法寫那麼多呢。」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒錯沒錯，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "奶奶總是像這樣",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "把信紙寫得滿滿的呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「而且，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這次我也有想給日和看的東西。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "爺爺奶奶之前有沒有說過，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我們是相親結婚的？」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦咦？",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我第一次聽說耶？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣啊，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為他們平時感情都很好，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我還以為一定是戀愛結婚的……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「相親當時，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我記得正好跟",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n現在的日和差不多同年紀吧。」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣啊……",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n在差不多我這個年紀時相親，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n在珊托魯斯是很正常的嗎……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「雖然相親當下也曾感到尷尬不自在，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但交往後逐漸地，隔閡就完全消失了呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們現在感情這麼好，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就像日和也知道的一樣喔。」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯嗯，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這我相當清楚喔──",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n爺爺奶奶現在也很相親相愛呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「回想起來，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那或許是一見鍾情啊。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因為",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那之後雖然過了許久，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但我一次都沒有後悔過。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n要是日和也能和那麼棒",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "的人相遇就好了呢。」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈……",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "關於這點應該沒問題，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼回事？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有什麼裝在信封",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "裡……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這是，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "照片……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「然後呢，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這正好是個好機會，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳看看附在信裡的照片。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n非常棒的人對吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n日和也會喜歡這樣的人吧？」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "日和從信封中取出的是一張照片。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n其中所拍攝的，是一名獸人族的年輕男性……"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我好像有看過",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這種照片……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是常常寄到怜家裡的",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "相親照片！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "話說，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n難道說……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這是寄相親照片來給我",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "的意思嗎！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n咦咦咦咦咦咦！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "話說，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "信的後續呢！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "奶奶寫了什麼……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只有這張信紙和",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一張照片……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦、",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦咦咦咦──",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那之後煩惱一整天的日和，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n就把{player}約出來了。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不管我檢查幾遍，",
        "unit_id": 100111,
        "voice": "vo_adv_1087005_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "信上都沒有再寫任何東西，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
