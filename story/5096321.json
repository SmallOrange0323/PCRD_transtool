[
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚哇哇哇哇哇！？",
        "unit_id": 122411,
        "voice": "vo_adv_5096321_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這魔物是怎麼回事，",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好驚人的水勢、",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "水勢啊──！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和，",
        "unit_id": 122511,
        "voice": "vo_adv_5096321_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "小心點！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這隻魔物",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會操控水來破壞我們的陣型，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n而且還準確地趁我們陣型崩壞的時候攻擊過來……！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "要是被這種攻擊給命中，",
        "unit_id": 122611,
        "voice": "vo_adv_5096321_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "後果可不光是失去意識而已喔……！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜、",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我會想辦法用魔法來阻擋牠的，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳們就趁那時候攻擊！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣，謝謝妳！",
        "unit_id": 122411,
        "voice": "vo_adv_5096321_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n怜，",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "趁優衣保護我們的時候",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一口氣進攻吧！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，",
        "unit_id": 122511,
        "voice": "vo_adv_5096321_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在被對方的步調給吞沒之前，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n讓我們攻陷牠吧！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "各位，",
        "unit_id": 122611,
        "voice": "vo_adv_5096321_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "麻煩你們囉！",
        "unit_id": 122611
    }
]