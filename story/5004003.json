[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼、呼、",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈、哈……！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n自己走啦，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我沒有什麼力氣，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳不會要我背著妳走吧？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要不是因為情況緊急，哪會給妳這種福利啊！",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n記得要好好感謝我啊！？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們到了可蘿仔他們消失的地方了喔！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔咕……",
        "unit_id": 107511,
        "voice": "vo_adv_5004003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不要叫得那麼大聲啦，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的頭都嗡嗡作響了。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳沒問題吧？",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳現在看起來狀況超差的耶～",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總是精神飽滿不是妳唯一的優點嗎？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔嗯。和大家一起來旅行太開心了，",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n結果玩過頭，一路累到隔天了對吧？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也和妳一樣啊，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全身肌肉酸痛的……！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以，我才不想揹著妳這個笨重的身軀走咧！",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n快下來，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "從這裡開始就給我站好自己走了吧！？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。妳一邊抱怨……卻一邊擔心我的身體狀況，",
        "unit_id": 107511,
        "voice": "vo_adv_5004003_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還盡可能地穩住身子揹起我，我真的好喜歡小凱留喲。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿咻……",
        "unit_id": 107511,
        "voice": "vo_adv_5004003_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼感覺暈暈的。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳真的沒問題嗎？",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要為妳施點",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "恢復魔法嗎？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不用了。小可蘿他們不是消失了嗎？",
        "unit_id": 107511,
        "voice": "vo_adv_5004003_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n很有可能是發生了什麼異變了……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n魔力還是",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "儘可能的保存起來比較好吧。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說的也是。",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳的話，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只要吃點什麼東西就能若無其事地恢復了吧……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "海之家居然還沒開始營業，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "本來想去隨便買點什麼來吃的說。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 107511,
        "voice": "vo_adv_5004003_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是對不起……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我現在，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺吃什麼都無法打起精神了。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有件事雖然很難以啟齒……",
        "unit_id": 107511,
        "voice": "vo_adv_5004003_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我今天一早起來後，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n發現我帶著過來的",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「皇家裝備」不見了。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我慌慌張張地到處尋找，還是不見蹤影……",
        "unit_id": 107511,
        "voice": "vo_adv_5004003_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要有「皇家裝備」，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n攝取到的卡路里就會",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "直接變成滿滿元氣呢。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "蛤啊？",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　「皇家裝備」不見了？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這是怎麼回事，好好管理自己的東西好不好！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如此重要的東西，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是妳的生命線不是嗎……！？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚。",
        "unit_id": 107511,
        "voice": "vo_adv_5004003_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過真的很不可思議耶……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為為了就算睡眠期間被襲擊也能隨時應對，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我一直有把「皇家裝備」抱著睡的習慣。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "早上起來，",
        "unit_id": 107511,
        "voice": "vo_adv_5004003_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不知為何就消失不見了。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「消失不見」啊……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n該怎麼辦啊，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳能強得這麼離譜",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不就是因為多虧了「皇家裝備」嗎？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳現在只穿著泳裝一點裝備也沒有，",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本是無用武之地的米蟲啊！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好過份……",
        "unit_id": 107511,
        "voice": "vo_adv_5004003_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不過妳說的倒是一點也沒錯，我沒辦法反駁～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哭哭。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要哭了啦……真是傷腦筋～這下真的很不妙了。",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我現在魔力也枯竭中，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可的「皇家裝備」還不見蹤影？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "已經山窮水盡，一點辦法也沒有了！",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該如何是好，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n{player}跟可蘿仔和那傢伙消失不見了啊！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸～！",
        "unit_id": 107712,
        "voice": "vo_adv_5004003_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "　【美食殿堂】的各位～！",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚喵！？",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n啊啊嚇死我了，妳是……嗯……？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，是咲戀育幼院的鈴莓！",
        "unit_id": 107511,
        "voice": "vo_adv_5004003_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳在海之家打工對吧……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}！\n你不是消失不見了嗎？",
        "unit_id": 107511,
        "voice": "vo_adv_5004003_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你怎麼會",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和鈴莓在一起……？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個。",
        "unit_id": 107712,
        "voice": "vo_adv_5004003_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就是不知道為何{player}倒在了海邊……",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我暫時幫他做了點應急救治，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "並了解了一下狀況。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "看來{player}和可可蘿，",
        "unit_id": 107712,
        "voice": "vo_adv_5004003_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n似乎是一起被",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "巨大魔物拖進海中去了。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "像這樣，被海中伸出的像觸手一般的東西纏住……",
        "unit_id": 107712,
        "voice": "vo_adv_5004003_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n在驚慌失措下，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "連抵抗的機會都沒有，就被拖進海裡去了吧。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔～嗯。",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n才想說你們",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼突然消失不見的……？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "巨大魔物？",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　那是什麼啊！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n平時那麼和平的瑪爾傑海岸，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "居然有那種東西？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說回來。",
        "unit_id": 107511,
        "voice": "vo_adv_5004003_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n既然如此，{player}為什麼還一副沒什麼大礙的樣子啊？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有一起被拖下去的",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿呢……？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這個嘛，按照{player}的說法……",
        "unit_id": 107712,
        "voice": "vo_adv_5004003_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n在被拖入海中的同時，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n好像是可可蘿小姐用了自己的長槍",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "將觸手切斷了的樣子。",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "比起自己的安危，",
        "unit_id": 107712,
        "voice": "vo_adv_5004003_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n先確保了{player}的安全……",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過在切斷了纏繞{player}的觸手的同時，",
        "unit_id": 107712,
        "voice": "vo_adv_5004003_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n失去了意識，",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "於是就這樣……",
        "unit_id": 107712
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼嘛……",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為何都到了這種時候，還選擇以「主人﹞為優先而忽略自己啊？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可蘿仔這傢伙，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是個大笨蛋～！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是",
        "unit_id": 107811,
        "voice": "vo_adv_5004003_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼時候的事了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在水裡面無法呼吸，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再不趕快把可蘿仔救出來的話，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她會缺氧而死的……！",
        "unit_id": 107811
    }
]