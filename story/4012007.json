        "words": "真是緊實。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……妳這是",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "怎麼鍊出來的？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗯──？",
        "unit_id": 132412,
        "voice": "vo_adv_4012007_001"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "沒做什麼啊，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "就是正常地在外面玩而已。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哼，這樣啊，",
        "unit_id": 132512,
        "voice": "vo_adv_4012007_002"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "小孩子的運動量真厲害。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……嚼嚼嚼嚼。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "啊──",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "躺著吃的魷魚乾是",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這世上最美味的──",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "欸欸，小苑。",
        "unit_id": 132412,
        "voice": "vo_adv_4012007_003"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n彩羽的身體裡面是小苑的時候，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n感覺力氣好像下降了耶～",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我、",
        "unit_id": 132512,
        "voice": "vo_adv_4012007_004"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我不覺得啊──？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……唉，好吧，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "應該稍微鍛鍊一下體力了……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "太好了──！",
        "unit_id": 132412,
        "voice": "vo_adv_4012007_005"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "那去外面玩吧！！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n玩「假裝不抓到一萬隻鍬形蟲",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "就回不家」的遊戲！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不，",
        "unit_id": 132512,
        "voice": "vo_adv_4012007_006"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "在體力練起來前會先死啦。",
        "unit_id": 132512
    }
]