[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被雪叫了出來。"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "喂～！",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "久等了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能像這樣等待這麼可愛的我到來，",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你也真是幸福呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就趕緊出發吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "去哪裡？",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？我沒有說嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我決定了唷。",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要環遊世界！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一想到竟然還有人不知道這麼可愛的我的存在，",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就覺得他們很可憐呀。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以呢，我要好好宣揚我的存在。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "總之，我預計先周遊還沒去過的城鎮。",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你也會幫我對吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好了，出發吧。",
        "unit_id": 100811
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這裡這裡！",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這麼一來，就不會引起魔物注意了唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看啊，看看這個！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒錯，這是熱氣球唷！",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n只要飛到天上，就算是魔物也碰不到我了對吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就決定用這個，來周遊各個城鎮唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然也想要請你幫忙……",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過這個熱氣球是一人搭乘的。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n抱歉，就只能我自己一個人去了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我懂你的心情唷。",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不想離開美麗的我對吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "又來了～",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n又在逞強，真是可愛呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n其實你很想跟來對吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，能夠請你忍耐嗎？",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n要是連你也不在了，公會的大家也會寂寞呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她們就交給你照顧了唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……我不想要傷心地離別，",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以我馬上就要動身出發囉。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那就再見了，要保重唷！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "等、等一下……請等一下！",
        "unit_id": 105511,
        "voice": "vo_adv_1008005_014"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n前輩，請阻止雪！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "步未……",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就算妳想挽留我也是沒用的唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我知道我離開了妳們會很難過……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不是這樣的！",
        "unit_id": 105511,
        "voice": "vo_adv_1008005_016"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n公會裡的道具和財產，幾乎都不見了！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "問了商人後，他們說是雪賣掉了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，妳說那個啊。",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為要買這個熱氣球需要錢呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以我把從以前就覺得不美的家具，",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n全部一起賣掉了唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、那是大家的家具耶？",
        "unit_id": 105511,
        "voice": "vo_adv_1008005_019"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我認為不可以擅自賣掉……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒錯是也！",
        "unit_id": 103011,
        "voice": "vo_adv_1008005_020"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n把我的掛軸還給我是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我要是沒有那個沙發，就沒辦法好好妄想了……",
        "unit_id": 104511,
        "voice": "vo_adv_1008005_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "把大家的共有財產私自利用，怎麼可以！",
        "unit_id": 105311,
        "voice": "vo_adv_1008005_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n快點回來！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "抱歉，但是熱氣球已經開始飄起來了。",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_023"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我要這樣直接去環遊世界了唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那個傢伙，打算逃走嗎……！",
        "unit_id": 105311,
        "voice": "vo_adv_1008005_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n步未，動手吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "欸……好、好的！",
        "unit_id": 105511,
        "voice": "vo_adv_1008005_025"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我知道了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嘿！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唔哇，氣球破洞了！？",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_026"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要、要掉……掉下去了―！！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好了，你無路可退了！",
        "unit_id": 105311,
        "voice": "vo_adv_1008005_027"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n去把我們的家具贖回來吧？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "放、放開我～！",
        "unit_id": 100811,
        "voice": "vo_adv_1008005_028"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這都是為了這個世界呀～！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，雪的旅行以失敗告終。"
    }
]