[
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "！",
        "unit_id": 129911,
        "voice": "vo_adv_5142322_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不好了……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n其他魔物聽見騷動聲，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也聚集過來了，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "甚至連闇影都……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃欸！？",
        "unit_id": 129811,
        "voice": "vo_adv_5142322_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼連惠理子的闇影都有啊！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要是被用蠻力暴打，那可不是開玩笑的啊！？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 129911,
        "voice": "vo_adv_5142322_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真沒禮貌呢。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳的闇影看起來也很輕巧地",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n在揮舞著大劍呢？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗚哇～",
        "unit_id": 129811,
        "voice": "vo_adv_5142322_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真的耶……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那群看起來只會用蠻力的傢伙究竟是誰……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是我們嗎。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "唉……",
        "unit_id": 129911,
        "voice": "vo_adv_5142322_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "現在不是裝傻的時候了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n敵人要行動了，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請舉起武器吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好！",
        "unit_id": 129811,
        "voice": "vo_adv_5142322_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "敵人每一擊的力道都很重！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不能只顧著攻擊，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也要留意防禦喔！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻。",
        "unit_id": 129911,
        "voice": "vo_adv_5142322_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n攻擊就是最好的防禦……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也有這種說法吧？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我就接受妳的忠告來戰鬥吧。",
        "unit_id": 129911
    }
]