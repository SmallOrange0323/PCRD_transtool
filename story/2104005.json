[
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在月光學院內，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n貪吃佩可一行人與學生們進行交流的日子，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在喧鬧之中一眨眼就過去了……"
    },
    {
        "type": "background",
        "background": "500081"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "時間來到了最後一天的前日，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在這天的放學後——"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……\n……",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}。\n怎麼了嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你怎麼還沒有回去呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈☆",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n的確是這樣呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一想到明天，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就要和這間教室分開了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後突然，",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "覺得有一點捨不得。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以才想",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再稍微待在這裡一下。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對啊☆",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "老實說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想再待個一年……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都想要在這打擾個三年了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的。",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也覺得非常、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常的開心。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……可是。",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n跟大家多多交流的這個目標，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n已經充分地達到了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也該回崗位了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n做為一名公主",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不得不去完成的職責，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有一大堆在等著我呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……{player}。",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n接續前陣子",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你和我說的那個話題。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當時你",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "稍微想起來的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「那邊」……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……在那個被稱為「現實」的世界中，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也有著和這裡相似、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被稱作「學校」",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的地方對吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我啊……",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "完全想不起來呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……就只有之前",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "去救小凱留的時候，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像有做了一場不是這個世界的夢而已……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但對於存在著「那邊的世界」的這個話題時，",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n很不可思議地是我完全不覺得有哪裡奇怪呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n以前",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "諾維姆和我們說明這件事時，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也有一樣的感覺。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……真令人困擾呢。",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "夢的「那邊」才是真實世界……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "居然有這種事……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的確，",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也曾想過這個世界的組成有點奇怪。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是我們，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也確實地在「這邊」的世界笑著、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哭著，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n並且吃著美食……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像這樣生活著。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……{player}，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你想怎麼做呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……可、",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可是，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該怎麼做？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們該做些什麼，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才能到「那邊」去呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說的也是呢……",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這不僅是想不想的問題而已。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就連要如何才能過去「那邊」，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也完全不清楚。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽起來也不像能用傳送魔法到達的地方……",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "按照你在夢中遇到的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那位米奈娃小姐的說法，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n首先我們得收集好那個叫「索爾魔珠」的東西對吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是……",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這還是「首先」而已，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也就表示還不只這樣對吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且假設",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們能夠到「那邊」去了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "卻也不知道還能不能",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "回到「這邊」來呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就我個人而言，",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "目前感覺……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "光是要做好身為公主的職責，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就已經竭盡全力了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……若要我",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "老實說的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比起思考該怎麼去「那邊」這件事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對我來說首先……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比較想要",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好好回報大家呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟當時為了打倒霸瞳皇帝，",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我受到了你",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有大家非常多的幫助。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哪怕這份恩情還得再慢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也想報答大家。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿☆",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n怎麼可以不放在心上呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哪怕我再怎麼努力，",
        "unit_id": 105812,
        "voice": "vo_adv_2104005_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可能也回報不完",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你賭上性命一次又一次",
        "unit_id": 105812
    },
    {
