[
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ふっふっふ、",
        "unit_id": 105312,
        "voice": "vo_adv_6106103_000"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "貴公！　",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "どうだ、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "この装いは！",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n実用性と機能美を兼ね備えた完璧な仕立てだ。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "どのような難題が",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n立ち塞がろうとも、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "もはや恐れるに足るまい！　",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "実に気に入ったぞ！",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "なぁっ！？　",
        "unit_id": 105312,
        "voice": "vo_adv_6106103_001"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "わわ、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "私としたことが……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ち、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "違うのだ！",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n装いも新たにしたことだし、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ここは一つ甘味で景気づけをと思って……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "んむぅっ",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "──や、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "やめろっ！　",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ハンカチで拭うなぁっ！",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "あっ、",
        "unit_id": 105312,
        "voice": "vo_adv_6106103_002"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "これはその……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "はは、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "メニューの名前を記したメモだ。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nカフェのメニューは種類が多い上に、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "どれもこれも名前が長くてな……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n覚えるのに難儀していて……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "貴公も覚えるのを手伝ってくれないか？",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そうだろう、",
        "unit_id": 105312,
        "voice": "vo_adv_6106103_003"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そうだろう！　",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "特にこのエプロン！",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n裾の部分まで生地がしっかり縫いこまれていて、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "頑丈で機能的で──",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "あっ……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "と、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "すまない。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "たくしあげるのははしたなかったな、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "はは……",
        "unit_id": 105312
    }
]