[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美美和{player}\n來找之前所救助的小小格里芬玩耍――"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哇～軟綿綿的～♪",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_000"
    },
    {
        "type": "dialogue",
        "name": "小小格里芬",
        "words": "噗噗噗噗，咕嚕咕嚕～♪",
        "unit_id": 2211
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗯，",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_001"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美也很開心呦～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "欸嘿嘿～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥也快過來這邊～",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_002"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "一起玩吧～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……咦？",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_003"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n哥哥，有許多人朝這裡走過來了耶？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "喔，看來小小格里芬的目擊情報",
        "unit_id": 911,
        "voice": "vo_adv_1020006_004"
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "似乎是真的。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "好呀！那麼就馬上來捕捉吧！",
        "unit_id": 811,
        "voice": "vo_adv_1020006_005"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦～！？",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_006"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n為什麼你們要抓小小格里芬先生呢？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "啊？這個小鬼幹什麼啊？",
        "unit_id": 911,
        "voice": "vo_adv_1020006_007"
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "因為那傢伙的毛皮可以賣到好價錢啊。",
        "unit_id": 811,
        "voice": "vo_adv_1020006_008"
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "\n雖然國家是禁止販賣的。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "知道了就給我去別的地方玩。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "你們要小小格里芬先生的毛皮……？",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_009"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不、不能做這種事啦～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n這樣牠好可憐呦～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "啊啊，",
        "unit_id": 811,
        "voice": "vo_adv_1020006_010"
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "可惡！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "\n這小鬼在這裡晃來晃去真煩人！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "\n別來阻礙我！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "啊唔……！",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_011"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n嗚哇～好痛喔～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "啊？你也打算來阻礙我嗎？",
        "unit_id": 911,
        "voice": "vo_adv_1020006_012"
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "給我讓開",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "哼！根本只會放話嘛！",
        "unit_id": 911,
        "voice": "vo_adv_1020006_013"
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "馬上就被打趴在地上了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "這樣就沒有人妨礙我們了。",
        "unit_id": 811,
        "voice": "vo_adv_1020006_014"
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "\n那麼，快點抓住牠吧！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥、哥哥，你不要緊吧？",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_015"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "怎麼辦……",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_016"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n再這樣下去，小小格里芬先生會……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦？哥哥有作戰計畫嗎？",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_017"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……美美只要去小小格里芬先生那裡就可以了吧。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美知道了～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥要和美美一起",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_018"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n解救小小格里芬先生喔！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "可惡！",
        "unit_id": 911,
        "voice": "vo_adv_1020006_019"
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "\n這傢伙突然大鬧起來了！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "你還想打嗎！？",
        "unit_id": 811,
        "voice": "vo_adv_1020006_020"
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "\n真是個煩人的傢伙！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "嗯？這個叫聲是……？",
        "unit_id": 911,
        "voice": "vo_adv_1020006_021"
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "\n那邊也有小小格里芬嗎！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "是、是你假裝的嗎！",
        "unit_id": 811,
        "voice": "vo_adv_1020006_022"
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "\n你竟然趕欺騙我們！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "\n你是在挑釁我們嗎！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥正在引開那群人的注意呦～",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_023"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "小小格里芬先生，趁現在趕快逃走吧～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "唔哇！",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_024"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n你突然這樣是怎麼了～？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "你喜歡和美美在一起嗎？",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_025"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "好喔～我們一起逃走吧～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "欸嘿嘿，小小格里芬先生的背上好～溫暖♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "喂、喂！",
        "unit_id": 911,
        "voice": "vo_adv_1020006_026"
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "\n她們打算逃走喔！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "才不會讓妳們得逞！",
        "unit_id": 811,
        "voice": "vo_adv_1020006_027"
    },
    {
        "type": "dialogue",
        "name": "盜獵者２",
        "words": "\n發射網槍！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哇！？",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_028"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n我們被網子網住了～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "小小格里芬",
        "words": "噗噗噗噗……",
        "unit_id": 2211
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "小小格里芬先生也動彈不得了……",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_029"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "這、這樣的話……就用美美的劍！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n我砍，我砍～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "太好了！",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_030"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n網子開了～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "小小格里芬先生快點逃～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "糟、糟了！",
        "unit_id": 911,
        "voice": "vo_adv_1020006_031"
    },
    {
        "type": "dialogue",
        "name": "盜獵者１",
        "words": "\n那個小鬼！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "小小格里芬",
        "words": "噗噗噗噗，咕嚕咕嚕～",
        "unit_id": 2211
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哇～好～厲害！",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_032"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n美美飛在天空中耶～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "飛在天空中呦♪",
        "unit_id": 102011,
        "voice": "vo_adv_1020006_033"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n啪噠啪噠、蹦蹦♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n可以飛到任何地方呦～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是小小格里芬平安脫逃，\n幾天後王宮騎士團根據{player}們的\n目擊情報抓到了盜獵者們。"
    }
]