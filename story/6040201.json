[
    {
        "type": "background",
        "background": "500159"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那個叫半藏的傢伙，",
        "unit_id": 102611,
        "voice": "vo_adv_6040201_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "居然敢傷害真陽，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是不可原諒。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "他那身打扮也很奇怪，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "到底是什麼來頭。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "都是多虧了真陽在應對時很冷靜呢。",
        "unit_id": 102611,
        "voice": "vo_adv_6040201_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然覺得她人太好了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是在面對那種人的時候",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣就好了對吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不對，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "果然還是很讓人生氣。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "黑社會之類的嗎？　",
        "unit_id": 102611,
        "voice": "vo_adv_6040201_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "他們",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "的確看起來不太正當呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "竟然帶著那種人，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "監察官也不是什麼正派的人吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們真的",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "遇到了一件棘手的事呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那孩子也是什麼危險人物嗎？　",
        "unit_id": 102611,
        "voice": "vo_adv_6040201_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不是啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這樣反而讓",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那種打扮的謎團變得更深了呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說真的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "到底是怎麼樣啊……",
        "unit_id": 102611
    }
]