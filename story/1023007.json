[
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "唉……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……咦？",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "{player}哥哥！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你好～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "總覺得我們最近很常見面呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你家難道是在這附近嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n還是說，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只是來散步？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我？",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_003"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我呀～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n是因為有一點事情。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒錯沒錯。",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我是因為和前陣子相同的事情",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n而來到城鎮裡的。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我平常",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n不太會到【咲戀育幼院】之外的地方來。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我沒有很喜歡",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n在外面走動。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "比較喜歡在室內玩耍。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽也說我",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n「興趣大多比較偏內向呢」。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "經常會罵我說",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "小孩子就到外頭去玩～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是，這也沒辦法呀。",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_008"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我從小，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就幾乎都是待在家裡。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也不知道在外面到底",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n該玩些什麼才好。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n在外面都會玩些什麼？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要是方便，請你教我吧♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不對。",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n反正你好像也很閒，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們一起玩吧！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯？",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n啊啊，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我的事情已經辦完了……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以就算去玩也沒關係。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就是……",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_013"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我必須每週",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n回自己家兩次",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "和爸爸媽媽見面。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只不過",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我並不太想見他們。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_015"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我沒有說過嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我在一個叫做【咲戀育幼院】的地方生活。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_016"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那裡是類似孤兒院的地方。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但是，\n其實我的家人，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n並沒有像胡桃一樣消失了……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我很普通地有自己的家，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n也有爸爸媽媽。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒有那回事……",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_019"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我最喜歡",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "爸爸媽媽了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那些人感覺",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有點不太一樣。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我沒辦法",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "很好地解釋清楚。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯？",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_021"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n咦，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你怎麼好像一臉擔心的表情？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒、沒事的啦。",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_022"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我家",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n完全不是什麼複雜的家庭！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "爸爸媽媽",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_023"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "都對我非常溫柔喔。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不如說，他們比以前更關心我，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n很珍惜我喔～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只是，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_024"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我有點問題……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n一看到爸爸媽媽，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就會有種奇怪的感覺。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "應該說是違和感嗎？",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_025"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n偶爾會讓我覺得害怕。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿。",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_026"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也有請醫生幫我看過了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n但醫生說這是青春期容易出現的問題。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "會覺得，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_027"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n周圍的人",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "都像是「虛擬」的一樣。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "會覺得大家在欺騙自己，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_028"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n看起來就像是在演戲的樣子……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "聽說是到了青春期開始萌生獨立心後，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n經常會出現的問題。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只是我的狀況比較嚴重……",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_030"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "醫生他是這麼說的。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "爸爸媽媽並沒有錯，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_031"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是我有點奇怪。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_032"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我不管怎樣，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n都會覺得他們不是真正的爸爸媽媽……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "會不禁感到害怕，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_033"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "然後用很過分的態度對他們。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n對他們怒吼、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "大吵大鬧……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n還逃家了",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好幾次。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也覺得",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_034"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那樣很對不起爸爸媽媽……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因此決定，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n在自己穩定下來前，先在【咲戀育幼院】生活。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就像是住院的感覺～",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_035"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不對，應該說是復健？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_036"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我家是蠻有地位的名門，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n然後與似乎同樣是貴族的咲戀媽媽有點關係……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以就將我",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_037"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n託給咲戀媽媽照顧了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_038"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我要是一直待在育幼院，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n會很對不起",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽和爸爸媽媽……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_039"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我必須要好好振作起來才行。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但總是不太順利。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……對不起。",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_040"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這些事",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "和哥哥沒有關係呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "太陽馬上就要下山了，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_041"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n要是太晚回去，咲戀媽媽會擔心……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我要回家囉。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿。",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_042"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n雖然對爸爸媽媽很抱歉，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n但我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "最近呀……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "和自己真正的家比起來，",
        "unit_id": 102311,
        "voice": "vo_adv_1023007_043"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n覺得【咲戀育幼院】",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "更有自己家的感覺。",
        "unit_id": 102311
    }
]