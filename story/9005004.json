        "type": "dialogue",
        "name": "4人",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_9005004_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "必須準備舞台、",
        "unit_id": 107111,
        "voice": "vo_adv_9005004_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "器材、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "服裝、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "工作人員",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "等等……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當然，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要我這位能幹的製作人出馬，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "勢必也得付一筆委託費吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過既然是為了那小子，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會算妳便宜點的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "抱、",
        "unit_id": 106412,
        "voice": "vo_adv_9005004_024"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "抱歉打擾了──────────！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聽到她提出的金額，雪菲立刻全速逃離現場。"
    }
