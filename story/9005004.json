    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪菲繼續思考送禮的事，同時在街上漫步。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一、二、",
        "unit_id": 1,
        "voice": "vo_adv_9005004_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一、二！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個響亮的聲音……",
        "unit_id": 106412,
        "voice": "vo_adv_9005004_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "莫非是……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌！",
        "unit_id": 102913,
        "voice": "vo_adv_9005004_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "注意站位！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n妳有點太後面了！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好的！",
        "unit_id": 104211,
        "voice": "vo_adv_9005004_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "紡希，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳的聲音有點飄。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n妳已經累了嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "才沒有那種事！",
        "unit_id": 105411,
        "voice": "vo_adv_9005004_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我才不會輸給小望跟千歌呢……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "果然是",
        "unit_id": 106412,
        "voice": "vo_adv_9005004_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "慈樂之音的三位成員……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "正在舞台上練習啊。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "即使是練習，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "她們也好認真、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好美喔……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……嗯？",
        "unit_id": 102913,
        "voice": "vo_adv_9005004_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那是……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雪菲？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n有什麼事嗎～？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊！？",
        "unit_id": 106412,
        "voice": "vo_adv_9005004_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "被發現了！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "抱歉，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我不是故意要打擾妳們練習的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵，",
        "unit_id": 104211,
        "voice": "vo_adv_9005004_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒關係啦。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們只是簡單排練一下而已。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過小望還是一樣賣力就是了。",
        "unit_id": 105411,
        "voice": "vo_adv_9005004_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……對了雪菲，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳找我們",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有什麼事嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我看妳剛才一臉嚴肅地看著我們。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，",
        "unit_id": 106412,
        "voice": "vo_adv_9005004_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個──",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "送給那個人",
        "unit_id": 104211,
        "voice": "vo_adv_9005004_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "的禮物嗎……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這可是個難題呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生那個人啊，",
        "unit_id": 105411,
        "voice": "vo_adv_9005004_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "隨便給他個東西他都開心得要命，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n妳不必這麼認真思考吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "反正",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "送什麼他都",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的很開心。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "紡希……",
        "unit_id": 104211,
        "voice": "vo_adv_9005004_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "原來妳這麼常",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "送禮物給他啊……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "──來場特別演唱會怎麼樣！",
        "unit_id": 102913,
        "voice": "vo_adv_9005004_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦！？",
        "unit_id": 106412,
        "voice": "vo_adv_9005004_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n特別演唱會！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "專為他",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "開的……！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒錯！",
        "unit_id": 102913,
        "voice": "vo_adv_9005004_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓跟他有交情的人通通站上舞台！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家一起為他獻唱怎麼樣！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n訓練課程就交給我們♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──喔，",
        "unit_id": 107111,
        "voice": "vo_adv_9005004_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳們在討論有趣的話題啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "製作人！？",
        "unit_id": 1,
        "voice": "vo_adv_9005004_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳剛才說特別演唱會是吧？",
        "unit_id": 107111,
        "voice": "vo_adv_9005004_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n人氣如日中天的現役偶像團體，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "專為一個人開演唱會嗎。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我個人是完全不反對啦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真、",
        "unit_id": 106412,
        "voice": "vo_adv_9005004_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的嗎！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯……",
        "unit_id": 107111,
        "voice": "vo_adv_9005004_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當然啦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們先來聊聊預算方面吧。",
        "unit_id": 107111
