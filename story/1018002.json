[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊緒向在廣場看書的{player}搭話。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀。",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n好巧喔？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你在做什麼呀？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "念書……？",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n啊，你在看教科書啊。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "自動自發地念書，真了不起呀。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？可是這個是很基礎的部分吧？",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這應該不是你這個年齡要學的範圍……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……欸！？喪失記憶？",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n因為沒有學習的記憶，所以只能從基礎開始學嗎……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這、這樣啊……",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n完全沒有發現。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對了！",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果你願意的話，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我可以教你……如何？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "別看我這樣，其實我是學校的老師唷！",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n喂，要不要成為我學校的學生？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "上次你還救了我，",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我也希望可以幫你。如何？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太好了！",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n那你可以跟我來嗎？",
        "unit_id": 101811
    },
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "到了！這裡就是我任職的學校，",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n月光學院。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天是週日，所以沒有其他人在，",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但平常有各種年齡和種族的學生在這裡念書♪",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以喪失記憶的你，",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n也可以安心地在這裡念書。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，被稱呼為老師，",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n還是有點害羞呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我還是個新人。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以呢，叫我伊緒就好了。",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們開始學習吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我負責的科目是國文，",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不過其他科目也可以指導基礎的部分。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那首先得先知道你理解的範圍。",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n先從哪個科目開始教好呢?",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你有希望先學哪個科目嗎？",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n現在在讀什麼呢？",
        "unit_id": 101811
    },
    {
        "type": "still",
        "still": "101800201"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，正好在看國文的教科書呀。",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n有沒有不懂的地方呢？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這個問題嗎？要回答登場人物的心情是吧。",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "仔細讀讀看這個句子。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n……如何？知道了嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對，答對了！真棒。",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……欸？是在說我嗎？",
        "unit_id": 101811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "抱歉！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我太靠近了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n太專注在指導，一不小心就……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸？為什麼？",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n距離太近了……？",
        "unit_id": 101811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "糟糕！",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不知不覺就靠得這麼近！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣的確無法學習呢……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "之後我會注意的～",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那下一個問題。",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這個你會嗎？",
        "unit_id": 101811
    },
    {
        "type": "still",
        "still": "101800201"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯嗯，很好唷。",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_026"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，這裡錯了唷。",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_027"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這個的話，像這樣……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，抱歉！",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯～教導你的話，總不小心會太放鬆呢～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那這裡的話呢，看教科書的這裡……",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！又跟你貼在一起了……",
        "unit_id": 101811,
        "voice": "vo_adv_1018002_030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊～怎麼辦才好呢～",
        "unit_id": 101811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "總是立刻貼近過來的伊緒，\n讓{player}始終難以集中精神……"
    }
]