    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃……",
        "unit_id": 101112,
        "voice": "vo_adv_5080101_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那是婆婆已經過世了的意思嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "才不是！",
        "unit_id": 100711,
        "voice": "vo_adv_5080101_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "婆婆還活著喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可是之後會離開，再也不能做布丁給宮子了！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原來如此。",
        "unit_id": 103311,
        "voice": "vo_adv_5080101_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "非常抱歉，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我完全沒聽懂妳在說什麼啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "別說了，快讓宮子吃婆婆做的布丁～！！",
        "unit_id": 100711,
        "voice": "vo_adv_5080101_007"
    },
    {
