[
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "志那都和埃拉回到原本的世界，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n厄莉絲再次陷入沉睡後過了數日……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n優衣正在靠近蘭德索爾的平原上與魔物對峙。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼……",
        "unit_id": 100211,
        "voice": "vo_adv_1289003_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "！",
        "unit_id": 100211,
        "voice": "vo_adv_1289003_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我得集中精神……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "集中──",
        "unit_id": 100211
    },
    {
        "type": "still",
        "still": "128900301"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「草野優衣。」",
        "unit_id": 129013,
        "voice": "vo_adv_1289003_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「──集中精神。」",
        "unit_id": 129013,
        "voice": "vo_adv_1289003_003"
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……！",
        "unit_id": 100211,
        "voice": "vo_adv_1289003_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "光之精靈啊──！",
        "unit_id": 100211,
        "voice": "vo_adv_1289003_005"
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……打、",
        "unit_id": 100211,
        "voice": "vo_adv_1289003_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "打倒了……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……厄莉絲。",
        "unit_id": 100211,
        "voice": "vo_adv_1289003_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……那時候，",
        "unit_id": 100211,
        "voice": "vo_adv_1289003_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n厄莉絲確實幫助了我。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "她在我身旁，",
        "unit_id": 100211,
        "voice": "vo_adv_1289003_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "和我一起",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "並肩作戰。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……我這樣子",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不行啊。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "只不過是這樣……",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就誤以為自己",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "更接近",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "厄莉絲的內心了。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……不可能",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼輕易就能和她拉近距離。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那只是",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "暫時幫我一把而已。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且……",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n那也是因為騎士先生",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "拜託厄莉絲的。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這些我明明都曉得……",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為什麼",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還是會不自覺地誤會呢。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "…",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "…一定是，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n因為我有機會道歉",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "了吧。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒錯……",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n因為我自己會比較輕鬆，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以才那麼想的。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這只是我的自我滿足。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我和厄莉絲之間的距離，",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "依然沒有",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "改變。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可不能自以為是起來。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……可是。",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "稍微有一點，",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n真的感覺",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "稍微有更接近她一點了。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我忍不住會這麼想。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……要是我這麼想，",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "又會",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "惹厄莉絲生氣了吧。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我傷害了厄莉絲──",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不對，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不只是厄莉絲。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我傷害了",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個世界的所有人。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……怎麼能這麼容易",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就感到輕鬆呢。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生？",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n你怎麼會在這……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣啊……",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "被發現了吧。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我一個人",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "接受了委託的事。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這……",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想了解，",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n現在的自己",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有多少力量。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為要是有大家在，",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我就會依靠大家……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我什麼都沒說就自己接下任務了。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個，",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我有件事想告訴你。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……我想，",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "出去",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "旅行。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不是去冒險，",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而是旅行……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這趟旅行是為了",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "償還傷害世界的罪孽。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……因為，",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個世界，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是應我的希望所產生的。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生……",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……但是，",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_034"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這仍然",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是我原本",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就期望發生的事。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哪怕",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "當下被霸瞳皇帝妨礙了。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且，",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n讓厄莉絲背負「諸惡根源」責任的人──",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "毫無疑問，",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_036"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就是我。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是我的願望，",
        "unit_id": 100213,
        "voice": "vo_adv_1289003_037"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "讓一切都扭曲了。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有人因此受了傷，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我甚至到現在都還在傷害人……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "包括厄莉絲和騎士先生……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就連贊恩先生",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "和雪菲也是……！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
