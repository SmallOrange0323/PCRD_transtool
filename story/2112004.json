    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n當時是被你和可可蘿小姐",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "救下來了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "假如，",
        "unit_id": 106412,
        "voice": "vo_adv_2112004_048"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就連那件事……",
