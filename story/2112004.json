        "voice": "vo_adv_2112004_049"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n根本沒資格",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "和大家……",
