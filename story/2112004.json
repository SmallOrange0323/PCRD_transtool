    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………",
        "unit_id": 106412,
        "voice": "vo_adv_2112004_043"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……「失去記憶前的我」……",
        "unit_id": 106412,
        "voice": "vo_adv_2112004_044"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n好像危害過那個",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "叫做霸瞳皇帝的人……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "假如厄莉絲等人",
