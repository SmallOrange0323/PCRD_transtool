        "voice": "vo_adv_2112004_045"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "想危害七冠，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "然後，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "假如我原本是",
