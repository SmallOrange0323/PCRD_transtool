    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "主要有三位。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "排在第一的，",
        "unit_id": 101411,
        "voice": "vo_adv_2112004_073"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是凱留。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我認為可能性是很低……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但畢竟她是有前科的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "搞不好，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "她或許是容易被洗腦的體質也說不定。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "排在第二的，",
        "unit_id": 101411,
        "voice": "vo_adv_2112004_074"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是優衣。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這部分當然是因為，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "她和敵方首腦似乎使用了相同的角色。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就算存在什麼魔法上的連結，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也並不奇怪。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "接下來，",
        "unit_id": 101411,
        "voice": "vo_adv_2112004_075"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "第三位。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我認為，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "目前可能性最高的人選是……",
        "unit_id": 101411
    },
    {
        "type": "background",
        "background": "501600"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……哎呀。",
        "unit_id": 106812,
        "voice": "vo_adv_2112004_076"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真厲害。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n霞的推理，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是正確答案。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……！",
        "unit_id": 105913,
        "voice": "vo_adv_2112004_077"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼說來……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真的是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐她……",
        "unit_id": 105913,
        "voice": "vo_adv_2112004_078"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和敵方",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "互通……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這邊先說清楚好了。",
        "unit_id": 106812,
        "voice": "vo_adv_2112004_079"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n她並不是基於自己的意志",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在流出這邊的情報。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大概是有什麼前提條件吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "例如她的精神",
        "unit_id": 106812,
        "voice": "vo_adv_2112004_080"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "變得像幼童一樣的時候。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "或者是……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n平時休眠的厄莉絲",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "處於覺醒狀態的時候才行。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……雪菲她的功用，",
        "unit_id": 106812,
        "voice": "vo_adv_2112004_081"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是厄莉絲的「終端」。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就像真那能夠將魔物及闇影",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "當成自己的「眼」一樣……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這、",
        "unit_id": 105913,
        "voice": "vo_adv_2112004_082"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼說的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "現在的話，",
        "unit_id": 106812,
        "voice": "vo_adv_2112004_083"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "總之可以放心。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n雪菲目前處於深層睡眠狀態。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……因為啊，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我對枕頭動了一點手腳。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_2112004_084"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和怜小姐所懷疑的一樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉比林斯達小姐之所以",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「在這個時間點」找上我們的原因是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯。",
        "unit_id": 106812,
        "voice": "vo_adv_2112004_085"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一部分是因為要等雪菲失去意識之後。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖說距離我被發現只是時間問題，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過目前我還不希望",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對方得知這邊的底牌。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……這件事，",
        "unit_id": 105913,
        "voice": "vo_adv_2112004_086"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓雪菲小姐知道了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她想必會非常、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常的痛苦。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n到時候，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人到底該如何是好……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……總之。",
        "unit_id": 106812,
        "voice": "vo_adv_2112004_087"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n目前這些討論",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就停留在",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我和可可蘿妳心裡吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我會盡量不著痕跡地",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓大家不討論這方面。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要說辦法的話，",
        "unit_id": 106812,
        "voice": "vo_adv_2112004_088"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "倒也不是不能",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "製造遮蔽魔力的結界，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "將雪菲整個人困在裡頭。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只是這個辦法……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……這麼做的話，",
        "unit_id": 105913,
        "voice": "vo_adv_2112004_089"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就會和厄莉絲以及美空，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n想對優衣小姐做的事",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "變得一模一樣了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是啊。",
        "unit_id": 106812,
        "voice": "vo_adv_2112004_090"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這種方法，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就當成最後的手段吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以趁這機會，",
        "unit_id": 106812,
        "voice": "vo_adv_2112004_091"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我先將下一步的目的地，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n告訴共同享有這個祕密的可可蘿好了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_2112004_092"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n麻煩您了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "索爾魔珠",
        "unit_id": 106812,
        "voice": "vo_adv_2112004_093"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "目前還剩下兩顆。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "其中一顆已經失蹤，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過另外一顆",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "的所在位置和",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "擁有者",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我都一清二楚。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………",
        "unit_id": 105913,
        "voice": "vo_adv_2112004_094"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所在位置──",
        "unit_id": 106812,
        "voice": "vo_adv_2112004_095"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在妳的故鄉。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n精靈族的隱世村莊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n而擁有者……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是「嚮導老君」。",
        "unit_id": 106812,
        "voice": "vo_adv_2112004_096"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n作為我們七冠的長老──",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "同時",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也是妳父親",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "的角色。",
        "unit_id": 106812
    }
]