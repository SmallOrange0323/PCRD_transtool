    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "以及彌勒……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n給動過什麼",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "手腳之類的……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "之所以會失去記憶，",
        "unit_id": 106412,
        "voice": "vo_adv_2112004_040"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n之所以會是龍人族這種",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "非常稀有的種族……",
