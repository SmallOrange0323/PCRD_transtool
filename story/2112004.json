        "voice": "vo_adv_2112004_042"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n並不是什麼應該",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "待在你們身邊的存在……",
