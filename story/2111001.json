        "type": "dialogue",
        "name": "彌勒",
        "words": "連美空小姐對誓約女君與",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "變貌大妃",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n施加的洗腦魔法都會解除掉。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來如此……",
        "unit_id": 106011,
        "voice": "vo_adv_2111001_071"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這就是你",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拿贊恩當棋子的理由嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n少了魔法等等{player}的強化，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在肉搏戰中幾乎無人是他的對手……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "就是這麼回事。",
        "unit_id": 192611,
        "voice": "vo_adv_2111001_072"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "不愧是千里真那的血親，妳很聰明呢。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "希留耶小姐。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦……！？",
        "unit_id": 106011,
        "voice": "vo_adv_2111001_073"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "好了。",
        "unit_id": 192611,
        "voice": "vo_adv_2111001_074"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n我不需要",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "再打出更多底牌了吧。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "作為「敵人」。",
        "unit_id": 192611,
        "voice": "vo_adv_2111001_075"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n作為身帶因果之人。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n就讓他來當諸位的對手吧。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……嗚喔喔喔喔喔喔……！",
        "unit_id": 191713,
        "voice": "vo_adv_2111001_076"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哥、",
        "unit_id": 106415,
        "voice": "vo_adv_2111001_077"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哥哥……！",
        "unit_id": 106415
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "嘖！",
        "unit_id": 191611,
        "voice": "vo_adv_2111001_078"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n在那傢伙的領域之內，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n連轉移道具都不能用嗎……！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "喂、",
        "unit_id": 191611,
        "voice": "vo_adv_2111001_079"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "喂，【美食殿堂】！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳們沒有什麼辦法嗎……！？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "魔法無效、",
        "unit_id": 105811,
        "voice": "vo_adv_2111001_080"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "強化被消除，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且對手還是贊恩先生……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很不妙呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這是面臨絕境了……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "可惡！",
        "unit_id": 191611,
        "voice": "vo_adv_2111001_081"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳們還真沒用啊，喂……！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊！？",
        "unit_id": 106011,
        "voice": "vo_adv_2111001_082"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那你也一樣吧，臭矮子！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對了～我想到了一個好主意。",
        "unit_id": 106011,
        "voice": "vo_adv_2111001_083"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你來當我們的擋箭牌！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們會趁這段時間逃走！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "啊啊！？",
        "unit_id": 191611,
        "voice": "vo_adv_2111001_084"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n開什麼玩笑，要當擋箭牌妳去當啊，垃圾貓！！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "兩、",
        "unit_id": 105811,
        "voice": "vo_adv_2111001_085"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "兩位！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在不是吵嘴的時候……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "黃的",
        "words": "噗嚕、",
        "unit_id": 191615
    },
    {
        "type": "dialogue",
        "name": "黃的",
        "words": "噗嚕噗嚕……！",
        "unit_id": 191615
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "！？",
        "unit_id": 191611,
        "voice": "vo_adv_2111001_086"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n黃的！？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你在幹嘛，給我退後啊，笨蛋！",
        "unit_id": 191611,
        "voice": "vo_adv_2111001_087"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n那可不是",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "平時的贊恩──！",
        "unit_id": 191611
    }
]