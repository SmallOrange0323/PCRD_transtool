[
    {
        "type": "background",
        "background": "500102"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──在蘭德索爾‧王座之廳。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n貪吃佩可、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "凱留、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪菲遇到了厄莉絲的合作者‧彌勒。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n彌勒在此時召來的男子是──"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊……",
        "unit_id": 191713,
        "voice": "vo_adv_2111001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊啊啊……",
        "unit_id": 191713
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "唔……",
        "unit_id": 191611,
        "voice": "vo_adv_2111001_001"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "真的是贊恩嗎……？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "史萊姆們",
        "words": "噗嚕噗嚕……！",
        "unit_id": 191612
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哥哥！",
        "unit_id": 106415,
        "voice": "vo_adv_2111001_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106415
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哥哥……！",
        "unit_id": 106415
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "唔唔唔……",
        "unit_id": 191713,
        "voice": "vo_adv_2111001_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好痛……",
        "unit_id": 105811,
        "voice": "vo_adv_2111001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……那、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個是……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "贊恩先生……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那副模樣",
        "unit_id": 106011,
        "voice": "vo_adv_2111001_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是什麼……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n簡直就像怪物一樣！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哥哥，",
        "unit_id": 106415,
        "voice": "vo_adv_2111001_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "吶！",
        "unit_id": 106415
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我",
        "unit_id": 106415
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "想起來了！",
        "unit_id": 106415
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我想起哥哥了！",
        "unit_id": 106415
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哥哥也",
        "unit_id": 106415,
        "voice": "vo_adv_2111001_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "想起我了",
        "unit_id": 106415
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對吧！？",
        "unit_id": 106415
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106415
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "求求你，",
        "unit_id": 106415
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "求求你回答我……！",
        "unit_id": 106415
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……咕……",
        "unit_id": 191713,
        "voice": "vo_adv_2111001_008"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "咕嗷嗷嗷……",
        "unit_id": 191713
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "退後，",
        "unit_id": 105811,
        "voice": "vo_adv_2111001_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小雪菲！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在的贊恩先生",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像失去了意識……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他的攻擊沒像上次戰鬥那樣手下留情，",
        "unit_id": 106011,
        "voice": "vo_adv_2111001_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這次被打中真的會送命啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……唔",
        "unit_id": 106411,
        "voice": "vo_adv_2111001_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "彌勒……！",
        "unit_id": 106411,
        "voice": "vo_adv_2111001_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你對哥哥",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "做了什麼……！？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "就像美空做過的那樣，",
        "unit_id": 191611,
        "voice": "vo_adv_2111001_013"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你對他洗腦了嗎！？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "喂！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "不。",
        "unit_id": 192611,
        "voice": "vo_adv_2111001_014"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n洗腦魔法需要有最低限度的思考能力",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "才能發揮效果。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "然而──",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "很遺憾的是，",
        "unit_id": 192611,
        "voice": "vo_adv_2111001_015"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n他已經死於厄莉絲的攻擊之下，",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "連一點思考能力都沒有留下。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……！",
        "unit_id": 106411,
        "voice": "vo_adv_2111001_016"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "所以，",
        "unit_id": 192611,
        "voice": "vo_adv_2111001_017"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "我用魔法強行將他製成了傀儡。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "畢竟，即使已經化為屍體，",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n讓龍人族優異的肉體",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "就這樣消失也太可惜了。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "傀儡……！？",
        "unit_id": 191611,
        "voice": "vo_adv_2111001_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的、",
        "unit_id": 106011,
        "voice": "vo_adv_2111001_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的確……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來不像洗腦魔法……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "死靈術。",
        "unit_id": 192611,
        "voice": "vo_adv_2111001_020"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "亡者召還。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "殭屍製造術──",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n即使被視為禁術，",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n《阿斯特朗傳奇》中",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "也實裝了這類邪術吧。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "我不太擅長",
        "unit_id": 192611,
        "voice": "vo_adv_2111001_021"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "運用魔法，",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "不過，我從厄莉絲那裡",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "獲得了力量的輔助。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "死靈術……！？",
        "unit_id": 191611,
        "voice": "vo_adv_2111001_022"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "所以說，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "現在的贊恩，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "就像是會走動的屍體嗎……！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怎、",
        "unit_id": 106411,
        "voice": "vo_adv_2111001_023"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怎麼這樣……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你",
        "unit_id": 105811,
        "voice": "vo_adv_2111001_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為什麼要做這麼過分的事！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "……？",
        "unit_id": 192611,
        "voice": "vo_adv_2111001_025"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "過分",
        "unit_id": 192611,
        "voice": "vo_adv_2111001_026"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "是什麼意思……",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "我只是在協助他，",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n完成職責",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "而已。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你說職責……！？",
        "unit_id": 106411,
        "voice": "vo_adv_2111001_027"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "美空小姐曾說過吧？",
        "unit_id": 192611,
        "voice": "vo_adv_2111001_028"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n【憤怒‧軍團】，",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n是為了持續達成優衣小姐的願望",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "而安排的「敵人」。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "唔……！",
        "unit_id": 191611,
        "voice": "vo_adv_2111001_029"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "竟敢瞧不起我們，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "可惡……！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "不只【憤怒‧軍團】而已。",
        "unit_id": 192611,
        "voice": "vo_adv_2111001_030"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n以前則是霸瞳皇帝君臨大地，",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n作為你們的「敵人」",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "統治著這個世界吧。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "霸瞳皇帝──",
        "unit_id": 192611,
        "voice": "vo_adv_2111001_031"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "「他」的存在",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "無比巨大。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n簡直就像是阻擋命運濁流的",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "巨大防洪閘。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……該不會……",
        "unit_id": 106011,
        "voice": "vo_adv_2111001_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n帆稀那時候",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所說的話……",
        "unit_id": 106011
    },
    {
        "type": "background",
        "background": "500021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "七冠的其中一人",
        "unit_id": 106711,
        "voice": "vo_adv_2111001_033"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "──霸瞳皇帝離去，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對世界所造成的影響",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n可比",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "凱留你們想像的，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還要巨大很～多喔，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就彷彿是這個世界",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "破了一個看不見的洞一樣。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為了不掉進",
        "unit_id": 106711,
        "voice": "vo_adv_2111001_034"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個洞裡……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你們最好",
