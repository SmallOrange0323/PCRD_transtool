[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊～……",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有夠心煩的啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "每天每天…",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為了處理最近克莉絲提娜\n襲擊【哞哞自衛隊】公會小屋事件的後續事宜，\n都亂成一團了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們也沒那種閒時間，",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "拜託饒了我吧……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再這樣下去，還會連帶影響到【咲戀育幼院】的",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n日常業務。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "（【咲戀育幼院】是孩子們居住的家，",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n幾乎是那裡唯一戰力的我，卻連日忙於參加會議，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n導致院內的守備變得薄弱。）",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "（如果像前幾天一樣，出現了那個叫什麼闇影的",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那種像魔物的東西的話，就沒辦法應付了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真擔心～明明沒空在這裡偷懶了。）",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "（總之……",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n已經先拜託父親",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n派警衛過來了。）",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "（父親也真是的，",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n連自己人的錢都要拿。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "實在是太貪得無厭了。）",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "（如果可以用金錢換取孩子們的安全那還好解決，",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但再這樣下去，【咲戀育幼院】的經營上會有困難的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要扶養的人數也增加了，家計相當拮据呢。）",
        "unit_id": 102811
    },
    {
        "type": "still",
        "still": "200400101"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "臉色不太好呢，小咲戀。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……請不要在名字前面加『小』，純。",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱歉，太過親暱了。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為我從小咲戀……\n咲戀妳還小的時候就認識妳了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "一不小心就把妳當作孩子看待了。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n失禮了，我向妳謝罪。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒關係的，",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n畢竟純妳在我小時候也陪我玩過。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我一直為了讓自己不被人小看",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n而勉強著自己……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也相當疲憊了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "兩位，",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n要不要喝杯茶～？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊……",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不好意思，讓妳一直做些像服務員的工作，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如此失禮真是抱歉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒關係，人家喜歡款待客人……",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "每天這樣高談闊論，喉嚨應該很痛吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家想喝茶～♪",
        "unit_id": 101011
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "（嗯～",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是個好人呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n【哞哞自衛隊】的公會長……真步。）",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "（她是個既溫柔又穩重的和平主義者。",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "平常的話，我甚至會想要跟她當朋友。）",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "（但現在可是非常時期……不對，是戰爭時期。）\n溫柔反而會變成絆腳石。",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且在這次的事件裡，【哞哞自衛隊】明明是被害者呢。）",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "（她連強硬地交涉都做不到，就這樣被迫接受了妥協方案。",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然實在令人看不太下去……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但畢竟我是站在第三方的立場，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n可不能過度偏袒某一邊呢。）",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝妳的好意，不過茶就不用了。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n畢竟，這也不是什麼女生聚會。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家並沒有打算賄賂喔？",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊……我並沒有猜疑妳，不，應該說我並沒有侮辱妳的意思。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n正如妳所見，我沒辦法喝東西。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳看，我戴著頭盔，不是很方便呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "把頭盔拿掉就好了吧。",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "連臉也不露出來給人看，有些失禮呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，不能以真面目示人是有原因的……",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是我並沒有打算輕視真步妳、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n【哞哞自衛隊】，或是獸人。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這次糾紛，",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是因為我們【王宮騎士團】的副團長……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n克莉絲提娜的自作主張而起。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "整體來說是她個人的失控行徑，",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n給妳們帶來困擾了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們已對她下達關禁閉的處分，讓她進行自我反省。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因此，我希望這次的糾紛能就此告一段落。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也差不多對連日召開的會議感到倦怠了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "（不過，",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n克莉絲提娜應該完全沒有反省之意吧……）",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "（她表面上在關禁閉，",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n實際上卻好像帶著密令",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在蘭德索爾外面形跡可疑地行動著。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "連正式的謝罪都沒有，人家有點耿耿於懷呢。",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我們這邊有人因此負傷了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也有人因為不知道何時會再遭到襲擊，害怕到晚上無法入睡。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱歉。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是我們【王宮騎士團】，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n沒辦法正式地承認錯誤並謝罪。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們是直屬於皇家的公會，",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n一旦謝罪，就跟整個國家低頭是一樣的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而在他國眼裡，這是一個示弱的行為。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n人民也會因此對我們感到不信任。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "皇家必須一直保持威嚴來統領國家。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然以我個人而言，也對這次的事情感到很抱歉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "然後……",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n遭到破壞的【哞哞自衛隊】公會小屋的修理費用，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n克莉絲提娜應該已經支付了相應的損害賠償金。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還有給傷者的慰問金。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為她非常有錢呢。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n可以很輕易地付掉這筆錢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不，不是錢的問題。",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是誠意、心意的問題喔。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那……",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果我獻上克莉絲提娜的人頭，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你就會滿意了嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "才、",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_041"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "才沒人說那種危險的話。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "你們也太血腥了吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "【王宮騎士團】的行事風格就是這樣呢。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_042"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是個嚴重的政治問題。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n把這件事當成克莉絲提娜個人的失控行徑來處理……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n對我們雙方都好吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話是這麼說沒錯…………",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_044"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但那種做法，大家無法認同喔。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "（嗯",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "～好累喔…………",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是，人家不努力不行呢）",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "（如果可以用錢之類的輕鬆解決，",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這件事也可以就此打住……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但這次不解決根本的問題，同樣的事情又會再度發生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "（下次如果又發生同樣的事，",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_047"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n或許就真的會演變成戰爭……）",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "（一般人類將會與獸人全面開戰。",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_048"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這樣的話，就會有更多人受傷了。）",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "（【哞哞自衛隊】的大家是由人家在安撫的說。",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_049"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n獸人們和【動物苑】全體抱著不畏開戰的心情。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n可能是因為獸人比較血氣方剛吧？）",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "（真討厭啊，這種事情…………想要以更溫和的方式解決說。",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_050"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "已經發生的事情，不能當作『從未發生』。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n必須想辦法將走向戰爭的態勢引導至和平的方向）",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "（居住在蘭德索爾的獸人們，",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_051"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n花了很長的時間才變得能夠過著和平的生活。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n拼命努力還得忍受許多討厭的事情）",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "（不能只是因為一次的意外，",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_052"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就讓一路累積下來的過去全部毀滅。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那樣人家也沒有臉面對祖先們）",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "（只是……",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_053"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n如此具歷史性的重要使命……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還有重擔和責任，人家有辦法背負嗎？）",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "(人家連自己家庭的問題，",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_054"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n都逃避了)",
        "unit_id": 101011
    },
    {
        "type": "still",
        "still": "200400101"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真步。",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_055"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不好意思換個話題，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有關闇影的調查有沒有進展？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦？",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_056"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n啊，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我們公會的霞正在調查這件事。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "目前只有在城鎮裡才有人目擊過闇影的樣子。",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_057"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果感覺到危險的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n可能還是把群眾疏散到郊外會比較好呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_058"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這樣可能比較好。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我家的孩子們都非常害怕呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在結束對闇影的調查以前……",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_059"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n或許我得先讓他們去安全的地方避難？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果不介意的話，讓人家幫妳介紹吧？",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_060"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有一個公會，平時就和我們【哞哞自衛隊】有來往，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n叫做【伊麗莎白牧場】。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "他們公會在遠離城鎮的深山中，過著安穩和平的日子。",
        "unit_id": 101011,
        "voice": "vo_adv_2004001_061"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那邊的公會長雖然是人類，但是和獸人也非常友好。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家覺得那邊是個中立的安全地帶唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～聽起來很不錯呢。",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_062"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然會給妳添麻煩，但是可以請妳幫我介紹一下嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且妳們還幫忙調查了闇影的事……",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_063"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n對妳真的是感激不盡。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也贊成真步的意見，",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_064"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n希望可以避免戰爭。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會支持妳的唷？",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "等等、等等。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_065"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n【咲戀育幼院】不是中立的第三方嗎，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小咲戀？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【咲戀育幼院】是隸屬於【公主騎士】的公會，",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_066"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "以立場來說，是比較偏妳們那邊的喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以，靠向獸人方",
        "unit_id": 102811,
        "voice": "vo_adv_2004001_067"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n才能稱得上公平不是嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是強詞奪理呀……",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_068"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳從以前就這麼口齒伶俐。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我不太擅於言詞，所以很羨慕妳呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "算了，我也同樣冀望和平。",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_069"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n讓我們一起仔細並謹慎地，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n摸索出讓所有人都能安穩生活的未來吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然時間有限，",
        "unit_id": 104711,
        "voice": "vo_adv_2004001_070"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但多少還是有些餘裕的。",
        "unit_id": 104711
    }
]