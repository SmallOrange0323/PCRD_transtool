        "voice": "vo_adv_2112002_067"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "關於無法脫離這個世界的原因──",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要解決「米奈娃的禁錮」，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "需要克服兩個課題。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "課題……",
        "unit_id": 105913,
        "voice": "vo_adv_2112002_068"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "說起來，在以前的阿斯特朗裡，",
        "unit_id": 106812,
        "voice": "vo_adv_2112002_069"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n玩家擁有「回到原本世界」",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這項安全指令──",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就像魔法一樣。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只是那道魔法",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為「再構築」而消失了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要復原回來。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
