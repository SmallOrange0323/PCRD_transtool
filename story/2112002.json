        "unit_id": 102611,
        "voice": "vo_adv_2112002_036"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "照現在稍微聽到璃乃等人的話來看，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好像也不是可以說這種話的時候了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "或者說，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "其實我們早就已經被捲進去了吧～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是的。",
        "unit_id": 106812,
        "voice": "vo_adv_2112002_037"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只要是這個世界的居民，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒有任何人是不會扯上關係的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n現在要講的就是這種程度的話題。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "認真說起來，",
        "unit_id": 104914,
        "voice": "vo_adv_2112002_038"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們的公會……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "祕密結社【拉比林斯】，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n原本就是為了解開這世界的謎團而活動的。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "像之前，",
        "unit_id": 104914,
        "voice": "vo_adv_2112002_039"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們去保護諾維姆的那件事，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也是公會活動的一部分。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "結果，",
        "unit_id": 101112,
        "voice": "vo_adv_2112002_040"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "解開世界謎團這件事，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也是不知不覺間會長妳自己就解決了呢……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不不，",
        "unit_id": 106812,
        "voice": "vo_adv_2112002_041"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是沒有和真那交手，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我猜到了現在",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也還是不會完整想起那些事。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n還有自己真實身分之類的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "再說了，",
        "unit_id": 106812,
        "voice": "vo_adv_2112002_042"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "目前也還留有很多需要去解開的謎題。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……例如她的安全裝置沒有運作之類的……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過真的沒有想到，",
        "unit_id": 104914,
        "voice": "vo_adv_2112002_043"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會長的真實身分居然會是這世界創造者的其中一人……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "說得沒錯～！",
        "unit_id": 101112,
        "voice": "vo_adv_2112002_044"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是「食料餵雞」的感覺呢！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哪裡有雞！？",
        "unit_id": 103311,
        "voice": "vo_adv_2112002_045"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n已經餵過了嗎！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就說了，",
        "unit_id": 106012,
        "voice": "vo_adv_2112002_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是那個意思……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說回來，",
        "unit_id": 105812,
        "voice": "vo_adv_2112002_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拉比林斯達小姐和似似花小姐被盯上的原因，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我記得是……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "厄莉絲小姐說",
        "unit_id": 105812,
        "voice": "vo_adv_2112002_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「想要創造一個新的世界」。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了這個目的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "需要從七冠的各位身上獲得情報，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是這麼一回事對吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "似乎是沒錯。",
        "unit_id": 106812,
        "voice": "vo_adv_2112002_049"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "確實我們是擁有著",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "創造世界所需的知識與經驗。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過這些東西",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "並非不可或缺。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟實際上，",
        "unit_id": 106812,
        "voice": "vo_adv_2112002_050"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「創造出來的世界」這個答案",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就已經在我們腳下了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只要從中歸納思考，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就應該能推測出創造的方法。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我認為她不需要抓住所有人，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只要有素材就能創造出足夠舒適的世界。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "世界這種東西",
        "unit_id": 105213,
        "voice": "vo_adv_2112002_051"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是那麼簡單就能創造出來的嗎？",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那似似花她們",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還真是厲害耶……",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過……",
        "unit_id": 104914,
        "voice": "vo_adv_2112002_052"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我有點能夠理解",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個叫厄莉絲的人的心情。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我也很想得到一個",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能和弟弟兩人獨處的世界。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果是個舒適的地方，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "感覺一定會更讚。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105913,
        "voice": "vo_adv_2112002_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就為了這個目的……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n【憤怒‧軍團】的各位",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就遭到對方利用了呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "當然，",
        "unit_id": 106812,
        "voice": "vo_adv_2112002_054"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "以對方的立場來看，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n自然是不可能將逐漸恢復記憶的我們",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "放著不管吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟，",
        "unit_id": 106812,
        "voice": "vo_adv_2112002_055"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "世界的創造者……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "應該說，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "身為「阿斯特朗傳奇」開發者的我們，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n如果",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真的恢復記憶的話。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "首先會考慮的，",
        "unit_id": 106812,
        "voice": "vo_adv_2112002_056"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "想必就是將扭曲的世界復原，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n讓各位玩家",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以回歸到「現實」那邊去。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……現、",
        "unit_id": 106012,
        "voice": "vo_adv_2112002_057"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "實……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "現實啊……",
        "unit_id": 105213,
        "voice": "vo_adv_2112002_058"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n如果那真的存在，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n那邊的我",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不曉得會是什麼樣子。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姐姐和我",
        "unit_id": 103813,
        "voice": "vo_adv_2112002_059"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會不會是同一個種族，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可以一起生活呢……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "現實的我，",
        "unit_id": 101112,
        "voice": "vo_adv_2112002_060"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一定是哥哥真正的妹妹！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在同一個房間裡",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一起生活著的！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不會有錯的！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃～？",
        "unit_id": 104914,
        "voice": "vo_adv_2112002_061"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要說的話，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "應該是「同一個屋簷下」喔～？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐等一下！？",
        "unit_id": 101112,
        "voice": "vo_adv_2112002_062"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不要從後面熊抱住我啦，我才剛吃飽！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……嗚欸。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可、凱留",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2112002_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃……",
        "unit_id": 105812,
        "voice": "vo_adv_2112002_064"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們說的現實，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我還沒辦法清楚想起來……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過拉比林斯達小姐，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳認為要回去那裡比較好是吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是的。",
        "unit_id": 106812,
        "voice": "vo_adv_2112002_065"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "現在或許還沒有什麼真實感，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但這裡只是虛假的世界，",
        "unit_id": 106812
