        "voice": "vo_adv_2112002_066"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要達成這個目的的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該怎麼做……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我做了許多調查，",
