    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "第一件事，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是該恢復回正常的狀態才行。",
