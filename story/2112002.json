        "voice": "vo_adv_2112002_070"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "覆寫這個世界。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以我們需要前往索爾之塔的控制室，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也就是說，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
