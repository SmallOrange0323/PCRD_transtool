[
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了讓兔子族能靠自己做生意，",
        "unit_id": 107111,
        "voice": "vo_adv_6104204_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我正在教導他們交易的基礎……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但說實話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我實在快昏倒了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那些傢伙",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "完全不懂得懷疑別人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要說學習能力差的部下，",
        "unit_id": 107111,
        "voice": "vo_adv_6104204_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在我當副團長時，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也已經照顧過好幾打了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總之，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你放心吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這件事也算在任務之內，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會確實把他們培育到能獨當一面的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "與其說是溫柔，",
        "unit_id": 107111,
        "voice": "vo_adv_6104204_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "他們那種個性已經可以說是超過濫好人的程度了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n他們這麼容易受騙的性格，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "跟你非常相似喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別給我一臉不可思議地歪著頭。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難道你沒有自覺嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這或許是我第一次被人稱呼為老師呢。",
        "unit_id": 107111,
        "voice": "vo_adv_6104204_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以往部下大多會給我亂取外號，\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "像是魔鬼教官之類的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子你要不要也來接受指導啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過那可是連魔鬼都會哭出來的斯巴達特訓就是了。",
        "unit_id": 107111
    }
]