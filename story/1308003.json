        "words": "稍微沖個澡",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就準備出門吧！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥你也是！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "至少去洗把臉。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好、",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的～！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我去端水過來～！",
        "unit_id": 130811
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在咲戀育幼院度過了一個熱鬧的早晨後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人前往報名參加比賽。"
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然而……"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "唉……",
        "unit_id": 4911,
        "voice": "vo_adv_1308003_035"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "不行了……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "比賽要停辦了……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦、",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦咦咦咦咦！？",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "難道說，",
        "unit_id": 4911,
        "voice": "vo_adv_1308003_037"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "是想報名參加比賽的人嗎？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "如果是的話，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "很抱歉……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n再這樣下去，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "比賽很有可能會取消……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請、",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請問發生什麼事了嗎？",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "其實……",
        "unit_id": 4911,
        "voice": "vo_adv_1308003_039"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "比賽可能會借不到場地。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n這個攝影比賽是第一次舉辦……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n說來慚愧，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "我自己",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "只是個業餘攝影愛好者。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "我也招募了一些無償協助的志願者，",
        "unit_id": 4911,
        "voice": "vo_adv_1308003_040"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "做了很多嘗試，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "但幾乎沒有什麼參加者，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "也因為這樣，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n原本要借場地給我們的人說，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "我們的比賽",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "「不夠格」。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不夠格……",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是嗎？",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "是呀……",
        "unit_id": 4911,
        "voice": "vo_adv_1308003_042"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "評審也是我們這些業餘人士，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n對方說，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "要把場地借來舉辦沒有權威又沒有公信力的比賽，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "得再考慮考慮。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "唉啊啊……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "這樣下去比賽可能無法舉辦了。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "原來如此……",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_043"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果是這樣的話，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那也沒辦法呢。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要讓很多人看到自己的照片",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_044"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n也有點難為情……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "是的，",
        "unit_id": 4911,
        "voice": "vo_adv_1308003_045"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "很抱歉讓你們白跑了一趟……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "唉，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "好不容易",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "收到了【墨丘利財團】",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n協助舉辦的提議……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "不是的，",
        "unit_id": 4911,
        "voice": "vo_adv_1308003_046"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "我也只是對名字略有耳聞，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "但是就在剛才，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "突然收到了他們的聯繫……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這一定",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_047"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是大小姐告訴他們的。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不好意思。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好、",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那個，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請讓我們一起幫忙籌備比賽吧！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "……我是很感激你們的提議啦，",
        "unit_id": 4911,
        "voice": "vo_adv_1308003_049"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "不過真的可以嗎？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在不久前，",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_050"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們才幫忙舉辦過慶典，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就包在我們身上吧！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "身為大小姐的女僕……",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_051"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不對……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n今天女僕的工作休息一天……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總之，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會好好努力的♪",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "話是這麼說，",
        "unit_id": 4911,
        "voice": "vo_adv_1308003_052"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "但要從哪裡開始著手呢……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "原來如此……",
        "unit_id": 4911,
        "voice": "vo_adv_1308003_053"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "如果有協辦單位的話，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n比賽的格調也會提升，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "是嗎……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "然後",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_054"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是參加者的部分呢。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果還有多餘的海報，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可以讓育幼院的孩子們也來幫忙張貼。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "是的，",
        "unit_id": 4911,
        "voice": "vo_adv_1308003_055"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "不好意思，我們因為人手不夠，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n所以還剩下很多海報……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "拜託你們務必幫忙！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有很多人會去拍攝胡桃演戲的照片，",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_056"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也會試著",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "邀請他們來參加的！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "什麼，",
        "unit_id": 4911,
        "voice": "vo_adv_1308003_057"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "你有認識的專業攝影師嗎？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n謝謝你！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總之，",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_058"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們就盡力而為吧。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就像鮮花祭的時候一樣！",
        "unit_id": 130811
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，{player}和鈴莓"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n又開始忙碌了起來。"
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，到了攝影比賽的報名截止日……"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是要報名參賽對吧。",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_059"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那麼",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "照片我們就收下了。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "好……",
        "unit_id": 4911,
        "voice": "vo_adv_1308003_060"
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "好的！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "執行委員",
        "words": "\n非常感謝您的參加！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "到了報名的最後一天，",
        "unit_id": 130811,
        "voice": "vo_adv_1308003_061"
    },
    {
