[
    {
        "type": "background",
        "background": "505035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "小棉花糖和傑克",
        "unit_id": 117911,
        "voice": "vo_adv_6076305_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "都是來自靈界對吧。",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "靈界到底是個什麼樣的地方，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才知道嗎？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如果到處都是可怕的妖魔們，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那就超不妙了！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "從靈界過來這裡經營鬼屋……",
        "unit_id": 117911,
        "voice": "vo_adv_6076305_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "難不成",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是真正的妖怪？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你那個朋友，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今年也有來參加萬聖節活動嗎？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有點看看呢！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然也不是一天兩天的事，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但秀才你",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "到處都有朋友真厲害耶！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如果有許多像小棉花糖那樣的妖魔，",
        "unit_id": 117911,
        "voice": "vo_adv_6076305_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那不就是天國了！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "難道所謂的靈界",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是指天國嗎……？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "天啊天啊，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家搞不好是天才！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那個，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才覺得呢？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家說對了嗎？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的假的！？",
        "unit_id": 117911,
        "voice": "vo_adv_6076305_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家以前就曾想過，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才未免也太過冒險了吧？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "話說回來，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "到靈界去真的沒問題嗎？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才該不會",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "身體是透明的吧？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你怎麼突然不說話了～！？",
        "unit_id": 117911
    }
]