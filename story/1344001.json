[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在失控的精靈引發騷動後過了一段時間──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}與千歌一起"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "造訪了精靈族之村。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我有重要的事要說，",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我……",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "想要小寶寶。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊……",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我、",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我講得不夠清楚！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不、",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不是那種意思……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不是的……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒、",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒有，所以說，那個、",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呃……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咳咳。",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呃……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然我說小寶寶，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但我是指新出生的精靈。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "其實，",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "前些日子與失控精靈的戰鬥，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓我的精靈們",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "相當疲憊……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要是近期發生了什麼事，",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我可能無法",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "像現在一樣",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n作為唱喚士借用精靈的力量。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n如果",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "變成那樣的話──",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的。",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我想說要是能獲得新的精靈之力，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我既能夠變強，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也能減少其他精靈的負擔吧。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的。",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "長老在不久前",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "告訴我了。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n說是有孕育新精靈的方法。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然聽說非常困難，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但並不是沒有先例。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就是指優衣小姐。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "當然優衣小姐的努力不在話下，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但我聽說在她身邊支持的你也出了很大一份力。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我不曉得",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "能不能成功。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n畢竟優衣小姐孕育出的精靈，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "和以唱喚術締結契約的精靈",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n是不同種類……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "儘管如此！",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "既然可能性不是零，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我也想挑戰看看。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n挑戰和你",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一起孕育出新誕生的精靈……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝、",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的！",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我從神廟借來了古老的文獻。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "畢竟大多都是相當古老的，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以不知道",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n正確度，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但應該還是值得一試的！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們馬上就來試試看吧。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這是用來孕育精靈的歌曲。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "想像自己想要孕育的精靈……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓魔力搭著歌曲……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "～～～～♪",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……咦、",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好奇怪啊……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "音有唱準",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對吧？　",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "什麼都沒發生呢。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真奇怪啊，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "樂譜應該沒錯才對，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我也練習過了。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是不是必須",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唱得更正確、更細膩才行呢……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "～～～～♪",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "果然很奇怪……",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "魔力竟然無法搭配上歌曲……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "得注意節奏才行。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "冷靜，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "冷靜下來再試一次。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼哈……",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼哈……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為什麼……？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n魔力竟然沒辦法順利搭配上歌曲……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "說的也是呢……",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為就算著急，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也一定不會有好結果。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我去向村裡的人",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "打聽一下。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n希望多少有一點線索。",
        "unit_id": 134411
    },
    {
        "type": "background",
        "background": "501200"
    },
    {
        "type": "dialogue",
        "name": "村裡的居民1",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_1344001_023"
    },
    {
        "type": "dialogue",
        "name": "村裡的居民1",
        "words": "孕育精靈的儀式？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "村裡的居民1",
        "words": "\n你們兩個",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "村裡的居民1",
        "words": "在挑戰那麼困難的事嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "拜託了！",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "無論如何都想成功孕育精靈。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n有沒有",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哪位博學多聞的人在呢？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "村裡的居民2",
        "words": "要說到這邊最博學的人，",
        "unit_id": 1,
        "voice": "vo_adv_1344001_025"
    },
    {
        "type": "dialogue",
        "name": "村裡的居民2",
        "words": "那就是隱居老婆婆了吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "村裡的居民2",
        "words": "\n她應該對增加魔力、復活之類的事很清楚。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有、",
        "unit_id": 134411,
        "voice": "vo_adv_1344001_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有那樣的人！？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請務必介紹給我！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "拜託你了！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "村裡的居民2",
        "words": "好、",
        "unit_id": 1,
        "voice": "vo_adv_1344001_027"
    },
    {
        "type": "dialogue",
        "name": "村裡的居民2",
        "words": "好的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
