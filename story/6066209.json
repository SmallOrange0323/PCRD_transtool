    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "君は水着になった魔法少女ナナカちゃんを見て、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n何か思うところはないのかな？　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ぶっちゃけ感想プリーズ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ど真ん中ストレートな感想ありがとね！",
