    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對初夢許的願望啊。",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當然是要許願",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "能以名偵探",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "的身分，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n解決更加困難的事件。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當然，",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生也會跟我一起。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n名偵探需要有優秀的助手……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且搞不好還會因為解決事件，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓我們的羈絆也加深呢！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "明天也要早起，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就先睡覺吧。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……呼",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……呼……",
        "unit_id": 128511
    },
    {
        "type": "still",
        "still": "513406301"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔……",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生抱歉啊。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為跟蹤了很久，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以我的注意力好像開始有點渙散了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "畢竟這次跟蹤的目標，",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可是以小心謹慎而出名的呢。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為此我們也需要慎重行事，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "以防被發現。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以我們現在",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才會像這樣處於目標的斜後方，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n裝成情侶",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "融入在群眾當中跟蹤。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如何？",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣絕對不會被發現對吧。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這種腳踏實地的調查，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "正是展現偵探實力的地方。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且為了推理，",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "線索也是越多越好……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦？",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n糟、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "糟了，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "光顧著聊天就沒有注意到……！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我想想，",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "既然如此……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請抱緊我，助手先生！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我們就假裝是在親熱的情侶來蒙混過去吧！",
        "unit_id": 128511
    },
    {
        "type": "still",
        "still": "513406302"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對啊！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n像這樣整個人抱上來，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n緊緊抱住的話，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還能遮住我們的臉……！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好像有點呼吸困難……！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不是抱的方式不好……！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "應該說",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是各方面都太刺激了嗎……！",
        "unit_id": 128511
    },
    {
        "type": "still",
        "still": "513406303"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦，",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為什麼你要貼得更緊呢！？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n要是再更激烈的話，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "反而會引起注目……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n助手先生！？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不行，",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這裡可是人來人往的地方啊！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不能做這種不知羞恥的……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊啊……！",
        "unit_id": 128511
    },
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊！",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……啊……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "什麼嘛，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原來是夢啊……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒想到才剛過新年，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就搞得氣喘吁吁地起床。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可是，",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這個夢",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "到底是在暗示什麼呢？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我有在做偵探的工作，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還跟助手先生……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "…………",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "算、",
        "unit_id": 128511,
        "voice": "vo_adv_5134063_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "算了，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "世界上有一個無解之謎也沒關係嘛！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再怎麼說，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也不可能跟助手先生挑戰這個謎題呢……",
        "unit_id": 128511
    }
]