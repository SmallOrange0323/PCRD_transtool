    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你問我不先給爸爸媽媽看嗎？",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_039"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "當然不可能給他們看囉！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……更不可能給朋友看啦！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "父母都不能看了，那當然啊！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "拜託了，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_040"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "別再欺負我了啦～～！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這要是被其他同學看到，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我就沒臉去學校了啦～～！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n大哥～～",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "拜託你住手～～！！",
        "unit_id": 100531
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呼，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_041"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "總算把照片給刪掉了。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……就算你露出一臉可惜的表情，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不行的東西就是不行！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然我很高興聽到你稱讚我，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_042"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但那個實在是太不好意思了啦～～！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我希望把這個當成",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大哥和我之間的祕密！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "話說回來，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_043"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我將來真的",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "會變成那種模樣嗎？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "完全無法想像耶。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是不是",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_044"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "成長到一半的時候，個性變了呢？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "如果個性沒有變的話，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我不覺得自己會想要",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n穿得那麼漂亮……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯～～",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大哥怎麼想呢？",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_045"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n你覺得就算過了十年，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "人的個性",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是不是也不會變？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n還是說，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "變成大人之後，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有很多東西都會有改變呢？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……那個軟體",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_046"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只是預測我將來的外表而已？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "實際上要成為什麼樣的大人，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "都是看我自己？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "話、",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_047"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "話題突然變得好艱深啊……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n虎虎也常常說一些類似的話，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n但說實話，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我都聽得不是很懂。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯、嗯……",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_048"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n人會因為經歷不同經驗而改變，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要成為自己理想中的模樣，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n去累積不起眼的努力是最重要的……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "原來如此！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大哥真是厲害，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_049"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好成熟！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n你一定",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是為了成為自己理想中的模樣而天天努力，對吧！？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……為什麼你要把眼睛別開？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "總之，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_050"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "聽了大哥的說明之後，我總算明白了！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n既然這樣，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我就要",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "以成為像虎虎一樣的英雄為目標，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n去做那些我能夠做到的事！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我想想……",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_051"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "首先得要長得更高一點！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n每天",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "都要喝牛奶，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "以長得跟大哥一樣高為目標！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我一定要加油，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "才能成為帥氣的大人～～！",
        "unit_id": 100531
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
