        "voice": "vo_adv_1005011_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們相處的感覺還是那麼令人暖心呢～～",
