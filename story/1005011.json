    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "學習各種事物，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n都會關係到她未來會成長成什麼模樣。",
