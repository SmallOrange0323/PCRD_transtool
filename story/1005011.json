[
    {
        "type": "background",
        "background": "500371"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在【王宮騎士團】體驗到各式各樣業務的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n茉莉與{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n王宮騎士對他們的信賴越來越深，兩人也體會到彼此的成長。"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一開始被分配到失物招領管理人的職位時，",
        "unit_id": 100512,
        "voice": "vo_adv_1005011_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我還很擔心自己的未來呢……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過最近，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我覺得自己",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "身為團員有了很大的進步！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要幫上鎮上的人的忙，",
        "unit_id": 100512,
        "voice": "vo_adv_1005011_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不光是打敗壞蛋而已，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n也有著許多不同方式──",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這是我最近學到的。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還有不少事情，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是我需要學習的呢。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過，",
        "unit_id": 100512,
        "voice": "vo_adv_1005011_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只要按照這個步調，我馬上就能成為能獨當一面的……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n怎麼",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "身體好像在發光？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "之前好像",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也發生過類似的事……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呀啊～～！？",
        "unit_id": 100512
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚……",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "噎嗚……！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我還是不能接受！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "應該要",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "平等對待每一個人才對吧！？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可是，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我一直很期待",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "能到遊樂園坐碰碰車耶！？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我還先看導覽手冊",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "預習有哪些車子，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n甚至已經決定好",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要搭哪一台了……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "結果身高居然只差一公分！！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……你說都已經是一個星期前的事情了，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_005"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "別再去糾結了？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}大哥也和爸爸說同樣的話嗎！？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大家",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "都不了解我的悲傷啊～～！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你們都說等到我長高一點再去遊樂園就好，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是誰知道身高什麼時候才會長高呢……？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也很想",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "快點長得跟大哥一樣高啊。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……怎麼了嗎？",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_007"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "幹嘛一直盯著我看？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你說你很期待看到我",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "長大之後會變成什麼樣子？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯──",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就是身高變高了而已，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "其他應該不會有什麼變化吧？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_008"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我爸爸跟媽媽",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在小時候跟現在，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "長相也完全不同。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n難道說，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我長大之後",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也會變得跟現在完全不同一個人嗎？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我開始",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有點擔心起來了……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這種事情查得出來嗎？",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……圖像加工軟體",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "「增齡模擬器」？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那是什麼",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "東西啊？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只要照了某個人的照片，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "AI就會預想那個人未來的模樣，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n再把長相加工成未來模樣的軟體……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦咦！？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好厲害喔！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "感覺很有趣！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我想玩玩看～～！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_011"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可是，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可以先",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "讓大哥試試看嗎？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n因為我也很好奇大哥未來會長什麼樣子啊♪",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "謝謝！",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_012"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那你",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "手機就先借我一下囉。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "看我這邊～～！",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_013"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "來，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "笑一個！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……接著，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_014"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就是設定要老多少歲對吧。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就隨便",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "設定個五十年後好了。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "喔喔，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_015"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "照片真的變成老爺爺了！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "長相雖然是有改變，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過還是",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "帶著原本的氛圍，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n看得出來是大哥呢。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這個軟體",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_016"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "感覺非常精準呢！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一想到要自己來試，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就開始有點緊張起來了。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒有啦，",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_017"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我當然不會臨陣退縮！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可是，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也不太想看到自己變成奇怪的臉呢……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大哥",
        "unit_id": 100531,
        "voice": "vo_adv_1005011_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也要在旁邊一起看？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這不知道該感到安心，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還是感到不安耶……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不管變成什麼樣子，",
        "unit_id": 100531
    },
    {
