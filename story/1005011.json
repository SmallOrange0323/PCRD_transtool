    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但畢竟還是比茉莉還要年長一些。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今後你也繼續幫助茉莉，",
        "unit_id": 190011,
        "voice": "vo_adv_1005011_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓她能夠成為理想的大人吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……我可不是要你教她",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "化妝或打扮喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1005011_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次就到這邊為止吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們所擁有的「未來」……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "相當期待呢♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500371"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯嗯……",
