        "unit_id": 106931,
        "voice": "vo_adv_5201006_007"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "能",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_008"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "不能別隨便跟我搭話？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n目前妳還派不上什麼用場。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n作為實驗鼠就安分地待著吧。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "…………",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_009"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──之後的幾天裡，開發沉默地持續著。"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "…………",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_010"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "…………",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_011"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "…………",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_012"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "………………………………………………真是令人絕望的命名品味呢。",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵，",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈！",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……妳有什麼事嗎？",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_015"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "克莉絲。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真抱歉。",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為你們展開的對話過於有趣，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我實在忍不住。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "區區的自言自語",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_017"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "可稱不上是對話啊。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "別用沒意義的閒聊浪費我的時間。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟俗話說，",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "時間就是金錢呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "哎呀，",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_019"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n妳是說妳能用金錢來換我的時間嗎？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "請原諒我的",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "諸多失禮。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哎呀，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對了，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我有一份真那大人在等的報告。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "從園上矛依未身上分析出的技能已經編入完成了。",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_021"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "園上……",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_022"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "既然說到技能，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "就是那個實驗品吧。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n真是花了相當長的時間呢。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "連名字都不記得",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "花時間是當然的，",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n畢竟",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那傢伙可稱不上配合。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是因為有晶的居中協調",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "才總算完成。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……依舊很天真呢。",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_025"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "那個迷宮女王。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "晶身為七冠的同時，也是個與我們不同的",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "傢伙啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "哼，",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_027"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "真讓我覺得噁心。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "妳報告結束的話就走吧。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也希望能",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "被真那大人如此熱情地惦記著呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我告辭了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_029"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "惦記他人根本",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "毫無意義啊。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我要登入了。",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_030"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n趕快準備好。",
        "unit_id": 106931
    },
    {
        "type": "background",
        "background": "500146"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "連接過程沒有異常。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n不過也理所當然就是了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我要立刻進行技能的確認。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_032"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n讀出顯示在介面上的技能吧。",
        "unit_id": 106911
    },
    {
        "type": "background",
        "background": "500146"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "確認發動。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_033"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n繼續。",
        "unit_id": 106911
    },
    {
        "type": "background",
        "background": "500146"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "發出的光太強了呢。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_034"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "多人同時使用的時候可能會損害視力。",
        "unit_id": 106911
    },
    {
        "type": "background",
        "background": "500146"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真不起眼呢。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_035"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如果不再讓外觀華麗點，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n闇系魔法很少會有人選用吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "──那就不必了。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_036"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這技能是什麼東西啊？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "屬性效果也一如設定。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_037"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n其實我是想讓重現性再提高一點的。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但她無論處境如何依舊很囂張呢……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那個實驗品。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "好了，",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_038"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "接下來是命中確認。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n去站在那邊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "對，",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_039"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那邊就行了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "把體力上限值設定為無限──",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "──究極混沌。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_040"
    },
    {
        "type": "background",
        "background": "500146"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "命中確認……",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_041"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒有問題。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "趕快站起來。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "反正也沒有疼痛感吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊啊，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "以妳的情況是會感受到嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過與我無關就是了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "接下來",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_042"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我會用所有種類的技能擊中妳。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳要",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "把承受那些時的感覺總結成報告提出來。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……什麼？",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_043"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳說希望我在攻擊之前",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "先說明？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
