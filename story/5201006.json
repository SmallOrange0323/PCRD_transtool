    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是這麼一回事。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n她打從一開始就沒打算",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "以技能對峙跟我決勝負。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而是在了解「自身利用價值」的前提下，",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_081"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n把那當成了賭金。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "時間沒有限制，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "要是我贏了，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就會失去一個寶貴的實驗品",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "字面意義上的賭上性命。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_082"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "比我以為的還難對付嘛。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n竟然單方面把勝負的決定權硬推給我。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "囂張的孩子。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_083"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n在我創造的世界裡，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並不需要像妳這種類型的人呢……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……沒錯，",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_084"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n一切如我所願的",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "新世界。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不會有任何人妨礙我，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只有膜拜",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "與崇敬，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "屬於我的世界。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我將會成為那個世界的神。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_085"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "雖然我不曉得其他七冠怎麼想。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n但就算那些傢伙打算妨礙我，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我也會按照我所希望的去做。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "嗯……？",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_086"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳在懷疑什麼？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真令人不快呢……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "簡直就像想說妳比我還理解我自己一樣嘛。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳──",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_087"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在「看」著什麼？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是因為使用靈魂登入嗎？",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_088"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n還是說妳有讀取他人記憶的方法？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "別開玩笑了，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "竟然有除了我以外的人妄圖理解我……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……配合這場鬧劇就到此為止吧。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_089"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我能肯定，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我是不會認輸的。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "所以，",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_090"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳就認輸吧──",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "──澄花。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_091"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……哼。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_092"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳問我真正的",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_093"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "願望嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真正的願望，除了我之外還有誰能夠理解？　",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我不需要什麼理解我的人。",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_094"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我的這個願望是不會有錯。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我只要，",
        "unit_id": 106911,
        "voice": "vo_adv_5201006_095"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "能夠成為新世界的神就好了──",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "七冠──霸瞳皇帝。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n千里真那為了登上唯一神的寶座而走上孤高的道路，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n從未正視自己心中真正的願望。"
    },
    {
        "type": "background",
        "background": "510460"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真那大人，",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_096"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我拿午餐過來了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我有說不用特地拿過來了吧。",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_097"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為晶吵著說要好好吃飯啊。",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_098"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話說回來，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "開發的狀況如何了？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "妳是想說我有狀況起伏不定的時候嗎？",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_099"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈！",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_100"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n看來我問了個蠢問題呢！",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "不過，",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_101"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "比起研究叛逆的實驗品，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "是要讓人舒服一些呢，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "澄花她。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦……",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_102"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "您變成以名字來稱呼她了呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "能不能別一一說出微不足道的事？",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_103"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n真讓人不快啊。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "這是技能調整的整理報告，",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_104"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n妳拿著這個就快滾吧。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我知道了。",
        "unit_id": 107131,
        "voice": "vo_adv_5201006_105"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "…………",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_106"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……真殘酷呢。",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_107"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "要我用名字稱呼，",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_108"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "還真是非常殘酷的願望啊。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "明明時候到了",
        "unit_id": 106931,
        "voice": "vo_adv_5201006_109"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "遲早都會消失的。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "沒有人聽見千里真那的低語。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n霸瞳皇帝沒有動冷掉的午餐，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "繼續進行遊戲開發──"
    }
]