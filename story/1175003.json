[
    {
        "type": "background",
        "background": "500651"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在造訪大江戶町後好一陣子都忙於工作的深月他們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了消除疲勞，前往一家受到好評的老字號溫泉旅館。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這裡就是",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "傳聞中大江戶第一的旅館……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我聽說這裡天天都客滿很熱鬧，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n可是現在除了我們以外，沒有其他人上門耶。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "隔壁的旅館好像生意更好。",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們該不會跑錯地方了？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "喔喔，",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_003"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "你們該不會是客人？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "難得你們特地光臨，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "真是抱歉。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n其實",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "這間旅館目前正暫停營業……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "暫停營業？",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n是有什麼問題嗎？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "這個……",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_005"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n我想用看的比較快吧。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "你們可以隨我來嗎？",
        "unit_id": 1412
    },
    {
        "type": "background",
        "background": "500670"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "原來如此。",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這間旅館引以為豪的溫泉……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "與我聽說的內容差異很大呢。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我聽說溫泉呈現漂亮的翡翠色，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n現在卻是混濁的可怕顏色，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "氣味也不對勁。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……那道溫泉",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "被毒素汙染了嗎？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "……正是如此。",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_009"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n直到前幾天為止，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "湧出的明明都是一如往常的溫泉……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n卻突然變成了這個狀態……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "啊……！",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_010"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "你該不會是……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "將軍！？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "我聽說過許多你的事蹟……！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "承蒙你特地來訪，",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_011"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "卻是這種狀況……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n真是沒臉見人……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "是的……",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_012"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n很遺憾……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "隔壁旅館明明和我們用的是同一個泉源，",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_013"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n但水質似乎沒有發生變化。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n所以，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "我認為原因出在我們的溫泉上……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "喔……",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n看起來明明沒有任何問題，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真不可思議。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "是呀。",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_015"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "由於原因不明無計可施，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "我們對此一籌莫展。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n在暫停營業期間，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "客人也被隔壁的旅館搶走……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "你們明明是以客人身分來訪的，",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_016"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n說這種話很讓人過意不去，可是……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "將軍！",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_017"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n請幫幫我們好嗎！？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "我們沒有其他人可以求助了！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "求求你、",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "求求你幫幫忙！",
        "unit_id": 1412
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真是的。",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你總是馬上就輕易答應這種要求。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不需要道歉。",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "無法放下遇到困難的人不管，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我覺得這種濫好人的一面很有你的特色。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我也",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一直想去那裡的溫泉，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n有這個機會正好。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "而且，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我對於",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "問題的原因大致有個推測……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看吧，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話才說完",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就到了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那個溫泉的",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "泉源所在地。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "聽了那個人的說法，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如果有原因的話，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我認為就出在這裡……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "果然如我所料。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不可以碰喔。",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那種植物",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有毒的。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "溫泉瀰漫的惡臭讓我反應過來，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n猜想可能是這種植物的毒素",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在某個地方溶進了泉水中。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但是，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在溫泉中沒有植物，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我心想這代表問題",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一定出在泉源上。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "結果不出所料，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "正是這樣。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過……",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這還真過分。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n只有通往那間旅館的泉源裡",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "浸泡著植物。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "巧妙地避開了",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "通往隔壁旅館的泉源。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這怎麼想都是",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有人刻意栽種的植物。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒錯。",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "既然是這樣，我也有個想法。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這種植物",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然有毒……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n只要好好運用，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也可以化為良藥。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "舉例來說，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_030"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "摻入這裡生長的樹木的樹液",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "消除毒性後……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你瞧，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼樣？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就是說吧？",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_031"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不只氣味好聞，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "藥效也很優秀喔。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_032"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只要像這樣……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n讓樹液能夠不斷摻進",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這種植物溶入的泉源中……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你看。",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_033"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n療效十足的藥浴完成囉。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵。",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_034"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "受到讚美",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "的感覺還不壞♪",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "即使只是清除覆蓋在泉源上的",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_035"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有毒植物，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n溫泉也會恢復原狀。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_036"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣做",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "感覺更能給找麻煩的人一點顏色瞧瞧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "而且旅館恢復營業後，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這種藥浴一定會派上用場的。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好了……",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_037"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "最後在這附近，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "把這種植物",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "種下去……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣就可以了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼，我們回去吧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "事情一定會變得很有趣的。",
        "unit_id": 117511
    },
    {
        "type": "background",
        "background": "500670"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後──"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "喔喔，",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_038"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "將軍！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "還有隨侍的醫生！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "前幾天真的",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_039"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "很謝謝你們！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n多虧了兩位，溫泉順利地恢復原狀……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "雖然不是恢復原狀，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "但湧出了有藥效的泉水！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "儘管才剛恢復營業，",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_040"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n消息靈通的溫泉愛好者們",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n聽說了傳聞後馬上聚集過來了！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_041"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "正如我所料。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我想著只要製造在這一帶",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很少見的藥浴，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "客人馬上就會回流。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n而且，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如果我的預測正確，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "差不多是時候──",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂，",
        "unit_id": 1,
        "voice": "vo_adv_1175003_042"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這是怎麼回事！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看吧，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_043"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "果然沒錯。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "壞人登場囉。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "你是隔壁旅館的……",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_044"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n看你臉色大變，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "怎麼了嗎？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "還問我怎麼了！",
        "unit_id": 4911,
        "voice": "vo_adv_1175003_045"
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "無法提供正常溫泉的旅館",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "生意為什麼會這麼興隆！？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "還搶走了我們旅館的客人，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "害我們做不成生意！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "其實自從我找了這兩位大人去查看泉源後，",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_046"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n溫泉就變得會湧出有藥效的泉水。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "真是感激不盡。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "有藥效的溫泉水……？",
        "unit_id": 4911,
        "voice": "vo_adv_1175003_047"
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "\n這不可能……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "究竟發生了什麼事……！？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "我沒有說謊喔。",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_048"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n我現在就去取溫泉水給你看。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "你一定會很驚訝的。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "請稍待一會。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵。",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_049"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然不知道是誰做的，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好像有人周到地",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在這裡的泉源",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n種植了作為藥浴原料的植物，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我們就拿來運用了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "妳說……",
        "unit_id": 4911,
        "voice": "vo_adv_1175003_050"
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "作為藥浴原料的植物……！？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "這不可能……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "那個應該有毒才對……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看來你學得不夠多喔。",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_051"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "即使是有毒植物，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只要運用得當，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也能為人帶來助益。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你就記起來吧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "嘖……！",
        "unit_id": 4911,
        "voice": "vo_adv_1175003_052"
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "\n既然如此，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "我也要在我們旅館的泉源……！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對了，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_053"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還要",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "給你一個忠告，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你最好別靠近泉源。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們在那附近",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "種植了魔物喜愛的植物。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要去是可以去，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但不知道能不能平安回來喔。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "妳說什麼……！",
        "unit_id": 4911,
        "voice": "vo_adv_1175003_054"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_055"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對我們來說",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "魔物不算什麼，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n要靠近泉源幾次都沒問題。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如果",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你企圖打更多壞主意的話……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要只對你旅館的泉源動手腳，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_056"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n在溫泉水中溶入劇毒也是做得到的。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n好好記清楚了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "唔……！",
        "unit_id": 4911,
        "voice": "vo_adv_1175003_057"
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "可惡，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "隔壁旅館的老闆",
        "words": "你們給我記住……！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "咦？",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_058"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "隔壁的老闆回去了嗎？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "我都特地去裝水過來了。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "算了，也罷。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "話說回來……",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_059"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n現在真的熱鬧到前陣子門可羅雀的情況好像假的一樣。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "這一切都是",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "多虧了將軍與妳的幫助。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "作為謝禮，",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_060"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "請讓我招待兩位住進旅館裡最高級的房間，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n品嚐最豪華的大餐！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "當",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "然，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "是免費招待！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_061"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你可真大方。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們當然是非常感謝……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過暫停營業了一陣子，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "店裡的資金",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也不寬裕吧？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "這個問題不用擔心！",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_062"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "拜兩位所賜，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n這間旅館開始作為小有名氣的觀光聖地引起話題了！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "大江戶町的英雄將軍與隨侍的醫生，",
        "unit_id": 1412,
        "voice": "vo_adv_1175003_063"
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "賜給了這間旅館藥浴，只要入住就能享受到！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "\n光是這個事實，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "旅館老闆",
        "words": "就具有很大的宣傳效果！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "原來如此。",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_064"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n即使讓我們免費住宿，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "能賺取的收益看來",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也綽綽有餘啊。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 117511,
        "voice": "vo_adv_1175003_065"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "說得對。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "既然是這麼回事，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們就不客氣地接受你的好意了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我很期待",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "最高級的款待哦。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對旅館老闆的經商精神深感佩服之餘，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n深月與{player}臉上浮現笑容。"
    }
]