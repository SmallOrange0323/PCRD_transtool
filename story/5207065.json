    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我要發表囉！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "經過嚴謹考量後……",
        "unit_id": 137111,
        "voice": "vo_adv_5207065_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我決定要邀請",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "步未加入大奧！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "步未可是",
        "unit_id": 137111,
        "voice": "vo_adv_5207065_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們公會",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "數一數二的忍者！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在消除氣息這方面",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "無人能出其右！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而且……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我知道喔……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "步未",
        "unit_id": 137111,
        "voice": "vo_adv_5207065_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "總是",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在調查將軍的事，",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n她就是個純粹的",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍狂熱者！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以！",
        "unit_id": 137111,
        "voice": "vo_adv_5207065_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不只是明裡暗裡……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "她應該會願意",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "按字面意思成為",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍的影子，",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "保護將軍！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要是",
        "unit_id": 137111,
        "voice": "vo_adv_5207065_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "步未願意加入大奧……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "登登登登登！",
        "unit_id": 137111,
        "voice": "vo_adv_5207065_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n將軍",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "駕到──！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n大奧的各位！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "請集合！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……咦？",
        "unit_id": 137111,
        "voice": "vo_adv_5207065_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n沒看到步未呢……？",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "怎麼回事……？",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "妮諾！",
        "unit_id": 105511,
        "voice": "vo_adv_5207065_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "步未，",
        "unit_id": 137111,
        "voice": "vo_adv_5207065_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "妳在嗎？",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不在的話",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就回答不在！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "步未～！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 105511,
        "voice": "vo_adv_5207065_010"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我真的在這裡喔～",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "能聽到聲音，",
