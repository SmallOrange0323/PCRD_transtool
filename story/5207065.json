        "words": "大奧就失敗了是也……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "妮諾放棄讓步未加入大奧，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但決心活用"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "她的潛行能力，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n組成女忍者部隊。"
    }
