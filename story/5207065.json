        "voice": "vo_adv_5207065_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "卻看不到人……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "步",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "未～！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍駕到是也──！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n請妳過來──！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯──",
        "unit_id": 137111,
        "voice": "vo_adv_5207065_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真奇怪是也……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "到處都找不到",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "步未……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不行……",
        "unit_id": 137111,
        "voice": "vo_adv_5207065_013"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這樣",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
