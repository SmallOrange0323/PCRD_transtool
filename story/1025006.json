[
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呼。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n終於進到城鎮裡了呢～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這下總算放心了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，真是著急死了呢。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n因為這次的行李很多，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n用手推車搬運了許多東西。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也藉助你的幫忙，",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "兩人一起推手推車……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "結果我好幾次失去平衡跌倒，",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n弄翻行李。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好不容易快到城鎮時，車輪卻陷進水溝中，",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n動彈不得……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "慌慌張張想辦法解決，又害得車輪脫落了。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n最後，手推車變得四分五裂。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這已經不是冒失的程度了啊，",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "太不幸了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "若不是有{player}幫忙將行李集中搬運，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n也許我就進退維谷了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你真的幫了大忙，我一定會報答這個恩情的。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我會送你謝禮喔～有什麼要求請儘管告訴我。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然我很冒失，沒辦法做什麼了不起的事……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦～這樣我會過意不去啊，",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}很謙虛呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是以服務來報恩是女僕的作風喔♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "想到再跟我說就好了，請儘管告訴我喔。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會報恩的♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哈哈。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你的肚子在叫呢～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "畢竟已經是晚餐時間了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我知道了！",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請交給鈴莓，主人～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀呀，我不小心喊了「主人」。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我從小就為了當個出色的侍從而接受訓練，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以即使現在，我也會出於習慣地這樣喊其他人。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總之，吃飯這點小事，要我請你吃多少都可以喔。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為在店裡吃太昂貴，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我就在【咲戀育幼院】親手做菜招待你吧♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。總之，實在有點累了……",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以我們先到那邊坐著休息一下吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n剛好那邊有長椅。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "蘭德索爾很大呢～",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n從這裡到位於郊外的【咲戀育幼院】，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還有段距離。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不休息地趕路前往，可能有點太勉強了。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哈哈。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}似乎還很有精神呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好厲害啊，男性的體力果然很好呢……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我的腳好像已經開始痠痛了啊。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚～腳底好痛。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀哇哇？",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}為什麼要碰我的腳？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我說了很痛啊！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，原來你要幫我治療呀。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n替我纏上繃帶……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起，我真的老是給你添麻煩呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我真是沒用……",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果一直這樣，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n無論多久我都無法成為像父母那樣出色的侍從呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，是的。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我家代代都是侍從喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我的父母在業界是屈指的能手……",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "父親被稱為「超人管家」，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n母親則是「超級女僕」。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "他們分別在不同主人身邊服侍，",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以我已經有段時間沒有見到他們呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n回鄉的時候也是，只有祖母在家。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也是從小就跟在大小姐身邊，",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n一直照料她的生活起居……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "比起擁有血緣關係的父母，",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我和大小姐在一起的時間更久。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我對父母不太有「家人」的感覺。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n對故鄉也沒有「家鄉」的感覺呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然有點寂寞，",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但因為出生在這種家庭，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n也是沒辦法的事。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而且對我來說，大小姐才是……",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "現在【咲戀育幼院】",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n才是我的家人，也是我的家。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起，話題好像變得有點陰沉。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是因為太累了嗎～",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}和家人的感情好嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣啊，",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_032"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n原來你和像妹妹一樣的女孩住在同一個屋簷下。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請好好珍惜她喔……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為家人果然就像寶物一樣。",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不，是像地面一樣。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "若是沒有了它，就會感到不安、寂寞……",
        "unit_id": 102511,
        "voice": "vo_adv_1025006_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n失去立足之地",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就會像我一樣失去平衡而跌倒。",
        "unit_id": 102511
    }
]