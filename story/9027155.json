[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在這裡！　",
        "unit_id": 106011,
        "voice": "vo_adv_9027155_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是之前那傢伙！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "上一次",
        "unit_id": 105911,
        "voice": "vo_adv_9027155_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的目的是調查謠言，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次的目標",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "則是要討伐那隻魔物。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n小心謹慎地迎戰吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "終於見到你了呢……",
        "unit_id": 105811,
        "voice": "vo_adv_9027155_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你這隻山寨龍！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今天一定要做個了斷！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……妳啊，",
        "unit_id": 106011,
        "voice": "vo_adv_9027155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還真有幹勁呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過我也贊成",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要打倒牠這一點。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有這種傢伙在，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n周遭的環境都被搞得亂七八糟了呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯。",
        "unit_id": 105911,
        "voice": "vo_adv_9027155_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就連美味的魚",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也無法讓主人品嘗，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在非常愧疚。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也要",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "使出全力應戰了！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要上了喔！",
        "unit_id": 105811,
        "voice": "vo_adv_9027155_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　黏濕山寨龍！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接招吧，",
        "unit_id": 106011,
        "voice": "vo_adv_9027155_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "黏濕山……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是叫這個名字吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要給牠取奇怪的名字啦！",
        "unit_id": 106011
    }
]