[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你好。",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n{player}。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你知道嗎。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天我的身體狀況特別好喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為今天有一場",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我一直很期待的作家的簽書會。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我不想搞垮身體，",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以最近在生活上比以往還要小心注意。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "萬一我的病情惡化不能下床走動……",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我也說過，\n這樣就要請你去幫我代簽。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過，",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我果然還是想親自去和作家見面。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "怎麼辦……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我好興奮。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的情緒如果太亢奮，",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "又會……頭暈了♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我們還有時間，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n要不要去哪裡喝杯茶呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "畢竟",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你也難得來陪我。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果{player}也能",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n快樂度過今天的話，我會很開心的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯，怎麼辦呢。",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我很少到城鎮來，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以對這裡不熟悉。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果{player}有",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n推薦的咖啡廳的話……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗚呀！？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我、",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我發出了奇怪的聲音。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}，你怎麼了？",
        "unit_id": 103811,
        "voice": "vo_adv_1038008_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n總覺得你又全身閃～閃發光喔……？",
        "unit_id": 103811
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我好久沒在城鎮裡走動了，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n好開心。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝你。\n陪我出來逛街……♪",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n也對呢，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我走了很多路，想稍微休息一下。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為我前陣子才出院而已。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "醫生和姊姊都",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嚴格禁止我勉強自己。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起，",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我一直在休息。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我覺得頭昏昏沉沉的，",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n膝蓋也很痠……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好像已經有點走不動了。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇，你不用那麼擔心也沒關係的。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這種程度的身體不適，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n對我來說是常有的事。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "或者應該說今天，",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我的身體狀況比往常還要好喔。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很抱歉讓你擔心了。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我這樣不行吧……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "難得我",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n能和你約會。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦，咦？",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我以為你是為了慶祝我出院，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n來和我約會作為獎勵。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊哈哈。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n總覺得好像只有我自己一個人很興奮，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯？",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你說當成約會也可以嗎？",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我好高興……",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嘻嘻，這是我有生以來的第一次約會。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}，\n我們進去那家店吧。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想稍微休息一下，",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n在那邊吃點甜點後就會恢復精神了。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不行嗎……？",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_031"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你是說可以吧。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n那麼我們進去吧。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊哈哈。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_032"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n只要在你面前，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我就會變得很愛撒嬌呢……♪",
        "unit_id": 103831
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我開動了。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_033"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嚼、",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嚼……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這個可麗餅",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真好吃。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只是，",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_035"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n它份量有點多，我可能會吃不完……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果你願意的話，要不要和我分一半呢？",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_036"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然這樣會變成",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_037"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n間接接吻。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_038"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為你是男生嘛，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n食量比較大呢。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_039"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n只有我一個人心跳加速，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好像笨蛋一樣……♪",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，你不知道嗎？",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_040"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "男生真的是",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不太在意這種事呢。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那麼，應該沒問題吧。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_041"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為對你來說，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n並不覺得這樣很害羞呢。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "來，",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_042"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊～♪",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇，你沒事吧？",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_043"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n很燙吧？",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你有沒有燙到舌頭？",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 103831,
        "voice": "vo_adv_1038008_044"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為你吃得太急了喔，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好吃嗎？",
