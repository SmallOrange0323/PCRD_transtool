    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "若出現必須賭上性命戰鬥的敵人，",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_060"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐我也會助妳一臂之力喔！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "非常感謝",
