        "voice": "vo_adv_5070001_054"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "先失陪了。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊哈哈，",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_055"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "從剛才開始就一直有很凶的客人變得很老實呢。",
