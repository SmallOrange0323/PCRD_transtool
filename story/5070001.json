        "voice": "vo_adv_5070001_061"
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "三位的幫忙。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "\n既然人潮散得差不多了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "\n那三位都可以",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "收工了。",
