        "name": "惠理子",
        "words": "明白了。",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_049"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我端炒麵過來了。",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_050"
    },
    {
