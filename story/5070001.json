        "voice": "vo_adv_5070001_074"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "想讓{player}大人",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "學會游泳而已。",
        "unit_id": 117011
    },
