    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是嗎。",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_062"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們就此告辭了。",
