    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "真的很感謝您。",
        "unit_id": 1,
        "voice": "vo_adv_5070001_056"
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "\n光是願意當店員幫忙就已經很感謝了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "\n沒想到您居然還願意充當保鑣。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我沒有那種意思。",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_057"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我只是不想",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓{player}大人的快樂暑假",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "遭到破壞。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_058"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "託惠理子的福，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就連帶家人一起來玩的人們",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也笑咪咪的喔！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……！！",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_059"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "若能讓您高興，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我會賭上性命",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "守護這個海之家！",
