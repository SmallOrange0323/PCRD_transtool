        "type": "dialogue",
        "name": "惠理子",
        "words": "好了，",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_075"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n請抓著我吧。",
        "unit_id": 117011
    },
    {
        "type": "still",
        "still": "507000101"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_076"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您做得很棒喔。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請照那個樣子擺動雙腳。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "等等！",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_077"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那樣根本沒有穿訓練護具的意義嘛！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我也想撐著弟弟啦！",
