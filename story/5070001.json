        "voice": "vo_adv_5070001_079"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好了，",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_080"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n請您不用在意背後，",
        "unit_id": 117011
    },
    {
