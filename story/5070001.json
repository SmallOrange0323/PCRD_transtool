        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_078"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這終究是我的計畫……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n妳在那邊",
