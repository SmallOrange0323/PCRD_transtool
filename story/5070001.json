    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這是我特製的",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "訓練護具。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "裡面裝了沙子。",
