[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "暑假第一天。{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在惠理子跟靜流的邀請之下來到海邊。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "說到夏天就會想到大海。",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "說到大海就會想到海水浴。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "首先是由我呈上",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為您想好的暑假計畫。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗚嗚……",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "明明我想搶先讓弟弟開心一下的。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這是用抽籤公平決定的，所以是沒辦法的事。",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "更重要的是，靜流，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳忘了重要的事情囉。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對喔！",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這是給你的禮物。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "請收下吧♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是暑假的指南，",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "更正，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是計畫書。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為了讓你享受最棒的暑假時光，",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我昨天跟惠理子一起製作了這個。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "從今天開始到暑假結束為止，",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們全都為您規劃好了。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您覺得如何呢？",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真的嗎！？",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "太好了。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這是我跟惠理子一起拼命想出來的。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為您的暑假不容許有任何疏漏……",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好了，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這下就能毫無牽掛地",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "進行今天的預定了。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n首先",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要在海邊欣賞您的泳技……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "慢死了！",
        "unit_id": 1,
        "voice": "vo_adv_5070001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你這混蛋是要讓我等多久！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "非、",
        "unit_id": 1,
        "voice": "vo_adv_5070001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "非常抱歉！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是幻聽嗎……",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n難得快樂的暑假正要開始，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我卻好像有聽見什麼不識相的噪音……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這位先生……",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_012"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "啥？",
        "unit_id": 911,
        "voice": "vo_adv_5070001_013"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "妳要幹嘛？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難得都來到海邊了，",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不好好享受會很可惜喔？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "吵死了！",
        "unit_id": 911,
        "voice": "vo_adv_5070001_015"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "干你們什麼事！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "客、",
        "unit_id": 1,
        "voice": "vo_adv_5070001_016"
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "客人。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "請冷靜一點。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "再說，這全都要怪你慢吞吞",
        "unit_id": 911,
        "voice": "vo_adv_5070001_017"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "的！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "噫！？",
        "unit_id": 1,
        "voice": "vo_adv_5070001_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好痛……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我柔弱的手掌被你打得",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好痛……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "我聽妳在鬼扯！",
        "unit_id": 911,
        "voice": "vo_adv_5070001_020"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "\n是妳自己擅自闖進來的吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "靜流。",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "怎麼了嗎，",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "惠理子？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "剛才",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "被這位先生",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "施加暴力了對吧？",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對啊。",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n他剛才用力揮下的拳頭",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "命中了惠理子呢。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "說什麼命中，",
        "unit_id": 911,
        "voice": "vo_adv_5070001_025"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "她明明就用手接下了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "喂！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "可惡，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "快放開我！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "王八蛋！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "根本拔不出來！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然是他先使用暴力，",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_026"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那無論我做什麼都算是正當防衛，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n是這樣沒錯吧？",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不可以做得太過火喔？",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "適度地懲罰他就好。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "就說",
        "unit_id": 911,
        "voice": "vo_adv_5070001_028"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "是妳擅自……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "呃，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "咦？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "\n我好像在哪看過妳……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "\n妳不是",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "破壞者嗎……！！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哼！！",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_029"
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "咕嘿！？",
        "unit_id": 911,
        "voice": "vo_adv_5070001_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "敢打擾我跟{player}大人快樂時光的人，",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我絕不會原諒。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "別忘了！",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我也在喔！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "那、",
        "unit_id": 1,
        "voice": "vo_adv_5070001_033"
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "那個，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "非常感謝您在我危險時",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "出手幫忙。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我只是趕走不識相的人，",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_034"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n免得妨礙{player}大人享受快樂暑假而已。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "他怎麼會氣成那樣啊？",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_035"
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "那是……",
        "unit_id": 1,
        "voice": "vo_adv_5070001_036"
    },
    {
        "type": "dialogue",
        "name": "海之家的客人們",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5070001_037"
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "因為有職員突然生病請假，",
        "unit_id": 1,
        "voice": "vo_adv_5070001_038"
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "\n導致人手不足，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "上菜速度變慢……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不愧是弟弟！",
        "unit_id": 117111,
        "voice": "vo_adv_5070001_039"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是溫柔！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "當然也會幫忙！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然計畫趕不及變化……",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_040"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果這能連接上您的快樂暑假計畫，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我也會幫忙。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "可、",
        "unit_id": 1,
        "voice": "vo_adv_5070001_041"
    },
    {
        "type": "dialogue",
        "name": "海之家的店員",
        "words": "可是……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "可是？",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_042"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒有什麼好可是的。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "你只要乖乖接受",
