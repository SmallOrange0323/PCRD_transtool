        "voice": "vo_adv_5070001_071"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我會緊密貼身地",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "支撐著您。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n請您放心並專心游泳。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "話雖如此，",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_072"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一開始就穿著這個游泳也很吃力。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您先抓著我吧。",
