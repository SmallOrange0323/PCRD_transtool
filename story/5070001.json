        "voice": "vo_adv_5070001_066"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我希望您務必",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在這個夏天有所成長。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼，",
        "unit_id": 117011,
        "voice": "vo_adv_5070001_067"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n首先",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您穿上這個。",
