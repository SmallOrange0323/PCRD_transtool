    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，\n{player}正和珠希一起餵貓。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "瞧～，我今天也帶飼料來了喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046004_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "大家要好好吃喔喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……？",
        "unit_id": 104611,
        "voice": "vo_adv_1046004_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，飼料已經沒了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那開新的罐頭吧――",
        "unit_id": 104611,
        "voice": "vo_adv_1046004_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵！？",
        "unit_id": 104611,
        "voice": "vo_adv_1046004_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n什麼喵，從罐頭裡發出光……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵啊啊啊啊啊啊！？",
        "unit_id": 104611
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要不要來份～，鯛魚燒～？",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "特別特別美味的鯛魚燒喵～。",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "過來看看喔，喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喲！",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你來得正好喵。喂，過來一下喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "其實喵……我有事想拜託你喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我想讓你試試看我新研發的樣品鯛魚燒，",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n請當我的實驗品喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一個100日圓，特別優惠你一個70日圓就好喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以拜託你喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那、那是…",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "…",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呃……的確，我明白你的心情喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我、我想應該不會死的喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n所以你就乖乖地配合實驗吧―",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "那、那個……",
        "unit_id": 131,
        "voice": "vo_adv_1046004_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哦，可愛的兄妹，歡迎光臨喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "鯛魚燒一個100日圓喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "那個……嗯……我們的零用錢很少……",
        "unit_id": 131,
        "voice": "vo_adv_1046004_015"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "可以用這些錢賣一半的鯛魚燒給我們嗎……？",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這是……50日圓……？",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只有50日圓啊喵……",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n嗯―，那麼……但是，喵……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……嗯，",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我想到了喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果你們幫忙做鯛魚燒的話，",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我就送你們鯛魚燒當作打工費吧喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "大姐姐……真的嗎？",
        "unit_id": 231,
        "voice": "vo_adv_1046004_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "當然喵，我不會說謊喵！",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還有……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "悉悉簌簌……",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_022"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗯……",
        "unit_id": 131,
        "voice": "vo_adv_1046004_023"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗯，我知道了！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "交涉成立喵！",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，馬上開始做鯛魚燒吧喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這裡的訣竅是要再這樣好好地烤……",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在這個地方一口氣這樣做喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯……這樣嗎……？",
        "unit_id": 231,
        "voice": "vo_adv_1046004_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "對喵！",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "很厲害喵！ ",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳是做鯛魚燒的天才喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嘻嘻嘻……大姐姐，謝謝。",
        "unit_id": 231,
        "voice": "vo_adv_1046004_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，這樣就完成了喵！",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你們兩人都知道怎麼做了嗎喵？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗯，",
        "unit_id": 131,
        "voice": "vo_adv_1046004_030"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "當然！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "很好很好，那麼走吧喵！",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_031"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "大哥哥！",
        "unit_id": 231,
        "voice": "vo_adv_1046004_032"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "請買我們做的鯛魚─燒！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這裡面，混有我的試驗品\n",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_033"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "和孩子們努力做的鯛魚燒喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "以特別促銷價格販售喔喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_034"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為是孩子們做的鯛魚燒，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n必須在他們面前吃喵～？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呵呵呵……你就乖乖的當我的實驗品吧喵！",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_035"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "全部都吃完了喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_036"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n跟我計畫的一樣喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，這些鯛魚燒是你們今天的打工費喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_037"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你們兩人選喜歡的吃吧喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗚哇啊啊啊啊啊啊……！",
        "unit_id": 231,
        "voice": "vo_adv_1046004_038"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "好多鯛魚燒……！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "大姐姐，謝謝妳！",
        "unit_id": 131,
        "voice": "vo_adv_1046004_039"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不要吃太多免得吃壞肚子喔喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_040"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗯！",
        "unit_id": 131,
        "voice": "vo_adv_1046004_041"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n真的很謝謝妳！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "大姐姐，再見喔！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真是純樸的孩子們喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_042"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "讓他們打工真是值得喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_043"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你的身體狀況還好嗎？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有30倍超辣的鯛魚燒，麻辣鯛魚燒，",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_044"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n還有很多充滿熱情的實驗品的喵？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯─，",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_045"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "實驗似乎以失敗收尾喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，開發新商品，犧牲是不可避免的喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是，謝謝你今天陪我喵♪",
        "unit_id": 104632,
        "voice": "vo_adv_1046004_046"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1046004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1046004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，我想那些鯛魚燒應該有10個以上，",
        "unit_id": 190011,
        "voice": "vo_adv_1046004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還真虧你能吃完呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖說是為了孩子們，你還真是拼命啊。",
        "unit_id": 190011,
        "voice": "vo_adv_1046004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我要稱讚你。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也虧珠希能馬上想到這樣的策略。",
