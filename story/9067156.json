    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "放棄魔物料理，該出發囉。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106011,
        "voice": "vo_adv_9067156_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔哇啊～！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐！",
        "unit_id": 105911,
        "voice": "vo_adv_9067156_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐她",
