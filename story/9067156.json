        "voice": "vo_adv_9067156_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "三人",
        "unit_id": 105811,
        "voice": "vo_adv_9067156_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都被抓住了呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……不愧是",
