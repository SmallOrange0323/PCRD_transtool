        "type": "dialogue",
        "name": "凱留",
        "words": "咿……！",
        "unit_id": 106011,
        "voice": "vo_adv_9067156_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n更黏答答了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "衣服的邊角開始溶化了啦！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快救我～！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "食人植物，",
        "unit_id": 105811,
        "voice": "vo_adv_9067156_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把小凱留還給我～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚哇啊啊～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "連貪吃佩可小姐也……！？",
        "unit_id": 105911,
        "voice": "vo_adv_9067156_012"
    },
    {
        "type": "dialogue",
