[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒想到",
        "unit_id": 105911,
        "voice": "vo_adv_9067156_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雙冠龍竟然會變形……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來吉歐‧格黑納的魔物，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "用一般的手段無法對付呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一活動",
        "unit_id": 105811,
        "voice": "vo_adv_9067156_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子就餓了～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以說，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們來料理雙冠龍吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就知道妳會這麼說……",
        "unit_id": 106011,
        "voice": "vo_adv_9067156_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才不要！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n至少讓我吃正常的飯啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，",
        "unit_id": 105811,
        "voice": "vo_adv_9067156_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不可以挑食！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且啊，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雙冠龍有調節體溫的能力！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n吃了說不定",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會覺得涼爽喔☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣啊～♪",
        "unit_id": 106011,
        "voice": "vo_adv_9067156_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……等一下，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳指的是雙冠龍的生態吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那就算",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吃下肚也毫無意義啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我才不會上妳的當，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "白癡佩可！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 105911,
        "voice": "vo_adv_9067156_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐跟",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就在剛才，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魔物已經",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被食人植物吃掉了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦咦！？",
        "unit_id": 105811,
        "voice": "vo_adv_9067156_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "食人植物先生，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不可以搶別人的食物喔！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉呀呀，",
        "unit_id": 106011,
        "voice": "vo_adv_9067156_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真可惜～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這下子",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可沒辦法了。",
        "unit_id": 106011
