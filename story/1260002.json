    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_005"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我可以問你一件事嗎？",
