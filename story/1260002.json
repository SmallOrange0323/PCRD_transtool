    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不需要吃得那麼急也沒關係唷～",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "要細嚼慢嚥哦，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_031"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "嚼嚼、",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "嚼嚼、",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "嚼嚼……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "吃飽後我們再一起去洗澡吧……♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "剛、",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_032"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "剛才那句話不是在對哥哥說哦！？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n要一起洗澡的是……！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……啊，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "你說你知道？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "說的也是呢，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不好意思……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "嗚喵……♪",
        "unit_id": 1711,
        "voice": "vo_adv_1260002_033"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "嗯，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_034"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "怎麼",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "跑過來玩了。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n你的飯還沒有吃完哦～？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是想跟我說什麼嗎～？",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_035"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "說謝謝……",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_036"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是嗎。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵……",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_037"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "居然向我道謝。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "小貓咪，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "要道謝的話，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "應該要向這位哥哥說才對哦？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……那個，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_038"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n老實說……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "要不是跟哥哥一起遇見牠，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_039"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我想我一定……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n不會把這孩子帶回家。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……我。",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_040"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_041"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "並非大家心中所認為的……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n……那種聖女。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我不是什麼好孩子……",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_042"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……呵呵，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_043"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n過來吧。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "嗚喵～",
        "unit_id": 1711,
        "voice": "vo_adv_1260002_044"
    },
    {
        "type": "still",
        "still": "126000201"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_045"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "從小只要在別人面前，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n就會裝出一副乖寶寶的樣子……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n真的是不自覺的。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "裝得像貓一樣乖……",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_046"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "開玩笑的♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_047"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……剛才回來的路上，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_048"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我不是問了哥哥一個問題嗎？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n問你",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "覺不覺得我是普通的女孩子。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "沒錯，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_049"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我只是個普通的女孩子。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不是聖女也不是其他身分……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就只是個",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "普通的女孩子。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "所以",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_050"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "在打工地點被店長或常客",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n那樣子叫……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "讓我有點難為情。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……不過，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這些都是我自己的問題就是了。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "明明是自己裝成乖巧聽話的樣子，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_051"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n一旦被人稱做「聖女」時，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "卻又覺得討厭……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我這樣太任性了對吧……",
        "unit_id": 126012
    },
    {
        "type": "still",
        "still": "126000202"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……所以。",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_052"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n不管是把這孩子帶回來這件事，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "還是替牠做飯這件事，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n都不是出自純粹的善心。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……而是因為",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_053"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是在哥哥面前……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我才這麼做的。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "打工也是，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_054"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "因為是在哥哥面前，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n所以我才沒有逃跑。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "要是哥哥不在的話……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……啊，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_055"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "但並不是因為",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥在我心中是特別的……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不是因為這樣！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "也不能說不特別就是了……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_056"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……不對，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_057"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我到底在胡說些什麼啊？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n這些事我從沒對別人……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "甚至連莉莉我都沒有跟她說過……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……這就是我真實的樣子。",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_058"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n讓你幻滅了嗎？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……真的",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_059"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "嗎？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n哥哥果然很溫柔呢。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……！",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_060"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n很……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "很喜歡……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "真是的……",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_061"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n請別說那種",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "容易讓人誤會的話好嗎……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n尤其",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "絕對不能在莉莉",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "的面前說……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "知道了嗎？",
        "unit_id": 126012
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "126000201"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……呵呵，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_062"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "總覺得只要在哥哥面前，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n就會不小心把心裡話都說出口呢……♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "可是……",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_063"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "請幫我",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對大家保密哦。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "因為我似乎並不討厭",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "在哥哥面前裝乖喔♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……呵呵。",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_064"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n好……♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "喵～",
        "unit_id": 1711,
        "voice": "vo_adv_1260002_065"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_066"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對不起，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "飯才吃到一半呢。",
