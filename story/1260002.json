    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "話說，我從剛剛開始就一直出現幻聽……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n聽到了「喵～",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "喵～」",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "的聲音……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喵～",
        "unit_id": 1,
        "voice": "vo_adv_1260002_009"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "！！",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_010"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n看來似乎不是幻聽呢……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "在那邊。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "嗚喵～",
        "unit_id": 1711,
        "voice": "vo_adv_1260002_011"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "小貓咪……",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_012"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "你是怎麼了，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這麼晚了還獨自待在這裡。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n難不成是迷路了嗎？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_013"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "真的耶。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "只是太暗了有點看不清楚內容……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我看看～",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "「請哪位好心的人，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "好好愛護牠吧」……？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_014"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "意思是說，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這隻貓咪被人遺棄了……！？",
