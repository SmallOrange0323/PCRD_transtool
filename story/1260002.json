        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……唉。",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_002"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n聖女妹妹",
