    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "怎麼可以這麼不負責任……！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "喵～咕……",
        "unit_id": 1711,
        "voice": "vo_adv_1260002_015"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_016"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對不起。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "雖然覺得你很可憐……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "可是……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥、",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_017"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥！？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不可以啦，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這麼隨意地就……！",
