        "voice": "vo_adv_1260002_022"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我也會一起幫忙找找看有沒有人願意",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "收養牠的。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對不起哦，小貓咪。",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_023"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n那麼，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我們走吧……♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "喵～！",
        "unit_id": 1711,
        "voice": "vo_adv_1260002_024"
    },
    {
        "type": "background",
        "background": "500952"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "來吧，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_025"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "吃飯囉～",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "希望這個合你胃口……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是的。",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_026"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "因為牠的體溫好像有點低，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n所以我想說讓牠吃點溫熱的食物。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "當然",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我有把食物弄成貓舌頭也能安心食用的溫度♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "然後",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_027"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我也有另外做了一份人類吃的調味，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "如果你不介意就一起吃吧♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "請",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_028"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "慢用～",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "嗚喵～～♪",
        "unit_id": 1711,
        "voice": "vo_adv_1260002_029"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_030"
    },
