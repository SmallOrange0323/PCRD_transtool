    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_004"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "也稱不上煩惱就是了……",
