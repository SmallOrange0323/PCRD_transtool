    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "實在沒辦法一邊冒險，",
        "unit_id": 126012
    },
