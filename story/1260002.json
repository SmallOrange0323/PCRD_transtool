    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "當然，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_018"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我也同樣很想帶牠一起走……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "可是我們是冒險者。",
        "unit_id": 126012
    },
