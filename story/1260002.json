    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……啊，",
        "unit_id": 126012,
        "voice": "vo_adv_1260002_003"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對不起。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n不小心就嘆了口氣……",
