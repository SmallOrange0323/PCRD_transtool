    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "なにかのお役に立つかと、",
        "unit_id": 105913,
        "voice": "vo_adv_6056203_000"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\nトゥンヌスの生態についての勉強をしていたのですが……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ふむ、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "中々に奥深いものでございますね。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ふふ、",
        "unit_id": 105913,
        "voice": "vo_adv_6056203_001"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "承知いたしました。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "こちらに",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "トゥンヌスの生態を記した本がありますので、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n一緒に勉強いたしましょう。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "トゥンヌスの体は",
