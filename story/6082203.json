        "voice": "vo_adv_6056203_002"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "筋肉と、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "特殊な魔力器官で構成されているようです。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n加えて、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "泳ぐことに特化した形状が――",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "っと、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "主さま？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "……どうやら",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "眠くなってしまわれたようですね。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ふふ♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ああいえ、",
        "unit_id": 105913,
        "voice": "vo_adv_6056203_003"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "生態についてなので",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "調理方法は……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "もしかして",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "お腹が空かれたのでしょうか、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "主さま？",
