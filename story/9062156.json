[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼……",
        "unit_id": 106011,
        "voice": "vo_adv_9062156_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總算是抓到了～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但要怎麼處置",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠呀？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠還在生悶氣耶？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠好像對我們很不高興，",
        "unit_id": 105911,
        "voice": "vo_adv_9062156_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來很暴躁……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果不把牠帶回開拓村",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "給飼主的話，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可能會很難安撫牠的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說帶回去………",
        "unit_id": 106011,
        "voice": "vo_adv_9062156_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這是要怎麼帶呀？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們又沒帶籠子來。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不裝籠子，",
        "unit_id": 105811,
        "voice": "vo_adv_9062156_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "裝在我的肚子裡帶回去也是可以的呀～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "流口水……☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──！？",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……！",
        "unit_id": 105911,
        "voice": "vo_adv_9062156_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好了！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "格里芬好像被貪吃佩可小姐的貪吃嚇了一跳，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又開始躁動了──",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯喵呀呀呀呀！？",
        "unit_id": 106011,
        "voice": "vo_adv_9062156_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看看妳做的好事，白癡佩可！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "繩子斷了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠飛起來了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n往我們這裡衝過來了～～～！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿，",
        "unit_id": 105811,
        "voice": "vo_adv_9062156_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不好意思。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不小心就說出真心話了……☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然這樣，那就只能逃跑了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是呀……！",
        "unit_id": 105911,
        "voice": "vo_adv_9062156_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果就這樣一路往開拓村的方向逃的話，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或許牠會跟過來也說不定……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦咦！？",
        "unit_id": 106011,
        "voice": "vo_adv_9062156_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳們幾個",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "知道這裡是哪裡嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳問哪裡……",
        "unit_id": 105811,
        "voice": "vo_adv_9062156_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "艾爾皮斯島的",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "盡頭吧～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對呀！",
        "unit_id": 106011,
        "voice": "vo_adv_9062156_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡距離開拓村……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳知道有多遠嗎！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_9062156_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您冷靜下來。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下明白您的心情，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但除此之外，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n已經沒有其他對策也是不爭的事實。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最重要的是，",
        "unit_id": 105911,
        "voice": "vo_adv_9062156_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與其把牠裝進肚子裡帶回去，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不如跑好幾個小時……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不對，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好幾天，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一路跑回村裡還好一點……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幸好",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們已經對這片土地",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很熟悉了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔……！",
        "unit_id": 106011,
        "voice": "vo_adv_9062156_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說得也是……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒辦法了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～！",
        "unit_id": 105811,
        "voice": "vo_adv_9062156_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就大家一起",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n來一場愉快的艾爾皮斯島縱貫衝刺吧～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咚☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔唔唔～",
        "unit_id": 106011,
        "voice": "vo_adv_9062156_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然如此，就只能奉陪到底了……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可不要小看了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "長年調查這座島的我們哦～～～！！",
        "unit_id": 106011
    }
]