        "words": "半藏那傢伙",
        "unit_id": 112711,
        "voice": "vo_adv_6040210_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "消失到哪裡去了啊。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒有抓到他",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就覺得事情還沒有結束呢。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的有這種感覺呢。",
        "unit_id": 112711,
        "voice": "vo_adv_6040210_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為半藏他們好像只是為了錢而行動，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以我想應該是可以安心了……",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，該怎麼說才好呢～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然要逮到他們應該",
        "unit_id": 112711,
        "voice": "vo_adv_6040210_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "會花不少功夫，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但還是希望他們會被抓到呢。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "讓他們得到害我工作的報應吧。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "他們不會做這種會露出馬腳的事情啦。",
        "unit_id": 112711,
        "voice": "vo_adv_6040210_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "一定",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "已經逃到很遠的地方去了。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不想再看到那些傢伙",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "第二次了呢。",
        "unit_id": 112711
    }
]