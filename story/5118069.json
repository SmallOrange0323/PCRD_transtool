[
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]跳蚤市場會場連日都呈現盛況。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n而在會場的一角，碧卡拉正低著頭，一臉悲壯。"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]老鼠耳朵……",
        "unit_id": 125614,
        "voice": "vo_adv_5118069_000"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]弄丟了……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]明明是經歷一番波折才好不容易拿回來的，",
        "unit_id": 125614,
        "voice": "vo_adv_5118069_001"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]為什麼如此輕易地就又弄丟了呢……？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]真是對自己失望過頭，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]只剩下絕望了……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]真鬱卒……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]實在太鬱卒……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "冬麥斯",
        "words": "[FFFFFFFF]──！！",
        "unit_id": 9712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]人家知道啦，",
        "unit_id": 125614,
        "voice": "vo_adv_5118069_002"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]小冬……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n老鼠耳朵還在這個會場裡面對吧。",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n這一點就算是人家",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]也還是知道的……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]可、",
        "unit_id": 125614,
        "voice": "vo_adv_5118069_003"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]可是",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]在沒有老鼠耳朵的狀態下，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n要人家衝進人群裡面，是非常需要勇氣的呀……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]而且現在還是大白天……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]啊啊，",
        "unit_id": 125614,
        "voice": "vo_adv_5118069_004"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]可是可是，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]得立刻去找才行對吧……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n總不能又去麻煩吉塔小姐他們吧……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]如果真的那樣做，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]恐怕真的會害對方受不了，最後嫌棄人家……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "冬麥斯",
        "words": "[FFFFFFFF]──！",
        "unit_id": 9712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]咦……？",
        "unit_id": 125614,
        "voice": "vo_adv_5118069_005"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n啊，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]確實感覺到……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]老鼠耳朵的氣息逐漸接近了呢……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]該不會是",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]撿到老鼠耳朵的人正往這邊走過來……？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]方才的交涉，",
        "unit_id": 105913,
        "voice": "vo_adv_5118069_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]您表現得真是太精彩了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]凱留小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]\n託您的福，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]成功以便宜的價格買到了不錯的物品。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]\n主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]肯定也會很高興的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]那、",
        "unit_id": 106012,
        "voice": "vo_adv_5118069_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]那傢伙怎麼想，我根本無所謂啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]更何況，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]剛才那家店太不把客人放在眼裡了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]\n那種價格不殺價誰買得下手啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]話說回來……",
        "unit_id": 106012,
        "voice": "vo_adv_5118069_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]\n這個像髮箍的東西，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]要怎麼辦呀？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]剛才不小心就撿起來了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]若此處有失物招領中心",
        "unit_id": 105913,
        "voice": "vo_adv_5118069_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]就好了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]但似乎沒有看到感覺可能是的攤位。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]這也沒辦法呀，",
        "unit_id": 106012,
        "voice": "vo_adv_5118069_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]誰叫這裡人多店也多。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]反正我覺得在這邊隨便逛逛，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]應該就可以發現類似的攤位了吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]話說回來，",
        "unit_id": 105913,
        "voice": "vo_adv_5118069_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]此髮飾感覺真不可思議。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]簡直像",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]是以獸人族耳朵為範本製作出來的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]啊～",
        "unit_id": 106012,
        "voice": "vo_adv_5118069_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]這麼說，確實看起來像老鼠的耳朵呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]那麼，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]這東西的主人或許就不是獸人族囉。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]…………\n請……人家……",
        "unit_id": 125614,
        "voice": "vo_adv_5118069_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]咦？",
        "unit_id": 106012,
        "voice": "vo_adv_5118069_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]\n可蘿仔，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]妳說了什麼嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]不，",
        "unit_id": 105913,
        "voice": "vo_adv_5118069_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]在下什麼也沒說……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]請請……",
        "unit_id": 125614,
        "voice": "vo_adv_5118069_016"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]請還……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]還給人家……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]凱留小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_5118069_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]您有說什麼嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]我沒說話啦！",
        "unit_id": 106012,
        "voice": "vo_adv_5118069_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]真是的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]從剛才開始就怎麼搞的？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]\n難不成現在大白天的也會有幽靈出沒！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]請還給人家～～！！",
        "unit_id": 125614,
        "voice": "vo_adv_5118069_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]出、出出出出現啦────！",
        "unit_id": 106012,
        "voice": "vo_adv_5118069_020"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那個……",
        "unit_id": 125614,
        "voice": "vo_adv_5118069_021"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是人家……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是人家的東西……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n人、",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]人家如果……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]沒有它、",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]沒有它就會……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]妳突然冒出來是幹什麼呀！？",
        "unit_id": 106012,
        "voice": "vo_adv_5118069_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]而且還一直碎碎念一些像是咒語的話！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]妳是想跟我打嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]小心我宰了妳喔！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]凱留小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_5118069_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]還請冷靜下來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]她肯定",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "[FFFFFFFF]就是這個髮飾的主人吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是……",
        "unit_id": 125614,
        "voice": "vo_adv_5118069_024"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是、",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是的，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]沒錯、",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]沒有錯……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那、",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那是人家重要的……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]重要的老鼠耳朵……！",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]什麼嘛，",
        "unit_id": 106012,
        "voice": "vo_adv_5118069_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]原來是這樣啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "[FFFFFFFF]\n那也好，",
