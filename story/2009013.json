[
    {
        "type": "background",
        "background": "500055"
    },
    {
        "type": "still",
        "still": "200901301"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有必要說明一下呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "其實我呀，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是出生於那海另一邊的遙遠國度呢……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然隨波逐流來到了這個國家，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然而本籍仍在那兒。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在這個國度中立下無數的功績後得到了爵位，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n便以貴族的身分寄屬於【王宮騎士團】之下了呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n然而基本上，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我仍算是異國之人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而在我所出生的故鄉，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在祖國",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有著極大影響力的某個財團跟我……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這個嘛該怎麼講，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "簡單說就是跟我有點關係呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "費盡苦心和對方聯絡，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然後從他們那取得了資金。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n便以此為本金，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再利用了些管道與小手段，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "才會像這樣暫時就任【慈樂之音】的製作人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話雖如此，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但也就只是限定於她們此次巡演的製作人呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n儘管培育偶像還頗有趣的……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟我仍是個逃犯，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對外也不太好辦事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "且基本上，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我自己更想立於戰場之上呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "偶像業界雖某種角度來說也算是個戰場，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然而我更想要",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "站在那刀光劍影、濺滿鮮血的戰場唷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……反正，那個暫且就先不談了。",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500055"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也不是好事或吃飽太撐，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n才會決定要來當個什麼製作人的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不用說，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然是我所主導的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n【慈樂之音】今次的巡演我絕對會讓他盛大成功的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而當然，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "此事之下也暗藏其他的目的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "於下個週末所舉辦的，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "蘭德索爾的祭典當日……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "祕密社團【拉比林斯】將會有所行動。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而也是為此，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可說是事前準備的一部分呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然詳細的作戰在時限前還要再三研擬，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n現在就概要向你說明吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……【拉比林斯】在當日，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "將會襲擊王宮。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "最大的目的是，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n對我等最大的宿敵尤絲蒂亞娜進行暗殺或者捕獲……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而至少，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也得將那傢伙在王宮內所設置的",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n洗腦魔法裝置給破壞掉才行。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯嗯。",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那樣的東西，似乎被設置在王宮裡頭的模樣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那個凱留和【王宮騎士團】的眾人們，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n似乎也都是被那玩意兒給操縱了呢……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要能將之破壞，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "敵人的戰力也會大幅被削弱。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n倘若沒有被魔法給洗腦，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "誰都不會聽令那暴君……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聽令那尤絲蒂亞娜的指示吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要能解開洗腦，眾人便能輕易地反叛了吧。",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而尤絲蒂亞娜也將會變得毫無防備……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而那傢伙若直到當日，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n都還如同拉比林斯達一般處於昏睡狀態之下……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我們也預想能夠順勢進行暗殺。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "假若可行以我的角度來講，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可還真想見見他哭著跪地求饒的模樣就是了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過嘛，敵人可說就是這強大的國家，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "太過於奢求些什麼也不行。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "數日前，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "【拉比林斯】所保護的真軌",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n與他的主人似似花的分身進行了接觸。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "儘管不清楚她是用了什麼技倆，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "明明是被囚禁於王宮之內，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n卻還是成功地聯絡上了我等。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而從獲得的情報為根據，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n【拉比林斯】便決意在祭典之日",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "起義的樣子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟現在我與【拉比林斯】也是協力的關係，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也有讓我從牢獄之災解脫的恩情。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當前利害也一致，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以我也打算與她們合作。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你們也一樣，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若有這個打算也來出份力吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "【拉比林斯】襲擊王宮的當日，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也是將你們重要的伙伴蒂亞娜……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "將貪吃佩可給救出來的絕佳好時機嘛。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再怎麼說【拉比林斯】就只是將敵人頭目給解決，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n且將洗腦魔法裝置給破壞做為優先目的來行動。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n很可能無法將營救貪吃佩可，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也一同納入計劃。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因此，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這還得靠你們來行動。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在當日前重整好態勢，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "抱持好覺悟與",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "【拉比林斯】一同襲擊王宮，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n再想盡辦法將你們的伙伴給救出來即可。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而不論你們最後決定是否參與，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n【拉比林斯】在祭典之日都將會有所行動。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當然那一天不論你們究竟想要怎麼做，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也是你們的自由就是了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但可行的話，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也希望你們能夠順利救出貪吃佩可唷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和那傢伙鬧起來也挺起勁的嘛……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "實際上，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那傢伙也並未曾做出過什麼壞事不是嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在又濕又冷飄著霉味的牢房中，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n一面悲嘆度日過完人生也挺可憐的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總之，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "目前需要傳達的事項就只有這樣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在這之後我，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "或者其它的哪個人也會定期與你們進行聯絡吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若能一面頻繁地將互有的情報共享，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n且相互扶持、協助彼此行動就最好了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是嘛，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這孩子……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "叫可可蘿來著？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在這孩子醒過來以前，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你也會憂心到什麼事也辦不成吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "順帶一提。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "關於襲擊你們的那隻魔物，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "至今依舊不明。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n鮮少被目擊過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "大概是相當高階的魔物吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想八成，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是那可以操縱魔物的凱留……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n對影響力能夠傳達到之範圍內的所有魔物，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n下了襲擊{player}，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "諸如此類的命令吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "平時一般的魔物在城門前出入口，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n儘管會被待命的守衛給清除或趕走……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n然而該魔物卻過於強大，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "導致突破了守衛而進到了城中吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然後，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "便找上了你來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n【慈樂之音】她們，不過就像是被掃到了颱風尾一般。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而這事錯的是那操縱魔物的凱留，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你並無對此有任何自責的必要就是了呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話說回來。",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在城中多少還稱得上安全，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然而一出了城外，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你會被那種魔物給襲擊的可能性相當高。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "除非真有什麼要緊事，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不然短時間內還是盡力避免出到城外較好呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒兩下就會死的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟你似乎沒什麼戰鬥力嘛。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而平時似乎身兼保護你責任的這位叫可可蘿的孩子，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也就正如你所見。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……這孩子，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若能早日康復就好了呢。",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "200901301"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……妳是把我當成，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n沒血沒淚的什麼惡鬼羅剎之類的傢伙嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如此年幼的孩子受到了傷害，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一般來說都是會使人痛心的悲劇吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我雖然並非是什麼大德大善之人，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n甚至對血腥味更是來者不拒……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但也並非對不幸或悲劇，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "能夠照三餐樂在其中之人呀。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若每個人都能歡笑中幸福地生活下去，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "便是圓滿之事了。",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "200901301"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……這種話，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "出生至今我還是頭一次聽到呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你還真是個",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怪孩子呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "算了。",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我也是遭人追緝之身，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也不好在這兒待太久。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也得趕緊和【慈樂之音】會合，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n以關係者的名義偷偷利用『傳送門』前往異國囉。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "接著藏身至連王宮的魔爪也無法出手的異國之境，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n打算在起義之日到來前先做好各種萬全的準備。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "儘管東逃西躲的挺不是滋味，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是也別無他法。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在那復仇之果熟成之前，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也就只能垂涎三尺靜待等候了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107111,
        "voice": "vo_adv_2009013_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真讓人期待呀……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那祭典之日。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "到了那天，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可要將這個國家給徹底連根拔起囉。",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "200099901"
    }
]