[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "配送工作結束後，{player}在鎮上走著，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n遇見了不知為何正在四處張望的鈴。"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你來得正好！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你在說什麼啊？",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我這麼認真在工作，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哪有可能被傳喚嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "今天也是為了幫忙真陽兜售商品",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "才特地來城鎮的喔？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我真的很能幹呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真陽的兜售已經結束了，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以我現在才久違地在鎮上閒晃。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我可是有認真工作喔？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這點你可要",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好～好地記住喔。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀～",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但話說回來",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你來得正是時候。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我正在找熟人呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "其實我本來是打算和真陽一起去的，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但除了兜售商品外，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n她說還有和熟客的工作要做就走掉了～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你說我不用幫真陽的忙嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哈哈哈，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "討厭啦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那種事就交給專業的做，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我這個外行人怎能去搗亂呢？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有時不工作反而是最能幫上忙的喔。",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯嗯。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我其實",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在這種事情上很～有自知之明的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀～",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我真是個出色的女性啊～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那種事怎樣都好啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我現在有想要的東西。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我希望",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你能幫我找。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "馬上就答應真是幫大忙了～",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "先把詳情問清楚再回答會比較好喔？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為你本來就",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很容易被捲入各種麻煩事裡嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是不討厭你這點啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這次的不是什麼麻煩事，所以安心吧。",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n交友廣闊的你應該會知道些什麼。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我很期待喔。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我在找的是飲料……",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃啊～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不用拉我的手啦！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n哪裡有飲料店這種小事我還知道！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但不是啦～！",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我在找的是有點奇特的飲料。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然牧場的牛奶也不錯，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我想要更速食性一點的～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……啊。",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那個，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "別在意這個啦！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你看嘛！",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我最近工作很認真吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以怎麼說呢，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "像是工作完喝一杯？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "想要類似這樣的飲料～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "麥酒……",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對我來說還太早了～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就是想要類似那種感覺的飲料～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "據說",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有種在遊戲玩家間造成話題的飲料，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然我不清楚詳情。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我想說既然造成了話題，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "應該馬上就能找到，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "卻沒看到類似的東西，很傷腦筋呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你知道些什麼嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的嗎！？",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你真的很可靠耶～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n橡子和你真是不可或缺的呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哪裡有那種飲料呢？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n快帶我去吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我要買一大堆～",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼會在這種地方？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "想騙我",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "技術也要好一點吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉～",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "竟然對你有所期待，我真笨……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n真沒辦法，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "既然都來了，撿些橡子再回去吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "歡～～～～迎",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_027"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "大駕光臨！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎、",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎麼了！？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "森林深處有座隱藏的恢復之泉，",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_029"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n順利抵達的人將能獲得豪華獎品喔～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "唉呀？",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_030"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "你不是幫我們送貨的孩子嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n該不會有什麼貨少送了！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "是要跟旁邊的孩子一起參加嗎？",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_031"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "這樣的話非常歡迎喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n請務必找出恢復之泉！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那、",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那個～～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我聽不懂你們在說什麼，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼意思啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "咦？",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_033"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳什麼都不曉得就來了嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是來",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_034"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "找一種在遊戲玩家間造成話題的飲料。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "那就是這裡沒錯喔！",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_035"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "這是正式發售前的促銷活動。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n獎品正是那種飲料。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "……呃，",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_036"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "這種解釋好像不說比較好。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "我得習慣這種事才行。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "嗯，",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_037"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "小細節就別在意了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "總之往森林前進，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n到達終點就行了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "好好享受吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這該不會……",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_038"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是能免費獲得的意思？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "太棒了！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們迅速地抵達終點拿獎品吧！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "來吧，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_039"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們走！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒想到竟然正在舉辦這樣的活動。",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_040"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不僅能獲得飲料，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還能參加這種像遊戲一樣的活動，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n真是太周到了～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "探索森林",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_041"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對我來說根本小事一樁。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總之先跟隨人的氣息前進吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611,
        "voice": "vo_adv_1026010_042"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "喔～",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_043"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這布偶裝做得真像耶。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嚇了我一跳。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "嘎、",
        "unit_id": 1611,
        "voice": "vo_adv_1026010_044"
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "嘎喔喔喔喔！！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊哈哈！",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_045"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "叫聲也很像呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你就這樣繼續嚇人吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我得趕緊抵達恢復之泉，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_046"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n獲得飲料才行～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "嘎喔……",
        "unit_id": 1611,
        "voice": "vo_adv_1026010_047"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為聽到了窸窸窣窣的怪聲，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_048"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我就知道會有東西跑出來啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可別小看獸人的聽力喔。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好了，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_049"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "趕快前進吧～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我的極樂世界近在眼前了～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "恭喜～！",
        "unit_id": 411,
        "voice": "vo_adv_1026010_050"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n你們兩位是最先抵達的！！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "成功了～～！",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_051"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n…………",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "欸？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_052"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為在我們前面",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有很多人的氣息，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我還以為大家早就都抵達終點了。",
