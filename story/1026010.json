        "type": "dialogue",
        "name": "女性",
        "words": "咦？",
        "unit_id": 411,
        "voice": "vo_adv_1026010_053"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "但是確實是你們先……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～沒差沒差！",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_054"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不用在意！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n大家應該只是有點迷路了而已。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "獎品我就收下囉。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "東西就拜託你拿囉～",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_055"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是太周到了～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "歡迎回來。",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_056"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "玩得開心嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還行吧。",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_057"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "難度再高一點或許會更好。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_058"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但大家都迷路才讓我們變成最先抵達的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以難度這樣可能剛好吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "難易度調整真的不容易呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "咦？",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_059"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "你、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "你們最先抵達？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎麼了嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_060"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "不、",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_061"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "不，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "沒什麼……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "喔？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你一點也不像沒什麼的樣子耶……",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_062"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "真、",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_063"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "真的沒什……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那個～",
        "unit_id": 411,
        "voice": "vo_adv_1026010_064"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不好意思～",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "在那之後都沒有人來，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n是發生了什麼事嗎～？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "唔呃",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_065"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "其、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "其實……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你把場地的魔物驅除費省下來了～～～～！？",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_066"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "是、",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_067"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "是的……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那",
        "unit_id": 411,
        "voice": "vo_adv_1026010_068"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我能回到這裡是……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可能是妳運氣好，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_069"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n或是魔物被其他參加者吸引了吧，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "別說這個了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我就知道你會這麼說。",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_070"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要是見死不救，回去也會有罪惡感吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我就跟你一起去搜救吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "小、",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_071"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "小姑娘你們打算去救人嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_072"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "別看我這樣，好歹也是【哞哞自衛隊】的一員，沒事的啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "喔、",
        "unit_id": 1411,
        "voice": "vo_adv_1026010_073"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "喔～～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "那我就安心了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然，",
        "unit_id": 102611,
        "voice": "vo_adv_1026010_074"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我的派駐地點是平靜的【伊麗莎白牧場】，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
