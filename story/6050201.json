    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼短時間內做出這麼多精緻的衣服，",
        "unit_id": 114011,
        "voice": "vo_adv_6050201_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希真的很厲害呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過我稍微想了一下……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這些該不會",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原本全都是想讓我穿的衣服吧……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "到現在我都沒什麼信心，",
        "unit_id": 114011,
        "voice": "vo_adv_6050201_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過既然你這麼說了，我就加油看看吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過這樣……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該不能修行吧？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "身為一個虛幻的女幽靈。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 114011,
        "voice": "vo_adv_6050201_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我覺得茉莉的衣服不適合我喔。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你想看？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好吧，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "既然你這麼說了……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "吼～！",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "像這樣吼叫……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "果然很怪啊！",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要我穿紡希的衣服嗎？",
        "unit_id": 114011,
        "voice": "vo_adv_6050201_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那件我覺得最適合紡希了……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊，不過",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "吸血鬼的形象比較適合戰鬥呢！",
        "unit_id": 114011
    }
