        "voice": "vo_adv_5074322_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n當然不可能被輕易打倒囉。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過很遺憾，",
        "unit_id": 117511,
        "voice": "vo_adv_5074322_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "遇上我是你倒楣。",
