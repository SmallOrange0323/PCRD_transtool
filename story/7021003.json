[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "三個人不斷地與阻擋在前的魔物們戰鬥，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n持續朝著露娜之塔的上方前進。"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呼。",
        "unit_id": 103711,
        "voice": "vo_adv_7021003_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在打倒數量可觀的魔物後，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n戰鬥總算告一個段落了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我是還撐得住……",
        "unit_id": 103711,
        "voice": "vo_adv_7021003_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n趁現在先休息一下也好。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n深月小姐也這麼認為嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為我有點累了，若能稍作休息那就太好了。",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖說在那之後，她就沒有再做出可疑的舉動，",
        "unit_id": 103711,
        "voice": "vo_adv_7021003_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但總覺得不太對勁……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這對有在鍛鍊身體的小智來說，",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "或許是多管閒事，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n就讓我為妳泡杯可以消除疲勞的特調香草茶吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎會是多管閒事呢。",
        "unit_id": 103711,
        "voice": "vo_adv_7021003_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我會滿懷感激地享用的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯，",
        "unit_id": 103711,
        "voice": "vo_adv_7021003_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看來是我想太多了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n真正的壞人是不可能會和{player}成為朋友的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我馬上去做準備，",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "請妳稍待片刻。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好了，",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "請用吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這茶的香氣真的很不一樣呢。",
        "unit_id": 103712,
        "voice": "vo_adv_7021003_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為我用了好幾種藥草去調製。",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，我想應該不至於會太難喝。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼……",
        "unit_id": 103712,
        "voice": "vo_adv_7021003_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我就享用囉。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咕嚕。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103712,
        "voice": "vo_adv_7021003_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "的確，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "喝起來的口感很高雅，與香氣截然不同。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳真的喝下去了呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦！？",
        "unit_id": 103712,
        "voice": "vo_adv_7021003_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "難、",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "難不成妳下了毒！？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒錯，",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這是利用好幾種毒草去調製的",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "特調香草茶。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n好啦，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳應該開始感到體內的力量慢慢地流失殆盡了吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔，",
        "unit_id": 103711,
        "voice": "vo_adv_7021003_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我太大意了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳果然……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "當然沒這回事，",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我是故意嚇妳的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我並沒有下毒。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過這香草茶的確有放鬆的效果。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這、",
        "unit_id": 103711,
        "voice": "vo_adv_7021003_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這是怎麼一回事？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "小智",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "從剛剛就一直",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n對我抱著戒心啊。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不只對魔物，",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是對我也絲毫不敢鬆懈的話，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n妳是撐不了多久的喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103712,
        "voice": "vo_adv_7021003_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳注意到了呢。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那當然。",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我的經驗可不是累積假的喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "對不起，我胡亂懷疑了妳。",
        "unit_id": 103712,
        "voice": "vo_adv_7021003_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳不用道歉。",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這是",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "小智的工作啊。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "況且，",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我說這茶是用了好幾種毒草去調製，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "並不是謊言喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦！？",
        "unit_id": 103712,
        "voice": "vo_adv_7021003_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只要高溫煎炒過，毒性就會揮發掉。",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為我想讓",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你親身體驗一下，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我在塔外曾說過的「是毒是藥皆有用」",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這句話。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "…………",
        "unit_id": 103712,
        "voice": "vo_adv_7021003_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊，",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳臉上的表情還是充滿了不信任感。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "既然如此，這杯茶借給我一下吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咕嚕、",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_030"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咕嚕……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳看，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣多少可以相信我了吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我……",
        "unit_id": 103712,
        "voice": "vo_adv_7021003_031"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒關係。",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_032"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳能稍微相信我就行了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n因為我們",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "現在是",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n一起找尋{player}的記憶線索的夥伴。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103712,
        "voice": "vo_adv_7021003_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是的。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話說回來，",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_034"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "{player}。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n看你一臉也想喝的樣子。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我想也是。",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_035"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我和小智都喝了茶，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "卻只有你\n被排除在外。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "請用。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n就用這個杯子喝吧……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你害羞了嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……呵呵。",
        "unit_id": 103712,
        "voice": "vo_adv_7021003_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我一點也不介意，你就喝吧。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你看，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我剛剛喝的地方",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是這裡喔。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "而我是",
        "unit_id": 105111,
        "voice": "vo_adv_7021003_037"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "從這裡喝的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好啦，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你要從哪邊喝呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在恢復原有表現的智，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n以及還是老樣子的深月的捉弄之下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}朝著塔的上方繼續前進。"
    }
]