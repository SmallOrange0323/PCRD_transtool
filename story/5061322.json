[
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "真的是有夠難纏的傢伙。",
        "unit_id": 7011,
        "voice": "vo_adv_5061322_000"
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "好啊，",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "妾身就親自當妳們的對手吧。",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "\n妳們以為可以輕易打倒我嗎？",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "唔！",
        "unit_id": 116011,
        "voice": "vo_adv_5061322_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好強的氣場……",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這壓迫感可夠我們受了。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n相當麻煩呢。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妳還撐得住嗎？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂喂公主，",
        "unit_id": 115911,
        "voice": "vo_adv_5061322_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳以為是在跟誰說話啊？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們可是不管面對什麼樣的對手，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "都不會退縮的【哞哞自衛隊】耶！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "她",
        "unit_id": 115811,
        "voice": "vo_adv_5061322_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的好強……",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "她看起來更是寂寞的樣子。",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我能明白她的心情。",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為我也常因外表而遭人拒絕。",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，",
        "unit_id": 115811,
        "voice": "vo_adv_5061322_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我被夥伴們拯救了。",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n正因為是這樣的我，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一定可以救得了她……",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我會救她的！　",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我要上囉，公主殿下！",
        "unit_id": 115811,
        "voice": "vo_adv_5061322_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我絕對不會",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "放棄妳的！",
        "unit_id": 115811
    }
]