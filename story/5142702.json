[
    {
        "type": "background",
        "background": "501680"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "行軍訓練的進行處。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在新兵們的奮戰下討伐了大量魔物，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n取回了過去的平靜。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看樣子魔物也減少了很多，",
        "unit_id": 104711,
        "voice": "vo_adv_5142702_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "剩下的只靠我們應該也能處理完。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝妳們，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "惠理子、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真琴。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而且新兵們",
        "unit_id": 104711,
        "voice": "vo_adv_5142702_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也變強了很多，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n能有妳們來擔任教官，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真的是幫了大忙。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我一開始想說",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不曉得會變成怎樣呢～",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不管是被拜託當教官的時候，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還是惠理子進來的時候",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "都是。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過他們",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也成長到可以獨當一面了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n結果應該是很足夠了吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就是說啊。",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哎，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看來該做的事勉強都有做到，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是太好了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵……",
        "unit_id": 104711,
        "voice": "vo_adv_5142702_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可不只是勉強有做到",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這種程度而已呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳們兩位身為教官，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也是很棒的搭檔喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳說搭檔，",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是指我和惠理子嗎？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們不是那麼厲害的關係……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然不知道那樣的稱呼適不適合，",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n但我們確實是要好的朋友呢。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子……",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "畢竟真琴",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "似乎深深地受到我和那位大人之間的情誼所感動，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n還說會全力",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "支持我們呢。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不是，我才沒有這樣說！",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我在妳的心裡到底是什麼樣的人啊！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我就不多過問了。",
        "unit_id": 104711,
        "voice": "vo_adv_5142702_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但妳們兩位的存在",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "給了新兵們很好的影響，這是事實。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "既然要成為騎士團的一員，",
        "unit_id": 104711,
        "voice": "vo_adv_5142702_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "光是鍛鍊自己的身體",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "和磨練技術還不夠。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n作為彼此託付性命的夥伴，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n必須要與周遭的人",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "建立起堅定的信賴關係才行。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "分別擁有不同長處，",
        "unit_id": 104711,
        "voice": "vo_adv_5142702_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "互相彌補不足、挑戰困難……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳們這樣的信賴關係，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對新兵們來說，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n應該也成為了很好的目標吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那種事，",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "確實是如此呢。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "光憑我一個人，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "恐怕沒辦法帶領大家",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n來到這裡吧。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就各方面而言，",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有惠理子來真是幫了大忙。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要說這點的話，",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也是一樣的。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要不是有真琴的幫忙，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我就會過於執著用自己的方式訓練，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n那樣的話是拿不到徽章的吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "關於這點真的完全如妳所說啊……！",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果今後",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還可以繼續獲得真琴的協助，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那就太可靠了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳以後應該也會",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "繼續支持我們的愛吧？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊～",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不是，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "關於這點，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我說實在的……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "說實在的……",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "怎麼？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳果然要阻撓我們嗎？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n難道不只是母狗，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而是會背叛人家的純真之心，私下嘲笑的女狐狸嗎？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒問題！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n總之請讓我當妳的好朋友吧！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻，",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "謝謝妳♪",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還請妳今後",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "都要長久關照囉。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼各位，",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "距離完成任務只差一點了，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n大家一起互相幫助，好好努力吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒錯，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就像我和真琴這樣♪",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "新兵們",
        "words": "是！",
        "unit_id": 1,
        "voice": "vo_adv_5142702_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊真是的，",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼事情會變得這麼複雜啦……！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是因為我嗎？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為我不敢坦白才變成這樣的嗎？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "新兵們跨越訓練，也提升了團結力。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n另一方面，真琴則因為她與惠理子之間神奇的關係似乎還會持續下去，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而抱頭煩惱。"
    }
]