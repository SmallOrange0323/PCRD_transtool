[
    {
        "type": "background",
        "background": "501800"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夢中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}與意識相連的雪菲，\n一同面對米奈娃。"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "──誠如我之前說過的，",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_000"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "{player}。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n你絕對",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "不能真心信任",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "七冠那些人。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "她們那些人",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_001"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "無一例外，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "都是利己主義且傲慢、",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n自私且冷酷。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "而且……",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "無庸置疑的，",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_002"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n就真正意義上來說",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "她們才是萬惡的根源。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為、",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為什麼？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n拉比林斯達小姐和似似花小姐，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n看起來不像是那麼壞的人啊……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "問題",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_004"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "不在於有無惡意。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n行動及結果才是一切。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "你們看看阿斯特朗這個世界。",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_005"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n猶如在悲劇的集合體上",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "覆蓋一層名為無自覺的",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "輕薄假象。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "此等慘況，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "豈是一句「意料之外」就能推諉塞責的？",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "為避免這樣的狀況發生，",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_006"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "七冠──",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "開發者們，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n本應致力於測試和除錯，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "確保安全性萬無一失才是。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n否則，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "打從一開始就不應該開放的。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "也就是說──",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_007"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "倘若七冠",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_008"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "沒有創造出這個世界，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n倘若七冠",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "將這個世界營運得盡善盡美，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n就不會發生",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "「米奈娃的禁錮」，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "也不會衍生出悲劇了。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "因此，",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_009"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "她們是大罪人。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n與草野優衣一樣，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "是該被譴責的",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "萬惡根源。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "……我能理解",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_010"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "你想要袒護她們",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "的心理。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n所以……",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "……若想讓她們的罪過──",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_011"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "這場「禁錮」劃下句點，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "你還是該",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "與厄莉絲和解。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等、",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等一下……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我記得，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n美空",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "曾經說過一件事。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……她說一旦厄莉絲的願望實現，",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個世界",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就會毀滅……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "的確。",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_015"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n關於這點，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "我們必須找出解決對策。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "但真要說起來，",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_016"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "繼續與厄莉絲敵對下去的話，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n即使你們",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "哪天全數陣亡",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "也不足為奇。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "該怎麼做……",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "才好……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "厄莉絲殺了哥哥……",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我實在很難",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "原諒她。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要是跟",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "厄莉絲合作……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n哥哥和大家",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "都能獲救的話……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……{player}。",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你呢？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你覺得",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "該怎麼做才好……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "…………",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_022"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "無須煩惱。",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_023"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n只要你敞開心胸，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "一切都會順利解決的。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "來吧，",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_024"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "握住我的手──",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "這樣啊。",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_025"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "很好……",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "這是很明智的判斷。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "相信你的選擇",
        "unit_id": 191112,
        "voice": "vo_adv_2112007_026"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "肯定會拯救這個世界的。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n來吧，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "握住我的手──",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好的好的～",
        "unit_id": 1,
        "voice": "vo_adv_2112007_027"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "先等一下～",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501820"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_028"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就像似似花小姐的",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_029"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "變身那樣嗎……！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不是喔～",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "剛才跟你們說話的，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n確實是米奈娃本人沒錯。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……更正確地說，",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n是「厄莉絲模擬出來的米奈娃」",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "模、",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_032"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "擬……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "簡單來說，",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就是用「米奈娃的外觀和個性」，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n來說出「厄莉絲的願望」。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "她、",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_034"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "她想藉此，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n來說服{player}跟她和解……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_035"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "迷宮女王──",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_036"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n妳有嚴重的誤解。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為，",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_037"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我體內的米奈娃，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n也希望讓「禁錮」結束。",
        "unit_id": 129012
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "事實上，",
        "unit_id": 191111,
        "voice": "vo_adv_2112007_038"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n如今的狀況，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "對身為世界管理者的我來說，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "並不是我的本意。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n若要以人類的角度來表達的話，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "就是非常地令人不愉快。",
        "unit_id": 191111
    },
    {
        "type": "background",
        "background": "501820"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳是想說，",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_039"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "正因如此米奈娃才會助妳一臂之力是吧。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這顯然就是誤導不是嗎？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_040"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為呢，",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_041"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n妳所謂的結束「禁錮」的方法，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就是將這個世界徹底破壞掉對吧？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是不那麼做，",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_042"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳就無法與他有所連結。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "現在的阿斯特朗是「草野優衣的願望實現後的世界」。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而與米奈娃合而為一的妳，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是這個世界的營運裝置。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "──但是，",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_043"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n七冠所製作出的超級AI，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那個由可可蘿培養起情緒思維的女孩，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "理當不會有毀滅世界",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_044"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這種期望才對。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_045"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "話說回來──",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_046"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真教我",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_047"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "意想不到啊。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "米奈娃",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "竟然會被妳給吸收。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "厄莉絲。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "難怪即便我和似似花再怎麼努力尋找米奈娃，",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_048"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n都只是白費工夫啊──",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我才要告訴妳──",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_049"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n別再胡說八道了，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n迷宮女王。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在「再構築」時，",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_050"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不可或缺的願望核心",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「草野優衣」被奪走，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我正是為了填補那個缺陷才會誕生出來的。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "既然妳知道這一點，",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_051"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n應該不會對我的狀態，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "感到意外才是。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……其實",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_052"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我是在妳出現在",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年他們面前那時候才確定的。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要說為什麼妳會擁有如此驚人的力量，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n唯一的解釋就是妳把米奈娃給收服了。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "擁有",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_053"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "驚人力量的厄莉絲……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "之所以像這樣前來與我們接觸，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n是為了捕捉",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "{player}……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "別擔心。",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_054"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "她現在也並非",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "巔峰狀態。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n真要說起來，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n她其實只有在少年或優衣",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「無法實現願望」的時候才能夠現身。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "尤其在夢裡，",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_055"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "她更是無法多做干涉。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "刻意模擬成米奈娃的樣子",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是最好的證明。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "迷宮女王。",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_056"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "誠如米奈娃的記憶所示……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳是個聒噪的女人。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "無法干涉的人，",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_057"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是妳才對。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我先聲明，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我和妳的力量差距是天差地遠。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要比力量的話，",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_058"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我確實是比較不利。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但我至少",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以防止妳把少年的精神奪走啊。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且啊～？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "既然妳",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_059"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "都稱讚我",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很聒噪了，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那我就再多大吵大鬧一下好了。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦……？",
        "unit_id": 106412,
        "voice": "vo_adv_2112007_060"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "──米奈娃！",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_061"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n聽得到嗎！？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是我啦，",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_062"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "模索路晶！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n總算找到妳了，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好久不見！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_063"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳聽好了，米奈娃！",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_064"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳要堅強起來！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "即便妳本是人工產物！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那也不是問題！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為妳有",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_065"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "從可可蘿身上學得的聰明！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n有從【破曉之星】那裡學得的溫柔！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "應該也記得了",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "{player}所展現出的那種堅強意志",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "才對！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了不要枉費",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_066"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳那顆辛苦養成的心！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n現在不是妳屈就在",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "厄莉絲掌控之下的時候！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "跟我和少年他們一起",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_067"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓「禁錮」劃下句點吧！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n好嗎，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "米奈娃！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_068"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒用的。",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_069"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n米奈娃她，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "聽不到妳的聲音。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "無所謂～",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_070"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不管是不是白費唇舌，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n對患者精神喊話本來就是醫生的基本職責啊。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_071"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我相信米奈娃。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在妳體內的她",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "肯定有在聽。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "她在聽我的，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "以及",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年的心聲。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……笑話。",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_072"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n七冠終究，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也只有這點程度……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "勸妳別小看語言的力量喔，",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_073"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「厄莉絲大人」。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟這個世界",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是用人類最強的工具──",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "語言所構築而成的。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "語言。",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_074"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n0與1。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\nON與OFF。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "既然數位世界裡的存在，",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_075"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "皆是用二進位來呈現，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "為何身為角色的我，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會如此心煩意亂呢──",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這個世界…………",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "厄莉絲。",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_076"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那是因為",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳是草野優衣的……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "──妳果然，",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_077"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有嚴重的誤解。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n迷宮女王。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "方才，",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_078"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳說了，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n「現在的我，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "無法干涉妳們」",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這句話。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n然而──",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "無論，",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_079"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是在夢中，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n還是在保存力量的狀態下，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n妳們的抵抗能力，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對我而言都等同於零。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "──！",
        "unit_id": 106811,
        "voice": "vo_adv_2112007_080"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "執行，",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_081"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "管理者權限。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "命令。",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_082"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n消除掉",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "迷宮女王──",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "──「D型檢體0005b」。",
        "unit_id": 129012,
        "voice": "vo_adv_2112007_083"
    },
