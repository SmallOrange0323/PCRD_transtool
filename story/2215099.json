        "voice": "vo_adv_2215099_060"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "絕對饒不了妳！",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n我一定會殺了妳！！",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n我絕對要殺了妳！！！",
