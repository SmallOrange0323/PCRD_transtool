        "type": "background",
        "background": "502681"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "啊啊啊啊啊啊啊！！！",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_056"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "那算什麼！",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_057"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n那到底算什麼──！",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n就憑妳！？",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "竟然敢自稱女神！！？",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "如果妳是女神……",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_058"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "那麼我們，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "又是為了什麼……！！",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "黎薩、阿爾莎特",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2215099_059"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我絕對──",
