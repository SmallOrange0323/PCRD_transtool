[
    {
        "type": "background",
        "background": "502380"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──吉歐‧格黑納。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在遠離涅妃‧涅羅公主的領土，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n處於雷電交加之地──"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士？",
        "words": "──庫卡卡卡卡……！",
        "unit_id": 136014,
        "voice": "vo_adv_2215099_000"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_001"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "皇家裝備，",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_002"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "「憤怒」……！",
        "unit_id": 193713
    },
    {
        "type": "background",
        "background": "502380"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士？",
        "words": "──！",
        "unit_id": 136014,
        "voice": "vo_adv_2215099_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「──這群",
        "unit_id": 7532,
        "voice": "vo_adv_2215099_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "失敗作──」",
        "unit_id": 7532
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "──！！",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_005"
    },
    {
        "type": "background",
        "background": "502380"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可？",
        "words": "…………",
        "unit_id": 180412,
        "voice": "vo_adv_2215099_006"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "唔……",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_007"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "──冷靜下來。",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_008"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n這連闇影都稱不上，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "不過是幻影罷了。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "既然如此──",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "「復仇的怒吼」──！",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_009"
    },
    {
        "type": "background",
        "background": "502380"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可的幻影",
        "words": "──！",
        "unit_id": 180412,
        "voice": "vo_adv_2215099_010"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "呵。",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_011"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n呵呵呵……♪",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "啊啊──",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_012"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "劍真是輕盈無比。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n如今「憤怒」已完全",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "受控於我的理性之下。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n無論是皇家裝備，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "還是我自身的感情。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "就連那位阿剌克涅女士，",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_013"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "現在也不是我的對手。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n即使真正的尤絲蒂亞娜公主豁出一切，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n將「暴食」發揮到極致，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我也一定能將她斬殺。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "沒錯。",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_014"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我絕不會再讓任何人，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "從我手中奪走任何東西。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "無論",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "對方是誰。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_015"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "話說回來──",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_016"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "這片被稱為「追憶之戰域」的地帶。",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_017"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n正如傳聞所說，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "它會讀取造訪者的記憶，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n並創造出角色的幻影……",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "似乎是這麼回事。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "出現在我眼前的，",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_018"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "盡是些令人不快的面孔。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n我的「姊妹」，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "在這裡是無法重現的嗎……",
        "unit_id": 193713
    },
    {
        "type": "background",
        "background": "502380"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "──還有，",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_019"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "身為這片戰域管理者的「狼」，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "也沒有現身。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n如果剩下的「六凶」",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "有機會成為幻境龍后的阻礙，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n我原本想趁機以實力將其排除。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "哼，算了。",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_020"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "原本就聽說「狼」",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "會避免與他人接觸。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n既然如此，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我也沒有必要去刺激對方。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "直到世界迎來變革前，",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_021"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "乖乖躲在巢穴裡，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n夾著尾巴等著吧──",
        "unit_id": 193713
    },
    {
        "type": "background",
        "background": "502681"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_022"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "歡迎回來，",
        "unit_id": 195214,
        "voice": "vo_adv_2215099_023"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "芙蕾雅。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n皇家裝備的試刀，",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "進行得還順利嗎？",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "是的，",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_024"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "託妳的福。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n已經確認了超乎想像的威力。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n也難怪會被稱之為外掛裝備。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "是嗎，",
        "unit_id": 195214,
        "voice": "vo_adv_2215099_025"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "真是太好了。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "那麼──",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "接下來呢？",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n和妳真正的目標，",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "那位貪吃公主殿下來場復仇戰嗎？",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "是啊。",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_026"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "雖然不知道她到底有什麼打算，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "但我也聽到了可笑的傳聞，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n聽說她在這種節骨眼上，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "居然還在蘭德索爾舉辦博覽會。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "既然如此。",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_027"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n我就在眾目睽睽之下，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "親手斬下她的首級吧。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n作為掀起革命的王族，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "這樣的結局再適合不過了。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "我姑且",
        "unit_id": 195214,
        "voice": "vo_adv_2215099_028"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "還是問一下。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n有什麼我可以幫忙的嗎？",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "聽說薇歐莉特公主，",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "好像也死性不改地在四處亂竄呢。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "不必了。",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_029"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n只要有現在的我",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "和「憤怒」的力量──",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……不。",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_030"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "失禮了。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "果然還是請妳助我一臂之力吧。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "黎薩。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "只要使用妳的咒術",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_031"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "和皇家裝備，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n要在市中心引起混亂應該易如反掌吧。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n為了避免無謂的阻礙，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "希望妳能幫忙採取聲東擊西的行動。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "這點忙，",
        "unit_id": 195214,
        "voice": "vo_adv_2215099_032"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "不過小事一樁。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "……呵呵。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……怎麼了？",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_033"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "對",
        "unit_id": 195214,
        "voice": "vo_adv_2215099_034"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "不起。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n只是有點意外。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "沒想到妳竟然會這麼直率，",
        "unit_id": 195214,
        "voice": "vo_adv_2215099_035"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n又不帶任何算計地來拜託我呢。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "是妳先問我",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_036"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "需不需要幫忙的吧。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "呵呵，",
        "unit_id": 195214,
        "voice": "vo_adv_2215099_037"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "說得也是。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n看妳使用了那麼多次「憤怒」也依然冷靜，",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "這樣我就放心了。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "──是啊。",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_038"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n即使我是複製人，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "不過只要能駕馭「皇家裝備」……",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n我就不需感到自卑、",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "虧欠，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "甚至是憤怒。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我只需要像機器一樣，",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_039"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "保持冷靜。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "將那個給自己冠上女神阿斯特賴亞之名，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n並謊稱是她子孫的可憎一族，",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "徹底抹除就行──",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "──關於那件事，",
        "unit_id": 195611,
        "voice": "vo_adv_2215099_040"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n芙蕾雅……",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "阿爾莎特。",
        "unit_id": 195214,
        "voice": "vo_adv_2215099_041"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n妳什麼時候來的……",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "打從一開始",
        "unit_id": 195611,
        "voice": "vo_adv_2215099_042"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "就在囉？",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "看妳們感情那麼好在打情罵俏的，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n要是打擾到妳們就不好了嘛。",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我們並沒有在",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_043"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "打情罵俏。",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "「那件事」",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "是指什麼？",
        "unit_id": 193713
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "……那個啊。",
        "unit_id": 195611,
        "voice": "vo_adv_2215099_044"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n聽了之後",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "可別生氣喔？",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "我設定為「戀人」",
        "unit_id": 195611,
        "voice": "vo_adv_2215099_045"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "的NPC。",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n被我安排在蘭德索爾潛伏著，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "我透過對方以影像魔法取得情報。",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "然後",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "就像這樣──",
        "unit_id": 195611
    },
    {
        "type": "still",
        "still": "221509901"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是",
        "unit_id": 138311,
        "voice": "vo_adv_2215099_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "尤絲蒂亞娜‧F‧阿斯特賴亞。",
        "unit_id": 138311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n以這個國家的公主之名起誓──",
        "unit_id": 138311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論我所珍愛的人們，",
        "unit_id": 138311,
        "voice": "vo_adv_2215099_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是幸福的餐桌，",
        "unit_id": 138311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這一切……",
        "unit_id": 138311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都由我來守護！",
        "unit_id": 138311
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "──！！！",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_048"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "……這",
        "unit_id": 195214,
        "voice": "vo_adv_2215099_049"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "是……",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "為了守護國民，",
        "unit_id": 195611,
        "voice": "vo_adv_2215099_050"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n因而覺醒了嶄新力量的",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "貪吃佩可。",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "那個模樣",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "簡直就像──",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "簡直就像",
        "unit_id": 195611,
        "voice": "vo_adv_2215099_051"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "女神大人一樣……",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……唔！！！",
        "unit_id": 193713,
        "voice": "vo_adv_2215099_052"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "──終究是失敗作。",
        "unit_id": 1,
        "voice": "vo_adv_2215099_053"
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "\n想重現女神阿斯特賴亞，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "根本是痴人說夢嗎……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "──既然繼承人已經誕生，",
        "unit_id": 1,
        "voice": "vo_adv_2215099_054"
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "奪取皇家的計畫也只能作廢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "\n既然如此，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "讓這些複製人繼續活著只會徒增風險。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "\n全部處分掉吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "──不。",
        "unit_id": 1,
        "voice": "vo_adv_2215099_055"
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "\n不能只是處分，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "至少也要回收一點資金。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "\n讓她們成為電腦化實驗……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "所謂登月計畫的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "研究者",
        "words": "基石吧──",
        "unit_id": 1
    },
