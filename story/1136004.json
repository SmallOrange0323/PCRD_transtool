[
    {
        "type": "background",
        "background": "500950"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "早上，在海邊旅店醒來的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有個罕見的訪客。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗨、",
        "unit_id": 104711,
        "voice": "vo_adv_1136004_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗨，少年……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "身體狀況如何？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 104711,
        "voice": "vo_adv_1136004_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你不用勉強自己起來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n畢竟昨天才發生過那種意外。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你看起來很有精神，",
        "unit_id": 104711,
        "voice": "vo_adv_1136004_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是太好了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我就像你看到的這樣，非常健康。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n畢竟我平時都有在鍛鍊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "重要的是，",
        "unit_id": 104711,
        "voice": "vo_adv_1136004_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那個……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "昨天的事……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "關、",
        "unit_id": 104711,
        "voice": "vo_adv_1136004_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "關於那件事……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那個……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這、",
        "unit_id": 104711,
        "voice": "vo_adv_1136004_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這道光是……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗚！",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你等很久了嗎，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也剛把舞台整理乾淨。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "話說回來，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你可真是幫了大忙呢。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n把舞台",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "換到與平常不同的沙灘上後，",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n超級英雄秀的人手也會不足。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有你加入後，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "感覺氣氛比平時還要更加熱絡呢。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而且，",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你還留下來幫忙撿沙灘上的垃圾……",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這樣真的好嗎？",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝你，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "幫了我一個大忙呢。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為了特地跑來海邊欣賞虎虎英雄秀的孩子們，",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我想盡量讓他們看見美麗的景色。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不光是舞台上的表演。",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我希望能讓",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "今天也變成他們的美好回憶。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我是這麼想的啦……",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好，",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "再撿一下垃圾",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就休息吧。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年？",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嗯……",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你是對那個小孩感到在意嗎？",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n他確實是從剛才就一直看著我們……",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "喔，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他朝這邊走過來了呢。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小弟弟你是怎麼啦？",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "虎虎！",
        "unit_id": 131,
        "voice": "vo_adv_1136004_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "喔，你是說這個面具嗎？",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n對啊。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也是",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "虎虎的粉絲喔。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "是虎虎沒錯，",
        "unit_id": 131,
        "voice": "vo_adv_1136004_016"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "但不是那樣！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎麼啦？",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你不是在說這個面具的事嗎？",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "大姐姐，",
        "unit_id": 131,
        "voice": "vo_adv_1136004_018"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "妳就是真正的虎虎對吧？",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "她就是！",
        "unit_id": 131,
        "voice": "vo_adv_1136004_019"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n我一眼就看出來了！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就、",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就算你那麼說……",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你、",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你看錯囉？",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我並不是虎虎……",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我才沒有看錯！",
        "unit_id": 131,
        "voice": "vo_adv_1136004_022"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "妳就是虎虎！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他應該不是隨便說說，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而是有他自己的根據吧……",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只要看著他耿直的眼神就能明白。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我或許可以編個謊話來蒙混過關。",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是……",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "妳是虎虎對吧？",
        "unit_id": 131,
        "voice": "vo_adv_1136004_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看著這孩子耿直的眼神，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "讓我很想坦然承認。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……我想當個能坦白的人。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n尤其",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是在他的面前……",
        "unit_id": 113631
    },
    {
        "type": "still",
        "still": "113600401"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你可以靠過來一點嗎？",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_027"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "咦？",
        "unit_id": 131,
        "voice": "vo_adv_1136004_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "事情確實",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就是你說的那樣。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "果然！",
        "unit_id": 131,
        "voice": "vo_adv_1136004_030"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "大姐姐就是虎虎！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "虎虎的真面目",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "必須保密才行。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你能明白嗎？",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "咦～？",
        "unit_id": 131,
        "voice": "vo_adv_1136004_032"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "不能跟朋友講嗎？",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "噓……！",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小聲點。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n搞不好有壞蛋正在偷聽我們說話。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "對、",
        "unit_id": 131,
        "voice": "vo_adv_1136004_034"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "對喔！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n要是被壞蛋知道就糟糕了！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒錯。",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "英雄必須隱藏真面目才行。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為了實現正義，",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你可以一起保守祕密嗎？",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我知道了！",
        "unit_id": 131,
        "voice": "vo_adv_1136004_037"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "虎虎！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n這全都是",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "為了實現正義對吧！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒錯。",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是你跟虎虎之間的約定。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗯！",
        "unit_id": 131,
        "voice": "vo_adv_1136004_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那好，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們來打勾勾。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "哇～！",
        "unit_id": 131,
        "voice": "vo_adv_1136004_041"
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "要加油喔～！",
        "unit_id": 131,
        "voice": "vo_adv_1136004_042"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n掰掰～！！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝。",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n天氣很熱，要小心別中暑囉！",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年，",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你怎麼了嗎？",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還好啦……",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就像我剛才說過的，",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不光是表演，",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我希望今天",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n能成為他",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "美好的回憶。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是嗎？",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_046"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n有人",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "像那樣相信自己，",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n確實是英雄最大的幸福。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可是，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_047"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為什麼會被注意到呢……",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這面具也是一般店面有在賣的東西……",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年知道原因嗎？",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那、",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_048"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那算什麼回答嘛……",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過，",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵……",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "被你稱讚的感覺",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還不差。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n謝謝你。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好，",
        "unit_id": 113631,
        "voice": "vo_adv_1136004_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "把剩下的垃圾撿一撿後，",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就在海邊玩吧。",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你當然",
        "unit_id": 113631
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "會陪我對吧？",
        "unit_id": 113631
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1136004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "每次都會見到我，所以你應該已經知道了，",
        "unit_id": 190011,
        "voice": "vo_adv_1136004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你剛才看到的光景就像是在做夢一樣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話又說回來，真是叫人吃驚呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1136004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n純居然連換上泳裝都要戴面具。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但比起面具，只要看到那個英姿煥發的模樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1136004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n熟悉的人就會馬上認出她是英雄。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "本人不是刻意做的，所以似乎沒有自覺。",
        "unit_id": 190011,
        "voice": "vo_adv_1136004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但她肯定天生就是個英雄。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，那部分的祕密就由你小心替她掩護了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正因為是平時負責保護大家的英雄，",
        "unit_id": 190011,
        "voice": "vo_adv_1136004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n才會需要有個人來保護她。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且，",
        "unit_id": 190011,
        "voice": "vo_adv_1136004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能辦到那件事的人就只有你而已哦。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500950"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……",
        "unit_id": 104711,
        "voice": "vo_adv_1136004_057"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我不小心睡著了嗎……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年也睡著了嗎？",
        "unit_id": 104711,
        "voice": "vo_adv_1136004_058"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但畢竟",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "時間也還很早，這也沒辦法呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "然後，",
        "unit_id": 104711,
        "voice": "vo_adv_1136004_059"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我想說……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "關於昨天的泳裝跟",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我的長相……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是啊，",
        "unit_id": 104711,
        "voice": "vo_adv_1136004_060"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "希望你能為我保密。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只是，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "難得有這個機會……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可以請你",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "再稍微陪著我的祕密嗎？",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "500164"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 113611,
        "voice": "vo_adv_1136004_061"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "果然這個時間點幾乎沒有什麼人呢。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然對小咲戀他們不好意思，",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就讓我們兩人獨占沙灘吧。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在其他人蜂擁而至之前，",
        "unit_id": 113611,
        "voice": "vo_adv_1136004_062"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只有段短暫的時間……",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以在那之前，我想做一些有假期感的事。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呼……",
        "unit_id": 113611,
        "voice": "vo_adv_1136004_063"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "直接用肌膚感受海風的感覺，",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我還不習慣啊。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……喂、",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "喂。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "別那麼一直盯著看……",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎麼？",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……你是在意這套泳裝嗎？",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我原本確實是",
        "unit_id": 113611,
        "voice": "vo_adv_1136004_064"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "打算一直穿著鎧甲……",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "畢竟是要來海邊。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以我",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "姑且是有帶泳裝來啦。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……想像能以這種方式",
        "unit_id": 113611,
        "voice": "vo_adv_1136004_065"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "度假的念頭，",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我倒也不是不曾有過。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過……",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我只想在你面前做……",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝、",
        "unit_id": 113611,
        "voice": "vo_adv_1136004_066"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝你……",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我總覺得你比平時",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "更加可靠呢。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "會對我說這種話的人，",
        "unit_id": 113611,
        "voice": "vo_adv_1136004_067"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就只有你而已。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n現在就",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "讓我坦率地接受你的好意吧。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "感覺就像是",
        "unit_id": 113611,
        "voice": "vo_adv_1136004_068"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "自己成了公主一樣……",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呃，",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不……",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒什麼。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你、",
        "unit_id": 113611,
        "voice": "vo_adv_1136004_069"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你不要一直盯著我看啦。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那樣很難為情……",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是的。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在兩人獨處的沙灘上，安靜得只剩下海浪聲。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而{player}與純的夏天，才正要開始。"
    }
