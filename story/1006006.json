    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與茜里約好一起去購物。"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥真早呢？",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "等很久了嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "才剛到……？",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那就好。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼我們去買東西吧。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你問我這次要買什麼嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n嗯～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "到我們到了就知道喔。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "商店在這邊喔。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿～",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里第一次跟哥哥做這樣的事呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "總覺得不停地心跳加速。",
        "unit_id": 100611
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，看到那家店了。",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n在這邊。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是喔，這是內衣店喔。",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "前不久茜里最喜歡的內褲破了，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n所以想說要去買新的～。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "難得要買新內褲，",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n就想說要買哥哥喜歡的類型。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "請多多提供意見喔。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸？這裡確實專賣女用內衣褲……",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但是跟我一起的話，哥哥也可以進去喔。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好啦好啦，茜里也想聽聽哥哥的意見，",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就不用太在意啦。",
        "unit_id": 100611
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇！有很多種呢～",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這件透明透明的內褲，",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥不覺得很可愛嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "還是",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這件很像繩子的內褲，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n才符合哥哥的喜好呢～？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥，哪件內褲好呢？",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "兩種都太暴露……？",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "才沒這種事。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因為這是茜里的幸運內褲嘛～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "難得能聽聽哥哥的喜好，",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里要買一條最厲害的幸運內褲喔。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼，哥哥！",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這件透明內褲跟繩子內褲，你喜歡哪件呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "要讓茜里穿這件透明內褲，",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥這色狼～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "能體會這種若隱若現的美，",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥還真是老饕呢……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘻嘻，開玩笑的啦。",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因為是哥哥幫茜里選的，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我馬上就來試穿囉。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果不看一下穿起來的樣子，",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_019"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n也不知道怎麼樣。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "等我換好之後，哥哥再給點意見喔。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "女顧客１",
        "words": "呀——！",
        "unit_id": 1211,
        "voice": "vo_adv_1006006_020"
    },
    {
        "type": "dialogue",
        "name": "女顧客１",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客１",
        "words": "為什麼會有男人在這店裡！？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客１",
        "words": "\n該不會是變態！？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客２",
        "words": "這是女人的敵人啊！",
        "unit_id": 411,
        "voice": "vo_adv_1006006_021"
    },
    {
        "type": "dialogue",
        "name": "女顧客２",
        "words": "\n來人啊！快去聯絡【哞哞自衛隊】——！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥，茜里試穿好了喔～",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_022"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "果然只有哥哥幫我挑的最適合…",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "…",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦、咦？哥哥……？",
        "unit_id": 100611,
        "voice": "vo_adv_1006006_023"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥跑去哪裡了呢～？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}的身影已不見蹤跡，\n購物也就此中斷了。"
    }
]