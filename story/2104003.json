        "voice": "vo_adv_2104003_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "了啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n該怎麼說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就是知道。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "剛剛在教室中",
