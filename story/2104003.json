        "name": "凱留",
        "words": "我到底是",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼了呀。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼會",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這麼……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……為什麼……",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "內心會這麼的煩躁呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我以前在這種地方遇到過什麼不好的事嗎……？　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不，",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才沒有那種事呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n畢竟說到底，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我根本就沒有",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "上過學才對。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……應該沒有吧……？　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔……",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……總覺得",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好不舒服……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……\n……",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……還是回家吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一直像這樣待在這，",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不是辦法嘛。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……唉……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "——小凱留！",
        "unit_id": 105812,
        "voice": "vo_adv_2104003_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可……",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……抱歉。",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳明明說這是公務，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "卻被我搞得一團亂了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n之後看是要殺要剮我都隨便妳了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我才不會",
        "unit_id": 105812,
        "voice": "vo_adv_2104003_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "做那種事情啦……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……比起這個……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要不要和我一起",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "回教室呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我說呀。",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳也看到了吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "剛剛我的表現。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我好像，",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒辦法",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應付這種事情呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n被大家關注，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "引起騷動，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被誰搭話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n然後我一失控，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就做出脫軌的行徑，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最後讓所有人傻眼……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是哪裡不對呢……",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽起來有點莫名其妙，",
