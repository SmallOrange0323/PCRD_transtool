    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但連自己都不懂為什麼會這樣。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……抱歉。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我還是、",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "回家好了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很抱歉啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等一下！",
