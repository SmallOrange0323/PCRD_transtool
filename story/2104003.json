        "voice": "vo_adv_2104003_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，{player}☆",
        "unit_id": 105812,
        "voice": "vo_adv_2104003_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}……",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的☆",
        "unit_id": 105812,
        "voice": "vo_adv_2104003_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那我們就回去吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_2104003_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "準備？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……咦、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來吧，",
