    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後被人指指點點。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就像看到了臭掉的垃圾一樣，",
        "unit_id": 106012
