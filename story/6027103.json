    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "幫派的工作嗎？",
        "unit_id": 106611,
        "voice": "vo_adv_6027103_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "問得很好！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我可是家族的高級幹部祈梨大人！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你想問什麼就問吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要我出手，",
        "unit_id": 106611,
        "voice": "vo_adv_6027103_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不管什麼工作都輕而易舉！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "再拿更大一點的工作來吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我要變成大人物，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "把欠款什麼的都一筆勾銷！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯，",
        "unit_id": 106611,
        "voice": "vo_adv_6027103_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有嘉夜夜在，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而且手下也都是一些不錯的傢伙。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我想我應該有混幫派的天分！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n如果是小哥你的話",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也可以收你當小弟喔。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "感覺老大派給我的工作，",
        "unit_id": 106611,
        "voice": "vo_adv_6027103_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好像都只有簡單的工作。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……總覺得有種不被信任的感覺，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "心裡有點悶悶的。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "開、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "開玩笑的，開玩笑的啦！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "重要的工作",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也有好好在做！",
        "unit_id": 106611
