[
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "完成繁忙工作的諾維姆和尾狗刀，終於回到了城鎮。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "唉……",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "呼……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "今天、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "真的……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "有、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "累到……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "說得沒錯，",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_001"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "被使喚來使喚去的，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真的很累……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不過，",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_002"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這是為了恢復我們的自由之身。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n為了自由，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這一切都不算什麼！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆，",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_003"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳真了不起，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "能麻煩妳連我的份也一起努力嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "開什麼玩笑！",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_004"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "肉體勞動你幾乎",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "都推給我了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n你負責動腦是沒關係，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "但偶爾也動動手好嗎！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "開玩笑的，",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_005"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我也開始",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "想念自由了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n該認真工作的時候，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我不會馬虎的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "……真的拜託你說到做到喔？",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_006"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "話說，",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_007"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "恢復自由之後你想做什麼？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n我有很多想試試看的事情就是了。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳也太心急了吧。",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "現在說這個，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不覺得還太早了嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "才沒這回事！",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_009"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "有目標",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "才會有動力想去達成吧？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "……不過說歸說，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我們的目標，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "也只有一個而已，是吧！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_010"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "是這樣嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你明明就知道還裝傻，",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_011"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "真的",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "很壞心眼耶！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n就是之前跟你講過的那個啊！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "來嘛，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你說說看！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我那時候是有點被沖昏頭了。",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_012"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n拜託饒了我吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "尾狗刀！",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_013"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……唉，",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_014"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "別用那種眼神看我嘛。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "「我們要成為世界上最壞的人」。",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_015"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這樣可以了嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "沒錯！",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_016"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這樣",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "明天又能繼續努力了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真是單純啊。",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_017"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我也有點想學學",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳那種純粹的個性。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳那率直",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "又堅定的心，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "一定能在未來開拓出活路的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "尾狗刀在心裡暗自讚賞著。"
    }
]