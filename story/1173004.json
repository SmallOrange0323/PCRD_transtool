[
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌跟{player}順利脫離孤島，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n平安回到沙灘上。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "終於回來了呢。",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我一時之間還擔心得不知所措，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但現在總算是放心了。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "原本那麼熱鬧的沙灘",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n也已經變得靜悄悄的了。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這也是理所當然的。",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "畢竟",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "太陽也已經下山了。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "牽著手在沙灘上散步，",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一起打倒魔物，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在孤島上體驗短暫的野外求生。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n今天發生了很多事呢……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然是難忘的一天，",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但難得來到夏日的海邊，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我很想再多做些",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "普通情侶會做的事情……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "或許吧。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唉呀，",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天的我",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "果然",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很大膽……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天真的是",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "非常感謝你。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我們差不多該回旅館了──",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦，",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "月光",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有這麼亮嗎……？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "越來越耀眼了……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呀啊！",
        "unit_id": 117311
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}，你好。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……那個，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你還好嗎？",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你看起來有點累。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "原來如此……",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我自己也差不多。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我每天",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都為了暑假後的大賽在上課。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "當我稍微有空時，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "又是打個工就結束一天了。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大賽要比的曲子一直演奏不好，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓我很煩惱……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "明明暑假也快要結束了，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我卻一直處於低潮。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "感覺",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都沒有體驗到夏日風情呢。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只不過我",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就算不忙，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也跟所謂「夏日娛樂！」",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "之類的毫無緣分就是了。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我甚至想不起",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我最後一次去海邊或游泳池，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n是何時的事情了。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然我早就放棄去想，",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但無法享受季節風情",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "似乎也有些寂寞。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是、",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是沒關係，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但我沒有太多時間，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以也不太有辦法",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "出遠門之類……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "附近的祭典也",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "早就結束了，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "剩下還有什麼是充滿夏日風情的……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "煙火……",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "煙火很棒呢。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果是晚上的話，我應該抽得出時間。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵，",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我好久沒玩煙火了，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以有點期待。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可以嗎？",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我會期待的。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他要準備煙火的話，",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我要怎麼辦呢。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對了，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我至少穿個浴衣，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "展現點夏日風情吧。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "得馬上回家找出來才行。",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "希望還穿得下……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯……",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我選這個。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好的，",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "麻煩你了……",
        "unit_id": 104231
    },
    {
        "type": "still",
        "still": "117300401"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哇，",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好漂亮！",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "點亮夜晚的火花……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真的很美呢。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊哈哈，",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "氣勢好驚人！",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然有點可怕，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但好像很好玩呢。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦，",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你有珍藏的煙火嗎？",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但這是……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "蛇炮對吧！",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊哈哈哈！",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總覺得",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好好笑呢，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這個蛇炮。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊，",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我好像",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很久沒有",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "笑得這麼開心了。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n來自大賽的煩惱，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不知道跑哪去了。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我好久沒有像這樣",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "正經地享受夏天了……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這比我想像中的",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還要快樂很多……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真想",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "跟他一起享受",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "各式各樣的事情……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_029"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天很謝謝你邀請我。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n能看到漂亮的煙火，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我心情輕鬆多了。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_030"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "原來你也會",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "說客套話呢。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不是客套話？",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n那個……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你的誇獎。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "穿、",
        "unit_id": 104231,
        "voice": "vo_adv_1173004_031"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "穿浴衣就行的話，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我會再穿的。",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以明年也再一起玩煙火……",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n不，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "除了煙火之外，",
        "unit_id": 104231
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們也盡情享受各式各樣的夏日風情吧！",
        "unit_id": 104231
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好～",
        "unit_id": 190011,
        "voice": "vo_adv_1173004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "居然在夏天的尾聲用煙火創造回憶，",
        "unit_id": 190011,
        "voice": "vo_adv_1173004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就你來說，還挺機靈的嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這種回憶",
        "unit_id": 190011,
        "voice": "vo_adv_1173004_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很棒呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "既青春又十分美好！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這邊發生太多事情，",
        "unit_id": 190011,
        "voice": "vo_adv_1173004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "導致我偶爾會快要忘記，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但你是學生對吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "學生時代的事就只有現在才能做，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以你可不要讓自己後悔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "尤其像千歌這種認真的女孩子",
        "unit_id": 190011,
        "voice": "vo_adv_1173004_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "似乎不擅長主動去玩樂，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以就算有點強硬，你也要拉她一把喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "千歌也是普通的女孩子。",
        "unit_id": 190011,
        "voice": "vo_adv_1173004_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是快樂的事情，她就會覺得快樂，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n對她來說，那些事都會成為寶貴的回憶。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，今天就聊到這吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1173004_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你接下來也好好享受夏天♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯……",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_039"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不小心睡著了嗎……？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n是今天發生太多事情，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "累積了不少疲勞嗎。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_040"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我做了個好夢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n是跟你一起玩煙火的夢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "夢裡的我真的好開心……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_041"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你也做了相同的夢？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總覺得既開心又難為情，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這種感覺真奇妙……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是，",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_042"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "看到夢裡的我玩得那麼開心，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n讓我現在也",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "想試著玩煙火看看。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "話雖如此，",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_043"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在店家大概也已經關門了，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不可能買到煙火對吧。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊，",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_044"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他無論做什麼都竭盡全力……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這點非常帥氣，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "非常耀眼……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是，",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_045"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我不可以老是向他撒嬌對吧。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為了能抬頭挺胸",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "待在你的身邊，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我也必須要改變才行。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請等一下。",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_046"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你不可以一個人去找。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我也要一起去。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就算沒買到煙火也沒關係。",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_047"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n夏天",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "明年也會再來。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以──",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "未來也都和我，",
        "unit_id": 117311,
        "voice": "vo_adv_1173004_048"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一起享受夏天吧！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "全力度過夏日某一天的千歌，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再次於成長的路上邁出了一大步。"
    }
]