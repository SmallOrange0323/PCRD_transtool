        "name": "真琴",
        "words": "北方森林……！？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "？",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_073"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有什麼問題嗎？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……棲息在北方森林的魔物，",
        "unit_id": 129811,
        "voice": "vo_adv_5142005_074"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "強度和其他區域的魔物是天差地遠。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n聽其他教官說，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "似乎是最近才開始棲息在那附近的。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "事前說明時不是也有講了嗎？",
        "unit_id": 129811,
        "voice": "vo_adv_5142005_075"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n騎士團說",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "「不要走出區域外」。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是新兵遇到了那邊的魔物……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可不堪一擊啊。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "騙、",
        "unit_id": 711,
        "voice": "vo_adv_5142005_076"
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "騙人的吧……？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "\n那麼",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "弗萊迪他……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_077"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們出發",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "去救援吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等、",
        "unit_id": 129811,
        "voice": "vo_adv_5142005_078"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等等！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "怎麼了嗎，",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_079"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真琴？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳真的",
        "unit_id": 129811,
        "voice": "vo_adv_5142005_080"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要自己去救人嗎……？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果教官出手協助訓練──",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "──就會沒辦法",
        "unit_id": 129811,
        "voice": "vo_adv_5142005_081"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "獲得勳章喔？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "！！",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_082"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……要不然",
        "unit_id": 129811,
        "voice": "vo_adv_5142005_083"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我一個人去救他也可以。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n畢竟我也不需要什麼勳章。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但妳不同……",
        "unit_id": 129811,
        "voice": "vo_adv_5142005_084"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳是為了勳章而成為教官的不是嗎？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳說的……",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_085"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是沒錯……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了這位大人，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "什麼事……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我都會去做。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，",
        "unit_id": 129811,
        "voice": "vo_adv_5142005_086"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我知道。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也很清楚妳是認真的。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n所以才會問妳。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "…………",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_087"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……果然",
        "unit_id": 129811,
        "voice": "vo_adv_5142005_088"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還是我一個人去吧？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那、",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_089"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那樣子……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "可是……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n唔",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦……？",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_090"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n{player}大人……？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}、",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_091"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_092"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……唔。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_093"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "說的沒錯……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n如果是您，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "當然會這樣說呢……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……真是抱歉。",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_094"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n身為您的伴侶，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我很慚愧沒能立刻做出回答。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人。",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_095"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "想去救新兵。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "所以……",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_096"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "拜託您了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n請您跟我一起去……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "由我和您合力",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "去拯救新兵吧！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂喂，",
        "unit_id": 129811,
        "voice": "vo_adv_5142005_097"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "別忘了我啦。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們一起去吧，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真琴……",
        "unit_id": 129911,
        "voice": "vo_adv_5142005_098"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "謝謝妳。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼我們",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "趕緊出發──！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "面對身陷危機的新兵，惠理子放棄了徽章。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她與{player}和真琴一起"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n直奔北方森林。"
    }
]