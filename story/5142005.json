        "type": "dialogue",
        "name": "真琴",
        "words": "不過",
        "unit_id": 129811,
        "voice": "vo_adv_5142005_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我不是開玩笑的，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "現在看來真的有機會……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可以獲頒勳章呢。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻，",
