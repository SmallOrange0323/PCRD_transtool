    {
        "type": "dialogue",
        "name": "旁白",
        "words": "王都‧蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有一位少女佇立在熙來攘往的街道旁。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從遠離蘭德索爾之地──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "佐賀而來，\n為了成為揚名立萬的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一位偶像。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她的名字是──"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我是櫻！",
        "unit_id": 136111,
        "voice": "vo_adv_4014001_000"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我在遠離蘭德索爾，",
