        "voice": "vo_adv_4014001_001"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "名為佐賀的地方出生，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "享年17歲。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "雖然平常有點沒用，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "有時候會覺得自己是不是很倒霉。",
        "unit_id": 136111
