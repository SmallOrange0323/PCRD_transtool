    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "……但是現在！　",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我是偶像團體──",
        "unit_id": 136111,
        "voice": "vo_adv_4014001_002"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "法蘭秀秀的一員！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "雖然因為製作人的指示，",
        "unit_id": 136111,
        "voice": "vo_adv_4014001_003"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "突然要進行",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "個人活動，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "但總會有辦法的！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "因為以前的我",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "和現在的我已經不一樣了！",
