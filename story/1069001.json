[
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某日，{player}在貪吃佩可的請託下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到王城要與被關押中的霸瞳皇帝見面。"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還想說是誰會來見我呢……",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_000"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你們幾個找我有事？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原本……",
        "unit_id": 107111,
        "voice": "vo_adv_1069001_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "應該是有的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要是早知道你成了一具行屍走肉，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們就不必特地跑這一趟了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "陛下。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真想不到你的眼神會變得如此失意。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我本來也有事情想問你，",
        "unit_id": 107011,
        "voice": "vo_adv_1069001_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但看來你應該是不會回答了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你這有氣無力的音色",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "已經說明了一切。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "隨便你們",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_003"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "怎麼想。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n如果是要問",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "「這個世界不會結束」的原因，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n大可不必心急，時候到了你們自然會知道。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們遲早會知道",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_004"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "「那個理由」是什麼貨色。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只是不需讓我多費唇舌而已……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不愧是陛下。",
        "unit_id": 107111,
        "voice": "vo_adv_1069001_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n即便成了階下囚，你那神機妙算的洞察力依然健在。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不費吹灰之力",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就看穿我們此行的目的是嗎。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳也太小瞧我了吧，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_006"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "克莉絲？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如果只是來確認結果，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳早該明白這只是浪費時間不是嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你不也一樣嗎，",
        "unit_id": 107011,
        "voice": "vo_adv_1069001_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真那？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "彼此互相揣測對方的想法，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然後實證自己推導出來的假說，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "最終會以這樣的結果作收，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這點我們當然心知肚明。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "之所以非得不辭辛勞地跑這一趟，",
        "unit_id": 107111,
        "voice": "vo_adv_1069001_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可以說是基於同為七冠的情誼吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聽說我們",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "曾經是夥伴不是嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……無聊透頂。",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111,
        "voice": "vo_adv_1069001_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也有一部分是因為真正的「陛下」，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n拜託我們陪這小子一起來啦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們是為防萬一而湊成的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "世界最頂尖的",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "護衛喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然連接著魔力吸取裝置，",
        "unit_id": 107011,
        "voice": "vo_adv_1069001_011"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但正牌的尤絲蒂亞娜，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n對你還是充滿了戒心。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哼，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_012"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "盡耍些小聰明……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n那位公主殿下",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還沒搞懂",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "根本不會發生任何萬一呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……不多說了，",
        "unit_id": 107111,
        "voice": "vo_adv_1069001_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們先走一步。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n看來那個小姑娘的擔憂是多餘的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯。",
        "unit_id": 107011,
        "voice": "vo_adv_1069001_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再跟他多說什麼也不會有交集。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "克莉絲跟我就先告退了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "之後見。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再會囉，陛下！",
        "unit_id": 107111,
        "voice": "vo_adv_1069001_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "下次見面時……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個嘛，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n應該會是在一場",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真正顛覆世界的激戰之中吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……在那之前",
        "unit_id": 107111,
        "voice": "vo_adv_1069001_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你可要保重身體喔？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "反正只要我待在這裡，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_017"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "根本不可能發生意外……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我跟克莉絲不一樣，",
        "unit_id": 107011,
        "voice": "vo_adv_1069001_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對你並沒有深厚的感情，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "即便如此，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我似乎還是感到些許遺憾。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你豈止是拒絕對話，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "甚至不想活──",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "──似似花……",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_019"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "快給我閉上妳的嘴。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我會的。",
        "unit_id": 107011,
        "voice": "vo_adv_1069001_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對於一個碰到死路就止步的人，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我已經無話可說了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再見，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真那。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_021"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "總算滾出去了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "所以呢？",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_022"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你單獨留下來，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n是想對我",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這個可憐的俘虜做什麼？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……什麼東西？",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_023"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……這是在我的預料之中，最無聊到沒有下限的。",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_024"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我才不要",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那種東西。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "凱留……",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_025"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我原以為她只是找到新的靠山而背叛我，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n現在她還要來施捨我？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "看來從你們戰勝的那一刻起，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "她就把我當作寵物一般看待了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不單是把可笑的變心結果",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_026"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "具體製作出來，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n甚至還由你送來給我，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒有比這更諷刺的事了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如果真覺得那麼愧對我，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_027"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "當初別背叛不就好了？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是個",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "愚蠢的孩子。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這個世界為什麼依然卡在無聊的停滯狀態，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_028"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n一看到你我就明白了……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "醜話說在前頭，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_029"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我沒打算實現你和",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那位公主殿下的願望。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那不然我幫你說怎麼樣？",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_030"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n還是你想自己說？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如果可以的話，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你也想──",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……這一點我敬謝不敏。",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我可不想淪落到那種下場……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不說我被囚禁在這一成不變的時間中，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_032"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你自己又如何？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "看你這樣子，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_033"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是被公主殿下搶走功績，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n每天都只是在一成不變的世界裡過著百無聊賴的日常生活對吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "堂堂的弒神英雄，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_034"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "會滿足於這樣的結果？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_035"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "身為神的我被你給殺了……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那就等同我死了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n看我這副狼狽樣就知道了吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "從你的立場來看，這是理所當然的結果吧。",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_036"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你那既非憐憫又非輕蔑的眼神，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "讓我感到無比屈辱。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我曾經",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_037"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "打碎你的靈魂……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "曾殺過你一次的人就是我。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你應該不會毫無感覺吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "其實",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_038"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你想要盡情傷害我……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是想殺了我。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你心底深處，藏著這樣的情緒對吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……詭辯之詞。",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_039"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "即使你「現在」不想殺我，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n可當初對戰時卻不是這麼回事吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "看我折磨凱留、",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n傷害你的夥伴，讓你覺得我不可原諒不是嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊哈哈哈！",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_040"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你說這什麼蹩腳的謊話！",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n一個從死亡深淵復活過來的人，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不可能會沒有注意到！",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……別自欺欺人了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "即便你是個與我們七冠全然相悖、",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_041"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只憑著一股利他精神而活的人，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還是無法不對威脅到自己性命的存在感到恐懼與憤怒……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "想要擺脫那種情緒，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_042"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "唯有消除其情緒根源。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那麼，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "方法就只有一種了吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你無法拯救我。",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_043"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我也不想被你拯救。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我們之間不可能有連結。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我們是無法相互理解的。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我對你",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_044"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "已經是好話說盡……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不是現在這個你，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而是過去那個不論打倒幾次都會再出現的你。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……我已經厭倦了。",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_045"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在這個可能性受限的停滯世界裡，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n持續觀測那些一成不變的答案，究竟是何等的空虛啊……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就算來到這裡，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_046"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也不會有任何改變。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "用你的劍刺穿我，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n然後帶著那個連當供品都不夠格的瑕疵品回去吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "包庇一個會背叛別人的瑕疵品，你可真了不起啊？",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_047"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n因為是對你們表達善意，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "所以你就認同那孩子的背叛行為？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "到頭來，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_048"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你也是個只能獨善其身的人。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你要知道，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你所認為的救濟",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並不是所有人都認同的普世價值。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我討厭接納別人的想法，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_049"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "尤其是",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你和那孩子。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你想幫助我？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那種自以為是的行為我絕對不會接受。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如果你真的非得要我聽話，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_050"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n那就用諾維姆的力量洗腦我，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "把我變成一個言聽計從的傀儡吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "可你也只能使用那種手段。",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_051"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "認清現實點？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n盡情體驗這個悲慘結局，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "然後陷入瘋狂吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這個遊戲既不能進行下去又不能退出……",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_052"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只能反覆回到同一個存檔點，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "眼看故事停滯不前……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那就是我得到的東西。",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_053"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n是我排除了包括你和晶在內的一切障礙，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n費盡心力才抵達的旅程終點……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……哎呀，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_054"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "把你被我傷害的過程講得如此冠冕堂皇，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n應該讓你",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "很不爽吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……請你不要妄想連我都籠絡好嗎？",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_055"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你我這種身處天秤兩端的人，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n無論如何都無法完全壓抑對彼此的厭惡感。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "水和油攪拌後只會形成泛著大理石紋理的液體，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_056"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n不明就裡的蠢蛋會看著此景洋洋得意以為油水相溶了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n而你就是這個蠢蛋。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不懂得活用過去積累的知識，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_057"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "凡事以想法和情感為優先。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "認為這樣可以拯救他人，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "自以為真的拯救了他人……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這種行為，我打從心底感到礙眼。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_058"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我已經厭倦了想方設法去打擊你們的反抗意志，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n也已經無話可說，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "更不想聽你們說話了……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊啊，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只有一件事。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "有一件事我要跟你說清楚。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不可以讓拒絕相互理解的對象活下去。",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_059"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n世界上，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只能存在一種",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "基準或主張。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "即便你私心想要認同我，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_060"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但你的夥伴們能容忍這件事嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n肯定不能。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "所以，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你能夠給我的施捨就只有一種：",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n讓我",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "從這個世上消失。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "一開始",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_061"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我設法消滅你的時候，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也是很樂在其中呢……♪",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n看你和那些拚死抵抗的夥伴們一起，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n跪倒在我的壓倒性力量之前，那種表情真是美妙無比啊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若是回憶不起來，你就想像看看……",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_062"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "熊熊燃燒的街道上，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "看我愚弄你那些筋疲力盡的夥伴，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n一次又一次、一次又一次、一次又一次……！",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "很想阻止我吧？",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_063"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你卻做不到……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "為什麼呢？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……因為你想要幫助我啊。",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_064"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只因為僅僅一次的奇蹟發生，讓你苟活下來，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你就萌生出如此天真的想法。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "再說，不光是你的夥伴。",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_065"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "其他那些遭受牽連的人呢？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "肯定有許許多多的人都對我",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "恨之入骨。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n不僅止於阿斯特朗，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "現實世界裡也一樣。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "一旦得知真相，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_066"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "肯定會有人想直接對我宣洩恨意。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你又有什麼權利",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "去制止他們？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只要我這個存在沒有完全消失，就會有人因此而受罪，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_067"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n那麼你要怎麼幫助我？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還是說",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你任何一方都不想放棄？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……說穿了，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你就是個傲慢的人。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你的一念之私",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_068"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "會使所有人類受苦，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這樣你還要讓我活著？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "明明就沒有那麼偉大，還裝作一副代表全人類的模樣，你可真行啊！",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你確實",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "已經失敗過一次了不是嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這樣的人能博得誰的信任？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……請不要用我給予的選項外的答案來搪塞。",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_069"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "把我這番話",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也說給你的夥伴們聽聽。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n會跟你說出同樣答案的人，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "肯定……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "少之又少。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……光是欺負你我也厭了，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_070"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你回去吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你只會一直逃避問題，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真無趣。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "下一次……",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_071"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "有了，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "等到世界毀滅、",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "一切又從頭來過的時候，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我們再會吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n盡可能垂死掙扎吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_072"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……你還是，",
        "unit_id": 106911,
        "voice": "vo_adv_1069001_073"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不肯放棄呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "霸瞳皇帝細聲吐露出的這句話，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並沒有傳入{player}耳中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n默默地消失在空氣中。"
    }
]