    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「我們優妮們」。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "剛才還感嘆自己交不到朋友而隨著個人風格饒舌，",
        "unit_id": 110911,
        "voice": "vo_adv_9004004_026"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n現在卻放著這麼多朋友不管，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不如說那孩子是超乎常人的高手？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "自由、反抗、最初的衝動──",
        "unit_id": 110811,
        "voice": "vo_adv_9004004_027"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "比起Rapper，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那傢伙的生活方式更像是Punk呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那麼碧會去當樂團的主唱嗎？",
        "unit_id": 110911,
        "voice": "vo_adv_9004004_028"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就和在場的成員們一起組樂團。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哇啊啊啊！",
        "unit_id": 111011,
        "voice": "vo_adv_9004004_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什麼呀，感覺很有趣！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與聚在玩具工廠的大家歡談未來可能發生的事情後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}便動身前往下一個目的地。"
    }
]