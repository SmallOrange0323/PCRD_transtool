        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這麼忽然，有什麼事嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "公會的年度活動紀錄……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來如此，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不愧是團長！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "受到大家的依賴，好厲害！",
        "unit_id": 104011
