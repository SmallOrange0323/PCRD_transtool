    {
        "type": "dialogue",
        "name": "碧",
        "words": "原、",
        "unit_id": 104011,
        "voice": "vo_adv_9004004_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來團長在呀……！",
