    {
        "type": "dialogue",
        "name": "碧",
        "words": "我想說久久來打一次工好了……",
        "unit_id": 104011,
        "voice": "vo_adv_9004004_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n因為現在是忙碌期，人手不夠，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n所以工廠長就拜託我來幫忙。",
