        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這次究竟",
