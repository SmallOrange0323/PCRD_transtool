        "voice": "vo_adv_1047010_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真失職……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n得花更多心思在夥伴身上才行。",
