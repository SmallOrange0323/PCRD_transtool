        "voice": "vo_adv_1047010_060"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "這塊地點是我先看好的！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "這種事誰知道啊！",
        "unit_id": 311,
        "voice": "vo_adv_1047010_061"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n我也是早就想好要在這邊開店了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "起爭執了嗎。",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_062"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒辦法，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我過去一下……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為什麼阻止我，",
