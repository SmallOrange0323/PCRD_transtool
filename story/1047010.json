        "voice": "vo_adv_1047010_048"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我還有任務，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以差不多該走了……",
