    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "！？",
        "unit_id": 104712,
        "voice": "vo_adv_1047010_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我、",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我又在想少年的事情了……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，",
        "unit_id": 104712,
        "voice": "vo_adv_1047010_046"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不是在叫你……",
