    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "先冷靜下來。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n在這個地方爭執也無濟於事啊？",
