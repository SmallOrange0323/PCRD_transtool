        "voice": "vo_adv_1047010_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總之",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這附近都已經解決了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n稍微休息一下就回去蘭德索爾吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……雖然最近已經習慣討伐魔物，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但還是被魔物擊中了一下……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我得更努力精進自己才行。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好痛……",
