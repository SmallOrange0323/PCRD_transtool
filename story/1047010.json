    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然很高興，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但你不能來這個地方喔。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那個……",
