    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎、",
        "unit_id": 104712,
        "voice": "vo_adv_1047010_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎麼了嗎，少年。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n怎麼抓住我的手……",
