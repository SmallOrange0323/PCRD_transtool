    {
        "type": "background",
        "background": "500021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你只是想要回來蘭德索爾啊？",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_059"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這樣的話一開始就先跟我說──",
        "unit_id": 104711
    },
