        "voice": "vo_adv_1047010_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "多虧穿著鎧甲，只是瘀傷而已。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不是什麼大傷口。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，",
        "unit_id": 104712,
        "voice": "vo_adv_1047010_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "受傷了這件事意味著……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖說人手不足，",
