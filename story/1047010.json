        "type": "dialogue",
        "name": "純",
        "words": "真、",
        "unit_id": 104712,
        "voice": "vo_adv_1047010_047"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真人？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "擔心我而來的嗎？",
