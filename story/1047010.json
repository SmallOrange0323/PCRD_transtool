        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "等、",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "等等。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "至少讓我戴上頭盔。",
