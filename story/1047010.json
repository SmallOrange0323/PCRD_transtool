        "voice": "vo_adv_1047010_042"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "想些什麼啊……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n可不能帶不是團員的人一起來。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這麼一說，",
        "unit_id": 104712,
        "voice": "vo_adv_1047010_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "最近都在忙任務的事情，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不知道其他團員們",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在做什麼呢……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "作為團長",
