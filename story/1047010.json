[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "純想著要和{player}約見面，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n卻說不出口，日子就這樣過去了。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "今天也是一成不變。",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然沒事就是好事，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但沒有要做的事情就會不禁胡思亂想啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……從那之後，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就沒法跟少年說任何話了啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "儘管知道該跟他約下次見面，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是該怎麼開口才好……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不行不行，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "得集中精神工作才行。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "該怎麼做才好呢……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "抱歉在任務執行時打擾了，",
        "unit_id": 712,
        "voice": "vo_adv_1047010_004"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "團長！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_005"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "這傢伙堅持要過來道歉……",
        "unit_id": 712,
        "voice": "vo_adv_1047010_006"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "那個……",
        "unit_id": 711,
        "voice": "vo_adv_1047010_007"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "之前的事情真的很抱歉。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是你啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n以後",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "多注意一下就好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這麼一說，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果沒有發生那件事，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那天也許就不會遇到少年了……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我在想些什麼。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n什麼事都沒發生才是最好的啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "……團長？",
        "unit_id": 711,
        "voice": "vo_adv_1047010_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "再說，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "直接向少年提出邀請，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就不會",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "像這樣陷入沉思了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "該如何開口呢……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔……",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來我是這麼",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "優柔寡斷的人嗎……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "那個……",
        "unit_id": 711,
        "voice": "vo_adv_1047010_013"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "差不多就行了，",
        "unit_id": 712,
        "voice": "vo_adv_1047010_014"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "新人。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "團長很忙的。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n肯定在擔憂【王宮騎士團】的狀況，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n並正在思考之後該如何行動。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "這、",
        "unit_id": 711,
        "voice": "vo_adv_1047010_015"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "這樣啊。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n不愧是前輩，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "很清楚團長的事情呢。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "那當然。",
        "unit_id": 712,
        "voice": "vo_adv_1047010_016"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "團長的事情就交給我。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n好了，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我們也去接任務吧。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n雖然沒辦法接下艱難的任務，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "應該還是有些什麼可以做的。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……艱難的任務、",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗎。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在這之中應該有討伐魔物的任務吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "咦？",
        "unit_id": 712,
        "voice": "vo_adv_1047010_018"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我想可能會有……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣啊。",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可以暫時",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "麻煩你留在這邊負責警備嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我去確認一下現在有什麼任務。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "是",
        "unit_id": 712,
        "voice": "vo_adv_1047010_020"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我知道了！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……沒錯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為有多餘的心思才會考慮這些多餘的事情。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n接下艱難的任務，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "然後重新提起幹勁吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "……不愧是團長啊。",
        "unit_id": 712,
        "voice": "vo_adv_1047010_022"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "前、",
        "unit_id": 711,
        "voice": "vo_adv_1047010_023"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "前輩？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "即使什麼話都沒說，",
        "unit_id": 712,
        "voice": "vo_adv_1047010_024"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "看著她的背影就能明白了。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n團長為了補足我們的不中用，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n而決定去挑戰困難的任務……！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "原來是這麼一回事啊。",
        "unit_id": 711,
        "voice": "vo_adv_1047010_025"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "果然，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "團長很厲害呢……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我們也是，",
        "unit_id": 712,
        "voice": "vo_adv_1047010_026"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "為了能夠稍微追上團長，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n要加油囉！！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "好",
        "unit_id": 711,
        "voice": "vo_adv_1047010_027"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "的！！",
        "unit_id": 711
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從那之後過了幾天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}因為很在意純的情況，所以正在找她。"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "今天就在這附近巡邏喔！",
        "unit_id": 712,
        "voice": "vo_adv_1047010_028"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n因為團長正在努力著，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我們也得加油才行！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "好！",
        "unit_id": 711,
        "voice": "vo_adv_1047010_029"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "但是，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "團長一個人沒問題吧？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n討伐魔物的話，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "還是不要單獨行動比較好吧……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "團長的話沒問題的。",
        "unit_id": 712,
        "voice": "vo_adv_1047010_030"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n我無法想像她陷入苦戰的樣子呢。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "唔，",
        "unit_id": 712,
        "voice": "vo_adv_1047010_031"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "什麼啊，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "你哪位。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n好像在哪裡見過你……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "我記得",
        "unit_id": 711,
        "voice": "vo_adv_1047010_032"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "這位是團長的熟人",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "沒錯喔。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "啊，",
        "unit_id": 712,
        "voice": "vo_adv_1047010_033"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "那個和團長一起執行任務的男子啊。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n你在找團長嗎？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "團長傍晚應該會回去據點。",
        "unit_id": 712,
        "voice": "vo_adv_1047010_034"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n她現在",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "正在對付運輸道路上出現的魔物，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n並在附近的森林進行調查。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我先說，",
        "unit_id": 712,
        "voice": "vo_adv_1047010_035"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "不要去森林那邊喔。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n會妨礙團長的。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n在據點等她就好。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我們也有巡邏的工作，",
        "unit_id": 712,
        "voice": "vo_adv_1047010_036"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "所以先走了……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "等等，",
        "unit_id": 712
    },
    {
