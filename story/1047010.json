        "voice": "vo_adv_1047010_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "被擊中的傷口很嚴重嗎……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然確認一下比較好，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但戴著面具很難確認吶……",
