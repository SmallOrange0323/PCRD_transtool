    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒錯，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "像少年一樣好好注視周遭……",
