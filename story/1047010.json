        "name": "王宮騎士",
        "words": "別在這種人來人往的路上起爭執。",
        "unit_id": 712,
        "voice": "vo_adv_1047010_069"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n你們都是想要做生意的人，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n好好溝通不就行了嗎？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "……知道了。",
        "unit_id": 1411,
        "voice": "vo_adv_1047010_070"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "真拿你沒辦法……",
        "unit_id": 311,
        "voice": "vo_adv_1047010_071"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……看來似乎不需要我出面呢。",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_072"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "果然就算我不在，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_073"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n團員也有在好好工作呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n少年讓我看這些究竟是為什麼……？　",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "那個……",
        "unit_id": 711,
        "voice": "vo_adv_1047010_074"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "像剛剛這樣對應就可以了嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n不嚴厲一點說的話",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "會被瞧不起吧……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "瞧不起的話，",
        "unit_id": 712,
        "voice": "vo_adv_1047010_075"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "最後嚐到苦頭的是他們。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n而且……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "如果是團長的話不會用那麼粗暴的方式。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "團長雖然沉默寡言，",
        "unit_id": 712,
        "voice": "vo_adv_1047010_076"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "不過看著她的背影可以學到很多。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n我們應該好好效仿，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "並努力追上她，是吧？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "……",
        "unit_id": 711,
        "voice": "vo_adv_1047010_077"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "是",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……明明我這麼沒出息，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_078"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "卻被當成模範了啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我只是為了自己才去接任務的，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_079"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n然而在夥伴眼裡我是這樣子的人啊……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年是為了鼓勵我，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_080"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "才讓我看這些的嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……這樣啊。",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_081"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝你，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_082"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n託你的福，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "讓我瞭解到團員們很信任我。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不論過程如何，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_083"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我用我的方式努力的話……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n夥伴都會看在眼裡，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是嗎。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "然後，也是為了他們，",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_084"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我感到我需要更加精進自己。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……我察覺到的",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_085"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不只是這件事。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我發現只要和鼓勵我的少年待在一起，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n心情就會平靜下來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_086"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "現在這種心情，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "肯定是因為我變得\n像普通的女孩子一樣，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "會想和某個人待在一起，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n事到如今，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "才察覺到這種事……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……你真的教會了我許多事呢。",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_087"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_088"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你的表情一臉寫著",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不知道為什麼我要一直道謝呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你還記得我之前說的嗎？",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_089"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我很憧憬可以做一些像普通女孩子會做的事……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "託你的福……",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_090"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我覺得，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n自己或許也越來越像個普通的女孩子了",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔……",
        "unit_id": 104711,
        "voice": "vo_adv_1047010_091"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "被當面",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這麼問的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我會有點困擾……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這個嘛，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n下次見面的時候",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我再好好跟你說。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不管{player}怎麼問純，\n都被她避開問題了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不過，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "她的聲音聽起來似乎很開心。"
    }
]