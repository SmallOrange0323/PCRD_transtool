[
    {
        "type": "background",
        "background": "500660"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "舞會啊，",
        "unit_id": 115911,
        "voice": "vo_adv_6061301_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對千金小姐們來說，是她們所嚮往的舞台，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n卻不是我的風格。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我最不擅長應付這種場合了。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "什麼，",
        "unit_id": 115911,
        "voice": "vo_adv_6061301_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "連你也對舞會有興趣？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你只是想跟我一起跳舞……？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那、",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那就沒辦法了，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我會好好考慮一下的。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你、",
        "unit_id": 115911,
        "voice": "vo_adv_6061301_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你在說什麼啊……！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "像我這種人對於舞會什麼的……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "穿上這樣的洋裝根本毫無說服力……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是啊！",
        "unit_id": 115911,
        "voice": "vo_adv_6061301_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "力量與力量之間的碰撞！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很令人熱血沸騰！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……不過，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這裡的貴族好像不喜歡這種的，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這方面就",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓我在工作上盡情發揮吧。",
        "unit_id": 115911
    }
]