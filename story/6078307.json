[
    {
        "type": "background",
        "background": "501050"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "織姫……",
        "unit_id": 113211,
        "voice": "vo_adv_6044307_000"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "いや、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "宿星の星姫を救うことができて",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "本当によかった。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "我が魂を受け継いで、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "どんな困難にも立ち向かえるはず。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "来年はどうなっているのか、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "楽しみだな。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "おお、",
        "unit_id": 113211,
        "voice": "vo_adv_6044307_001"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "それは面白いな！　",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "彦星や浮気星との連携技があるやもしれん。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\nそうなったら来年は",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "我らと星姫の戦いができるかもしれんな。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "どちらの力が上回るか、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "今からワクワクしてきたぞ！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "うむ、",
        "unit_id": 113211,
        "voice": "vo_adv_6044307_002"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "そうだな。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "仲睦まじく過ごしているうちに",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n何かトラブルに巻き込まれてしまう可能性はあるからな。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "もしそうなってしまった時は、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "また私たちが助けに行くとしよう！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "そうだな。",
        "unit_id": 113211,
        "voice": "vo_adv_6044307_003"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "次の機会があれば、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ミツキとエリコも誘うとしよう。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n本当に願いが叶う七夕祭りと聞いたら",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "きっと興味を……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "なんか",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "嫌な予感がするな。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "誘うの、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "やめておいた方がいいか……？",
        "unit_id": 113211
    }
]