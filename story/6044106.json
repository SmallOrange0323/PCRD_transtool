[
    {
        "type": "background",
        "background": "501060"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "話又說回來，",
        "unit_id": 113111,
        "voice": "vo_adv_6044106_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "牛郎那傢伙真是令人難以置信。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有那麼可愛的織女陪伴，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n居然還對其他女人移情別戀？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是難以置信。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是啊，",
        "unit_id": 113111,
        "voice": "vo_adv_6044106_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是個無藥可救的色狼。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那種傢伙需要被狠狠教訓一頓。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我們來協助織女",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好好地懲戒他一番吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我想",
        "unit_id": 113111,
        "voice": "vo_adv_6044106_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "應該還是有喜歡吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但那種渣男藉口最多了，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "比如說「我最愛的是妳！」",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "之類的。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這種理論怎麼可能說得通啊，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是沒救了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你不用懂也沒關係。",
        "unit_id": 113111,
        "voice": "vo_adv_6044106_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你就維持這個樣子，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "坦率地",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "做你自己就行了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種單純的性格，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我覺得很好喔。",
        "unit_id": 113111
    }
]