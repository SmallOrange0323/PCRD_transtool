[
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "會發現傳說中的貓嗎！？",
        "unit_id": 1,
        "voice": "vo_adv_1046007_000"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "珠希探險隊聽見在尚未發現的秘境中，",
        "unit_id": 1,
        "voice": "vo_adv_1046007_001"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有不明貓「巨貓」的目擊情報後，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一路飛奔到叢林深處！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "等待他們的是岩石！ 懸崖！ 還有驅貓瓶！",
        "unit_id": 1,
        "voice": "vo_adv_1046007_002"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n究竟他們一行人能否平安無事的回來呢！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯─，搞什麼啊喵？",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n對剛剛的旁白好像一臉無限吐槽的表情喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯嗯，你不要在意這種細節喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這種事是樂在其中的人才是贏家喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "死腦筋可是不行的喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那當然是今天喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "原本就是為了遊說你加入探險隊，",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n才找你的喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "對了，「巨貓」身高2公尺，",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n體重500公斤，據說用雙腳走路喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不知道會發生什麼事，所以要好好跟著我喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "貓咪們",
        "words": "喵─！ ",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "大家，如果發現可疑的東西，",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n要馬上告訴我──",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯，那是……！",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "糟糕喵，眼前有大岩石正滾過來喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呀─！",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n危險喵─！ ",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "抱！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼……",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "剛剛真危險喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你、你說什麼呢喵？",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我不知道喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我、我沒有指示貓去滾動大岩石喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我一定不會故意讓牠們這樣做的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那、那麼！",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我們快點往裡面前進喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，珠希探險隊冒著生命危險，",
        "unit_id": 1,
        "voice": "vo_adv_1046007_017"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n前往叢林深處。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "對探險隊來說，旁白是不可缺少的喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "比起那個，我們往前吧喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵────！",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你看這個腳印喵──！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這個腳印，粗略來看也有1公尺以上喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這不是一般的貓的腳印……",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這就是巨貓存在的鐵證喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，喂，你們在做什麼喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我不是要你們在今天之內好好完成工作嗎喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這樣的話，我就不給你們打工費的葛棗獼猴桃喔喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "貓咪們",
        "words": "喵，喵―！",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，喂，別逃喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_023"
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "喵……喵！？",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵―――！ ",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "岡薩雷茲！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "探險隊的突擊隊隊長岡薩雷茲，",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n因為過於害怕驅貓寶特瓶，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "半身懸空掛在懸崖上喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵！ ",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "岡薩雷茲！ 抓住這個鰹魚乾喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "岡薩雷茲",
        "words": "喵……",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你說牠似乎沒有真的想爬上來……",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你在說什麼喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你看看岡薩雷茲拼命的眼神喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "岡薩雷茲",
        "words": "喵……",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你說「我已經不行了……掰掰，珠希……喵」！？",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "岡薩雷茲，你不能放棄喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊啊―――！",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "岡薩雷茲――――――――！！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，岡薩雷茲消失在懸崖下方……",
        "unit_id": 1,
        "voice": "vo_adv_1046007_030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n珠希探險隊忍住眼淚繼續前進！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "岡薩雷茲……！",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_031"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你不會白白犧牲的喵――！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "岡薩雷茲……為了你，",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_032"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我一定會找到巨貓的喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著，在珠希探險隊的眼前，",
        "unit_id": 1,
        "voice": "vo_adv_1046007_033"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n令人期待已久的不明貓生物終於出現！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊――――！ 注視前方喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_034"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在那裡喵！ 是巨貓喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "聚集的貓咪們",
        "words": "喵喔―。",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "…………",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_035"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好了，打工結束喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_036"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "探險隊的大家，列隊",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_037"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n打招呼喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵―。也就是說，",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_038"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這是整人喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你有嚇到嗎喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈。你果然沒嚇到啊喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_039"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真可惜喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵？",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_040"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你問我為什麼做這種事？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……為了帶你來這裡喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_041"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……因為這裡是我們初次見面的地方喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_042"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你還記得嗎喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我一想到從這裡開始發生了許多這樣那樣的事情，",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_043"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就想無論如何都要帶你來這裡喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……那個，",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_044"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為我平常不怎麼坦率……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……一直以來謝謝你喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_045"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈，這麼正經的說果然很難為情喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046007_046"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "今天就到此結束吧―",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……啊！ 我看見巨貓在那裡喵！",
        "unit_id": 104611,
