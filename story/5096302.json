[
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 122611,
        "voice": "vo_adv_5096302_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這不是",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛剛那隻魔物嗎……！？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我還以為牠已經回海裡了……！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大概是來",
        "unit_id": 122411,
        "voice": "vo_adv_5096302_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雪恥的吧？",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n好啊──！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們接受你的挑戰！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和……",
        "unit_id": 122511,
        "voice": "vo_adv_5096302_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我認為對方可不會當這只是運動比賽喔。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n而且這隻魔物，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好像比剛剛更有氣勢了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們最好不要掉以輕心。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好！",
        "unit_id": 122411,
        "voice": "vo_adv_5096302_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我會小心的！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過該怎麼說好呢，",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我覺得還是好好跟牠戰鬥",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "會比較好……！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我知道了。",
        "unit_id": 122511,
        "voice": "vo_adv_5096302_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不管怎麼樣，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n既然牠要過來，我們也只能戰鬥了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一起上吧！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就像怜說的那樣，",
        "unit_id": 122611,
        "voice": "vo_adv_5096302_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n牠變得好凶暴……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生也要小心點喔！",
        "unit_id": 122611
    }
]