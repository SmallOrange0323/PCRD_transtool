[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "再一次，那是發生在某天的午後――"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請把臉轉向這裡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下來幫您擦嘴巴。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "擦",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "擦",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "變得非常乾淨了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下來幫您拿掉餐巾。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像這樣",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把手舉高嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做得非常好。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就算說您是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把手舉高的專家",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也不為過。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請問這之後要怎麼辦？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "肚子吃得很飽了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那樣的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請在在下的大腿上",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "午睡……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……等一下。",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_008"
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯？",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請問怎麼了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "才不是什麼",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_010"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "「請問怎麼了」吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "妳以為這裡是哪裡？",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_011"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n是一般",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "用餐的店裡面喔。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "在這裡面，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_012"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n到底是怎麼做才能變得這麼寵人啊。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "就算是看到雷姆的可愛和為姊姊著想的地方，\n而不停寵愛她的拉姆，看到妳的溺愛也為之感到戰慄了。",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_013"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "再怎麼說，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_014"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n可可蘿也有點太寵過頭了吧？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒、",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絕對沒有那回事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "照顧主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是在下的使命。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下並不是只因為使命",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而去侍奉的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是女僕對吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "侍奉主人的心情，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您應該也能明白不是嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_018"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是啊，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "也不是不能明白。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n拉姆也",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "向羅茲瓦爾大人宣示了忠誠。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "但是，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_019"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "羅茲瓦爾大人\n是個身邊的事物都能自己處理的人。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "以這大前提來看，\n就與這位{player}有著很大的不同。",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_020"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "根本無法參考。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐的想法在下明白了，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在暫時",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還需要時間。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否能請您",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "暫時在旁看著我們就好呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "為什麼妳要做到這種地步……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_023"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "說到底這並不是拉姆能夠插嘴的事情。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "只是，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_024"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這點先和妳說好了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n要是太過寵溺，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "對雙方都不是好事。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那麼做，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_025"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "一定會成為{player}，\n這個男人成長的阻礙。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_026"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "居然不借用在下的大腿，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n揉著昏昏欲睡的眼睛",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "站起來了……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您真是太了不起了，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓在下深深",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感動到為之顫抖了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "看這樣子，\n暫時是不行了呢……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_031"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喂，",
        "unit_id": 1411,
        "voice": "vo_adv_1098003_032"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "小姑娘們。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n妳們是",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "公會【美食殿堂】的人嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "嗯……？",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【美食殿堂】的成員。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問有什麼事嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "嗯，",
        "unit_id": 1411,
        "voice": "vo_adv_1098003_035"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是關於公會小屋的事情，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我想找相關人員談一下，所以才在找妳們。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不會耗費妳們太多時間，",
        "unit_id": 1411,
        "voice": "vo_adv_1098003_036"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n如果能現在談談就幫大忙了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "談事情",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是嗎。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明白了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這件事就由在下來處理。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在貪吃佩可小姐",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和凱留小姐不在，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這並不是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "需要勞煩主人的情況。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就讓在下可可蘿，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "毅然地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "擔任談話的對象。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喔、",
        "unit_id": 1411,
        "voice": "vo_adv_1098003_040"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喔喔？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那麼，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "跟我到公會小屋來。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白了。",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就過去了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下這就出發了，但……",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_042"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……什麼？",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_043"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "妳就去吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n為什麼要盯著拉姆看？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白這是非常失禮的請求，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是否能在在下回來之前，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您陪著",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐很可靠能幹，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您能陪著主人的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也能感到放心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "就在剛才",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_046"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n拉姆才說過要妳讓他獨立，妳卻要拜託拉姆？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "妳以為拉姆會樂意接受，那就大錯特錯了。",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_047"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆和把善良當作衣服穿在身上的愛蜜莉雅大人不一樣。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "而且，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_048"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n也和禁不起別人肯求的雷姆不一樣。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐的意見非常正確。",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "務必懇請",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您能幫忙。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人是",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下重要的人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就連片刻",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都不能將他置身於危險之中。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_051"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "片刻都",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_052"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不希望讓他遭遇危險，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是嗎。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_053"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆可不會寵他。",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_054"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n只是在旁邊看著而已。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這是條件。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣就足夠了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n拉姆小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常謝謝您！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這不是什麼值得道謝的事情。",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_056"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n因為",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆真的只會在旁邊看著而已。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "所以，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_057"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n請別抱有超過這之上的期待。",
        "unit_id": 109811
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "等一下，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_058"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "太危險了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n那裡是馬車要通行的路吧，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "靠路邊走。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "為什麼你會想橫越馬路？",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_059"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n來這裡",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "啊啊，真是的，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "到拉姆旁邊來。",
        "unit_id": 109811
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "要是跟著那看一眼就知道很可疑的人群走，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_060"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n可以想見一定會遭到苦頭吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你再多珍惜自己一點如何？",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_061"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n你要是有什麼萬一，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "可可蘿會哭的。",
        "unit_id": 109811
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "幫老人家搬行李，真了不起。",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_062"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這不是壞事。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那是正確的。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "但是，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_063"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n居然跟著走到蘭德索爾之外來，這就不正常了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "光是單程就花了數小時，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_064"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n結果只是坐在走廊邊喝個茶就回來，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "實在不符合勞力成本。",
        "unit_id": 109811
    },
    {
        "type": "background",
        "background": "500132"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "天色完全暗下來了……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_065"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n明明應該只是在旁邊看著就沒事了才對……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "嗯，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_066"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你還真是挺折騰的呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n託你的福，害拉姆足足 3 小時都被耽誤在原地。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "如果抱著大行李走了單程 2 小時的路，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_067"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n無論是什麼茶都會覺得好喝呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是讓人步調都亂了。",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_068"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n你平常都是這樣生活的嗎？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_069"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "原來如此。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n像這麼無防備的話，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "的確是讓人移不開視線呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "難怪在路上的熟人也莫名得多。",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_070"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "也就是說，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "因為無法置之不理，所以熟人也跟著增加。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "而且，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_071"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n還都是無法對放不下心的人置之不理的善人。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "哈！",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_072"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆是善人？",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_073"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你別惹人發笑了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆只是剛好",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_074"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n和可可蘿約定好才照顧你而已。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "作為證據，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_075"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n拉姆回去以後馬上就會卸下這個職務了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "像現在馬上……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_076"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "――",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_077"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您們兩位",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_078"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到底去了哪裡？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "見您們始終沒有回來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下感到非常擔心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "向街上的人到處打聽後，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_079"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n才聽說您們抱著大行李",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "朝街外走去了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "只是和有困擾的老婆婆",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_080"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "坐在走廊邊喝了茶而已。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "比起那種事……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_081"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "――？",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_082"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n拉姆小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您摸在下的頭",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是怎麼了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "可可蘿，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_083"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆撤回那時在店裡的發言。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "{player}",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_084"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n還很需要有個負責照料的人。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "而",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_085"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "擔任那個職務的人就是可可蘿。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n除了妳，沒有其他人能勝任了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐……！",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_086"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您能明白在下了呢！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下能侍奉主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_087"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n每天到底",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有多麼感謝這份幸運的心情。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "可可蘿的感謝我才不管呢。",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_088"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n只是",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "為窺見一部分的辛勞而感到滿足而已。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "總之，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_089"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這樣工作就結束了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n之後就全部交給可可蘿……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_090"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "喂，{player}。",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_091"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n你為什麼要拉著拉姆的衣角呢？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "今天過得很開心，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_092"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n所以希望能再一起到處去走走……？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "居然能讓主人",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_093"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "變得這麼親近。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和拉姆小姐一起度過的時間相當開心呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆只記得那是段很累人的時間。",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_094"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_095"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_096"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_097"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "啊、",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是的。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n別用那種像是被遺棄的小狗的眼神看著。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "知道了。",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_098"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n要是再有機會，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "之後若有那個心情就陪你吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "只是，",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_099"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n下次可可蘿絕對要跟在旁邊才行。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆絕對不要",
        "unit_id": 109811,
        "voice": "vo_adv_1098003_100"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "再代替像處理毀壞物手法的可疑人士一樣，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "抱著老人家的大行李走路了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1098003_101"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n原來您們還遇到了這種事嗎！？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}像是隱藏害羞般地搔著頭。\n幫助人真不是憑一朝一夕就能順利做好的呢。"
    }
]