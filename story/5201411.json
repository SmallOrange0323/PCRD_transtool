    },
    {
        "type": "dialogue",
        "name": "迷宮女王",
        "words": "呃──那麼，",
        "unit_id": 133712,
        "voice": "vo_adv_5201411_001"
    },
    {
        "type": "dialogue",
        "name": "迷宮女王",
        "words": "\n平常很少湊齊的成員都聚在一起了，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "迷宮女王",
        "words": "\n就來辦個慶功宴吧！",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "4人",
        "words": "「我可不要。」「我不要。」\n「誰要啊。」「怎可能要。」",
        "unit_id": 1,
        "voice": "vo_adv_5201411_002"
    },
    {
        "type": "dialogue",
        "name": "迷宮女王",
        "words": "我想也是啦～！",
        "unit_id": 133712,
        "voice": "vo_adv_5201411_003"
    },
    {
        "type": "dialogue",
        "name": "嚮導老君",
        "words": "晶，",
        "unit_id": 107211,
        "voice": "vo_adv_5201411_004"
    },
    {
        "type": "dialogue",
        "name": "嚮導老君",
        "words": "妳還是老樣子啊。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過，",
        "unit_id": 106912,
        "voice": "vo_adv_5201411_005"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我想想……",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若是把麻煩對手在此一併掃蕩的慶功宴，",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "或許會很不錯呢？",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "原來如此，",
        "unit_id": 133912,
        "voice": "vo_adv_5201411_006"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "遇合有緣，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "斬殺所有一切。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "哈哈，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "似乎會是很合我胃口的慶功宴呢☆",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "哦。",
        "unit_id": 107311,
        "voice": "vo_adv_5201411_007"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "這看起來比任何酒宴都來得有趣嘛。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "我是無所謂喔？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "就是這樣我才討厭成天只會用暴力當作溝通手段的傢伙。",
        "unit_id": 133812,
        "voice": "vo_adv_5201411_008"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "你們要打就請便吧。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "……我說晶，",
        "unit_id": 134011,
        "voice": "vo_adv_5201411_009"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "不阻止他們沒關係嗎？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "迷宮女王",
        "words": "嗯？",
        "unit_id": 133712,
        "voice": "vo_adv_5201411_010"
    },
    {
        "type": "dialogue",
        "name": "迷宮女王",
        "words": "唉呀，管他們愛怎麼樣就隨他們吧。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "迷宮女王",
        "words": "──反正我們從以前",
        "unit_id": 133712,
        "voice": "vo_adv_5201411_011"
    },
    {
        "type": "dialogue",
        "name": "迷宮女王",
        "words": "就一直都是這樣嘛。",
        "unit_id": 133712
    }
]