[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從身體流出了",
        "unit_id": 121011,
        "voice": "vo_adv_5085301_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無法控制的力量……！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算想試著強行控制它",
        "unit_id": 121111,
        "voice": "vo_adv_5085301_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也辦不到……！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 121011,
        "voice": "vo_adv_5085301_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我不會輸的。",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我跟許多同伴",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肩負著同樣的心意……！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啊……",
        "unit_id": 121111,
        "voice": "vo_adv_5085301_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在這麼華麗的舞台上，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可不能一個人說出喪氣話。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就讓我堅持一下、",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "逞強一番吧……！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真有氣魄呢，少女們！",
        "unit_id": 121211,
        "voice": "vo_adv_5085301_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n讓我也充滿了幹勁！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "偶爾這樣子也不錯呢，",
        "unit_id": 121211,
        "voice": "vo_adv_5085301_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "與一大群人並肩戰鬥。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n以眼神為信號，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "維持默契，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "聽從某人的指示。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……少年啊，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我很期待喲。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你的指揮能力。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "麻煩你了！",
        "unit_id": 121011,
        "voice": "vo_adv_5085301_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就靠你了！",
        "unit_id": 121111,
        "voice": "vo_adv_5085301_007"
    },
    {
        "type": "dialogue",
        "name": "{0}",
        "words": "……一起上吧，",
        "unit_id": 1,
        "voice": "vo_adv_5085301_008"
    },
    {
        "type": "dialogue",
        "name": "{0}",
        "words": "各位！",
        "unit_id": 1
    }
]