    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "【龍族巢穴】嗎……",
        "unit_id": 116611,
        "voice": "vo_adv_6066201_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "算是",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有點奇怪的公會吧。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在你看來，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我家公會",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一開始給你的印象如何？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈，",
        "unit_id": 116611,
        "voice": "vo_adv_6066201_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "多謝誇獎。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……等等，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你這話也有把祈梨算在內？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n果然你",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是個怪人。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "畢竟，",
        "unit_id": 116611,
        "voice": "vo_adv_6066201_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們也是個幫派，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "會這麼認為也沒辦法呢。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "現在的印象是……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你說沒怎麼變嗎？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "或許是這樣也沒錯呢！",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對吧？",
        "unit_id": 116611,
        "voice": "vo_adv_6066201_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖說我們光是龍人族這點就很稀奇，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但也不僅如此呢。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "況且我們老大也很狂，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n祈梨她……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "從許多方面來說也是個厲害人物呢。",
        "unit_id": 116611
    }
]