[
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "諾維姆與尾狗刀在敗給{player}等人之後，回到了城鎮。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n諾維姆心中的不甘頓時爆發。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "嗚咿──！",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "可惡，又敗給他們了──！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哎呀，",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_001"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "他們真的很強。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "想不到他們可以這麼不氣餒，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n這次是我們徹底輸了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不是",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_002"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "「這次是」！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n而是「這次也是」",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "吧！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦？",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_003"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "是這樣嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "以前的事我早就忘了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "別裝得那麼悠哉！",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_004"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n是我們輸了耶？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "要表現得更懊悔一點！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯，",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_005"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就算妳這麼說，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "拚輸贏這種事，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "輸了就是輸了啊？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就算是我，",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_006"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "也不是為了打輸而去應戰。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n別看我這樣，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我也是考慮過許多取勝的手段。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過，",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_007"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "勝負是難以預料的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就算做好萬全準備來應戰，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n眼看勝利在即，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "卻因為些微的關鍵因素而遭逆轉，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n也是常有的事。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "所以，雖然我會盡自己所能地來取勝，",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n但絕不會對最後的結果抱持",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "過高的期望。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我反而很不能理解",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_009"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "為何要拚命到這種程度。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "若能再放輕鬆點不是很好嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "是嗎，",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_010"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你不能理解啊……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那麼，我就說給你聽吧！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "當然是因為如果輸了就不好玩啦！",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_011"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我想要獲勝，",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_012"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "然後愉悅地開懷大笑！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "說什麼這次如果輸了，下次再加油就好，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這樣一點也不好玩！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "戰鬥就是要",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_013"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "全部獲勝！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這就是我的生存方式！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "唉……",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_014"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這種生存方式感覺很累人呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我肯定沒辦法做到。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "哼，",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_015"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我也不認為你能夠理解我的生存方式啦！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n我要去睡了，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你最好多用點你那顆妹妹頭腦袋想想下次怎麼贏！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哎呀，",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_016"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真讓人傷腦筋。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我倒是很羨慕",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "她那率直的個性呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "無論如何，",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_017"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "但願諾維姆她能貫徹",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那我無法做到的生存方式。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "為此，我也能一直當個",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "惹人嫌的妹妹頭渾蛋喔。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "尾狗刀望著矛依未離去的背影，輕聲低語著。"
    }
]