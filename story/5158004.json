    {
        "type": "dialogue",
        "name": "旁白",
        "words": "靠集體潛意識聯繫著的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "非常深沉的夢中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在回過神來的時候，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "出現在{player}面前的是──"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士，",
        "unit_id": 132811,
        "voice": "vo_adv_5158004_000"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你醒過來了嗎。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你沒事真是太好了。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "請你振作一點，",
        "unit_id": 132811,
        "voice": "vo_adv_5158004_001"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這是夢裡的景色喔。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "因為現實中的我們",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "應該在牢房裡面。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "總之，",
        "unit_id": 132811,
        "voice": "vo_adv_5158004_002"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "去跟伊緒會合吧。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然我有試著找她，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但是找不到。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我在這裡喔～♪",
        "unit_id": 1,
        "voice": "vo_adv_5158004_003"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "哎呀？",
        "unit_id": 132811,
        "voice": "vo_adv_5158004_004"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n從面前的箱子裡",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "傳來伊緒的聲音……？",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "驚喜──♪",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n聖誕禮物",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是我喔～",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "聖誕禮物是我喔～",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……唉，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為你無視我，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以我只能自己出來了啊。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "奇怪……",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我真是的，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我是怎麼了啊？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "居然會說禮物是我這種話……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……這個",
        "unit_id": 132811,
        "voice": "vo_adv_5158004_008"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "說不定是",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n潛意識所造成的呢。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那是什麼意思啊？",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_009"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "潛意識",
        "unit_id": 132811,
        "voice": "vo_adv_5158004_010"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "本來",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是無法控制的東西。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n然後，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這裡是由集體潛意識製造出來的夢的世界……",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不確實維持注意識的話，",
        "unit_id": 132811,
        "voice": "vo_adv_5158004_011"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n潛意識可能就會顯現出來。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "原來如此……",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "感覺就像是被脫光一樣，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓人很害羞呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剛剛的事情……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "其實",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個是",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我想在聖誕節做做看的",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n其中一種情境喔～！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……？",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_014"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n騎士，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你那句話",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是什麼意思啊？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總覺得，",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你那個說法聽起來，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n好像是之前有收過那種禮物一樣……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦，",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是那樣嗎……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n到底是",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "從誰那邊……？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 132811,
        "voice": "vo_adv_5158004_017"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然我很在意，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但是現在就專心執行任務吧。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n騎士，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我之後會問你詳情喔。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那會是",
        "unit_id": 132811,
        "voice": "vo_adv_5158004_018"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "怎麼樣呢……",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "比起那個，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我覺得話題被轉移了呢。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是啊，",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "之後再讓他告訴我們關於禮物的詳情吧。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總之，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我會充分注意潛意識的。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼，",
        "unit_id": 132811,
        "voice": "vo_adv_5158004_020"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "關於取回愛的方法，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "像至今為止一樣，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "一個人一個人解決會沒完沒了。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n如果有什麼",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "能把整座城鎮捲進來的",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "好主意……",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "關於那個。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "像剛剛的禮物一樣，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n活用聖誕節特有的情境如何？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是啊。",
        "unit_id": 132811,
        "voice": "vo_adv_5158004_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為聖誕節是特別的季節，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n所以不是會讓人覺得比平常更浪漫，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n或是不可思議地發生讓人心跳加速的事情嗎？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那種魔法般的瞬間是聖誕節特有的，我覺得如果能有效活用的話，",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "跟心跳加速的相乘效果下，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就算是城鎮全體的愛應該也能喚醒。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "心跳加速的相乘效果",
        "unit_id": 132811,
        "voice": "vo_adv_5158004_024"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗎……",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真不愧是伊緒。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n那麼，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "接下來",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就只剩下實現那個情境了吧。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是的。",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是首先",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n要找出能讓大家",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "心跳加速的聖誕節情境，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n到底是什麼才行。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就是這樣，",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_026"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們來一場聖誕節約會吧♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "聖誕節約會？",
        "unit_id": 132811,
        "voice": "vo_adv_5158004_027"
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "達令，",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你能幫我試味道看看嗎？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊～♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "味道如何？",
        "unit_id": 132912,
        "voice": "vo_adv_5158004_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剛剛好嗎？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n還是說",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要再加點鹽比較好？",
        "unit_id": 132912
    },
    {
