    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真步造訪了鬧區中的雜貨店。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並且採買完了公會小屋所需的日常用品，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n現在則正在享受著購物的歡樂時光。"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "神奇真步魔法靈，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咕嚕咕嚕靈～……☆",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "竟然能在這裡",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n遇見這～麼大、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n又這麼可愛的熊熊先生呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是沒想到呢～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "熊熊先生，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "從今天開始你就是我們家的孩子了唷～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓我們一起在真步真步王國過生活吧♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……咦？",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n行李太多了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我拿不動呀……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也沒辦法就這樣擱在這，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "該怎麼辦才好呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n竟然能在這裡遇見您……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們果然有著",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不論在哪都能相遇的命運呀～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可是",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您說要幫忙呀……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可以嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這行李，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有一點多就是了……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哇！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……嚇我一跳呢～",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您難不成比我們當初相遇時",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還更強壯了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生真是越來越棒了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這讓人家又更喜歡您了呀～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那麼，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "恭敬不如從命，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在到公會小屋之前……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗚哇啊～！",
        "unit_id": 415,
        "voice": "vo_adv_1010009_009"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n媽媽！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那孩子，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n難不成",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "迷路了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也一塊，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "稍等一下嘛～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "……",
