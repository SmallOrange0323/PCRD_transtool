        "voice": "vo_adv_1010009_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只要見到有困擾的人，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n馬上就會伸出援手去幫忙呢。",
