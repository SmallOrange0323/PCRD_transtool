    {
        "type": "dialogue",
        "name": "真步",
        "words": "對呀～。",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不只是對人家一個人而已，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n而是讓大家都能夠幸福的，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "很棒的王子先生唷～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以說，他一定",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "馬上就能夠找到妳的媽媽的♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗯、嗯！",
        "unit_id": 415,
        "voice": "vo_adv_1010009_019"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "欸嘿嘿，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "雖然我只有在故事書上看過，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n但是王子殿下",
