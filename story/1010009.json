        "type": "dialogue",
        "name": "真步",
        "words": "仔細一看",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還流了滿身大汗……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "原來是這樣呀……",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是辛苦您了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總之，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "找個地方好好休息一下比較好呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n找一家店怎麼樣呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦……",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您問我說，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n可不可以去找一下",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n剛剛在尋人途中遇見的婆婆",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "幫忙搬行李嗎……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人、",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家是沒關係，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但王子先生",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不找個地方休息的話……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "已經走掉了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "哎呀……",
        "unit_id": 611,
        "voice": "vo_adv_1010009_034"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "你願意幫忙嗎？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n真對不住呢……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "這行李實在太重了……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_035"
    },
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "回到公會小屋了呢～♪",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還讓您替我搬行李了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝您呀，王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "馬上就去替您倒杯茶，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您就在那邊先坐一會兒吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣呀……",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但其實啊，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n我有一件事情，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "想要拜託王子先生的說……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "其實啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家重新換了大浴場的擺設，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n造了一座真步真步大澡堂呢，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但是我們家的孩子們，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就是不怎麼跟人家說",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "她們的感想呀～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以說，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "才想讓哪個誰用用看，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n然後再好好地聽聽有什麼感想呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可以嗎？",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_041"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝您，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那麼，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就拜託您了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "辛苦您了呀～",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真步真步大澡堂感覺怎樣呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_043"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n看起來有放鬆了一下實在太好了呢～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_044"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "其實我還有另外一件事",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也想要拜託您……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n能稍等我一下嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總之，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "把這邊的靠枕像這樣排起來……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "然後再把蕾絲的布毯蓋上去……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真步真步王國的沙發就完成了呢～",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這次能讓人家聽聽您的感想嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……嗯？",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_047"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您怎麼了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "果然還是被發現了呀。",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_048"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n既然這樣的話……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嘿～呀♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_049"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來給王子先生膝枕囉～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "想抵抗也是沒有用的～♪",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_050"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n現在累癱了的王子先生，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就算是柔弱的人家也不是對手呢～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您就認命，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_051"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "乖乖地聽人家的話吧♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是人家的勝利呀～",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_052"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n呵呵，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "偶爾這樣子玩也很新鮮呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……那個呀，王子先生。",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_053"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n今天",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一塊行動時人家就在想。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_054"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不論什麼時候都很溫柔，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的是很棒的人呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……可是呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_055"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n如果您拼命過了頭，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總有一天會撐不住的喔？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "若王子先生倒下了，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_056"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "會有很多人會很難過的……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n當然不只是王子先生身邊的人們，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也會很難過的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以拜託您了，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_057"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還請您",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "別太過勉強自己了呢……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那就好♪",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_058"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就算只有今天，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您就在人家的腿上好好休息吧～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話說回來，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_059"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "摸起來讓人好安心呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n頭髮也軟軟的……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_060"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "該不會",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "想睡了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可以唷，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_061"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您就睡吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家會叫醒您的，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "請您放心……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……哎呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_062"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "已經睡著了呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還是一樣，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "睡臉真可愛呢～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……今天會好好地讓您乖乖撒嬌的，",
        "unit_id": 101011,
        "voice": "vo_adv_1010009_063"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您就做好覺悟吧♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——被那甜甜的話語，溫柔地包覆著，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}就這樣沉沉地睡去了。"
    }
