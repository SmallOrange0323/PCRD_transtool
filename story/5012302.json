[
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……感、",
        "unit_id": 101411,
        "voice": "vo_adv_5012302_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "感覺到比先前更強大的力量。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我真不像話……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都對步未說了\n那樣的大話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "手卻還在發抖……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對、",
        "unit_id": 105511,
        "voice": "vo_adv_5012302_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對不起！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "突然握住妳的手……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我只是\n希望多少能緩解霞的顫抖。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳要是也能，",
        "unit_id": 101411,
        "voice": "vo_adv_5012302_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這麼自然地握住助手先生的手就好了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真琴也是，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳們真是讓人費心呢♪",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "居、",
        "unit_id": 105511,
        "voice": "vo_adv_5012302_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "居居居、居然要握住前輩的手……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n應該說是太不敬了，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還是該說太尊貴了！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "在握住的那瞬間，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我會變不正常的啦……！！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵……",
        "unit_id": 101411,
        "voice": "vo_adv_5012302_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "多虧妳，我的手停止發抖了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n謝謝妳，步未。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一口氣打倒敵人吧……！",
        "unit_id": 101411
    }
]