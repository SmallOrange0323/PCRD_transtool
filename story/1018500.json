[
    {
        "type": "background",
        "background": "509010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "居然會被你找出來，",
        "unit_id": 101811,
        "voice": "vo_adv_1018500_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n簡直",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就像是老師跟學生的立場交換了一樣，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有種不可思議的感覺呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你找我出來有什麼事情呢，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "老師？　",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "唉呀，",
        "unit_id": 101811,
        "voice": "vo_adv_1018500_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "被學生祝福生日快樂，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真讓人有種幸福的感覺呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "成為老師",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真是太好了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 101811,
        "voice": "vo_adv_1018500_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "或許因為是你吧……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "感覺更加地幸福呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剛剛說的",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要對其他人保密喔？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你記得我的生日呢，",
        "unit_id": 101811,
        "voice": "vo_adv_1018500_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我好高興。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為完全沒想過居然會被你祝福呢，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以有點嚇到了呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "其實呢，",
        "unit_id": 101811,
        "voice": "vo_adv_1018500_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為不知道到底會是什麼事情，心臟撲通撲通地跳呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "聽到你說的一百分的溫柔話語讓我安心了呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "唉呀，",
        "unit_id": 101811,
        "voice": "vo_adv_1018500_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是在模仿我？　",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真是有你風格的生日禮物呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "比起任何高價的東西都更令我高興呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "最能烙印在心底的禮物，",
        "unit_id": 101811,
        "voice": "vo_adv_1018500_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "應該就是指這種東西吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你又",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "教會了我一件事情呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "能有像你這樣的學生，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我真的",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是個很幸福的老師呢……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "畢竟很難得，",
        "unit_id": 101811,
        "voice": "vo_adv_1018500_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天就好好慶祝吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "生日",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "能跟男孩子一起過還是第一次呢，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "心裡不禁小鹿亂撞。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一定會是很棒的一天吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝你。",
        "unit_id": 101811
    }
]