    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，{player}的mimi收到了特別的訊息。"
    },
    {
        "type": "dialogue",
        "name": "mimi",
        "words": "今天是你開始玩阿斯特朗傳奇值得紀念的日子。",
        "unit_id": 3
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看完這則通知後的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n帶著懷念的心情來到了公園。"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "哦，少年。",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_000"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n你果然到這裡來了呀。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你問我嗎？",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_001"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "如你所見，我在工作呀。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "畢竟我這可是可麗餅店呢。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "開玩笑的。",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_002"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我跟你一樣。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "突然有點想沉浸",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在回憶裡。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你知道",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "今天是什麼日子吧？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "沒錯，",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_003"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是你第一次登入阿斯特朗傳奇的日子。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n而這裡是",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你成為我的公主騎士的地方。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "哎呀，",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_004"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不過還真懷念呢。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "感覺像是很久以前的事了。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "哦，",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_005"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我給你的mimi你有好好地用呢。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯嗯，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "很好很好。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "當時把那個mimi給你",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_006"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "的時候，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我都覺得自己好像有點",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "太強硬了呢。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我給你添了不少麻煩吧……",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_007"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也把你捲進了不小的麻煩事裡，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n你該不會",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "很痛恨",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我吧？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……真的嗎？",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_008"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n就沒有一點點埋怨我？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "樂在其中……",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_009"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗎。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "哈哈哈，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "真有你的。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "作為阿斯特朗傳奇的製作人之一，",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_010"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n能聽見你這麼說就是最棒的報酬了。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那以後",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_011"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也請盡情享受吧。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "說笑的啦。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "怎麼了，少年。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "怎麼會，",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_012"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我怎麼可能那麼想呀。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "正因為是你，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我才能放心託付給你的。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我的公主騎士就是你，",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_013"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "非你不可。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "希望你能相信這一點。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "好，",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_014"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "接下來。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n你難得來這麼一趟，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我給你一個獎勵吧。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那麼，",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_015"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我親手烤的可麗餅怎麼樣？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "別擔心啦，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我會很用心地烤的。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "還有……",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_016"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "雖然今天",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "的確是紀念日，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但這可還不是終點哦？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n要鬆懈是不是太早了呀？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "因為你的冒險",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_017"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "還會繼續下去。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n你可要盡情享受啊。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就是這樣，",
        "unit_id": 106832,
        "voice": "vo_adv_9006009_018"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那就拜託你囉。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我的",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "公主騎士♪",
        "unit_id": 106832
    }
]