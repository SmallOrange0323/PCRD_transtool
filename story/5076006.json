[
    {
        "type": "background",
        "background": "505035"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人得知小棉花糖是超特級妖魔‧地獄犬後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n開始想辦法制止牠──"
    },
    {
        "type": "dialogue",
        "name": "小棉花糖",
        "words": "嘎唔唔唔……",
        "unit_id": 15211,
        "voice": "vo_adv_5076006_000"
    },
    {
        "type": "dialogue",
        "name": "小棉花糖",
        "words": "汪汪！！",
        "unit_id": 15211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "哎呀～～～！！",
        "unit_id": 411,
        "voice": "vo_adv_5076006_001"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n那隻怪物",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "是怎麼一回事！？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "不好了！",
        "unit_id": 10511,
        "voice": "vo_adv_5076006_002"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "牠已經在鎮上造成危害了！？",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "小棉花糖，",
        "unit_id": 117711,
        "voice": "vo_adv_5076006_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "等等！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "快冷靜下來～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "這樣很危險喔，",
        "unit_id": 10511,
        "voice": "vo_adv_5076006_004"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "不可以隨便出手！",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n妳會被吃掉的！",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "怎麼會……！",
        "unit_id": 117711,
        "voice": "vo_adv_5076006_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "各位，",
        "unit_id": 117811,
        "voice": "vo_adv_5076006_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大家都沒事吧？",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n有沒有",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "受傷呢？",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們沒有受傷，",
        "unit_id": 311,
        "voice": "vo_adv_5076006_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "只是為祭典所做的準備全都泡湯了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不僅攤位遭到破壞，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "連食材也全被吃光了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "就是說啊，",
        "unit_id": 411,
        "voice": "vo_adv_5076006_008"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我的攤位也是！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "為了這次的萬聖節，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我還特地研發了新口味呢！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "妳說新口味……",
        "unit_id": 117911,
        "voice": "vo_adv_5076006_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n難不成",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "大家都是開甜點店的？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是啊……",
        "unit_id": 311,
        "voice": "vo_adv_5076006_010"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n眼看萬聖節慶典就要開始了，我們可是卯足了幹勁呢……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "在這之前，",
        "unit_id": 411,
        "voice": "vo_adv_5076006_011"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "店面也曾被一大群小白狗給團團包圍……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "今年實在是禍不單行哪……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "看來小棉花糖就算生氣了，",
        "unit_id": 117711,
        "voice": "vo_adv_5076006_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還是",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "很愛吃甜食呢……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "是啊……",
        "unit_id": 10511,
        "voice": "vo_adv_5076006_013"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "這般對吃的強烈執著，",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "不禁讓我想起某人……",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "咦……",
        "unit_id": 712,
        "voice": "vo_adv_5076006_014"
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "你們是之前的那群人！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "我們接獲通報，說有巨型犬在鬧事……",
        "unit_id": 712,
        "voice": "vo_adv_5076006_015"
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "\n雖說其樣貌跟你們之前帶在身邊的妖魔好像不太一樣，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "\n該不會有什麼關聯吧？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呃、",
        "unit_id": 117711,
        "voice": "vo_adv_5076006_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那個……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為發生了一些事，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "牠才變成那般模樣，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "然後就逃走了……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "……",
        "unit_id": 712,
        "voice": "vo_adv_5076006_017"
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "這樣啊。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "\n你們還記得我曾說過，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "要是牠實際造成損害，我就得處置牠吧？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可是，",
        "unit_id": 117711,
        "voice": "vo_adv_5076006_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒有人受傷啊～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只、",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只是攤位遭到破壞……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "這就是所謂的實際損害。",
        "unit_id": 712,
        "voice": "vo_adv_5076006_019"
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "\n就算現在沒有人受傷，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "要是繼續放任不管，很快就會有傷者出現……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "我也不想這麼做……",
        "unit_id": 712,
        "voice": "vo_adv_5076006_020"
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "\n畢竟",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "牠長得一副軟綿綿的可愛模樣……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "咳咳。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "不過！",
        "unit_id": 712,
        "voice": "vo_adv_5076006_021"
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "\n該優先考量的是我所身負的職責！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "也就是",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "市民的安全！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "向所有部隊傳達下去！",
        "unit_id": 712,
        "voice": "vo_adv_5076006_022"
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "無論如何都得加以討伐！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "\n牠雖然逃得快，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "哪怕是逃到世界的盡頭，我們也得追上去！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "不能再讓牠",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團隊長",
        "words": "造成任何危害了！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士團士兵們",
        "words": "遵命！！！",
        "unit_id": 1,
        "voice": "vo_adv_5076006_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "怎、",
        "unit_id": 117711,
        "voice": "vo_adv_5076006_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "怎麼這樣……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "香織……",
        "unit_id": 117911,
        "voice": "vo_adv_5076006_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們就做我們",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "做得到的事吧？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒錯！",
        "unit_id": 117811,
        "voice": "vo_adv_5076006_026"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "首先，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "為了減少損害，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n必須把牠引誘到沒有人的地方去是也。",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "如此一來，",
        "unit_id": 117811,
        "voice": "vo_adv_5076006_027"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "騎士團或許就會願意聆聽我們的想法！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "話雖如此，",
        "unit_id": 117811,
        "voice": "vo_adv_5076006_028"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就算要引誘牠，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "小棉花糖也不會留心聽我們的話吧……",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有理也說不清是也……",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "因為牠是地獄犬啊……",
        "unit_id": 10511,
        "voice": "vo_adv_5076006_029"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n根本不會在乎",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "渺小人類所說的話……",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是，",
        "unit_id": 117911,
        "voice": "vo_adv_5076006_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對我們來說，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "牠是小棉花糖啊！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是那隻全身雪白、",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "軟綿綿的",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超可愛小狗狗！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為平時只顧著吃甜點，",
        "unit_id": 117911,
        "voice": "vo_adv_5076006_031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n又長得像棉花糖，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "香織才會幫牠取這個名字……",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "不，",
        "unit_id": 10511,
        "voice": "vo_adv_5076006_032"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "那才是牠原本的模樣……",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 117911,
        "voice": "vo_adv_5076006_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對了……",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是這樣！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "小棉花糖果然還是",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "小棉花糖！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "這是什麼意思？",
        "unit_id": 10511,
        "voice": "vo_adv_5076006_034"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為",
        "unit_id": 117911,
        "voice": "vo_adv_5076006_035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "牠只顧著吃甜點啊。",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n牠沒有傷害鎮上的人，",
