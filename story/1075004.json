        "voice": "vo_adv_1075004_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "貓獸人吧。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "貓這種生物很討厭水的～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不會游泳說真的也不意外。",
