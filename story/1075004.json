        "voice": "vo_adv_1075004_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總算有反應了呢！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你剛剛是不是",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有一瞬間在發呆呢～？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說不定你是中暑了，",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請好好補充水分，待在陰涼處休息哦。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也要",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再繼續慵懶一陣子……♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊～",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_064"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": " 陽光好舒服……☆",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嗯？",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n怎麼了嗎，{player}？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你一直盯著我看～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的臉上沾到了什麼東西嗎？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你覺得之前好像也有過，\n像這樣兩個人靠在一起休息的時候……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗎？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好像也有一樣的感覺呢。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_067"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝我，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼這麼突然，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說那是我的台詞才對啦！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算不做什麼特別的事、",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不去努力游泳或是勉強自己玩得開心……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "光是像這樣子，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起度過平靜的時光就覺得無限感激了。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我呀，",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_069"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "以前似乎一直嚮往著過這種生活。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而夢想在不知不覺中實現了呢～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最近真的相當幸福。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以呀，",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該說謝謝的，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是我才對哦……{player}♪",
        "unit_id": 107511
