        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要不要再去游一趟呢～♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，你要不要也一起去？",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n很好玩的哦～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n用盡全力撥開海浪，朝著地平線那端游去♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊哈哈。",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看{player}這個樣子，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像還沒記起游泳的方法？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟你失去記憶了～",
