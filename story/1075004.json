    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我在想你也許原本就會游泳，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為光今天一天就看得出來你越游越上手了呢。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然早上連讓臉碰到水都不敢，",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不過現在已經能稍微游泳和潛水了。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "照這個步調，",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n明天應該就可以和我一起長泳了。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那我就期待著明天到來的同時，今天先一個人去游泳吧～♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為小凱留和小可蘿好像都不會游泳……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然一個人覺得很寂寞，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但也沒辦法。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯。",
        "unit_id": 107511,
        "voice": "vo_adv_1075004_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然她本人好像打算隱瞞這件事……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不過她一直不把泳圈放開，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要把推她進海裡時她又會暴怒。",
