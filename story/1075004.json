    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "難得來到海邊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "趁還相安無事的時候盡情地玩樂吧。",
        "unit_id": 190011
