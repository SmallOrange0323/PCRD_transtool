    },
    {
        "type": "dialogue",
        "name": "樂園守護者",
        "words": "──嘰喔喔喔喔喔！",
        "unit_id": 17111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "打倒它了……？",
        "unit_id": 102911,
        "voice": "vo_adv_5110402_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太好了，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們贏了！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是啊，",
        "unit_id": 106511,
        "voice": "vo_adv_5110402_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "辛苦了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這是一場還算熱血沸騰的戰鬥。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n偶爾打場像這樣的架也不錯。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦，",
        "unit_id": 106116,
        "voice": "vo_adv_5110402_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳還這麼有幹勁啊？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n既然如此，我來當妳的對手！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我可是很強的喔！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好啊，",
        "unit_id": 106511,
        "voice": "vo_adv_5110402_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是該這樣！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼，我們再打一場吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的，",
        "unit_id": 102911,
        "voice": "vo_adv_5110402_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們好不容易打贏了，別這樣──！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "開玩笑的啦。",
        "unit_id": 106511,
        "voice": "vo_adv_5110402_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就算是打架狂的我也懂得察言觀色。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n因為戰鬥",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還沒結束呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是啊，",
        "unit_id": 106116,
        "voice": "vo_adv_5110402_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "引起這場騷動的傢伙還沒有被揍飛！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我們的戰鬥",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這才剛要開始！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "矛依未，",
        "unit_id": 102911,
        "voice": "vo_adv_5110402_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳說了這句台詞就表示要結束了喔……",
        "unit_id": 102911
    }
]