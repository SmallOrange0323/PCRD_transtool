[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "路空出來了……！",
        "unit_id": 105911,
        "voice": "vo_adv_5058323_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這群魔物",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的統領者，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即將要現身了……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真不愧是",
        "unit_id": 106011,
        "voice": "vo_adv_5058323_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "率領這群魔物的傢伙呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還真是有魄力。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟剛才的那些小嘍囉完全不一樣……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的……！",
        "unit_id": 105911,
        "voice": "vo_adv_5058323_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n比起被大量魔物的襲擊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎要更為棘手。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留、小可蘿，",
        "unit_id": 105811,
        "voice": "vo_adv_5058323_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們還好吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家沒有必要害怕。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就按我們自己的步調戰鬥吧♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們自己的",
        "unit_id": 105911,
        "voice": "vo_adv_5058323_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "步調……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯！",
        "unit_id": 105811,
        "voice": "vo_adv_5058323_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們想像一下。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這場戰鬥結束之後，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家一起坐在餐桌的樣子。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家一起開心吃飯的模樣。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "勇氣是不是漸漸湧起來呢？",
        "unit_id": 105811,
        "voice": "vo_adv_5058323_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "力量有沒有慢慢湧上來呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……是的，",
        "unit_id": 105911,
        "voice": "vo_adv_5058323_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "掌握到勝算了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──我吃不下那麼多啦──！",
        "unit_id": 106011,
        "voice": "vo_adv_5058323_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "害我想像過頭了啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的確不覺得我們會輸呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 105811,
        "voice": "vo_adv_5058323_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來妳們也都完全準備好了呢☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那麼那麼，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們上吧──！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911,
        "voice": "vo_adv_5058323_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "迎戰吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下會",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好好守護著主人的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要【美食殿堂】的力量聚集在一起，",
        "unit_id": 105911,
        "voice": "vo_adv_5058323_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下就無所畏懼……！",
        "unit_id": 105911
    }
]