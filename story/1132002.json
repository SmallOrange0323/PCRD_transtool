[
    {
        "type": "background",
        "background": "501050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了尋找海底城的魔具，{player}等人突破了第一道關卡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n邁向下一個考驗──"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "根據店長的說法，",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "第二道關卡應該就在這附近啊……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "喲，",
        "unit_id": 1511,
        "voice": "vo_adv_1132002_001"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "歡迎光臨。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "要不要來點冰冰涼涼的西瓜呀？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……「海底城的邀請」。",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_002"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "……！",
        "unit_id": 1511,
        "voice": "vo_adv_1132002_003"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "那張通行證，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "你們已經通過第一關卡了啊。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "這倒是來了個挺有意思的對手呢。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "嘻嘻嘻……！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "第二道關卡是羈絆的考驗。",
        "unit_id": 1511,
        "voice": "vo_adv_1132002_004"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "也就是打西瓜！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "雖然只要一次擊中就算過關了，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "但你們做得到嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵，",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就只是打西瓜而已嗎？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n在疾風之冥姬面前，形同兒戲！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這種程度的考驗真令人笑掉大牙！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "口氣真大。",
        "unit_id": 1511,
        "voice": "vo_adv_1132002_006"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "好，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "那小姑娘妳就負責打西瓜吧。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n那邊的小哥負責指揮。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "來，",
        "unit_id": 1511,
        "voice": "vo_adv_1132002_007"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "小姑娘，妳把眼睛蒙上……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "然後原地",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "轉個10圈吧！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "什麼！？",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_008"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n居然使用強制擾亂魔法，太卑鄙了！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳都算計好了！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "嘻嘻嘻，",
        "unit_id": 1511,
        "voice": "vo_adv_1132002_009"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "誰叫妳不認真把話聽完呢！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "來吧，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "快開始吧！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔，",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_010"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呼……呼……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n不行了……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "完全搞不清楚哪裡有什麼……！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "哈哈哈！",
        "unit_id": 1511,
        "voice": "vo_adv_1132002_011"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "看來妳也只是耍耍嘴皮子而已嘛！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "讓我看看，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "妳能打中西瓜嗎！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……在這樣的黑暗之中，",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_012"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我只能仰賴你了。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n吉格魯特，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "讓你這道光引領我的方向吧……！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你起碼也表現出一點合作的意願吧！",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_013"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n聽好了，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你要負責下達指令！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "明白了嗎！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……直、",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_014"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "直走嗎？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "妳走偏了啦，",
        "unit_id": 1511,
        "voice": "vo_adv_1132002_015"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "右邊！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "右邊！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "啊～",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "走過頭了，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "再左邊一點！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "後面啦！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我才不聽妳的聲音！",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_016"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "說吧，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n告訴我，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我這一劍，該往何處揮下！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喝！",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_017"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好耶，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "有擊中的手感！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "嘖，",
        "unit_id": 1511,
        "voice": "vo_adv_1132002_018"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "做得還不賴嘛……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "你們合格了。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n想不到你們連羈絆的考驗也突破了。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "不過下一道關卡才是關鍵考驗！",
        "unit_id": 1511,
        "voice": "vo_adv_1132002_019"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "你們有辦法克服嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "哈哈哈哈哈！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "啊，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "去第三道關卡之前，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "先吃個西瓜吧。",
        "unit_id": 1511
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "下一關是武鬥考驗，",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_020"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沙灘排球啊。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n好像會有魔具的看守人阻擋我們的去路，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "要以2對2和他們決勝負。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_021"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你對沙灘排球有信心嗎？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "什麼！？",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_022"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "前世的你和我歷經了許多生死一線的驚險瞬間，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n居然不知道「沙岸之球戲」──",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沙灘排球！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "咦……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真的嗎？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "連規則都不懂！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎麼會這樣……",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_023"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "都走到這一步了，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "命運卻在這個時候對我們露出獠牙…！！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "要向命運低頭還太早了。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n現在開始還不算遲，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們去取回前世的記憶吧！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……好，",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_024"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "特訓開始！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "別想東想西了，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我不要求你學會發球和攻擊。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n但至少要學會",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "托球和接球。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好，",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_025"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "規則大致上都記住了吧？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那由我來攻擊，你試著接球！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喝！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……喂，不准逃！",
        "unit_id": 113211,
        "voice": "vo_adv_1132002_026"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你這是怎麼了？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
