[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "智與深月"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n以怒濤洶湧的氣勢打倒了接連現身的魔物。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "小智，",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "魔物往妳那邊去囉！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "交給我吧！",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "喝～～！",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "高招。",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "偶爾有像這樣肝膽相照的合作，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "感覺也不壞呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳說，",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "肝膽相照嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為我這邊公會的成員都是些爾虞我詐的傢伙們。",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n即便彼此之間有合作，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n也不會是像這樣的模式。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【王宮騎士團】最重視合作關係，",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以除了這種戰鬥方式之外，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我很難想像還會有什麼樣形式的戰鬥。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過倒是有一個人例外。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一想到成員全都是像那傢伙那樣的團體……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n【暮光流星群】還真是個可怕的公會。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵。",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我倒認為",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "她們比起",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n全由是毒是藥皆無用者所組成的團體來得好多了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是毒是藥皆無用……",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我並不是在說\n【王宮騎士團】就是這種團體喔。",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳誤會了。",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我只是在想，現在的我",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "大概就是這種人吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這是什麼意思呢？",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_011"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "魔物來得正是時候。",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦？",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有件事我一直放在心上！",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那就是我無法獨自一人擊倒剛才的那一大群魔物！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以，",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這次我要單獨戰鬥！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n請你們不要插手！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哈……",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "年輕人實在令人頭疼。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真拿她沒辦法。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那我就再偷偷地……",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看招……！",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀。",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳果然是用了某種東西",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "來擊倒魔物。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是被我看到就會覺得困擾的東西嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還不到會覺得困擾的程度啦……",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不說這個了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們是不是先解決完那邊比較好啊？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳說得對。",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，妳手中的東西，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "待會也要請妳說明清楚喔。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我想與其用說的，不如直接讓妳看比較快……",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n就像這樣。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一、",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一擊就打倒魔物……！？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個是還在進行實驗的毒藥。",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如果可以的話，我並不想讓任何人看到……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "想不到",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳竟然注意到了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n看來我有點小看妳了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如何？小智，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳要逮捕我嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我不會逮捕妳的。",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為深月小姐",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只是打倒了魔物而已。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣好嗎？",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我還以為妳是為了引出足以逮捕我的證據，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n才會裝傻地說要獨自一人對抗魔物呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我並不是為了要逮捕妳。",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我必須",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "相信深月小姐會出手相救。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為那種傻事我是做不來的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我只是",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "對於注意到深月小姐的可疑舉動，\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "卻沒有深入追究的自己\n很反感。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "覺得自己被牽著鼻子走的行為表現，",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_031"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不配當【王宮騎士團】的一員。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以為了確認這一點，",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我才會耍了這愚蠢的花招。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_033"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳對於我說妳在裝傻這事感到耿耿於懷吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是有那麼一點。",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_034"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也很慶幸可以就此確認\n深月小姐是個好人。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那個毒藥也是",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_035"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為了能更有效率地打倒魔物而研發的吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯？",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_036"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個毒藥",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我是打算改良成\n完全不會被",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "檢測出來的毒藥喔？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……咦？",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_037"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦？",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_038"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒收！",
        "unit_id": 103711,
        "voice": "vo_adv_7021004_039"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我要沒收那個毒藥！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n妳所持有的量全都要沒收！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105111,
        "voice": "vo_adv_7021004_040"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如果要被沒收，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不如全都用在這座塔的魔物身上，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "同時還可以蒐集資料，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣做有意義多了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看著深月開心地躲避智的追捕，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n對她們兩人沒轍的{player}不禁深嘆了一口氣。"
    }
]