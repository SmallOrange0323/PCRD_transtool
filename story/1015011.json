[
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "花種子發芽後經過了數天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}每天都一早就跑來澆水。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "今天天氣真好～♪",
        "unit_id": 101512,
        "voice": "vo_adv_1015011_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n吹著舒服的風，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "花圃裡的小花好像也很開心地左右搖晃。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "既然今天幼稚園也放假，",
        "unit_id": 101512,
        "voice": "vo_adv_1015011_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n偶爾就悠哉悠哉一下吧。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵。",
        "unit_id": 101512,
        "voice": "vo_adv_1015011_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n{player}你要不要也一起呢？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "躺在柔軟的草地上，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "度過悠閒的時光……♪",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，",
        "unit_id": 101512,
        "voice": "vo_adv_1015011_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好大的哈欠呀～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是不是因為",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "陽光太溫暖，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以讓你想睡覺了……？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "畢竟自從種子發芽後，",
        "unit_id": 101512,
        "voice": "vo_adv_1015011_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你就每天早上都會來澆水嘛。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀。",
        "unit_id": 101512,
        "voice": "vo_adv_1015011_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n因為其他孩子都不在，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以變成了撒嬌鬼嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "唔、",
        "unit_id": 101512,
        "voice": "vo_adv_1015011_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯……？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我怎麼好像也開始睏了起來。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "都是因為陽光太舒服了……",
        "unit_id": 101512
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這不是{player}嗎？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵。",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n真是太巧了。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你也來買東西嗎？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為沒事做，所以正在閒逛？",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不錯耶～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "運用假日的方法真是奢侈呀♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……我？",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我算是",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……放假兼",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "工作吧。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "最近",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_011"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我打算和幼稚園的孩子們",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一起弄個花圃出來。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n所以",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "來這裡買花的種子。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦？",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你要陪我去買東西嗎？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過，",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "今天是你珍貴的假日不是嗎？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……這樣好嗎？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "把假日",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "拿來和我一起度過……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_014"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好有精神的回答呀。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就請你多指教囉♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_015"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真是熱情呢～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師都要誤會囉……♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵。",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老實說，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "有你跟著一起來，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我也就放心多了。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "如果只有我自己去買，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一定會花很多時間挑選，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以我很高興可以",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "問問{player}你的意見呢♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼……",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我想想。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我們",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "先到購物中心",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "去逛逛吧。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……你問我怎麼不是直接去花店？",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為那邊",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "晚一點再去也沒關係",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "畢竟難得有機會",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "和你一起行動，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我有很多想做的事嘛。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "如果早早把事情辦完道再見的話，",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那珍貴的假日就……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……太可惜了嘛，",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_021"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不是嗎？",
        "unit_id": 101532
    },
    {
        "type": "background",
        "background": "510330"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這間生活雜貨店，",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我很常來喔～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n是購買幼稚園裝飾品之類的",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好地方。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_023"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這個玩偶好可愛喔～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n孩子們也會很喜歡吧……♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊……",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_024"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這條領帶，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好像很適合你。",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "看，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真的很適合呢♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯？",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_025"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "怎麼了？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你好像有點坐立難安的樣子……",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "難不成",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_026"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是靜不下來嗎？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為對生活雜貨之類的",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒什麼",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "興趣嗎？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不是這樣嗎？",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_027"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n哎呀，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼是",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "為什麼會這麼緊張呢？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "周遭的……？",
        "unit_id": 101532,
        "voice": "vo_adv_1015011_028"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "欸欸，",
        "unit_id": 1,
        "voice": "vo_adv_1015011_029"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "你看那兩個人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "你覺得是什麼關係啊……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "是家人嗎……",
        "unit_id": 1,
        "voice": "vo_adv_1015011_030"
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "不對，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "互動的氣氛不像。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "\n可是他們看起來感情那麼好……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "看來真的是……♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "真的是",
        "unit_id": 1,
        "voice": "vo_adv_1015011_031"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "歲數差很多的情侶！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n可是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "他們還提到什麼孩子們的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "該不會……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子１",
