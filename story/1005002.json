    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "噫，",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_034"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "聽到叫聲了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那危險的魔物，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就在這附近！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個，{player}，",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_035"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不要發出聲音……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n盡量",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "安靜地、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "慢慢地",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "掉頭回去。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我的第六感告訴我，",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_036"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這將會是前所未有的大危機。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_037"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "奇怪？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不不",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不、不好意思！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我好像",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "腳軟了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "害怕得",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_038"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "動不了了……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n真是丟臉～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "明明在舞台劇裡登場的「正義的夥伴」，",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_039"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n面對任何狀況都能夠抬頭挺胸的。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚、",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_040"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我果然，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n還是沒辦法",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "成為像虎虎那樣的人嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……呀哇？",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_041"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}，\n你願意",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_042"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "抱著我",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "走嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "得、",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_043"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "得救了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我真的",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "發抖到站不起來，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n連尾巴的毛都倒豎起來了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……啊，",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_044"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "剛才說錯話了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然我",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "看起來像是有尾巴，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但這是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "單純的",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "裝飾什麼的～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這不是真的，",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_045"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n是像飾品一樣的東西！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你、",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_046"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你可以相信我嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "拜託了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我希望你把剛才的話當作沒聽到～！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔耶？",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_047"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n你說現在比起這個，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n先趕緊從森林裡逃出去……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "說得也是呢，",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_048"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}說的沒錯！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗅嗅……",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_049"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我的鼻子很靈，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n只要循著味道，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好像就能夠知道來的路了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大概是那個方向哦～",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_050"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "作為你抱著我的謝禮，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我幫你指路！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_051"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你說「真像動物呢」",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "才才才、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "才不是呢！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我才",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_052"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不是動物，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "理所當然的",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也不是獸人哦～！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……噫呀？",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_053"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n請、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "請不要抓我的尾巴啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那裡是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很敏感！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_054"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊沒事？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "尾巴只是個裝飾品，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "什麼感覺也沒有，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n請把我剛才的發言忘掉！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這個……",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_055"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "比起這件事，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n得在像是魔物的東西靠近以前，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "從這裡撤退！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "把多餘的疑問先丟一旁，",
        "unit_id": 100511,
        "voice": "vo_adv_1005002_056"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n現在只需要",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "全力地逃跑～！",
        "unit_id": 100511
    }
]