    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "……這附近",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "黑暗力量相當濃烈……",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "\n",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "不斷刺激著姐姐我的鼻子……！",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "沒錯。",
        "unit_id": 119011,
        "voice": "vo_adv_5078204_001"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n這裡的氛圍和先前不一樣。",
        "unit_id": 119011
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n讓人連",
        "unit_id": 119011
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "眼睛都跟著濕潤起來了……！",
        "unit_id": 119011
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "呃，",
        "unit_id": 4211,
        "voice": "vo_adv_5078204_002"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n兩位的感想",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "怎麼像是剛吃了什麼辛辣的東西似的……",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "……啊！",
        "unit_id": 119112,
        "voice": "vo_adv_5078204_003"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n會不會是因為空花，",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n剛剛偷偷點了",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "辣椒香氛蠟燭的關係！？",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "……為什麼要點那種東西？",
        "unit_id": 4211,
        "voice": "vo_adv_5078204_004"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "這種",
        "unit_id": 119112,
        "voice": "vo_adv_5078204_005"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "直衝著眼睛和鼻子而來的刺激……",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "真是太舒爽了……！",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "總……",
        "unit_id": 4211,
        "voice": "vo_adv_5078204_006"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "總而言之，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "我們先找出反逆獸吧！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "牠一定藏身在什麼地方──",
        "unit_id": 4211
    },
    {
