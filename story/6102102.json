    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "遊戲展示會裡，",
        "unit_id": 123611,
        "voice": "vo_adv_6102102_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "每個攤位的氣氛都很熱鬧耶。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看來，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好像發表了許多不同類型的遊戲。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你有沒有",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "對哪個類型的遊戲有興趣呢？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "美少女遊戲啊……",
        "unit_id": 123611,
        "voice": "vo_adv_6102102_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這麼說來還滿合理的。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為你的身邊無論何時，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n都有女孩的身影嘛。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你想透過遊戲，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n學習怎麼和那些女孩相處……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "原來是這樣啊。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我明白了。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是喔，",
        "unit_id": 123611,
        "voice": "vo_adv_6102102_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你對棒球有興趣啊……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "其實",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也有一點興趣……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過自從決定走劍術這條路之後，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我就不會去看比賽了。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……改天想跟我來場棒球遊戲的對決？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這個嘛，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只玩一次的話……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣啊，",
        "unit_id": 123611,
        "voice": "vo_adv_6102102_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "正好萬聖節也快到了呢。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n有機會的話，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我很想在旁邊看你玩恐怖遊戲耶。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為你害怕的模樣",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一定很有趣。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵♪",
        "unit_id": 123611
    }
]