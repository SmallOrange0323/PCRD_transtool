[
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼哈，",
        "unit_id": 105811,
        "voice": "vo_adv_2008013_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "終、終於到洞穴外頭來了呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105911,
        "voice": "vo_adv_2008013_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遠比想像的還要更加艱辛啊。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為太慌亂，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "白白浪費了很多體力……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且似乎耗費了不少時間，連太陽都快西下了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……哦呀？",
        "unit_id": 105911,
        "voice": "vo_adv_2008013_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您沒有大礙吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105811,
        "voice": "vo_adv_2008013_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}，喘吁吁的呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣可不行唷～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得再多鍛練些才行♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105811,
        "voice": "vo_adv_2008013_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請不要那麼沮喪嘛。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟被可怕的敵人追著跑嘛，所以才會特別緊張的吧。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以氣喘吁吁的，也是沒辦法的唷。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦，是真的嗎？",
        "unit_id": 105811,
        "voice": "vo_adv_2008013_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有腹肌還是什麼嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在哪在哪，讓我摸摸看……♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大家！ ",
        "unit_id": 106112,
        "voice": "vo_adv_2008013_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "暫時停下來！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚呀！？",
        "unit_id": 105811,
        "voice": "vo_adv_2008013_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n怎、怎麼了嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……太糟了。",
        "unit_id": 106112,
        "voice": "vo_adv_2008013_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n似乎，我們的行動全被對方給看穿了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳們看，周圍全都是敵人。",
        "unit_id": 106112,
        "voice": "vo_adv_2008013_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這可是個完全沒有破綻的布陣呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛才通過的洞穴裡那些魔物也沒有全部被消滅，",
        "unit_id": 106112,
        "voice": "vo_adv_2008013_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以也沒辦法回頭……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒路可逃了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "怎、怎麼可能……騙人的吧？",
        "unit_id": 104911,
        "voice": "vo_adv_2008013_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "【拉比林斯】據點的這個逃脫出口，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "應該是不會有人知道的才對！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "話說回來據點本身的位置，應該也是隱藏的相當嚴密啊，",
        "unit_id": 101112,
        "voice": "vo_adv_2008013_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n還是兩三下就被發現了呢……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這些敵人，好像有著非常不尋常的情報收集能力呀。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "敵人是王宮……也就是國家的權力呀～事到如今，",
        "unit_id": 101112,
        "voice": "vo_adv_2008013_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就算不甘願也只能認了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只要不計代價成本來用人的話，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "世上就幾乎沒有辦不到的事呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚～呣呣，",
        "unit_id": 101112,
        "voice": "vo_adv_2008013_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還真的到處都是敵人呀……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們簡直就是",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "『甕中吃鱉』啊，該怎麼辦呀？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是『甕中之鱉』唷，璃乃？",
        "unit_id": 104911,
        "voice": "vo_adv_2008013_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯……",
        "unit_id": 107111,
        "voice": "vo_adv_2008013_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也曾經是【王宮騎士團】\n裡頭所屬的一員，以我的經驗來說能夠理解。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那個公會除了維護治安以外，撲滅犯罪者也是職務的一環。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "擁有著與搜索相關的，最先進的各種技術。",
        "unit_id": 107111,
        "voice": "vo_adv_2008013_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來是大範圍地施放高度精密的探索魔法，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n然後將我們的逃難路徑和當前位置給計算出來了吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "看來不僅是有備而來，還成功擺了我們一道呢。",
        "unit_id": 107311,
        "voice": "vo_adv_2008013_018"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n放眼望去到處皆是人山人海的魔物和軍隊，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n都可以說是國與國之間戰爭的規模了。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "是怎樣啊，有必要做到這種地步嗎？",
        "unit_id": 190711,
        "voice": "vo_adv_2008013_019"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我們到底是做了些什麼！？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "嗯。",
        "unit_id": 191011,
        "voice": "vo_adv_2008013_020"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "真如方才於餐桌前的談話所述，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n敵人的領袖真的是改變了世界的罪魁禍首的話……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "【拉比林斯】和我們，",
        "unit_id": 191011,
        "voice": "vo_adv_2008013_021"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n可說是反抗權勢的礙眼存在吧。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n畢竟我們可是逐漸迫近了世界之謎。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "總之，不可能置之不顧。",
        "unit_id": 191011,
        "voice": "vo_adv_2008013_022"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n像這樣子積極的試圖擊潰我們也是理所當然。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "所謂權力，",
        "unit_id": 191011,
        "voice": "vo_adv_2008013_023"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "會將一個人的寬容與人性給徹底剝奪……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "一路至今，已見過無數次如此使人心寒之事了。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你要怎麼辦？",
        "unit_id": 107111,
        "voice": "vo_adv_2008013_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這可說是四面楚歌窮途末路，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也不為過的狀況。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是要抱著必死的覺悟殺出重圍，",
        "unit_id": 107111,
        "voice": "vo_adv_2008013_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "試著逃脫嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還是說要放棄，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在這裡投降嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可不想選後者呢。",
        "unit_id": 107111,
        "voice": "vo_adv_2008013_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n倘若又得要回到那乏味的牢獄之中，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不如在戰場上盛開死亡之花要好上百倍。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我也是這麼想！",
        "unit_id": 190711,
        "voice": "vo_adv_2008013_027"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "哦哦哦，管他是軍隊還是魔物都沒在怕的啦！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n來啊，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "把你們全都給揍得稀巴爛……！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "喂～",
        "unit_id": 106211,
        "voice": "vo_adv_2008013_028"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我很抱歉在你們摩拳擦掌想要大幹一場的時候打擾了，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n但可不可以稍微聽一下我們的話呢？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……",
        "unit_id": 106112,
        "voice": "vo_adv_2008013_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀！？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "唷，又見面了呢，小矛依未。",
        "unit_id": 106211,
        "voice": "vo_adv_2008013_030"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "看妳活蹦亂跳的真是太好了～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n如果妳死了，要回收我重要的胸針可就困難多了呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "…………",
        "unit_id": 106112,
        "voice": "vo_adv_2008013_031"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "別那樣瞪人嘛，真可怕欸……",
        "unit_id": 106211,
        "voice": "vo_adv_2008013_032"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "女孩子啊，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "還是笑笑的最可愛了唷♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦呀哦呀？",
        "unit_id": 107111,
        "voice": "vo_adv_2008013_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n對我就不打聲招呼了嗎，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "尾狗刀小少爺？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可曾好好關照你過了好陣子呢，",
        "unit_id": 107111,
        "voice": "vo_adv_2008013_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好個不知禮儀的傢伙呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然不知道為什麼你會身在此處，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但惹我不開心可是會後悔的唷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "雖然想說的話多的不得了。",
        "unit_id": 106211,
        "voice": "vo_adv_2008013_035"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n抱歉呢～但如果我太多嘴的話，可是會被上頭的人給罵的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n那麼，小弟先退下囉。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "陛下，",
        "unit_id": 106211,
        "voice": "vo_adv_2008013_036"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "接下來就交給妳囉♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "『陛下』……？",
        "unit_id": 106112,
        "voice": "vo_adv_2008013_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "難不成真那、那個尤絲蒂亞娜復活了嗎！？",
        "unit_id": 106112
    },
    {
        "type": "still",
        "still": "200801301"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "尾狗刀，對人的稱呼還請三思。",
        "unit_id": 106013,
        "voice": "vo_adv_2008013_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我只不過就是，陛下暫時性委任了全權的存在而已。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n過度的諂媚或拍馬屁是沒有意義的。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而當然，",
        "unit_id": 106013,
        "voice": "vo_adv_2008013_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "若膽敢忤逆我也會有得你受的。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸……？",
        "unit_id": 105811,
        "voice": "vo_adv_2008013_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n凱、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……！",
        "unit_id": 105911,
        "voice": "vo_adv_2008013_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是的。",
        "unit_id": 106013,
        "voice": "vo_adv_2008013_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我就是凱留，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是國王陛下的代理人。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今日前來對反政府組織【拉比林斯】，",
        "unit_id": 106013,
        "voice": "vo_adv_2008013_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n及意圖藏匿重罪刑犯之人們進行剿滅。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在此乖乖束手就擒即可。",
        "unit_id": 106013,
        "voice": "vo_adv_2008013_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果要繼續抵抗的話，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會將你們抹殺至一人也不剩。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳、妳在說什麼呀……小凱留？",
        "unit_id": 105811,
        "voice": "vo_adv_2008013_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳發生什麼事了嗎！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抹殺……",
        "unit_id": 105911,
        "voice": "vo_adv_2008013_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為什麼，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要說這種話呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那個溫柔的凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是不可能對在下等人有所不利的！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我並沒有允許妳們發言。",
        "unit_id": 106013,
        "voice": "vo_adv_2008013_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一分鐘，等妳們做決定。",
        "unit_id": 106013,
        "voice": "vo_adv_2008013_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這之後，倘若妳們沒有表現出投降的意願……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n將會根據國王陛下的意志，也就是法律",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "將妳們全數處刑。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請謹慎思考，",
        "unit_id": 106013,
        "voice": "vo_adv_2008013_049"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請妳們做出賢明的判斷。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可、",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可可蘿、{player}……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果依舊頑強抵抗的話，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可無法保證妳們能活著離開這裡。",
        "unit_id": 106013
    },
    {
        "type": "still",
        "still": "end"
    }
]