[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哦哦……",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n真是久違了呢，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "蘭德索爾。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "原來有這麼熱鬧嗎……",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔唔，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "人太多了真不舒服。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}～",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不要和我離得太遠哦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "和{player}走散的話，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我一定會迷路的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n牽著手……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我啊，本來就不擅長面對人群呢。",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n可能因為在盡是動物的牧場裡久住，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這症狀又變得更加嚴重了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "外來的刺激太多了，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "感覺好刺眼啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚～好想趕快回去牧場……",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總之，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "快去【哞哞自衛隊】的據點吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然事實上，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是不知道路該怎麼走啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}，你知道地點在哪嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦……",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}你，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n在【哞哞自衛隊】裡有認識的人啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n意外地交友廣闊呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真令人佩服。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，畢竟你連跟像我這樣的人都能混熟嘛……",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n基本上就是不怕生，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n和誰都能馬上親近起來的感覺對吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真厲害啊……",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "令人尊敬。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然不覺得我能變得像{player}一樣，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但感覺有點羨慕。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀算了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n趕快把該做的事完成吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我被說了～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要好好向【哞哞自衛隊】提出報告書，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n還要順便接受訓練呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然上次【哞哞自衛隊】的大家來到牧場時，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n已經報告過近況了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但果然，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "光這樣好像還是不夠。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我要是不好好接受訓練重新做人的話，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n也可能會被【哞哞自衛隊】開除。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然我是無所謂啦。",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為本來就是受父母所逼，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n才加入的公會。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但要是媽媽知道了我被公會除名，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好像會很傷心……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "被開除也就很難",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "以任務這個藉口賴在牧場不走了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然很麻煩，但我會加油的。",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n為了能夠再次，恢復無所事事的懶散和平生活。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就算是我，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也會付出最低限度的努力呦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不知為何，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}似乎受【哞哞自衛隊】的大家所託，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要把我帶下山的樣子。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我要是不好好做的話，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n也會給{player}添麻煩呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那樣實在是～",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很不好意思呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我可是想和{player}友好相處的哦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為你是個會陪我玩遊戲，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n又會照顧人的好傢伙嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然對你來說，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n需要陪著像我這樣棘手的人……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "其實應該覺得很麻煩吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你能夠這麼說，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是蠻感謝的啦……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但你也真是奇特呢，{player}。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你啊，喜歡照顧別人嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還是說，你對我……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "話說，不可能有這種事吧。",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為我沒有能讓人喜歡的要素嘛，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這我倒是知道的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚嗚。",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n連{player}都要說教啊～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為喪失記憶而沉默寡言，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不會吵鬧囉嗦這點明明是你的優點的說。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "算了……這也是因為，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我是沒用到會讓人想勸說的傢伙對吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然我也覺得這麼懶散不太好，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_031"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但我就是這種性格嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀算了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n走吧，{player}。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n喋喋不休地說個不停也沒有用。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然【哞哞自衛隊】那邊說，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_033"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n無論何時到她們的公會小屋露面都可以。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但是我想迅速解決麻煩的事。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也不能總是這樣，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_034"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n把問題全部都丟給{player}嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n畢竟是我的問題啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "快點去露個面……",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_035"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n訓練也好，無論什麼我都會做的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只限今天我會加油的哦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣一來，你會誇獎我嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_036"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n誇我很努力了呢之類的……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然我也了解，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_037"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那並不是了不起到能夠被誇獎的事情。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只是一般的……",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_038"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n對別人來說理所當然就能做到的事，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n對我來說並不簡單呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為我是被溺愛著長大的啊……",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_039"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n光是能夠站起來，光是會喊媽媽，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就會被摸摸頭誇獎說真了不起呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "以對待小嬰兒一般的良好待遇，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_040"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n把我扶養長大到這個年齡。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊……並不是說，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_041"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我對媽媽的教育方針有什麼意見呦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是，世界上最幸福的人呦。",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_042"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為是被愛著、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "被肯定著",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而養育茁壯的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只吃喜歡的東西，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_043"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n討厭的事或辛苦的事都幫我推得遠遠的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是最近，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_044"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n大家也說了這樣下去不行……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大家可都是，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_045"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n辛苦到我難以置信的程度在生活著呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我啊，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_046"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "感到很困惑呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n活著還真是辛苦啊，{player}。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是大家，",
        "unit_id": 102611,
        "voice": "vo_adv_1026006_047"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n都是這樣生活著的對吧……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真麻煩。",
        "unit_id": 102611
    }
]