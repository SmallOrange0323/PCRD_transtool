[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在為思念故鄉的香織打氣後，過了幾天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}像平常一樣，做著送貨的打工。"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那麼小哥，",
        "unit_id": 311,
        "voice": "vo_adv_1017010_000"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n就拜託你把這個東西運到商店了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喔，",
        "unit_id": 311,
        "voice": "vo_adv_1017010_001"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "怎麼啦？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你對那箱貨物有興趣嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哦，",
        "unit_id": 311,
        "voice": "vo_adv_1017010_002"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我想也是。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n這是最近才剛進貨的東西。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n堆了這些貨品的船隻",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "來自相當遙遠的大海另一端。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "因為有很多稀奇的東西，",
        "unit_id": 311,
        "voice": "vo_adv_1017010_003"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我才想在這邊賣看看。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "像是這個樂器，你不覺得很少見嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n這東西的名字好像叫三線……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你知道嗎？",
        "unit_id": 311,
        "voice": "vo_adv_1017010_004"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "真是博學啊。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n咦？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你想知道那艘船在哪裡？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我是無所謂──",
        "unit_id": 311
    },
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗨呵～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "歡迎來到【哞哞自衛隊】的公會小屋～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們隨時都很歡迎{player}來喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那我先來表演",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一段舞蹈～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那個，",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "之前很謝謝你喔～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "多虧了{player}，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我充滿了活力～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n怎麼啦～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你說現在不是跳舞的時候？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不對，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "跳舞是最重要的事情喔～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦……？",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n什麼意思啊～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "貨品裡有",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來自我故鄉的樂器？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n運來那個樂器的船",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來到",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這附近了……！？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "原來如此……",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如果那艘船是來自我的故鄉，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只要請對方讓我搭上那艘船……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我就能回到故鄉了……？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "…………",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對不起～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我有點驚訝，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "才會出神了～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "謝謝你告訴我這件事～！",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n那就趕快",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "去找那艘船看看吧～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}也願意跟我一起來嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "謝謝你～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n有{player}陪著的話，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我會覺得很放心～♪",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們到海邊了～！",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我看看喔，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "碼頭是在那邊對吧～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是一艘非常大的船吧～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我看看～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "非常大的船……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "那妳肯定是在找我的船吧。",
        "unit_id": 1411,
        "voice": "vo_adv_1017010_017"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "那可是我的搭檔，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "經歷過了無數次的航行喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喔～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n最近",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "把奇怪的貨物……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "樂器運來的船隻，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n就是大叔的船嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "嗯，",
        "unit_id": 1411,
        "voice": "vo_adv_1017010_019"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "沒有錯。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "我不是在自誇，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n但我的船能夠運送",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "其他人沒辦法比擬的貨品。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "最近也是啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1017010_020"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "我湊巧抵達了一座相當炎熱又熱鬧的島嶼，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n在那裡買進了各式各樣的東西！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n那是個充滿歌曲和舞蹈的",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "美好島嶼喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就是那裡～！",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不會錯的～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那裡就是我的故鄉喔～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那是座日頭十分耀眼的",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "美好島嶼，對吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "妳說什麼！？",
        "unit_id": 1411,
        "voice": "vo_adv_1017010_022"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n小姑娘，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "妳是從那座島過來的嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "這還真是千里迢迢啊～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "回不去……？",
        "unit_id": 1411,
        "voice": "vo_adv_1017010_023"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "原來如此，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "是這樣啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以說啊，",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我想知道，如果這艘船會再去那座島，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n能不能讓我上船呢……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "唔嗯……",
        "unit_id": 1411,
        "voice": "vo_adv_1017010_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不可以嗎～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_026"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "我是很想讓妳這麼做啦，",
        "unit_id": 1411,
        "voice": "vo_adv_1017010_027"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "但就像剛才說過的，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "我是湊巧抵達那座島嶼的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n那是發生在",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "一場漫長航行中的巧合。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "如果循著同一條航路去找找看，",
        "unit_id": 1411,
        "voice": "vo_adv_1017010_028"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n應該就能夠找到……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "但我想那恐怕",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "得要花上不少時間。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大概",
        "unit_id": 101711,
        "voice": "vo_adv_1017010_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "會花上多久的時間……？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "就算一切順利，",
        "unit_id": 1411,
        "voice": "vo_adv_1017010_030"
    },
    {
        "type": "dialogue",
        "name": "船長",
