    {
        "type": "dialogue",
        "name": "碧",
        "words": "等我交到很多朋友，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不再是邊緣人後……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\nBB團肯定會消失……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我確實是",
        "unit_id": 104011,
        "voice": "vo_adv_1040012_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "想要朋友……",
