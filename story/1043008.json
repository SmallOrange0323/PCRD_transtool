[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉唉啊啊啊……",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好鬱悶，好想死。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，不能擺出這麼陰沉的表情呢。",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "明明天氣難得這麼好……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看，索爾之塔比平常看得更清楚哦♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉唉啊啊……",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n嗯？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n幹嘛啊，{player}？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉呢，雖然今天也請你來幫忙撿街道上的垃圾～",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我卻一直笨手笨腳，害工作完全沒有進展呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊，嗯。沒事的，不要擔心。",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我啊，是不太會被負面情緒牽著走的人～",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n到了明天，我就會忘得一乾二淨了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗚嗚。",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不過常常像這樣，就把重要的事情忘光光……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我會不會惹惱「那傢伙」，然後就被討厭呢？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哇哇，垃圾袋的中間裂開了……",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗚～今天真是倒霉的日子。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n地上也沒有多少垃圾，今天就先撤退吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}，才剛過中午沒多久……",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n回家的路上要不要去哪裡玩玩？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "拜託啦～我還不想要回家啦～！",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就當作是幫我，好嘛好嘛♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哇哇？",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n又是那道光，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好刺眼！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這到底是什麼啦，真讓人不舒服！？",
        "unit_id": 104311
    },
    {
        "type": "background",
        "background": "510180"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊，嗚嗚……",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n好鬱悶，好想死。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n哦哦，{player}……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你這傢伙，來屋頂上做什麼啊？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～？今天啊，",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我想要一邊看著風景發呆一邊吃午飯啦。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "教室裡頭很吵呢，我想一個人稍微想點事情。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}，你這傢伙也一樣嗎？",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n屋頂上有時候會有像我一樣的不良學生逗留，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以不要隨便靠近哦。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊？不要用問題來回答問題啦，{player}。",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你啊，該不會是因為擔心我無精打采……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n從教室跟著我到這裡來的吧？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是搞不懂你呢……",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們是朋友嗎？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不是吧？",
        "unit_id": 104331
    },
    {
        "type": "still",
        "still": "104300801"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦！？",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n好危險，怎麼突然來這一陣強風啊？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n剛剛差點就失去平衡、不小心掉下去！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……喂喂，{player}。",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你看到了嗎？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我在問你是不是看到我的內褲了啦！",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你沒有看？",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "才怪！從你這傢伙站的位置和角度，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n想也知道怎麼可能沒看到呢！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～你真的沒有看到嗎？",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n哼……不過像我這種毫無魅力的傢伙，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就算拜託你看我的內褲你也不想看吧？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒有那種事？",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你說我很有魅力？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你說我臉很漂亮，身材又很好……？",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "說什麼啊真是噁心，誇獎我你什麼也得不到哦？",
        "unit_id": 104331
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，算了。",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n和{player}亂聊一下子後，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我覺得心裡舒服多了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "果然，任何事都不能一個人承受呢。",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，雖然不是什麼大事……",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我和妹妹吵架了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原因是我打破要和她一起去買東西的約定就是了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但那是因為有推也推不掉的事情要辦……",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不過啊，整體來說全都是我的錯呢。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我知道我應該乖乖道歉啦。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要讓她心情好起來，改天得和妹妹一起去買東西，",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n然後買個她喜歡的東西送她吧。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過能讓女孩子開心的東西，說真的我也不太清楚。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "欸，你說熊的布偶就可以了嗎？",
        "unit_id": 104331,
        "voice": "vo_adv_1043008_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂，為什麼你會說出熊這個詞啊？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你這傢伙，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "果然看到了吧，我的小熊內褲……！？",
        "unit_id": 104331
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小、小熊內褲……！",
        "unit_id": 190011,
        "voice": "vo_adv_1043008_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊哈哈，真琴真是令人意外地有女孩子的一面……☆",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後呢，你真的看到了嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1043008_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "快點老實說出來，快點快點♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要是看到了，等等得好好道歉哦～？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要是錯過道歉的時機，",
        "unit_id": 190011,
        "voice": "vo_adv_1043008_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n之後會連「對不起」也說不出來……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n說不定就會一直後悔陷入煩惱當中，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對吧。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦！？",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_032"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你怎麼了啊，突然睡著又醒過來！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而且你還突然，下跪……？",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_033"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還說「對不起」？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼要道歉啊，我完全搞不懂？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你完全沒有理由道歉哦，{player}。",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_034"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你總是來幫我工作……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n反倒是我，對你只有滿滿的感謝呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊哈哈。我也來學學{player}，",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_035"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不管是下跪也好其他方式也好，我都要道歉得到原諒呢……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n一直猶豫不決地煩惱將問題拖延下去，這也不像我。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_036"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我稍微和妹妹吵架了，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n所以就有點消沉。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "回家之後，我會馬上道歉的哦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_037"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n去買個禮物來讓她開心好了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是你有空就陪我去吧，{player}。",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_038"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們去店鋪之類的地方逛逛，一邊選送妹妹的伴手禮，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n一邊四處晃晃玩耍吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只有工作的人生，其實非常寂寞呢～♪",
        "unit_id": 104311,
        "voice": "vo_adv_1043008_039"
    }
]