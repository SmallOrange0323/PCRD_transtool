[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你的故事，可終於開始了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這故事，究竟會是悲慘結局，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還是好結局呢？也許就只有老天爺才知道呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，你光是處理眼前所發生的事情都快忙不過來了……",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該會有點搞不清楚狀況。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因此，就由我來幫你補充一下吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為此，",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "才會有這個你與「幕間」的我的對談唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但對你來說，這就像是夢境一般的事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以大概很快就會忘了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還有些期待你會記得任何一點事情，而注意了措辭呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……總而言之，得從前提開始說起呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "身為喪失記憶的主角你，和你的隨從可可蘿，",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n約莫在蘭德索爾打著零工，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n且一面在旅館裡頭生活了一個月唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "順帶一提，可可蘿以外的女孩子……也就是貪吃佩可她們，",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在你們開始在旅館生活之前，就和你們先暫時分別了唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但畢竟生活於同個街上，偶爾也會碰巧見上一面就是了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而在這期間，你和許許多多的女孩子們相遇了。",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "大略估算一下，你至少和四十人以上的女孩子認識了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你與她們談話、交流著，且逐漸與她們培養出了感情唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦？你說你沒有那個記憶？",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的是這樣嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "仔～細一點回想看看吧。",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n試著稍微認真點從腦海裡去翻找一下那些記憶，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該就能回想起，你和那些女孩子們的相遇，還有交流的故事了唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然從她們的發言中，冒出了些你沒有印象的單字……",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但也說不定，你其實早就已經聽聞過了那些單字，還請她們教過你了呢",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "綜合了那些情報，還有你自身的經歷與經驗……",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你必須要去解開這世界、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還有你自身的謎團。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這也是你，為了你自己必須該做的呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且這也是為了導正這個，扭曲又奇怪的世界喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……哎呀，可不行像這樣從一開始就悠悠哉哉的聊起天了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這長篇大論，就先到這告一段落吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你呀，就盡情享受這屬於你的故事吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟這可是你的人生呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2001000_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但若遇上了瓶頸，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也會適時的伸出援手的啦。",
        "unit_id": 190011
    }
]