[
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "此時，與流夏和七七香分別的{player}，\n與杏奈一同抵達了洞窟。"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呼～",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒想到才剛到達就準備了食物給我們吃，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n真是太棒的職場了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "工作的幹勁都湧上來了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "而且工作內容，",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還只要在洞窟裡挖掘，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這樣簡單的工作――",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "啊啊啊呀，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "抱歉。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "哦，",
        "unit_id": 911,
        "voice": "vo_adv_5008002_002"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "小心點――",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這男人感覺真壯碩呢……",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n剛才的人，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好像在哪見過……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你對那男人的臉有印象嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "總覺得",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我的宇宙本源很在意那個人啊。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "通緝犯？　",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對啊",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "通緝令！　",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "難怪我會覺得似曾相識！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你記憶力真好呢，吉格魯特！　",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "幫大忙了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你、",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你說什麼～！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "欸？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你不是失去記憶嗎，吉格魯特！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不對，",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不是在說這個！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我記得那傢伙……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對啦，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是通緝犯！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "站住，你這傢伙！　",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_008"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你就是被通緝中的通緝犯吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "這麼說來，妳……",
        "unit_id": 911,
        "voice": "vo_adv_5008002_009"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "不就是移動龍卷風嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "怎麼，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "想在這裡打嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你明白的話就好辦了。",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_010"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你就懾服於我強大的力量下，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n化為饗宴的祭品吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "那邊那兩人！　",
        "unit_id": 1111,
        "voice": "vo_adv_5008002_011"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "你們在做什麼！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "\n這裡禁止私鬥！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "通緝犯可就在眼前啊？　",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_012"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "而且觸犯禁忌就是我的――",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "如果這麼做，會拿不到薪水喔！",
        "unit_id": 1111,
        "voice": "vo_adv_5008002_013"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "\n那樣也沒關係嗎！？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那、",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_014"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那樣就傷腦筋了……！　",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我好不容易才到這裡來的，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n怎麼能沒拿到打工錢就默默回去……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不對，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "果然還是應該無視規定，打倒眼前這傢伙才對……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "撿回一條命了。",
        "unit_id": 911,
        "voice": "vo_adv_5008002_015"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "再會啦！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "啊，",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_016"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "可惡，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "難得獎金自己送上門了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒辦法了……",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_017"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "專注在工作上吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呼……",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_018"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呼。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "工作是很單純，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n可是要像這樣持續不斷挖洞，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還真難熬……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_019"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你那裡如何？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那是因為你一直在搬運我挖掘的土石啊。",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_020"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "會累也是當然的……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "謝謝你這麼努力，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這麼說來，",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_021"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我沒問過什麼時候休息呢。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n就在這裡刻下休息之時吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哈啊，",
        "unit_id": 1,
        "voice": "vo_adv_5008002_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哈啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哈啊……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你怎麼了，吉格魯特？",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_023"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎麼突然變得這麼喘。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你有這麼累了嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "奇怪，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喘的人不是吉格魯特。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是誰啊……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是這個男人啊……！",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_024"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喂，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎麼了？　",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "振作點啊！！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "因為一直沒有休息，",
        "unit_id": 311,
        "voice": "vo_adv_5008002_025"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "所以頭暈了而已……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "謝謝。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "我沒見過",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "你們呢……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們是今天才來的。",
        "unit_id": 100911,
        "voice": "vo_adv_5008002_026"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "今後請多指教。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "妳說今天才來的……！？",
        "unit_id": 311,
        "voice": "vo_adv_5008002_027"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "妳、",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "妳可以靠過來點嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "我不會害妳們的。",
        "unit_id": 311,
        "voice": "vo_adv_5008002_028"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "你們最好",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "快點逃走比較好。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n這裡是——",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "喂！　",
        "unit_id": 1111,
        "voice": "vo_adv_5008002_029"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "你們在那裡做什麼！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "對、",
        "unit_id": 311,
        "voice": "vo_adv_5008002_030"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "對不起！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "我腳滑了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n",
