[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "忍和{player}在蘭德索爾散步時，\n突然被奇妙的光芒環繞。"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "又是這道光……好、好刺眼……",
        "unit_id": 103111,
        "voice": "vo_adv_1031008_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呀！",
        "unit_id": 103111,
        "voice": "vo_adv_1031008_001"
    },
    {
        "type": "background",
        "background": "510351"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，{player}，你好。",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我現在在做什麼嗎？我在看雜誌。",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這本靈異週刊很有趣唷。",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對吧，爸爸？",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……爸爸？",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……不好了。不知道什麼時候，",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我父親被掉包成假貨了。",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看來是被偷走了。",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不會的。",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n因為我父親沒有半個粉絲，所以那是不可能的。",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我想那也不可能。",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為幾乎沒有人會相信，",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n那個骷髏頭是我的父親。",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我想這可能是某個骨董仲介商搞的鬼，",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n一定是想把我父親賣到某個地方。",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我父親附身的骷髏頭，做為「椿丘水晶骷髏頭」，",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_009"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n被認為是古代文明的時代錯置古文物而引起了話題。",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過實際上那只是父親在路邊攤買的便宜貨。",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，{player}，請等一下！",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_011"
    },
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼…",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "…\n{player}……請……請等一下……",
        "unit_id": 103133
    },
    {
        "type": "background",
        "background": "510101"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼、呼……",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}……等、等等我……",
        "unit_id": 103133
    },
    {
        "type": "background",
        "background": "510351"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼、呼……",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼啊……",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "總算追上你了……",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個，不知道犯人的長相和服裝的話，",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n要找出來實在太困難了。",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不用了。在這個城鎮，",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我想我會比警察更快找到犯人。",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就交給我吧。",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這裡可是有很多只有我能對話的目擊者。",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你看。",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "跟在{player}後面的女性也說，",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n她看到犯人了喔。",
        "unit_id": 103133
    },
    {
        "type": "background",
        "background": "510281"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "嘿嘿嘿……",
        "unit_id": 1331,
        "voice": "vo_adv_1031008_019"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "\n用這個傳聞中的骷髏頭，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "\n來大撈一筆吧。",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "找到了。",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_020"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n你就是偷走我父親的犯人吧。",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n把我父親還來。",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "呿！被發現了嗎！？",
        "unit_id": 1331,
        "voice": "vo_adv_1031008_021"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "別來妨礙我，快滾到一邊去！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "！",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "嘿，妳就乖乖地倒在那裡吧！",
        "unit_id": 1331,
        "voice": "vo_adv_1031008_023"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "\n後會無期啦！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "……嗯？骷髏頭變紅了――",
        "unit_id": 1331,
        "voice": "vo_adv_1031008_024"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "好燙燙燙燙！",
        "unit_id": 1331,
        "voice": "vo_adv_1031008_025"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "\n搞、搞什麼啊，怎麼回事！？燙得拿不了啊！？",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一定是因為小偷揍飛了我，所以我父親生氣了。",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_026"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "好、好恐怖的骷髏頭……",
        "unit_id": 1331,
        "voice": "vo_adv_1031008_027"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "這種鬼玩意兒我不要了啦！！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，小偷逃走了。",
        "unit_id": 103133,
        "voice": "vo_adv_1031008_028"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103133
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過既然我父親平安無事回來，也不用去追他了。",
        "unit_id": 103133
    },
    {
        "type": "still",
        "still": "103100801"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "太好了，爸爸。",
        "unit_id": 103132,
        "voice": "vo_adv_1031008_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這個人幫忙我一起找你喔。",
        "unit_id": 103132
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以爸爸也向他道謝吧。",
        "unit_id": 103132
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯嗯……",
        "unit_id": 103132,
        "voice": "vo_adv_1031008_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103132
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我父親說，",
        "unit_id": 103132
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103132
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「我說過不准再接近忍了吧！我宰了你喔！」",
        "unit_id": 103132
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸真是的，這麼害臊啊。",
        "unit_id": 103132,
        "voice": "vo_adv_1031008_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這次多虧了",
        "unit_id": 103132,
        "voice": "vo_adv_1031008_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "聚集在這裡的眾多幽靈們，",
        "unit_id": 103132
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n才能順利地找到我父親。",
        "unit_id": 103132
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "竟然有這麼多的幽靈一起來幫忙……",
        "unit_id": 103132,
        "voice": "vo_adv_1031008_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這都是因為你平常做人很成功的關係。",
        "unit_id": 103132
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真是太了不起了，{player}。",
        "unit_id": 103132,
        "voice": "vo_adv_1031008_034"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "自己的父親被偷走卻沒發現……",
        "unit_id": 190011,
        "voice": "vo_adv_1031008_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n忍也真是個隨性的孩子呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但還好最後順利找回來了～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？這是我給你的禮物！ 你做了個好「夢」嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1031008_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是我依照你跟忍以前的記憶創造出來的「夢」，",
        "unit_id": 190011,
        "voice": "vo_adv_1031008_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n原來現在的你會採取這樣的行動呀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我看了也很開心呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～ ♪",
        "unit_id": 190011,
        "voice": "vo_adv_1031008_038"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……啊，{player}，",
        "unit_id": 103111,
        "voice": "vo_adv_1031008_039"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n你醒來了嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也是剛剛才醒來喔。",
        "unit_id": 103111,
        "voice": "vo_adv_1031008_040"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n和上次一樣，我夢到了一個奇妙世界。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n{player}也做了一樣的夢嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……這樣呀。",
        "unit_id": 103111,
        "voice": "vo_adv_1031008_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n果然是很不可思議的夢呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這會不會是某種心電感應呢？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，{player}。",
        "unit_id": 103111,
        "voice": "vo_adv_1031008_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你在夢裡面也幫了我找到父親，謝謝你。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你在夢裡面也很溫柔呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "忍和{player}的心中都想著，\n想再做一些這令人感覺奇妙又懷念的夢。"
    }
]