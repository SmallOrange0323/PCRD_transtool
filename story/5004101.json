    {
        "type": "dialogue",
        "name": "花凜",
        "words": "【美食殿堂】的各位，",
        "unit_id": 190811,
        "voice": "vo_adv_5004101_000"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "晚安！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "現在",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "正在舉辦抽獎活動，有機會獲得豪華獎品喔，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n要不要來挑戰看看啊？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "抽獎？　",
        "unit_id": 106012,
        "voice": "vo_adv_5004101_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種東西不會中的吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留、小凱留！",
        "unit_id": 105812,
        "voice": "vo_adv_5004101_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想要那個三獎的高級水果禮盒！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算妳目標那麼明確也抽不中啦！",
        "unit_id": 106012,
        "voice": "vo_adv_5004101_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正是免費的……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就試試看吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您加油，",
        "unit_id": 105913,
        "voice": "vo_adv_5004101_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好啦好啦，",
        "unit_id": 106012,
        "voice": "vo_adv_5004101_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喀啦喀啦～。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "可惜！\n白球是沒中的意思喔～",
        "unit_id": 190811,
        "voice": "vo_adv_5004101_006"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就當作是安慰獎給妳一顆糖果♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，是食物！",
        "unit_id": 105812,
        "voice": "vo_adv_5004101_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真羨慕小凱留，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "中了大獎呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～我也來抽！　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喀啦喀啦～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "哦，哦哦！　是金球！\n",
        "unit_id": 190811,
        "voice": "vo_adv_5004101_008"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "恭喜您！　抽中大獎了～♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請收下",
        "unit_id": 190811,
        "voice": "vo_adv_5004101_009"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "頭獎「迷人的南國之旅」的招待券！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n四天三夜，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "祝妳在度假區玩得愉快！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n可以參加的名額有四個人喔～♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "南國旅遊！？",
        "unit_id": 106012,
        "voice": "vo_adv_5004101_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳太厲害了耶！　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是頭獎耶，頭獎！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真不愧是",
        "unit_id": 105913,
        "voice": "vo_adv_5004101_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚……",
        "unit_id": 105812,
        "voice": "vo_adv_5004101_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "高級水果禮盒……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳在說什麼啊！　",
        "unit_id": 106012,
        "voice": "vo_adv_5004101_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和水果比起來，絕對是南國比較好吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，妳當然會邀請我們一起去的對吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那是當然的！",
        "unit_id": 105812,
        "voice": "vo_adv_5004101_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就讓我們【美食殿堂】的成員一起去吧～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "蔚藍的大海、",
        "unit_id": 106012,
        "voice": "vo_adv_5004101_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "白色的沙灘、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "耀眼的太陽！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n最棒的夏天",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正在等著我們～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可・可可蘿・凱留",
        "words": "下一回，",
        "unit_id": 1,
        "voice": "vo_adv_5004101_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可・可可蘿・凱留",
        "words": "「危險的假期！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可・可可蘿・凱留",
        "words": "　海岸邊的美食家公主」",
        "unit_id": 1
    }
]