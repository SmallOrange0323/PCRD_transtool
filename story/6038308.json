        "voice": "vo_adv_6038308_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在我調查的結果中，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你與女性的交友關係應該相當廣泛才是。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n如同我以前問過的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那裡面有沒有能與我這孤傲的精神產生共振的靈魂呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "以前也說過了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是和我很相像的人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "常會因為被誤認為小孩而發火？",
        "unit_id": 111011,
        "voice": "vo_adv_6038308_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呵呵，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "太年輕了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我反而是會將其加以活用\n的人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這身體的稚嫩，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是鏡像及量測值所呈現的事實。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
