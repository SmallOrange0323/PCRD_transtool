[
    {
        "type": "background",
        "background": "500881"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聖誕節",
        "unit_id": 127911,
        "voice": "vo_adv_5132411_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "結束了呢。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像這樣看著收拾工作，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就更加確實感受到了……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 127911,
        "voice": "vo_adv_5132411_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會感到如此寂寥，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是之前也同樣開心的證明吧！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您說的沒錯呢。",
        "unit_id": 6111,
        "voice": "vo_adv_5132411_002"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我也因為得以",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "充分看到面對麻煩",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n手忙腳亂的克蕾琪塔小姐",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "而感到非常滿足。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我把那扭曲的快感藏在心裡！",
        "unit_id": 128011,
        "voice": "vo_adv_5132411_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不過啊，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我為了僅僅一天的聖誕節",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n拼命準備至今，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "所以果然確實會有寂寥感呢。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "──真的只是那樣嗎？",
        "unit_id": 6111,
        "voice": "vo_adv_5132411_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳有說什麼嗎？",
        "unit_id": 128011,
        "voice": "vo_adv_5132411_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不，",
        "unit_id": 6111,
        "voice": "vo_adv_5132411_006"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "沒什麼。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……我稍後會堵住秘書一號那口無遮攔的嘴。",
        "unit_id": 128011,
        "voice": "vo_adv_5132411_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "讓陛下有寂寥的感受可是嚴重的事態，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n所以，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還請陛下這之後稍微陪我一下。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 127911,
        "voice": "vo_adv_5132411_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以是可以，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但究竟要做什……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我招呼了這次協助的人來慶功宴！",
        "unit_id": 128011,
        "voice": "vo_adv_5132411_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n雖然也能以讓人回味的感傷作結，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但果然必須",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要讓陛下常保笑容才行！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "費用出自克蕾琪塔小姐的個人財產，",
        "unit_id": 6111,
        "voice": "vo_adv_5132411_010"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "所以還請",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "盡情吃喝吧。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哼，",
        "unit_id": 128011,
        "voice": "vo_adv_5132411_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳以為我會因為那種話而慌亂嗎？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "錢這種東西，不管再怎麼花，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也只要用完再賺就好了！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……欸嘿嘿，",
        "unit_id": 127911,
        "voice": "vo_adv_5132411_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "結果從頭到尾，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我都一直在依靠克蕾琪塔小姐呢。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那我就感謝妳的好意，",
        "unit_id": 127911,
        "voice": "vo_adv_5132411_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不客氣地盡情享受了☆",
        "unit_id": 127911
    }
]