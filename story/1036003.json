[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正在散步途中的{player}，\n看見了正在嘆息的鏡華。"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哎……好煩啊。",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊。{player}\n午安。",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……你問為什麼我在嘆氣？　",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "其實呢……最近學校有個吊單槓的考試……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可、可是……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "翻上槓。我到現在都還是做不來。",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "全班就只有我一個人翻不上去，所以正憂鬱著呢……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好的，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不用了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "若因為我個人的問題，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而佔用到{player}的時間，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就太不好意思了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且……",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}看起來，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不是很靠得住……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "很會吊單槓嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦！？單槓跟翻上槓都不知道是什麼嗎！？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真虧你這樣還說著要幫忙啊……",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "聽好了喔？所謂的翻上槓啊，",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就是手握著單槓，然後把身體給翻上去的招式喔。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "對對，就是像這樣握著……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……聽不懂所以要我示範給你看？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以說！我就是不會啊！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒錯沒錯。就是像那樣把腳往上踢，",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n然後再把單槓拉向自己的胸口……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊！　",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "翻、翻上去了呢……",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯嗯，沒有錯。這就是我說的翻上槓。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "竟、竟然這麼輕鬆就……總覺得深受打擊呢……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以說，我自己一個人練習就可以了啦！",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你就趕快回去啦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇呀",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請、請不要隨便就把人家舉起來啊！",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我懂了啦！會讓你幫忙的啦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你就在旁邊給我一些建議就好了！",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哈啊哈啊……",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_014"
    },
    {
        "type": "background",
        "background": "500021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哈啊……",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哈啊哈啊……",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哈啊……",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哈啊……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哈啊哈啊……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還、",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還是不行……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n明明{player}，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼輕鬆就翻上去了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真、真好呢，像你這樣。",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n憑你那高大的身材，又有力量……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就只是個翻上槓，當然做得到嘛！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "像、像我身高這麼矮，又還只是個小孩子……",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "翻不上去也是理所當然的！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦？你說全班裡不是就只剩下我一個人做不到嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那、那個是……是因為……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，我！回精靈之森的馬車就快要開了，",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以我差不多該回去了呢！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "再見！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "明、明天嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "練習什麼的，已經夠了啦。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n還讓你得繼續陪著我也不好意思。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……我，",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我明白了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "既然",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}都這麼說了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n那麼，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "明天就也在這裡。",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "翌日──"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哎……翻上槓的練習，我一點也不想去啊……",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n絕對練不好的……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "媽媽，早安。",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？怎麼了嗎？這麼慌張？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n今天往蘭德索爾的馬車取消了嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n蘭德索爾正下著大雨，所以整條路都濕了，因此馬車跑不了？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是這樣啊……啊！",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這麼說來，吊單槓的練習也得「取消」了呢！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n再怎麼說，我也沒辦法去蘭德索爾了嘛。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這也是沒辦法的事呢，",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_028"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "得要通知{player}，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "取消今天的特訓呢！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "媽媽，我想要用遠距離通訊魔法，",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n可不可以支援我一些魔力呢？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "通訊魔法對我來說還太難了，一個人還做不好……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……………………",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，能聽見我的聲音嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我是鏡華。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n現在正用著通訊魔法和你通話。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……嗯嗯，看起來你那邊正下著大雨呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雨聲大到就連這邊都聽得到喔。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個……雖然今天有約好說要陪我來練習，",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_033"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n可是現在我過不去了呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為大雨所以馬車都被取消了，已經沒辦法出發去蘭德索爾了喔。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真～的是非常遺憾。原本很想練習的呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_034"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是，沒有馬車能夠去的話，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n也是沒辦法的嘛。那就先……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦？你說那你要來精靈之森這裡？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_035"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以不是說了嗎？馬車都被取消了啊。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就算你說，你想從蘭德索爾過來也……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦？還聽的見嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_036"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n喂？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "魔、魔法被中斷了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "遠距離魔法是種相當高級的魔法，",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_037"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n如果對方移動了，就會無法順利通訊了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "一定是那個人，開始移動了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……移動？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_038"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "該，該不會！真的是往這邊過來了嗎！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n難道說用走的！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是蘭德索爾離這裡這麼遠！還下著大雨！",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_039"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n道路也被大雨沖得都是泥濘！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "再怎麼說也……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可、可是……如果是那個人的話，說不定真的……",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_040"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然是個怪人，但很溫柔……",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_041"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n雖然沒什麼常識，但很溫柔……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n雖然看起來傻傻的，但很溫柔……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "很溫柔……",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_042"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我、我……！",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_043"
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "background",
        "background": "500191"
    },
    {
        "type": "background",
        "background": "500192"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……哎。沒想到你真的會來。",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_044"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你花了幾個小時，才走到這裡的啊！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……你說趕緊來練習？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_045"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "說到這個，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}，其實呢……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_046"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你要示範給我看？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所、",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以先聽我說！{player}，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "其實，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "！！！",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_047"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}為什麼翻不上去了？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_048"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎麼了嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n果然是走得太累……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你、你這不是受傷了嗎！",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_049"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你說因為道路太濕滑所以摔了一跤？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的！才說你是傻了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真的是個大傻瓜呢……",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_050"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是……謝謝你。",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_051"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}，看好囉？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_052"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n翻上槓是要這樣做的！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎、怎樣呀！這才是翻上槓喔！",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_053"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哼哈哈，看來是被嚇到了吧。",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_054"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "其實，我已經學會了怎麼翻上槓了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "一想到，說不定你真的打算過來，",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_055"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我、我就坐著也不是，站著也不是……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "想著如果說要為你",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_056"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n做點什麼，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也就只能想到學會翻上槓而已……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "欸嘿嘿，所以就一直練習，直到剛剛終於可以翻上去了呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_057"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你、你在說什麼呀！",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_058"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果有誰一定要道謝的話，那也應該是我才對啊！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真、真的嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_059"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝、謝謝你的誇獎。這都是多虧了你喔。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "總、總而言之，請先到我的家來吧。",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_060"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n還得先處理一下你的傷口呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊……但是也很晚了，",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_061"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n如果現在要回蘭德索爾也太危險了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n而且也沒有馬車可以坐。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真、真拿你沒辦法呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_062"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n今天，就讓你在我家借住個一晚吧。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但，",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_063"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "精靈族可是相當保守的。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "若不小心被媽媽他們看到的話，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n說不定會被趕出去……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "只、",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_064"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "只能對媽媽都保密，偷、偷偷讓你在我的房間裡過一晚了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚、嗚嗚……可，可是……這、這有一點……",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_065"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但……也沒有別的辦法……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……嗚～～～～！！！",
        "unit_id": 103611,
        "voice": "vo_adv_1036003_066"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然而，最後卻輕而易舉地就讓母親給識破了。而{player}，\n則受到了鏡華家的熱烈款待，最後在客房悠閒地度過了一晚。"
