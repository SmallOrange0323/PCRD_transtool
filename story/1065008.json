        "voice": "vo_adv_1065008_075"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "安心下來了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n有你這個死黨在，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我還真是個幸福的人啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼！",
