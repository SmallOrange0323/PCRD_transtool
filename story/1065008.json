        "voice": "vo_adv_1065008_070"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我睡著了嗎。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "感覺又做了奇怪的夢……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在夢中的我啊，",
        "unit_id": 106511,
        "voice": "vo_adv_1065008_071"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "又膽小，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "又柔弱……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒辦法跟任何人戰鬥。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n如果我變成那樣……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "光是想像就覺得害怕。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是啊，",
        "unit_id": 106511,
        "voice": "vo_adv_1065008_072"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不管發生什麼事，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有你在呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒必要擔心。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果真的到了那個時候，",
        "unit_id": 106511,
        "voice": "vo_adv_1065008_073"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你會好好",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "聽我說話吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我、",
        "unit_id": 106511,
        "voice": "vo_adv_1065008_074"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "很強……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這是當然的！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我可是職業打手喔？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……感覺",
