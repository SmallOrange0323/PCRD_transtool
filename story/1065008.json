        "voice": "vo_adv_1065008_076"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "繼續特訓吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n只要跟你一起，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我就能得到更強大的力量。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
