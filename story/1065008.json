    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "經過飲食店騷動後過了幾天，\n{player}被嘉夜叫出來，陪她一起特訓。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呼唔唔唔……",
        "unit_id": 106511,
        "voice": "vo_adv_1065008_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喝！",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯──",
        "unit_id": 106511,
        "voice": "vo_adv_1065008_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "果然和那時候不太一樣啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂，",
        "unit_id": 106511,
        "voice": "vo_adv_1065008_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你怎麼看呢？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎樣才能像",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我前幾天那樣",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "使用龍人族的力量呢……？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那次吵架的時候，",
        "unit_id": 106511,
        "voice": "vo_adv_1065008_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有確實感受到、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n自己的體內",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有比平時更強的力量存在。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "從身體裡面，",
        "unit_id": 106511,
        "voice": "vo_adv_1065008_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "力量好像要溢出來一般……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對對對，",
        "unit_id": 106511,
        "voice": "vo_adv_1065008_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就像這樣",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "全身發光……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "話說，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這是怎麼回事，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這個光！？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗚哇！",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "────假日{player}到遊樂中心，\n到處逛逛看機台思考著要玩什麼樣的遊戲。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長！",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊哈哈！",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嚇一跳吧？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "話說",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "難得的休假日，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你一個人來遊戲中心？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "獨自在遊戲中心玩……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "明明人很好但都常落單，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是稀奇耶……！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "抱歉，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "開玩笑的。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一個人在遊戲中心玩這件事，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我也是唷。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在家很無聊所以跑來這裡玩了，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過一個人的話，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "原本還覺得有點沒意思呢。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對了！",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "吶，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n跟我用機台比拳力一決勝負吧！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "輸家，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要請贏家吃甜食唷。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如何？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "來玩吧！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "難不成，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你覺得自己會輸嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "太好了！",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那就決定了唷！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長還滿意外地",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不服輸耶。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼學長先來吧。",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "上吧～！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長──",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "加油～♪",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "輕量級……？",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咦咦咦～？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這是怎麼了學長～",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "難不成",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你想對我手下留情嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不用客氣沒關係的！",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還是，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你那麼想請我嗎？",
        "unit_id": 106531
    },
    {
        "type": "still",
        "still": "106500801"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼接下來",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "輪到我了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n如此一來，我就要贏了唷……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可以嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯～",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_016"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "說出這種話真的好嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n雖然直接比我也能輕鬆贏，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但我改變心意了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長居然會擔心我，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_017"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是太貼心了～！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是那樣一來，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我的實力",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就會被低估吧？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長是認真的話，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_018"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我也會認真的。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你可別後悔唷……？",
        "unit_id": 106531
    },
    {
        "type": "still",
        "still": "106500802"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喝啊啊……",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_019"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘿！",
        "unit_id": 106531
    },
    {
        "type": "still",
        "still": "106500803"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "鏘鏘～！",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_020"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "重量級！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我贏了──！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n所以，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是學長請客～♪",
        "unit_id": 106531
    },
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要讓學長請什麼好呢……",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "冰品嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "蛋糕？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "聖代？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可麗餅？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不對，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "果然全部都要！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒事啦，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "騙你的。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "快點，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "走吧！",
        "unit_id": 106531
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊──",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天和學長在一起好開心呢──！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "久違出拳心情很舒暢呢！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……因為是遊戲，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_023"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以可以放心的出拳。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嘉夜……？",
        "unit_id": 1,
        "voice": "vo_adv_1065008_024"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咦？",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_025"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "好久不見──！",
        "unit_id": 1,
        "voice": "vo_adv_1065008_026"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "妳好嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "這陣子在做什麼呢？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊……",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_027"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我很好。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳呢？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我也很好唷！",
        "unit_id": 1,
        "voice": "vo_adv_1065008_028"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "妳最近沒來道場，還很擔心妳呢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n那個，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "這位是？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "啊……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "不好意思呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "該不會，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "正在約會嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊哈哈，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_029"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是啦。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我跟學長才不是那樣的關係。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n只是單純一起玩遊戲的朋友。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n……對吧，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "啊哈哈，",
        "unit_id": 1,
        "voice": "vo_adv_1065008_030"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "抱歉抱歉！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "你好，初次見面！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n我呢，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "是嘉夜的好朋友唷。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "剛練習完要回家的路上，",
        "unit_id": 1,
        "voice": "vo_adv_1065008_031"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n沒想到能碰到嘉夜真是太好了～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "真的很開心啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "喂嘉夜。",
        "unit_id": 1,
        "voice": "vo_adv_1065008_032"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "下次來道場玩吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n老師們也很想念嘉夜呢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯……",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_033"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯、",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果我剛好想去的話。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不好意思。",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_034"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "趕著要去一個地方。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n那麼……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "再見啦。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "掰掰。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯！",
        "unit_id": 1,
        "voice": "vo_adv_1065008_035"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "再見！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "掰掰──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……學長。",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_036"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "甜食就先取消吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n作為替代",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "想請你陪我一下。",
        "unit_id": 106531
    },
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝你願意陪我，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_037"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n那我們稍微走一下吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_038"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……學長。",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_039"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不好意思呢，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n能稍微聽一下",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我說話嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "才不會講那麼久啦，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_040"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "放心吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那也",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是我想說得很冗長的事。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是的～",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_041"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼可能需要那麼久啦！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……學長呀，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的很不會開玩笑呢。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我有稍微覺得輕鬆一些。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "剛剛的女生啊，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_042"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是我的空手道夥伴。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "從小都一起去道場，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "兩個人總是互相競爭。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我會開始學空手道，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_043"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n是因為不想被很會打架的大哥一直保護著，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n自己也想變強……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是我",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_044"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "跟天賦異稟的大哥不同，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我沒有才能。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n所以我透過不斷練習，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "把自己練強到可以參加全國大會的比賽。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "很厲害吧？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在去年大會決賽……",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_045"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我贏了她，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "成為了冠軍。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "當下當然很開心啊。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為超高興的。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "原本以為她也會祝賀我。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是和她互相敬禮後，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_046"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我看到她悔恨哭泣的表情，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一直以來",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在我心中",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "想要變強的心情，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n突然消失得",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "無影無蹤了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然我不是第一次贏過她，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_047"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n也有輸給她過呢。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "從那之後別說比賽，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_048"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就算是練習，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只要站在對手面前，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我就越來越無法出拳了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "結果我就放棄空手道，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_049"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "開始閒得發慌……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不知道什麼時候開始，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我的治療師推薦我玩阿斯特朗傳奇。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n等我發現時已經玩得很入迷，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "轉生成",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "龍人族了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我啊，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_050"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一玩起阿斯特朗傳奇的時候，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n不論是怪物或是刻意來PK的玩家，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我都可以很平常心的揍人唷？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_051"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "回到現實",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就完全做不到。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不管對方是誰都無法出拳。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "身體變得僵硬……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "僵硬到就連自己",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "都會想笑的程度。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可能因為在阿斯特朗傳奇的我並不像我，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_052"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以沒問題吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我想既然如此，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還稍微",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "改變過髮型之類的呢。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "難不成，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "像遊戲裡那樣比較好嗎。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……遊戲很棒呢。",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_053"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "即使對戰，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "實際上也不會有人受傷。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n想變強的話，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要多強就能變得多強。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "空手道呀，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_054"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為討厭和朋友比賽，導致我無法繼續對戰了，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n繼續苦撐下去，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也沒辦法變成多優秀的選手吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……其實我以前，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_055"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是想變強到能把大哥打倒，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n想練到那麼強悍的程度呢。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_056"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我想講的話講完了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天就回家吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "甜食",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "等下次見面時再請我吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "願意聽我說這些，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_057"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝你呢，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我很高興。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……學長。",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_058"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是溫柔……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而是天真唷。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是嗎，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_059"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "或許吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不想傷害對戰的對手，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你不覺得很矛盾嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "結果，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我還滿天真的呢。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長你呀，",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_060"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是無底限的老好人呢？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就連我沉浸感傷中自己講個不停，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你也是溫柔的對待我呢。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是",
        "unit_id": 106531,
        "voice": "vo_adv_1065008_061"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是因為這點，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "覺得很帥氣唷。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "再見啦。",
        "unit_id": 106531
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1065008_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我呀，",
        "unit_id": 190011,
        "voice": "vo_adv_1065008_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在上次的戰鬥中，看到嘉夜的龍人族力量覺醒時，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n感到非常不安呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我當時在想，",
        "unit_id": 190011,
        "voice": "vo_adv_1065008_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她會不會被那股力量吞噬呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是看到你們在那個世界相處的情形，",
        "unit_id": 190011,
        "voice": "vo_adv_1065008_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我覺得應該沒問題。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "平時嘉夜那麼貪戰的理由，",
        "unit_id": 190011,
        "voice": "vo_adv_1065008_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n一定也是受到那邊的影響吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要繼續跟你在一起，",
        "unit_id": 190011,
        "voice": "vo_adv_1065008_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嘉夜也應該能控制住力量。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今後你也要好好",
        "unit_id": 190011,
        "voice": "vo_adv_1065008_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看著嘉夜唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為無法預測她今後會如何發展，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這點還是沒有改變呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011,
        "voice": "vo_adv_1065008_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "差不多時間到了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見啦。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯……",
