[
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看招！",
        "unit_id": 125014,
        "voice": "vo_adv_5110203_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天樓霸斷劍！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喝啊──！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "樂園守護者",
        "words": "──嘰喔喔喔！",
        "unit_id": 17111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呼～",
        "unit_id": 125014,
        "voice": "vo_adv_5110203_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣就行了，",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "話說回來，妳們兩位",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的很強呢！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啥？",
        "unit_id": 124911,
        "voice": "vo_adv_5110203_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "都什麼時候了，才在說這個……",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為",
        "unit_id": 125014,
        "voice": "vo_adv_5110203_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "之前都是跟城鎮居民對戰，",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n根本沒機會看到妳們認真戰鬥的模樣！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不管是戰鬥偶像還是打手，",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "果然都不是隨口瞎掰的！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這個嘛，",
        "unit_id": 124811,
        "voice": "vo_adv_5110203_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為戰鬥也是【慈樂之音】的重要工作啊！",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我要是認真起來，可不是只有這樣。",
        "unit_id": 124911,
        "voice": "vo_adv_5110203_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "等這場騷動結束後，我們來交手比試一下吧。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n如果是矛依未，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "應該可以打場讓人熱血沸騰的架呢！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 124811,
        "voice": "vo_adv_5110203_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這些就等一切全都結束後再說吧。",
        "unit_id": 124811
    }
]