    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "跟我不一樣。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "哼。",
        "unit_id": 193211,
        "voice": "vo_adv_1345004_059"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "反正那個個性──",
