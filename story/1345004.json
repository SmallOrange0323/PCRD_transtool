    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "……等等，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "我現在辦不到～！",
        "unit_id": 126431
