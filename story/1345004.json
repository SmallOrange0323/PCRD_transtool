    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嗶、",
        "unit_id": 134513,
        "voice": "vo_adv_1345004_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嗶────",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
