    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n只是配合嚮導職責被最佳化而已──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……應該",
        "unit_id": 193211,
        "voice": "vo_adv_1345004_060"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "是這樣才對。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n但是那孩子",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "最近變得有點會生氣，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n或是會感到悲傷……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "對吧。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真要說起來，",
