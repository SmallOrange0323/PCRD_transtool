    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "她就像是米奈娃初期型的原型樣板，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n就算具備學習功能也不奇怪。",
