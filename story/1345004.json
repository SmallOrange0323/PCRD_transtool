    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "加快速度果然很舒服呢～♪",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n騎士先生，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "請你好好抓緊我喔！",
