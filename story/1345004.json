    {
        "type": "dialogue",
        "name": "千惠",
        "words": "你肚子餓了嗎？",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "那我",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "來煮飯吧！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n我會為主人",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "做好吃的料理……",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "唔～？",
        "unit_id": 126431,
        "voice": "vo_adv_1345004_028"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n奇怪奇怪，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "為什麼我的肚子也發出了和主人一樣的聲音？",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "原來如此！",
        "unit_id": 126431,
        "voice": "vo_adv_1345004_029"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n這麼說來，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "我一直覺得肚子有種空虛的感覺！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "原來這就代表",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "肚子餓了呀～",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "……話說回來，",
        "unit_id": 126431,
        "voice": "vo_adv_1345004_030"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "料理要怎麼做呢？",
