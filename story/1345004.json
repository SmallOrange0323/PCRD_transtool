    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──某天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}在街上走著……"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "騎士先生──！！",
        "unit_id": 126431,
        "voice": "vo_adv_1345004_004"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n你好～～！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "我們又見面了呢，",
        "unit_id": 126431,
        "voice": "vo_adv_1345004_005"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "騎士先生！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n那個呀，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "我今天有一個請求！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "是的！",
        "unit_id": 126431,
        "voice": "vo_adv_1345004_006"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "好久不見♪",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n我想再見到騎士先生，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "所以一直在找你喔！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "然後我就發現你的背影，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "於是就跑過來了！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "沒錯沒錯♪",
        "unit_id": 126431,
        "voice": "vo_adv_1345004_007"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "其實呀──",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "我想請騎士先生",
        "unit_id": 126431,
        "voice": "vo_adv_1345004_008"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "當我的主人！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "路過的女性",
        "words": "主、",
        "unit_id": 1,
        "voice": "vo_adv_1345004_009"
    },
    {
        "type": "dialogue",
        "name": "路過的女性",
        "words": "主人……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路過的女性",
        "words": "\n（討厭，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路過的女性",
        "words": "是那種玩法……？）",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路過的男性",
        "words": "竟然是自己送上門的女僕！？",
        "unit_id": 1,
        "voice": "vo_adv_1345004_010"
    },
    {
        "type": "dialogue",
        "name": "路過的男性",
        "words": "\n真是無恥又讓人羨慕……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "怎麼樣呢？",
        "unit_id": 126431,
        "voice": "vo_adv_1345004_011"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n可以吧，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "騎士先生！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "不，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "主人～♪",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "雖然不太懂，",
