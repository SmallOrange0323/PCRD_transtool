        "voice": "vo_adv_1345004_013"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "這裡就是主人的家呀！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "啊，",
        "unit_id": 126431,
        "voice": "vo_adv_1345004_014"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "這麼說來，我還沒能說明呢！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n那個，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "我一直在找主人……",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "應該說，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "我一直在尋找Master。",
