    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "完全讓人摸不著頭緒……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "是下意識駭進周圍的裝置，並做了最佳化嗎？",
