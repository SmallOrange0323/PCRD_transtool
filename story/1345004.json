        "type": "dialogue",
        "name": "克蘿茜",
        "words": "呃，",
        "unit_id": 134513,
        "voice": "vo_adv_1345004_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "奇怪奇怪？",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n眼前",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "閃閃發光的！",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n視線感應器明明沒有異常，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "究竟是怎麼回事？",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "而且",
        "unit_id": 134513,
        "voice": "vo_adv_1345004_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "能量明明是騎士先生提供給我的，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n但好奇怪喔，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就像之前一樣，",
        "unit_id": 134513
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "突然進入了休眠狀態──",
        "unit_id": 134513
