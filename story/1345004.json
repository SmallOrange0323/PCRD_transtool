    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "好的♪",
        "unit_id": 126431,
        "voice": "vo_adv_1345004_031"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n我之前吃的飯菜做成了真空包裝，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n但如果是現在的我，",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "這次或許就可以正常飲食了！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "好的♪",
        "unit_id": 126431,
        "voice": "vo_adv_1345004_032"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n我開動了～！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "嚼嚼，",
