        "voice": "vo_adv_1345004_012"
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "但我知道了！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "我們走吧！",
        "unit_id": 126431
    },
    {
        "type": "dialogue",
        "name": "千惠",
        "words": "\n不管到哪裡我都會陪你同行的，",
        "unit_id": 126431
    },
