        "unit_id": 19711
    },
    {
        "type": "dialogue",
        "name": "審判狼蛛",
        "words": "\n判決──",
        "unit_id": 19711
    },
    {
        "type": "dialogue",
        "name": "審判狼蛛",
        "words": "死刑！",
        "unit_id": 19711
    },
    {
        "type": "dialogue",
        "name": "審判狼蛛",
        "words": "死刑！",
        "unit_id": 19711
    },
    {
        "type": "dialogue",
        "name": "審判狼蛛",
        "words": "死刑啊啊啊啊啊啊！！",
        "unit_id": 19711
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……",
        "unit_id": 136011,
        "voice": "vo_adv_5210301_001"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n那是、",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "審判長先生真正的姿態……？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "這也是、",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "過去的我所造出的罪孽嗎……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "確實呢……",
        "unit_id": 137411,
        "voice": "vo_adv_5210301_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "魔法生物，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "照理說是不具備自我的。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "阿剌克涅小姐。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n捕食同族",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而突變成的這副模樣，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是那位審判長自己所期望的樣子喔。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "沒錯！",
        "unit_id": 136011,
        "voice": "vo_adv_5210301_003"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "跟之前嘩啦嘩啦～跑出來的樣子完全不一樣嘛。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n所以",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "不是小阿的錯喔！",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果妳還是覺得有責任，",
        "unit_id": 137411,
        "voice": "vo_adv_5210301_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就親手做個了斷吧。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……我明白了。",
        "unit_id": 136011,
        "voice": "vo_adv_5210301_005"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我會做好覺悟的。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "拿娜也",
        "unit_id": 136211,
        "voice": "vo_adv_5210301_006"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "會全～力幫忙的喔！",
        "unit_id": 136211
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n",
        "unit_id": 136211
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "那麼那麼，",
        "unit_id": 136211
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "預～備！",
        "unit_id": 136211
    },
    {
        "type": "dialogue",
        "name": "拿娜‧霞‧阿剌克涅",
        "words": "我有異議！！",
        "unit_id": 136011,
        "voice": "vo_adv_5210301_007"
    }
]