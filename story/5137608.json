[
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "激務を終えたノウェムとオクトーは、やっとの思いで街へと戻ってきた。"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "はぁ……",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_000"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ひぃ……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "さすがに、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "今日は……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "疲れた、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "な……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "まったくだねぇ。",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_001"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ホント、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "使いっ走りは辛いよ……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "でも、",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_002"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "これも全部アタシらが自由になるためだ。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n自由のためならこれくらい、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "どうってことないぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "偉いねぇ、",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_003"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ノウェムは。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "よければボクの分も働いてくれる？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ふざけるな！　",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_004"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "肉体労働は",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ほとんどアタシに押し付けてるくせに！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n頭使うのもいいけど、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "たまにはオマエも動け！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "冗談冗談。",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_005"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクだっていい加減",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "自由が恋しいからね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nやるべきときには",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "キッチリと仕事はするよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "……本当に頼んだぞ？",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_006"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ところで",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_007"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "自由になったら何したい？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nやってみたいことは色々あるんだけどな。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ずいぶんと気が早いんじゃない？",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_008"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "鬼が笑い過ぎて",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "過呼吸になりそうだけど。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "何言ってんだ！　",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_009"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "目標があれば",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "それに向かってがんばれるだろう？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "……といっても、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシらの目標なんて",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "一つしかないんだけどな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "……",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_010"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そうだっけ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "分かってるくせに、",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_011"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "本当に意地が悪いな",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オマエは！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n前に聞かせてくれたアレだろ！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ほら、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "言ってみろ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "あの時はちょっとテンションおかしかったんだよ。",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_012"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n勘弁してほしいなぁ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オクトー！",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_013"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "……ふぅ、",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_014"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そんな目で見ないでよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクらは世界で一番悪いヤツらになる。",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_015"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "これでいいかい？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ああ！　",
        "unit_id": 106114,
        "voice": "vo_adv_5111608_016"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "これでまた",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "明日からがんばれるぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "単純だなぁ。",
        "unit_id": 106211,
        "voice": "vo_adv_5111608_017"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "でも、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そのシンプルさは",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ちょっと見習いたいよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "その真っすぐで",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "揺らがない思いが、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "きっと活きてくるはずだからね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "心中でこっそり賞賛するオクトーだった。"
    }
]