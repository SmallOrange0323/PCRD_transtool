    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "紡希，好像挺開心的呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1054008_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n似乎是和某個人在一起的緣故呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼雀躍不已的樣子，",
        "unit_id": 190011,
        "voice": "vo_adv_1054008_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n想必是非常想要見到你呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子一陣子之後會有什麼樣的變化呢？還請你好好照看她喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1054008_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如此荊棘的道路反而是越要向前行呢，還是說……",
        "unit_id": 190011,
        "voice": "vo_adv_1054008_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "倘若時機成熟，你一定要好好接受她喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1054008_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "醒來之後，我看大概她又會是一副慌慌張張的樣子了。",
        "unit_id": 190011,
        "voice": "vo_adv_1054008_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為要掩飾自己的感情，還是相當困難的吧。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔唔……",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_060"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不是的……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "才不是……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……啊！這、這裡是……咦？",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_061"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "剛才那是，做夢……？　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生也睡著了嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_062"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我也是……記得剛才，我們是一起在挑衣服，然後……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我和騎士先生被誤認為是一對情侶了……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_063"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊！不是的，那只是夢裡發生的事而已！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "難道我……休假時和騎士先生一起出門了？就像那樣？",
