[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "紡希這一天，在慈樂之音那邊和裁縫店這裡都沒有安排工作，\n享受著難得的假日。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……好久沒有，這種解脫的感覺了……",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n今天要來做些什麼事情好呢～♪",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……話說休假的日子，應該要做什麼來著？",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "做自己喜歡的事情吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "裁縫……平時工作就在做了。還有呢……？",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n嗯，嗯……喜歡，喜歡……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "喜歡怜大人！",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好想見怜大人──！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "話說回來，最後一次見到怜大人的臉，是很久以前的事了呢……？",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊啊，怜大人我好想見到妳啊～！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……最近反而，都是和騎士先生在一起啊……",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "起初還以為他是個想要接近怜大人的壞蟲……",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說起來騎士先生在休假時，都在做些什麼呢……？",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我幹嘛想騎士先生的事情啊！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不對啊！我喜歡的人是怜大人才對啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呀哇啊！",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n為什麼會在這種時候被你發現啊……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我剛才稍微想了一下騎士先生的事情……",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊什麼事都沒有！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "都沒有哦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "　\n我說都沒有你聽懂了嗎！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請你不要突然跑出來好嗎！",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我這邊一點準備都沒有……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼回事，這道光……？是不是有誰穿著超搶眼的衣服？",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說起來之前好像也是……",
        "unit_id": 105411,
        "voice": "vo_adv_1054008_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n見過，這道光……",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……似乎是太早來了。到咖啡店裡等好了……",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "喂？",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_016"
    },
    {
        "type": "dialogue",
        "name": "朋友",
        "words": "紡希對不起。",
        "unit_id": 1,
        "voice": "vo_adv_1054008_017"
    },
    {
        "type": "dialogue",
        "name": "朋友",
        "words": "\n我的父親來自國外的朋友突然要來家中拜訪……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "朋友",
        "words": "\n家父囑咐我，要和大家一同共進午餐。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣啊……家裡有事那就沒辦法了呢。",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那下次我們再一起去買東西吧！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "朋友",
        "words": "謝謝妳。",
        "unit_id": 1,
        "voice": "vo_adv_1054008_019"
    },
    {
        "type": "dialogue",
        "name": "朋友",
        "words": "\n我一定會再還妳這個人情的。那麼，再會了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "再會。",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "和外國人共進午餐啊……",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n要和大小姐學校的朋友們相處，比想象中的還要辛苦呢……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也不想什麼都沒做就打道回府，",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n一個人逛街倒也無妨……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "果然還是找個人來吧……",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n還在可以邀請的人，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還有誰呢……？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好想和怜大人一起去買東西啊……",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣我就可以為怜大人",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "穿上各式各樣的衣服了～！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊！這樣的妄想根本停不下來啊，下次再說吧！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還有誰呢……有誰……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……想到了！無所事事的人！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_026"
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "喂，是騎士先生嗎？現在有空嗎？不，一定很閒對吧！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說謊──！欲言又止的肯定是在騙我！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼，現在馬上十萬火急給我到達指定地點！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你這樣說，就還是有閒的意思對吧？",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那就馬上給我趕到這邊來！我已經把地址傳給你了！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那就拜託你了喔～！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_030"
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──幾十分鐘後。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你太慢了！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還是謝謝你來了～！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "其實……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……就是這麼一回事。",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n於是我的腦海中馬上就浮現出騎士先生的臉了！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "小學的同學由於社團活動很忙，",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n王林道的同學們大家都是大小姐，所以我比較抗拒突然叫她們來。",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果是騎士先生陪我就剛剛好呢。",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n感覺你也提得動東西，再說也沒有其他比較有空的人在了……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在陪我一起去買東西吧！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n作為謝禮我會幫你挑衣服的！好嗎？欸？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "再怎麼猶豫你人都到這裡了，那也就是說，",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你會陪我的對吧？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你這身俗氣的服裝我也會想想辦法的！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就這麼決定吧！謝謝你。",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我會好好鍛煉騎士先生的時尚品味的！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來吧我們走囉──！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要從哪裡開始逛呢～♪",
        "unit_id": 105431
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，騎士先生你看！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那件連身裙，是不是很可愛啊？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "荷葉邊的袖子非常講究，真可愛呢～！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我們進去裡面看看吧！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "難不成，你是在害羞嗎？哼哼，沒問題的啦！　",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這間店也有展示男士穿的衣服啦！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊──！這件好可愛～！這件也是！這件也不錯欸～！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不好意思，我去試穿一會兒稍微等我一下！",
        "unit_id": 105431
    },
    {
        "type": "still",
        "still": "105400801"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "鏘鏘──！如何？適合我嗎？",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n很適合對不對嗎？謝謝！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼這一件和我剛才穿的那一件，你覺得哪一件比較適合我？",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你快點回答啊──！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是給我回答都很合適的話我就把你綁起來丟到店門外去哦♪",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可愛！？啊啊，是在說衣服可愛對吧……",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的，在這種奇怪的地方讓人產生誤會！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯～嗯。騎士先生喜歡這種類型的啊。",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這樣子啊……哦……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我知道了！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這件，我要買！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "客人的女朋友，穿什麼都很合適呢。",
        "voice": "vo_adv_1054008_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "女、",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_050"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "女朋！？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "才、",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "才才才不是那種關係！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且話說",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼我要和這種俗氣的人在一起！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不我是說，你穿的衣服很俗氣……！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n而且，我已經有怜大人了！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生你也說幾句話啊！",
        "unit_id": 105431,
        "voice": "vo_adv_1054008_052"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們才不是那種關係！",
        "unit_id": 105431
    },
