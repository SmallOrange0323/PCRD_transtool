[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "遵從著誓約，克莉絲提娜連著好幾天……\n來到{player}身邊並向他求婚。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "她本身也有【王宮騎士團】的工作，\n雖然很忙的樣子，但又會在快忘記時突然地來訪。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "或許是想讓人看到賢慧的一面吧，一下煮飯一下打掃。\n她表示應該要了解結婚對象的一切，\n而說起了自己的人生經歷……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但或許是開始覺得厭煩了吧，\n求婚的方式感覺也漸漸變得隨便了起來。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "即使如此，\n她還是每週都會去見{player}一次。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對過著打打殺殺生活的她而言，\n和{player}的那些交流，\n似乎意外地能撫慰她的心。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "打擾了。",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我又來見你了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵。",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我今天考慮到你可能只愛年紀比你小的女孩子，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以把我還是可愛幼女時的照片帶來了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然已經完全長大成人了，",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但小時候的我也一樣是我。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是多少能讓你對現在的我抱有好感的話……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "{player}，\n躺在沙發上睡著了啊。",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我總是在這個時間來露臉，",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n他應該有料想到我會來才對。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不多少有一點戒心的話，",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "會讓人很沒勁啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "他倒是也沒有嫌煩，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "或是想要拒絕我的樣子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "狀況進展得很慢，沒有如預料中進行，真讓人焦急。",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "他到底是有什麼不滿？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "明明都被這樣的美女給求婚了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦哦？　",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這道光是……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "感覺和{player}\n發動能力時的光芒很相似呢？",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗨～",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好久不見……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n克莉絲來玩囉♪",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "咦，",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "奇怪？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那邊那個負責看店的人，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可以打擾一下嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "晶應該就在這個公園的可麗餅店才對，",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n她不在嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯……",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你是受她所託來這顧店啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那真是辛苦了，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我代替朋友向你賠罪。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可是，",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "晶那傢伙也真是奇怪呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "明明已經存到足以在好幾段人生中玩樂度日的錢了，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為什麼還要這麼認真地在這種窮酸的攤販做生意？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "透過眺望往來公園的一般行人、",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "做她擅長的人類觀察，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難道能獲得什麼靈感嗎……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我要不要有空也來學她看看好了？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哎呀，失禮。",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在店前面一直自言自語會妨礙營業呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就給我一份可麗餅吧，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "配料就交給你選擇了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話說回來，",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n既然是晶拜託你來看店的，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你也和她有什麼關係嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯～",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "感覺好像在哪裡見過你……？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哎呀。",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "抱歉這樣打聽你的事，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我先表明我的身份吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我是",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "克莉絲提娜‧摩根。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是美國人，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "目前在某個企業擔任代表。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "公司據點是在祖國，我主要是在那裡進行活動，",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但碰巧有點事情而來這個國家出差……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想說來見見好久不見的老朋友，",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以才會到這裡來。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只是看來很不巧，",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我沒見到她就是了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我接獲的情報應該是正確的才對，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n看來晶也是",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "察覺到我接近才藏起來了吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼……",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n晶那傢伙",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在躲避「七冠」這件事看來是真的呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "連我這個應該是她朋友的人都被她躲著了，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還真傷心呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？真快呢，",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "已經做好了啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "謝謝，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會好好品嚐的。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你那是什麼表情？",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n難道說，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你認識我嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟我和晶她們一起",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n被統稱為「七冠」，名聲莫名地廣為人知了呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來我也算",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還有點名氣的人吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和其他不太公開露面的那些人不一樣，",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我很積極出現在公眾面前嘛。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還連著好幾天，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "緊湊地上電視節目和接受雜誌的採訪。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了販售商品，企業的大家長成為招牌是很有效的手段，",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而我就如你所見是個美女，所以也有足夠的宣傳效果。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然很麻煩，但沒辦法。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會大方華麗地活下去的。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯。",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可麗餅好像要燒焦了，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "做好的話就給我吧。",
        "unit_id": 107131
    },
    {
        "type": "still",
        "still": "107100401"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我開動了。",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n嚼嚼……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n嗯～",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這國家的料理真清淡呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過似乎是使用不錯的食材，",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n若再多考慮地點和宣傳的話，營業額也會上升吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你要的話我就給你建議吧？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟我也是做這種工作的。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對那個晶來說，也是馬耳東風吧。",
        "unit_id": 107131
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哎呀，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "時間已經到了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "調整行程才湊出大概三十分鐘的閒暇時間，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n結果就這樣用掉了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒見到晶真可惜呢。",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過只要主張我是為了工作登入的話，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在阿斯特朗傳奇裡就能見到面了吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在我們所打造出來的",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "永恆不滅的理想鄉裡。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，",
        "unit_id": 107131,
        "voice": "vo_adv_1071004_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我先告辭了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "謝謝你陪我度過愉快的時間，{player}……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再會♪",
        "unit_id": 107131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是像夢一樣的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n醒來之後，就會全都忘光了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就這樣～",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "重複說明好幾次相同的事情，開始讓人覺得麻煩了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次乾脆先錄音起來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後再播放出來好了",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總而言之，",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你在「那邊」",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也和那個「誓約女君」相遇了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那可不是偶然，",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為對「誓約女君」來說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n和你見面似乎也是她的目的之一。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你沒有自我介紹，她卻叫了你的名字對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我說的「誓約女君」就是指克莉絲提娜唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n被稱為「七冠」的七名超越者，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n都被媒體冠上了別名。",
        "unit_id": 190011
    },
    {
        "type": "still",
        "still": "200700801"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "克莉絲提娜是「誓約女君」，",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "其他六人各自有",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n「霸瞳皇帝」、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「迷宮女王」、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「變貌大妃」、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「跳躍王」",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……還有什麼啊？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "每個別名",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都是很像君主、國王的名字對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以頭戴王冠的七名支配者，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被人稱為「七冠」。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但他們本應只是支配著自己所創造的遊戲的",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n徒有虛名的君主……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然而世界被「再構築」的現在，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "名號就彷若體現出他們的本質。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "他們就是",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個世界的支配者。",
        "unit_id": 190011
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然克莉絲提娜",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n似乎忘了自己的立場，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但她可是不能忽視的強大存在呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要盡可能",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "慎重地與她接觸。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n記得要小心處理唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是……",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真讓人感到意外，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在的你竟然能和她一直平凡地交流呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想，",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你們能就這樣在和平的氛圍中好好相處下去……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那就好了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為你們「前世」彼此對立、",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "互相廝殺，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n直到最後你們走的路都始終沒有任何交接。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在能像這樣並肩",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "走在一起簡直就像是奇蹟。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不對，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的就像夢一樣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "結婚？",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有什麼不好的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我會支持你祝福你的……{player}♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正，全部都是泡沫般的夢……",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "去盡情享受",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n原本不可能會有的未來",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和人生吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就再見了，{player}。",
        "unit_id": 190011,
        "voice": "vo_adv_1071004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n下次在夢中再見吧。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯嗯？",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然只有一瞬間，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但我好像失去了意識。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且，",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是怎麼回事？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "未知的記憶甦醒而來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "「七冠」、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "「誓約女君」、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "「亂數聖域」、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "【圓桌武士】……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，小子，",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你和我……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在「前世」原來是敵人嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若是如此的話，",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若我們彼此是敵人的話……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那結婚，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "或是相愛相隨這些事，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真的都只是癡心妄想呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總感覺，",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "出乎意料地寂寞。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_060"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你還在睡啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也沒蓋上被子……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣會感冒的喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就讓你枕著我的大腿吧。",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n多少會溫暖一點吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不管過去是如何，",
        "unit_id": 107111,
        "voice": "vo_adv_1071004_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "未來又會如何，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就暫時",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我們陪伴彼此互相溫存吧。",
        "unit_id": 107111
    }
]