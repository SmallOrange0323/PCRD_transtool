[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美咲獨自一人在咲戀育幼院的廚房中煩惱著。"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗯～",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要做什麼好呢……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我被拜託負責看家，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "原本還想說現在育幼院沒有其他人，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "正是大好機會！的說……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "果然還是",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "做媽媽教我做的手工蛋糕好了？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個蛋糕，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我和胡桃一起做的時候，大家都很喜歡呢。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "感覺不太夠呢，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還是應該說不夠華麗吧。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這種時候，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我希望能展現自己的風格，把東西弄得很豪華。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦？",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是有客人來了嗎？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "來了～",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我馬上過去～！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "原來是你啊，",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你來得正是時候呢。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你帶了好多東西。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那些東西",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是怎麼了？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "原來是要配送的包裹啊，",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "辛苦了。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "欸欸，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你送完包裹後，來這裡一趟。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我現在非常煩惱，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以需要你的意見。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為了在煩惱的淑女，",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你也一起來動腦筋想解決的辦法！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……就是這樣，",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我想要感謝",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "育幼院的大家平時對我的照顧。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對吧～！？",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "身為成熟的淑女，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n就是要認真想這方面的事情才行呢！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以，",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我想以很多當季水果，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n做出時尚甜點，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "來舉辦一場派對！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "滿滿的奶油",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "配上烤得鬆鬆軟軟的迷你蛋糕，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "然後在閃閃發亮的果凍上，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "裝飾寶石般的水果！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "酥脆的派皮",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "配上奶油的千層酥也令人難以取捨呢……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雖然會有點孩子氣，",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但是經典的草莓鮮奶油蛋糕也不能少呢。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "畢竟育幼院",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還有很多年幼的小孩子呀。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "欸，",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_012"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你怎麼想？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "既然都來到這一步了，",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_013"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n就請一流的甜點師",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "幫我們配送過來啊♪",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這還用說嗎！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這可是要表達我的感謝之意，",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_014"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果還做和平時一樣的事，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不就沒意義了嗎？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "而且……",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_015"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "身為成熟的淑女，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n還是少不了當季水果。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這是我昨天讀的時尚雜誌上頭寫的。",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_016"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "「春天頂級的水果是",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "淑女的愛好」",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "喔！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "裝飾了蛋糕、花和水果……",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_017"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這感覺",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就是最頂級的",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "奢華了！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "欸",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "欸，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "很棒對吧！？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你也想吃吃看對吧！？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦？",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_018"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n做自己能力範圍內的事……？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是的～！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我不想聽你和媽媽一樣在那裡嘮叨啦！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我是想做平常不會做的事情，",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_019"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "然後給大家一個驚喜。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……不、",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_020"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你說的話",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也的確有道理。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我一個人又做不了什麼大不了的東西……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對了！",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_021"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你也來幫我做吧。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n比起一個人，兩個人能做的事更多呀！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我就任命你當我的助手吧♪",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "既然說定了，",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_022"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就該來決定要做什麼了！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "說到草莓和奶油，",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_023"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "的確就是草莓鮮奶油蛋糕。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果有很多種類的甜點，那還沒關係，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但如果只挑選一種，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n會缺少了成熟感呢。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那很好吃呢～！",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_024"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "鬆餅！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "很遺憾，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "鬆餅感覺不夠高級呢。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還有沒有什麼別的點子？",
        "unit_id": 121411,
        "voice": "vo_adv_1214003_025"
    },
    {
        "type": "dialogue",
        "name": "美咲",
