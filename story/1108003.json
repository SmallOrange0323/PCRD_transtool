[
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某個假日。\n因打工地點接連被檢舉，而失去工作的克蘿依，\n跑到有點遠的隔壁村莊，拜訪形跡可疑的商人。"
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "妳剛剛說妳叫做克蘿依嗎？",
        "unit_id": 611,
        "voice": "vo_adv_1108003_000"
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "\n也就是說，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "想委託妳",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "採集植物。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊。",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "植物。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "印象中",
        "unit_id": 611,
        "voice": "vo_adv_1108003_002"
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "在圖鑑上這附近……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "有了有了，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "是這傢伙吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "這傢伙是瀕臨滅絕的物種，",
        "unit_id": 611,
        "voice": "vo_adv_1108003_003"
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "不能在一般的市面上販賣。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "但是，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "由於能當作某種黑魔術",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "的催化劑，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "所以才有這樣的需求。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "\n妳對那是什麼樣的術式",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "有興趣嗎？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，完全沒有。",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n不如說是，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "完全沒有。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "啊，",
        "unit_id": 611,
        "voice": "vo_adv_1108003_005"
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "對於商品不知情工作起來",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "比較方便的意思嗎。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "比起那些，酬勞更重要。",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "如果採集那種葉子回來，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n真的會用剛剛提到的",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "價格買進嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "生意最講求的可是",
        "unit_id": 611,
        "voice": "vo_adv_1108003_007"
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "信用，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "我們不會",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "對商業夥伴騙人的唷。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "如果願意幫我們採集的話，",
        "unit_id": 611,
        "voice": "vo_adv_1108003_008"
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "\n就麻煩妳",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "搭著馬車",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "往東邊的森林前進。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "\n那麼，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "地圖也先給妳吧，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "拿著。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等等，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等一下。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這裡是。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "哎呀，",
        "unit_id": 611,
        "voice": "vo_adv_1108003_010"
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "妳注意到了嗎。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "\n雖然是在人類村莊長大但也知道不少呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "沒錯，",
        "unit_id": 611,
        "voice": "vo_adv_1108003_011"
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "那裡是精靈之森。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "\n所以",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "城鎮的人――",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "特別像我們這樣的人是沒辦法進入的。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "\n我們身上的那股味道，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "可是瞞不住森林的守門人呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "不過，",
        "unit_id": 611,
        "voice": "vo_adv_1108003_012"
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "妳的話應該可以想到辦法吧？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "即使墮落了還是同個種族嘛。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哦，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "說我墮落啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真好笑。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "如果沒興趣的話",
        "unit_id": 611,
        "voice": "vo_adv_1108003_014"
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "拒絕也沒關係唷。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "無所謂……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我只是在想，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那座森林並不是那麼容易能進入而已。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "嗯……？",
        "unit_id": 611,
        "voice": "vo_adv_1108003_016"
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "\n看來妳，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "好像還不是這邊的人呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "\n墮落之前收手",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "也是一條路唷，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "小妹妹。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯――，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也是呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但是，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那種事我自己擔心就好唷。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "隨妳高興。",
        "unit_id": 611,
        "voice": "vo_adv_1108003_018"
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "反正酬勞",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女商人",
        "words": "最後才會付。",
        "unit_id": 611
    },
    {
        "type": "background",
        "background": "500320"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "噗呼……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼回事――",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒什麼動力――",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "咦――？",
        "unit_id": 1,
        "voice": "vo_adv_1108003_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n姐姐，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "學校明明放假，妳要去哪啊――？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊――，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "有點事。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "打工唷。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "工作嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1108003_023"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n明明是放假卻要工作嗎？　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "姐姐，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "好偉大――！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "吶吶，",
        "unit_id": 1,
        "voice": "vo_adv_1108003_024"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "是怎麼樣的工作？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n麵包店？　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "打掃相關？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "\n透過魔石廣播",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依的弟弟",
        "words": "賺取廣告收入？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_025"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "差不多就是那樣吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n先這樣，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我出門了。",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500320"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然這麼說……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_026"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒辦法。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n是連對家人",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也說不出口的工作。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過啊……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_027"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n希望早日能治好媽媽的疾病，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n好讓那些孩子",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "盡量撒嬌啊――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_028"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "早點離開學校，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "找份不錯的工作好了……",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "哦，",
        "unit_id": 3311,
        "voice": "vo_adv_1108003_029"
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "哦。",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "\n所以今天，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "是因為遙遠先祖的緣分",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "而來到這座森林參觀？",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "那麼，歡迎您的蒞臨。",
        "unit_id": 3311,
        "voice": "vo_adv_1108003_030"
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "\n請當作自己的故鄉一樣，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "盡情地在這裡放鬆吧。",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_031"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "謝謝。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "我們的住處",
        "unit_id": 3311,
        "voice": "vo_adv_1108003_032"
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "就在對面，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "\n散步回去的時候",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "請務必來坐坐。",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "\n",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "那麼告辭了，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "森林守衛",
        "words": "遙遠的遠房客人。",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊……走掉了。",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_033"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "噗呼……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_034"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n話說，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也太容易就放我進來了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "而且沒有",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_035"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "任何監視……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "安全沒問題嗎，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這座森林。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n也太好搞定了吧，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "看守人。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……不過，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_036"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也許這表示",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我受到信任吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……即使墮落",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_037"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那麼……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_038"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯――，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "該怎麼辦呢――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說回來，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_039"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n在這種滿地都是草的地方",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "找出不熟悉的草，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n看來",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也不會太順利呢――",
        "unit_id": 110811
    },
    {
        "type": "still",
        "still": "110800301"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "欸，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_040"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好容易就找到了耶。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "欸……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_041"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說這個，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "根本像雜草一般，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n瘋狂地長得到處都是嘛。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n稀有度也太低了吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是殺手筆劍嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_042"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這個讓人沒幹勁的冒險。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n好像一秒過關。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n一點",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "都沒有熱血沸騰的感覺。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "噗……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_043"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "該怎麼辦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算了，無論如何，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_044"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n只要拔出這些草",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "帶回去就好了吧……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_045"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_046"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒錯。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好累啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "先暫時停下，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "稍微休息好了。",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呀啊啊啊啊啊！",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_047"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你、",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_048"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你是誰……！？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我可是什麼都還沒採啊？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，你是……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_049"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n蛤！？　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "為什麼{player}會在這裡……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說回來，等一下。",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_050"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你能不能不要再突然出現在我背後。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這樣會讓我嚇到，害我無意識地發出萌角般的聲音啦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這麼一來，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可能會因名譽損毀而吃上官司喔。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……那麼？　",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_051"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你在這裡，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "做什麼。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "又是這個啊。",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_052"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，你到底是要迷路多久。",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_053"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n是興趣嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "跟重訓一樣的頻率，每天都來迷路一下嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說回來，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_054"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "能用迷路技踏入精靈之森，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n也算是才能的一種，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "應該要好好培養這項才能才是。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦？",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_055"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊――，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "有點事呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼樣……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_056"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_057"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就是，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "該怎麼說……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "採集相關？　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "花草的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_058"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "觀賞用。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n好像聽說這些草，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "非常好拍",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "又好看呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你看看，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "顛覆這個植物界常理的",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嶄新形式――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，很普通啊……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_059"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就是THE植物啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不如說愈看愈覺得它就是普通的雜草……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算了，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_060"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼說呢就是，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也許",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這樣反而",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "新奇。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "該說是太樸實",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "反而戳到笑點嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這才是真正的",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "「大草原www」。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "麻煩死了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊――，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_061"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對――，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "料理用。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n聽說這種葉子，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "非常的美味。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n無論煮或炒都很好吃，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "家庭主婦",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也會突然為之瘋狂。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "欸、等等……！？\n{player}，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_062"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你在做什麼，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你不能吃啦！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可以不要突然",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "用那種清爽感，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "做些脫線的事情嘛。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_063"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就是，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我剛剛說的",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "都是騙人的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以就是啊……",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_064"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n吶，可以不要再這樣了嗎，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這麼單純的疑問。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n會讓我想起出門前的弟弟們，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "有種微妙感。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_065"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個眼神啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那個純真的眼神。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你們啊，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "很像呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個眼神，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_066"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "其實很有影響力。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "…………",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_067"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好吧，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_068"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "決定了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n走吧，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "{player}。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我送你到蘭德索爾吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "跟我來――？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒關係。",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_069"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不用。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我不做這個了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "果然。",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_070"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然現在才說。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n不過總覺得，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "連對家人都說謊好像不太對呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "只要看到你，",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_071"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "總會那麼想。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算是那樣吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以，要走了。",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_072"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克蘿依折返回去，\n用穩健的步伐離開現場。"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦？",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_073"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n{player}，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "為什麼不跟上來。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n一直坐在那裡做什麼。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "別這樣。",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_074"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不行。",
        "unit_id": 110811,
        "voice": "vo_adv_1108003_075"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你是乖孩子，乖乖放在那裡。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不然阿姨給你殺手筆劍。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}不知道為何被激烈反對，\n且被硬塞了稀有度很低的道具。"
    }
]