    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "五彩繽紛又奪人目光的食物、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n遊玩遊戲便能獲得獎勵的娛樂性。",
