        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n特製牛肉串！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如何？",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_040"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "超好吃的吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n不必客氣，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你可以盡情地誇讚它喔！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "怎、",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_041"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "怎麼會……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "到底是哪裡出錯了？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我不明白，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "完全不明白……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
