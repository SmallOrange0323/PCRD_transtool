    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "多麼有趣的想法呀！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n微甜的麵衣和番茄醬、芥末醬很搭呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這邊這個是烤肉串吧。",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_029"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我嚐嚐……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嗯──！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "甜甜辣辣的醬汁和炭火烤過的香氣真令人欲罷不能！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n食物的尺寸正好能讓女性方便享用這點",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也很棒呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呼，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "有點口渴了呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "麻煩你",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "準備飲料──",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你已經準備好啦。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n真漂亮的瓶子，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "裡面裝著",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "玻璃彈珠？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "原來如此，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "它是用來塞住瓶口的呀。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嗯──！",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "又甜又舒爽呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這就是優花梨在喝的麥酒嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n不是嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這樣啊。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呼，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_032"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "每樣食物都非常美味，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也很有意思呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n庶民食物",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是多麼有趣呀！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "而且，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_033"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "食物的成本",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "都不算高。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n沒想到這麼便宜的食材",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "能做出這麼好吃的料理。",
