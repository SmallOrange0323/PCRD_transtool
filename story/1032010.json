        "voice": "vo_adv_1032010_036"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "接下來會變得很忙碌喔！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n也要請你認真工作！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "賣不出去……",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_037"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "完全賣不出去啊！",
