    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "來到這裡的客人們，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n渴望的並不是",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "奢華又高級的美食。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "他們是作為日常生活的延續，",
