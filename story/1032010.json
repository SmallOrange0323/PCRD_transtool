        "name": "秋乃",
        "words": "哼哼，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_035"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "相信商人的直覺果然是對的。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們馬上去",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "籌備開店地點和食材吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
