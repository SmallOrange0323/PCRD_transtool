[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被秋乃"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n帶到了蘭德索爾的街道上。"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們今天的工作",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是要去調查",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n公會經手的新產品！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "要實際去市場上視察，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "和業者們直接對話，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n了解現今",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "市場的動向。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "當然！",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那些可是要交到客人手中的重要商品。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "理應由我",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "親自出馬。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不親自用雙眼觀察、",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "用雙手觸摸的話，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n就無法判斷商品的好壞。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好了，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "出發囉！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n雜貨和食材、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還有美術品等等，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "有一堆需要調查的東西等著我們呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "得到接下來可能會流行的甜點情報了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們快去確保食材來源吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那些",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "新銳藝術家們的作品也非常棒！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n替他們籌辦展覽，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "應該會很有趣。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對了對了，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我也很在意最近要開幕的遊樂場！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們也想要在面",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "設立一個店面呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "果然親自出來視察最好了。",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n接著就回公會",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "和其他人討論剛才買的商品合不合適吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請小心對待那些東西。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "它們可是非常重要的參考品呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "逛著逛著",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不知不覺",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就買了這麼多。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我也太集中於工作，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "都忘記要喘口氣了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不間斷地工作，可不是什麼好事。",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "趁著這個機會，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們去吃個東西，休息一下再回去吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_012"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "找一間和我相稱的優雅的店……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那邊",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好像很熱鬧呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "商人的直覺",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_013"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在叫我去那裡探個究竟呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們去看看吧，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這、",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這是……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "一間間攤販排列在路旁，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n大家都在邊走邊吃。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這該不會",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就是所謂的",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "攤販街吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n雖然欠缺了些優雅感，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但很有活力呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_016"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在這裡嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n……這樣啊，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "既然你都麼說了，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我就聽從自己剛才的直覺吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_017"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這麼說起來，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "珠希也有開設賣鯛魚燒的攤販。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那鯛魚燒好吃到我現在都還記得那份感動呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "要是其他攤販",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_018"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也能帶給我那種感動，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我就務必要嚐一嚐了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_019"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "交給你選擇了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n請幫我挑一些看起來好吃的食物！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "攤販的食物",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "究竟有多美味，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就讓我見識一下吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "辛苦了。",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你買了很多東西呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "原來如此，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_022"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "賣相雖然不是很好，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n但食物本身卻都足以挑逗人的本能呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還有這個裝食物的容器，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_023"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是用紙做的吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "吃完就能直接丟棄，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "很合理呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼首先是",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這個小小顆的圓形食物，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是叫章魚燒嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "馬上來吃吃看吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "豪燙！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "太、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "太燙了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呼呼……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不、",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_025"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不過，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這酥脆的外皮",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "和黏稠的內餡所組合而成的特殊口感！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "甜甜的醬汁、美乃滋，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "與充滿風味的配料合而為一，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n從未體驗過的美妙滋味在我口中擴散開來！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "章魚燒，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是驚人的食物……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "再來是這個串起來的麵包。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這該怎麼吃呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "要直接一口咬下嗎！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不使用任何餐具就直接吃，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_027"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這樣也太不端莊了吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不過，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果這種吃法是這裡的習慣，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我就配合吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼我要吃了……",
