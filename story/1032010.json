        "voice": "vo_adv_1032010_047"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "都看起來很開心。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n雖然吃到美味的食物的確會很讓人高興，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n但我覺得好像不只如此。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哇！",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_048"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你看。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那裡在賣色彩鮮豔的東西！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那是食物嗎……？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總覺得很吸引人呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_049"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那邊的孩子們在買餅乾呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n咦？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "輪盤？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那到底是什麼啊？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "哦，",
        "unit_id": 1411,
        "voice": "vo_adv_1032010_050"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "那邊那位美女！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "要不要買煎餅呢？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "讓男朋友買給妳吃嘛。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "男、",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_051"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "男朋友！？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你、你誤會了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我和這個人還不是那種關係……",
