        "voice": "vo_adv_1032010_046"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不知從何飄來的醬料香氣。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n總會讓人感到心情激動呢。",
