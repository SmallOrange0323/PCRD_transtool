        "voice": "vo_adv_1032010_067"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "從攤販的活潑氛圍、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "與攤販老闆的交談中",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n得到快樂而來的。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
