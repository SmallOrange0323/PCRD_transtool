        "voice": "vo_adv_1032010_034"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這麼便宜的食材都能做出這種料理了，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n有了高級食材和一流廚師的話，",
