    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這是為什麼呢？",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_038"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "食材和廚師全都是一流的，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n料理也非常美味，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n就連店鋪本身都設計得很有品味啊！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_039"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
