    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我看你們感情很好，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不小心搞錯了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
