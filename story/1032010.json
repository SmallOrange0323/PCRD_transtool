    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請你",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "做本小姐的嚮導。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呼，",
        "unit_id": 103211,
        "voice": "vo_adv_1032010_044"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "話說回來，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這裡的人真多。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真難走。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n要是沒有你在，",
