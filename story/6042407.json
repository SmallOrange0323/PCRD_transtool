    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "同伴",
        "unit_id": 106612,
        "voice": "vo_adv_6042407_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗎……",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也是呢。",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n重要的不是她的外表，",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而是內心才對！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……小哥你幹麼一直盯著我看啦！",
