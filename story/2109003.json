        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n從麵粉堆中爬出來了嗎……？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "黃的",
        "words": "噗嚕噗嚕～♪",
        "unit_id": 191615
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀啊！",
        "unit_id": 103611,
        "voice": "vo_adv_2109003_048"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n又變得黏答答了……！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美、禊",
        "words": "「鏡華！？」\n「鏡華！？」",
        "unit_id": 1,
        "voice": "vo_adv_2109003_049"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "喂喂！！",
        "unit_id": 191611,
        "voice": "vo_adv_2109003_050"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n妳們可別太小看我啊！！",
        "unit_id": 191611
    },
    {
        "type": "background",
        "background": "500351"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊！？",
        "unit_id": 102811,
        "voice": "vo_adv_2109003_051"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽！！",
        "unit_id": 102311,
        "voice": "vo_adv_2109003_052"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「那傢伙竟然也沒事！？」",
        "unit_id": 2111,
        "voice": "vo_adv_2109003_053"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而、",
        "unit_id": 102511,
        "voice": "vo_adv_2109003_054"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而且……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n魔物們的傷口",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "都癒合了……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哼！",
        "unit_id": 191611,
        "voice": "vo_adv_2109003_055"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n模索路晶的陷阱是很棘手沒錯……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "但少了公主騎士的妳們",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "怎麼可能打得贏我！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗚……！",
        "unit_id": 102811,
        "voice": "vo_adv_2109003_056"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我不會讓你",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對孩子們出手的！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "誰管妳啊！",
        "unit_id": 191611,
        "voice": "vo_adv_2109003_057"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "快給我去死吧！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我接下來可是要去阿澤爾德那裡……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "痛扁霸瞳皇帝啊！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咲戀大小姐！",
        "unit_id": 102511,
        "voice": "vo_adv_2109003_058"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請快逃走吧！！",
        "unit_id": 102511
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "同一時刻，蘭德索爾宮殿附近──"
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "……",
        "unit_id": 191911,
        "voice": "vo_adv_2109003_059"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "呼……",
        "unit_id": 191911,
        "voice": "vo_adv_2109003_060"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "唉呀唉呀。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "王宮周圍果然",
        "unit_id": 191911,
        "voice": "vo_adv_2109003_061"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n設置了大量",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "針對我們的陷阱。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "看來由我來抓捕霸瞳皇帝",
        "unit_id": 191911,
        "voice": "vo_adv_2109003_062"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "是正確的啊。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n雖說若換成贊恩，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "應該也能靠武力突破所有陷阱就是了……",
        "unit_id": 191911
    },
    {
        "type": "still",
        "still": "210900301"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "站住！",
        "unit_id": 104711,
        "voice": "vo_adv_2109003_063"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n【憤怒‧軍團】！！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們不會再讓你",
        "unit_id": 103711,
        "voice": "vo_adv_2109003_064"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "前進半步了！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "哎呀哎呀。",
        "unit_id": 191911,
        "voice": "vo_adv_2109003_065"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n原來是【王宮騎士團】團長，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n及其率領的主力部隊諸位啊。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "話說回來……",
        "unit_id": 191911,
        "voice": "vo_adv_2109003_066"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "現在鎮上各處",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "似乎都充斥著騷動呢。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n你們不需要趕去支援嗎？",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你別裝傻了！",
        "unit_id": 100511,
        "voice": "vo_adv_2109003_067"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那些都是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你的同伴們搞的鬼吧！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你們真正的目標",
        "unit_id": 103711,
        "voice": "vo_adv_2109003_068"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是七冠……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是霸瞳皇帝對吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "來王宮的你就是敵方的主將！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "真是不錯的判斷──",
        "unit_id": 191911,
        "voice": "vo_adv_2109003_069"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我是很想這麼說，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n但看來你們的兵力已經分散了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n光憑著",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "這點程度的部屬",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "能夠攔得下我嗎？",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "居然瞄準陛下和{player}不在的時機偷襲……",
        "unit_id": 104711,
        "voice": "vo_adv_2109003_070"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n看來你們在一定程度上掌握了我方的動向。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……只不過，",
        "unit_id": 104711,
        "voice": "vo_adv_2109003_071"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就算是情報走漏、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "戰況對我們極其不利──",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "儘管如此，",
        "unit_id": 100511,
        "voice": "vo_adv_2109003_072"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也不構成我們退縮的理由！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在{player}他們回來以前，",
        "unit_id": 103711,
        "voice": "vo_adv_2109003_073"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們會死守這裡……！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "……呵呵，",
        "unit_id": 191911,
        "voice": "vo_adv_2109003_074"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n在他們「回來以前」",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "是麼。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "前提是騎士少年他們──",
        "unit_id": 191911,
        "voice": "vo_adv_2109003_075"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "要能回得來才行啊。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "什麼……？",
        "unit_id": 104711,
        "voice": "vo_adv_2109003_076"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "「萬能人偶」！",
        "unit_id": 191911,
        "voice": "vo_adv_2109003_077"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n把礙事者通通除掉！",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "萬能人偶",
        "words": "──「嗡──！嗡──！」",
        "unit_id": 191912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔哇！？",
        "unit_id": 100511,
        "voice": "vo_adv_2109003_078"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那些人偶",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "接連聚集過來了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小智、",
        "unit_id": 104711,
        "voice": "vo_adv_2109003_079"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "茉莉、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "以及各位！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n魔像就麻煩你們了！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不必勉強，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只需要爭取時間就好！",
        "unit_id": 104711
    },
    {
        "type": "still",
        "still": "210900302"
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "了解！！",
        "unit_id": 1,
        "voice": "vo_adv_2109003_080"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那純呢！？",
        "unit_id": 103711,
        "voice": "vo_adv_2109003_081"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "當然──",
        "unit_id": 104711,
        "voice": "vo_adv_2109003_082"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是去對付他！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "…………",
        "unit_id": 191911,
        "voice": "vo_adv_2109003_083"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "上次雖然是我們敗北……",
        "unit_id": 104711,
        "voice": "vo_adv_2109003_084"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但這次可沒那麼簡單了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "【憤怒‧軍團】！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "很好很好。",
        "unit_id": 191911,
        "voice": "vo_adv_2109003_085"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "那麼……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "別光動嘴皮子了，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "也讓我見識見識你們的實力吧。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正合我意──",
        "unit_id": 104711,
        "voice": "vo_adv_2109003_086"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "【王宮騎士團】，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "出動！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "喔喔喔！！",
        "unit_id": 1,
        "voice": "vo_adv_2109003_087"
    },
    {
        "type": "still",
        "still": "end"
    }
]