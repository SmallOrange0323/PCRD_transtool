    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "別讓它掉了！　",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "去給我接好！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "是――！　",
        "unit_id": 811,
        "voice": "vo_adv_1011012_060"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "欸，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "啊……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "糟糕！",
        "unit_id": 911,
        "voice": "vo_adv_1011012_061"
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "\n魔物被香的味道",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "給吸引過來了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "呀――！　",
        "unit_id": 811,
        "voice": "vo_adv_1011012_062"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "你等等我啊，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "大哥！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "你這蠢蛋！　",
        "unit_id": 911,
        "voice": "vo_adv_1011012_063"
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "別過來這裡啊！　",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "可惡――！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "\n為什麼會遇到這種事啊――！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……魔物",
        "unit_id": 101112,
        "voice": "vo_adv_1011012_064"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "全都去追那些人了呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣事情算是",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "告一段落了嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是的！　",
        "unit_id": 101112,
        "voice": "vo_adv_1011012_065"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這是哥哥和我的勝利！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n謝謝你。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是說呢……",
        "unit_id": 101112,
        "voice": "vo_adv_1011012_066"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "煩惱這種事，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一點都不像我呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n既然真的希望，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那就全部得到手就行了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "無論是作為妹妹，",
        "unit_id": 101112,
        "voice": "vo_adv_1011012_067"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還是作為戀人……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "無論是哪邊，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "他都是我最喜歡的哥哥了！　",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿，",
        "unit_id": 101112,
        "voice": "vo_adv_1011012_068"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒什麼！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們一起",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "來整理這裡吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這是哥哥和我的共同作業！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "同時獲得新決心與新力量的璃乃。\n臉上的笑容就如同平原的天空般晴朗無比。"
    }
]