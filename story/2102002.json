[
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似似花。",
        "unit_id": 105812,
        "voice": "vo_adv_2102002_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳剛剛說的那個『世界的危機』……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是什麼意思啊？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……您還記得嗎，",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "陛下。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在那場戰鬥的最後……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在真那倒下之前",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所留下來的話語。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然。",
        "unit_id": 105812,
        "voice": "vo_adv_2102002_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……她說",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們接下來",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似乎得要",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n親自面對那個『元凶』……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯……",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真那會如此謹慎地準備，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "便是為了和那位『元凶』進行戰鬥。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n原本她並沒有將我們",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "放在眼裡。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……然而不巧的是，",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "被幽禁中的真那至今仍未恢復意識。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n因此那『元凶』",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "究竟是何方神聖，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就連我也無從知曉……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然而我",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "發現徵兆了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n……儘管是推測",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "徵兆……",
        "unit_id": 105812,
        "voice": "vo_adv_2102002_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……三個月前。",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在妳做為一名公主，將統治了這個國家的",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "『霸瞳皇帝』打倒之後。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在王宮內，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也掀起了一陣混亂對吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的。",
        "unit_id": 105812,
        "voice": "vo_adv_2102002_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然是藉由純，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有回想起來我是誰的那些貴族們幫忙，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好不容易安定下來……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真那不光只是對這個王宮出手，",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也對黑社會伸出了魔爪掌控。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "盜賊公會、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "暗殺者公會、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "研究禁術的公會……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就連惡質的犯罪集團，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都沒辦法反抗真那。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……若以混亂的規模而言，",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "黑社會的混亂還要更加慘不忍睹才是。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "畢竟不僅是蘭德索爾，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在整片大陸上，處於黑社會的人們，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n或多或少，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都受到了真那的影響。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原、",
        "unit_id": 105812,
        "voice": "vo_adv_2102002_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來是這樣啊……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……然而。",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那份混亂，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "卻在表露於世人面前之前，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就迅速地平靜下來了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……不。",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該說是『被平息下來了』才對。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "被一個名為【憤怒‧軍團】，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "卻無人知曉的公會所平息。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳說無人知曉",
        "unit_id": 105812,
        "voice": "vo_adv_2102002_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那公會管理協會呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "儘管有類似的登錄……",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但似乎是受過了偽裝的樣子。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過嘛，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這等情事",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在黑社會之中也並非是什麼稀奇事……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也有變換了樣貌，",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然後見到了【憤怒‧軍團】進行戰鬥的現場。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……一個善於搞破壞的老手傭兵集團，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "僅僅一瞬就被殲滅了……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n然而對方卻只有一名的劍士。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……那個人，",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "相當地異常。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n擁有著類似七冠",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "『能超越世界法則』",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "的力量。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "甚至可能",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還在那之上……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……！",
        "unit_id": 105812,
        "voice": "vo_adv_2102002_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "鎮壓了黑社會的",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "【憤怒‧軍團】……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n有關他們的目擊情報，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "已經接近了這座城的周邊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想必不用多久，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他們便會襲擊這座蘭德索爾了吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "襲擊……！",
        "unit_id": 105812,
        "voice": "vo_adv_2102002_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這座城嗎！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯……",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……似似花。",
        "unit_id": 105812,
        "voice": "vo_adv_2102002_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳在發抖嗎……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……豈有可能……",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n……我承認。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這並非是假裝的……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我自身的恐懼……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然而，",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為何……？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就連我自己",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也不清楚……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在不遠的將來，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我總有預感會發生些相當、相當恐怖之事……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此。",
        "unit_id": 105812,
        "voice": "vo_adv_2102002_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n女孩子的第六感——",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是像那樣的東西嗎！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "第六感……",
        "unit_id": 107011,
        "voice": "vo_adv_2102002_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……儘管我並不是很喜歡那種用詞。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然而我確實",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
