        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但在這個村莊要幫忙的事都做完了呢。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 130811,
        "voice": "vo_adv_6144107_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "得買伴手禮給大小姐和孩子們才行！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯～",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你覺得要選什麼好呢？",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "花束是嗎～",
        "unit_id": 130811,
        "voice": "vo_adv_6144107_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐感覺會很喜歡呢♪",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而且要是請店員幫忙包裝長得稀奇的花，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n孩子們感覺也會很喜歡。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "種子",
        "unit_id": 130811,
        "voice": "vo_adv_6144107_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是嗎？",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n……原來如此，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣育幼院的大家就可以一起種花了呢！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我覺得這是很棒的點子！",
        "unit_id": 130811,
        "voice": "vo_adv_6144107_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐應該也不討厭種花，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n要是能漂亮地盛開，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一定會成為最棒的回憶～♪",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 130811,
        "voice": "vo_adv_6144107_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那樣可是作弊喔！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然我自己不小心忘記買伴手禮的時候，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也會在市場買特產蒙混過去就是了～！",
        "unit_id": 130811
    }
]