        "voice": "vo_adv_1007007_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可是、可是，因為宮子是幽靈，",
        "unit_id": 100711,
        "voice": "vo_adv_1007007_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n原本就覺得總有一天會消失，所以不要緊的。",
        "unit_id": 100711
