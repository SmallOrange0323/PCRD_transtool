    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚……最近狀態很不好……",
        "unit_id": 100711,
        "voice": "vo_adv_1007007_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n而且越來越嚴重來的。",
        "unit_id": 100711
