        "type": "dialogue",
        "name": "宮子",
        "words": "不、不知道──",
        "unit_id": 100711,
        "voice": "vo_adv_1007007_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n而且總覺得頭好痛來的──",
        "unit_id": 100711
