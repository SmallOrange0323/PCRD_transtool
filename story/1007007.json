        "type": "dialogue",
        "name": "宮子",
        "words": "其實宮子",
        "unit_id": 100711,
        "voice": "vo_adv_1007007_014"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "在成佛之前，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "有話想跟你說來的。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子很豁達，每天都想著這件事情，",
        "unit_id": 100711,
        "voice": "vo_adv_1007007_015"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n這樣不管什麼時候成佛都沒關係來的……",
