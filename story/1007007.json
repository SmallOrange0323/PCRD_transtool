    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "再也不能和你玩的話太寂寞了喲～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是、是嗎？",
        "unit_id": 100711,
        "voice": "vo_adv_1007007_007"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "太好了喲！好幸運來的～♪嗯哼哼～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……可、可是，成佛的話，",
        "unit_id": 100711,
        "voice": "vo_adv_1007007_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n就再也不能和你見面了喲……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子不想要那樣的……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "以後沒辦法見到你了……",
        "unit_id": 100711,
        "voice": "vo_adv_1007007_009"
    },
