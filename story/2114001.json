[
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "～♪",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……抱歉打擾了。",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哈囉～",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雪菲～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "請進請進，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "門沒鎖喔～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好久不見了……",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯♪",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n站著說話不方便，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "坐吧坐吧～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "請用茶和三明治♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n可、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳年紀輕輕的，",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這麼客套可不行喔～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我還準備冰淇淋了當飯後甜點呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……謝謝。",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "說真的，我最近",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "都沒吃過什麼像樣的食物……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "話說回來，",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳準備得還真齊全呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我明明才剛從公會管理協會那裡",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "打聽到",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個地方的。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這點小東西",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒什麼大不了的啦。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畢竟我早就用",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我的能力",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "「看到」",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳要來了嘛～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……「看到」……",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……帆稀小姐。",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在開始談話之前，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "恕我冒昧得先問妳一個問題。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "關於我們",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "當前的敵人……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n「厄莉絲」的事，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳也都已經知道了吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "當然。",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "從【憤怒‧軍團】那一戰之後──",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n到ICPO的豬先生",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓大家空間跳躍的事，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n全～部都「讓我看到」了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……我……",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "似乎是那個",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「厄莉絲」的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "末端裝置……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我在連自己都不知情的狀況下，",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n不斷地",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "把大家的情報洩漏給敵方……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不僅如此，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我甚至還傷害了",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "拉比林斯達小姐……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "…………",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n只有在厄莉絲清醒，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n而我處於",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "無意識狀態的時候才會「被看到」。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以帆稀小姐這處據點，",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n應該沒有被厄莉絲他們「看到」才對。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "至少",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "目前還沒……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "感謝妳顧慮到我。",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我跟變貌大妃她們不一樣，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n並沒有那麼執著於要把自己隱藏起來。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以就算行蹤暴露了，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳也不用感到自責喔～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……謝、",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝妳……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總之，",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來龍去脈我大致都了解了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n妳是想知道",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "該如何才能擺脫「末端裝置」",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "的身分，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n才會來找我的對吧～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是的。",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_023"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我想",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "跟夥伴們在一起。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "而且",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也不想讓哥哥一直處在",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "敵人的掌控之中……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "聽說不光是龍人族，",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_024"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n帆稀小姐",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對這個世界的各種事物都頗有研究。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以我想……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳可能會有什麼線索。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "或許造成妳的困擾了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵。",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n哪有什麼困擾，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別那麼說啦。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就像我現在也正讓嘉夜她們",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_026"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "幫我做些「地下工作」那樣，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我也會",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要求妳幫我一些忙喔。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……妳可有",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "心理準備～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯。",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_027"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我不敢說",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我什麼事都做……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但我會盡我所能",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "幫忙的。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵。",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_028"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n那麼就──",
        "unit_id": 106711
    },
    {
        "type": "still",
        "still": "211400101"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯～♪",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_029"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n妳的手很巧呢，雪菲☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n再來請幫我畫這裡的網格～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好、",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_030"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好的──",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為什麼會要我幫忙畫漫畫……！？",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_031"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哎呀～因為，",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_032"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n截稿期限",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就快到了嘛～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也常常找{player}",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_033"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來當我的助手啊～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可是最近",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_034"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "他似乎忙到不行，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n害我累積了一大堆原稿。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n而且沒有他在身邊，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我好像也沒什麼靈感～",
        "unit_id": 106711
    },
    {
        "type": "still",
        "still": "211400102"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "原來如此。",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_035"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n既然",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是接替{player}的工作，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那我得",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "更用心做好才行……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_036"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是個認真的孩子～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不過漫畫是用來取悅人的東西，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我還是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "希望妳也能樂在其中啦。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……樂在其中……",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_037"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……欸欸，雪菲。",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_038"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n妳邊畫邊聽我說就好，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我有個問題想問問妳。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳──",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_039"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n對這個世界",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有什麼看法？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_040"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n什麼看法……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「另一個世界」的事……",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_041"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我稍微",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "想起來了一點……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我記得我是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "跟哥哥還有雙親住在一起。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n所以……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個世界",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是虛構出來的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_042"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不管是像這樣握著筆的觸感，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n還是三明治的味道……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我都覺得是千真萬確的。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n實在難以相信",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這裡是虛構世界……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯嗯，",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_043"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有呢～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還有就是……",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_044"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "究竟是厄莉絲的錯，",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_045"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是七冠那些人的錯……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "實在搞不清楚。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我覺得這個世界",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很殘酷……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "當然，我很喜歡【美食殿堂】的夥伴，",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_046"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n以及在冒險過程中",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "認識的那些人。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但即便如此……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對我而言，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個世界還是……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯～",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_047"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然很遺憾……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n但妳會這麼想也是無可奈何的呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畢竟妳現在",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "處於一個相當難受的立場。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……帆稀小姐呢……？",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_048"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳對這個世界",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "又有什麼看法？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我？",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_049"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我嘛～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "超喜歡的☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……不。",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_050"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n應該說「曾經」",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "超喜歡吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「曾經」……",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_051"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "意思是指",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "過去的事？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯～",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_052"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "當然啦，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我以前也不是完全沒有不滿之處。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看到開發者問題重重，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看他們獨享外掛之利在遊戲裡占盡優勢，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我也會覺得「這算什麼啊～？」。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃、",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_053"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過……",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_054"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還真厲害呢☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n「mimi」這東西～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可以體驗各種",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_055"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在現實中做不到的事☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n像是使用魔法、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在天上飛之類的♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "mimi……？",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_056"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_057"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "抱歉抱歉☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n妳的認知還沒有",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "恢復到那個程度呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真要說起來，",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_058"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "其實我這個人呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n從小",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就很會編故事，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "或是把想像中的東西畫出來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我覺得很有趣、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很喜歡。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是因為這樣，",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_059"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我才成了一位漫畫家。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n並且為了了解虛擬實境，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一頭栽進了網路的領域。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n……然後在那過程中，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "認識了「她」……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "先不說那個。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "當我頭一次戴上mimi，",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_060"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "然後啟動《阿斯特朗傳奇》的時候，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我真的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真～的興奮到不行，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "到現在都還記憶猶新。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n那種感覺",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就好像跳進故事書裡的世界一樣。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可是，",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_061"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我所喜歡的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "並不是現在這樣的阿斯特朗。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n至少……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不是會",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓妳這種好孩子受到傷害的世界。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……現在這樣",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一點都不好玩對吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_062"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然如此……",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_063"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "吶？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就算「長老」說不可能，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我也會想設法做點什麼事對吧～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可以的話，",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_064"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我希望雪菲",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不光是做我的漫畫助手……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n也能協助我去做",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我想要做的事。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不光因為妳是龍人族。",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_065"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n如果有妳這個厄莉絲的「末端裝置」相助的話……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不對。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果妳",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_066"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "願意把自己託付給我，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n說不定我就能找出什麼密技，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來攻略這個無法破關的遊戲喔～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嗯。",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_067"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n不如說，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是我想拜託妳這麼做。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但……",
        "unit_id": 106412,
        "voice": "vo_adv_2114001_068"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n具體而言",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "究竟該怎麼做呢？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個嘛。",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_069"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n總之就是……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來開",
        "unit_id": 106711,
        "voice": "vo_adv_2114001_070"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "外掛吧～♪",
        "unit_id": 106711
    },
    {
        "type": "still",
        "still": "end"
    }
]