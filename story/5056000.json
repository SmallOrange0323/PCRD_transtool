    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……翌日。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n【美食殿堂】公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不、",
        "unit_id": 1,
        "voice": "vo_adv_5056000_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "超────不妙噠啦！？",
        "unit_id": 106012,
        "voice": "vo_adv_5056000_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……請、",
        "unit_id": 105913,
        "voice": "vo_adv_5056000_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您冷靜下來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "太激動的話，會咬到舌頭的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能冷靜啊！",
        "unit_id": 106012,
        "voice": "vo_adv_5056000_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可蘿仔，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳為什麼還能這麼冷靜！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊嗚嗚嗚……！",
        "unit_id": 106012,
        "voice": "vo_adv_5056000_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是這樣沒錯，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但也不要說得那麼白嘛……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有",
        "unit_id": 106012,
        "voice": "vo_adv_5056000_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "錢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "身無分文……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽起來多麼空虛啊……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊、",
        "unit_id": 106012,
        "voice": "vo_adv_5056000_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在某意義上是這樣沒錯啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你怎麼突然講這種話？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有什麼難過的事都可以找我們商量喔？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……呃，",
        "unit_id": 106012,
        "voice": "vo_adv_5056000_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是沒有錢啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有錢！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們身無分文！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……是。",
        "unit_id": 105913,
        "voice": "vo_adv_5056000_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n沒想到",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟會陷入這樣的窘境。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "昨天尾牙上所吃的許多料理，",
        "unit_id": 105913,
        "voice": "vo_adv_5056000_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像比想像中還貴上許多……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即便客氣地說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【美食殿堂】的財政仍是岌岌可危。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了過新年所留的積蓄",
        "unit_id": 105913,
        "voice": "vo_adv_5056000_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也已經見底了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如今手邊，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只剩下幾個",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當季特價購入的橘子……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只剩這個時期價格便宜的橘子，",
        "unit_id": 106012,
        "voice": "vo_adv_5056000_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還真是寫實又生動得詭異……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳從剛剛開始就在做些什麼啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說這個嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_5056000_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是在做點假花。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "年初年末的休假期間，",
        "unit_id": 105913,
        "voice": "vo_adv_5056000_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可能也沒有平常的打工能做。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下認為接一些這種在公會小屋也能處理的工作是最適合的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哪怕一點也好，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下希望能以此貼補【美食殿堂】的財政。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_5056000_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "麻煩您處理這個紙箱裡的──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們怎麼還能悠悠哉哉地做這些副業！",
        "unit_id": 106012,
        "voice": "vo_adv_5056000_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都已經快新年了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都要過年了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "年菜呢！？",
        "unit_id": 106012,
        "voice": "vo_adv_5056000_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "年糕湯呢！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n新年就是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能和大家一起悠閒享用美味料理的日子吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才不要窩在家做副業啊……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是，",
        "unit_id": 105913,
        "voice": "vo_adv_5056000_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到底該怎麼辦呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也能從公會管理協會那裡",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接下委託賺取酬勞，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但這樣真的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能在新年前",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "擺脫現在的財政困境嗎──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒問題的！",
        "unit_id": 1,
        "voice": "vo_adv_5056000_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n小凱留！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "小可蘿！{player}！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "豪華的新年！",
        "unit_id": 105812,
        "voice": "vo_adv_5056000_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "年菜、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "年糕湯、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "入味的燉煮料理！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要大家一起努力，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就一定能取回它們！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……貪吃佩可？",
        "unit_id": 106012,
        "voice": "vo_adv_5056000_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在公會陷入困境時，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳是跑去哪裡溜達了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯♪",
        "unit_id": 105812,
        "voice": "vo_adv_5056000_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了找到辦法解決【美食殿堂】的大危機，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我到街上去尋找線索了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為一直思考著新年的事情，",
        "unit_id": 105812,
        "voice": "vo_adv_5056000_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我現在肚子很餓呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "光是想到年糕湯，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就會讓人馬上流口水，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿嘿……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳、",
        "unit_id": 106012,
        "voice": "vo_adv_5056000_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳可別在這種狀況下說",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「大家一起去吃飯吧☆」",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "之類的喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這一點都不好笑……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一點都不好笑，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在",
        "unit_id": 105913,
        "voice": "vo_adv_5056000_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們手頭就只剩橘子了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果您能接受，那請用吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦♪",
        "unit_id": 105812,
        "voice": "vo_adv_5056000_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n謝謝妳，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "橘子酸味進到飢餓的肚子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……啊啊，",
        "unit_id": 106012,
        "voice": "vo_adv_5056000_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "僅存的一點食糧瞬間就消失了啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
