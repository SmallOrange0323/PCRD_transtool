        "words": "小、",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_057"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥……！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n在保護我之前，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要先保護好你自己呀……！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n再這樣下去，小哥就要被打到面目全非了……！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就這樣默默看著小弟被打倒，",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_058"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n可有損幫主的名譽……！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以……！！　",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "保……",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_059"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "「保護部下是上司的職責」！！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不准欺負我的小弟！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n既然你有此意，那麼我也……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "喝啊啊啊──！",
        "unit_id": 116511
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "好痛好痛！",
        "unit_id": 1614,
        "voice": "vo_adv_1165002_060"
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "真的很痛！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "\n我不是魔物啦！！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "…………什麼？",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_061"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊啊啊啊啊啊！？！？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你變裝成魔物在保護這個地盤是嗎？",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_062"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還有……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "偷走了食物的人，是你對吧！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "……不行嗎。",
        "unit_id": 416,
        "voice": "vo_adv_1165002_063"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "為了生存，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "我別無手段可選了啊！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼！？",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_064"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "居然還敢惱羞成怒！？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我可是被你害得惹上了麻煩欸！？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看樣子你似乎沒有在反省呢。",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_065"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n那麼我就把你的首級交給【王宮騎士團】好了！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "等等……！",
        "unit_id": 415,
        "voice": "vo_adv_1165002_066"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "事情會發展成這樣，",
        "unit_id": 415,
        "voice": "vo_adv_1165002_067"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "都是因為我！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "\n哥哥他沒有錯，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "真對不起！！！！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳是那時候的……",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_068"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "原來你們是兄妹嗎。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……畢竟妳有替我叫來小哥，我欠妳一次人情，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n要我聽聽妳的藉口，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也不是不行啦。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……原來如此。",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_069"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你們的父母「消失」了，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n而且你們在被領養的家庭又被欺負，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以才會離家出走是吧。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "要是只欺負我就算了。",
        "unit_id": 416,
        "voice": "vo_adv_1165002_070"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "但是那些傢伙",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "連我妹妹都想打。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n所以我",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "為了保護妹妹，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "決定要兩個人一起逃出來活下去！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼……",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_071"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然下決心時很獨當一面，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但終究還是小鬼呢。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你如果決定不去討好他人，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要兩個人活下去，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我會替你們加油。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_072"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你所做出的事是怎麼回事！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n居然在一般民眾做生意時搗亂，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n把你口中說想保護的重要妹妹",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "捲進了危險之中！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你的生活方式，",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_073"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "以幫派的作風來說，不成道理！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你做為那孩子的頭目，太失職了！！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "……我知道。",
        "unit_id": 416,
        "voice": "vo_adv_1165002_074"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n但是，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "以後我該怎麼辦才好……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼，",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_075"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真拿你沒辦法。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要讓你們兩個人",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n都來接受我們家族照顧，也不是不行喔！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "家族？",
        "unit_id": 416,
        "voice": "vo_adv_1165002_076"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼。",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_077"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我是蘭德索爾裡最偉大幫派裡的大幹部！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n在我底下",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可是有很多部下的！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而這位小哥，",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_078"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "正是我的親信！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n雖然他一臉呆呆的，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但其實挺可靠的喔！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "可是……",
        "unit_id": 416,
        "voice": "vo_adv_1165002_079"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你如果不情願，只要金盆洗手就好了。",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_080"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們的宗旨，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是去者不留，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "來者不拒，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n想怎麼做",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是你們的自由。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "……這樣啊。",
        "unit_id": 416,
        "voice": "vo_adv_1165002_081"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n反正我們一直逃跑也累了，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "就過去看看好了。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "嗯！",
        "unit_id": 415,
        "voice": "vo_adv_1165002_082"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯嗯。",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_083"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這樣就圓滿解決了……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在這之前。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊嗚嗚……",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_084"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我得去向老大報告",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們要照顧的小鬼又增加了……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥……",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_085"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說的也是！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n畢竟我身為幫主，做出了英明的判斷，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n區區一兩個懲罰……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……嗚嗚。",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_086"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我才不會",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "害怕被懲罰呢……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n祈梨大人",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要去貫徹自己的道義了！！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，{player}一面為藏不住害怕的祈梨打氣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並和新的祈梨幫成員一起"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "踏上了歸途。"
    }
]