[
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}受到祈梨召集，前往小巷子裡。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當他抵達時，祈梨和小孩子們正在那裡等著他。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那麼，",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然全員到齊了，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就開始今天的會議吧！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n首先從東幫開始報告！！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "是的！",
        "unit_id": 5411,
        "voice": "vo_adv_1165002_001"
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "東幫沒有問題！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "\n",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "我們和西幫的小孩們也沒有起爭執，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "一起在這邊的地盤融洽地玩耍著！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "我們第一次去家族開的攤販裡幫忙時，",
        "unit_id": 5411,
        "voice": "vo_adv_1165002_002"
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "\n西幫的小孩們教了我們很多……",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "\n",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "有願意幫助我們的夥伴，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "真是太好了！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "嘿嘿！",
        "unit_id": 111,
        "voice": "vo_adv_1165002_003"
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "東幫也有教我們讀書，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "彼此彼此吧！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "唉",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "～",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "要是這個地盤裡有能夠避風雨的地方，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "\n我們讀書的時間，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "應該就可以再增加一點了吧。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "需要能遮蔽風雨的地方，",
        "unit_id": 5411,
        "voice": "vo_adv_1165002_004"
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "我也是這麼想的！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "\n",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "這個地盤",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "要是能建立祈梨幫的據點，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "身體虛弱的小孩就也能來玩了！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "\n",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "幫主，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "把大家一起蓋據點這個計畫，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "東邊的小孩",
        "words": "當作是下次的議題如何呢？",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就這麼辦！",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "順便也要蓋祈梨大人的房間喔！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n呵呵呵，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你們直到不久前明明還水火不容的……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這都是多虧有祈梨大人的指導呀！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那麼下一個",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "換西幫報告！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "……",
        "unit_id": 111,
        "voice": "vo_adv_1165002_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……？",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n怎麼了，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你肚子痛嗎？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "都是因為你太愛吃了～",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "才不是呢！！",
        "unit_id": 111,
        "voice": "vo_adv_1165002_009"
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "……其實啊，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "我們被一般民眾",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "懷疑是不是有偷東西。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼！？",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "告訴我",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "更詳細的情況！！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "我們的成員",
        "unit_id": 111,
        "voice": "vo_adv_1165002_011"
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "剛好在犯案現場，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "所以",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "就被一般民眾懷疑他也是共犯。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "要是我沒有趕過去，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "店家應該已經報案了。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "確實",
        "unit_id": 111,
        "voice": "vo_adv_1165002_012"
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "無家可歸的小孩會被懷疑也很正常啦……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "總之就是這樣，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "西邊的小孩",
        "words": "\n大家暫時別去市場會比較好喔。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼叫「總之就是這樣」",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這可是關係到祈梨幫名譽的",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嚴重問題欸！？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我明白情況了！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這件事情",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就交給我處理！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥，",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們要去找出犯人！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n跟著祈梨大人一起來吧！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要待在這裡，",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "犯人應該就會出現了……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "……小鬼逃到哪裡去了！？",
        "unit_id": 1,
        "voice": "vo_adv_1165002_016"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n我這次一定要把你交給【王宮騎士團】！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "……！",
        "unit_id": 416,
        "voice": "vo_adv_1165002_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看到了嗎！？",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那傢伙就是犯人！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那傢伙逃跑的通道",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有兩個出口！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呵呵呵……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們要繞到前面去",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "堵住他的去路！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你走這裡！",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我去封住那邊的路！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就這樣，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你可別冒失搞砸了喔！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……哦？",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_021"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "犯人往這裡跑來了呢！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呵呵……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "居然會選擇有我在的這條路，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看來你的命數已盡。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n1，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "2……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "鏘鏘！",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_022"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "祈梨大人子駕到！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "趕快束手就擒吧──",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "抓到妳了！",
        "unit_id": 1411,
        "voice": "vo_adv_1165002_023"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "臭小鬼！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "…………咦？",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_024"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "偷過一次還不罷休，",
        "unit_id": 1411,
        "voice": "vo_adv_1165002_025"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "居然一再把我們的店當作目標……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n我這次可不會再原諒妳了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不、",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_026"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不是……！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不是我……！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "妳說什麼！？",
        "unit_id": 1411,
        "voice": "vo_adv_1165002_027"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n聲音那麼小，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "連妳說了什麼藉口都聽不見啦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小、",
        "unit_id": 116511,
        "voice": "vo_adv_1165002_028"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥……！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "你不是前陣子來打工的大哥嗎！",
        "unit_id": 1411,
        "voice": "vo_adv_1165002_029"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "……嗯？",
        "unit_id": 1411
    },
    {
