[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔～唔唔唔～……？",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個，棲息在歐拉爾高山的魔物是～？",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "鷹鳥、巴倫鳥……還有就是？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n西、西？叫作西什麼的？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，是叫西牟鳥……",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔～我實在太不擅長記魔物的名字了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哇，呀！？",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n嚇我一跳！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，哥哥！",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好久不見！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是的，請哥哥別突然從背後叫我好嗎～？",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我被嚇得差點要從嘴裡噴出吊燈了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（唔唔。會長明明有交代我",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n盡量不要和哥哥接觸的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但這次是哥哥主動來向我搭話，應該不算犯規？）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（可是……",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然我很寂寞，但還是得盡可能不和哥哥扯上關係才行。）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個～",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n請問哥哥有什麼事嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我現在正好在讀書……",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想集中精神，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以我沒什麼時間陪哥哥的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不會不會，我一點也不用功！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我都是快要考試了才臨時抱佛腳拼死地背書的，",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "其實只要平時更踏實地準備，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就不會在緊要關頭時手忙腳亂了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯嗯？這種問法是……？",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "難道哥哥不知道什麼叫作『讀書』嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥沒有讀過書嗎？",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這是多麼幸福的人生呀！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n真令人羨慕！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "畢竟哥哥失去記憶了。",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這也是沒辦法的……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個，說起讀書，",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "它可是比任何魔物都還要可怕又麻煩的人類之敵喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊哈哈。",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個呀……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想進位在蘭德索爾裡的",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n設計師培訓學校學習。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為我最喜歡縫紉了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然這是件頗困難的事，不過因為我家並不富裕，",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我想盡可能地在入學考試拿高分，拿獎學金入學。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒錯，優秀的新生可以拿到獎學金喔。",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，其實我不太擅長讀書……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我只要能合格，就感覺有如公雞報喜了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不是公雞報喜，應該是可喜可賀？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿……",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我正在努力讀書。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我很不擅長記單字，在這方面吃了不少苦頭呢。",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "術科測驗多少還能應付，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但筆試實在很不妙。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我在家裡又無法集中精神學習，",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n最近都只帶著學習用具到處閒晃……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我一直有在讀書。",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為下週就要考試了，所以我很著急。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請哥哥教我讀書……",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是辦不到的吧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "畢竟哥哥失去記憶了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想請個家庭教師。",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我看就來拜託靜流姐好了？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊哈哈。",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n反倒是哥哥，是不是有很多事想請教我呢？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "失去記憶的話會什麼都不懂吧，這樣會很不安吧。",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果有什麼我知道的事，我都能教哥哥喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有人一起學習的話，也能得到鼓勵，",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還能互相監視，不讓對方逃避學習，我覺得效果很好……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我們兩人就一起學習吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "以前，我常像這樣……",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n和哥哥並肩坐在一起讀書喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真懷念呢，欸嘿嘿♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊……",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_031"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我說的哥哥不是指哥哥你，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n該說是其他的哥哥嗎～？那個，那個？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，哥哥問我為什麼要叫你哥哥……？",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "該說是說來話長，自、自然而然就這樣了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請哥哥別計較那個了，我們來讀書吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個呀。",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_033"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我現在正在背魔物的名字和牠們的棲息地。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為魔物能用來做衣服之類的素材，",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這個部分不好好地熟記是不行的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以考試科目裡，",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_035"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n有考關於魔物知識的問題喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然住在城鎮的話很少會遇到魔物，",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是記起來也沒有損失啦。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我打算用諧音之類的方式來記，",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_037"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是實在很費力。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "光是膠狀魔物就有上百種，",
        "unit_id": 101112,
        "voice": "vo_adv_1011002_038"
