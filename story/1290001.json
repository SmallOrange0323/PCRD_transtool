[
    {
        "type": "background",
        "background": "501623"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}獨自一人來到了沉睡中的厄莉絲所在的城堡。"
    },
    {
        "type": "still",
        "still": "513600502"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……厄莉絲曾因為對{player}的心意過於強烈，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而期望能夠活在只有兩人的理想鄉中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是這個心願同時也會將世界導向滅亡。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人為了守護世界，而與厄莉絲對抗。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n……最終，厄莉絲的願望沒有達成，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n眾人也以為厄莉絲因為力量耗盡而消散了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但是，厄莉絲的存在卻因為米奈娃而被保護了下來。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n透過某個事件，{player}等人知曉了厄莉絲的存在。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了尋求她的幫助，他們前往被隱藏的城堡與她再次相見。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是……在與{player}他們一同解決事件後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她為了修復受傷的身心，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再度陷入了深沉的睡眠……"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_000"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500510"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……騎士先生……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_001"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "來找我了啊。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……那個。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "今天，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是有什麼事嗎……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "探望……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_003"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……這樣啊。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n你，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是在擔心我呀。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "謝謝。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我的話，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒問題的。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "雖然要馬上甦醒，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是有點困難……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過修復的過程很順利。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_007"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "放心了嗎……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……那麼，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我也放心了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "呵呵。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不要道歉。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_008"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為是我自己決定要做的事。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……能夠幫上騎士先生的忙，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "真是太好了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……騎士先生很溫柔呢。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "真的……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n居然還會關心我。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……沒錯。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_010"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n騎士先生對誰都很溫柔。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n所以……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "並不是只有對我，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_011"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "特別好。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……老實說，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我好想要就這麼以為……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n但抱有這樣的期待，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還是會，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有那麼一點……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "令人害怕，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嗯……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_013"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我想想……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……那麼。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_014"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我想聽聽，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你的事。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為現在的我，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_015"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "除了沉睡以外什麼都做不到。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "能知道的，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就只有這座城堡中的事。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過如果發生了會讓我體內的米奈娃殘渣",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_016"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n起反應的世界異變，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那就是例外了……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但殘骸就是殘骸。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "權限是有限的。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所以……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_017"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在我沉睡的這段期間，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生都做了些什麼事呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我很想知道。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_018"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "謝謝。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不自由這件事，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_019"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我已經習慣了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n因為從我誕生以來就是這樣。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "即使如此，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_020"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我還是知道了騎士先生的事。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n你的喜悅與悲傷，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "以及痛苦……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還有締結的羈絆。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那些你所經歷過的一切。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就連從索爾之塔被解放之後。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_021"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n即便不自由，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也還是擁有力量。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n有足以借給美空他們的力量。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……但是現在。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_022"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n就連那股力量，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也失去了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "雖然不是想以這個事實當作藉口……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_023"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但我想向溫柔的你撒嬌。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在不會會錯意的程度內……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那之後……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}向厄莉絲述說了"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在「背面世界」中冒險的事。"
    },
    {
        "type": "still",
        "still": "220100102"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "220100701"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "220500401"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500510"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「背面世界」……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_024"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n騎士先生的冒險，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "已經到那麼遠的地方了呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我知道有這個世界存在……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_025"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n因為入口，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就離這座城堡很近。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但並不知道詳情。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……說到底。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_026"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n沒有騎士先生的世界，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒有了解的必要。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為這附近是隱藏資料夾",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_027"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "──該怎麼說，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "非常難",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "找到的地方。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n戒備森嚴到，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "要是沒有線索，就連霸瞳皇帝也無法認知到這裡……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所以，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "用來藏匿東西正好適合。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_028"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這是怎麼回事呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n照騎士先生說的話，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那裡也不同於複製的阿斯特朗，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n是非常遼闊的世界，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "而且竟有許多個……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有這可能嗎……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……還有。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_029"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n【幻變少女】",
        "unit_id": 129011
    },
    {
        "type": "still",
        "still": "210709902"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500510"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_030"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那些",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "【幻變少女】的冒險者們……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n有在努力嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……這樣啊。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_031"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n如果沒有造成騎士先生的困擾……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n那就好了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我製作出的角色的一部分，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_032"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "似乎還殘留在她們體內……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "即使如此，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我也不會說",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「她們和『製造者』相似」。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳們，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是靠著自己的意志，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "去尋求騎士先生的幫助吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "咦……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_033"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我看起來，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "像那樣嗎……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "思考……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_034"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "啊啊……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_035"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "讓騎士先生誤會了呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我只是想聽聽你說的故事。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n並不是在羨慕你們的冒險……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "該怎麼做才好……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_036"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "說不是",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "的話，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生也會不高興吧……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_037"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……我？",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_038"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n和，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……騎士先生，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_039"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會錯意了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我有興趣的，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_040"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就只有你一人。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不管是「背面世界」的事情，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還是【幻變少女】的事情。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為是你告訴我的……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我才會稍微，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有那麼點在意。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不過。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_041"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你誤會了，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_042"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "什麼的。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n實在是說不出口。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_043"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嗯。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n等我恢復精神之後。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_044"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n是你的邀請。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……哪天……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_045"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n等我恢復精神之後。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n那個時候，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "希望你能再來邀請我。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_046"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嗯。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就這麼做吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生居然會邀請我一起冒險，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_047"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "真是意想不到。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……現在的我……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_048"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒有力量。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n別說是自行甦醒了，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就連將騎士先生關在這個夢境中也辦不到。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……又更深切地……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_049"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n讓我了解到。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我真的是",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "什麼都沒有呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "既沒有自由，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_050"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也沒有力量。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……連同出生也是，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "毫無意義。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "甚至……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_051"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n就連活著的目的，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也失去了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……只有騎士先生和我的理想鄉。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_052"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我已經不再奢望，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "能到達那樣的地方。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……可以的話……",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_053"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我想就這樣永遠地沉睡。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不再甦醒。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_054"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n就這樣",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不被任何人注意到，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n和這個世界的終結，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一同消逝。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……明明是這麼想著的。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_055"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我卻，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_056"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "又遇見了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "再次地，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "見到了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n就像這樣。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "和你重逢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這個事實。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_057"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n深深烙印在我的心中。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……所以。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_058"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n如果，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n期望和我一起去冒險的話……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……為了回應這份心意。",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_059"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我也許可以試著活下去。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……我說，",
        "unit_id": 129011,
        "voice": "vo_adv_1290001_060"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n再多說一點吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不管是怎樣的事情都好……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
