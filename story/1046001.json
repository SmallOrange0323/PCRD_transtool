[
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}走在山路時，\n傳來有人在激烈戰鬥的聲音。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喵！ 喵，喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_000"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "太好了，",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "打倒牠了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "領教到我的實力了吧喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……嗯，",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哇啊啊啊啊啊！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我以為打倒的這隻魔物居然分裂了喵啊啊啊！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚嗚嗚，真棘手喵……",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我以為只要從反方向同時攻擊，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n就能簡單的打倒牠們喵……至少再有一個人幫忙的話──",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喵……？ 在那邊的是冒險者嗎喵？",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喵喵喵─！ 來得正好喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你來幫我一下喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喵喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那麼，當我說「預備─起，喵」，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你就從另一邊攻擊喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "預備─起，喵",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "！",
        "unit_id": 104611
    },
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很完美喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "另一隻也……預備─起，喵喵！",
        "unit_id": 104611
    },
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "魔物２",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物２",
        "words": "！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喵喵！ ",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "大獲全勝喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "多虧有你幫忙喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖然想送你什麼當作謝禮，",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不巧的是，我身上沒什麼特別的東西喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是，總有一天我一定會答謝你的喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請期待吧喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼，我先告辭了喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "非常謝謝你喵！",
        "unit_id": 104611
    },
    {
        "type": "background",
        "background": "500211"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與貓耳少女分開後，\n{player}走在崎嶇不平的山路上。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喵？ ",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "感覺剛剛好像有人從山崖跌落了喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在那裡的，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不就是剛剛幫助我的人嗎喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不好了喵───！",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我現在馬上就來救你喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喵咕嚕靈！",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你很驚訝嗎喵？",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為我是貓獸，動作輕盈，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n所以很擅長跳躍、潛入之類的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯，這些話等等再說喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你身上都是傷喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喵─……",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你的傷不要緊吧喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你不介意的話……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "作為剛才你幫我的謝禮，",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我以390盧幣的優惠價格賣你療傷藥喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什麼啊，你一臉被貓抓傷的樣子喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我可是將原價一倍以上的藥，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n特別優惠給你的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不要說這麼失禮的話喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我可是將原價一倍以上的藥，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n特別優惠給你的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯─，真沒辦法喵……",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n就算這麼說，但剛剛受到你的幫助喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯，",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我決定了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "今天就讓你試用吧喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你說謝謝我……",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這是我給你的謝禮，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n所以你沒有必要向我道謝喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……啊，對了，",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n雖說要向你道謝，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "剛剛忘了問你的名字喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯……你叫這個名字啊喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我是珠希喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為我在鯛魚燒店打工，常常會到處奔走，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n所以我想我們一定會再見面的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "之後也請多關照喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼我就先告辭了……",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦，喵喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你臉頰上還有傷口喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是我已經沒有療傷藥了喵……",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_031"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣的話――",
        "unit_id": 104611
    },
    {
        "type": "still",
        "still": "104600101"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "――舔。",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_032"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你問我做什麼，",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_033"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為你還有傷口，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我就是舔一下幫你消毒喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈，你好像相當驚訝喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_034"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "算了，這是給你的優惠！",
        "unit_id": 104611,
        "voice": "vo_adv_1046001_035"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "再見喵―♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "珠希留下不知所措的{player}，\n如風般離開了……"
    }
]