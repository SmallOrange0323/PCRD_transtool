[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "遭到吸血鬼獵人攻擊的隔天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪身穿著禮服，站在全身鏡前欣賞著自己的美。"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真不敢相信……！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n今天的我",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也是這麼美！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "穿上漂亮的禮服，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "又顯得更美！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "世上竟然會有這樣的美存在……",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這簡直",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是奇蹟啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過……",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在看到如此美麗的我之後，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我的心中也產生了欲望呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如你所見，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "現在的我",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n即使在世界萬物之中，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也是無可比擬的美，對吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我想要",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再變得更加美麗。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為此，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我想藉由",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "穿著更有魅力的漂亮衣服，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來進一步襯托我的美。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "話雖如此，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我也知道這只是我的癡心妄想。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼可能找得到",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "比身上這件禮服更具魅力的衣服……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……不，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "等等。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對了……！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我美麗的腦細胞",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "突然閃過了一個絕妙點子！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "仔細想想，這是很簡單的事。",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n根本不用特地去找其他衣服……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只要將這件禮服的魅力加以展現，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所有的問題就迎刃而解了！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只用了１塊結晶，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就變得這麼美。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "同時使用３塊結晶，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你覺得會變成怎麼樣？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這樣",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "肯定會讓禮服美上３倍啊！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你害怕我會變得",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "比現在更美是嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這也難怪了，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為沒有人能夠想像",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n超越現在的美會是什麼樣子吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "老實說，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我也很害怕。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "自己",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "竟然要達到",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "超越這世間所能理解的美……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了美，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "什麼事我都會做。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n因為這正是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我被賦予的使命！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "事情",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是這樣！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n那就馬上來",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "試著同時使用10塊結晶看看吧！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我要試！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "禮服啊，展現出",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你真正的美來吧──！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好啦，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如何！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n看到變得更美的禮服，你有何感想？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "──呃，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真奇怪。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n總覺得看起來跟之前沒什麼兩樣……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "果然是這樣呢……",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_016"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唔，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "想不到我的美之理論竟然是錯的！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看來",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不管同時使用幾塊結晶，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n禮服的外觀都不會改變……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我還是想誇獎自己一下。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了變得更美，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "願意勇敢挑戰！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我們稍微去外面走走，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "轉換一下心情吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我也想要",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "向蘭德索爾的人們",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "分享我的美麗呢。",
        "unit_id": 126311
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_020"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "陽光好刺眼……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對了，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你知道",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "太陽為何會如此耀眼燦爛嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那是因為",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_021"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我長得太美，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓它看得臉都紅了！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "太陽也是有相當",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可愛的一面呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "嗯……？",
        "unit_id": 311,
        "voice": "vo_adv_1263002_022"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "那個女孩子……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "真不敢相信，",
        "unit_id": 1511,
        "voice": "vo_adv_1263002_023"
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "她怎麼會美成這樣……！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "\n讓我看得目不轉睛！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哎呀，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_024"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "街上的人們",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "全都直盯著我看呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這也是情有可原的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "她簡直就是活生生的藝術品……！",
        "unit_id": 311,
        "voice": "vo_adv_1263002_025"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n光只是看著她，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "就讓人心動不已！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n這是我第一次",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "有這種感覺……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "……就是因為這樣，",
        "unit_id": 1511,
        "voice": "vo_adv_1263002_026"
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "讓我好想獨自占有她。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "\n完全不想讓其他人看見她的美……！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……你這麼一說，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_027"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "的確是呢。總覺得氛圍有點古怪。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "感覺似乎跟平常有哪裡不太一樣……？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "像這樣的美……",
        "unit_id": 1511,
        "voice": "vo_adv_1263002_028"
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "我不想讓給任何人……！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "\n只有我能夠擁有",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "欣賞那份美的權利！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "居民3",
        "words": "妳在說什麼夢話！",
        "unit_id": 6511,
        "voice": "vo_adv_1263002_029"
    },
    {
        "type": "dialogue",
        "name": "居民3",
        "words": "\n我絕不允許",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "居民3",
        "words": "除了我以外的人直盯著她看！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "啊啊，",
        "unit_id": 1511,
        "voice": "vo_adv_1263002_030"
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "我受夠了。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "妳煩不煩啊！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "\n如果妳敢來妨礙我……！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "居民3",
        "words": "啊，好痛！？",
        "unit_id": 6511,
        "voice": "vo_adv_1263002_031"
    },
    {
        "type": "dialogue",
        "name": "居民3",
        "words": "妳打我……！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "居民3",
        "words": "\n既然這樣，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "居民3",
        "words": "我也要打回去！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "什麼……！？",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_032"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這到底是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼一回事！？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就算我再怎麼美，這未免也太──",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "──唔",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_033"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "！？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "現在又怎麼了……！？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我突然",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有一種很不好的預感……！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "吸血鬼之力",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_034"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "從中湧現而出……！？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n……原來如此，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是那些結晶的關係嗎！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為同時用了好幾塊結晶，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_035"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "禮服整個失控了！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "然後，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "街上的人們",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都被它給魅惑住了！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "連我也想不到會是這種情況……",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_036"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "吸血鬼的禮服",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "竟然具有",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這般力量……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "我要把蘭德索爾的人們全都打飛！",
        "unit_id": 311,
        "voice": "vo_adv_1263002_037"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n因為只有我",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "能夠欣賞那女孩的美！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "喝啊！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "大家",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_038"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都殺氣騰騰的……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再這樣下去，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "蘭德索爾的人們會為了得到我",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而相互爭執……！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果變成那樣，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_039"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我或許就成了傾國的美人！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哎呀，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_040"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這種情況要是持續下去，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "感覺後果不堪設想呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你沒有受到魅惑的影響，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是不幸中的大幸！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過話說回來，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_041"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為什麼你沒事呢？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……喔，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_042"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為你和伊莉亞相處了很長一段時間，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n可能已經對吸血鬼有了抵抗力",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是嗎，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "原來如此呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一般人應該大多",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_043"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都對魅惑沒有抵抗力……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再這樣下去，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "蘭德索爾搞不好真的會滅亡呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……我",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_044"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不喜歡這樣。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果是因為我太過美麗，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_045"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而導致蘭德索爾滅亡的話，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n那也是沒辦法的事。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這我可以接受。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "然而，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_046"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果是因為失控的禮服",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n讓蘭德索爾面臨危機這種事，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我可不喜歡。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再說……",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_047"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我最沒有辦法接受的是，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "禮服竟然比我本人還來得搶眼！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這種事",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_048"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我絕不允許！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n說到底，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "衣服的存在就只是為了襯托出我的美罷了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我不會讓禮服",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_049"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來妨礙我的……！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n哪怕是吸血鬼之力，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也沒有辦法阻止我！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而且，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_050"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我美麗的腦細胞",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n已經想到解決這個情況的妙計了！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "總之，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_051"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只要想辦法處理這股魅惑就行了吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這種事",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很簡單。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果是我認真使出的可愛之力，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_052"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n要抑制住吸血鬼之力，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "肯定是綽綽有餘！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以說……",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_053"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你快點稱讚我吧！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就如同花朵需要水分，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_054"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而我所需要的是讚美的話語。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這是為了讓我變得更可愛、",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "更美麗動人！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好啦，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_055"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你別客氣！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n看你想怎麼稱讚我",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就儘管說出來吧！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_056"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很好。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這好像有點太常聽到了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了讓我變得更加地燦爛耀眼，",
        "unit_id": 126311,
        "voice": "vo_adv_1263002_057"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n需要與之相符的讚美！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再多多",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "稱讚我吧！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
