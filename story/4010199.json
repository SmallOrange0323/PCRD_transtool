[
    {
        "type": "background",
        "background": "509012"
    },
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……應該就是這裡了是也。",
        "unit_id": 103031,
        "voice": "vo_adv_4010199_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "今天，",
        "unit_id": 103031,
        "voice": "vo_adv_4010199_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "被人放在學校鞋櫃裡的",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "老舊信封。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "上頭寫著，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要在這裡等待……！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這一定是",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "挑戰書是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯嗯！",
        "unit_id": 103031,
        "voice": "vo_adv_4010199_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來者何人！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n還不快點現身，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你這可疑人士！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咕、",
        "unit_id": 103031,
        "voice": "vo_adv_4010199_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咕啊！？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒想到我會",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在這種地方被打敗，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "太、",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "太遺憾了，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是也……！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……呼～！",
        "unit_id": 103031,
        "voice": "vo_adv_4010199_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不愧是將軍！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n真是出色的隱身術是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這封信",
        "unit_id": 103031,
        "voice": "vo_adv_4010199_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "果然是將軍放的嗎？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "難道說為了叫我出來，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你特地",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "跑到了我的學校是也？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哦──！",
        "unit_id": 103031,
        "voice": "vo_adv_4010199_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你居然記得我的生日──！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n居然能夠實際體驗戰死來作為",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "生日禮物，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我真是",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "太感動了是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咦？",
        "unit_id": 103031,
        "voice": "vo_adv_4010199_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不只這樣？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這是",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "剛剛",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "殺死我的刀……！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n難道說，這個",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要送給我……！？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呼～！",
        "unit_id": 103031,
        "voice": "vo_adv_4010199_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "謝謝你！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n沒想到能從將軍那裡",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "獲贈一把刀……！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n製作得好精細，簡直就像真的一樣，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好美麗是也……！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "決定了！",
        "unit_id": 103031,
        "voice": "vo_adv_4010199_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要用這把刀",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來永遠守護",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來吧，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "今天我們兩個就這樣",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "直接",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "到街上漫步是也！",
        "unit_id": 103031
    }
]