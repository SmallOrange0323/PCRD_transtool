[
    {
        "type": "background",
        "background": "505032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "成功擊退了魔物，開心地看著幽靈與孩子們嬉戲的景象之後――"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？　",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "怎麼了嗎？　",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "最後還有一個請求嗎……？",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不好意思，{player}。\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "剛才幫我們阻止魔物的那些幽靈們",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n好像想跟我們說話。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的。",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "說是有個請求……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯嗯。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦咦！？　",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這、",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣再怎麼說也……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗚嗚。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那、",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他們好像是一對夫婦，\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要是能在這麼開心的節日，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "約、",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "約會的話，\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "把這當作紀念，就能毫無牽掛地順利升天了。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "然後",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他們問說能不能……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "讓太太附身在我身上，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n先生則是附身在{player}身上，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "讓兩個人可以在這一天",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "做最後的約會……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我不允許！　",
        "unit_id": 2412,
        "voice": "vo_adv_1081002_006"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "絕對不允許！",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n就算神明點頭，我也不可能答應的！",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗯？　",
        "unit_id": 2412,
        "voice": "vo_adv_1081002_007"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "什麼？　",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "下次會介紹很不錯的女幽靈給你認識，",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n所以請不要這麼生氣？",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "耍人……",
        "unit_id": 2412,
        "voice": "vo_adv_1081002_008"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不對，耍骷髏頭也要有個限度啊！",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n本大爺怎麼可能會輸給這種誘惑……",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗚，唔唔唔唔。",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n也、",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "也不是不能考慮一下啦……",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸、",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_009"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你的意志力也太薄弱了吧……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個……",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "其實我也很感謝他們幫忙救了那些孩子們，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n也很想盡可能地做些什麼來答謝他們，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但約會就有點……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而且，",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還得顧慮{player}的想法。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可、",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可以嗎！？　",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可、",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可是。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可是可是……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗚嗚……",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我知道了。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n因為我從來都沒有約會過，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以不知道能不能達成他們的願望……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我、",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我會加油的。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？　",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我知道了。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "首先是在鎮上散步……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要、",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要牽著手。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "小伙子！　",
        "unit_id": 2412,
        "voice": "vo_adv_1081002_015"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "你有先消毒過嗎！？",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n要是你敢用你骯髒的手碰忍，",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我就把那手指給咬斷！",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你別說這麼可怕的事啦。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那麼，",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "麻煩你了。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊……",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "人類的手，真的很溫暖呢。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n因為爸爸一直都冷冰冰的。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "唔。",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_019"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "感覺我的臉開始發燙了……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？　",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_020"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "想要聽一些男女朋友之間會說的肉麻話",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗎？",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "又、",
        "unit_id": 2412,
        "voice": "vo_adv_1081002_021"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "又要做了啊！　",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗚唔唔唔唔……",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……親～",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "親愛的……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我、",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我愛你。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍、",
        "unit_id": 2412,
        "voice": "vo_adv_1081002_023"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍……",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳也太不會演戲了吧。",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這樣很可愛唷！",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不論什麼時候看到你，",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "都好帥……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦……",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_025"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那、那個，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是在演戲",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對吧……？",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那、",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你這樣看著我，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我不知道該做出什麼反應才好……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗚嗚。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這是怎樣……",
        "unit_id": 2412,
        "voice": "vo_adv_1081002_027"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這是怎樣這是怎樣這是怎樣\n這是怎樣這是怎樣這是怎樣這是怎樣這是怎樣這是怎樣――",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_028"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你不要抖得那麼誇張啦。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "雖然我快被怒氣衝昏了頭，",
        "unit_id": 2412,
        "voice": "vo_adv_1081002_029"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n不過這都是為了認識可愛的女孩子。",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍耐，",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我要好好忍耐……！",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個，",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那麼",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "接下來要做什麼……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？　",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們牽手的方法不好",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "？",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣有些距離感，覺得很寂寞？　",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可是我覺得現在已經靠很近了。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不是那種距離，",
        "unit_id": 108111,
        "voice": "vo_adv_1081002_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而是心的距離……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "原、",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "原來如此。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "談戀愛這門學問，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真的很深奧呢。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要、",
        "unit_id": 108111,
