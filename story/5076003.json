        "voice": "vo_adv_5076003_054"
    },
    {
        "type": "dialogue",
        "name": "博士",
        "words": "是啊，",
        "unit_id": 7511,
        "voice": "vo_adv_5076003_055"
    },
    {
        "type": "dialogue",
        "name": "博士",
        "words": "我的專門領域是預測危機，",
