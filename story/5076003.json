    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "都會拯救現實世界的！",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n畢竟我還得參加每年例行的派對呀！",
