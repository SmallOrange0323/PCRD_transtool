        "name": "鈴奈",
        "words": "抓了這麼久！？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這種事要早點說嘛！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "放心吧，",
        "unit_id": 10511,
        "voice": "vo_adv_5076003_035"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "那是不可能的。",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "這隻……",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "是叫小棉花糖",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "嗎？",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "牠的靈力",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "低得驚人。",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "就連我看到牠，",
        "unit_id": 10511,
        "voice": "vo_adv_5076003_036"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "都會把牠當成普通的狗，",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "所以妳們大可放心！",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "我在找的妖魔，",
        "unit_id": 10511,
        "voice": "vo_adv_5076003_037"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "有著山一樣巨大的身驅，穿梭在靈界的黑暗中……",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n豎立的毛髮",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "像熊熊燃燒的火焰……",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n閃著光芒的鋒利尖牙",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "能咬碎一切……",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "而且……",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "嗚嗚，",
        "unit_id": 10511,
        "voice": "vo_adv_5076003_038"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "光說就覺得可怕，我說不下去了……",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
