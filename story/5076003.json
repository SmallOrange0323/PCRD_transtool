        "voice": "vo_adv_5076003_057"
    },
    {
        "type": "dialogue",
        "name": "博士",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "博士",
        "words": "下次見到他時，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "博士",
        "words": "務必把他抓來這裡！",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "博士",
        "words": "話說回來……",
