    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然人家聽不太懂，",
        "unit_id": 117911,
        "voice": "vo_adv_5076003_056"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但感覺好隨便喔……",
