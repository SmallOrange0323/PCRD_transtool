        "voice": "vo_adv_5076003_039"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "博士的研究",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "究竟是正確的，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "還是錯誤的，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n果然還是",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "令人搞不懂……",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "{player}，你也在試圖拯救世界吧？",
        "unit_id": 10511,
        "voice": "vo_adv_5076003_040"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "或許我們的目的不同，",
        "unit_id": 10511,
        "voice": "vo_adv_5076003_041"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "但現在就互相合作吧。",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n如果",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "發現感覺很危險的妖魔，",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "就通知我。",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "聽好了，",
        "unit_id": 10511,
        "voice": "vo_adv_5076003_042"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "記得千萬別刺激牠，",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n那個妖魔的靈力，",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "在靈界之中也是數一數二的。",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "光靠幾個人類合力，",
        "unit_id": 10511,
        "voice": "vo_adv_5076003_043"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "對上牠是毫無勝算……",
