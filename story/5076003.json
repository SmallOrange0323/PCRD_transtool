    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "當然！",
        "unit_id": 10511,
        "voice": "vo_adv_5076003_044"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "我無論如何",
