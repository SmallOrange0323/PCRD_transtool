    {
        "type": "dialogue",
        "name": "優衣",
        "words": "把、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "把頭抬起來……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿♪",
        "unit_id": 100111,
        "voice": "vo_adv_9070156_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "被誇獎了♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
