    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不管是跟什麼樣的魔物戰鬥，",
        "unit_id": 100311
