    {
        "type": "dialogue",
        "name": "怜",
        "words": "敵人體型越大越強壯，",
        "unit_id": 100311,
        "voice": "vo_adv_9070156_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就越需要能遠距離攻擊的火力。",
        "unit_id": 100311
