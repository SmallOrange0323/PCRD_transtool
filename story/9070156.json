    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "勝利勝利♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "可璃亞、普蕾西亞",
        "words": "好厲害……！\n好厲害。",
        "unit_id": 1,
        "voice": "vo_adv_9070156_001"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
