        "type": "dialogue",
        "name": "日和",
        "words": "真是的～",
        "unit_id": 100111,
        "voice": "vo_adv_9070156_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這種事等等再說！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "首先",
        "unit_id": 100111
