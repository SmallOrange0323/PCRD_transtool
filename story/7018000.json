[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "來到露娜之塔的{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n陪在他身旁的還有冒失女僕鈴莓。"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "與你的記憶有關的線索",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就在這裡啊。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n既然如此──",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有句話叫平安回家前都要多加小心",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "。\n為了不讓你受傷，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也會全力以赴地服務你的！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那我們就",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "趕快進塔裡……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "──呀哇！？",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……對、",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我居然牽連了你，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "讓你跟我一起跌倒了……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我馬上到旁邊去……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這明明是我的錯……",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你這個人真是的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "托你的福，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我完全沒有受傷。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不管我再怎麼小心，還是冒冒失失的……",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這實在是太丟臉了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果能改過來，我也很想改掉，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但就只有這一點……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……沒、",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒事！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "反省是很重要，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但也不能這麼消極啊！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好了，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就打起精神，重新開始吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "…………說到這個，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要怎麼進入塔裡啊？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "原來如此，",
        "unit_id": 103113,
        "voice": "vo_adv_7018000_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是使用在這裡的術式來移動啊。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀！？",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有個女孩子在不知不覺間冒出來了！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "…………難道說，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你認識她嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "…………",
        "unit_id": 103113,
        "voice": "vo_adv_7018000_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃……",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "被漂亮的人盯著看，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "會讓人很緊張呢！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "初次見面，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我叫鈴莓。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我是在當占卜師的忍。",
        "unit_id": 103113,
        "voice": "vo_adv_7018000_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "旁邊這位則是我的……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "咻～！",
        "unit_id": 2411,
        "voice": "vo_adv_7018000_012"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這位女僕妹妹挺清純的嘛！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n本大爺對小鬼沒興趣，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "但仔細一瞧，妳發育得還不錯……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n好，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "就讓妳來服侍本大爺吧！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀哇～！？",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "骷、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "骷髏頭說話了耶！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "它是魔物嗎！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "突然叫人魔物，妳這小鬼真是沒禮貌啊！",
        "unit_id": 2411,
        "voice": "vo_adv_7018000_014"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n不過，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "因為本大爺心胸寬大……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n如果妳能用自己的胸口來安慰本大爺，也是可以原諒妳啦！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "唔嘻嘻～！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咿～！？",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請你不要靠過來……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真是的……",
        "unit_id": 103113,
        "voice": "vo_adv_7018000_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n別做這種丟臉的事情啦。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "沒有沒有，",
        "unit_id": 2411,
        "voice": "vo_adv_7018000_017"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n本大爺是想以靈媒的身分調查女僕妹妹……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n忍也很在意",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "後面的「那個」吧？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然是這樣沒錯……",
        "unit_id": 103113,
        "voice": "vo_adv_7018000_018"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "那",
        "unit_id": 2411,
        "voice": "vo_adv_7018000_019"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這件事就交給本大爺吧！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n本大爺會好好調查她的，仔細到像是把女僕妹妹的全身上下都舔過一遍！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀啊！？",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請你別過來，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請你別過來！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……啊！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我一個失手，",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "讓手杖飛出去了！！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "手杖到底飛去哪裡了……！？　",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "那本大爺就來見識一……",
        "unit_id": 2411,
        "voice": "vo_adv_7018000_022"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嘔嗚！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "為、",
        "unit_id": 2411,
        "voice": "vo_adv_7018000_023"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "為什麼有隻巨大的魔物從天而降……？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "…………啊！",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "找到",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我的手杖了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但手杖",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為什麼會從天上掉下來呢……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "鈴莓丟出去的手杖被樹反彈，",
        "unit_id": 103113,
        "voice": "vo_adv_7018000_025"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n最後打中飛在天上的魔物，掉到這裡來……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "事情應該就是這樣吧。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也就是說……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是天譴喔，",
        "unit_id": 103113,
        "voice": "vo_adv_7018000_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_7018000_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這位是妳的父親嗎！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對對對、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "都是因為我冒冒失失的……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不，",
        "unit_id": 103113,
        "voice": "vo_adv_7018000_028"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳不必介意。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為父親",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "以前雖是位德高望重的靈媒……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一如妳所見，",
        "unit_id": 103113,
        "voice": "vo_adv_7018000_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他現在變成了會在女兒面前坦蕩蕩地丟人現眼，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n令人十分困擾的骷髏頭。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
