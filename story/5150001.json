    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "帆稀表示害蘭德索爾陷入異常氣象的原因"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n是出自於環境系統「索爾生成系統」的狀況不佳。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在聽說這件事的隔天──"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "喂，",
        "unit_id": 311,
        "voice": "vo_adv_5150001_000"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "這是什麼啊？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "到底是怎麼搞的！？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "我還想說怎麼今天好涼快……",
        "unit_id": 1211,
        "voice": "vo_adv_5150001_001"
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "\n到昨天為止還沒有像這樣的水道吧！？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "居民3",
        "words": "我……",
        "unit_id": 413,
        "voice": "vo_adv_5150001_002"
    },
    {
        "type": "dialogue",
        "name": "居民3",
        "words": "是在做夢嗎……",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "…………",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哇～",
        "unit_id": 106711,
        "voice": "vo_adv_5150001_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n鬧得真大呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "帆稀……",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳也太會挑時機出現了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妳早就知道會變成這樣了吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為昨天涅比亞露出的表情，",
        "unit_id": 106711,
        "voice": "vo_adv_5150001_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就跟祈梨想到什麼惡作劇點子時的表情一樣啊～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我以防萬一來關心一下……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但情況完全超出我的預料呢～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是從根本去更改",
        "unit_id": 106711,
        "voice": "vo_adv_5150001_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "蘭德索爾的構造嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n道路完全變成水道了呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n水質……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是海水呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是連接大海了嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……我已經試過很多次了。",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞那傢伙，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還很周到地將環境系統的管理者權限",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只轉移到她自己身上，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "其他人都無法操作。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她真的是哦，",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有夠愛耍小聰明的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊啊，受不了那孩子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到底在想什麼──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這種事",
        "unit_id": 190911,
        "voice": "vo_adv_5150001_010"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "還用得著我說嗎♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞！",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗨～",
        "unit_id": 190911,
        "voice": "vo_adv_5150001_012"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "菲歐♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n今天天氣真好♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳不覺得正好適合來惡作劇嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "難道妳要說……",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妳是為了惡作劇",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就把事情鬧得這麼大",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯，",
        "unit_id": 190911,
        "voice": "vo_adv_5150001_014"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這還用問嗎♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳不記得我的興趣了嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "姐姐♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算這樣妳也做得太過火了！",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不想想這樣會造成多少人的麻煩！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "真的是這樣嗎？",
        "unit_id": 190911,
        "voice": "vo_adv_5150001_016"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n妳要不要再仔細看一下周遭呢？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "周遭……",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_017"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "既然如此……",
        "unit_id": 311,
        "voice": "vo_adv_5150001_018"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "就只有脫了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "這麼說來，",
        "unit_id": 1212,
        "voice": "vo_adv_5150001_019"
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "今年都沒有機會去海邊玩呢。",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "\n",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "居然能在居住的城市裡過暑假，",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "超棒的♪",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "居民3",
        "words": "這該不會是絕佳的賺錢商機？",
        "unit_id": 51311,
        "voice": "vo_adv_5150001_020"
    },
    {
        "type": "dialogue",
        "name": "居民3",
        "words": "\n立刻來準備擺攤",
        "unit_id": 51311
    },
    {
        "type": "dialogue",
        "name": "居民3",
        "words": "賣刨冰吧！",
        "unit_id": 51311
    },
    {
        "type": "dialogue",
        "name": "居民們",
        "words": "呀呼──！",
        "unit_id": 1,
        "voice": "vo_adv_5150001_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……這裡的人適應力也太強了吧。",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都有些順應氣氛隨遇而安的特質呢～",
        "unit_id": 106711,
        "voice": "vo_adv_5150001_023"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "看吧，",
        "unit_id": 190911,
        "voice": "vo_adv_5150001_024"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "大家不是都很樂在其中嗎♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唔！",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算是這樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也不改妳做得太過火的事實！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在立刻",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "把環境系統還來！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我、",
        "unit_id": 190911,
        "voice": "vo_adv_5150001_026"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不、",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "要♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n把這～麼有趣的東西",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "收起來不用太可惜了♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n就由涅比亞大人我",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "來把它活用得有趣又好玩吧♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……",
        "unit_id": 106711,
        "voice": "vo_adv_5150001_027"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要是我",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也能像她那樣堂堂正正地放手去做就好了呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我說妳！",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不要一臉羨慕的樣子！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呀哈哈♪",
        "unit_id": 190911,
        "voice": "vo_adv_5150001_029"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n菲歐真愛生氣～！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我差不多也該告辭了～♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞，給我站住！",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等等……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "溜得真快……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "聯絡她……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她也不會回應吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唉……",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個狀況該怎麼處理啊？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要環境程式在涅比亞手上的一天，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我不覺得事情會就此結束了……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總之，",
        "unit_id": 106711,
        "voice": "vo_adv_5150001_032"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只能去捕抓涅比亞了吧～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……說得也是。",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然無法否認事情如她所願進行著。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你……",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這不是別人，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而是我妹妹搞出來的問題。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我不能交給你去負責。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我會負起責任，",
        "unit_id": 190011,
        "voice": "vo_adv_5150001_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "去捕抓涅比亞的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
