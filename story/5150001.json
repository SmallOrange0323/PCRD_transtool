        "name": "純",
        "words": "就有如夏日度假村",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "一樣。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……語氣說得很沉重，",
        "unit_id": 105812,
        "voice": "vo_adv_5150001_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "報告內容卻很歡樂呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不不不，",
        "unit_id": 105812,
        "voice": "vo_adv_5150001_071"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是這樣吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n城鎮的構造發生改變",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是很糟糕嗎！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n城鎮的居民不要緊嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是的。",
        "unit_id": 104711,
        "voice": "vo_adv_5150001_072"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n居民似乎都換上了泳裝，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "享受著夏天的樣子。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "享受、",
        "unit_id": 105812,
        "voice": "vo_adv_5150001_073"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "夏天……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個國家的人民",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "適應力真強呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是，",
        "unit_id": 105812,
        "voice": "vo_adv_5150001_074"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然發生那種事情，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也不能坐著不管！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請幫我準備服裝！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要泳裝！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請幫我準備泳裝！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我絕對",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是要去玩哦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "請等一下，",
        "unit_id": 104711,
        "voice": "vo_adv_5150001_075"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "陛下。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n畢竟",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "城鎮構造發生變化，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是不可大意的異常狀況。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還請陛下在此",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "擬定對策。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_5150001_076"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "請陛下",
        "unit_id": 104711,
        "voice": "vo_adv_5150001_077"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好好工作。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼這樣～～～～～～～！",
        "unit_id": 105812,
        "voice": "vo_adv_5150001_078"
    }
