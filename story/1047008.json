[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔嗯。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n別一直看著我，少年。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真令人害羞。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "平常被面具跟頭盔所遮住的陽光，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n現在迎面照射到雙眼，好刺眼。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "感覺風撫過臉頰，",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n颼颼地吹著，讓人無法冷靜下來。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只、只是脫下了頭盔而已就……",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n像個普通的女孩子一樣，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果穿上可愛的衣服，不知道我會變得如何。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也許會因為羞恥心而爆炸。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n既然已經決定這麼做了，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "騎士是決不食言的。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好好的展現出原本的面貌……",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n換裝後，與少年去遊玩吃飯。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為是我自己想這麼做的。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以，我會加油的。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n沒問題的。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是，稍微讓我深呼吸一下。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "吸氣、吐氣……",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好了，沒問題的。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "首先在這家服飾店，",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n買件普通的衣服。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "然後借用更衣室換裝。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n接著把脫下的鎧甲跟頭盔，寄放在保險櫃。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很簡單。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我會把這個任務完美的達成給你看。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我會努力的，希望你為我加油。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……少年？",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你不回答的話我會很困擾，會很不安的。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "難道說。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為我一直磨磨蹭蹭的，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以你發呆了嗎？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年？",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n怎麼了，這樣蹲坐著……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n身、身體不舒服嗎？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是……",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n少年，睡著了嗎？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n之前也有，發生過同樣的事吧？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真沒用呢，我……",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為了自己的事情就已經忙到不行，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n沒察覺到少年的不尋常。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是個不及格的騎士，真是丟臉。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒事吧，少年？",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "起來了，在這種路邊睡覺是不行的。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不僅會妨礙通行，",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n一不留神還會被馬車輾過的。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔……",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n好刺眼。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不行……",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為什麼呢，連我也變得昏昏欲睡。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是什麼？",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n發生了什麼事？",
        "unit_id": 104712
    },
    {
        "type": "background",
        "background": "510040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……咦？",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這裡是，哪裡？",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那個……？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真奇怪。",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n記憶一片混亂。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就像睡昏頭一樣，頭腦無法好好運轉。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我是，白銀純。",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n二十五歲。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n職業是變裝演員……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "最近主要在遊樂園裡，",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n以表演英雄秀維生。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "父親是蒙面摔角手，",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n母親是代筆作家。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n姊姊是，有名吉祥物的玩偶演員。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哥哥是，隱藏來歷的占卜師……",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妹妹雖然是普通的國中生，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是經常戴著安全帽。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為在這樣的家庭長大。",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n對我來說，隱藏自己的真面目是理所當然的……",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "即使不是站在舞台上工作時，",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也像這樣戴著面具。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我記得。",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這就是，我。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "明明應該是如此的……",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為什麼呢，這個不協調的感覺是？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……唔？",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎麼回事，發出了慘叫聲？",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n咦，這個聲音是……？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "啊哈哈哈！",
        "unit_id": 1331,
        "voice": "vo_adv_1047008_040"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "所有人，都不准動！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "要是做了多餘的舉動，這個小鬼會受傷的喔！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "媽媽～！",
        "unit_id": 131,
        "voice": "vo_adv_1047008_041"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n救我，好可怕啊～",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "吵死了！",
        "unit_id": 1331,
        "voice": "vo_adv_1047008_042"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n喂喂店員！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n把所有的錢塞到這個包包裡！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那是，所、所謂的強盜嗎……",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n怎麼會有這種事，又不是漫畫。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎、怎麼辦。",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總之，先打電話給警察。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "哎呀，說了不准動了吧！",
        "unit_id": 1331,
        "voice": "vo_adv_1047008_045"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n所有人，把手機丟到腳下！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n可別想聯絡警察！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔……",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_046"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n看來是預謀犯罪呢，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然幼稚又拙劣，但似乎有好好考慮過應付警察的對策。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "孩子們的安全第一，",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_047"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不能隨便行動呢。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "又不是特攝節目。",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_048"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n對於實際的犯罪行為，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我什麼都辦不到。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗚哇！",
        "unit_id": 131,
        "voice": "vo_adv_1047008_049"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n不要不要不要，媽媽～",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "喂、喂！",
        "unit_id": 1331,
        "voice": "vo_adv_1047008_050"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n不准胡鬧！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n殺了你喔，小鬼",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "你、你一點都不可怕唷！",
        "unit_id": 131,
        "voice": "vo_adv_1047008_051"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n正義的英雄會來打倒壞蛋的！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "救命啊，虎虎！",
        "unit_id": 131,
        "voice": "vo_adv_1047008_052"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n幫幫我～！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗚、嗚嗚……",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_053"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小孩子明明在呼救，我卻無法動彈。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好可怕……",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_054"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那個強盜手上有刀，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n要是被刺到的話會死掉的。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "……嗚喔！？",
        "unit_id": 1331,
        "voice": "vo_adv_1047008_055"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "欸……？",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_056"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那是，少年？",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_057"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為什麼會在這裡？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "話說，他在做些什麼，",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_058"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n毫無防備地向強盜衝過去……？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n會被殺掉的！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "搞、搞什麼啊這傢伙！？",
        "unit_id": 1331,
        "voice": "vo_adv_1047008_059"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n給我讓開！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗚哇，少年！？",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_060"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n住、住手！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這樣毆打他的話會死掉的！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "吵死了！",
        "unit_id": 1331,
        "voice": "vo_adv_1047008_061"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n是這傢伙逞英雄跑出來的錯！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊……",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_062"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n少年被揍得面目全非了！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為、為什麼要做出那麼危險的舉動？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "這傢伙，可惡！",
        "unit_id": 1331,
        "voice": "vo_adv_1047008_063"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n真令人鬱悶！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n真的把你宰了喔…… ！？",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎、怎麼辦？",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_064"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n強盜似乎太過激動而忘記自己握著刀子，",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就這樣放置不理的話，少年會死掉的！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦咦？",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_065"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為什麼要向我使眼色？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你希望我怎麼做呢……？",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔……",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_066"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不能對少年見死不救。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "多虧了有少年引誘住他，",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_067"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n強盜現在正在注意那邊。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "機會來了！",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_068"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n快動啊，我的手腳！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n現在不行動的話會後悔的！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "喝啊啊！",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_069"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "嗚哇喔喔喔！？",
        "unit_id": 1331,
        "voice": "vo_adv_1047008_070"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "太好了！",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_071"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n突襲的飛踢成功了！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n強盜總算離開少年他們的身邊了。",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那、那邊的強盜，給你個勸告！",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_072"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n現在馬上停止作惡，投降吧！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "這傢伙……！",
        "unit_id": 1331,
        "voice": "vo_adv_1047008_073"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n搞什麼，戴著像笨蛋一樣的面具！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "跟面具無關吧！",
        "unit_id": 104732,
        "voice": "vo_adv_1047008_074"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總之，把刀子丟下！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我現在要叫警察了，不准動！",
        "unit_id": 104732
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "啊！？",
        "unit_id": 1331,
        "voice": "vo_adv_1047008_075"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n開什麼玩笑，瞧不起人嗎你這傢伙！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n去死吧……！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呀啊……",
        "unit_id": 1,
        "voice": "vo_adv_1047008_076"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n被、被刺到了！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不對，刀子刺中的是面具！",
        "unit_id": 1,
        "voice": "vo_adv_1047008_077"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我毫髮無傷！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "多虧了面具被打飛，",
        "unit_id": 1,
        "voice": "vo_adv_1047008_078"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n可以好好看清前面了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "能贏！",
        "unit_id": 1,
        "voice": "vo_adv_1047008_079"
    },
    {
        "type": "still",
        "still": "104700801"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "向天祈禱吧，惡徒！",
        "unit_id": 104733,
        "voice": "vo_adv_1047008_080"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n接受正義的制裁吧……！",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "啊啊……！？",
        "unit_id": 1331,
        "voice": "vo_adv_1047008_081"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好，結束了！",
        "unit_id": 104733,
        "voice": "vo_adv_1047008_082"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n一擊就打倒了！",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n正義必勝！",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總之，先把不省人事的強盜給綁起來吧……",
        "unit_id": 104733,
        "voice": "vo_adv_1047008_083"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n啊啊，真是膽戰心驚啊。",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "謝、謝謝你虎虎！",
        "unit_id": 131,
        "voice": "vo_adv_1047008_084"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "好可怕啊～！",
        "unit_id": 131
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯、嗯。",
        "unit_id": 104733,
        "voice": "vo_adv_1047008_085"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然我只是戴著面具，",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n並不是真的虎虎",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……算了。",
        "unit_id": 104733,
        "voice": "vo_adv_1047008_086"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n沒事吧，有沒有受傷？",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很害怕對吧，好乖好乖",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "。",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "欸嘿嘿，沒事的！",
        "unit_id": 131,
        "voice": "vo_adv_1047008_087"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "真的很謝謝你喔，大哥哥♪",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104733,
        "voice": "vo_adv_1047008_088"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但我不是「大哥哥」，",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而是「大姐姐」才對喔",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而且。",
        "unit_id": 104733,
        "voice": "vo_adv_1047008_089"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n比起向我道謝，",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還是去向那邊的少年說吧。",
        "unit_id": 104733
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為他可是打算賭上性命保護你的呢。",
        "unit_id": 104733,
        "voice": "vo_adv_1047008_090"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他才是，真正的英雄。",
        "unit_id": 104733,
        "voice": "vo_adv_1047008_091"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……好的，辛苦了",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_092"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然我一直都這麼想。",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_093"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你，真的過著令人不可置信的日常生活呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在這個和平的國家裡被捲進強盜事件，",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_094"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n機率不是微乎其微吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然也沒差。",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_095"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在旁邊看著，也是很有趣……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "萬幸的是。",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_096"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n除了作惡的強盜以外，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n似乎無人傷亡",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是。",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_097"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n太過亂來是不行的喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那又不是遊戲，",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_098"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是不能死而復生的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開～玩笑的……",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_099"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對現在的你說那些也沒用啊",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "比起那些，快點醒來吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_100"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或許眼前的狀況，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n會比強盜事件更難應付也說不定。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然不知道位於「這邊」的純，",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_101"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n設定是如何……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看見她的真面目，也就表示，",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_102"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你深入了她所帶著的問題。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明好好地給過你忠告，",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_103"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但你卻無視並和她扯上關係。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "至少別中途放棄，",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_104"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n請你誠實的面對喔",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要是純沒有行動的話，",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_105"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也許你就已經被強盜殺害了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為是救命恩人，",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_106"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不要忘了感謝的心情……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要好好的珍惜她喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無論何時。",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_107"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n能夠摘下她的面具，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n觸及其心中深處之人……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都只有你喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1047008_108"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_109"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯、嗯嗯。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_110"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦，我睡著了嗎？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_111"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "早安，少年。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是抱歉。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_112"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n果然，我好像還沒恢復常態。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在約會中不知不覺睡著，",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_113"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n實在是太不知禮儀了呢。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊啊不對，這並不是約會啊……",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_114"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "當然，我明白的。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只是溫柔善良的你，",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_115"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n陪陪寂寞的大姐姐而已。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_116"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n即使這樣也感到很高興、很幸福。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我一直都對這種事情很憧憬。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……振作精神，",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_117"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n再度開始行動吧。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "首先，得先尋找替換的衣服呢。",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_118"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "接著，在你推薦的店吃午餐吧。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "即使沒有戲劇性的事件……",
        "unit_id": 104712,
        "voice": "vo_adv_1047008_119"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我，也相當滿足了。",
        "unit_id": 104712
    }
]