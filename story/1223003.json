    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈、哈、哈！",
        "unit_id": 104412,
        "voice": "vo_adv_1223003_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n率直的稱讚真令人心情舒暢！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來吧，",
        "unit_id": 104412,
        "voice": "vo_adv_1223003_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "眷屬們！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身下令！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n去找出貝斯的所在……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊好痛！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "壞巴特",
        "words": "──咕喔喔喔喔喔！",
