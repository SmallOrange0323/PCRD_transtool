        "voice": "vo_adv_1223003_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還真奇怪呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒辦法了，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這裡就交給妾身吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n現身吧，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吾之眷屬們！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "壞巴特",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 2011
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "哇──！",
        "unit_id": 122311,
        "voice": "vo_adv_1223003_017"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "伊莉亞好厲害──！",
