        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳用了「魅惑」嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "魅惑？",
        "unit_id": 122311,
        "voice": "vo_adv_1223003_026"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比",
