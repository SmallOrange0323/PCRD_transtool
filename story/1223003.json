        "voice": "vo_adv_1223003_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真可惜。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n班比若能加入我軍，",
