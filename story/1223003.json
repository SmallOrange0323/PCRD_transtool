        "voice": "vo_adv_1223003_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n唔……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你們今天的心情怎麼特別差啊……！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若你們不願聽話，",
        "unit_id": 104412,
        "voice": "vo_adv_1223003_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身就恢復真正的模樣──",
        "unit_id": 104412
    },
