    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身離征服世界的夢想就更近了……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "征服世界？",
        "unit_id": 122311,
        "voice": "vo_adv_1223003_029"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n嗯……",
