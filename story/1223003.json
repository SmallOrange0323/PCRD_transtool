    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與班比得到了伊莉亞的協助，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再度開始尋找貝斯。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "很Q彈？",
        "unit_id": 104412,
        "voice": "vo_adv_1223003_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "胖胖的？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "粉紅色的龍？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n……那就是妳在找的貝斯？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "沒錯唷！",
        "unit_id": 122311,
        "voice": "vo_adv_1223003_001"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n既Q彈又胖胖的！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "粉紅色的龍，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "那就是貝斯唷！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "牠雖然有尖牙和利爪，",
        "unit_id": 122311,
        "voice": "vo_adv_1223003_002"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "但卻一下子",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就能和蝴蝶",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "或是小動物玩在一塊呢──！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "以前小小的，班比還背得動牠，",
        "unit_id": 122311,
        "voice": "vo_adv_1223003_003"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n但不知道是不是因為給牠吃了很多水果……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "牠現在",
        "unit_id": 122311,
        "voice": "vo_adv_1223003_004"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "已經長大到能背起班比",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "的程度了唷！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "然後",
        "unit_id": 122311,
        "voice": "vo_adv_1223003_005"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "那個啊──",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "牠和僕從一模一樣呢！！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "和這傢伙一模一樣……？",
        "unit_id": 104412,
        "voice": "vo_adv_1223003_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這世上有這麼弱小的龍存在嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "有唷有唷！",
        "unit_id": 122311,
        "voice": "vo_adv_1223003_007"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "貝斯和僕從",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "都很容易被欺負，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比很擔心呢──",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "原來如此……",
        "unit_id": 104412,
        "voice": "vo_adv_1223003_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如果是這麼奇特的龍，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n應該至少會聽到一兩件傳聞才對，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但卻從沒聽過呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳雖然說是偷偷溜出來的……",
        "unit_id": 104412,
        "voice": "vo_adv_1223003_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但綁架妳的那群傢伙，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可能已經發現你們逃走了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "先不說班比，",
        "unit_id": 104412,
        "voice": "vo_adv_1223003_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼懦弱的貝斯要是被發現就糟了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……倒不如說，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "牠也有可能已經被抓住了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這附近",
        "unit_id": 104412,
        "voice": "vo_adv_1223003_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有許多適合藏身的洞窟。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然不知道牠是迷路還是被綁架了……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但似乎值得去找找看。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "貝斯要是被那些叔叔發現的話……",
        "unit_id": 122311,
        "voice": "vo_adv_1223003_012"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "得快點找到牠才行！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "可是……",
        "unit_id": 122311,
        "voice": "vo_adv_1223003_013"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "洞窟有很多個對吧？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n要從哪裡開始找才好呢──？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳",
        "unit_id": 104412,
        "voice": "vo_adv_1223003_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒有蝙蝠眷屬嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "沒有唷。",
        "unit_id": 122311,
        "voice": "vo_adv_1223003_015"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比的僕從就只有{player}呀！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……妳",
