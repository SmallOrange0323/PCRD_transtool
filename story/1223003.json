        "voice": "vo_adv_1223003_022"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "不可以欺負伊莉亞唷！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "壞孩子們，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "來這裡排排站好！！",
