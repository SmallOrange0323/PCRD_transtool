[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106011,
        "voice": "vo_adv_5084702_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "竟然在這種時候叫人去討伐魔物，真不會挑時機。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個該死的眼鏡女，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一定是以看我們苦惱為樂，在背地裡嘲笑我們啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911,
        "voice": "vo_adv_5084702_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n花凜小姐並不是這樣的人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是啊，",
        "unit_id": 106411,
        "voice": "vo_adv_5084702_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "倒不如說，會拜託我們，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "應該是她認為這魔物相當危險，很需要有人幫忙討伐吧。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……而【美食殿堂】",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "確實擁有相當的實績。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也就是說，",
        "unit_id": 106011,
        "voice": "vo_adv_5084702_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又有棘手且麻煩的敵人在等著我們嗎。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過現在貪吃佩可跟那傢伙都不在，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不曉得有沒有問題呀……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀。",
        "unit_id": 105911,
        "voice": "vo_adv_5084702_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難不成是感到不安了？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎、",
        "unit_id": 106011,
        "voice": "vo_adv_5084702_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能有那種事呢！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種委託，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我一個人去處理也綽綽有餘啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n走，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們就跟著我上吧，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天我可是隊長！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵♪",
        "unit_id": 105911,
        "voice": "vo_adv_5084702_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐",
        "unit_id": 106411,
        "voice": "vo_adv_5084702_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的很會哄凱留呢……",
        "unit_id": 106411
    }
]