[
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "聖學祭的壓軸好戲，",
        "unit_id": 116411,
        "voice": "vo_adv_5064605_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "全員參加的綜合接力賽啊。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "現在只要閉上眼睛，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊啊，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就能看見那時的光景。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n化身為風奔跑的我、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "流過視界的景色、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "響亮入耳的歡呼……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "…………",
        "unit_id": 116411,
        "voice": "vo_adv_5064605_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂、",
        "unit_id": 116411,
        "voice": "vo_adv_5064605_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂，克蘿依，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳為什麼不吐槽呢？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「優妮學姐不是沒有跑嗎」，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "快用妳那殺手般的眼神來說這句話啊。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這樣下去",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不就像是我有說謊癖或",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妄想症嗎？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦……",
        "unit_id": 116211,
        "voice": "vo_adv_5064605_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，什麼事？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我完全沒在聽。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "剛好在",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "閉上眼睛想美冬姐的英姿。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂喂喂，",
        "unit_id": 116411,
        "voice": "vo_adv_5064605_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這可讓我空虛又寂寞喔。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳不是時常",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "優妮學姐優妮學姐的，跟我很親近嗎？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不用跟我客氣，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "投向這小小胸口的懷抱吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好了，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呃……",
        "unit_id": 116211,
        "voice": "vo_adv_5064605_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，什麼事？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我完全沒在聽。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "克蘿依～！",
        "unit_id": 116411,
        "voice": "vo_adv_5064605_006"
    }
]