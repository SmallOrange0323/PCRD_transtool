        "voice": "vo_adv_6023207_000"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "なんか楽しいことないすかー？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n貴重なチエルの青春残量が",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "刻一刻と擦り減ってるんですけど。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "はー、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "勿体なー……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "てか、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "どっか遊びに連れてってくださいよう。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "同じくです。",
        "unit_id": 110911,
        "voice": "vo_adv_6023207_001"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "チエルん家わりとお金持ちだけど、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n両親ちゃんとしてるから",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "子供には子供らしい経済観念を強いるんです。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "てか、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "お金なんかなくたっていくらでも遊べるッ！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "付いてこい！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "えー、",
        "unit_id": 110911,
        "voice": "vo_adv_6023207_002"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "なんでですかあ。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "いいじゃないですか、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ちょっとぐらい……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "えっ、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "配達の仕事中？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "あ、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ガチのやつでしたか、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ごめんなさい。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "それじゃ失礼しますね。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "良かったら、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "また今度遊んでやってください。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "はあ……",
        "unit_id": 110911,
        "voice": "vo_adv_6023207_003"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "そうですね、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "本人が言うなら否定はしませんけど。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "でも、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "逆にですよ？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "何もないってことは制限もないってことです。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n何者にもなれるじゃないですか！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "可能性に満ちてますよ、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "先輩！",
        "unit_id": 110911
    }
]