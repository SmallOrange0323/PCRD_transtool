[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束打手工作的嘉夜和{player}，\n在街上悠閒散步著。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好好打一架後心情很好呢！",
        "unit_id": 106511,
        "voice": "vo_adv_1065004_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝你幫我找工作呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "比起我自己一人去找，",
        "unit_id": 106511,
        "voice": "vo_adv_1065004_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "反而拜託你後賺的更多呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你啊，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "到底都是去哪裡找委託人呀？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對了。",
        "unit_id": 106511,
        "voice": "vo_adv_1065004_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "差不多該吃飯了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有秘訣的話要跟我說啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣，我獨自一人時也能……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼了？",
        "unit_id": 106511,
        "voice": "vo_adv_1065004_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "周遭突然變亮……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n發生什麼事了……",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "510302"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那天，從學校放學回家的{player}，\n繞路走在車站前面。"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "因為妳也是同一個道場嘛。",
        "unit_id": 1331,
        "voice": "vo_adv_1065004_004"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n我知道妳是那傢伙的妹妹。",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "把那傢伙叫過來這裡！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以說，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我從剛剛開始已經說過沒辦法了呀？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為我沒有我哥的電話號碼。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "手機的通訊錄",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可以給你檢查。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個笨蛋大哥……",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不要給我添麻煩啦。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊～啊，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好想快點回去玩阿斯特朗傳奇……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "廢話少說快點把他叫出來！",
        "unit_id": 1331,
        "voice": "vo_adv_1065004_007"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n我們沒給他好看，沒辦法消氣啦！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就算突然大聲吼我，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "做不到的事就是做不到。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "而且你們這群傢伙，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "全都輸給大哥了吧？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "打架只會受傷而已，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "到底有什麼好玩的？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "算不上比賽，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "也拿不到獎金跟獎盃吧？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "話說回來，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "想贏大哥的話",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "用口頭吵架會比較容易喔。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是你",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看起來跟大哥一樣笨，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "應該會輸吧！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "唔！",
        "unit_id": 1331,
        "voice": "vo_adv_1065004_011"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "竟然把我當傻子！！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n給我識相一點，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "不然我可不會饒妳啊……！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "該不會生氣了吧？",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為生氣所以要打比自己年紀小的女生嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以我才說你是笨蛋啊～？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "什麼……！",
        "unit_id": 1331,
        "voice": "vo_adv_1065004_013"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳還真是給我亂說得很開心啊！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n真是火大，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳和妳的大哥都一樣！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我也很生氣呀！",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "竟然被你這種根本沒見過的笨蛋，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n要我叫最近都沒跟我說話的大哥出來！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你們如果要找我大哥打架，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就請自己解決吧！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不要把我捲入無聊的事裡！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼告辭！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳哪裡都別想去！",
        "unit_id": 1331,
        "voice": "vo_adv_1065004_016"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "話說回來，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳放棄空手道了吧？",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n反正都會把他叫來，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "不然妳就留下來做人質吧。",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……你還真敢說啊？",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n就算我放棄空手道，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "也不代表我變弱了唷？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "其實是騙人的！",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不太妙啊。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好像說得太嗆了？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n但是不那樣說的話，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我也無法消氣……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "為什麼我得應付這種傢伙啊……",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "現在這個時間，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我原本應該要在玩阿斯特朗傳奇了呀……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……笨蛋大哥。",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你現在在哪裡啊。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是超生氣。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n到處讓他這樣隨意地胡鬧……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "如果就這樣挨了一拳後",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我再反擊的話會比較好？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這樣就可以當成是正當防衛……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "應該沒辦法吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "別說這傢伙了，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我連對練習夥伴都沒辦法出手，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "現在的我根本做不到。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "想大鬧一場的人是我啊……",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊──真是的，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "誰來救救我────",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦……？",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你、",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是誰？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n網聚……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不好意思，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我不清楚。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……呃，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你在說什麼呢？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不可能在這種地方網聚的呀。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "你幹嘛呀你！",
        "unit_id": 1331,
        "voice": "vo_adv_1065004_025"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "是那傢伙的同伴嗎！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n少來妨礙我們！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊！",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒事嗎！？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊────",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "喂！",
        "unit_id": 1331,
        "voice": "vo_adv_1065004_027"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "逃掉了嗎！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "可惡！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "給我站住！！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "等、",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "等一下！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "別這樣",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "拉我的手啦！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n就說了不要這樣！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "話說你",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有在聽人說話嗎……？",
        "unit_id": 106531
    },
    {
        "type": "background",
        "background": "510352"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……謝了。",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_029"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "到這裡就沒事了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我的事，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_030"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你可以不用管沒關係……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你呀，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要當老好人可以，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但都沒有想過自己會被牽連嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什麼啊，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_031"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你是因為這樣所以才救我的嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "椿丘的學生，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "都是像你這樣的人嗎……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……說到椿丘，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_032"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "該不會！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個。",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_033"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你的名字，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "讓我猜猜！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n{player}對吧？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊哈哈！",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_034"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你一臉驚恐想說我怎麼知道！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n被我說中了吧！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是太巧了！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我的朋友啊，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_035"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n提過椿丘高中裡",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有一個比起自己更喜歡幫助別人的人唷！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "果然如春咲所說，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_036"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你真的是個好人呢！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n她說你是學長！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但在我看來，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_037"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "春咲也是",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不輸給學長的老好人呢。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_038"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是鬼道嘉夜。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就讀聖都學園一年級。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "請多指教，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長♪",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝你剛才救了我！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "其實我大哥",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_039"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是這附近有名的打架狂，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以剛剛才會發生這些紛爭。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "話說回來，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_040"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我從春咲那裡聽說的，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n學長和春咲",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是玩阿斯特朗傳奇認識的嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼學長！",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_041"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n也跟我一起玩阿斯特朗傳奇吧！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我用mimi加你朋友，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_042"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "告訴我你的ID！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n下次和春咲組隊，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "大家一起玩吧！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……加好了。",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_043"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今後請多指教♪",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然可能讓人有點意外，",
