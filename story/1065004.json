    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呵呵呵，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_046"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這你沒聽過吧？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "現在還在測試中，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只有申請通過的人才能夠「轉生」唷！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "話雖如此，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_047"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但得知申請辦法的，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n只有很少部分的人呢。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你知道為什麼我會這麼了解嗎？",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_048"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那就要跟你保密了",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊啊，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但我不是七冠唷。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總之我",
