    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是的，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_051"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我就說過不用擔心我啦！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我沒事。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以你放心吧，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是的，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_052"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長你也太會擔心了吧！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "太會擔心了啦。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我已經沒事。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然學長看起來人畜無害，",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_053"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但其實滿可靠的呢。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘿……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……學長",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_054"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是有趣的人呢。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天謝謝你。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "再見！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那就是傳說中的學長",
