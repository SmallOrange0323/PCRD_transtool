        "voice": "vo_adv_1065004_044"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但我玩得還滿投入的喔。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n最近還開始用了密技的部分。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對了！",
        "unit_id": 106531,
        "voice": "vo_adv_1065004_045"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你知道龍人族嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這次在阿斯特朗傳奇大型更新中追加的種族！",
