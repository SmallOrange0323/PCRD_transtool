        "voice": "vo_adv_1065004_049"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "超常玩阿斯特朗傳奇的。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n也因為遊戲的關係和春咲變要好了！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好想快點和學長一起玩呢～",
