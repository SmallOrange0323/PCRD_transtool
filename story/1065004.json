        "voice": "vo_adv_1065004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "內心不太安定，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要稍微移開視線好像就會消失……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "即便如此，",
        "unit_id": 190011,
        "voice": "vo_adv_1065004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和你說話時她就會露出很棒的表情。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n對那個孩子來說",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是個很好的相遇呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和這邊的嘉夜不同，",
        "unit_id": 190011,
        "voice": "vo_adv_1065004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她不喜歡打架這點，讓我很驚訝呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是因為大哥的影響嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是這樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1065004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼這邊的嘉夜會那樣子呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過不好對付這點是不會錯的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "選擇和嘉夜一起是你的自由，",
        "unit_id": 190011,
        "voice": "vo_adv_1065004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但是發生什麼事都不奇怪唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這點要請你注意。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且不只嘉夜，",
        "unit_id": 190011,
        "voice": "vo_adv_1065004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還有龍人族的事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在這邊的世界也請務必小心唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話雖如此，",
        "unit_id": 190011,
        "voice": "vo_adv_1065004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "當你從這個夢中醒來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就會都忘記了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但這次希望你能儘量記住……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，無所謂。",
        "unit_id": 190011,
        "voice": "vo_adv_1065004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
