    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我從沒想過自己居然會",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有變成怪盜的一天……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "唔唔……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我明明",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "應該已經決定要做了……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n可是現在",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "卻又開始感到害怕……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩你在為我",
        "unit_id": 121511,
        "voice": "vo_adv_6090101_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "擔心呀……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "很高興你為我擔心……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可、",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可是，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我覺得自己",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不能在這裡逃避……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n為了朋友、",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為了大家……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "即使感到害怕……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也要加優……！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "謝、",
        "unit_id": 121511,
        "voice": "vo_adv_6090101_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "謝謝",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩……♪",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n聽你這麼說，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "讓我有勇氣了！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "現在不是",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "感到害怕的時候呢。",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我會作為怪盜",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "偷到寶物的……！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "既、",
        "unit_id": 121511,
        "voice": "vo_adv_6090101_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "既然前輩這麼說……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那我就稍微",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "相信自己看看……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好了……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖、",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不曉得自己能做到什麼程度……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但我會挑戰看看的……！",
        "unit_id": 121511
    }
]