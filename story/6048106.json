        "words": "沒、",
        "unit_id": 113712,
        "voice": "vo_adv_6048106_000"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "沒想到",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "超級模特兒竟然真的來了……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "為什麼你這種人",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "會認識那麼厲害的人啊？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "說起來她到底是叫你什麼？",
        "unit_id": 113712,
        "voice": "vo_adv_6048106_001"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "啊，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "是說那個秀才啊……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "咦？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "你是秀才！？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "怎麼可能啊！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "鈴奈",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "是不是不擅長讀書啊？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "沒錯呢，",
        "unit_id": 113712,
        "voice": "vo_adv_6048106_002"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "原本覺得辣妹看起來有點難以親近，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n不過鈴奈完全不會讓人覺得害怕呢。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n這一定就是她之所以受歡迎的理由吧！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "反正",
        "unit_id": 113712,
        "voice": "vo_adv_6048106_003"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "一定又是這樣吧。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n不過不知道為什麼",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "你這傢伙的周圍常圍繞著很多女孩子呢。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這真的是偶然嗎？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "……真是神秘啊。",
        "unit_id": 113712
    }
]