        "unit_id": 100111,
        "voice": "vo_adv_2112001_072"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣搞不好會像獸人族之國那時候一樣，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n被誰盯上也說不定呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100111,
        "voice": "vo_adv_2112001_073"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然說是順便不太好，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但雪菲也是，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在她睡著的這段期間，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就由我們來顧著吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有勞兩位了。",
        "unit_id": 105913,
        "voice": "vo_adv_2112001_074"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怜小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "日和小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴的聲音",
        "words": "──哦哇！？",
        "unit_id": 102611,
        "voice": "vo_adv_2112001_075"
    },
    {
        "type": "dialogue",
        "name": "鈴的聲音",
        "words": "\n搞什麼啊～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴的聲音",
        "words": "人家睡得正香的時候跑進來～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪的聲音",
        "words": "鈴，",
        "unit_id": 105213,
        "voice": "vo_adv_2112001_076"
    },
    {
        "type": "dialogue",
        "name": "莉瑪的聲音",
        "words": "妳也真是的～",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪的聲音",
        "words": "\n都說過有客人要來了，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪的聲音",
        "words": "竟然還睡著～",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪的聲音",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪的聲音",
        "words": "連栞也是？",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "栞的聲音",
        "words": "對、",
        "unit_id": 103813,
        "voice": "vo_adv_2112001_077"
    },
    {
        "type": "dialogue",
        "name": "栞的聲音",
        "words": "對不起……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞的聲音",
        "words": "\n我想說和鈴一起",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞的聲音",
        "words": "試試看新的枕頭，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞的聲音",
        "words": "\n一試就越來越想睡……",
