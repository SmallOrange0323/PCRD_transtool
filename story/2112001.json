[
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "好不容易贏得了賭上世界命運的遊戲對決，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但連續戰鬥使得{player}等人滿身瘡痍。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他們在拉比林斯達的邀請下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "動身脫離蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一望無際，",
        "unit_id": 105913,
        "voice": "vo_adv_2112001_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無窮無盡……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有岔路也沒有出口，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一路都是一直線持續下去呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒想到竟然在蘭德索爾地下深處",
        "unit_id": 100111,
        "voice": "vo_adv_2112001_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "做了這麼一條路，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "拉比林斯達小姐",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是真的很厲害！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對啊。",
        "unit_id": 100311,
        "voice": "vo_adv_2112001_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n待在這裡",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該可以暫且當作安全了吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在的我們要是遇到克莉絲提娜或似似花，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "連一回合都擋不住……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯……",
        "unit_id": 106012,
        "voice": "vo_adv_2112001_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……小凱留？",
        "unit_id": 105812,
        "voice": "vo_adv_2112001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有什麼問題嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看妳從剛剛就往後看了好幾次。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "莫非，",
        "unit_id": 105913,
        "voice": "vo_adv_2112001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有什麼人跟在後頭，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是感覺到什麼可疑的魔力……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不，",
        "unit_id": 106012,
        "voice": "vo_adv_2112001_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "倒也不是那麼回事啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這條地下道，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正常行走的時候是沒什麼奇怪的感覺……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可是岩石層另外一側的空間",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像是逐漸彎曲的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100111,
        "voice": "vo_adv_2112001_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是嗎！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以我們走一步，",
        "unit_id": 106012,
        "voice": "vo_adv_2112001_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就相當於走了十步左右。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且我們後面的路還堵住了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n像是不讓人追上來一樣……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是真的嗎！？",
        "unit_id": 105812,
        "voice": "vo_adv_2112001_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我完全都看不出來！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我過去看一下～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，白痴佩可！？",
        "unit_id": 106012,
        "voice": "vo_adv_2112001_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳不要自己特地往回跑啦！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "──真的塞住了耶～！",
        "unit_id": 105812,
        "voice": "vo_adv_2112001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常感謝您，",
        "unit_id": 105913,
        "voice": "vo_adv_2112001_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這麼一來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "暫時就可以放心了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯。",
        "unit_id": 100111,
        "voice": "vo_adv_2112001_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們現在",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "每個人都遍體鱗傷。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要是在這裡交戰的話",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就不太妙了呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n而且優衣和雪菲",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也都還在沉睡……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯……",
        "unit_id": 100311,
        "voice": "vo_adv_2112001_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n差不多可以換手一下了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣讓我背吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100111,
        "voice": "vo_adv_2112001_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唔",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n麻煩妳了，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913,
        "voice": "vo_adv_2112001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也和您交換，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由在下來背雪菲小姐吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是……",
        "unit_id": 105913,
        "voice": "vo_adv_2112001_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔～？",
        "unit_id": 106012,
        "voice": "vo_adv_2112001_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳就先好好蓄積魔力吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像這種力氣活，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "交給這傢伙和貪吃佩可就行了啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的☆",
        "unit_id": 105812,
        "voice": "vo_adv_2112001_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n儘管交給我吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……比起這個……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106411,
        "voice": "vo_adv_2112001_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100211,
        "voice": "vo_adv_2112001_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雪菲",
        "unit_id": 105812,
        "voice": "vo_adv_2112001_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有優衣……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n到現在，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "完全都沒有要醒過來的樣子呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對她們兩人而言，",
        "unit_id": 100311,
        "voice": "vo_adv_2112001_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比起肉體上的損傷，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n想必是精神上的傷害比較嚴重吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n唯有這方面",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是使用魔法也沒辦法治好的……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2112001_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不僅王宮被奪走，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "贊恩先生……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還以那種形式",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "落入敵人手裡……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "彌勒……",
        "unit_id": 106012,
        "voice": "vo_adv_2112001_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n唯有那個傢伙",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "絕對不可饒恕……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且也還得找到方法，",
        "unit_id": 105812,
        "voice": "vo_adv_2112001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n解除克莉絲提娜小姐和似似花小姐中的洗腦……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯。",
        "unit_id": 100111,
        "voice": "vo_adv_2112001_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "再說……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我覺得",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也該和厄莉絲小姐好好談一次。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯。",
        "unit_id": 100311,
        "voice": "vo_adv_2112001_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "然後……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該怎麼去面對",
        "unit_id": 100311,
        "voice": "vo_adv_2112001_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所謂的「現實」這件事，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們也差不多",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該下定決心了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106012,
        "voice": "vo_adv_2112001_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說得也是。",
        "unit_id": 105812,
        "voice": "vo_adv_2112001_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嘿嘿……",
        "unit_id": 105812,
        "voice": "vo_adv_2112001_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳、",
        "unit_id": 106012,
        "voice": "vo_adv_2112001_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳喔……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不只是貪吃佩可小姐而已，",
        "unit_id": 105913,
        "voice": "vo_adv_2112001_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n包含在下在內，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都已經肚子餓扁了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖說也有之前以公主型態戰鬥的因素在內，",
        "unit_id": 100111,
        "voice": "vo_adv_2112001_035"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
