[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天在居酒屋──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n優花梨與酒友熱烈訴說單日露營時"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "品嚐到最棒的那一杯一事。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "──就像這樣，",
        "unit_id": 103412,
        "voice": "vo_adv_1222003_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我最近週末主要都是去單日露營。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n即使遇到辛苦的工作，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n只要想到之後能享受露營暢飲，我就能熬得過去。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "酒友1",
        "words": "是喔～！",
        "unit_id": 6511,
        "voice": "vo_adv_1222003_001"
    },
    {
        "type": "dialogue",
        "name": "酒友1",
        "words": "用新鮮果實做成能讓心情舒暢的果汁，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "酒友1",
        "words": "\n還有時髦的露營餐啊～！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "酒友1",
        "words": "感覺就很開心～！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對啊，",
        "unit_id": 103412,
        "voice": "vo_adv_1222003_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "尤其是在大自然裡喝的麥酒更是別樹一幟……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不對，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那就算說是革命都不為過！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "酒友1",
        "words": "不錯耶……",
        "unit_id": 6511,
        "voice": "vo_adv_1222003_003"
    },
    {
        "type": "dialogue",
        "name": "酒友1",
        "words": "只是聽妳的話，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "酒友1",
        "words": "就能配好幾杯麥酒了……！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "酒友1",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "酒友1",
        "words": "我也來試試看",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "酒友1",
        "words": "單日露營好了！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯，",
        "unit_id": 103412,
        "voice": "vo_adv_1222003_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳一定要試試看。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "單日露營喝到最棒的那一杯，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n那真的",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是讓人欲罷不能！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "哈哈哈！",
        "unit_id": 7511,
        "voice": "vo_adv_1222003_005"
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "\n看來妳完全迷上了啊，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "我推薦妳也是值得了。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是、",
        "unit_id": 103412,
        "voice": "vo_adv_1222003_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是你！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真是好久不見！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n那時候謝謝你",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "替我解惑。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "不會，",
        "unit_id": 7511,
        "voice": "vo_adv_1222003_007"
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "這不算什麼。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "\n對我這個麥酒資歷長達40年的前輩來說，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "能夠幫助年輕人真是太好了。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "\n看來你很享受……",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "最棒的那一杯呢。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是啊！",
        "unit_id": 103412,
        "voice": "vo_adv_1222003_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n託你的福，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "讓我徹底改善了一成不變的麥酒時光。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "這樣啊……",
        "unit_id": 7511,
        "voice": "vo_adv_1222003_009"
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "但是，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "那時候我也還很嫩……",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "\n我在那之後也不停持續露營暢飲，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "最後我終於找到真理，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "不對──",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "超越露營暢飲最棒的那一杯，",
        "unit_id": 7511,
        "voice": "vo_adv_1222003_010"
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "也就是真正最棒的一杯……！",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你、",
        "unit_id": 103412,
        "voice": "vo_adv_1222003_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你說什麼……！？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我現在露營喝麥酒的生活就已經夠充實了……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你說除了最棒的那一杯，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "居然還有更厲害的！？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "酒友1",
        "words": "這話感覺會說很久……",
        "unit_id": 6511,
        "voice": "vo_adv_1222003_012"
    },
    {
        "type": "dialogue",
        "name": "酒友1",
        "words": "我先加點",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "酒友1",
        "words": "下酒菜吧。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我要魷魚乾，麻煩了！",
        "unit_id": 103412,
        "voice": "vo_adv_1222003_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……那、",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那麼，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "「真正最棒的一杯」",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "沒錯……",
        "unit_id": 7511,
        "voice": "vo_adv_1222003_014"
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "那是在",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "酒友2",
        "words": "我難得和家人一起去露營時的事情……",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唔呣唔呣……！",
        "unit_id": 103412,
        "voice": "vo_adv_1222003_015"
    },
    {
        "type": "background",
        "background": "501591"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼～！",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "今天的露營也好開心～！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n果然不管來幾次都不會膩……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這個解放感……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "今天想特別一點，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "吶？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我想說偶爾清醒地露營",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也不錯吧～",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "老實說，我是覺得少了些什麼……",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_018"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是……！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這都是為了真正最棒的一杯……！　",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊～",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "其、",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "其實今天……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我想說要在這",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "過夜……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "然、",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_021"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "然後……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你能夠陪我嗎？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真的？",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "太好了～！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "然後啊！",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我為什麼會想在這過夜……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那是因為我想和你一起品嚐真正最棒的一杯。",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你剛才有瞬間露出了不安的眼神呢。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒問題，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你放心。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我指的不是那種只有大人才能喝的能讓心情舒暢的水。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_026"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可是，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唔～嗯……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但根據不同看法，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也不是不能說是大人的味道",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "吧？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "之前",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "推薦我體驗露營暢飲的人，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n他跟我提到真正最棒的一杯。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我聽了之後，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就非常想和你一起體驗真正最棒的一杯……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你想想，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "自從和小碧她們一起去過團體露營後，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你就一直陪我來單日露營不是嗎？",
