    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好像也緩和了不少……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "連外面傳來的聲音，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "都不可思議地令人感到悅耳……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是因為聽到了他睡覺的呼吸聲嗎……",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_060"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n總覺得……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "令人感到非常安心……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這個感覺……",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_061"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "長大之後就忘記了呢……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n身邊有他人的體溫……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "有種好懷念、",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好溫柔的感覺……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……多虧如此，感覺能睡個好覺了……",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_062"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n……這件事的謝禮……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我會留到早上一起給你的……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "晚安……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "──欸，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_063"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "{player}。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "快起床。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你看，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_064"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "早上了喔。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n快從帳篷裡出來吧。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "早安。",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_065"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……呵呵，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "有趕上時間真是太好了。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這朝陽很美對吧？",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_066"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n天空很清澈，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "感覺比平時更耀眼。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "然後這個……",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_067"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "給你，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真正最棒的一杯。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n是剛泡好的咖啡，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "趁熱喝吧。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你一臉很意外居然不是麥酒呢。",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_068"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "先喝一口看看吧。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我相信你一定會懂那個理由的。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_069"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好驚人！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這就是",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真正最棒的一杯呢！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "其實……",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_070"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我到剛才喝到前都還半信半疑的。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n因為",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "「早上的咖啡就是真正最棒的一杯」，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這可是麥酒的酒友說出口的耶。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這是小碧給我的咖啡豆。",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_071"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "的確是很好喝的豆子，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是這和之前大家一起喝的感覺完全不一樣對吧？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真正最棒的一杯，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_072"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "似乎和豆子好壞無關。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "早上天氣微冷的露營區……",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_073"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n沐浴在剛升起的朝陽中……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n與珍視之人",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "靜靜喝著咖啡並感受一天的開始……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "聽說",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_074"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這就是真正最棒的一杯。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_075"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不管是只有我一個人，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n還是只有你，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "都無法體驗到這份感動。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "告訴我這件事的人，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_076"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n是在與家人一起去露營時發現這點的。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "聽說他是偶然沒喝麥酒提早就寢，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_077"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n於是隔天很早起床。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n才有機會跟太太一起享受咖啡。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_078"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我昨天也決定忍耐不喝麥酒，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n要早睡早起。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "昨天一直賣關子真是抱歉呢，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_079"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可是，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我希望你能體會最自然的感動。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_080"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "太好了。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我鼓起勇氣邀請你也是值得了。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這也是露營的樂趣之一呢。",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_081"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我又找到了新的樂趣。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝你，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_082"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "{player}。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呃、",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_083"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呃，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就是……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n應該說是",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝你陪我，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還是該怎麼說呢，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "昨晚我雖然逞強說是擔心你，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_084"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n但其實是我自己覺得很不安……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可是，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_085"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "一看到你那悠悠哉哉～地感覺，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我就安心睡著了。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "仔細想想，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_086"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不只是今天，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你總是像這樣為我帶來平穩的時光呢。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然應該是我這個大人",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_087"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "要帶給你平穩才對……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我想就算不必在你面前逞強也沒關係，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對吧？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以，",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_088"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "今後你如果也能像這樣，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n陪我一起喝最棒的那一杯，我會很高興的。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也希望",
        "unit_id": 122211,
        "voice": "vo_adv_1222003_089"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "總有一天能和你一起喝麥酒，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好嗎？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優花梨露出淡淡的微笑"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "望著美麗的朝陽，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並與{player}一起享用真正最棒的一杯。"
    }
]