[
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "{player}！今天也很感謝你，",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n為了BB團的活動而來到森林裡……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我想到了一件事情……！",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我認為提高BB團的知名度，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n也是我們成員重要的職責之一吧。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只要增加BB團的知名度，",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "想知道交朋友的方法的人，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n應該就會來到這個森林的！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "想交朋友的人聚集在一起，",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n大家就能一起思考交朋友的方法，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這樣就肯定能提高效率！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗯嗯，我有一個想法……",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那就是創作一首BB團的主題曲，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你覺得這個方法如何呢？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要是一首不自覺地就可以使人琅琅上口、",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n馬上就能記住的歌！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦，這是個好主意……？",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n真、真的嗎！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝謝！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所、所以今天……",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我想說如果可以和你",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一起填詞就好了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦，你願意和我一起填詞嗎？",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝謝！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，我們先想想草稿吧……",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我打算一邊聽你的意見，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n一邊創作！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後他們兩個人討論了大約三小時，\n完成了主題曲的歌詞草稿。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "完成了！",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我來朗讀一次吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「BB團朋友讚譽曲（暫定）」",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果想成為朋友，",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n就手牽手吧！啦啦啦～",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們並不可怕啊！",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我們名叫BB團，嚕嚕嚕～",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……不……",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣就好了嗎……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你的反應很委婉呢……",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n但我跟你的感想一樣……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "總覺得，是不是少了點吸引力……",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "再輕快一點……",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "像是能夠吸引青少年的那種節奏，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n會不會好一點呢……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "加進一點饒舌試試吧。",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n比起歌詞的意思，把焦點放在發音上。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對啊。聽說街上的年輕人，",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n有種利用即興饒舌來交流的文化。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我也想吸引這一類型的人。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還有……第一行的歌詞令我有點在意……",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是的。我覺得這句……",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n好像把朋友形容得太草率了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n加上對「朋友」的定義應該比較好吧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個，因為每一個人對朋友的",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "定義都不相同，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這裡明確地說出朋友的定義會比較體貼聽眾吧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還有這裡，第三行的「我們並不可怕啊」。",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這裡如果太強調我們不可怕這點，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n是不是可能會引起反效果呢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我覺得比起強調我們不可怕，",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不如強調我們很親切",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "才是正確的表現方式。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這麼說來，前陣子在家做飯時，",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n因為蓋著鍋蓋，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以醬汁滾了就整個滿出來呢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果那個時候有人願意提醒我的話，",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我就會覺得那人很親切。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不如試試將這種含義加到歌詞裡吧！",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還有，乳酸菌之類的東西也對人有益……",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "然後，為了不要讓歌詞偏重於親切、貼心，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n所以把閃電等帥氣的單詞也加進去吧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，雙關語也要仔細的寫上解釋！",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n如果聽眾沒有注意到就太可惜了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "完成了！這樣很完美！",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_030"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我再來朗讀一次吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……咳咳。",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_031"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我要開始囉……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「BB團朋友讚譽曲",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "←",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "讚譽和參與的發音相近」",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "Hey ",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_033"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "YO！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那裡的小子！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我想和你！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n成為朋友唷！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "紅毛雪貂！",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_034"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "新式體操！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n碗豆酥！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "決鬥書！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n學生手冊！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "想到對策！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個也是這個也是！",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_035"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n來吧來吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "和你一起喲！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我好想！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "認識新朋友喲！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "（※附註，這裡的「朋友」是指，",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_036"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n一星期有超過一次以見面、書信，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n或念力等方式互相聯絡者。）",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "暫且不管這個，",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_037"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "醬汁！醬汁！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n醬汁！醬汁！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你！家裡的！",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_038"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n醬汁滿出來了喔！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "醬汁！醬汁！",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_039"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n滿出來的話！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "醬一支",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_040"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "高電壓閃電棒",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊啊～ 像那樣子～ 對人有益的～",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_041"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n乳酸菌和BB團～♪",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "…………",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_042"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "創作出一首不錯的歌呢！",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_043"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這應該是一首用心良苦的佳作！",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_044"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這一切都是因為你的幫忙才能達成。",
        "unit_id": 104011,
