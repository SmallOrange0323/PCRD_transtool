    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "拜託你了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦……？",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_048"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_049"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、我以為只要有歌詞的話，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n後續就會萬事OK了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你問我有沒有認識的人會作曲……",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_050"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n認識什麼的……門路什麼的……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n想要依靠別人，",
