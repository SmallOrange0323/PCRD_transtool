        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還有，這是我和你的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "第一次合作……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我超開心的。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嘿嘿嘿……好開心喔……",
        "unit_id": 104011,
        "voice": "vo_adv_1040005_046"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n歌詞真不錯……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "總之現在就只缺曲子了！",
