[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在精靈族之村，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌著手進行演唱會的準備。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n同時一找到空閒時間，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "也在努力練習歌曲演唱。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "～～～～♪",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}！\n這是當然的！",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為這次可是為了村民們",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所舉辦的特別演唱會！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且，",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我也很高興蘭法小姐和我有一樣的想法……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n想要用自己的方式",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "盡全力回應她！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這裡離村子有一小段距離，",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我想說在這裡就不會被人看到，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可以好好地練習。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以──",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "啊！",
        "unit_id": 6511,
        "voice": "vo_adv_5202062_004"
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "果然沒錯吧！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "\n我就想說從遠處傳來了美妙的歌聲！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "如果能像那樣自由自在地唱歌，",
        "unit_id": 3311,
        "voice": "vo_adv_5202062_005"
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "\n肯定會很快樂吧……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "…………",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒問題的，",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n雖然確實嚇了我一跳，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過這種程度不要緊的。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "兩位，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我在這裡練習的事，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還請拜託幫我保密喔。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "偷看的兩人",
        "words": "「好的～！」",
        "unit_id": 1,
        "voice": "vo_adv_5202062_009"
    },
    {
        "type": "dialogue",
        "name": "偷看的兩人",
        "words": "\n「是……！」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "話說回來，",
        "unit_id": 6511,
        "voice": "vo_adv_5202062_010"
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "妳的歌聲真的很棒呢！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "不像我，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "想要發出高音的時候",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "總是會唱破音。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "明明很喜歡唱歌，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "這種時候就會對自己很失望。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "怎麼會，",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "喜歡的想法就是最重要的！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n而且",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唱歌",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也是能透過一點訣竅來提升的。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "比如說，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "破音的話──",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "～～～～♪",
        "unit_id": 6511,
        "voice": "vo_adv_5202062_012"
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "……好厲害，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "居然能這麼滑順地唱出高音！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "我還是第一次能這麼隨心所欲地唱出來……！",
        "unit_id": 3311,
        "voice": "vo_adv_5202062_013"
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "\n明明之前唱的時候",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "還會越唱越走音……！",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "兩人看起來都好開心……",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真令人懷念啊。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "以前也有一次像這樣，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "和小孩子們在正式開始之前練習呢。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n當時是一起登上舞台……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對了！　",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你們兩位。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要是方便的話，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n演唱會當天可以請你們來當伴唱和聲嗎？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "咦咦！？",
        "unit_id": 6511,
        "voice": "vo_adv_5202062_016"
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "這種事……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "能夠站上舞台我是很高興，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "可是，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "我們這樣的外行人真的可以嗎……？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "我也是，",
        "unit_id": 3311,
        "voice": "vo_adv_5202062_017"
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "就算說客套話也稱不上很會唱歌……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "\n",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "要是失敗的話……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請不要那麼有壓力。",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不只是想唱歌給大家聽，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n更希望大家能夠一起同樂。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且，",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唱歌",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對唱喚士來說雖然是保護人們的工具……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但我認為應該是能夠更輕鬆地，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "抱持純粹的心去享受的。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以兩位也請放心，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "盡情歌唱吧！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "……被妳這麼一說，",
        "unit_id": 6511,
        "voice": "vo_adv_5202062_020"
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "就覺得自己好像能夠辦到了呢。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "這樣的話，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性精靈族",
        "words": "我也去問問看其他人！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "唱歌的事，",
        "unit_id": 3311,
        "voice": "vo_adv_5202062_021"
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "請妳再多多指導我們吧！",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "\n千歌小姐……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "不對，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "男性精靈族",
        "words": "千歌老師！",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "千歌老師？",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這稱呼，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對我來說太過獎了！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "連{player}也這麼說……！",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "等一下。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以我，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可以教{player}練習？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n像是和蘭法小姐特訓",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那時候一樣？　",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為了{player}，",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我要手把手地一步一步從基礎開始指導他唱歌……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有時候……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還、",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還要把手放在腹部上……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要是唱得好，",
        "unit_id": 134411,
        "voice": "vo_adv_5202062_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就說「你唱得很好哦！」",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "來稱讚他……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要是聽到「千歌老師，",
        "unit_id": 134411
    },
    {
