[
    {
        "type": "background",
        "background": "500651"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "深月與{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在大江戶町購物。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "放在那邊的中藥，",
        "unit_id": 117511,
        "voice": "vo_adv_1175002_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還有那邊的中藥，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有多少我就買多少。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我記得這個也剩得不多了……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可以拿給我嗎？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 117511,
        "voice": "vo_adv_1175002_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你怎麼看得這麼認真？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對呀。",
        "unit_id": 117511,
        "voice": "vo_adv_1175002_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "中藥是以各種藥草為原料製作的，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因此種類繁多。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "譬如這種中藥，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就是用含劇毒的植物製成的喔。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 117511,
        "voice": "vo_adv_1175002_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那種危險的植物",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只要運用得好，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也會替人們帶來健康。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n就像活在黑暗中的科學家，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有時會作為醫生幫助他人一樣。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒錯。",
        "unit_id": 117511,
        "voice": "vo_adv_1175002_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "仔細一看，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就會發現它的形狀有些扭曲怪異。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣的植物",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對人有所助益，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很不可思議吧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵。",
        "unit_id": 117511,
        "voice": "vo_adv_1175002_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "難以用常識對付但確實很有實力，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "中藥這樣的一面，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n或許跟",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "【暮光流星群】有些相似呢。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "另一頭也有經手中藥的藥品批發商呢。",
        "unit_id": 117511,
        "voice": "vo_adv_1175002_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們過去看看吧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我在醫院看診時幾乎把藥材都用光了，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n想在回蘭德索爾前",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "補充庫存。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "往這邊走，",
        "unit_id": 117511,
        "voice": "vo_adv_1175002_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "跟我來。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "──呀！？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哎呀",
        "unit_id": 1111,
        "voice": "vo_adv_1175002_008"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "抱歉……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我不小心走神了……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳不是",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "深月醫生嗎？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 117511,
        "voice": "vo_adv_1175002_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你是……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我記得是",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來道一家的……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你的臉色好蒼白，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼了嗎？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不……",
        "unit_id": 1111,
        "voice": "vo_adv_1175002_010"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n沒什麼大不了的……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n這歸根究柢都是我的錯……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "將軍……",
        "unit_id": 1111,
        "voice": "vo_adv_1175002_011"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "謝謝你。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "一直受到你們的照顧，我真沒出息……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那個，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "其實──",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯～",
        "unit_id": 117511,
        "voice": "vo_adv_1175002_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "總之，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有個惡質的旅行商人騙你買下了",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "昂貴的",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "假中藥吧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "沒錯。",
        "unit_id": 1111,
        "voice": "vo_adv_1175002_013"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "因為希望頭目長保身體健康……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我不慎聽信了",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那個旅行商人的花言巧語……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我以為買到了好藥，",
        "unit_id": 1111,
        "voice": "vo_adv_1175002_014"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "去找熟悉中藥的傢伙炫耀，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "他卻告訴我那是假的中藥……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……的確，",
        "unit_id": 117511,
        "voice": "vo_adv_1175002_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個成分",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是沒有藥效的植物。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n唉，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "以外行人的眼光",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "應該無法分辨中藥的真假……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這商人手段還真黑心。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "即使質問他，",
        "unit_id": 1111,
        "voice": "vo_adv_1175002_016"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "他也用不知情來推託過去………",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就算去告狀，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "【王宮騎士團】的人也說因為沒有證據，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n無法逮捕旅行商人……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我在搞什麼啊……！",
        "unit_id": 1111,
        "voice": "vo_adv_1175002_017"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "頭目不在的期間，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我不僅沒保護好城鎮，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n還上當遭到詐欺……！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "部下這麼不爭氣，",
        "unit_id": 1111,
        "voice": "vo_adv_1175002_018"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "頭目也沒辦法安心休息吧……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "沒有臉見頭目……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "因為是前幾天才發生的事，",
        "unit_id": 1111,
        "voice": "vo_adv_1175002_019"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我想大概還在……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "等等。",
        "unit_id": 117511,
        "voice": "vo_adv_1175002_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真是的。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你還是老樣子，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看到有人碰到困難就沒辦法置之不理。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n真是個濫好人。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "算了。",
        "unit_id": 117511,
        "voice": "vo_adv_1175002_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n既然是這麼回事，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我也有個想法。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一個對於會做非法生意的惡質之輩",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "非常管用的方法。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "來來來，",
        "unit_id": 414,
        "voice": "vo_adv_1175002_022"
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "靠過來看過來！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "\n這可是名聞天下，以作為萬靈藥著稱的中藥！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "鎮民1",
        "words": "喔，",
        "unit_id": 1511,
        "voice": "vo_adv_1175002_023"
    },
    {
        "type": "dialogue",
        "name": "鎮民1",
        "words": "還有這樣的中藥啊。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "鎮民1",
        "words": "\n給我瞧瞧。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "當然沒問題！",
        "unit_id": 414,
        "voice": "vo_adv_1175002_024"
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "據說服下這種藥任何疾病都會痊癒，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "\n還會延壽10年，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "是在蘭德索爾大受好評的珍品！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "鎮民2",
        "words": "那還真厲害！",
        "unit_id": 311,
        "voice": "vo_adv_1175002_025"
    },
    {
        "type": "dialogue",
        "name": "鎮民2",
        "words": "雖然我很想要……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
