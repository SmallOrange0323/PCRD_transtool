        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我很高興呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "惡徒1",
        "words": "……像妳這樣的人，",
        "unit_id": 911,
        "voice": "vo_adv_1001010_071"
    },
    {
        "type": "dialogue",
        "name": "惡徒1",
        "words": "要是",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡徒1",
        "words": "我們能早點遇到就好了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡徒1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡徒1",
        "words": "那我們走了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100111,
        "voice": "vo_adv_1001010_072"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "走掉了呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那些人，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果有好好反省就好呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "護衛１",
        "words": "哼，",
        "unit_id": 1111,
        "voice": "vo_adv_1001010_073"
    },
    {
        "type": "dialogue",
        "name": "護衛１",
        "words": "哪可能每次都讓妳這麼順利呀！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "護衛１",
        "words": "像你們這樣天真的人，",
        "unit_id": 1111,
        "voice": "vo_adv_1001010_074"
    },
    {
        "type": "dialogue",
        "name": "護衛１",
        "words": "總有一天會吃到苦頭的！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "護衛１",
        "words": "別再讓我們遇到了！　",
        "unit_id": 1111,
        "voice": "vo_adv_1001010_075"
    },
    {
        "type": "dialogue",
        "name": "護衛１",
        "words": "掰啦！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "護衛１",
        "words": "\n反正一定會橫死在某處吧，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "護衛１",
        "words": "笨蛋們！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100111,
        "voice": "vo_adv_1001010_076"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "天真的人……",
        "unit_id": 100111,
        "voice": "vo_adv_1001010_077"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的很天真嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n即使惡徒也想要幫助他們，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣的作法真的有錯嗎。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……嗯，",
        "unit_id": 100111,
        "voice": "vo_adv_1001010_078"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是吧。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不管眼前誰有困難，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我都無法置之不理！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒什麼了不起的唷。",
        "unit_id": 100111,
        "voice": "vo_adv_1001010_079"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "等我回過神，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "發現身體早已先行動而已。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生。",
        "unit_id": 100111,
        "voice": "vo_adv_1001010_080"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣鼓勵我，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝你。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "被人說我天真也沒關係。",
        "unit_id": 100111,
        "voice": "vo_adv_1001010_081"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n今後",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我要不斷不斷地，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不論是誰",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都要繼續幫助他們！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "重新打起精神的日和，\n在心中暗自強烈地發誓。"
    }
]