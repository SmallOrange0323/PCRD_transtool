    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦？",
        "unit_id": 131711,
        "voice": "vo_adv_5150005_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……也是。",
        "unit_id": 131711,
        "voice": "vo_adv_5150005_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "各位，",
        "unit_id": 131711,
        "voice": "vo_adv_5150005_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "謝謝你們。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "蘭德索爾的人們",
        "words": "──！",
        "unit_id": 1,
        "voice": "vo_adv_5150005_016"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……呵呵。",
        "unit_id": 190912,
        "voice": "vo_adv_5150005_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哦～",
        "unit_id": 131811,
        "voice": "vo_adv_5150005_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來如此呀～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好了……",
        "unit_id": 131711,
        "voice": "vo_adv_5150005_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼要做這種事？",
        "unit_id": 131711,
        "voice": "vo_adv_5150005_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n有話要辯解的話我就聽妳說吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……嘀咕嘀咕嘀咕……",
        "unit_id": 131811,
        "voice": "vo_adv_5150005_021"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……因為",
        "unit_id": 190912,
        "voice": "vo_adv_5150005_022"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "環境系統正好",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就在那裡啊……",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "帆稀，",
        "unit_id": 131711,
        "voice": "vo_adv_5150005_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別灌輸她那種歪理。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "既然被抓到了，",
        "unit_id": 131711,
        "voice": "vo_adv_5150005_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就給我一五一十全說出來。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不管怎麼說，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳都不單單只是想要惡作劇吧？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳是這麼認為的？",
        "unit_id": 190912,
        "voice": "vo_adv_5150005_025"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n妳還是真是很信任我呢。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我的惡作劇哪有什麼理由──",
        "unit_id": 190912,
        "voice": "vo_adv_5150005_026"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "──是為了愛梅斯對吧？",
        "unit_id": 131811,
        "voice": "vo_adv_5150005_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼？",
        "unit_id": 131711,
        "voice": "vo_adv_5150005_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了我……？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "她有問過愛梅斯對吧～？",
        "unit_id": 131811,
        "voice": "vo_adv_5150005_029"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就是那句",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "「有好好享受嗎？」",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "喔。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯……",
        "unit_id": 131711,
        "voice": "vo_adv_5150005_030"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "喂！",
        "unit_id": 190912,
        "voice": "vo_adv_5150005_031"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "可以別擅自在那邊亂猜嗎？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我才沒有追求",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那種展開呢！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳不想說嗎？",
        "unit_id": 131813,
        "voice": "vo_adv_5150005_032"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n真拿妳沒轍～",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來，{player}，",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n張開嘴巴～♪",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "噫！",
        "unit_id": 190912,
        "voice": "vo_adv_5150005_033"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n知道了！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我知道了啦！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我招，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我全招就是了～～～！",
        "unit_id": 190912
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哈囉～",
        "unit_id": 190911,
        "voice": "vo_adv_5150005_034"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "菲歐～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我來囉～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "來了要幹嘛，我又沒找妳來。",
        "unit_id": 190011,
        "voice": "vo_adv_5150005_035"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哇，妳好冷漠。",
        "unit_id": 190911,
        "voice": "vo_adv_5150005_036"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n這是對心愛的妹妹該有的態度嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "難得我跑來看妳耶～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我可是很忙的啊。",
        "unit_id": 190011,
        "voice": "vo_adv_5150005_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我必須很頻繁地",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "整理他的記憶才行。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是哦……",
        "unit_id": 190911,
        "voice": "vo_adv_5150005_038"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "欸，菲歐，",
        "unit_id": 190911,
        "voice": "vo_adv_5150005_039"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n妳最近過得快樂嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……幹嘛突然問這個？",
        "unit_id": 190011,
        "voice": "vo_adv_5150005_040"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳想嘛，",
        "unit_id": 190911,
        "voice": "vo_adv_5150005_041"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我們兩個",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n不是可以出去外面了嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我很好奇妳有好好去享受一下嗎。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒有，",
        "unit_id": 190011,
        "voice": "vo_adv_5150005_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "享受這種事情對我來說又沒必要。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……我的使命是引導他。",
        "unit_id": 190011,
        "voice": "vo_adv_5150005_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "跟我本身是否有好好享受這點毫無瓜葛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "可是，菲歐。",
        "unit_id": 190911,
        "voice": "vo_adv_5150005_044"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n妳以前不是更常在外頭跑來跑去的嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "跟他一起到處跑。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那時的妳更顯得生龍活虎吧？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那已經是過去式了。",
        "unit_id": 190011,
        "voice": "vo_adv_5150005_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在的我",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "長相和名字都變了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……無法再回到",
        "unit_id": 190011,
        "voice": "vo_adv_5150005_046"
    },
    {
        "type": "dialogue",
