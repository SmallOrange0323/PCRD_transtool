[
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了採集素材，\n{player}來到了溪谷。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "救救我～",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有人在嗎！？請救救我！",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我爬上山崖之後，下不去了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n手臂……已經沒力了……！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哇！腳踩的地方！",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n要、要掉……要掉下去了～！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呀啊啊啊！！",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "――嘎！",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還、還以為我要死掉了……",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊啊啊啊！謝謝對不起！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n竟然麻煩你救我了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "――搞什麼。原來是你啊。",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呼……害我窮緊張了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……你問我那裡做什麼？",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n有人拜託我，所以才在那蒐集素材。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們的公會長魔力變弱了，",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n所以每個成員都正在蒐集增強魔力的素材。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這也是公會活動的一環。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好像有種花只生長在那個懸崖，",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我想要採集那個花，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n結果就下不來了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎、怎麼了？表情這麼嚴肅……",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……我一個人去太危險？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "原來你是擔心我啊……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這種事情我當然知道。",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_011"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但是，那個……欸，就是……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就沒有人可以跟我一起去呀！",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n不行嗎！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "平常都是妹妹會和我一起行動，",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n但她說今天沒辦法……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我又沒有其他可以拜託的人……",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_014"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n也不想要拜託別人，結果被當作厚臉皮的傢伙。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "………………",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_015"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呼……",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_016"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這種時候，如果是我妹妹的話就能處理得很好吧。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我妹妹和誰都能立刻打成一片。",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_017"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "很受大家喜愛……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n真是好羨慕她……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我總是想著，",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_018"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "希望有天可以變得像妹妹那樣……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n不過我還是不擅長和別人交談……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以說，如果公會長能找回魔力完全復活的話，",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_019"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我想拜託她用魔法幫我改善怕生這一點……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "今天也是因為沒有人可以拜託，",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_020"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n所以我就自己一個人來了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸、",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_021"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸欸！？你說交給你……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n你、你在耍什麼帥――",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "――不對！",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我才沒有覺得你很帥氣！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸？也、也不是啦，",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我並沒有覺得你靠不住。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然你少了根筋，但辦事很牢靠；",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "平常好像都在發呆，但其實很認真……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "覺得很開心，或是覺得你很值得依靠……",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_025"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我真的完全沒有那樣想呦！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可、可是……那個，",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_026"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可以拜託你……嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真的嗎！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個……謝、謝……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "――哼、哼！",
        "unit_id": 102211,
        "voice": "vo_adv_1022002_028"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n既然你都這麼說了，就讓你幫忙吧！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為太過倔強，依里無法好好說聲謝謝。"
    }
]