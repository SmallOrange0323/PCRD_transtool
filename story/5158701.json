[
    {
        "type": "background",
        "background": "501680"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "よーし、",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_000"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "この辺りの魔物は片付いたなっ。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\nみんな",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "休憩に入れー！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "新兵たち",
        "words": "はい、",
        "unit_id": 1,
        "voice": "vo_adv_5142701_001"
    },
    {
        "type": "dialogue",
        "name": "新兵たち",
        "words": "教官！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "しかし、",
        "unit_id": 129911,
        "voice": "vo_adv_5142701_002"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "魔物が山ほどいるとは聞いていましたが。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n本当に",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "次から次へと湧いてきますわね。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "ま、",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_003"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "想像してた通りではあるさ。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "実戦経験を積むにもちょうどいいだろ。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "お疲れさま。",
        "unit_id": 104711,
        "voice": "vo_adv_5142701_004"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n魔物の掃討は順調に進んでいるようだね。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "ああ、",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_005"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "おかげさまで。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n新兵もしっかり戦えてるし、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "エリコも……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "クスクス……",
        "unit_id": 129911,
        "voice": "vo_adv_5142701_006"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "忌々しい魔物たちですが、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n私たちが愛を育むための糧になると思えば、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\nかわいらしいものですわね。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "うん、",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_007"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "エリコも力が入ってるぜ。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "……動機はちょっと不純だけどな。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "それはよかった。",
        "unit_id": 104711,
        "voice": "vo_adv_5142701_008"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\nならこの訓練も、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "次の課程に進んで問題なさそうだね。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "え？　",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_009"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "まだ何かやるのか？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "やること自体はこれまでと同じ、",
        "unit_id": 104711,
        "voice": "vo_adv_5142701_010"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "協力して魔物を倒すだけさ。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\nただ次はゴール地点を設けず、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "隊列が保てる限り",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n行軍を続けてもらいたい。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "要するに、",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_011"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "進めるところまで進むってことか。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "ほんっと、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "無茶振りが多い騎士団だな……！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "問題ありませんわ。",
        "unit_id": 129911,
        "voice": "vo_adv_5142701_012"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n彼らの実力を考えれば不可能ではありませんし、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "それに……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "新兵１",
        "words": "追加の訓練って聞いてびっくりしたけど、",
        "unit_id": 711,
        "voice": "vo_adv_5142701_013"
    },
    {
        "type": "dialogue",
        "name": "新兵１",
        "words": "\n魔物もそんなに強くないみたいでよかったよ。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新兵２",
        "words": "むしろ",
        "unit_id": 717,
        "voice": "vo_adv_5142701_014"
    },
    {
        "type": "dialogue",
        "name": "新兵２",
        "words": "俺たちが強すぎるのかもしれないな！",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "新兵２",
        "words": "\nこれなら",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "新兵２",
        "words": "騎士団でもどんどん出世できそうだぜ！",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "思った通り、",
        "unit_id": 129911,
        "voice": "vo_adv_5142701_015"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "敵を侮り慢心する輩が出る頃合いですので。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "教育し甲斐がありそうです……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "クスクスクス♪",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "おーい、",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_016"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "エリコ？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n新兵にお仕置きするのがメインじゃないから、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "そこは忘れんなよ？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "さあみなさん……",
        "unit_id": 129911,
        "voice": "vo_adv_5142701_017"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "いえ、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "思い上がったゴミ虫たち。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "これより先には",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "今までと別次元の地獄が待っていますので、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "お覚悟を。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "新兵たち",
        "words": "い、",
        "unit_id": 1,
        "voice": "vo_adv_5142701_018"
    },
    {
        "type": "dialogue",
        "name": "新兵たち",
        "words": "イエスマム！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "……ま、",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_019"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "油断禁物なのは確かだしな。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\nあたしたちも、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "気合入れ直していくかっ！",
        "unit_id": 129811
    }
]