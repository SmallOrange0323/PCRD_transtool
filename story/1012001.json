    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "媽～媽！",
        "unit_id": 111,
        "voice": "vo_adv_1012001_015"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n這裡好高喔～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "喂！ 不是說了不能攀爬陽台的柵欄嗎！",
        "unit_id": 411,
        "voice": "vo_adv_1012001_016"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n快點下來！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "沒關係啦～――",
        "unit_id": 111,
        "voice": "vo_adv_1012001_017"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗚哇！？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗚哇哇！ 我、我要……",
        "unit_id": 111,
        "voice": "vo_adv_1012001_018"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "掉下去了～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "呀――！",
        "unit_id": 411,
        "voice": "vo_adv_1012001_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯～，睡得好飽～！",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "精神百分百！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "糟、糟糕了！",
        "unit_id": 311,
        "voice": "vo_adv_1012001_021"
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "\n孩子要從二樓掉下來啦！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "\n誰快來接住他！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦！ ",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我才剛睡醒，就發生大事啦！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡就交給我吧――！",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "馬力全開！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": " 嘿―――噫！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "啊哈哈哈！ 好厲～害！",
        "unit_id": 111,
        "voice": "vo_adv_1012001_024"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n我浮起來了～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "發、發生什麼事了……？",
        "unit_id": 311,
        "voice": "vo_adv_1012001_025"
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "\n孩子浮起來了！？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "\n那似乎和魔法不一樣……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "奇蹟啊！",
        "unit_id": 511,
        "voice": "vo_adv_1012001_026"
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "\n神蹟救了那孩子啊！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "你沒事吧？ 太好了！",
        "unit_id": 411,
        "voice": "vo_adv_1012001_027"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "太好了，大成功～！",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n閃亮亮☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "欸嘿嘿～",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_029"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "做了好事之後心情真好――",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚哇！？ 我旁邊有人！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_030"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "莫非……你你你、你看見了？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒、沒錯沒錯！",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_031"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這、這是魔法喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我我我、",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我是魔法師～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你問它叫什麼魔法？",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_032"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那是超能……，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好險好險！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "總總總、總之是很厲害的魔法！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怎怎怎、怎麼辦！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_033"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我沒想到會有人在……！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "總之，",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_034"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "剛剛的事不算數！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不算不～算！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我什麼都沒有做！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怎、怎麼可能有超能力啊！",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_035"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你竟然相信那種東西……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦？ 你沒提到超能力？",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_036"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "完、完了～！ 這招就是誘導性審問吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是，證據應該還不足呢！",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_037"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不管被如何拷問，我都不會招供的！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……咦？ 什麼？",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_038"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你說救了孩子很了不起……？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是、是這樣嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_039"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "欸嘿嘿～，我一被稱讚就會害羞呢～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是，這沒什麼喔～",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_040"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我只是覺得孩子有危險，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就一瞬間使出了超能力而已！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……呃，啊！",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_041"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我自己說出使用超能力了！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚～被發現就沒辦法了……",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_042"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我就只特別告訴你吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "其實我是超能力者！ 閃亮亮☆",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_043"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……你問超能力是什麼？",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_044"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦――！？ 難得我下了好大決心才告訴你，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你竟然是這種反應？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個，",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_045"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所謂的超能力呢，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是自我出生起就擁有的、很厲害的能力～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "與魔法不同，並非靠著學習而來的喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "能飛行、瞬間移動、移動物品……",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_046"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n能做到許多事情！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，像魔法一樣的攻擊也可以喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但、但是，這件事是祕密喔。",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_047"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以拜託你，不要告訴任何人喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "若是我會使用超能力的事被發現，",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_048"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我會被賣給地下組織，被強迫工作……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "或是做人體實驗、解剖什麼的……！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚……我才不要啊～",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_049"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n喂，你絕對不能說喔？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……你、你願意答應我嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_050"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "謝謝～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我的超能力是被溫柔的人看見，真是太好了～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我的名字是初音！",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_051"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "喂喂，你呢？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……呼嚕。",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_052"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～……咦？",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_053"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n啊，對不起喔～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我一使用超能力，馬上就會變得想睡……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我已經到極限了……",
        "unit_id": 101211,
        "voice": "vo_adv_1012001_054"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "晚安～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}不知該拿睡在路中間的初音怎麼辦，\n感到束手無策。"
    }
]