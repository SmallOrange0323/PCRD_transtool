    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感謝招待～☆",
        "unit_id": 105812,
        "voice": "vo_adv_2008008_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯，",
        "unit_id": 104911,
        "voice": "vo_adv_2008008_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "粗茶淡飯不成敬意～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看到大家這麼會吃，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐很高興唷！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 104911,
        "voice": "vo_adv_2008008_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "吃多一點也沒關係唷{player}！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n畢竟還在發育期嘛！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n要充分攝取營養，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "才會長成一位迷人的紳士唷！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘎哇哇啊……！？",
        "unit_id": 104911,
        "voice": "vo_adv_2008008_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "發、發出奇怪的聲音了啦！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可不可以別這樣嚇人家呀！？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過",
        "unit_id": 104911,
        "voice": "vo_adv_2008008_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我很開心唷，{player}！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要你想，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我就永遠會是世界第一的姐姐唷……☆",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "大家～！",
        "unit_id": 101112,
        "voice": "vo_adv_2008008_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我這邊是負責洗東西的，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以盤子請往這裡端唷～♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳們～",
        "unit_id": 105812,
        "voice": "vo_adv_2008008_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是無微不至呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～這真是呀，",
        "unit_id": 105812,
        "voice": "vo_adv_2008008_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃飽飽又大滿足呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後飯後一杯茶也很美味～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真幸福……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2008008_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過在下有一個疑問，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這些食材是從哪裡取得的呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡離城裡也有一段距離，",
        "unit_id": 105913,
        "voice": "vo_adv_2008008_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要入手這些物資也很不容易才對……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過就是用拉基拉基的空間跳躍，",
        "unit_id": 106112,
        "voice": "vo_adv_2008008_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "傳送到城鎮的近郊而已。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就算不坐馬車之類的交通工具，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也可以想去哪就去哪囉。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "講真的，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "超級方便的呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "嘻嘻。",
        "unit_id": 107311,
        "voice": "vo_adv_2008008_011"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n能幫上忙是我的榮幸。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105812,
        "voice": "vo_adv_2008008_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但就是因為太過於便利……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以王宮才會壟斷了空間轉移之類的魔法，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n並且禁止一般民眾使用的吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟使用在軍事之上的話，",
        "unit_id": 105812,
        "voice": "vo_adv_2008008_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就能佔到很大的優勢呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯，",
        "unit_id": 106112,
        "voice": "vo_adv_2008008_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可以將己方主力",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一瞬間就送到了敵方的陣地之類的呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n而且不管是銀行的金庫還是哪裡，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "想去哪就可以去哪呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是嘛，",
        "unit_id": 106112,
        "voice": "vo_adv_2008008_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為了防範空間跳躍，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也有可以捕捉到瞬間移動使用者的魔法陷阱，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以也不是無敵的就是了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "嗯嗯。",
        "unit_id": 191011,
        "voice": "vo_adv_2008008_016"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "也因此，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "要拯救被囚禁在王宮裡的似似花大人，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n就算想利用這個能力也相當困難。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n但也因為這樣所以讓人傷透了腦筋，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "究竟該怎麼辦才好啊？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "……沒辦法幫上忙，",
        "unit_id": 107311,
        "voice": "vo_adv_2008008_017"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我也很抱歉。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "你不需要道歉，",
        "unit_id": 191011,
        "voice": "vo_adv_2008008_018"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "拉基拉基。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "況且",
        "unit_id": 191011,
        "voice": "vo_adv_2008008_019"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "無法抵禦敵軍的襲擊，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n眼睜睜看著似似花大人被人奪走，全都是我的過失。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "啊，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "對無能為力的自己感到痛心。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過實際上，",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "該怎麼辦呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那個叫似似花的",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "被囚禁在我和小子待過的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n王宮的地下監獄裡頭……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可以這麼推測。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "該處是為了拘留政治犯所造出來的監牢，",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n只用半吊子的手段可沒辦法突破喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n畢竟可是連我",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都無法逃脫出來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106112,
        "voice": "vo_adv_2008008_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們有在思考了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "放心吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然只要拉比林斯達醒過來，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有她幫忙就很簡單了～",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但也不想太勉強她呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，",
        "unit_id": 106112,
        "voice": "vo_adv_2008008_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "克莉絲提娜和拉基拉基，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也和拉比林斯達一樣被稱為",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "『七冠』",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這個世界中沒有不可能的事唷，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別放棄希望再加把勁吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個。",
        "unit_id": 105913,
        "voice": "vo_adv_2008008_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請問所謂的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『七冠』，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是指什麼呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知道為什麼",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總覺得相當在意。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且不知道為何在下的父親之名，",
        "unit_id": 105913,
        "voice": "vo_adv_2008008_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在古文書上",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也被記載為『七冠』。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是這樣的嗎！",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "才想說在妳身上",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "感覺到不平凡的因緣，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n原來是有這種關係啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳的父親",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和我是同質的存在嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真令人好奇呀♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咿……",
        "unit_id": 105913,
        "voice": "vo_adv_2008008_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "別這樣直盯著在下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105812,
        "voice": "vo_adv_2008008_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克莉絲提娜……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請妳不要把小可蘿給嚇壞了喔？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我倒是想嚇嚇她，",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "期待會不會因不安的情緒使然就直接殺了過來呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳也一樣，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "心血來潮的話就讓我們再愛恨交織地廝殺一番吧……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n公主‧蒂亞娜♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個～",
        "unit_id": 105812,
        "voice": "vo_adv_2008008_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "第一次遇到妳的時候我就很好奇了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為什麼妳",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會知道我的本名呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n明明不只是王宮的相關人士，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就連親人都全把我忘記了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是從陛下那聽來的唷。",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都被背叛了還差點掉了小命，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n已經不需要",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "『陛下』這種充滿敬意的稱呼了呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就讓我改個口吧。",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是從那非善類的尤絲蒂亞娜口中，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聽到了關於妳的事情。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說妳自認為自己是公主，",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n借尤絲蒂亞娜之名到處行騙",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "的可憐小姑娘呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為覺得妳礙眼才會委我去處理一下，",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n先前……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我和妳會兵戎相向就是為了此事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但不是呀。",
        "unit_id": 105812,
        "voice": "vo_adv_2008008_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那邊才是『假貨』，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我是『真貨』的尤絲蒂亞娜唷？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想也是呢。",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "或多或少，我也有察覺到了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "將『真貨』給抹殺後取而代之，",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是那非善類的尤絲蒂亞娜預先做好的打算吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n至於真意為何，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也不是很清楚。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但畢竟是個崇尚權力的傢伙。",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在王位上，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了穩固現在的地位，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "會不遺餘力的使用各種手段吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也是因為那點，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "強烈的性格讓我為之傾心。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但不至於純情到都要被殺了，",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還能夠打從心底去仰慕那傢伙。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "卻也不是能將好意或敬愛全部轉化為憎恨，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如此愛恨分明的人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "大嬸……",
        "unit_id": 190711,
        "voice": "vo_adv_2008008_041"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n雖然聽不太懂在說啥，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "但打起精神來吧。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n這可不像妳呀。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可還不到被稱人為『大嬸』的年紀啊，",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你是要我說幾次？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": " 看來是很想死啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "願意安慰挺令人開心的……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "謝謝你，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總而言之，",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這個世界現在",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "似乎有什麼駭人的陰謀正在進行中。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼都不明白就被捲入",
        "unit_id": 107111,
        "voice": "vo_adv_2008008_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "甚至丟了小命也不是滋味，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可以的話還是盡可能想把握事態。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106112,
        "voice": "vo_adv_2008008_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也就是為了這件事，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才會準備了這個能共同分享情報的機會。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我對克莉絲提娜和大吾，",
        "unit_id": 106112,
        "voice": "vo_adv_2008008_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n還有與拉基拉基跟真軌也都還沒有說過這些話……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n在這，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "想要徹底把話一次都給說清楚。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在開始我要說的事，",
        "unit_id": 106112,
        "voice": "vo_adv_2008008_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n對你們而言",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可能是一些難以置信的事情也說不定。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n裡頭可能還參著我的願望、臆測，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "甚至是誤解吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是。",
        "unit_id": 106112,
        "voice": "vo_adv_2008008_049"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還是希望大家能先別抱持疑慮，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在全都聽完後再各自進行考量。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n然後，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再去思考在這個被徹底改寫的，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "既殘酷又可怕的世界中，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n該怎麼去面對",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和保有自己的信念。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "當下的",
        "unit_id": 106112,
        "voice": "vo_adv_2008008_050"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個世界，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "正被惡意侵蝕著。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "若什麼也不去想，",
        "unit_id": 106112,
        "voice": "vo_adv_2008008_051"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只是單單的接受現狀就只會變得不幸……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "最糟的情況，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也很有可能會就此失去一切，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在那絕望之中迎向死亡喔。",
        "unit_id": 106112
    }
]