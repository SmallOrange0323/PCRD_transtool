[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【王宮騎士團（NIGHTMARE）】的成員智，\n在蘭德索爾邊疆地帶的獸人居住區附近走著。"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然是第一次踏進",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "獸人族的居住地，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但街景看來倒是挺普通的呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不過也這是當然的呀，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為獸人的生活型態",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "和我們差不多。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "其實除了",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "尾巴和動物般的身體之外，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n獸人在本質上跟人類沒兩樣呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "和魔物不同……",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只是走在路上的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "應該不會無緣無故地跑來攻擊才是。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "即使如此，",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "多少還是得有所警戒。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n在歷史上來看，獸人族跟我們",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "『王宮』的勢力……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "特別是和\n【王宮騎士團（NIGHTMARE）】的關係不是很好。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "長年在",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "迫害和",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "血淚抗爭中度過。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然是我出生前發生的事了……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但還是不要對獸人族",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "完全卸下防備才是呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "獸人女子",
        "words": "…………",
        "unit_id": 413,
        "voice": "vo_adv_5006001_005"
    },
    {
        "type": "dialogue",
        "name": "獸人男子",
        "words": "…………",
        "unit_id": 414,
        "voice": "vo_adv_5006001_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看吧，",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "正被他們盯著看呢……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這就是",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "獸人們平時對我們的態度。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但總是被這樣抱持敵意，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還是覺得有點感傷呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "即使想開開玩笑，表示友好，也很難化解這敵意吧。",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n充其量就是被吐口水，或是被趕出去而已吧",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "該怎麼辦？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然我很想問路呢。",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但拿著武器的人這麼多，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n任意接近的話恐怕會引發戰鬥。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嘛算了。",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n今天是休假，既沒有訓練也沒有任務，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就輕鬆地慢慢找吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯……",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n從那間有著大掛鐘的店旁邊十字路口",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n往北稍微前進。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哦！",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是這邊嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這棟兩層樓的建築是",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉的家嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那孩子還真的",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "住在獸人的居住區呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊啊啊啊啊，",
        "unit_id": 100511,
        "voice": "vo_adv_5006001_014"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "搞不清楚了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "媽媽真是頑固，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "絕對絕對絕對……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不是純的錯！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "純可是我崇拜的人！",
        "unit_id": 100511,
        "voice": "vo_adv_5006001_015"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n總有一天，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也希望能像純一樣成為正義的一方……！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哦哦？　",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n突然衝出來很危險哦，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這裡一直都會有馬車經過的呀？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦！？",
        "unit_id": 100511,
        "voice": "vo_adv_5006001_017"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n咦，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智～姐！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？　",
        "unit_id": 100511,
        "voice": "vo_adv_5006001_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為什麼你在這裡？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為什麼最近都沒參加訓練呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我很擔心你是不是發生什麼事了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "特地來看看你的情況喔。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "畢竟我被",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "拜託要照顧你呀。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "再說一般來說都會覺得奇怪吧……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你一直是很健康的孩子，也沒什麼生過病，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n平時又很認真，完全不聯絡一聲就缺席訓練實在不太尋常。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以很擔心，",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "想說你是不是發生了什麼事呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以才\n特地跑到你交給【王宮騎士團（NIGHTMARE）】",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "的住址這邊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還用了我珍貴的休假呢。",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過還好，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你看起來很有精神，真是太好了呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊、",
        "unit_id": 100511,
        "voice": "vo_adv_5006001_023"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚？　",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不是啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然我住在獸人族的居住區，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但我可不是獸人，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有原因的啦～……！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯～　",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然你拼命遮掩，我也很難直接說，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但其實一眼就能看出你是獸人喔。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你的頭巾",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "把獸耳遮蓋住了吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不，不是啦！　",
        "unit_id": 100511,
        "voice": "vo_adv_5006001_025"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我才不是獸人的啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "如果是的話，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我就不會特意跑去加入和獸人交惡的\n【王宮騎士團】了吧！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯……",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "算了啦，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一直逼你也沒什麼意義。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過。",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一直站著說話也無法靜下心來，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n要不要找間店慢慢談？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n剛好是午餐時間呢，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "順便吃個飯吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我請你喔。",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "前陣子劍術比賽才得到優勝，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n拿到獎金後口袋挺深的呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511,
        "voice": "vo_adv_5006001_029"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這樣不好意思啦～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不過我",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "的確也有想和小智姐談的事情……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嘻嘻。",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "小孩子不用顧慮太多。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n走吧……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且有一個疑似是茉莉媽媽的人，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n帶著跟鬼一樣地表情追著你呢♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦、",
        "unit_id": 100511,
        "voice": "vo_adv_5006001_031"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "每次媽媽露出那個表情時事情就嚴重了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "之前",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "跟爸爸吵架時也是露出同個表情，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那時媽媽氣到失去理智，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "把家裡弄到半毀！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗚呀，",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "太可怕了……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "快快離開吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "把手給我，",
        "unit_id": 103711,
        "voice": "vo_adv_5006001_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "公主殿下。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我會把你護送到安全的地方♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哇哇，",
        "unit_id": 100511,
        "voice": "vo_adv_5006001_034"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "緊握住你的手就可以了嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "了解，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "手牽手快逃喲～！",
        "unit_id": 100511
    }
