[
    {
        "type": "background",
        "background": "501420"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那個那個，",
        "unit_id": 117911,
        "voice": "vo_adv_6076303_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "博士他啊，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "頭腦好得不得了對吧。",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n還研究什麼大災難……？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "之類的東西。",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "即使聽他說明，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也聽得不是很懂的說。",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "比秀才還要秀才嗎？",
        "unit_id": 117911,
        "voice": "vo_adv_6076303_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那他也太厲害了吧！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "除法之類他也超會？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "該不會連更困難的計算也難不倒他……？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "天啊天啊，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "博士他",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是真正的博士對吧。",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "乾脆下次請他教人家讀書好了……",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是這樣嗎？",
        "unit_id": 117911,
        "voice": "vo_adv_6076303_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這樣人家",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就稍微安心了！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家先前還在擔心，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要是就只有人家聽不懂，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那該怎麼辦～",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過，如果秀才也是一樣，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "總覺得應該就沒有問題了！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像",
        "unit_id": 117911,
        "voice": "vo_adv_6076303_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一定要寫出",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那個什麼論文來呢。",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所謂博士的工作，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是指一輩子都持續在寫",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "暑假的自由研究作業嗎？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "唔哇……",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "光只是想像，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "頭就痛起來了～",
        "unit_id": 117911
    }
]