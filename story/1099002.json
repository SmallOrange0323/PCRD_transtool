        "voice": "vo_adv_1099002_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n【咲戀育幼院】的各位所照顧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以偶爾也要來",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幫忙採買才行。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1099002_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是非常了不起的想法。",
        "unit_id": 105913
