    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天天氣晴朗、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "風和日麗，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是絕佳的採買之日呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說我們平時總是受到",
