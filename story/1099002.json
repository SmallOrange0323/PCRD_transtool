        "voice": "vo_adv_1099002_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有主人和在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "人手就相當足夠了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我嗎？",
