        "voice": "vo_adv_1099002_003"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是啊。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n我也覺得非～常了不起喔。",
        "unit_id": 109911
