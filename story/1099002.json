        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也深感佩服。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯嗯，",
