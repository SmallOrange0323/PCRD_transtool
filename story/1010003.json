[
    {
        "type": "background",
        "background": "500232"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生、王子先生。",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n天空可以看到星星呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "反射月光和星光……",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "整座冰晶山脈都",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n閃閃發光呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是漂亮啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好可愛呀～……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生？",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果王子先生不回話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家可是會很寂寞的……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀～",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生剛剛快睡著了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "睡著的話可是會死掉的喔～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "冰晶山脈的",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n氣溫異常地低。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "等等唷，人家施展一下暖氣魔法……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "神奇真步魔法靈，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n咕嚕靈波～……☆",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯，成功施展了。",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n感覺上和王子先生在一起的時候，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n魔法的成功率變高了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可是，嗯……",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n要說能不能隨心所欲地施展魔法，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n成功率還是一半一半。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎麼樣，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n從身體裡面開始覺得暖和起來了吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯，人家就是施展了那種魔法～♪",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果稍有差錯的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n說不定會從身體裡面爆炸。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "能成功真是太好了～",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n快看快看，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家還變出了營火喔♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生、王子先生，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n快到這裡來。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "熱氣騰騰很溫暖吧～？",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "暖呼呼的……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不用跟人家",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n道謝的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "都是人家不好，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n我們才會從馬車上摔出來。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "負起責任讓王子先生平安回家，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是人家的職責。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀～？",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不是「真步小姐」，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家希望您叫「真步公主」呢……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真是壞心呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話說回來，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家應該要",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "感覺著急一點比較好。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為人家的個性",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就是那樣……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現在反而感覺像去野餐一樣地開心呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……哎呀～？",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n看來通訊魔法終於接通了♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家想總不能這樣遇難下去，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以就和【哞哞自衛隊】的大家聯絡了唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n大家大概也很擔心人家……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為不知道大家的所在地，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以人家費了一番工夫。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "通訊魔法得要計算座標之類的，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還蠻麻煩的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不論如何，【哞哞自衛隊】的大家",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好像要來救援了……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "再忍耐一下，王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也已經弄清楚",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n很多事情了唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "看來是有竊盜集團侵入了",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n咱們負責戒備的博物館……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n結果咱們就被抓起來了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然不知道是不是要把咱們跟偷來的東西",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n一起賣掉。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但咱們被綁起來，然後用馬車載走……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不知道是幸還是不幸，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但總算是從竊盜集團的馬車逃了出來。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "再加上",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n因為人家失蹤而擔心的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n【哞哞自衛隊】夥伴們……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "她們探測人家的",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n魔力或氣味……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n試著追蹤人家的位置。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "於是找出了竊盜集團的巢穴，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n很快速地消滅了他們。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過自衛隊的夥伴們不懂得拿捏分寸，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以人家真擔心竊盜集團的人呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "她們不只是順利奪回了被偷走的東西，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_035"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還消滅了竊盜集團……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "獲得了超過【哞哞自衛隊】標準以上的成果，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真是令人雀躍對吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～果真是吉人自有天相呢。",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家什麼都沒做，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n每件事情就都迎刃而解了……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "每次",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n都有這樣的感覺♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "整個世界都安穩和平。",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就像童話故事一樣，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可喜可賀、可喜可賀……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呼……",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n雖然發生了這麼多事，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不過王子先生參觀博物館了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "博物館可以免費參觀。",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_041"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n想打發時間的時候，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是個好選擇呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您失去記憶了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "原來如此。",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_043"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以王子先生到陳列古物的博物館走走……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是想找找看有沒有一些記憶的線索嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣呀。",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_044"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生也真是辛苦呢，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好可憐呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n很想幫上忙……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但是魔法也不是萬能的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話說回來，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生明明只是",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n來博物館參觀毫不相干的人……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "卻被捲入了這種麻煩事，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_047"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真是抱歉呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家要是好好地守衛住博物館……",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_048"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n趕走竊盜集團的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就不會變成現在這樣了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是對不起呀。",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_049"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n明明保護大家的安全",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是【哞哞自衛隊】的工作。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯？",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_050"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生才覺得抱歉？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "為什麼王子先生要道歉呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯嗯，王子先生……",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_051"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n看到人家要被竊盜集團給抓走，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以想來救人家是嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "想這麼做但因為力不從心，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_052"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n結果自己也被抓了起來？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "原來如此。",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_053"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n果真是一位王子呢……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_054"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是想救人家對吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n有那個心意就足夠了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然現實",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_055"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n很難像繪本一樣順利，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但只要我們都能慢慢成長就好了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣的話，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_056"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n總有一天一定可以迎接幸福的結局♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓我們",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_057"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n一起變強吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以下一次",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_058"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n一定要保護好人家唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也會",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_059"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n變成值得讓王子先生捨命相救……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "優秀出眾的公主的♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，王子先生，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_060"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n看來有人來接我們了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家聽到大家的聲音了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……王子先生？",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_061"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "睡著了呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "為了不要讓王子先生凍著，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_062"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家來抱住王子先生吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "吶～很溫暖吧？",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_063"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好孩子、好孩子♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_064"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是個好孩子……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊哈哈，",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_065"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是個好結局的話",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n一切過程都是好的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這次也是",
        "unit_id": 101011,
        "voice": "vo_adv_1010003_066"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n可喜可賀、可喜可賀……♪",
        "unit_id": 101011
    }
]