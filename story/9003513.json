        "voice": "vo_adv_9003513_003"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "本沒打算捲入消耗戰的……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "真無奈啊。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "萬能人偶",
        "words": "「嗡──嗡──」",
        "unit_id": 191912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哇哇！",
        "unit_id": 100511,
        "voice": "vo_adv_9003513_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n它們",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "又出現了！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "萬能人偶──",
        "unit_id": 191911,
        "voice": "vo_adv_9003513_005"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "耗費了我這麼多心血，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "應該能爭取到一些時間吧。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n且讓我重整旗鼓囉。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂喂，大叔！",
        "unit_id": 106511,
        "voice": "vo_adv_9003513_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "明明才打到一半，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你是想逃嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才",
        "unit_id": 100311,
        "voice": "vo_adv_9003513_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "已經說了要做個了斷吧……！？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我當然",
        "unit_id": 191911,
        "voice": "vo_adv_9003513_008"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "也想分出勝負。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n但戰鬥",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "比預期的延長了許多……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "所以我想",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "先用餐休息片刻。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇，",
        "unit_id": 105811,
        "voice": "vo_adv_9003513_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那很不錯呢……☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "純、智",
        "words": "陛下！",
        "unit_id": 1,
        "voice": "vo_adv_9003513_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開、",
        "unit_id": 105811,
        "voice": "vo_adv_9003513_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開玩笑的啦～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "呵呵。",
        "unit_id": 191911,
        "voice": "vo_adv_9003513_012"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n那麼，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "容我先失陪了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵♪",
        "unit_id": 106711,
        "voice": "vo_adv_9003513_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不會讓你逃走的唷～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "唔……！？",
        "unit_id": 191911,
        "voice": "vo_adv_9003513_014"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n……才一瞬間就阻止了傳送……！",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不放過虛弱的獵物，",
        "unit_id": 106711,
        "voice": "vo_adv_9003513_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "確實地取其性命……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是狩獵的基本喔～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唷呼♪",
        "unit_id": 106511,
        "voice": "vo_adv_9003513_016"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "老大看出大叔的意圖了啊！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不愧是老大！",
        "unit_id": 106611,
        "voice": "vo_adv_9003513_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n作風老是這麼陰險啊～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在教訓祈梨之前……",
        "unit_id": 106711,
        "voice": "vo_adv_9003513_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "差不多該束手就擒了吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "【憤怒‧軍團】♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我不會",
        "unit_id": 191911,
        "voice": "vo_adv_9003513_019"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "讓妳稱心如意……！",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔……！？",
        "unit_id": 103711,
        "voice": "vo_adv_9003513_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n沒想到",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "他還保留了這麼多力量……！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "別大意！",
        "unit_id": 100311,
        "voice": "vo_adv_9003513_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n接下來可是關鍵時刻……！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的！",
        "unit_id": 105811,
        "voice": "vo_adv_9003513_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這是最後的對決了！",
        "unit_id": 105811
    }
