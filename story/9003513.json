        "words": "呵呵。",
        "unit_id": 106711,
        "voice": "vo_adv_9003513_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你差不多沒有退路了呢～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "……哎呀哎呀。",
