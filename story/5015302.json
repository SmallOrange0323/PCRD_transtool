[
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這股驚人的力量……",
        "unit_id": 105311,
        "voice": "vo_adv_5015302_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真不愧是",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "仿造了東國惡人的代名詞，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n也就是模仿惡代官的魔物呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不過，",
        "unit_id": 109611,
        "voice": "vo_adv_5015302_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "惡代官",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n在東國的傳說裡，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "其實",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "並不強啊？",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是、",
        "unit_id": 109511,
        "voice": "vo_adv_5015302_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是這樣嗎……！？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那個像野獸般的眼神，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我還以為\n一定是知名的虐待狂……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然我也畏懼權力，",
        "unit_id": 105311,
        "voice": "vo_adv_5015302_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過我一直覺得",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n世界上存在著英雄們會去討伐的邪惡之王……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "總之，",
        "unit_id": 109611,
        "voice": "vo_adv_5015302_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "它的弱點是",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "女性",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "和金錢，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大概",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一擊就會",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "被英雄給打死了呢。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……感覺應該很容易就能獲勝。",
        "unit_id": 105311,
        "voice": "vo_adv_5015302_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你們兩位，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要一口氣分出勝負了喔！",
        "unit_id": 105311
    }
]