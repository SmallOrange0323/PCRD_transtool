[
    {
        "type": "background",
        "background": "500332"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由於【new generations】的訓練而停留在村莊裡的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}一行人——"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……好～",
        "unit_id": 112611,
        "voice": "vo_adv_1126003_000"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "沒有人看到我。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "趁現在……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嗚呀啊啊啊啊！？",
        "unit_id": 112611,
        "voice": "vo_adv_1126003_001"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嚇我一跳——……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "不要突然叫住我啦～",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "會害我以為出現什麼東西了。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……咦，",
        "unit_id": 112611,
        "voice": "vo_adv_1126003_002"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "因為我偷偷摸摸的",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "所以很在意？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "哎、",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "哎呀，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "你在說什麼啊——！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "小未央並沒有",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "在做什麼奇怪的事情喔——！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "只是，",
        "unit_id": 112611,
        "voice": "vo_adv_1126003_003"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "該怎麼說……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "稍微",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "轉換心情",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "去散散步而已！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "所以你",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "不用太在意，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那就掰啦——！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1126003_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來您在這裡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "洗澡水已經放好了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請來這邊——",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請等一下，",
        "unit_id": 105913,
        "voice": "vo_adv_1126003_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人一個人去的話很危險的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "發生什麼事了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……因為未央小姐進了森林？",
        "unit_id": 105913,
        "voice": "vo_adv_1126003_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個時間應該沒有理由進去森林的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的有點令人在意呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白了。",
        "unit_id": 105913,
        "voice": "vo_adv_1126003_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請讓在下同行吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "走吧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請牽著在下的手。",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……還沒看到未央小姐的蹤影呢。",
        "unit_id": 105913,
        "voice": "vo_adv_1126003_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再繼續往前走的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是森林的深處了——",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "1、",
        "unit_id": 112611,
        "voice": "vo_adv_1126003_009"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "2、",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "3、",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "4！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n5、",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "6、",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "7、",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "8！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個聲音是……",
        "unit_id": 105913,
        "voice": "vo_adv_1126003_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從那裡傳來的吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們走吧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
