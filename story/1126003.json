        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "Ko！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……好，",
        "unit_id": 112611,
        "voice": "vo_adv_1126003_012"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "再從頭來一遍吧！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嗚呀啊啊啊啊——！？",
        "unit_id": 112611,
        "voice": "vo_adv_1126003_013"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n……咦？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "你們兩個怎麼會在這裡！？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉，",
        "unit_id": 105913,
        "voice": "vo_adv_1126003_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們跟在後頭來的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人對於",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "未央小姐進了森林一事",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感到十分在意。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "哎呀……",
        "unit_id": 112611,
        "voice": "vo_adv_1126003_015"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "原來是這樣啊……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我還以為勉強矇混過去了呢。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是在複習剛才訓練的內容呢，",
        "unit_id": 105913,
        "voice": "vo_adv_1126003_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不過為什麼要瞞著大家到森林裡呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊……",
        "unit_id": 112611,
        "voice": "vo_adv_1126003_017"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那個……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "因為……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果要複習，",
        "unit_id": 105913,
        "voice": "vo_adv_1126003_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "待在村子裡會比較安全，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人那份擔憂的心情",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也能感同身受。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……",
        "unit_id": 112611,
        "voice": "vo_adv_1126003_019"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "因為難為情才不想開口的，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "事到如今也沒辦法了。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n其實啊，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這是我為了精進自己",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "而展開的祕密特訓。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我們呀，",
        "unit_id": 112611,
        "voice": "vo_adv_1126003_020"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "上次的演出完全搞砸了對吧？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n那件事讓我超級不甘心，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "有種「不多練習可不行！」",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "的感覺。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我想要練到至少",
        "unit_id": 112611,
        "voice": "vo_adv_1126003_021"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "有足夠的自信能斷言下次絕對沒問題為止。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "只不過，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我也不想太勉強島村村和澀凜凜……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "所以才會",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "一個人偷偷在森林裡練習。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人說得沒錯。",
        "unit_id": 105913,
        "voice": "vo_adv_1126003_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下認為這份心意雖然很了不起，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但妳是否太過求好心切了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊哈哈……",
        "unit_id": 112611,
        "voice": "vo_adv_1126003_023"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嗯，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我自己也很清楚。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "可是，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "因為自己心裡亂糟糟的情緒",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "讓我感到很焦慮。",
        "unit_id": 112611
    },
    {
