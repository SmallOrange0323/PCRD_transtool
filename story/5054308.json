[
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "怎、",
        "unit_id": 114411,
        "voice": "vo_adv_5054308_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "怎麼回事！？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那股",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不祥的氣息是！？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃，",
        "unit_id": 114511,
        "voice": "vo_adv_5054308_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "小心點。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n……那傢伙的強度，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "已經不是剛才可以比擬的了。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "為了重整態勢，暫時撤退也是方法之一……",
        "unit_id": 114611,
        "voice": "vo_adv_5054308_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不，",
        "unit_id": 114411,
        "voice": "vo_adv_5054308_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我不會撤退。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是讓它跑到蘭德索爾的大街上就不妙了。",
        "unit_id": 114511,
        "voice": "vo_adv_5054308_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們對它造成的傷害或許不大，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但只要累積起來應該就能重創它。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是啊，",
        "unit_id": 114411,
        "voice": "vo_adv_5054308_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "它不是戰勝不了的對手。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雖然是條困難重重的道路，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n但對有著深厚羈絆的我們而言，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒有辦不到的事！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳們兩個都決定戰鬥的話，我當然也會幫忙。",
        "unit_id": 114611,
        "voice": "vo_adv_5054308_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "防守就交給我吧。",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，",
        "unit_id": 114411,
        "voice": "vo_adv_5054308_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "攻擊的話……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們上吧。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果是和妳一起，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我有種什麼樣的敵人都能打倒的感覺呢。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "被妳這麼一說，",
        "unit_id": 114511,
        "voice": "vo_adv_5054308_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我就不得不回應妳的期待了呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "交給我吧！",
        "unit_id": 114511
    }
]