[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "流夏因為擊退妖刀的消息傳開，一躍成為鎮上的名人，\n不論走到哪裡都會有人向她搭話，流夏對此開始感到疲倦。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唉……",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_000"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "啊～！",
        "unit_id": 111,
        "voice": "vo_adv_1056007_001"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "是流夏耶～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "喂，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "表演一下咻啪啪啪揮刀的樣子嘛！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "笨～蛋。",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那可不是表演給人看的東西。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "下次再說吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "那個，流夏，",
        "unit_id": 511,
        "voice": "vo_adv_1056007_003"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "之前提過的那件事情，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "真的沒辦法嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那種事情請你找別人吧。",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也可以介紹認識的人給你。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過我現在正要去釣魚呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "啊～流夏！",
        "unit_id": 611,
        "voice": "vo_adv_1056007_005"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我終於找到妳了！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "關於妳跟我兒子的相親啊……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呃，我之前就說過不行啦……！",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦，小哥！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你怎麼這麼晚來！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來來，走吧走吧！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……真抱歉，",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓你陪我演戲。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "感覺我也",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "很久沒見到你了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "之前的擊退殺人魔……",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就是擊退妖刀那件事好像被傳了出去。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如你所見，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我一躍成為鎮上的知名人物。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "結果最近連不認識的人，",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也都會來找我搭話。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "剛剛跟我說話的人，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也是連名字都不知道……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我沒事。",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，謝謝你。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我不想再讓你擔心了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說起來，",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "為何只有我一個人被這樣吹捧呢？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "挺身而出的你，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "才應該是大家讚揚的對象啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "挑戰者",
        "words": "打擾了～！",
        "unit_id": 1111,
        "voice": "vo_adv_1056007_012"
    },
    {
        "type": "dialogue",
        "name": "挑戰者",
        "words": "您就是擊退殺人魔的流夏吧！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "挑戰者",
        "words": "\n請務必和我單挑一場……！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我才不要！",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要逃囉小哥！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "挑戰者",
        "words": "等、",
        "unit_id": 1111,
        "voice": "vo_adv_1056007_014"
    },
    {
        "type": "dialogue",
        "name": "挑戰者",
        "words": "等等我──！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "挑戰者",
        "words": "我好不容易才找到您的──！？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是夠了！",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_015"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "最近都是那種傢伙真受不了！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……延續剛剛的話題。",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "因為我出名了，最近想藉著打倒我，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n來提升自己名氣的傢伙越來越多了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "明明我啊，",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_017"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就只想悠悠哉哉地度日……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果是有煩惱的人來商量也就算了。",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可是像這樣無謂的打鬥和紛爭到底有什麼意義呢？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真那麼想讓人見識自己的實力，",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_019"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "去討伐魔物不就好了嗎。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你說是不是？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "太好了……",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真高興你了解。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "除了幫助他人以外，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是別叫我跟人戰鬥啊……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "謝啦。",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "其實我自己也很明白，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但忍不住就會去想這件事……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我也想早早跟這個煩惱",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "道別啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "多虧了現在這個情況，",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就算像這樣手上拿著釣具出門，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n也沒辦法悠哉釣魚……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且連午睡都辦不到。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，跟你聊了以後，",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "感覺稍微輕鬆了一點。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n總覺得一直受到你的幫忙。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "最近公會的人也都很忙，",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_024"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n沒有人有空聽我抱怨。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對了，",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "難得有機會，如果你不介意，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要不要讓我請你吃個飯？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n再聽我說點話吧。",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼……",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_026"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "終於可以放輕鬆了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我想要偶爾像這樣啊，",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_027"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n和你一起悠悠哉哉的度過。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說起來，",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我還沒有吃過",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這裡的鮮魚套餐呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n幫你點一樣的好不好？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不好意思～",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_029"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我要點餐……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳就是流夏？",
        "unit_id": 1211,
        "voice": "vo_adv_1056007_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……我就是，",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳呢？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不必多說了！",
        "unit_id": 1211,
        "voice": "vo_adv_1056007_032"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我要打倒妳，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "替哥哥報仇！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "報仇這話聽起來可是不太平靜呢。",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_033"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在受傷之前，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "乖乖回家比較好喔。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "給我住口！",
        "unit_id": 1211,
        "voice": "vo_adv_1056007_034"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我哥哥被你們抓起來了！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n哥哥因為私造魔法道具的罪刑，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "到現在都還被關在牢裡……！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……這麼說來，",
        "unit_id": 105611,
        "voice": "vo_adv_1056007_035"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "確實有這麼一回事呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過妳哥哥可是壞蛋喔。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "他是自作自受吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "的確哥哥他做了壞事……",
        "unit_id": 1211,
        "voice": "vo_adv_1056007_036"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "可是他對我和爸媽都很好！",
