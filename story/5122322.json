    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "朝我們這邊發動攻擊了……！？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "優花梨，",
        "unit_id": 126711,
        "voice": "vo_adv_5122322_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請冷靜下來看仔細一點。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那是",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "島鯨給我們看的幻影，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是我的闇影喔！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那麼，",
        "unit_id": 126811,
        "voice": "vo_adv_5122322_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個則是我的闇影……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "至於那邊，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是似似花的闇影！？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不是，",
        "unit_id": 126611,
        "voice": "vo_adv_5122322_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那是我的分身。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我、",
        "unit_id": 126711,
        "voice": "vo_adv_5122322_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我說似似花……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n現在場面很混亂，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可以請妳避免使用分身嗎……",
        "unit_id": 126711
    }
