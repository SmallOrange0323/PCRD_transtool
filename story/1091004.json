[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "靜流餵了{player}吃巧克力後，\n望著他高興的表情沉浸於幸福之中。"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵呵，",
        "unit_id": 109111,
        "voice": "vo_adv_1091004_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}弟弟果然很可愛呢。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能和{player}弟弟\n一起過情人節，感到很幸福喔。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哎呀，",
        "unit_id": 109111,
        "voice": "vo_adv_1091004_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "吃得太急了，噎到了嗎？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我去拿水過來，你稍等一下喔。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我看看……",
        "unit_id": 109111,
        "voice": "vo_adv_1091004_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n記得這裡應該有裝水的水瓶……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 109111,
        "voice": "vo_adv_1091004_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "找到了找到了！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "奇怪，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "水在發光？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "簡直就像是反射了太陽光一樣――",
        "unit_id": 109111
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "（……盯）",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}弟弟終於起床了！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "差不多到了該起床的時間，所以要來叫醒你，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不過睡臉太可愛，讓我看得入迷了〜",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一轉眼已經一小時了？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "其實今天要給{player}弟弟",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一個意外的驚喜！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "讓人很在意吧〜",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那你就快點換好衣服下樓吧。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我先過去等你！",
        "unit_id": 104931
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喂，{player}弟弟，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我在這裡喔〜",
        "unit_id": 104931
    },
    {
        "type": "still",
        "still": "109100401"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你總算下來了，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐等得要累死了啊。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "開玩笑啦〜",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "騙你的騙你的。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "其實我還在準備中。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你可以再等我一下下嗎？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……嗯？",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你為什麼要這樣子",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n盯著姐姐看呢？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦〜",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難道是看姐姐穿圍裙，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n讓你心動了嗎？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "該不會覺得",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我是你的新娘吧？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真可惜，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我是姐姐♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐現在呢，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n正在幫{player}弟弟做便當喔。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還差一點就完成了，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你要聽話的等喔！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯？　",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但你說我在做的是巧克力？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那當然囉！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n因為今天是情人節嘛。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "男孩子在學校裡，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n都會比較誰收到最多巧克力吧？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以姐姐要送給{player}弟弟",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n很〜多的巧克力呢。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在學校就算{player}弟弟沒有收到女孩子送的\n巧克力，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要有這些就不丟臉了吧？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你又說這種話來逞強了〜",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n難道是叛逆期到了？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是你這種個性實在很可愛呢〜",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "等你能收到很多巧克力的時候，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我就承認你是個能獨當一面的男孩，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在那之前就吃姐姐的巧克力長大吧！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊哈哈，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你真老實呢〜{player}弟弟。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n真不愧是姐姐的弟弟呢！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "老實的{player}弟弟真可愛呢。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}弟弟的魅力，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐非常了解的，所以不要緊喔！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你要一直是我最喜歡的{player}弟弟喔♪",
        "unit_id": 104931
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對了！　",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "早餐要吃的巧克力已經準備好了。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我放在桌子上，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你快去嚐嚐看吧。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還是說，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你想讓姐姐餵你吃啊？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……唔，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過實在是沒時間了。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "餵你吃這件事，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就等下次吧，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好嗎。",
        "unit_id": 104931
    },
    {
        "type": "background",
        "background": "510220"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "請吃這個巧克力〜。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "唔喔喔喔喔喔喔喔！　",
        "unit_id": 1,
        "voice": "vo_adv_1091004_027"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "謝謝你！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "\n加上老媽送的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "我今年收到兩個了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也送給你喔！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "謝、",
        "unit_id": 1,
        "voice": "vo_adv_1091004_029"
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "謝謝！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "\n謝謝你！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "\n太好了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "這樣今年就不是一個都沒收到了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還有你，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那位也是！　",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還有……",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……嗯，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這樣就全部的人都發過了吧。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有人沒拿到嗎？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "應該沒有吧――",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……啊，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "早安啊，{player}弟弟！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n來我的教室做什麼啊？　",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你一臉這樣想的表情呢。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看就知道了，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我是來給平日照顧{player}弟弟的同學們",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n送巧克力的喔。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "姐姐！！",
        "unit_id": 1,
        "voice": "vo_adv_1091004_034"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "\n謝謝妳，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "謝謝妳！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "多虧有妳，今年",
        "unit_id": 1,
        "voice": "vo_adv_1091004_035"
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "我總算不用自己買巧克力了……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_036"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能讓你們高興這樣最好了。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "當然我送各位的都是人情巧克力啦。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不過也都是姐姐親手做的呢。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "再來最後是……",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_037"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個給你，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是要送給{player}弟弟的本命巧克力！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你說明明早上已經收過了，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_038"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為什麼又送嗎？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為早上給你的是上午吃的份，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_039"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個巧克力是點心的份喔！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我會回去做晚餐的巧克力，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今天要早點回來喔♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還有，",
        "unit_id": 104931,
        "voice": "vo_adv_1091004_040"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "中午的巧克力我也追加帶來了！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "想吃的話我還有，不要客氣儘管說喔。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我最喜歡你了，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}弟弟。",
        "unit_id": 104931
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1091004_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗚哇〜",
        "unit_id": 190011,
        "voice": "vo_adv_1091004_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "靜流她真的很喜歡你耶……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你吃了那麼多巧克力，\n竟然沒有蛀牙嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1091004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "難得讓人很擔心你呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來……",
        "unit_id": 190011,
        "voice": "vo_adv_1091004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "靜流還真是個有趣的孩子呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖說偶爾會出現意料之外的舉動，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但一切都是因為她當你是家人，非常重視你喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1091004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你好像也接納了那孩子的行動，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果你們相處融洽那就行了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要再踏出一步的話，",
        "unit_id": 190011,
        "voice": "vo_adv_1091004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就需要你的勇氣了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只有這件事你要銘記在心。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開玩笑啦，",
        "unit_id": 190011,
        "voice": "vo_adv_1091004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次就先聊到這裡囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見啦――♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦？　",
        "unit_id": 109111,
        "voice": "vo_adv_1091004_048"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "睡著了？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是因為今天做了一整天的巧克力，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "太累了嗎？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊哈哈。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "話說回來",
        "unit_id": 109111,
        "voice": "vo_adv_1091004_049"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還真是不可思議的夢……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我竟然在",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}弟弟家裡做巧克力――",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而且",
        "unit_id": 109111,
        "voice": "vo_adv_1091004_050"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還讓他吃巧克力吃得很飽。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那不就是",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我今天沒能做到的事嗎……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵呵。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦，",
        "unit_id": 109111,
        "voice": "vo_adv_1091004_051"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難不成",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}弟弟也作了同樣的夢？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這樣啊〜",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "果然我們被命運給緊緊相連著呢♪",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼，",
        "unit_id": 109111,
        "voice": "vo_adv_1091004_052"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你在夢中感受到姐姐的愛了嗎？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今後姐姐會對你灌注更多愛情的！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然是辛苦的一天，不過在夢裡也達成了目標，\n靜流臉上露出了開朗的表情。"
    }
