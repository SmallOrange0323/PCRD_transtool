        "words": "哈啾～！　",
        "unit_id": 106611,
        "voice": "vo_adv_2012006_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哈啾～！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哈啾～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊嗚啊嗚……",
        "unit_id": 106611,
        "voice": "vo_adv_2012006_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n嘉夜夜。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "人家說不定感冒了耶。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這種天氣哪會有人感冒的啊。",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是不是有誰",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "偷偷在背後講祈梨的壞話嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "話說啊，",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要打噴嚏的話能不能給我轉過去呀。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n妳這樣口水不都噴到食物上了嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們是來擺攤的唷，",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可不能發生食物中毒之類的事件呀。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈～",
        "unit_id": 106611,
        "voice": "vo_adv_2012006_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對不……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈啾！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊啊，",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "鼻水！　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳鼻水都流下來了啦！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "欸呃呃……",
        "unit_id": 106611,
        "voice": "vo_adv_2012006_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不只是鼻水，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "都好像要噴出火來了……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n越是忍耐",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "鼻子就越是癢呀……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n哈啾、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈啾！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啾～！",
        "unit_id": 106611
    },
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哎呀呀，",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "祈梨的火",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "又把要賣的飯烤焦了啦！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "照這樣看來又要被老闆罵了啦……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘿～",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "現在有空嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "剛剛那爆炸是啥……？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗨──呵～☆　",
        "unit_id": 101711,
        "voice": "vo_adv_2012006_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這是『妳好』的意思唷～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳們倆，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是哪個公會的孩子呀？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可以問你們一些問題嘛～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊嗚！　",
        "unit_id": 106611,
        "voice": "vo_adv_2012006_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不認識的人！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好可怕……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n卡、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我知道啦。",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "祈梨妳躲在我後面。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有什麼話就和我",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "…",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "…",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳們兩個，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我好像在哪裡看過！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n在獸人居住區",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "做警備工作之類的",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "…",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "…",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那什麼？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是【哞哞自衛隊】唷。",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n若妳們沒做什麼壞事的話，我們也不會教訓妳們啦，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不用這麼害怕喔。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n本應維護和平的我們，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果反而讓大家不安，那可就本末倒置了呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳們倆，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那尾巴和嬌小的翅膀……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "難不成",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是龍族嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哇呀！",
        "unit_id": 106611,
        "voice": "vo_adv_2012006_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "被發現了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們的身分被人家給發現了啦，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該怎麼辦啊嘉夜夜！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是呀，",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_017"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們本來就沒有要隱藏什麼身分吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "正如妳所講的，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們是龍族的人唷。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那又怎麼了嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "欸欸！",
        "unit_id": 101711,
        "voice": "vo_adv_2012006_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n突然打斷妳們我也很不好意思，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但希望可以跟我說明一下～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "龍族是什麼？　",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我沒聽過那個名字呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "其實我也不是很懂啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只聽我媽她說過，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有這麼一群人們就是了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然口耳相傳說以前存在過，",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但大家都認為實際上是不存在的，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "似乎是非常稀有的獸人亞種唷。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在分類上也算是獸人的一種，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n所以才會和美美那群孩子們一樣，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "來幫忙開店的嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊啊，",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們在某個幫……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊不是，",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_023"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是在公會底下的基層做事的唷。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為上頭的命令，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天才心不甘情不願的在這工作的！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊嗚～……",
        "unit_id": 106611,
        "voice": "vo_adv_2012006_024"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我不想永遠過這樣的生活，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n總是被那個老闆使喚來使喚去的……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我是被老闆買下來的，所以就認了，",
        "unit_id": 106611,
        "voice": "vo_adv_2012006_025"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n可是嘉夜夜妳可以去過更自由的生活吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我怎可能會放著祈梨不管呢。",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_026"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我還算挺中意這種生活的啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且畢竟同胞不多嘛，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不互相關照一下怎麼行呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈嗚。",
        "unit_id": 106611,
        "voice": "vo_adv_2012006_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "果然嘉夜夜，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n雖然長相和舉止都和路邊的小混混沒兩樣，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但實際上卻是個好孩子呀……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～？　",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "剛剛說了什麼幫的嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然搞不懂妳們在說什麼……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但如果妳們有困擾的事，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不論何時都可以來找我們【哞哞自衛隊】幫忙的唷。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯，",
        "unit_id": 101711,
        "voice": "vo_adv_2012006_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們是有煩惱的獸人的好夥伴唷～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "非常謝謝妳們的好意，",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_030"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但就免了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果被知道我們和【哞哞自衛隊】有什麼交流的話又要挨罵了呀，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可以的話就不要再管我們了就好……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……？",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_031"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？　",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_032"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼了？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "大家小心！",
        "unit_id": 106511,
        "voice": "vo_adv_2012006_033"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n好像有什麼不太妙的東西往這邊過來了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不太妙？",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_034"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_035"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哇呀，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那是什麼？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對邊街旁的房子，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "竟然一棟棟被摧毀了！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是哪來的蠢蛋，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為祭典嗨過頭然後打起架來了嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真琴妳看，",
        "unit_id": 101711,
        "voice": "vo_adv_2012006_036"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好像有誰被轟過來了呀～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嘎啊啊啊！？",
        "unit_id": 100211,
        "voice": "vo_adv_2012006_037"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優衣～！？",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_038"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼了，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "究竟發生什麼事了？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這不是悠哉問問題的時候了～",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總之先接住她再說啦！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "歐拉～！　",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_039"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "差一點呀！",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_040"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳沒事吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優衣？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好險呀～！",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_041"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n若照剛剛那個速度直接撞到地板或牆壁上，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n可是會扁掉的唷！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊、",
        "unit_id": 100211,
        "voice": "vo_adv_2012006_042"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊嗚嗚……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真琴？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦！",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_043"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是真琴唷，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是妳那靠得住的童年玩伴唷！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "發生什麼事了啊，優衣",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳被誰襲擊了嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那、",
        "unit_id": 100211,
        "voice": "vo_adv_2012006_044"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不知道該怎麼說明，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我就連",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "被攻擊的理由",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也不知道呀。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "………！",
        "unit_id": 100211,
        "voice": "vo_adv_2012006_045"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "危險呀，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真琴！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦哇！？",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_046"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n剛才那是什麼，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有個像破壞光線一樣的東西穿飛過去了唷！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊～",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為受到波及，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以獸人們的攤販也被轟飛了好幾個呀！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那是什麼鬼呀，",
        "unit_id": 104311,
        "voice": "vo_adv_2012006_047"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n該不會真有什麼魔物",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "闖到城裡面來了嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那不是魔物唷……",
        "unit_id": 100211,
        "voice": "vo_adv_2012006_048"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n是一位",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可以對話的，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "人類女孩子喔。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n但不知道為什麼，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "她好像",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "非常憎恨我的樣子。",
        "unit_id": 100211
    }
]