    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n{player}也去海邊放鬆一下吧！",
        "unit_id": 108011
    },
    {
        "type": "background",
        "background": "500281"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊～",
        "unit_id": 107911,
        "voice": "vo_adv_5005003_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "今天也玩得好盡興！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好開心啊喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要回去珠希宮殿了喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也對，",
        "unit_id": 108011,
        "voice": "vo_adv_5005003_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "多虧有那些錢幣讓貓咪們好好地聽從我們的話，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n才能過起這麼棒的生活……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "被貓咪們包圍的「珠希宮殿」……",
        "unit_id": 108011,
        "voice": "vo_adv_5005003_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n全年無休的特賣會中的特賣會……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n還有專屬我們的訓練場",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "以及休閒設施……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這裡正是樂園啊喵～",
        "unit_id": 107911,
        "voice": "vo_adv_5005003_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n一切都比想像的還順利，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真是不可思議的地方喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不知道是不是錯覺，",
        "unit_id": 108011,
        "voice": "vo_adv_5005003_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "魔物最近好像也變溫順了樣子呢！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n{player}不是也",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "希望過著和平的生活嗎？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過真的……",
        "unit_id": 108011,
        "voice": "vo_adv_5005003_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "以前的生活到底算什麼呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n待在這裡的話，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就能夠過著喜歡的生活……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "說真的，",
        "unit_id": 107911,
        "voice": "vo_adv_5005003_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我開始覺得就算不離開這座島也沒關係了喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就是啊。",
        "unit_id": 108011,
        "voice": "vo_adv_5005003_015"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "在這裡生活還比較好……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "{player}不覺得嗎？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我是認真的！",
        "unit_id": 108011,
        "voice": "vo_adv_5005003_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你不也覺得這裡的生活比較舒適嗎？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我懂喵～",
        "unit_id": 107911,
        "voice": "vo_adv_5005003_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就算不用工作也沒關係喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n想在這裡悠～閒地什～麼都不去想的度日喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "像這樣永遠在這裡，",
        "unit_id": 108011,
        "voice": "vo_adv_5005003_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "三人一起感情很好地過日子……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這樣不是很幸福的生活嗎？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真是很棒的想法喵～！",
        "unit_id": 107911,
        "voice": "vo_adv_5005003_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果我們是這座島的女王的話，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n{player}就變成國王了喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈！",
        "unit_id": 107911,
        "voice": "vo_adv_5005003_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "講到要結婚還太早了啦～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那樣好像也不是什麼壞事～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "畢竟在這裡什麼都很自由喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈！",
        "unit_id": 107911,
        "voice": "vo_adv_5005003_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒問題啦喵～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n既然現在能過得這麼開心，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "順著這個趨勢走的話，\n一定全都能順利進行喵～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就是啊。",
        "unit_id": 108011,
        "voice": "vo_adv_5005003_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為這裡不是蘭德索爾嘛。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我們能，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "過著喜歡的生活，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是因為這裡是夢之島嘛！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們要忘記過去的事情，",
        "unit_id": 108011,
        "voice": "vo_adv_5005003_023"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "在新的世界活下去唷……！",
        "unit_id": 108011
    },
    {
        "type": "background",
        "background": "500070"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "同時另一方面，在【墨丘利財團】的公會小屋裡……"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "優花梨，",
        "unit_id": 103211,
        "voice": "vo_adv_5005003_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n還沒有接到",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "來自珠希和美冬",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "的聯繫嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯，",
        "unit_id": 103411,
        "voice": "vo_adv_5005003_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "什麼都沒有……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n果然，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可能是被捲入什麼事件裡了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就是啊……",
        "unit_id": 103211,
        "voice": "vo_adv_5005003_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "一定是在瑪爾傑海岸，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n發生什麼事情了呢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "在海上下落不明的話，",
        "unit_id": 103411,
        "voice": "vo_adv_5005003_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n該不會，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "已經來不及……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "什麼的……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "等一下，",
        "unit_id": 103211,
        "voice": "vo_adv_5005003_028"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可以不要開這種玩笑話嗎！？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那兩位",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "才沒這麼柔弱呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也、",
        "unit_id": 103411,
        "voice": "vo_adv_5005003_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也是呢……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不小心都往負面的事想。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n說不定，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "正漂流到了某座島優雅地度著假呢！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嗯，",
        "unit_id": 103211,
        "voice": "vo_adv_5005003_030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果是那樣也令人擔心呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n希望她們不要玩過頭才好！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總之……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們也出門去探聽她們的消息吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，秋乃和優花梨，\n為了尋找珠希和美冬前往了瑪爾傑海岸。"
    }
]