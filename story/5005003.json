    {
        "type": "dialogue",
        "name": "旁白",
        "words": "透過珠希做的鯛魚燒，\n貓咪們間互通的區域貨幣「貓幣」開始流通，\n現在，珠希和美冬的王國極盡繁榮地發展中。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊──",
        "unit_id": 107911,
        "voice": "vo_adv_5005003_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "把我的銅像放更後面點就可以了喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "喵──",
        "unit_id": 1711,
        "voice": "vo_adv_5005003_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好，",
        "unit_id": 107911,
        "voice": "vo_adv_5005003_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "辛苦了喵──",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這是貓幣喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "喵──",
        "unit_id": 1711,
        "voice": "vo_adv_5005003_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "太好了喵──！",
        "unit_id": 107911,
        "voice": "vo_adv_5005003_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我的銅像終於也建好了喵──！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚喵～",
        "unit_id": 107911,
        "voice": "vo_adv_5005003_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "貓果然很棒喵～♪",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n透過金錢的流動不僅能讓牠們主動幫忙，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "甚至也能變成勞動力……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n多虧如此",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們即使不工作也是這座島的女王喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為心情很好，",
        "unit_id": 107911,
        "voice": "vo_adv_5005003_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我再出去玩一下喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，",
        "unit_id": 108011,
        "voice": "vo_adv_5005003_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "珠希！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真是的……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "算了！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我也要去新的訓練場鍛鍊一下了！",
