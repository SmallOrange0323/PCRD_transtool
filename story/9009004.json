[
    {
        "type": "background",
        "background": "502110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在吉歐‧格黑納的居住區──"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "吶，烏爾姆，",
        "unit_id": 127712,
        "voice": "vo_adv_9009004_000"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "萊拉耶爾殿下應該",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n會更喜歡我剛才找到的",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "「黃金岩漿糖漿」吧？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那可是吉歐‧提格尼亞所沒有的，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "永不冷卻的糖漿呢……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "不過",
        "unit_id": 127812,
        "voice": "vo_adv_9009004_001"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "味道就只是略酸的檸檬味嘛。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "比起那個，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "去毒的植物魔物醃製物更好吧。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "什、",
        "unit_id": 127712,
        "voice": "vo_adv_9009004_002"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "什麼去毒的魔物呀！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "怎麼能夠把那種東西拿給萊拉耶爾殿下呢！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n我們要找更安心、安全的東西……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "咦～",
        "unit_id": 127812,
        "voice": "vo_adv_9009004_003"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "但是，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "一般常見的東西又沒什麼意思。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "偶爾也要冒險一下吧？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "雖然",
        "unit_id": 127712,
        "voice": "vo_adv_9009004_004"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "是那樣沒有錯！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "但是，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "也不代表可以挑一些奇怪的東西呀！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "得要好好考慮才行……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "所以我才說要分頭行動嘛。",
        "unit_id": 127812,
        "voice": "vo_adv_9009004_005"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我們各自去買適合萊拉耶爾殿下的紀念品，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n再回到這裡集合。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "那麼",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "晚點見了，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "老姊。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "啊，",
        "unit_id": 127812,
        "voice": "vo_adv_9009004_006"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "騎士先生～",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "老姊就拜託你了～",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n她要是不小心走丟了會很麻煩的。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "慢著！",
        "unit_id": 127712,
        "voice": "vo_adv_9009004_007"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "說我會走丟是什麼意思呀！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……唔。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "她走掉了……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……好。",
        "unit_id": 127712,
        "voice": "vo_adv_9009004_008"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "也真是的……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n我是絕對不會買那些奇怪的東西的！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "這就是這個世界的蘋果……",
        "unit_id": 127712,
        "voice": "vo_adv_9009004_009"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "熱蘋果！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n遠比吉歐‧提格尼亞的蘋果",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "要來得更大更紅！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……啊，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不過看起來好像很辣……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "咦，",
        "unit_id": 127812,
        "voice": "vo_adv_9009004_010"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "老姊。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "這個怎麼樣？",
        "unit_id": 127712,
        "voice": "vo_adv_9009004_011"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "用壓力鍋油炸穀物製成的點心！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n除了葛粉帶有的輕微甜味……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n還稍微加了",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "一點香料。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "咦，",
        "unit_id": 127812,
        "voice": "vo_adv_9009004_012"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "老姊。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "請給我這個～",
        "unit_id": 127812,
        "voice": "vo_adv_9009004_013"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n中間這個",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "有點發光的星形水果。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那個，",
        "unit_id": 127712,
        "voice": "vo_adv_9009004_014"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "請給我正中間的",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "這個。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "發出微微的光芒正好呢。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德、烏爾姆",
        "words": "「啊，烏爾姆。」\n「咦，老姊。」",
        "unit_id": 1,
        "voice": "vo_adv_9009004_015"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "妳用不著跟過來吧。",
        "unit_id": 127812,
        "voice": "vo_adv_9009004_016"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我才沒有跟著妳呢！",
        "unit_id": 127712,
        "voice": "vo_adv_9009004_017"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不對，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆妳才是不要學我啦。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我是自己選的。",
        "unit_id": 127812,
        "voice": "vo_adv_9009004_018"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "不過……",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德、烏爾姆",
        "words": "就是說啊……",
        "unit_id": 1,
        "voice": "vo_adv_9009004_019"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我、",
        "unit_id": 127712,
        "voice": "vo_adv_9009004_020"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我覺得不管是哪個，萊拉耶爾殿下都會很高興的……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "那當然。",
        "unit_id": 127812,
        "voice": "vo_adv_9009004_021"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n這可是我們兩個人挑選的啊？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "妳也",
        "unit_id": 127712,
        "voice": "vo_adv_9009004_022"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真是的……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然琳德說出這句話時有些傻眼，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但總覺得她的表情很柔和，看起來很愉快。"
    }
]