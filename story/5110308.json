[
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔喔……",
        "unit_id": 125014,
        "voice": "vo_adv_5110308_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這傢伙的等級",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不同於以往的魔物呢……！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是說啊，",
        "unit_id": 124811,
        "voice": "vo_adv_5110308_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且它看似沒有想要放過我們的樣子。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "說起來，",
        "unit_id": 124911,
        "voice": "vo_adv_5110308_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "它原本就不是可以輕易擺脫的對手。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……我說啊。",
        "unit_id": 125014,
        "voice": "vo_adv_5110308_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜、望",
        "words": "駁回。",
        "unit_id": 1,
        "voice": "vo_adv_5110308_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我、",
        "unit_id": 125014,
        "voice": "vo_adv_5110308_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我什麼都還沒說耶！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不用妳說，我們也都知道。",
        "unit_id": 124811,
        "voice": "vo_adv_5110308_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "矛依未，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳打算自己一個人迎戰對吧？",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "然後，",
        "unit_id": 124911,
        "voice": "vo_adv_5110308_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "讓我們可以趁機脫逃是吧？",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是個蠢蛋……",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔……",
        "unit_id": 125014,
        "voice": "vo_adv_5110308_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可、",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是……",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要不然這下該怎麼辦？",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "很簡單啊。",
        "unit_id": 124911,
        "voice": "vo_adv_5110308_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們一起擊倒他，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣就行了。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖說是臨時湊成的，",
        "unit_id": 124811,
        "voice": "vo_adv_5110308_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但我們早已像支小隊了吧？",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳要信任",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……",
        "unit_id": 125014,
        "voice": "vo_adv_5110308_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抱歉。",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我差點就做出了與壞蛋作風不符的差勁選擇。",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "望！",
        "unit_id": 125014,
        "voice": "vo_adv_5110308_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘉夜！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "跟著我這個大壞蛋諾維姆大人一起上吧！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n讓膽敢阻擋在我們前面的傢伙，",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在地獄裡悔不當初！",
        "unit_id": 125014
    }
]