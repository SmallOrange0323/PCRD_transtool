[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105811,
        "voice": "vo_adv_0000134_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這好像就是最後的試練了唷！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但也不愧說是最後的試煉，",
        "unit_id": 106011,
        "voice": "vo_adv_0000134_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看起來感覺相當的不妙呢……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所謂是似而非，",
        "unit_id": 105911,
        "voice": "vo_adv_0000134_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此之事，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "更使人深感恐懼呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟很危險嘛，",
        "unit_id": 105811,
        "voice": "vo_adv_0000134_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿還是待在後頭的話會比較好吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您真愛說笑呢，",
        "unit_id": 105911,
        "voice": "vo_adv_0000134_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "至今以來所走過的條條道路，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可並非是虛假不實的妄言。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此的試煉，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也必定能夠跨越給您見識。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真拿妳沒辦法呀。",
        "unit_id": 106011,
        "voice": "vo_adv_0000134_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n既然可蘿仔都把話說得這麼絕啦，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就讓妳也算上我一個吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就讓我們跨過這場戰鬥，",
        "unit_id": 105811,
        "voice": "vo_adv_0000134_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "入手那強大的力量吧！",
        "unit_id": 105811
    }
]