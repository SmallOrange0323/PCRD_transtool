[
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "――由於霸瞳皇帝在蘭德索爾之中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n解放了無數的魔物與闇影。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "乘坐於飛空艇內，且飛行在蘭德索爾上空進行俯瞰的【慈樂之音】，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在{player}他們的請求下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n對分散在城內各處的公會們，進行了整合戰力的誘導……"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "――如此，",
        "unit_id": 104211,
        "voice": "vo_adv_2014098_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "便是至今的來龍去脈。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n而{player}一行人，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在正為了打破尤絲蒂亞娜……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是為了打破霸瞳皇帝的野心，而正在採取行動。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而我們則是希望能委託",
        "unit_id": 104211,
        "voice": "vo_adv_2014098_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "【純白之翼】的各位，能夠在他們",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所無法觸及的城鎮外圍，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "進行闇影與魔物的撲滅。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "誘導的部分，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就包在我們【慈樂之音】的身上！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "感激不盡！",
        "unit_id": 105311,
        "voice": "vo_adv_2014098_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我等一行人，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然也正在和魔物戰鬥……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但這騷動實在太大了，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n導致我們也不知道",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "到底該從哪裡下手才好！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咕呵呵呵……",
        "unit_id": 104511,
        "voice": "vo_adv_2014098_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "雖然你們不能對城裡的其他人出手……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n但如果是空花的話，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你們想要怎麼下手都隨便你們唷……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "來嘛，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "魔物們～♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 104211,
        "voice": "vo_adv_2014098_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不好意思。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n不僅是魔物，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "潛藏在各處的闇影也希望妳們能一同處理。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他們好像",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對敵人來說是情報來源的樣子……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "收到！",
        "unit_id": 105311,
        "voice": "vo_adv_2014098_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n那麼【慈樂之音】唷，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "與我等一同並肩作戰吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "馬上，",
        "unit_id": 105311,
        "voice": "vo_adv_2014098_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就有新的敵人了嗎！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n那就放馬過來吧……！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "七七香‧∞‧爆轟――！",
        "unit_id": 1,
        "voice": "vo_adv_2014098_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "天冥風哭雷陣掌――！",
        "unit_id": 1,
        "voice": "vo_adv_2014098_008"
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗚哇啊啊―～～～！？",
        "unit_id": 105311,
        "voice": "vo_adv_2014098_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "哇哈啊―～～～♪",
        "unit_id": 104511,
        "voice": "vo_adv_2014098_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咕，",
        "unit_id": 105311,
        "voice": "vo_adv_2014098_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼回事啊……！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n那爆炸是怎樣……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哈～哈哈哈！",
        "unit_id": 100911,
        "voice": "vo_adv_2014098_012"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n由於我們的『最強究極殲滅魔法』，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這附近的魔物全部都被",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "轟到虛無的彼方去了唷！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我就想大概這樣最快了嘛！",
        "unit_id": 101311,
        "voice": "vo_adv_2014098_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們倆果不其然，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是理論上最強",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "的呢☆",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳們幾個，",
        "unit_id": 105611,
        "voice": "vo_adv_2014098_014"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能這麼積極是不錯啦……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不覺得妳們好像也把無辜的人都轟飛了嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105111,
        "voice": "vo_adv_2014098_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵呵呵呵……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不管是這裡還是那裡，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "都有很多實驗品呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我這隻『單眼』，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "都開始迫不及待了呢……♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎……",
        "unit_id": 102711,
        "voice": "vo_adv_2014098_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就盡是一群雜魚魔物，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "到處在閒逛。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "若我那命中注定之人出了什麼閃失，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "可饒不了你們唷……？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個那個……",
        "unit_id": 104211,
        "voice": "vo_adv_2014098_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "【暮光流星群】的人們，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n應該是妳負責接洽的對吧……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對、",
        "unit_id": 102911,
        "voice": "vo_adv_2014098_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對不起呀，千歌！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但是這些人，根本就不聽人說話啊！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這幾位是……",
        "unit_id": 104511,
        "voice": "vo_adv_2014098_019"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "【暮光流星群】？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是為了找尋『暮光之都』而進行活動的，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n相當「不妙」的一群人呢～。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來如此……",
        "unit_id": 105311,
        "voice": "vo_adv_2014098_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也有聽過傳聞呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n她們幾個，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就是在黑社會中也頗有名聲的公會成員們嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔呣……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "聽著，",
        "unit_id": 105311,
        "voice": "vo_adv_2014098_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "【暮光流星群】唷！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我等【純白之翼】，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n擁有各位所尋找的，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "關於『暮光之都』的情報！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "若各位願意協助我等，",
        "unit_id": 105311,
        "voice": "vo_adv_2014098_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "一同將魔物與闇影們擊破的話，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n就將情報給妳們！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n如何！？　",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不來場交易嗎！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦？",
        "unit_id": 104511,
        "voice": "vo_adv_2014098_023"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n莫妮卡，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我們手中有那麼稀有的情報嗎～？　",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊啊，",
        "unit_id": 105311,
        "voice": "vo_adv_2014098_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這個嘛……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "現在的話連個影子都沒有。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但若是說有什麼讓她們聽話的方法，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "除了這個之外我也想不到了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是情急下",
        "unit_id": 104511,
        "voice": "vo_adv_2014098_025"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "脫口而出的啊～",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
