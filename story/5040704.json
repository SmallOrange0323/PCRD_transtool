[
    {
        "type": "background",
        "background": "500997"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼……",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這到底是怎麼一回事啊……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我已經筋疲力盡了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n還好最後有趕跑……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "看那個大小，",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "牠應該是老鼠的老大吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "既然已經把老大趕跑了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "應該不會再有事了吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我希望不會再有事了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這些孩子們……",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "太好了～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n完全沒有一點損傷。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯？　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎麼感覺好像比剛剛更有光澤了？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這東西熟成有這麼快嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "算了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我也在短時間內趕老鼠趕到得心應手了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這些孩子們會突然熟成也沒什麼好奇怪的吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不知道",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是不是心理作用……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "感覺聞起來也變得更好吃了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真奇怪。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "之前明明完全比不上橡子的說。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "的確能認同印有伊麗莎白牧場標記的產品就會受歡迎這件事呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n真陽太厲害了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我再次對妳刮目相看了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為了要回應真陽的期待，",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我要繼續這樣保護起司……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那裡怎麼有個洞。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "難不成是老鼠窩！？　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是從這裡跑出來的嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～真是的！　",
        "unit_id": 102611,
        "voice": "vo_adv_5040704_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這不就表示等一下又會有老鼠跑出來嗎！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好啊！　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不管來幾次我都會擊退你們的！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n放馬過來吧！！",
        "unit_id": 102611
    }
]