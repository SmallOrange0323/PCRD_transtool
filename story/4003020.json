[
    {
        "type": "background",
        "background": "501970"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "煩死了，",
        "unit_id": 107811,
        "voice": "vo_adv_4003020_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快點倒下啦！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這個大塊頭大叔，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是想打多久啊～！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！",
        "unit_id": 107611,
        "voice": "vo_adv_4003020_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱、",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請等一下。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對方",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這、",
        "unit_id": 107511,
        "voice": "vo_adv_4003020_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是在拍手",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吧？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n該不會",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是在誇獎我們？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺有點不好意思呢～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊？",
        "unit_id": 107811,
        "voice": "vo_adv_4003020_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞什麼嘛，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在才說這個……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算你這樣講，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在把你大卸八塊以前，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我可沒有停手的打算──",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 107611,
        "voice": "vo_adv_4003020_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈們代為傳達說……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「此番戰鬥",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "妳們表現相當精彩，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我要給妳們獎賞。」",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……海中之王是這麼說的。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──我改變主意了，",
        "unit_id": 107812,
        "voice": "vo_adv_4003020_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好，就聽聽他想說什麼吧。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n既然要送我們東西，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那倒是能勉為其難地收下。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐",
        "unit_id": 107612,
        "voice": "vo_adv_4003020_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘴巴上雖然這麼說，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但尾巴卻很開心似地搖個不停，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是可愛……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳妳妳、",
        "unit_id": 107812,
        "voice": "vo_adv_4003020_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳很煩耶！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這樣搖是想讓對手大意！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是我",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "故意的！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也、",
        "unit_id": 107512,
        "voice": "vo_adv_4003020_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也就是說接下來是",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "領獎時間嗎！？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "──國王陛下！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想要吃海鮮吃到飽！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果要給我們獎賞，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請務必送我們食物！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂、",
        "unit_id": 107812,
        "voice": "vo_adv_4003020_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "白癡佩可，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳在講什麼啦！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳要吃的我再抓給妳，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在先選財寶──",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "選財寶又不能拿來吃！",
        "unit_id": 107512,
        "voice": "vo_adv_4003020_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "經過剛剛的惡鬥，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我肚子已經餓扁了……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且",
        "unit_id": 107512,
        "voice": "vo_adv_4003020_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐有說過，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n財產贈與要辦很多手續，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃東西只要撥預算就好了！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然我不太清楚是什麼意思，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但總之好像比較划算！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 107812,
        "voice": "vo_adv_4003020_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓人很難反駁！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳腦袋到底是好還是不好啦！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩、",
        "unit_id": 107612,
        "voice": "vo_adv_4003020_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在妳們爭論的時候……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n已經由在下",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "收下獎賞了……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是食物嗎！？",
        "unit_id": 107512,
        "voice": "vo_adv_4003020_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是財寶吧！？",
        "unit_id": 107812,
        "voice": "vo_adv_4003020_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 107612,
        "voice": "vo_adv_4003020_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像是個有裝飾的……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "小盒子。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "上頭的裝飾相當別緻。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～",
        "unit_id": 107812,
        "voice": "vo_adv_4003020_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看它的大小，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該不是什麼金銀財寶吧。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且不管是它的外觀，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是贈與者，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都讓人有不好的預感……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不、",
        "unit_id": 107512,
        "voice": "vo_adv_4003020_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是吃的嗎……？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不對，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "食物還有可能放在裡面……！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快打開看看吧！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等、",
        "unit_id": 107812,
        "voice": "vo_adv_4003020_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "絕對不准打開！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這種故事我在書上看過……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是打開了，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "通常都不會有好下場！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎、",
        "unit_id": 107512,
        "voice": "vo_adv_4003020_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼這樣……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n偷偷看一下裡面也不行嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只是確認一下裡面是不是吃的而已……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別再想吃的了啦！",
        "unit_id": 107812,
        "voice": "vo_adv_4003020_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳要是變成慢吞吞的老太婆我可不管喔！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好了好了，",
        "unit_id": 107612,
        "voice": "vo_adv_4003020_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "妳們兩位……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難得海中之王陛下親自贈送了獎賞，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下們就心懷感激地收下，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "先在此告辭吧。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈們",
        "unit_id": 107612,
        "voice": "vo_adv_4003020_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好心地告訴了在下，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這附近有上升流，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要從那裡往上游，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很快就能抵達海面了。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也好，",
        "unit_id": 107812,
        "voice": "vo_adv_4003020_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趕快離開",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種地方吧。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n況且我的水中呼吸魔法也快失效了。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…走了，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要回去囉。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚，",
        "unit_id": 107512,
        "voice": "vo_adv_4003020_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明是吃遍之旅，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "結果卻什麼也沒吃到……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以咬著妳的尾巴嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣說不定可以減輕一點飢餓感……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我最好是會答應啦！",
        "unit_id": 107812,
        "voice": "vo_adv_4003020_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我的尾巴可不是魷魚乾！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵……",
        "unit_id": 107612,
        "voice": "vo_adv_4003020_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海中之王陛下。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下等人",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就先告辭了。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……歡迎再來玩，",
        "unit_id": 107612,
        "voice": "vo_adv_4003020_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是嗎？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果有機會的話，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下們一定會再來的。",
        "unit_id": 107612
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──呼～",
        "unit_id": 106012,
        "voice": "vo_adv_4003020_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吃得好飽。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n感覺好像把這輩子會吃的海鮮都吃完了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚼嚼……",
        "unit_id": 105812,
        "voice": "vo_adv_4003020_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咕嚕。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳已經吃飽了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還吃得下！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳不要的話我就吃掉囉♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106012,
        "voice": "vo_adv_4003020_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把我的螺肉還來！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那是我要留到最後吃的！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我個性可沒那麼收斂，吃了一輩子份的海鮮就滿足了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105913,
        "voice": "vo_adv_4003020_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請放心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這裡",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有追加的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海鮮拼盤。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好耶♪",
        "unit_id": 105812,
        "voice": "vo_adv_4003020_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n嘿嘿，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒想到打開盒子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "裡面竟然會不斷地冒出海鮮……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真的是對海中之王",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感激不盡！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "回程路上妳不小心打開盒子的時候，",
        "unit_id": 106012,
        "voice": "vo_adv_4003020_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我還以為完蛋了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既是財寶，",
        "unit_id": 105913,
        "voice": "vo_adv_4003020_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是食物……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海中之王陛下的思慮真是周到呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n想必是這樣高尚的品德，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才讓精靈們",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼仰慕吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啊，",
        "unit_id": 106012,
        "voice": "vo_adv_4003020_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙還滿通情達理的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這生魚片口感真奇怪，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是什麼魚啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，",
        "unit_id": 105913,
        "voice": "vo_adv_4003020_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也不太清楚。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n硬要給個名稱的話──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就叫長腳魚的生魚片吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是喔～",
        "unit_id": 106012,
        "voice": "vo_adv_4003020_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "長腳的魚啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……長腳的魚？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳剛剛",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說魚長腳！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105913,
        "voice": "vo_adv_4003020_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那種魚的腳十分修長美麗。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可能是因為在海底生活，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比起長鰭，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n長腳會比較方便吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以說是生命的奧妙。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來如此……",
        "unit_id": 106012,
        "voice": "vo_adv_4003020_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才怪！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最好是這樣！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那個海中之王",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底送了什麼鬼東西啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還滿喜歡它的口感的說～",
        "unit_id": 105812,
        "voice": "vo_adv_4003020_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留妳不喜歡的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那我就吃掉囉♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好啦，",
        "unit_id": 106012,
        "voice": "vo_adv_4003020_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "隨便妳了啦……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "王族果然",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都是些怪人。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "下次遇見那個海中之王，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我一定不放過他！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105913,
        "voice": "vo_adv_4003020_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說得也是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "下次如果有機會見面，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n再帶些特別的回禮前去拜訪吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會用心準備的♪",
        "unit_id": 105913
    }
]