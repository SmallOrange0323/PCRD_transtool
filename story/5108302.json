        "voice": "vo_adv_5108302_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然是神，就不能再稍微自制一點嗎～？",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總之，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要再款待祂一次了，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "深月、",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "美里！",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "知道了。",
        "unit_id": 124711,
        "voice": "vo_adv_5108302_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這次再更猛烈地",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "款待祂一下吧……！",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼我也",
        "unit_id": 124511,
        "voice": "vo_adv_5108302_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "再款待得狠心一點吧。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……妳們是在說款待吧？",
        "unit_id": 124611,
        "voice": "vo_adv_5108302_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n是在說接待客人的事吧？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "接招吧──！\n吃我這一記！",
        "unit_id": 1,
        "voice": "vo_adv_5108302_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呃、",
        "unit_id": 124611,
        "voice": "vo_adv_5108302_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那個……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對了！",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "為了讓來場的客人們不要誤會，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我在此說明一下，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n這只是本旅館在進行款待，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "敬請見諒……♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……嗯呵呵♪",
