    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n那位神明大人",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "又在作亂了耶……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀……",
        "unit_id": 124611,
        "voice": "vo_adv_5108302_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "看來是心情又好過頭了呢。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是的～",
