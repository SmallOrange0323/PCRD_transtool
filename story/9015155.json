[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那就是這次",
        "unit_id": 105911,
        "voice": "vo_adv_9015155_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【公會管理協會】\n所委託要討伐的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魔物――地獄獵犬。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又出現了很驚人的魔物呢～☆",
        "unit_id": 105811,
        "voice": "vo_adv_9015155_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "身體有半邊是骨頭，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣根本就不知道牠是活著還是死了耶！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然說因為牠在這邊作亂的關係，讓溫泉小鎮的人感到十分困擾沒錯，",
        "unit_id": 106011,
        "voice": "vo_adv_9015155_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但【公會管理協會】這次的委託也太誇張了吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是不是把我們誤會成什麼",
        "unit_id": 106011,
        "voice": "vo_adv_9015155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n武鬥派公會的討伐部隊之類的啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總之，",
        "unit_id": 105911,
        "voice": "vo_adv_9015155_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為主人看起來一副很熱的樣子，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n趕快去打倒那隻魔物吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要上了！",
        "unit_id": 105911
    }
]