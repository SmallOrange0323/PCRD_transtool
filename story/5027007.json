    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "比老大生氣時還要恐怖。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對不起啦。",
        "unit_id": 106511,
        "voice": "vo_adv_5027007_029"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一不小心氣到失去理智了。",
