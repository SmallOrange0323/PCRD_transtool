    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "　",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那孩子從遺跡蒐集到的出土文物喔？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n按照現在這個世界的歷史，",
