        "voice": "vo_adv_5027007_024"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我已經都打點好了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒問題。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "反正，很快他們",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就會再來委託我們艾爾皮斯島的工作的。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畢竟『我們』可以暫時趕走",
        "unit_id": 106711,
        "voice": "vo_adv_5027007_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那些盤據在城裡的地痞流氓，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n對王宮和管理協會來說，",
        "unit_id": 106711
    },
