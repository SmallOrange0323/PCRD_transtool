[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而後，在某日午後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n黑鐵鎧甲佇立於蘭德索爾王宮城門前。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有兩個人影再度集結到她面前。"
    },
    {
        "type": "still",
        "still": "502700001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "茉莉團員",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "和小智姐",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一同回歸了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳們回來啦，",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小智、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "茉莉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n沒事就好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n事不宜遲，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可以請妳們先報告一下調查【龍族巢穴】的結果嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是。",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "船隊的成員，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "幾乎都是幫派份子跟品行不良的傢伙。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這次的『開拓』",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "並非是以幫派的立場進行，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n而是【龍族巢穴】原本的公會活動。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過竟然能讓幫派分子協助公會的工作",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真是做了件厲害的事呢，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "帆稀……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "她們在找的是",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "遺跡還有",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沉睡在遺跡裡的某樣東西……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但我還沒有清楚掌握",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "她們打算要如何使用。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然之前的情報是說那座『島』並沒有文明存在過的跡象，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但從她們的說法聽來，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "似乎那裡曾有過遺跡的樣子。",
        "unit_id": 104711
    },
    {
        "type": "still",
        "still": "502700701"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "的確有個遺跡！",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還有",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有個",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很像龍的生物在那裡！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "對了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個人也跟她們在一起！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n總覺得",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "他們好像很熟的樣子。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣啊？",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這倒是挺有意思的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "正確來說",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "應該是遺跡的殘骸",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "，還有就是",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "像龍一般的生物。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那個『島』恐怕無法以一般的方法來處理。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "難怪連管理協會都難以應付。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "比起這個――",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "龍人族更加危險……",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳想說的是這個吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然她們同時也有以幫派的立場在進行活動……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是她們",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n看起來不像那種",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "單純以惡意在行動的公會……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "抱歉，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這裡面參雜了不少我個人的主觀意見。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果小智妳這麼認為",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那我就相信妳。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳識人的眼光，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總是讓我獲益良多。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嘉夜和祈梨",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_012"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "絕對不是壞人！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "帆稀的話，就不知道她到底在想什麼就是了……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不，",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然有些讓人在意的地方，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過她也是那個人的朋友……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我想",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "應該不會有問題才對。",
        "unit_id": 103711
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "502700702"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "說得也是！",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_014"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　感覺我們能成為好朋友呢！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來如此，",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "既然是少年的朋友，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "應該沒問題吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "才幾天不見，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "感覺妳們好像有所成長。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n特別是小智，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看起來比出任務前成熟了許多呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒錯！",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_016"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　比以前",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "更可靠了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是嗎？",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "　我自己是沒什麼感覺……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也許是多虧了",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【龍族巢穴】還有那個人吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為了表達謝意，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "找他一起去吃飯，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "順便捉弄他一下如何？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好耶！",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "剛好很想念蘭德索爾的料理說！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "執勤時間也快結束了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果妳們不介意的話我也一起去吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也得",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好好慰勞一下妳們兩位。",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純要請客嗎？",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "　",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "太棒了！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n好，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們來比比看誰會先到平常去的那家店吧！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊！",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_021"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳太賊了！小智姐！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n等等我～！",
        "unit_id": 100511
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "話說，",
        "unit_id": 106511,
        "voice": "vo_adv_5027007_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "結果怎麼樣啊？老大。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這次的工作",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也不算是空手而回吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就公會的工作而言是這樣沒錯～",
        "unit_id": 106711,
        "voice": "vo_adv_5027007_023"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為我們的主要目標是要找到龍，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就這點來說算是失敗了～……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……那些對管理協會和騎士團有影響力的貴族",
