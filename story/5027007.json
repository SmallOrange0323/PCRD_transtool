        "voice": "vo_adv_5027007_041"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "　又要去？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我想暫時待在文明社會放鬆一下啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我倒是很期待！",
