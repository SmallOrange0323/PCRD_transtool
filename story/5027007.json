    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "選一個好嗎……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "希望妳覺醒呀，",
