        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也就是說……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳不覺得，這代表",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有我們可以介入",
        "unit_id": 106711
    },
