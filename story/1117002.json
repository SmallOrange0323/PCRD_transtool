        "name": "伊莉亞",
        "words": "但總算是要跟這傢伙，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n進展到要",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "一起去某間店裡了！　",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如果是在店面裡，",
        "unit_id": 111711,
        "voice": "vo_adv_1117002_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身的『偉大計劃』進行起來，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也能減少一些尷尬了。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為了這傢伙",
        "unit_id": 111711,
        "voice": "vo_adv_1117002_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身所構想的",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "『偉大計劃』……",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "無論如何都要",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓這傢伙把那個……",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯？　",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你、",
        "unit_id": 111711,
        "voice": "vo_adv_1117002_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你啊，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要帶妾身去哪裡啊？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那邊可沒有什麼店……",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "欸、",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "欸！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不、",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不要那麼用力拉啊～～！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……原來如此。",
        "unit_id": 111711,
        "voice": "vo_adv_1117002_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n雖然的確是店家，",
        "unit_id": 111711
