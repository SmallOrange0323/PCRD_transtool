    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是！　",
        "unit_id": 111711,
        "voice": "vo_adv_1117002_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那種人根本",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不能當成範本！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咱們倆",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就用咱們倆的方式來",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好好享受吧！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對了……",
