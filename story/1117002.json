    {
        "type": "dialogue",
        "name": "旁白",
        "words": "――兩人抵達了蘭德索爾鬧區。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n因為聖誕季而非常熱鬧的鎮上，令伊莉亞感到十分驚訝。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這、",
        "unit_id": 111711,
        "voice": "vo_adv_1117002_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這到底是……",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n鎮上比起平常",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還要更加地明亮呢。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就像是只有這裡",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是白天一樣呢……",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還有",
        "unit_id": 111711,
        "voice": "vo_adv_1117002_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "房屋跟樹上都有裝飾……",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n小鎮的一切都很美麗呢！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯！",
        "unit_id": 111711,
        "voice": "vo_adv_1117002_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n跟妾身所知年代的聖誕節差異非常大呢！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n光是看著鎮上都很開心呢。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……但是，",
        "unit_id": 111711,
        "voice": "vo_adv_1117002_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "今晚可不是用這種方式享樂喔。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就讓妾身教教你，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "享受大人夜晚的方法吧。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "比起用說的，",
        "unit_id": 111711,
        "voice": "vo_adv_1117002_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "用看的更快吧。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你看，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看看那邊。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "今天要開心地度過喔，",
        "unit_id": 311,
        "voice": "vo_adv_1117002_005"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我的愛人♪",
