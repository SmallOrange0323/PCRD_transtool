        "voice": "vo_adv_1117002_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你你、",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你在說什麼啊！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那、",
