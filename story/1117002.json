    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就像那樣。",
        "unit_id": 111711,
        "voice": "vo_adv_1117002_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那樣子正是",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "享受聖誕節的成年男女的樣子喔。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n學習他們的樣子……",
        "unit_id": 111711
    },
