[
    {
        "type": "background",
        "background": "500021"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "日和造訪了平常都有去幫忙的格鬥技道場，\n此時剛好跟小孩們上完了課。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家～！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": " 回家路上一路小心唷～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "好～的！",
        "unit_id": 1,
        "voice": "vo_adv_1001005_001"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "日和老師，謝謝妳了～！",
        "unit_id": 111,
        "voice": "vo_adv_1001005_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯嗯！ 即使才剛剛練習完，大家還是很有精神呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也不能輸呀～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也快到武鬥會了，要努力一點才行呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛剛有說道場等一下還有人使用，",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我得找個不會給其他人添麻煩的練習地點才行……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……咦？ 在那邊的是……",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……果然，是騎士先生！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗨～，騎士先生在做什麼呢～？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來騎士先生在散步呀！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我呀？ 因為我會出戰這次的武鬥會，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "正打算去城鎮外面練習一下呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生會陪我一起練習？",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": " 太好了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，事不宜遲馬上出發！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有個我經常去練習的地點，今天是去那裡唷！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "鏘鏘～！ 到了～！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生可以慢慢來唷。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼我先準備一下～♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……咦？ 騎士先生很在意這個呀？",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然詳細經過我已經忘了，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但這個是從優衣手中收到的玩偶唷。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "又白又毛茸茸的絨毛很舒服的唷～？",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為大小也剛剛好，所以我把它當成練習對象！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然我想認真做接近實戰的練習，但都沒有練習對象……",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n所以大多都是一個人練習。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……就像這樣子！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不論如何攻擊它都不會破損，挺方便呢～！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過呢，像剛才的打擊練習還比較好做，",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但因為它是四足步行的玩偶，所以比較難向它施展格鬥技……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "例如投擲技、關節技之類。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，願意當我的練習對手嗎！？",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了！ 那麼，拜託騎士先生了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "首先就從關節技開始練習唷！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我會向騎士先生施展技巧，騎士先生要抵抗唷！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就算騎士先生向我攻擊也沒關係的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，要開始了唷！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好～！ 先下手為強！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "――其實是假動作！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我就知道騎士先生會往那裏躲！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "千鈞一髮！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過這樣的攻擊是打不中我的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "抓到騎士先生了！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喝！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哼哼哼，騎士先生這麼快就被我抓住了呢。",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你看，我的拘束技也牢牢地牽制住騎士先生了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這樣子騎士先生就逃不了吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，騎士先生這麼激烈亂動的話……",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我就說了嘛。",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我已經牽制了手腕的關節，越掙扎只會越痛唷？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不行的啦。",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這個姿勢的話，騎士先生的手是抅不到的唷！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且騎士先生的右手還被我封住了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，還好嗎？ 要投降嗎？",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還不投降？",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": " ……好吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n直到騎士先生投降為止，我就奉陪到底吧……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但如果騎士先生太死纏爛打的話，我會折磨騎士先生的手臂唷――",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呼喵啊！？",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不可以抓尾巴的呀呀啊啊啊～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊嗚嗚……招式被破解了……",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_029"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可、可是……抓尾巴太狡猾了呀。",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_030"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……被人觸摸我的尾巴，還是第一次呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛、剛剛的是，騎士先生犯規出局呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_031"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只要我想掙脫的話，隨便都能掙脫的說……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘛，雖然向騎士先生施技的是我啦……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_032"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但都是因為騎士先生遲遲不肯投降呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總、總之，跟男生練習關節技還是先放棄好了。",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唉……果然還是要找個女生，做為練習對手才行呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……！ 對呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果是打擊練習的話，即使是和騎士先生練習也沒問題呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且老是找玩偶當對象也不太好，",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_035"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然還是跟正式比賽時一樣，跟人練習是最好的呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以，今後也請多多指教了！",
        "unit_id": 100111,
        "voice": "vo_adv_1001005_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……真是謝謝呢，騎士先生。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看著希望能多多少少幫上一點忙的\n{player}，日和感到十分的高興。"
    }
]