[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，{player}\n也幫忙修特帕魯追捕通緝犯，\n兩人完成任務後來到餐廳慶祝。"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "一直而來，我經常得到吉格魯特的幫助。",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "感謝你的大力相助。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "如果我能發揮原有實力的話，",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n無論是多強勁的對手，都可以瞬間擊倒的……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但因為我還沒恢復前世的力量。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "如果我可以回想起更多前世的記憶，",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n就可以得到更多力量……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "所以我想和你商量一下……",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我從朋友七七香和深月口中得知，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n在這座大陸上，好像有一種叫做「逆轉時空之隱泉」的泉水。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "傳聞只要喝下這個泉水，",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就可以回想起自己",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n深藏在心中的記憶和遺忘了的過去。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "最重要是，這個泉水湧出的水脈，",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n居然就在這附近的洞穴裡！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特呦……",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "要不要去找看看？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不愧是我的盟友！一說就明白了！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不不，不要這樣說，去一次看看吧……？",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_008"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這對拿回我的力量來說是一件必須做的事！拜託了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……你答應了？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "太好啦！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就這樣決定了！快快出發吧！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_009"
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "如果照七七香借我的古文書記載，",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_010"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這裡的深處應該有水脈……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_011"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喔！找到了！是飲水場呀！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但是這個看起來只是普通的泉水……",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_012"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真的是這裡嗎……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……嗯嗯？吉格魯特呦，怎麼樣？",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_013"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "有什麼發現嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "――哦哦！只有這裡湧出白色的泉水……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_014"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "原來如此。這就是「逆轉時空之隱泉」吧……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我先來喝一口試試吧。",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_015"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "咕嚕、咕嚕！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_016"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "咦……？",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_017"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那個……不好意思，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n請問您到底是哪位呢……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……您說您是閃光的吉格魯特先生對吧。",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_018"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "雖然這樣子問有點失禮，但我們是第一次見面……對嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n為什麼，我們兩人會在這裡……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "――哈！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_019"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我到底是怎麼了……！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不、不是的，我記得清清楚楚的！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_020"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n剛才的我，變回了以前的自己……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是還未想起前世記憶時",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "的我！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這是什麼泉水！？",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_021"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我還很期待可以回想起前世的記憶呢……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我不需要能變回以前的自己的泉水呀！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "聽、聽好了吉格魯特！？忘記剛才的事吧！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_022"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n那時的我，一定是有什麼不對勁！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那只不過是過去存在於這個世界的我而已……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……等一下喔？",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_023"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n如果這個泉水能讓人想起在這個世界的回憶，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "失去記憶的吉格魯特喝下後……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "難道會，回到失去記憶前的自己嗎！？",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_024"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特……你希望想起過去的事嗎？",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_025"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這樣呀……那麼，",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_026"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你喝看看這個泉水吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n來吧，先喝一杯吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但我剛才效果沒有維持很久呢……",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_027"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n看來多喝點應該比較好。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特呦，再喝一杯吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "保險起見，再喝一杯吧。",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_028"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "來吧，喝吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……還剩一點！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_029"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n最後再喝一杯！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎麼樣？",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_030"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n喝了這麼多的話，應該能回想起很久以前的事了吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……咦……？",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_031"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n吉格魯特呦，你沒事吧……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n你發出了像嬰兒的聲音……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……不會吧？！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_032"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n難道喝得太多，回到了嬰兒時期的自己！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "等一下！這樣一來就不妙了！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_033"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我沒有照顧過嬰兒呀！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "振作一點呀吉格魯特！快點回來呀！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_034"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n回到原來的你啊！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哇啊，不要哭！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_035"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "乖、乖，不要哭。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯……該怎麼哄嬰兒比較好呢？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好痛！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_036"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喂，不要扯我的首飾！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呀！你、你！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_037"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你摸哪裡呀……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……該該該該、",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_038"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "該不會你想要喝奶吧！ ",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n就算我是疾風之冥姬也做不到呀……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……但努力的話，我也能擠出來嗎……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哇啊真是的！你是乖孩子，所以不要再哭了！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_039"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我也很想哭呀！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "啊啊對不起！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_040"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喔，好乖好乖……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n是、是呀，你是乖寶寶喔……♪",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯……",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_041"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我要維持這個動作多久啊……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但我又不能就這樣不管他，",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_042"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n在他恢復正常前，我得在他身邊才行……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n而且又是我叫他喝泉水的……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……對啊。無論何時都不可以捨棄夥伴。",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_043"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這才是我們熾炎戰鬼煉獄血盟暗黑團啊……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n你說對吧……吉格魯特。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──不久後，修特帕魯與恢復正常的{player}\n迅速地一同走出了洞穴。\n然後幾天後……"
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "──喔喔，你在這裡呀，吉格魯特。",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_044"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "前幾天我們都吃了苦頭呀……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我拜託深月她們幫我調查從洞穴帶回來的泉水，",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_045"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n好像喝了泉水的人們，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n會把自己的本質顯現出來。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒想到你會因為喝太多而變成嬰兒，",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_046"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n那時我真的是束手無策啊……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但是你的本質竟然是嬰兒……",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_047"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵呵，就算曾經是吉格魯特，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n在現世還是個想跟人撒嬌的年紀啊。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……吉格魯特呦。我不太擅長讓別人對我撒嬌。",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_048"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但是如果你無論如何都想要撒嬌的話，我……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還是當我沒說吧！把剛才說的忘記！",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_049"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n從宇宙本源中消除！可以吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "比起那件事，",
        "unit_id": 100911,
        "voice": "vo_adv_1009006_050"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我們現在前往書店去補一下戰記的庫存量吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n來幫忙一下！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "快快出發，我的盟友呀！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──不讓{player}看到自己臉紅，\n修特帕魯拉著他的手走出餐廳。"
    }
]