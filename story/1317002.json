[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "愛梅斯讓{player}幫忙挑選了泳衣。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n隔天，兩人趁勢來到海邊。"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "昨天買了泳裝，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "隔天就來海邊",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼的……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是不是有點太急了？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣不就像是我想快點穿泳衣一樣嗎？",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……不不，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是因為那傢伙提出了，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我才逼不得已啊。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n既然都讓他幫我選了，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就得好好穿給他看",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖說",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這種事原本並不是我的職責",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是了。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你一個人能好好換衣服了嗎？",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "衣服換得比女孩子還慢",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可讓人不敢領教啊。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過因為",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我昨天試穿了很多遍，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以已經習慣換衣服就是了……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呃，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛剛當我沒說。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼事都沒有，忘了吧，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "聽懂了嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你選的",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這件泳裝。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以我跟你的關係，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可不需要什麼客套的感想喔。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你還真會裝腔作勢呢……",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是在哪裡學的？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然很不像你，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但我不覺得反感喔。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果你有準備花束之類的，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我搞不好會笑出來。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為幹勁十足喔。",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n像這樣……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "使勁",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "傾注力量，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就會變成這樣了。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那就是你想說的所有感想嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哦……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣啊。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "0分呢。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "色狼！",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你在做什麼啊？變態！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……你啊，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那種行為，就算被這樣說也無可厚非吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n希望你別忘了，是因為我跟你的關係才容許這種事的。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……嚇我一跳。",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以今天要做什麼？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你有計畫嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我要先說，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我已經在你的記憶裡看過一堆海邊的情境了喔。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就讓我來見識一下你的本事吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要讓我開心的難度可是很高的喔♪",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "─",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "─嗯～♪",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是沙灘的觸感……！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好柔軟，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "腳都要陷進去了……！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我是妖精的時候很小，所以不曉得，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但尺寸跟你們一樣的話，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就很明白了啊。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總覺得好不可思議。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──啊，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你看一下那個！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是螃蟹喔！",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有螃蟹！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n呵呵，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然以前有點怕，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但如果是現在的我，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就覺得不算什麼了呢！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在這邊的是什麼？",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "躲進沙子裡了！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等一下！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你是逃不出我的手掌心的喔～♪",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──呀♪",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這就是海……",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明才在海邊而已，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就已經讓我深受震撼了啊。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但我果然還是",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒有突然跳進去的勇氣呢。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還是不會游泳嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這可不行呢，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這種時候你得當我的護花使者才行。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就在這裡泡泡腳也不錯就是了呢♪",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……！",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是覺得",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我很好搞定嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛剛我只是",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那個……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "覺得海邊很稀奇",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "才跑在前面而已。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要是認為我很開心就大錯特錯了。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好了，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就讓我見識一下你的本事吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我就知道你會這麼說。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這是最容易預料的選擇。",
