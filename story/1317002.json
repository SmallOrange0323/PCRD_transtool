        "voice": "vo_adv_1317002_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n引導你也是我的工作。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯……",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "海岸在那邊呢。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然也可以馬上回去……",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但也對呢，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就再稍微",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "享受一下這個很有你的風格的麻煩吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然可能會被巨大的鯊魚或烏賊之類的襲擊就是了。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "來，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再睡一下吧♪",
        "unit_id": 131711
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "…………",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……哎呀，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你醒了？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看來還沒清醒呢。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我玩得很盡興，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以就不跟你計較了吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一天竟然如此短暫呢。",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我比想像中還要享受。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然我說了",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要見識你的本事，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但這是我打從一開始就完全明白的事吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為我比誰都還",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "更長時間看著你。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……在你周遭的人們",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都是這種心情吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我稍微有點",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能理解了。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒什麼喔。",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……我不小心說了多餘的話。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還真是鬧過頭了。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n幸好沒被認識的人看見。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "聽好了，",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天的事",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可別跟任何人說喔？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "尤其是涅比亞。",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要是被那傢伙知道了，感覺她會一直拿來嘲笑我。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可以嗎？",
        "unit_id": 131711,
        "voice": "vo_adv_1317002_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "約好了喔。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天的事",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是只屬於我跟你",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的祕密喔。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「那可不行啊♪」",
