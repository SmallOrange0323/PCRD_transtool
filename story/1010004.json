[
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，王子先～生♪",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家是真步公主是也。",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "能再次見面真是太開心了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先～生……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……阿嗚！？",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，好痛……",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不行呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這一帶的路真是凹凸不平……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家沒好好看著地面走路，",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以跌倒了呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，沒關係。",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家沒受傷唷，王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為人家不想弄髒衣服，",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以在衣服上加上了防禦魔法。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然應該只是彈走髒污的魔法，",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但也可以防禦一定程度的物理撞擊唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也搞不大清楚原因，",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但很方便呢～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家沒有好好地學過魔法。",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n雖然自己獨自研究了很多資料，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但好像都施展出一些莫名其妙的魔法呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "反而對基本的魔法都搞不清楚……",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家真是個能力不均衡的魔法師。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好丟臉呀♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話說回來，",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生在這裡做什麼呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這一帶",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n治安不是很好……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n在這裡晃來晃去，可是非常危險的唷？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也是因為這樣，身為【哞哞自衛隊】",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n一員的人家才會在這裡巡邏唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過一到這個時間，人家就開始想睡覺。",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n頂多巡邏到一半睡著的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "其他人會叫醒人家……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦？",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n奇怪了，其他人在哪裡呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生知道嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵～",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生怎麼可能會知道齁♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "糟～糕……又走散了。",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家總是一邊放～空一邊走路，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n回過神來就會走失了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過呢，人家很熟悉這一帶的路況……",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n雖然不至於回不了家，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但可能會讓大家擔心。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真討厭，",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家老是發生這種事。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "上次也",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n連累了王子先生一起被抓了起來呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那時候給王子先生帶來麻煩，真抱歉。",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "下次會好好地向王子先生道歉♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦？",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生，這是什麼……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好像有什麼東西在閃閃發光呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然很漂亮，",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但有點刺眼呢……♪",
        "unit_id": 101011
    },
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，王子先～生？",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您好♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "相隔好久終於實際見到面了呢～",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生過得好嗎？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n剛放學嗎？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，王子先生穿著制服……♪",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好像身穿軍服的騎士一樣……♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，我們學校因為不嚴格……",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以有時候比較早下課唷。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "差不多上午課程就結束了，",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以人家很悠閒地到處散步♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "結果呢……",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n快看快看，王子先生。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這是什麼呢？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是什麼啊？",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n塞滿了可愛的東西呢。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "閃閃發光的，好漂亮喔♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是美麗～",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這簡直是魔法的寶箱……♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "喔～抓娃娃機……？",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯嗯。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n原來是叫做抓娃娃機的魔法寶箱呀？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只要順利地解鎖的話……",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就可以救出",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n困在寶箱裡面的可愛玩偶嗎？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呼～",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_035"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這就是傳說中的那個……？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也就是說，",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這裡是激盪夢幻與魔法漩渦的刺激奇幻樂園……",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所謂的遊戲中心對吧～♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家平常不會來這一帶，",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n而且學校附近也沒有這種地方，所以是第一次看到呢。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "偶爾真的該到遠一點的地方走走呢～",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "捲入意想不到的故事情節中，簡直像做夢一樣♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家還巧遇了",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生……♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生、王子先生，",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家想試試看這個叫抓娃娃機的東西，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生知道玩法嗎？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯嗯……",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_041"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生要示範給人家看呀。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "太感謝了，王子先生♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在這裡投幣，",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哇？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好大的聲音呀。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "喔～按那邊的按鈕是嗎？",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_043"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好厲害喔，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的好像魔法一樣♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，那邊的……",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_044"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n希望王子先生幫幫那隻小狗狗。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "其他都是貓咪，",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n只有一隻是小狗狗呢。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好可憐喔，得好好保護它才行～♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哇，王子先生好厲害呀……",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "加油呀～",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家幫王子先生加油唷～♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊、啊……",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_047"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好可惜。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n救援失敗，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n小狗狗掉下去了。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_048"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生英勇迎戰也贏不了，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n看來抓娃娃機是座難以攻陷的城堡了？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，要再試一次呀。",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_049"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真是不畏懼困難英勇奮戰的勇者呢～",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生的話",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_050"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n一定可以救出小狗狗的♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家相信一定可以的……",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_051"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸，",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_052"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家來玩好嗎？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "辦得到嗎～……",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_053"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家總是笨手笨腳的耶。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不行，",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_054"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n為了要救出那隻小狗狗……",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家要努力看看。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "幫人家加油，",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_055"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哇，喔喔？",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_056"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n呃～……小狗狗掉到洞裡了嗎？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎、怎麼樣……",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_057"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n啊，人家順利救出它了嗎？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "太好了，可以稍微放心了。",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_058"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n歡迎來到這裡的世界，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n小狗狗……♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯？",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_059"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生要把小狗狗給人家嗎？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "當然好呀，人家好高興呢……♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣就讓它成為人家的孩子吧。",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_060"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n一起回人家的城堡吧，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不會讓你過不自由的日子的。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101032,
        "voice": "vo_adv_1010004_061"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n多虧了王子先生，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真步真步王國的居民又增加了呢♪",
        "unit_id": 101032
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了～♪",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是呢，",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她沒什麼變，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還是用獨特的世界觀生活呢……真步這孩子",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明只是去遊戲中心玩而已。",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但在她的內心裡，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n似乎上演了一場冒險劇呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她總是看起來很開心。",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這一點也讓人羨慕就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也被捲入了真步所",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n編織出來的可愛故事呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還滿幸福的不是嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總覺得……",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你和真步在一起的時候，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就像個小孩一樣總是雙眼閃閃發亮呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還互相叫彼此",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n王子先生、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真步公主。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我不是在笑你們喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這樣不是很好嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n每個人的幸福都是不一樣的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "『那邊』是她夢中像繪本一般的世界，",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼『這邊』的她又有怎樣的幻想呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過和繪本不同，",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她絕對無法逃避那些現實的煩惱……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "希望她不要因此覺得幻滅就好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵。",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不論會是怎樣的故事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你也會陪著她的對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了不破壞她的美夢，",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你要好好地守護她唷……王子♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1010004_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n說著長篇大論也沒用……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這次就先失陪了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呼、呼……♪",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_076"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗚嗚……？",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_077"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，剛剛睡著了。",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_078"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝叫人家起來，王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_079"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n因為王子先生突然就站著睡著了……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家想說要保護王子先生，就靠在王子先生身邊了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是呢，",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_080"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n看著王子先生的睡臉，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n連人家都開始想睡了♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不行、不行。",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_081"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n在夜晚的路上睡著的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n會感冒的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我們打起精神",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_082"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n回家吧……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_083"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n咱們【哞哞自衛隊】的公會之家",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就在這條路的對面唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家暫住在那裡的。",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_084"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……王子先生要來看看嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "為了趕跑睡魔，來喝杯茶吧～",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_085"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n正好有誰在的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還可以送王子先生回到家裡。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_1010004_086"
    },
    {
        "type": "dialogue",
        "name": "真步",
