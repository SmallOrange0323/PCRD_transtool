    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和七七香持續進行的美少女遊戲模擬約會\n過了一陣子後──"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呼……",
        "unit_id": 113311,
        "voice": "vo_adv_1133004_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "總覺得",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天好累啊……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真想快點回到旅館打滾耍廢……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "說的也是。",
        "unit_id": 113311,
        "voice": "vo_adv_1133004_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n早上去了活動，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "中午開始就一直在模擬美少女遊戲約會呢。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣玩一整天",
        "unit_id": 113311,
        "voice": "vo_adv_1133004_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對七七香來說也是很吃力的……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "行程再緊湊也該有個限度……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且中途開始",
        "unit_id": 113311,
        "voice": "vo_adv_1133004_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我就太過在意你，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n到頭來",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "感覺是我被耍得團團轉……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是的。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天已經充分享受過假期了，",
        "unit_id": 113311,
        "voice": "vo_adv_1133004_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "往後幾天，我只要一直窩在房間裡",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看看書",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就能心滿意足了吧……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 113311,
        "voice": "vo_adv_1133004_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "明天開始你也好好放鬆……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你怎麼突然在發光呀！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n模擬美少女遊戲約會也不會有這種事件呀！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "搞錯類型了吧！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚呀──！",
        "unit_id": 113311
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……………",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒有，",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我也才剛到☆",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……你以為我會這樣回答你嗎？",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這個愚昧之徒──！！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "居然在活動當天遲到，",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你在搞什麼呀！？",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n今天可是關鍵的決戰時刻耶，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "太輕敵了吧！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒有把Cosplay的服裝交給你",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是明智的選擇。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n遲到還忘記帶道具的話，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可不是鬧著玩的啊。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……啊，",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "都到最後入場時間了！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n快快快，動作快點！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不快點的話，我們就只能排隊一般入場了～！",
        "unit_id": 101332
    },
    {
        "type": "background",
        "background": "510270"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呼，",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "總算是趕上了……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "安全上壘。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒什麼時間了，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "快點換衣服吧。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "來，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你的服裝！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我沒跟你說嗎？",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "鏘鏘鏘～！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "神滅的巴哈姆提亞☆",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果是你也熟悉的作品，",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "Cosplay起來會更開心吧？",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然和我們在「那邊」見面時",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "穿的服裝差不多啦。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我可是精心挑選過布料，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "夏天穿起來也是很涼快的！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n就算披著斗篷也不會熱，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "透氣度超群呦☆",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "衣服換好以後",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就在這裡集合喔。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n然後",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們再一起出發",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "去Cosplay廣場！",
        "unit_id": 101332
    },
    {
        "type": "still",
        "still": "113300401"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可別因為我很可愛，",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就小看我呦！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "哇，",
        "unit_id": 1,
        "voice": "vo_adv_1133004_017"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "這不是巴哈姆提亞的莉莉艾利嗎！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "還原度好高啊……！",
        "unit_id": 1,
        "voice": "vo_adv_1133004_018"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那個，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我可以拍照嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好的──",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可以～♪",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n看好了！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "吃我一擊！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "哇～！",
        "unit_id": 1,
        "voice": "vo_adv_1133004_020"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "謝謝！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "旁邊這位小哥也不錯呢……",
        "unit_id": 1,
        "voice": "vo_adv_1133004_021"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "可以麻煩兩位一起",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "讓我拍照嗎！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯嗯，",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "表情也很到位，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有模有樣的呢♪",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣子可以嗎──？",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "可以，",
        "unit_id": 1,
        "voice": "vo_adv_1133004_023"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "非常完美！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "那個～",
        "unit_id": 1,
        "voice": "vo_adv_1133004_024"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "下一個",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "可以換我拍嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好的！",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_025"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "請依序排隊喔～！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇～",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "氣氛好熱烈喔～！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n可以和你一起Cosplay，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我心滿意足♪",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哈哈哈，",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_027"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其實還是有點害羞的啦。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我也是女孩子嘛，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "意識到相機鏡頭",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還是會很害羞的。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我更想和你經歷各式各樣的體驗。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n所以",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "根本沒有心思去想害不害羞的事！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "透過這次活動，",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你也能夠理解Cosplay的魅力了吧？",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n下次我會準備別套服裝的，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們再一起Cosplay吧！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "作為重要的夥伴，",
        "unit_id": 101332,
        "voice": "vo_adv_1133004_030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天也要請你多多關照啦～！",
        "unit_id": 101332
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1133004_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是一場快樂的美夢吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然不曉得你們醒來以後，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還會記得多少。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然七七香是個宅到骨子裡的女孩子，",
        "unit_id": 190011,
        "voice": "vo_adv_1133004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但卻不是那種以自我為中心",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "自顧自地滿足的人。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為你願意理解她的興趣，",
        "unit_id": 190011,
        "voice": "vo_adv_1133004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以她想和你共享她喜愛的事物。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不是單方面的灌輸，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而是兩個人一起享受樂趣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或許這就是關鍵？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "行動時也會想著要和你分享喜悅，",
        "unit_id": 190011,
        "voice": "vo_adv_1133004_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這就是她可愛的地方呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n今後你也繼續和七七香一起",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "體驗更多有趣的事吧。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呼啊……",
        "unit_id": 113311,
        "voice": "vo_adv_1133004_035"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "奇怪，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我睡著了！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我只是玩了一整天，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有累到這種程度嗎……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "睡著的時候，",
        "unit_id": 113311,
        "voice": "vo_adv_1133004_036"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我好像作了個",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "奇怪的夢。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我夢到自己和你",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "去參加蘭德索爾的活動。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……咦？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你也做了同樣的夢？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對呀。",
        "unit_id": 113311,
        "voice": "vo_adv_1133004_037"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "感覺",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "作完那種夢之後，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不趁現在多享受一點好像就虧大了！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我剛剛才說了",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "想好好放鬆一下……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 113311,
        "voice": "vo_adv_1133004_038"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們還是去四處晃晃吧。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "難得來度假，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我想和你",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一起玩個痛快！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "七七香帶著和夢裡同樣的表情，\n朝{player}露出了笑容──"
    }
]