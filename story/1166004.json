    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在惡質貴族那件事過了一陣子後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}對在街上遇到的嘉夜打了招呼。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啥？",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呃，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是你啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "抱歉，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我剛才的態度很糟糕吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n真的",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "很對不起。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不，什麼都沒有……",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哎，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "想用這句話瞞過你是不可能的吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "其實在那之後，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我和老大報告了和貴族發生的糾紛……",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "──所以說，",
        "unit_id": 116611,
        "voice": "vo_adv_1166004_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "事情就是這樣。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為我的過失，搞砸了大好機會。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒能回應妳的期待，真是抱歉啊。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "畢竟雖然當時的情況特殊，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我或許可以",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "處理得再好一點。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是，",
        "unit_id": 116611,
        "voice": "vo_adv_1166004_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我絕對沒有做錯事情。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就只有這件事，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我能抬頭挺胸地這麼肯定。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個嘛～",
        "unit_id": 106711,
        "voice": "vo_adv_1166004_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n如果能因為這件事打好關係，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n或許就能帶來龐大的利益，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在這一點上的確像是損失慘重呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 106711,
        "voice": "vo_adv_1166004_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "正是因為嘉夜一直努力到現在，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這門生意才能上軌道，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "現在也經營得很順利。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳真的幫了一個大忙喔～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是、",
        "unit_id": 116611,
        "voice": "vo_adv_1166004_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是嗎？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "既然妳都這麼說了，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "下次就──",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一直以來真的是辛苦妳了。",
        "unit_id": 106711,
        "voice": "vo_adv_1166004_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "接下來的事情就交給我吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……咦？",
        "unit_id": 116611,
        "voice": "vo_adv_1166004_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "什麼意思？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "包括嘉夜會讓這門生意上軌道，",
        "unit_id": 106711,
        "voice": "vo_adv_1166004_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n還有",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "會犯下嚴重失敗的事情在內，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "全～都在我的意料之中啊☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "、以",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "、說，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不管再怎麼嚴重，我都能處理好喔～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "繼任的導遊已經決定好了，",
        "unit_id": 106711,
        "voice": "vo_adv_1166004_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "下個大好機會也開始有了動作。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嘉夜不必擔心任何事情，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳就跟以前一樣繼續加油吧，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "打手小姐☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這……",
        "unit_id": 116611,
        "voice": "vo_adv_1166004_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣啊！",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哎～",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "都是老大的任性害我接下了莫名其妙的工作啦。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n那我馬上就去打架囉。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊～好～開心啊～！",
        "unit_id": 116611
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "事情",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是這樣。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就像老大說的，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這下子我就能專心當打手了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "明明就有一堆的好處，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我的心情卻不管怎麼樣都不太爽快。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就算打架也不太開心，",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我好像",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有點不對勁啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘿，",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "該怎麼辦才好啊……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呃，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這陣光芒是怎麼回事！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗚、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗚哇──！",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "奇怪～？",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哎呀哎呀～？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n看這寂寞的背影，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "該不會是學長吧～？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊哈哈，",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_016"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "果然是你！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你在這種地方做什麼啊？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n該不會是",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "來見我的吧？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_017"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好的，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我得到了55分的答案～",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你這樣不行啦，學長～！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要以更高的分數為目標啊～！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n真希望你能再用功一點，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學習怎麼跟女孩子相處。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不提這個了，我說學長啊，",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_018"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你拿在手上的東西是什麼啊～？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我知道那是書啦。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我是要問你那是什麼書！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "該不會是",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_019"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那種書吧？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果是的話，這樣不太好呢，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "非常不好。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在這件事情上",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你要怎麼解釋啊？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學～長？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咦？",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_020"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這、",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這個……",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那、",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那種書就是那種書啊！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n別讓我講出來啦，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "笨蛋！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "騙人，",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我只是在開玩笑的……",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "討厭，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你是想拿什麼給我看啊？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "抱歉抱歉，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "等一下啦……",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n咦？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是騙我的？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔～！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "區區的學長，你膽子還真大耶！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我不該這樣捉弄人的啊。",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "反省反省。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不開玩笑了，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我好在意學長買了",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "什麼樣的書喔。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_023"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這是",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "接下來會上映電影的懸疑作品對不對？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n哦～",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "原來原作是漫畫啊。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘿，學長，",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_024"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你不介意的話，我們就一起看吧。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我也對那本漫畫有興趣。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咦？",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_025"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "下次會借我看？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉……",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長真的是有夠遲鈍。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好了，我們走吧。",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_026"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我想想喔，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "或許正好適合去公園之類的地方看。",
        "unit_id": 106532
    },
    {
        "type": "still",
        "still": "116600401"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哦，",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_027"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "圖畫得很漂亮嘛。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我可能挺喜歡",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這種風格的。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "等等，學長，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你翻得太快了啦。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你有在仔細看內容嗎？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯？",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_028"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你說女主角和我很像？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你的意思是",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我很可愛……",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是指這個，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n而是在說我不會瞻前顧後這一點？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你很過分耶～受不了！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔哇，",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_029"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "女主角的上司好可疑……",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n會露出這種笑容的角色",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "肯定都是心眼很壞的人，對吧？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長～",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_030"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我好像",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "知道犯人是誰了。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你還不知道是誰嗎？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "提示就是……",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "答錄機的錄音喔！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "騙人騙人騙人！",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_031"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "劇情的發展不可能是這樣啊！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n第一話的廣播居然是伏筆，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這怎麼可能注意到啊！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊～",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_032"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真有趣～！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n如果是這部作品，的確能理解為什麼會拍成電影啊。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n下次去買預售票吧！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這個嘛……",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_033"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然我單純覺得角色和故事很有趣，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但女主角他們",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對自己的工作引以為傲，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我喜歡的大概是這個部分吧。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就算會感到迷惘",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_034"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "或不安，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就只有那份驕傲絕對不會有所動搖，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也不逃避。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就是因為這樣，他們才能成功解決事件。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣很帥對吧！",
        "unit_id": 106532
    },
    {
        "type": "still",
        "still": "116600402"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_035"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "和我",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "完全不一樣。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我總是在逃避。",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_036"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "逃避空手道，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也逃避重要的朋友。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就算在阿斯特朗裡變得再怎麼強，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我也只會對現實視而不見。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要是像這樣繼續逃避下去，",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_037"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我會變成什麼樣子呢？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n會做起什麼樣的工作呢？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……不，",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_038"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我連自己周遭的事情都解決不了了，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我不認為自己有能力工作啊。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_039"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你大概是在鼓勵我吧，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但你是真心這麼認為的嗎？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是在隨口說說？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你說可能性……",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_040"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果只是可能性，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "的確是要多少有多少啦。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然我還沒辦法練空手道，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但如果是其他的運動，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我或許就能努力去做。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然模特兒是辦不到啦，",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_041"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但因為",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我還挺可愛的，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n搞不好可以當偶像或動作片演員！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊哈哈，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在試著往各種方向想像後，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我都有點開心起來了。",
        "unit_id": 106532
    },
    {
        "type": "still",
        "still": "116600401"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我搞不好出乎意料地",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_042"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "想當什麼都可以，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n努力讓自己變得想當什麼都可以，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣比較簡單，也比較好懂呢！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊～",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_043"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然沒有解決任何事情，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但我總覺得梗在胸口的東西稍微減輕了。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_044"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "最主要還是因為我發現到",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只要能保持這種心態就好了吧。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝你，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你果然很可靠耶。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對了，",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_045"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "為了拓展我的可能性，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n和學長上同一所大學或許也不錯。",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘿，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣很棒對吧？",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是的～！",
        "unit_id": 106532,
        "voice": "vo_adv_1166004_046"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這種時候要回答「我們一起上大學吧」才對吧！",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n呵呵，",
        "unit_id": 106532
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊哈哈哈♪",
        "unit_id": 106532
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的好的，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1166004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀～",
        "unit_id": 190011,
        "voice": "vo_adv_1166004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嘉夜真的會讓在旁邊看的人為她捏把冷汗啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那種不平衡的感覺既充滿了魅力，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "同時也會",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓人感到害怕呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1166004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次的事情讓我確定了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n嘉夜肯定需要你的力量。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對那孩子來說，",
        "unit_id": 190011,
        "voice": "vo_adv_1166004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你那份恰到好處的寬容和溫柔是不可或缺的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算那孩子危險的部分接近了極限，",
        "unit_id": 190011,
        "voice": "vo_adv_1166004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也一定能幫助她。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一直看著你的我都這麼說了，",
        "unit_id": 190011,
        "voice": "vo_adv_1166004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "肯定不會有錯。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以拜託你了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要照顧嘉夜喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就交給你囉，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "學長♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯，",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_053"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呼啊……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂喂，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "居然不小心在路上睡著，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真難看耶。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且我還做了很奇怪的夢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "夢裡的我",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_054"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "相當地迷惘啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是丟臉……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然這樣說，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但現在的我",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也和她差不多。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "感到迷惘，",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_055"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因此逃避，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "卻自顧自地感到心煩意亂。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……我搞不好",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "其實沒有",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "自己想像得",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼堅強啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是……",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_056"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣嗎……？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你說得沒錯啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n不管再怎麼堅強，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "世上不可能存在沒有煩惱或迷惘的人。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "畢竟就算是老大那樣的人，",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_057"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她能獨力辦到的事情也是有限的啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "堅強的人",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_058"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一定是能面對迷惘",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "並做出決定的人。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "迷惘並不代表弱小，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "無法做出決定才是真正的弱小。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "夢裡的我",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_059"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "逃避了各種事情，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "然後失去了方向。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她還是下定了決心，要從原地跨出腳步。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而我",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_060"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "目前的情況也和她一樣。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "老大的做法",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "的確讓我很火大。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "感覺就像完全被看透了，讓人覺得很討厭啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_061"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我做的事情徹底順著老大的算計，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還把老大的命令",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "當成藉口，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "無法做出任何決定就繼續逃避，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n還一個人擅自感到不爽，這樣的自己，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "更讓我火大。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過啊，",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_062"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我並沒有渺小又軟弱到什麼都無法決定，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我要證明自己擁有",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "能顛覆老大預測的可能性！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "什麼啊？這麼突然……",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_063"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這是",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "之前參加導覽的孩子們寄來的！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "上面寫著和我一起遠足很開心，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "下次還想一起去玩。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這原本是在老大的個人需求下硬塞給我的工作，",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_064"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我沒什麼感情或嚮往，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n能撐過研習",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也有一半是出於意氣用事。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "實際工作時雖然很快樂，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "卻也相對地遇到了一堆辛苦的事情。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_065"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我並沒有討厭起導遊的工作喔。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n原本以為自己一輩子只能當打手，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "卻也能做起這種正正當當的工作，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我或許為這件事情感到開心吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "畢竟我也不知道自己能不能一直",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_066"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "混幫派或當打手，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "果然還是先去嘗試所有自己想做的事情，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n讓自己的可能性成長，我現在覺得這樣應該也不壞。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是啊，",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_067"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "首先是回去做導遊！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我想回應孩子們的聲音，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n也想讓老大承認，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "以這份工作來說我做得才是最棒的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "再說，",
        "unit_id": 106511,
        "voice": "vo_adv_1166004_068"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
