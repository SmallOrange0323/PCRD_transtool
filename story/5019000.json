    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【月光學院】即將在幾週後放暑假。\n學期末特有的浮躁氣氛充滿著教室每個角落，\n學生們正興奮不已地討論著暑假時的計畫。"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為暑假要到了，",
        "unit_id": 105011,
        "voice": "vo_adv_5019000_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就這麼興奮。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還真是小孩子呢～",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不是還有半個月嗎。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吶吶，",
        "unit_id": 101611,
        "voice": "vo_adv_5019000_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n美咲在暑假時",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有什麼行程嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我嗎？",
        "unit_id": 105011,
        "voice": "vo_adv_5019000_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這個嘛，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我～……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "妳好像很閒呢！",
