        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "妳憑什麼擅自決定啊！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是說，",
        "unit_id": 105011,
        "voice": "vo_adv_5019000_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "妳在說什麼？",
