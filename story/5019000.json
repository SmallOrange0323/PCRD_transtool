    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 101611,
        "voice": "vo_adv_5019000_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對吼。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是呀～……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我被選為",
        "unit_id": 101611,
        "voice": "vo_adv_5019000_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "活動的形象代言人了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要在離蘭德索爾很遠的島上，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n參加海水浴場的開幕活動！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "很不錯嘛！",
        "unit_id": 105011,
        "voice": "vo_adv_5019000_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "　",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "妳真厲害呢！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嘿嘿嘿，",
        "unit_id": 101611,
        "voice": "vo_adv_5019000_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝妳！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那個工作結束後，",
        "unit_id": 101611,
        "voice": "vo_adv_5019000_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "能休假一段期間，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "想說要不要留在島上繼續玩耍！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以說，",
        "unit_id": 101611,
        "voice": "vo_adv_5019000_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "難得有機會，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我想跟朋友一起玩嘛。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n聽說那邊的海灘好像非常漂亮呢～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦！？",
        "unit_id": 105011,
        "voice": "vo_adv_5019000_012"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "　那樣子",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不就是去渡假嗎！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對對，",
        "unit_id": 101611,
        "voice": "vo_adv_5019000_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以想說不知道妳能不能去，",
        "unit_id": 101611
