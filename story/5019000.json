    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什、",
        "unit_id": 105011,
        "voice": "vo_adv_5019000_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼！？",
