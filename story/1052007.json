[
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。\n所以說，人家就是你在找的莉瑪哦。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "相信我",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "～\n在這片森林裡遇到不可思議的女孩子，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n用類似魔法的力量把我變化成人類的樣子。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是真的。\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家沒有說謊。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（嗚嗚。\n他用非常懷疑的眼神看著我……",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過也是呢，這本來就是不可能的事。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（畢竟又不是繪本情節，\n從來沒有聽說過動物能夠變成人類的。）",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（我也一樣，要是沒有親身體驗，\n就幾乎沒辦法相信。）",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（並不是用幻覺，讓外表變得看起來像人類，\n而是真正改變了肉體。）",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（似似花究竟是什麼人呢……",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這個不可思議的女孩子，難道說是神明嗎？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然很在意，不過現在不是想那個的時候了。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（我得做點什麼，\n好讓這個人相信我就是莉瑪。）",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（這個人似乎因為我不見了，很擔心的樣子。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "既然同樣是人類了……",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n忍耐至今想做的各種事情，很多都能做了呢。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（像是在城鎮裡兩人一起買東西……",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好想要一～直和這個人一起做那些事。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "普通的人類男孩和女孩可以做的所有事。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個，\n總而言之，你可以相信人家就是莉瑪嗎？",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_011"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家什麼都願意做。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n明明就是本人，卻受到『是冒牌貨～』『是別人～』的對待，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家會非常寂寞的",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊啊，的確……",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_013"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是知道只有莉瑪知道的事情，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就能證明人家是莉瑪了對吧？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那麼，你就問問看吧？",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_014"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "任何問題都能回答出來給你看♪",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "話是這麼說……\n不過意外地有點難呢。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是有像只屬於我和你的共有祕密，\n那就簡單了。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不過",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我們沒有深入聊過彼此的事。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊……\n初次見面的情形，還記得嗎？",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_017"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我撞倒了你對吧。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不過，你卻完全沒有生氣。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "面對我這種存在，\n一般人應該會認為我是魔物並感到害怕才對……",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_019"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過你卻很正常地和我說話呢。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那時候我非常開心哦。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝。\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家從那個時候開始，就一直最喜歡你了哦。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唔～像我會做的事，會是什麼？",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_022"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n真難呢？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "平常我總是讓你\n摸摸我的毛皮……",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_023"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過一變成人類的樣子後，毛皮立刻就不見了。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_024"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就算你抱過來，也不會覺得毛絨絨的呢。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，我想到了一個好主意♪",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_025"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_026"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呸！",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哼哼。人家有吐口水的習慣哦。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "普通的人類女孩，不會做這種事對吧？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n這很像我、很像莉瑪對吧～♪",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦、咦……？",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_028"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n為什麼擺出和被父母甩巴掌的小孩一樣的表情……？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊啊……話說回來，",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_029"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n人家為了不被你討厭，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "都忍耐著不要對你吐口水！",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家大概也沒有對你吐過口水吧？",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_030"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n突然被吐這麼一口，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n你也",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "會嚇一跳吧…",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "…",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "對對對、對不起！",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_031"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n幫你擦掉！",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊啊真是的，人家還以為這是個好主意呢？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗚嗚……\n對不起。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_032"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n要證明自己是自己，太難了。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "既然只會讓你擔心……",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_033"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那人家還是變回原本的樣子好了",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "再拜託似似花，請她把人家變回去……",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_034"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "其實人家真的很想去約會，還想做各式各樣的事。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過事情沒辦法那麼順利呢。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "果然，\n我還是沒有辦法體驗到和人類女孩一樣的幸福嗎……？",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_035"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（不過，沒關係。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_036"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這個人，擔心著『平常的我』。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（就算沒有人類的外貌……",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_037"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n還是有男孩子會毫無偏見地看待我、正常地面對我呢。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（這樣就應該滿足了，\n不可以再奢求更多。）",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_038"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？\n什麼……",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_039"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這張傳單，要給我嗎？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "『玩偶裝舞會』……\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_040"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這是什麼？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n總覺得有點可疑。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唔，就像化裝舞會一樣……",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_041"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n隱藏真實身分，穿著玩偶裝參加舞會？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這麼一來，莉瑪也能參加嗎？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就是為了邀請莉瑪去這個派對，\n{player}才會去牧場對吧。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_042"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n因為能夠自由參加，要是我有空也能參加……是嗎？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。\n謝謝，我覺得可以的話就參加看看吧。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_043"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "該說你不管面對誰都很悠哉呢，",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_044"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n還是說你都會用同樣的態度待人呢……",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家最～喜歡你這一點了哦。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（舞會嗎……\n在繪本裡，",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_045"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這種所有女孩都憧憬的",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n公主故事中常見的劇情發展，是必定會出現的橋段呢。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（我雖然沒辦法像",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_046"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n繪本裡的女主角一樣能歌擅舞。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（不論是原本的樣子，還是人類的樣子，",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_047"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要尋得快樂的結局，似乎都很難。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（但是我會努力。\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_048"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "畢竟還有為了我而來到這種深山的人在。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（要是不好好獲得幸福、不開懷地笑，就太對不起他了。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_049"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不對，是誕生到這世上就沒有意義了呢。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（雖然不知道老天爺為什麼要這樣，",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_050"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n給予我人類的心以及魔物的外表。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（不過我不會屈於命運，更不會躲起來哭泣的。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_051"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我，會好好地獲得幸福。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……抱歉……\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_052"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可以請你抱抱人家嗎？一下下就好。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可以嗎？\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_053"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "耶……",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘻嘻，好奇怪的感覺。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "感覺你好高大。",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_054"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n彼此的肌膚相互碰觸，心跳直接傳了過來。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "原來是這種感覺～我會好好記住，不會忘記的。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝你。\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052007_055"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家至少也做了個幸福的夢。",
        "unit_id": 105212
    }
]