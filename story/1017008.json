[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "準備好了嗎～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那要開始囉～！",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我負責爬樹摘那些像苦瓜的東西丟下去，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你負責張開網子接住！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大概就是這種感覺～簡單簡單♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "謝謝你來幫忙採收呢～！",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這次採收了很多，\n等下我也會用剛採收的苦瓜做料理請你吃呦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯！",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "上次那個像是山賊集團的大哥，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n把這一帶劃做地盤種了很多種作物……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我有好～好地向他取得許可了呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大哥他還跟我說，",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n因為腰痛沒辦法自己採收，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以拜託我幫忙呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "他的小弟們好像也在忙著處理其他工作？",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "總之這可是能拿酬勞的正當工作呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "【哞哞自衛隊】的大家",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "上次倒是對我生氣了……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "她們說我的工作不是採收蔬菜，而是守護城鎮的治安才對♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過呢，【哞哞自衛隊】的大家吃到好吃的料理後，",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n也一定會肚子飽飽地",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "露出笑容的～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n船到橋頭自然直呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那我們馬上開始吧～！",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我會一口氣連續丟下那些像苦瓜的蔬菜，你要接好呦！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一、二、三，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來囉～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀！？",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n又是這個讓人不舒服的光線！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哇呀呀，嚇了一跳害我失去平衡了啦～！？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哇哇、哇啊啊！？",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要、要摔下去啦～！？",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "510070"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}～！\n",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗨──呵！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "最近很常遇到你呢～",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你在這裡做什麼呢～？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯，我還沒有回到故鄉，在這邊悠閒晃晃呢～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "最近又要舉辦空手道的大會，",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我也打算參加那場比賽呦～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "比起一直回沖繩又跑來，直接留在這邊比較省事吧？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯！",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "謝謝你～我會加油的～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我一定會取得優勝，",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n希望你也來幫我加油呢～♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喔喔，想不到你觀察力還不錯呢～",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我總記得你本來更不太會顧慮別人才對呀？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "該說是士別三日當刮目相看嗎～♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你有沒有在這附近看到貓呢～？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我的小包包被那隻貓搶走了呢～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你說那隻貓長怎麼樣？",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那個呀～是個小小隻又圓滾滾的三色貓～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "牠的嘴邊應該叼著我的包包，",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n看到後應該可以馬上認出來才是的～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "欸，就在那邊？",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那邊是哪邊？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊啊，原來在樹枝上呀～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這隻壞貓～不准動～！",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "快把包包還給我呀～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不然，我就扒你的皮來做三味線～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "等等我爬上樹去抓那隻貓……",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n希望你在旁準備支援，以防牠逃掉～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "貓的身手很靈巧～感覺很可能讓牠逃掉呢～♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那我要上去囉～！",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘿咻、",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘿咻♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你怎麼了～？哪裡痛嗎？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "為什麼要用手遮眼睛，還轉頭看其他地方啊～？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "欸？你問我為什麼我沒有穿內褲？",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為我的衣服被貓搶走了呀～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我剛剛換衣服換到一半，",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_026"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n替換用的內褲也全部都在包包裡呀～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗚嗚，兩腿之間涼颼颼的感覺怪怪的呢～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊……",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你是因為我沒穿內褲才會轉頭看其他地方呀？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒想到你還挺紳士的呢～啊哈～♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒關係呀，就算被你看到也……",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗚啊！？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n一聊起來就被那隻貓發現了～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要被牠逃掉了～！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可惡～把我的內褲還來！",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀、哎呀呀！？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n急著抓貓讓我失去平衡了～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要摔下去啦！？",
        "unit_id": 101731
    },
    {
        "type": "still",
        "still": "101700801"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊嗚……",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n對、對不起。",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n還好有你抱住我～你沒有受傷吧～？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "欸嘿嘿。",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_031"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n總算是平安拿回包包了～",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這下我總算能夠裝上一個文明人最低限度的裝備了～♪",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我可不是故意給你看的呢……",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_032"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀呀？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你怎麼暈過去了？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "該不會是因為接住摔下來的我～才被撞到暈過去吧？",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_033"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n仔細一看，他好像流鼻血了？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "怎、怎麼辦……有沒有東西可以擦呢～？",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "總不能用內褲來擦吧……？",
        "unit_id": 101731,
        "voice": "vo_adv_1017008_034"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n對不起對不起！",
        "unit_id": 101731
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n這一次實在不能用一句「船到橋頭自然直」解決呢～？",
        "unit_id": 101731
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唔～我開始擔心「這邊」的香織，",
        "unit_id": 190011,
        "voice": "vo_adv_1017008_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n有沒有好好穿上內褲了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n對你來說也真是一場災難呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不不，反而該說讓你賺到了嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1017008_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然你喪失了記憶，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不過那方面的知識回復到哪種程度了呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "果然你自己也是有點開心吧～？",
        "unit_id": 190011,
        "voice": "vo_adv_1017008_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n欸欸，不要不說話回答一下呀～！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你這個小色鬼～欸嘿嘿♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，現在不是作弄你的時候呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1017008_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看來目前的時機不太巧，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n「這邊」的香織也正好要從樹上摔下來了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你趕快醒過來，好好接住她吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1017008_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "搞不好呢，還能從香織那邊獲得獎勵……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呦♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊嗚嗚……",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_040"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "奇、奇怪了？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我暈過去了嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對不起呢～",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_041"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你緊急地接住了從樹上摔下來的我嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你有沒有受傷？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_042"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我是為了保護好剛剛好不容易採收的像苦瓜的東西，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "才沒有做好護身倒法，於是就暈過去了呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真是太大意了～",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_043"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過也多虧如此，這些像苦瓜的東西也都平安無事～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們兩個人一起暈倒後已經過了不少時間，",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_044"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "得趕快採收剩下來的部分才行！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你站得起來嗎？",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_045"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "很好很好，看來你還很有精神呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n那我們也重新振作，努力採收像苦瓜的東西吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_046"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n怎麼了？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "欸，內褲……內褲怎麼了嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我今天有穿內褲呀～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_047"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯，雖然有時候會忘記，不過今天有記得穿上呦～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你看你看，我有穿吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你怎麼會突然說起內褲的事情呢……",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_048"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真讓人意外，畢竟你也是個男孩子呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你對女孩子的內褲有興趣嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……你呀。",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_049"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你會爬樹嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就算不會也得學會，我可以教你呦～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以說囉。",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_050"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n爬上樹然後採收苦瓜的工作，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n換你來做。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "總覺得你今天色色的，",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_051"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n要是我爬樹你一定會一直盯著我的內褲看吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不會看？真的嗎？",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_052"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯，其實我也不是穿裙子，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n就算給你看到內褲也不太會在意才是呀……？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯……",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_053"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不知道為什麼，我突然覺得有點害羞起來了啦～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這是為什麼呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017008_054"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就算被你以外的人看到，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我也一點都不會在意的呀……？",
        "unit_id": 101711
    }
]