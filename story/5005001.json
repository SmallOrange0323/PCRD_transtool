    },
    {
        "type": "background",
        "background": "500280"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎歐歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀，",
