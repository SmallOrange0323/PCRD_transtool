    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈，",
        "unit_id": 107911,
        "voice": "vo_adv_5005001_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣是嚇不倒我的喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嘿、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嘿、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵♪",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵咪喵咪……",
