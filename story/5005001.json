        "voice": "vo_adv_5005001_029"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "比想像中還容易打倒呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n該不會這裡的魔物……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "非常弱？",
