[
    {
        "type": "background",
        "background": "500281"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}、珠希和美冬\n在不知何時被沖上岸的海灘分頭探尋著。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "如何，",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "珠希？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個方向有沒有人在？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒想到竟然",
        "unit_id": 107911,
        "voice": "vo_adv_5005001_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有很多隻貓咪呢喵～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "大隻的、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "小隻的、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n條紋的、混色的和花斑的小貓們……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n拼命地向我撒嬌示好呢喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好可愛喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣啊，",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有很多隻貓咪真是太好了……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不對，",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "才不好！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "現在可不是和貓咪玩耍的時候吧！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我、",
        "unit_id": 107911,
        "voice": "vo_adv_5005001_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我～也有好好調查過有沒有人在喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n但是在調查的範圍裡",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "到處都沒有看見人影喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣嗎，",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我這裡也是類似的結果呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "都是小狗之類的小動物，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "感受不到有人在的跡象……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "{player}呢……？",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "看你愁眉苦臉的樣子",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "應該也是一樣的結果呢……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "唉……",
        "unit_id": 107911,
        "voice": "vo_adv_5005001_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "話說肚子好像開始餓起來了喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "確實。",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "雖然不曉得正確的時間，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但應該也差不多到晚餐時間了吧。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為連船本身都不見了，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "釣到的魚也沒了……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n今天的晚餐，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "該怎麼辦才好呢……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊……",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我剛剛看到在那邊的海裡有大魚的影子！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "{player}、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "珠希，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n同心協力來捉魚吧！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "{player}踩進海裡，",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "把魚往我這個方向趕。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n然後我會用槍把魚打上來，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n最後由珠希捕捉！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我知道了喵！",
        "unit_id": 107911,
        "voice": "vo_adv_5005001_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n來吧，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "把魚趕到美冬的方向喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對，{player}，做得不錯呢！",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n就是這個氣勢哦！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "{player}不用試圖去抓也沒關係啦！",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n趕過來我這邊就好！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "來了！",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "珠希，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我要把魚打上來，抓好囉！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "看招────！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "交給我喵────！",
        "unit_id": 107911,
        "voice": "vo_adv_5005001_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n捕──────捉！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "抓到了喵──────────！",
        "unit_id": 107911,
        "voice": "vo_adv_5005001_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "太好了呢！",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "　馬上烤來吃吧！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我來用樹枝摩擦生火！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "各式各樣的打工經驗可不只是擺著好看喔！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "喝啊────！",
        "unit_id": 108011
    },
    {
        "type": "background",
        "background": "500282"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼……",
        "unit_id": 107911,
        "voice": "vo_adv_5005001_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好好吃喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "肚子吃得好飽喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵，",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n也許生存能力還滿強的嘛！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 107911,
        "voice": "vo_adv_5005001_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "剛好這裡",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有像是睡袋一樣蓬鬆的草喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "今晚就在這待到天亮喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也是，",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_021"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "今天耗費了不少體力……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n暫且就先休息吧。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "晚安啦……",
        "unit_id": 108011
    },
    {
        "type": "background",
        "background": "500280"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "早上了喵────！",
        "unit_id": 107911,
        "voice": "vo_adv_5005001_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這個草，",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_023"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好像比想像中還舒適呢！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "接下來……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "只要找到逃出這個小島",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "所需的東西，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n就太完美了……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對了，",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_024"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "昨天還留有一些沒調查的區域……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要說原因的話，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n因為有幾隻魔物在附近徘徊",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "所以效率不太好呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，",
        "unit_id": 107911,
        "voice": "vo_adv_5005001_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "順便當作提神，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "大家一起去擊退喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯，",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就這麼做吧！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n大家，往這裡，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "跟我來！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "果然……",
        "unit_id": 108011,
        "voice": "vo_adv_5005001_027"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那裡有魔物們在呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n趕緊把它們趕跑吧！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕歐歐歐歐歐！",
