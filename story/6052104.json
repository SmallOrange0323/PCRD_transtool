    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "是嗎……",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "是當偵探的魔法少女吧。",
