        "voice": "vo_adv_6052104_003"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "哦～",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "是喔……",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "虧我還想像了很多……",
        "unit_id": 114211
    },
