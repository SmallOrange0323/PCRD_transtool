[
    {
        "type": "background",
        "background": "509015"
    },
    {
        "type": "background",
        "background": "510082"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗨，小子。",
        "unit_id": 107131,
        "voice": "vo_adv_4010245_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n好久不見，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我親自來找你囉☆",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "「為什麼」還真是出乎我意料的回應啊。",
        "unit_id": 107131,
        "voice": "vo_adv_4010245_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你不是沒有我的聯絡方式嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以我才會像這樣特地跑過來你家啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今天是什麼日子……",
        "unit_id": 107131,
        "voice": "vo_adv_4010245_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你應該知道吧？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈☆",
        "unit_id": 107131,
        "voice": "vo_adv_4010245_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很好，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "感謝你的祝福。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我本來還想說你會記得的機率只有五成，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n幸好你這小子沒讓我失望♪",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是你不記得的話，",
        "unit_id": 107131,
        "voice": "vo_adv_4010245_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我原本打算",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "直接把你綁走，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n跟著我克莉絲提娜小姐一起來場全國生日巡迴之旅喔☆",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……呵。",
        "unit_id": 107131,
        "voice": "vo_adv_4010245_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "外頭的喧囂我並不討厭，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不過偶爾也會渴望",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有一處能靜下來的地方。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "像這樣簡樸",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "卻能沉澱心情的空間，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "尤其是不可多得啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 107131,
        "voice": "vo_adv_4010245_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是什麼……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "草莓鮮奶油蛋糕？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣好嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這不是小子你的點心嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "草莓鮮奶油蛋糕加兩杯果汁。",
        "unit_id": 107131,
        "voice": "vo_adv_4010245_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這場宴會未免也太迷你了吧！",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會心懷感恩地享用。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我這個人開宴會",
        "unit_id": 107131,
        "voice": "vo_adv_4010245_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一向都是極盡奢華……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但這種悠然自適",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "卻有另一種說不出的美妙。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n感覺是金錢換不來的、",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "獨一無二的價值。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 107131,
        "voice": "vo_adv_4010245_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來乾一杯吧！",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說笑的，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不需要搞得那麼誇張。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們就靜靜地",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "享受這個",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只有我倆的生日吧。",
        "unit_id": 107131
    }
]