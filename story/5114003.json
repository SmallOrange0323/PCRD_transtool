        "voice": "vo_adv_5114003_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我在裝潢時髦的店內，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n架設了給貓咪自由活動的",
        "unit_id": 125111
