        "words": "哈啾！",
        "unit_id": 125111,
        "voice": "vo_adv_5114003_073"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼了，",
        "unit_id": 125212,
        "voice": "vo_adv_5114003_074"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "珠希？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒事喵～",
        "unit_id": 125111,
        "voice": "vo_adv_5114003_075"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只是突然打起噴嚏……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是有人在說我壞話喵……？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好了，",
        "unit_id": 125212,
        "voice": "vo_adv_5114003_076"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要把這個擺設",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "放在哪裡呢？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n說到吉祥物就是放在高處……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要是被貓弄掉下來會很危險的喵！",
        "unit_id": 125111,
        "voice": "vo_adv_5114003_077"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "放糖果櫃的附近……",
        "unit_id": 125212,
        "voice": "vo_adv_5114003_078"
    },
    {
        "type": "dialogue",
        "name": "條紋",
        "words": "唔喵……",
        "unit_id": 1715,
        "voice": "vo_adv_5114003_079"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "感覺貓咪牠們在警戒喵……",
        "unit_id": 125111,
        "voice": "vo_adv_5114003_080"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你們",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可以用不著那麼害怕喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這隻貓不會爭地盤喵。",
        "unit_id": 125111,
        "voice": "vo_adv_5114003_081"
    },
    {
        "type": "dialogue",
        "name": "黑",
        "words": "喵……",
        "unit_id": 1714,
        "voice": "vo_adv_5114003_082"
    },
    {
        "type": "dialogue",
        "name": "白",
        "words": "唔喵……",
        "unit_id": 1713,
        "voice": "vo_adv_5114003_083"
    },
    {
        "type": "dialogue",
        "name": "白",
        "words": "\n喵嗯……",
        "unit_id": 1713
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 125111,
        "voice": "vo_adv_5114003_084"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "牠們不太認同喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼，",
        "unit_id": 125212,
        "voice": "vo_adv_5114003_085"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還是擺在入口附近比較好嗎？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒錯喵。",
        "unit_id": 125111,
        "voice": "vo_adv_5114003_086"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣一來，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "客人進來的時候也會看到喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "店開了，",
        "unit_id": 125111,
        "voice": "vo_adv_5114003_087"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "鯛魚燒的材料也備齊了，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n今天真是美好的一天喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是啊！",
        "unit_id": 125212,
        "voice": "vo_adv_5114003_088"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也會",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "盡自己所能",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "讓店裡生意興隆！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "相信這進而",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也能讓我們公會茁壯！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯嗯，",
        "unit_id": 125111,
        "voice": "vo_adv_5114003_089"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n妳這麼有心很好喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好，",
        "unit_id": 125111,
        "voice": "vo_adv_5114003_090"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咖啡廳「Naschkatze」將從明天開始營業喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，",
        "unit_id": 125212,
        "voice": "vo_adv_5114003_091"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真期待。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "絕對會",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來客絡繹不絕！",
        "unit_id": 125212
    },
