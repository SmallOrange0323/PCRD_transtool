    {
        "type": "dialogue",
        "name": "旁白",
        "words": "閃耀的太陽。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "波光粼粼的海洋。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "眩目的泳衣季節。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在氣溫急速上升的盛夏海邊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n可璃亞和{player}在度假村打工。"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "讓您久等了。",
