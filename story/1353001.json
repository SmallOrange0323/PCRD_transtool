        "voice": "vo_adv_1353001_000"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這是您點的麥酒♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "下一位客人，",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_001"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "您要點章魚燒是嗎～",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥～！",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "章魚燒一份，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "麻煩你了～♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "{player}、",
        "unit_id": 1411,
        "voice": "vo_adv_1353001_002"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "可璃亞，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "辛苦了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不愧是你們兩位，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "真有默契～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "說什麼真有默契，",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_003"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "太過獎了。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是因為哥哥配合我，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "讓我做起來很順手♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……店長，",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_004"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不好意思，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "久疏問候了。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n餐廳的經營",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "還順利嗎？",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "嗯嗯，",
        "unit_id": 1411,
        "voice": "vo_adv_1353001_005"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "非常好喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "多虧你們，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我還開了海之家分店呢！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這些",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "都要感謝",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "你們那時來這邊打工啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哪裡哪裡。",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_006"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不過真是讓人懷念呢♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……哥哥，你還記得嗎？",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我第一次打工時的事情。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "嗯，",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_007"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我和你討論想打工的事，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n哥哥就跟我一起來了呢♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n那時候真的好開心～",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "你、",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_008"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "你忘記了嗎……？",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那時候，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我和哥哥討論想打工的事，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n你不就跟我一起來了嗎。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我那時是因為看到「充滿笑容的職場」，",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_009"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這個求職廣告才去應徵的。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "結果聽到的",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "卻是地痞們的",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "「咕嘿嘿～」",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "笑聲。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n一開始還以為",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "自己被騙了……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不過，",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_010"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "之後我和哥哥一起努力接待客人。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n客人們",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "也幾乎都很溫柔。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "真的是很寶貴的經驗呢♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "店長，",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_011"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "再次感謝你",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "當時的照顧。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n而且還又找哥哥和我一起來打工，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我真的非常高興♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "啊哈哈，",
        "unit_id": 1411,
        "voice": "vo_adv_1353001_012"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我才該跟你們道謝！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n你們真的很能幹呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不愧是",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我們的可璃亞！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不對……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是我們的",
        "unit_id": 1411,
        "voice": "vo_adv_1353001_013"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "聖女妹妹才對！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……唔。",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_014"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊、",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_015"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊哈哈……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "今天",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "請多指教♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "…………\n……",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_016"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……剛、",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_017"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "剛剛的我，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n有好好笑出來嗎……？　",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我這樣",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_018"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不行啊……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "突然就不知所措了。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "因為剛剛……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "被叫聖女妹妹",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "的關係……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……我，",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_019"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "才不是什麼聖女。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n只是在人前裝乖，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "扮演好孩子而已……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "因為，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "真正的我……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我，",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_020"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "才不是什麼聖女──",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "──唔！",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_021"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n哥、",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥……？",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……沒、",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_022"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "沒",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "錯！",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n那個，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "店長，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我並不是聖女妹妹！",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "……嗯？",
        "unit_id": 1411,
        "voice": "vo_adv_1353001_023"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "哈哈，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不不，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "在我的心目中妳就是聖女妹妹啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n我做了這麼多年的餐飲店，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "能像可璃亞一樣",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "治癒人心的",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n服務生可是──",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "哦，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "客人來了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "歡迎光臨──！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……唔。",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_024"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊，",
        "unit_id": 135311,
        "voice": "vo_adv_1353001_025"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是的。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我沒事。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那個……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "抱歉讓你擔心了。",
        "unit_id": 135311
    },
    {
