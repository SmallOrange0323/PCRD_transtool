[
    {
        "type": "background",
        "background": "501612"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗨嗨～！",
        "unit_id": 100111,
        "voice": "vo_adv_9008007_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們離開播音間，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n來度假村飯店進行現場直播囉！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而這間知名高級度假村，伴隨的是……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天要進行的特別企劃，",
        "unit_id": 100311,
        "voice": "vo_adv_9008007_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "「恐怖怪談」。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……一般來說，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "恐怖怪談不是夏天才會有的企劃嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n現在感覺時期還有點太早了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這地方看起來是個很漂亮的度假村，",
        "unit_id": 126012,
        "voice": "vo_adv_9008007_002"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "難道有什麼奇怪傳聞嗎？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯。",
        "unit_id": 100311,
        "voice": "vo_adv_9008007_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "據說這個度假村，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "以有幽靈出現聞名。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "去年夏天似乎就發生了不少靈異現象，引起很大的騷動。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n像是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會聽見可疑的呻吟聲、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "出現騷靈現象等等。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦咦咦……！？",
        "unit_id": 100111,
        "voice": "vo_adv_9008007_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "聽到這些，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "讓我忍不住背脊發寒了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那怪談企劃",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是要做什麼？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "當然就是說百物語囉。",
        "unit_id": 100311,
        "voice": "vo_adv_9008007_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們要來讀",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從聽眾那邊募集到的恐怖故事。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n據傳說，讀到第一百個故事後，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就會發生什麼事情喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "會、",
        "unit_id": 126012,
        "voice": "vo_adv_9008007_006"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "會發生事情……？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這真的不要緊嗎？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我對",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "太過恐怖的事有點沒辦法……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100311,
        "voice": "vo_adv_9008007_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這些不過只是迷信啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，讓我們馬上開始吧──",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "──然後，",
        "unit_id": 100311,
        "voice": "vo_adv_9008007_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在門另一頭的男人開口了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n「你仔細",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "聽好了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我沒有死。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n真正死掉的是……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在你身後的那一群人啊！」",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "呀啊────！！",
        "unit_id": 1,
        "voice": "vo_adv_9008007_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呼、",
        "unit_id": 100111,
        "voice": "vo_adv_9008007_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呼……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個故事未免太可怕了吧～！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就、",
        "unit_id": 126012,
        "voice": "vo_adv_9008007_011"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就是",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "說呀……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n從今天晚上開始，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我可能沒辦法一個人睡覺了……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n還是請普蕾西亞",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "把小樂借我抱好了……！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈哈，",
        "unit_id": 100311,
        "voice": "vo_adv_9008007_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉抱歉。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才有些趕時間地把百物語講完了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過什麼也沒發生呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就是說呢……！",
        "unit_id": 126012,
        "voice": "vo_adv_9008007_013"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "…",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "…呼。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "怜小姐說得果然沒錯，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n迷信就是迷信，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對吧。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵……♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊哈哈哈哈哈♪",
        "unit_id": 1,
        "voice": "vo_adv_9008007_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈……",
        "unit_id": 100111,
        "voice": "vo_adv_9008007_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n真的",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "會笑出來呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n沒想到我們竟然被迷信嚇得心驚膽顫的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是、",
        "unit_id": 100311,
        "voice": "vo_adv_9008007_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n話說回來……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "發出笑聲的，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是誰？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "…………",
        "unit_id": 126012,
        "voice": "vo_adv_9008007_017"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "呀啊啊啊啊啊～～～！？",
        "unit_id": 1,
        "voice": "vo_adv_9008007_018"
    }
]