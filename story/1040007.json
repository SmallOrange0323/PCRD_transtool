[
    {
        "type": "background",
        "background": "500181"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "碧和{player}擊退了襲擊精靈之森的魔物。\n但是，因為十分在意精靈之森的結界受到破壞一事，\n於是兩人就來到了森林的入口。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這裡，就是佈有結界的地方……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗯，果然……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n結界好像損壞了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "應該不是這裡，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而是城鎮的結界壞了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是的。",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n以前，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "與人類關係良好的精靈族和魔力非凡的人類精英們同心協力，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n在森林到城鎮之間佈置了結界。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "精靈族和人類的友誼……真令人羨慕啊……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，不、不是，抱歉，",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我離題了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "總之，多虧有精靈之森到蘭德索爾之間",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "的結界，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n讓兩個地方被魔物襲擊的機率降到最小。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "由於某些原因，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "城鎮的結界損壞了，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n所以也就失去了平衡……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要佈置新的結界，",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n需要拿著精靈之森祖傳的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "精靈族權杖前往城鎮，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n在那裡建造高台並祈禱三天。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果不立刻……前往城鎮佈置結界的話，",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼不論是森林還是城鎮，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n都會面臨危機。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為精靈族權杖，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只有精靈族",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "才能觸碰……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n必須由我",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "親自拿著前往城鎮才行……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我沒有去過城鎮……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有點害怕……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、那個，{player}……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n可、可不可以跟我一起去呢……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哇！",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝、謝謝！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那麼，我們出發吧！",
        "unit_id": 104011
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，\n碧和{player}拿著精靈族權杖前往城鎮。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哇！這、這裡就是城鎮啊……！",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "人、人好多……有點頭暈……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚哇……我、我不太習慣人群……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我好像對人有點過敏……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "抱歉，讓我休息一下……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……但是，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果可以和這裡人的所有人成為朋友的話，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那一定很棒……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哇，冰淇淋的攤販……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦，你要買給我嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝謝……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗯嗯！",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真、真好吃！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "城鎮真是個好地方呢……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人費了一番功夫，\n打聽到城鎮的保安負責人在餐廳，\n就急忙前往詢問。"
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "防衛負責人",
        "words": "原來是結界啊。我以前確實也聽聞過此事呢。",
        "unit_id": 1411,
        "voice": "vo_adv_1040007_018"
    },
    {
        "type": "dialogue",
        "name": "防衛負責人",
        "words": "\n不久前為了建房子把神社給拆了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "防衛負責人",
        "words": "\n看來那是問題的所在啊……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "防衛負責人",
        "words": "好了，我明白了！我會做好一切準備。",
        "unit_id": 1411,
        "voice": "vo_adv_1040007_019"
    },
    {
        "type": "dialogue",
        "name": "防衛負責人",
        "words": "\n妳就登上高台，佈置那個結界吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "防衛負責人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "防衛負責人",
        "words": "小姑娘，雖然連續三天會很辛苦，那就拜託妳了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好的！我會加油！",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_020"
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "之前建造祭典的高台時還有剩下的木材，",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n所以馬上就可以組建好，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們來的真是時候呢，{player}！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咚咚鏘鏘……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呵呵。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我想文化祭之類的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是這種感覺吧……",
        "unit_id": 104011
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "完成了！",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "精靈族權杖也擺放好了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n今天開始這三天，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我要守護好這個高台！",
        "unit_id": 104011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從那天開始，不論颳風下雨，\n碧都在高台上禱告，持續佈置著結界。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼……今天是待在這個高台的第二天……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n原來佈置結界……並不是件容易的事情……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，在廣場的那個人是{player}！",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n可以揮手嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "他會發現我嗎……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……咦？{player}……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n正和在廣場的人們愉快地聊天……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "…………是他的朋友嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……如果他交到了朋友……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那BB團會不會就要解散了呢……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "…………",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_028"
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然後，終於到了第三天的夜晚。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "今晚天氣非常晴朗，星星好美啊…………",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "感覺許願的話，好像會實現……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_030"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n{player}，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "現在一定正和某人玩得很開心吧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，啊呀呀，{player}！晚安！ ",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_031"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n今晚的星星很美喔！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "想到今天是最後一天……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有點捨不得離開這座城鎮了。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是……結果也沒交到朋友……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_033"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "與此相比……你……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，沒、",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_034"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒什麼！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呃……那個……我、我……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_035"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n因為一直都是一個人……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就算之後又剩我一個人，我也不會有事的……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_036"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你要過得幸福喔……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒什麼！ ",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_037"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對了，結界就快佈置好了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呃，哇，這個晃動是怎麼回事？",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_038"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "到、到底是……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_039"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊！ ",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n高台下有魔物……！什麼時候來的！ ",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n而且正準備破壞高台呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、我不會……讓你如願的！",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_040"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n嘿！",
        "unit_id": 104011
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_041"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼。終於打倒魔物了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "高台在搖晃……！ 啊！",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_042"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哇、哇！要、要掉下去……！",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_043"
    },
    {
        "type": "still",
        "still": "104000701"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在碧快要從高台掉下的時候抓住了她。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝、謝謝……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_044"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……不，我要堅守到最後。",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_045"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n即使與高台一起崩塌，我也甘願。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你有很多朋友。",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_046"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，我沒有任何朋友……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n所以即使我不在了，也不會有任何人感到難過……",
        "unit_id": 104011
    },
    {
        "type": "still",
        "still": "104000702"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦……？你說的不是，是什麼意思……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_047"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對、對啊。你跟我不一樣！",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_048"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為，你有很多朋友……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我都看見了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你在廣場跟很多人聊天……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_049"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那些人一定都是你的朋友……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼BB團就……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦，什麼？",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_050"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你說和城鎮的人聊天是有原因的？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要我往下看……嗎？",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_051"
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "喂，小碧！ ",
        "unit_id": 1,
        "voice": "vo_adv_1040007_052"
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "\n等事情結束之後，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "\n城鎮的大夥們想和小碧做朋友，所以要平安地下來喔─！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "城鎮的人們……！",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_053"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也就是說，你和城鎮的人們聊天，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n其實是為了拜託他們這一件事情嗎……",
        "unit_id": 104011
    },
    {
        "type": "still",
        "still": "104000703"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊、啊哈……不愧是BB團的團長……好厲害呀……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_054"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我居然有一瞬間懷疑過你，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n真是羞愧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……咦？",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_055"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你說",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且我已經有朋友了……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請、請不要騙我了……！ ",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_056"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n就、就算我再怎麼遲鈍也知道！至少現在沒有…… ",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你說我的朋友在哪裡啊……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦……？",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_057"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "{player}是，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "朋友……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你是說我是你的朋友嗎？",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_058"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n像我……這麼奇怪的人？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊哈……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_059"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這樣的奇蹟……就像做夢一樣……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我的願望……實現了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦，要先下去嗎？好、好的！",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_060"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}抱著碧從高台下來。"
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，高台要倒了……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_061"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只要再一下下，結界就能佈置好了說……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，重新再佈置就好了嘛。",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_062"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "比起這個……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、我交到朋友了呢。",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_063"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且，那個人居然是你……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_064"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我太高興了。那個，可以就這樣……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n再待一會嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我還想繼續沈浸在這餘韻之中……",
        "unit_id": 104011,
        "voice": "vo_adv_1040007_065"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這就是碧交到的第一個朋友。\n今後，BB團的兩人也一定會交到更多的朋友……"
    }
]