    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呼……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "這是第幾次了？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "紡希妳總是因為一些無趣的小事而找本小姐單挑。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼、",
        "unit_id": 134812,
        "voice": "vo_adv_5205411_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這是第幾次了呢？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "華音妳老是因為一些無聊的事情而跟我吵架。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "什麼無聊的事情！？",
        "unit_id": 134912,
        "voice": "vo_adv_5205411_002"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "是因為妳說妳那邊的世界下次要舉辦慈樂之音演唱會，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n本小姐才想說",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "要親自登台站在中央幫妳們表演耶！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳是說我一秒拒絕掉妳的這個判斷很無趣嗎！？",
        "unit_id": 134812,
        "voice": "vo_adv_5205411_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果妳說妳無論如何都要出場的話，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那我當然是不惜跟妳打一架",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也要阻止妳啊！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……無論如何都不行嗎？",
        "unit_id": 134912,
        "voice": "vo_adv_5205411_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算妳稍微裝可愛地說也不行。",
        "unit_id": 134812,
        "voice": "vo_adv_5205411_005"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "那麼就只能靠決鬥來解決了！",
        "unit_id": 134912,
        "voice": "vo_adv_5205411_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳以為決鬥贏了就能出場嗎！？",
        "unit_id": 134812,
        "voice": "vo_adv_5205411_007"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "哦～",
        "unit_id": 134912,
        "voice": "vo_adv_5205411_008"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呵呵呵♪",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n乖乖認命讓本小姐參加慈樂之音演唱會吧～！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n本小姐是不會放棄的～～～～～♪",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我受夠這個人了──！",
        "unit_id": 134812,
        "voice": "vo_adv_5205411_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n好想快點回去蘭德索爾～～～！",
        "unit_id": 134812
    }
]