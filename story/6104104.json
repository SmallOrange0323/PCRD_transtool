[
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然在都市也有兔子族，",
        "unit_id": 100512,
        "voice": "vo_adv_6104104_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n但也有些兔子族在深山中過著傳統的生活呢。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "像是買東西之類的",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不會不方便嗎？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你說沿著那種陡峭的山崖嗎？",
        "unit_id": 100512,
        "voice": "vo_adv_6104104_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真虧他們能辦到呢……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "他們有那種驚人的身體能力，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n也是多虧了山中生活啊。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這樣我就能理解了。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "說得也是呢。",
        "unit_id": 100512,
        "voice": "vo_adv_6104104_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "壞商人已經被我們教訓過了，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在這之後來的應該都是好商人才對。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為有克莉絲提娜阿姨盯著，所以可以好好放心！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊！",
        "unit_id": 100512,
        "voice": "vo_adv_6104104_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在我最近看的漫畫裡有這種場面！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n奧義的靈感",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就隱藏在像擦地板這種日常瑣事當中。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我想",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "暫時居住在這裡看看，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可以嗎？",
        "unit_id": 100512
    }
]