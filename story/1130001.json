    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可是，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n「我想幫上大家的忙，該怎麼做才好？」",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n突然問這種事，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩聽了應該也會很困擾吧……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚嗚……",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_034"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我果然還是",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "該自己想辦法解決……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_035"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n真的",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒有什麼啦，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "請別太在意。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊…………",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_036"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩……",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_037"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n在擔心我……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "然而我卻",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對他說謊了……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……果然說謊是不行的！",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_038"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我得好好說出來才對！　",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前、",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_039"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前杯！！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n還是請你梯梯我的煩老！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_040"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我又大吃螺絲了啦～！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n偏偏在這種重要的時候～～！！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚嗚……",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_041"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真想乾脆學兔子，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n挖個洞躲起來算了……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩……",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_042"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n竟然願意溫柔對待這樣的我……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真的非常",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "謝謝你……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_043"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那麼，我……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我想和你商量的就是……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我……",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_044"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "希望自己能更加幫上大家的忙……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可是，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不管怎麼嘗試，都不順利……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然我可能無法在戰鬥時派上用場，",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_045"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n但希望也能以其他形式幫上忙……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "至少，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "想做些什麼事情來支援大家。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可是，",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_046"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我卻不曉得該怎麼……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗯？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩……！",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_047"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n你臉頰上的傷，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是怎麼回事！？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你說不曉得在哪被樹枝給刮傷了……",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_048"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "請、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "請稍等我一下！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這裡草木如此茂密，應該會有……",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_049"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "找到了！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "接著只要",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "輕輕咀嚼葉片幾下……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "唔……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "唔姆……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這樣應該可以了？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩！",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_050"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n請將這片嚼碎過的葉子",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "敷在傷口上！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有療傷的效果！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "欸嘿嘿，",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_051"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒想到竟然\n能以這種形式幫上{player}前輩",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "的忙……！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n真該好好感謝教導我藥草相關知識的媽媽呢。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是、",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_052"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是的，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "多少學了點……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n真的只學了最基礎的部分而已！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……我只是想說，如果簡單學點藥草知識，",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_053"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n或許就能幫上",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "大家的忙了。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "因為想多少盡一點力，",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_054"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以我還會做些其他事，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n像是出遠門時先幫忙準備好要用的東西。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不知不覺間，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "便養成了一種習慣……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "像這個，",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_055"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是我幫大家準備的水壺。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "欸嘿嘿，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我剛才在小鎮逛的時候，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一回神就不小心都買好了。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊……",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_056"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "順道一提，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我也會隨身攜帶點心唷。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一開始是因為莫妮卡看到點心會很開心，",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_057"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n不過給公會的大家吃後，也得到很不錯的評價。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "下次我想泡個茶，",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_058"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n舉辦簡單的茶會。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "要是大家喜歡就好了～",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦……",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_059"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為璃乃她們",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "辦茶會嗎？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……說的也是，",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_060"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n讓她們參加茶會放鬆一下，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "或許可以",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "達到支援的成效呢……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可、",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_061"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可是，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "像我這樣的人辦的茶會，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n璃乃她們也",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不曉得會不會中意……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩……",
        "unit_id": 113011,
        "voice": "vo_adv_1130001_062"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我明白了！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "要辦茶會！！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為了多少幫上大家的忙，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也要好好假柚！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──因為想成為大家的助力，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n步未下定決心要舉辦茶會，用自己的方式支援大家。"
    }
