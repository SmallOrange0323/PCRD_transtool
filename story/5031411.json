    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位，",
        "unit_id": 111911,
        "voice": "vo_adv_5031411_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "競速賽也快要到尾聲了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這個競速賽大家賭上了各自的信念，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "十分的白熱化。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在有點令人依依不捨呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被逼著穿和服參加競速賽，",
        "unit_id": 112011,
        "voice": "vo_adv_5031411_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都快累死了……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一想到這個蠢比賽終於要結束了，感覺就很痛快。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，",
        "unit_id": 111811,
        "voice": "vo_adv_5031411_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳又說那麼壞心眼的話了～",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拚命跑著的小凱留的表情，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有最後一起大喊的畫面，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我都會當成重要的回憶，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好好珍藏在心裡的！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吵、",
        "unit_id": 112011,
        "voice": "vo_adv_5031411_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吵死了！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　把那種回憶給我扔了！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 111911,
        "voice": "vo_adv_5031411_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼鈴莓小姐，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "妳身為競賽的主角，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請在最後向大家",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說句話吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸！",
        "unit_id": 112111,
        "voice": "vo_adv_5031411_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "　我、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我嗎！？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "　欸，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "各、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "各位！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "　請到最後都不要掉以輕心，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一起好好享受競速散拔！？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚、嗚哇哇哇！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "　我在最後的最後搞砸了！",
        "unit_id": 112111
    }
]