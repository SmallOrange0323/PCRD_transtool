        "name": "妮諾",
        "words": "是怎麼來的了是也！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我現在",
        "unit_id": 137111,
        "voice": "vo_adv_1371003_046"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "站著的地方",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是最佳位置……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n裝作不經意地誘導我到這裡，",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在最佳的時機點，",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n讓我站著不動……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這不是能輕易做到的事！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要是不預測我的行動，",
        "unit_id": 137111,
        "voice": "vo_adv_1371003_047"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "正確掌握裝置",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "噴水的時間，",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n就絕對無法做到。",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也就是說……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這",
        "unit_id": 137111,
        "voice": "vo_adv_1371003_048"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "毫無疑問是完美的忍法！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n是將軍",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "身為優秀忍者的證據！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是也！！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來吧，",
        "unit_id": 137111,
        "voice": "vo_adv_1371003_049"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "完美忍法的",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "最後收尾是也！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "做好心理準備吧！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看我的！",
        "unit_id": 137111,
        "voice": "vo_adv_1371003_050"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也要被水噴是也♪",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "畢竟是這麼漂亮的夏日忍法！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n就來一起享受是也！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看招！",
        "unit_id": 137111
    },
    {
        "type": "background",
        "background": "501050"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "明明才剛開始學習忍法，",
        "unit_id": 137111,
        "voice": "vo_adv_1371003_051"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n卻在這麼短的期間內",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就理解到忍法的精隨……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不愧是將軍！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "身為忠臣，",
        "unit_id": 137111,
        "voice": "vo_adv_1371003_052"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我非常高興是也♪",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "話說回來，",
        "unit_id": 137111,
        "voice": "vo_adv_1371003_053"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真是被將軍",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嚇了一跳。",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n居然讓我看到如此美麗的忍法。",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "想要",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在將軍身邊侍奉的想法",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "又更加強烈了。",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我明明打算讓將軍度過愉快的夏日，",
        "unit_id": 137111,
        "voice": "vo_adv_1371003_054"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n用最美好的回憶當作禮物給你的……",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這樣的話",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "還得再加把勁是也！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "下次，",
        "unit_id": 137111,
        "voice": "vo_adv_1371003_055"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一定會獻上能夠讓將軍",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "感到驚喜的禮物！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n絕對、",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "絕對是也！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……！",
        "unit_id": 137111,
        "voice": "vo_adv_1371003_056"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍……！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "五",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "體投地──",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍果然",
        "unit_id": 137111,
        "voice": "vo_adv_1371003_057"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是最適合統一天下的人是也♪",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "請讓我",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "侍奉你一生一世！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "見到{player}的忍法，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "加深了妮諾身為忠臣的決心。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n像是要確認兩人間變得更加深刻的羈絆一般，"
    },
    {
        "type": "dialogue",
