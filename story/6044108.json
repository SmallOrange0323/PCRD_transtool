[
    {
        "type": "background",
        "background": "501050"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我這次",
        "unit_id": 113111,
        "voice": "vo_adv_6044108_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "似乎太貿然行事了，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣不是很好呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有杏奈和七七香在，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真的幫大忙了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我都忘了，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有時候依靠他人或把事情交給他人處理，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也是必要的呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈，",
        "unit_id": 113111,
        "voice": "vo_adv_6044108_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我一直",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "都很依靠你啊。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你不需要擔心成那樣，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "放心吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……謝啦。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯，",
        "unit_id": 113111,
        "voice": "vo_adv_6044108_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是啊。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原本覺得她們老是在做傻事，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n都忘了她們是會在關鍵時刻",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "及時伸出援手的夥伴呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果平時能再稍微正經一點，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我會更開心就是了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我一個人旅行的時間太長了，",
        "unit_id": 113111,
        "voice": "vo_adv_6044108_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "已經習慣獨自行動了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不過雖說是被捲進去的，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我還是得到夥伴組成公會了呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "為了能慢慢改掉這習慣，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也想漸漸改變自己的觀念。",
        "unit_id": 113111
    }
]