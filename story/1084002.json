[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "到了約定交還嬰兒的時間，\n{player}與千歌一起拜訪蛋糕店。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哇……",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "聖誕節的蛋糕店，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還真是華麗呢。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n每個蛋糕都看起來好好吃……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "唉。",
        "unit_id": 1411,
        "voice": "vo_adv_1084002_001"
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "怎麼在這個時候……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "可惡。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哎，",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哎呀……？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n蛋糕店老闆，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "怎麼了嗎？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　臉色非常難看啊。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "咦？",
        "unit_id": 1411,
        "voice": "vo_adv_1084002_003"
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "　",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "啊啊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "是你啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "謝謝幫我看顧小孩。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "是嗎，",
        "unit_id": 1411,
        "voice": "vo_adv_1084002_004"
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "已經是這種時候了嗎……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "唉呀、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "讓你們看到陰暗的一面，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "真不好意思。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是發生什麼事了嗎？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "嗯……",
        "unit_id": 1411,
        "voice": "vo_adv_1084002_006"
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "遇上一點點小問題吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "其實，本來準備要運送聖誕節蛋糕前往蘭德索爾鎮外",
        "unit_id": 1411,
        "voice": "vo_adv_1084002_007"
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "\n但是路上湧出了大量的魔物，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "因此接到禁止通行的通知，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "\n不知道這下怎麼辦……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "怎麼這樣！",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那就是說，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要送這個蛋糕……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "就是這樣。",
        "unit_id": 1411,
        "voice": "vo_adv_1084002_009"
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "很多人是很早以前",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "\n就大老遠跑來蘭德索爾下訂單，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "\n就為了等這個蛋糕呢……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "聖誕節蛋糕，",
        "unit_id": 1411,
        "voice": "vo_adv_1084002_010"
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "是期待著聖誕節的家庭的",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "\n幸福象徵啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "想到得讓這些家庭，",
        "unit_id": 1411,
        "voice": "vo_adv_1084002_011"
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "過著寂寞的聖誕節",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "就感到既難過、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "又愧疚……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "…………",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，{player}。",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我們能不能",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "出力幫忙呢？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是啊。",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n如果是我們兩人，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "應該能順利將蛋糕送上門的！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　那個、",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你說堆放著太可惜這我知道，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但不是那個問題啦……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "比起那個、",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "應該要想辦法",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "將蛋糕送達至訂購的家庭手中！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "蛋糕店老闆，",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "能讓我們",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "幫您運送蛋糕嗎？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "你們要去啊？",
        "unit_id": 1411,
        "voice": "vo_adv_1084002_018"
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "你們志願幫忙我是很感謝，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蛋糕店老闆",
        "words": "但是要讓你們冒生命危險就……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請您放心吧。",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "憑藉{player}跟我的本事，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "肯定能守護等待著蛋糕的家庭們\n的笑容。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}。\n用唱喚術邊驅趕魔物、",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "或讓牠們睡著再同時前進，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n應該可以順利抵達目的地。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "來，",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "快準備開始送貨吧！",
        "unit_id": 108411
    },
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "魔物可不會在乎什麼聖誕節呢。",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然是理所當然的事。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖說是突發的現象，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是居然出現這麼大量的魔物……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總之",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要注意別把蛋糕壓爛，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "小心前進吧。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "打開盒子，發現裡面裝飾的聖誕老公公已經被壓爛……",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果發生這種事，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那就太悲慘了。",
        "unit_id": 108411
    },
    {
        "type": "background",
        "background": "500540"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在，",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "到了蘭德索爾與交貨地的中間地點吧。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n雖然弱小的魔物",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可以用唱喚術讓牠們睡著、",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但也差不多",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "會出現強大的魔物也說不定……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊、",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "出現了！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "魔物向這邊",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "襲擊過來了！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}請將力量借給我！",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我要使用更強的唱喚術，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "擊退那個魔物！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唔唔……",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "力量從身體深處湧出來的這股感覺，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}的能力，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真的好厲害……！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "風之精靈啊，",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_029"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "將魔物擊退吧……！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼、",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_030"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然有點搖晃，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "蛋糕都沒事吧？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "看起來是沒問題呢。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "太好了。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊、",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_031"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "看到房子了呢！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　那邊就是交貨地點！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不好意思。",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_032"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "從蘭德索爾",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "訂購的蛋糕，已經送達了～",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "哇……！",
        "unit_id": 111,
        "voice": "vo_adv_1084002_033"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "　媽媽，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "是聖誕節蛋糕！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n特地為我們送來了耶！！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "哎呀呀……",
        "unit_id": 1511,
        "voice": "vo_adv_1084002_034"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "聽說今年出現很多魔物，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n還想說只能放棄了呢……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "感謝你們，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "將蛋糕送來！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "　真的很高興啊！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "聖誕老公公、",
        "unit_id": 111,
        "voice": "vo_adv_1084002_035"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "謝謝！！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "耶？",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_036"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　啊、不、",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不客氣。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "能讓您高興真是太好了。",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_037"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "來、",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "前往下一個家庭吧！",
        "unit_id": 108411
    },
    {
        "type": "background",
        "background": "500541"
    },
    {
        "type": "still",
        "still": "108400201"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "能平安地、",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_038"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "將蛋糕送達至全部的家庭，真是太好了。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我想現在每個人，",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_039"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都能夠一起度過\n幸福的聖誕節時光吧……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵。",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_040"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有許多人",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都對我們說、",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "聖誕老公公",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n謝謝你呢。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……{player}是聖誕老公公的話",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_041"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n那我就是馴鹿了嗎。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然鼻子是紅的。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我的唱喚術",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_042"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "能夠幫助這麼多的人，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我覺得非常高興。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵，",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_043"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只要想到大家幸福的表情，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n就覺得很滿足。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n真的是，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "太好了……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對了。",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_044"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果也能對精靈們，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n表達感謝的心情就好了……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "看來，",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_045"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要說我能做的事情，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就是唱歌……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對吧。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝。",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_046"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n當我唱歌時，{player}",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你要來聽喔。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哎呀？",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_047"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　在空中飛舞的精靈們都靠過來了。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵、",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不要那麼急嘛。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我也還沒決定要唱什麼呀。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "給我",
        "unit_id": 108411,
        "voice": "vo_adv_1084002_048"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一點點時間喔。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我會將發至內心的歌聲，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "當作禮物。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌這麼說著，嬌顏泛起了笑靨。"
