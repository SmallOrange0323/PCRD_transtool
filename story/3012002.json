[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正在森林裡進行公會任務時。\n{player}被莫妮卡一行人包圍了。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你可不要怪我。閣下的力量是把雙刃劍。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要是交到其他冒險者或壞人手上，會構成威脅。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "作為榮耀的純白之翼一分子，",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我必須要斬了閣下才行。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不、不能再給虐待狂先生欺負了……",
        "unit_id": 104511,
        "voice": "vo_adv_3012002_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "有、有點可惜呢……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過這也是沒辦法呢？",
        "unit_id": 100811,
        "voice": "vo_adv_3012002_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對我造成的危險，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也就是全人類的危機！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍，統一天下的任務，",
        "unit_id": 103011,
        "voice": "vo_adv_3012002_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就交給妮諾吧。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼，大家要上囉！",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "做好覺悟吧～！",
        "unit_id": 105311
    },
    {
        "type": "still",
        "still": "301200201"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不、",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不可以！",
        "unit_id": 105511
    },
    {
        "type": "still",
        "still": "301200202"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "奇、奇怪……",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒有被砍……？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……哼哼。",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳終於現身了，可惡的刺客。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下，這個傢伙的臉孔，",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n你可有看過？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "和、和我想像中的人不太一樣……",
        "unit_id": 104511,
        "voice": "vo_adv_3012002_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真的呢，",
        "unit_id": 100811,
        "voice": "vo_adv_3012002_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果是個虎背熊腰的大叔，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就能更進一步突顯我的可愛了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是女忍者呢！",
        "unit_id": 103011,
        "voice": "vo_adv_3012002_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好帥氣呀。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦……",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_013"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "大家千萬別大意。",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "他可是擁有能將自己的身影與存在感幾乎抹滅掉，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n並從暗處緊盯我們的功力的高手。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……哎、哎呀？",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這、這該不會是──",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "大家聽好！",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n趁現在把她抓起來！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要上囉。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是陷阱啊──！",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哇呀─！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "──從好幾天前開始，",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這傢伙感覺自己好像被某人盯著，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以他來找我商量。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯嗯，目的倒是蠻容易想像的。",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n畢竟這傢伙的特殊能力，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n擁有被人盯上的價值。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過呢，我認為由我們",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n主動出手實在有些危險，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n所以就訂了一個計畫。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果目標是這傢伙的能力，",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n那他被殺掉的話會很麻煩吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以我才故意裝成同伴內鬨的樣子……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚……哭哭……哭哭。",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼……妳也差不多該停止哭泣",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n把所有事情都老實地交代清楚吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳為什麼會盯上這傢伙？",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n妳的委託人是誰？其他國家嗎？還是冒險者公會？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳又是誰？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……這個問題……嗯……那個……",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這個……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來如此……看來妳口風蠻緊的。",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_026"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好吧。那我只能想辦法讓妳說出來。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n交給妳了妮諾。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "包在我身上。忍法・搔癢地獄之術！",
        "unit_id": 103011,
        "voice": "vo_adv_3012002_027"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咻趴！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哇呀！啊、等……啊……",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊哈哈……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n等一下，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊哈哈哈……好癢呀……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "快～說快說。",
        "unit_id": 103011,
        "voice": "vo_adv_3012002_029"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "討厭……不行……",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_030"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊哈哈……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳不說的話會持續一輩子呦。",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_031"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣沒有關係嗎──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不、不然的話，",
        "unit_id": 104511,
        "voice": "vo_adv_3012002_032"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n換空花被騷癢也是可……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "換成妳是要幹嘛！",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_033"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我說我說，",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_034"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對不起……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "拜託請快住手吧……嗚嗚。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……我並沒有惡意的。",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_035"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n請大家相信我。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒惡意的話怎麼會二十四小時跟著，",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_036"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n妳到底有什麼目的？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "別以為這種藉口我會相信──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不是這樣的！",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_037"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……那個……我……只是……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "前、前輩……咕噥咕噥……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，妳說啥？",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_038"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n妳聲音太小我聽不清楚。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以說……我對前輩他……",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_039"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咕噥咕噥……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這、這是不好說出口的事情嗎？",
        "unit_id": 104511,
        "voice": "vo_adv_3012002_040"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是沒辦法，",
        "unit_id": 100811,
        "voice": "vo_adv_3012002_041"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我將耳朵借給妳一下吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……什麼什麼。",
        "unit_id": 100811,
        "voice": "vo_adv_3012002_042"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為想要看前輩。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "前、前輩該不會是指……",
        "unit_id": 104511,
        "voice": "vo_adv_3012002_043"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是……是的……",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_044"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "──啥啊！？",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_045"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊啊！",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_046"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n請不要這麼大聲──",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒問題。妳不用擔心",
        "unit_id": 100811,
        "voice": "vo_adv_3012002_047"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我能夠理解你的心情。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我也是一樣的。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不管在哪不管做啥我都是這麼的可愛，",
        "unit_id": 100811,
        "voice": "vo_adv_3012002_048"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我想要欣賞可愛的自己想到無法忍受。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒有錯，我愛上了我自己呀！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……閣下的名字叫什麼？",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_049"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……我的名字是步未。",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_050"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "步未，妳真的只是為了這個原因而已？",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_051"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……是的。",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_052"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這麼說的話──",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_053"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來妳只是一個跟蹤狂呀！？",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_054"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "什、什麼跟蹤狂……",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_055"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我只是想……遠遠地看著前輩",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n這樣我就感覺非常幸福了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "社會上把這種人叫做跟蹤狂啦。",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_056"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是的……我本來以為",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_057"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n妳是其他國家或公會派來的刺客，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n根本沒必要這麼認真呀。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唉……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、那個……既然如此我就……",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_058"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒事了……",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_059"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳想去哪就去哪吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "謝，謝謝妳──",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_060"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "等一下！妳蠻有當忍者的才能呢。",
        "unit_id": 103011,
        "voice": "vo_adv_3012002_061"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "讓我們以統一天下當作目標一起前進吧～",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦……？",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_062"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什…喂！妳別隨便招募人。",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_063"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我才是公會長呀。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我倒是怎樣都沒關係。",
        "unit_id": 100811,
        "voice": "vo_adv_3012002_064"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果能戰鬥的人增加了，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那我可以欣賞自己的時間也能夠增加吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空、空花也沒有關係呦。",
        "unit_id": 104511,
        "voice": "vo_adv_3012002_065"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "而且我總覺得，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n步未和我有種同類的感覺……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……這樣下去我的煩惱可又要增加了──",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_066"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣、閣下覺得如何呢？",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_067"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n他可是一直跟蹤你的人呦？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩……",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_068"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎、",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_069"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎樣會這樣……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "謝、謝、謝謝謝謝你……！",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_070"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、我會、卯足全力加油的！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦？前、前輩！？",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_071"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這是請多指教的握手嗎……！？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚……",
        "unit_id": 105511,
        "voice": "vo_adv_3012002_072"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚喔喔……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "步未暈倒啦！",
        "unit_id": 103011,
        "voice": "vo_adv_3012002_073"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "沒、沒問題嗎？",
        "unit_id": 104511,
        "voice": "vo_adv_3012002_074"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……嗚嗚，",
        "unit_id": 105311,
        "voice": "vo_adv_3012002_075"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "前途一片黑暗呀……",
        "unit_id": 105311
    }
]