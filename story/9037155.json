        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n開始感到上癮了呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了呢☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確，",
        "unit_id": 105911,
        "voice": "vo_adv_9037155_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然一開始是覺得很噁心，",
        "unit_id": 105911
