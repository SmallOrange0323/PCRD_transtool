        "voice": "vo_adv_9037155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管怎麼想，這滑溜溜的感覺有夠噁心吧！？",
