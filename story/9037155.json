        "type": "dialogue",
        "name": "凱留",
        "words": "這樣子……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的確好像還不錯呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n把這裡像這樣子弄的話……",
        "unit_id": 106011
    },
