[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "終於找到了！",
        "unit_id": 106011,
        "voice": "vo_adv_9037155_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這傢伙實在是",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一到水裡就軟綿綿的，都沒地方抓，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n有夠難找的～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過我",
