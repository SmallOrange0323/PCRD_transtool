[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒想到",
        "unit_id": 105911,
        "voice": "vo_adv_5084308_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其中竟有如此強悍的魔物在……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐，",
        "unit_id": 106411,
        "voice": "vo_adv_5084308_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "快退下！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n前衛由我一個人負責就好……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下無法答應。",
        "unit_id": 105911,
        "voice": "vo_adv_5084308_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這隻魔物，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "攻擊力道相當強大……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若只靠一人擋下其攻擊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "未免太過危險。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是，",
        "unit_id": 106411,
        "voice": "vo_adv_5084308_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "如果妳被打中那麼一下，恐怕……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──這點大家都一樣吧。",
        "unit_id": 106011,
        "voice": "vo_adv_5084308_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐！？",
        "unit_id": 105911,
        "voice": "vo_adv_5084308_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請退下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您到前方會太……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不，",
        "unit_id": 106011,
        "voice": "vo_adv_5084308_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是這種時候，才更應該大家都到前方。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然情況對所有人來說都一樣危險，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼大家一起分攤，就好了呀。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只要我們同時",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "互相支援對方，就不會有問題。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要所有人一起往前進攻嗎！？",
        "unit_id": 106411,
        "voice": "vo_adv_5084308_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這種如履薄冰般的危險策略，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n若不夠有默契，恐怕無法配合對方的動作……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……默契的話，",
        "unit_id": 105911,
        "voice": "vo_adv_5084308_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有問題。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下說得沒錯吧，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 106011,
        "voice": "vo_adv_5084308_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "當然囉。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……雪菲，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道妳沒自信辦到嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……！",
        "unit_id": 106411,
        "voice": "vo_adv_5084308_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "辦得到，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我會做到的……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳可不要落後囉，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "準備上了！\n要上了！\n上吧！",
        "unit_id": 1,
        "voice": "vo_adv_5084308_011"
    }
]