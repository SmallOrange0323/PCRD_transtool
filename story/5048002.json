    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "怎麼會這樣？",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "沒、",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "沒看過這種效果啊！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "使用手冊裡面……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "也沒有相關說明……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "咦？",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "咦？",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不會吧？",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_001"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我就這樣被變成茜里？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這這、",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這下該怎麼辦啊……！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "喔～",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_002"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "這就是姊姊的身體嗎。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n雖然纖細到有點缺乏安全感，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "不過感覺還不賴嘛♪",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "欸，拉菲！",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_003"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "妳都做了些什麼呀！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n這魔法完全失敗了吧！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "呃，",
        "unit_id": 5511,
        "voice": "vo_adv_5048002_004"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這個嘛……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "妳、",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "妳放心，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這不是失敗啦！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n這只是……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "對了，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "是故意的！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我本來就是要施展這樣的魔法啦！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "那、",
        "unit_id": 5511,
        "voice": "vo_adv_5048002_005"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "那只是為防萬一，稍微確認一下而已……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "咦？",
        "unit_id": 5511,
        "voice": "vo_adv_5048002_006"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這個嘛……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "那、",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "那是祕密！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n天使的魔法都是企業機密，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "不能隨便地",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n洩漏給其他人！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "總、",
        "unit_id": 5511,
        "voice": "vo_adv_5048002_007"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "總而言之！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這絕對不是什麼失敗！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n依里接下來",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "一定能得到幸福才對！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n因為拉菲我可是名資優生天使！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "那、",
        "unit_id": 5511,
        "voice": "vo_adv_5048002_008"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "那麼我差不多該去巡邏了，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "先走一步囉～！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "咦，",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_009"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "拉菲？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "喂！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "妳不要走！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "吼唷真是的，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "又被她給逃了……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這下該怎麼辦啊！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "先放輕鬆吧，",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_010"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "姊姊。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "現在再追也追不上她的。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "話說回來",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_011"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我們竟然身心互換了！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n那個小女孩",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "還真的是個天使呢。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "這種漫畫情節般的事",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_012"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "以後應該一輩子都碰不上了，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我們就好好享受這難得的體驗吧！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "……這種情況下還有辦法這麼說，",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_013"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我真是服了妳耶。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不過",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_014"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這就是我跟茜里的差異吧。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n無論何時都不悲觀，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "帶著勇氣積極行動。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "真羨慕她這樣的個性……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "對了，",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_015"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "既然變成了茜里的外貌，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n那麼我好歹也該",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "讓自己進步一些。",
        "unit_id": 113712
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "茜里，",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_016"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "假設接下來還得身體互換一陣子，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n妳有什麼能讓我們渡過難關的好點子嗎？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "嗯？",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_017"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "關於這點……",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "哥哥，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "幫我們想想♪",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "妳喔……",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_018"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "哇～！",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_019"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "哥哥真是好主意！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "也、",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_020"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "也對，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "畢竟接下來總不可能都不跟人接觸。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "……也就是說，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我得模仿茜里的一舉一動嗎！？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "要我做出光是想像就快昏倒的",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_021"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "那些發言和行為……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不、",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不行不行！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我死也辦不到啦～！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "……姊姊，",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_022"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "妳排斥成這樣子，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n實在讓茜里有點受傷耶。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "嗚……",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_023"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "對、",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "對不起。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "可是啊，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "茜里妳的發言總是有點……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n不對，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "非常地遊走在尺度邊緣啊……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "咦！",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_024"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "會嗎？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n這我自己不太清楚呢，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "哥哥也有這種感覺嗎？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "問他也是白問的好嗎。",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_025"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "好吧，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不清楚的話就算了……",
