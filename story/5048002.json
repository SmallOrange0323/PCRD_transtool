        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n其實遇見拉菲那時我就覺得，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "她其實",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "跟姊姊好像有點像耶？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "咦？",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_048"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我們",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "一點也不像吧？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n妳在說什麼莫名其妙的話啊？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "咦～？",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_049"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我說真的啦，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "妳們兩個很像喔～",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "雖然如果要問哪裡像，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我也說不上來就是了。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "到底是怎樣啊……",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_050"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "嗯……",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_051"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "她明明看起來缺乏自信，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n卻堅稱自己是個資優生，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n實在叫人搞不太懂她……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我跟拉菲很像……",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_052"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "嗎……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n若要說我們哪裡像……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "先別說這些了。",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_053"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "姊姊！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n其實我",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "下星期要參加一場戶外音樂節。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "咦？",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_054"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "音、",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "音樂節？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "嗯，",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_055"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "到時會跟哥哥認識的女生一起參加。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "對方",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "可是那位超級名模鈴奈喔！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "很大咖對吧！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "超、",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_056"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "超級名模？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "那傢伙就算人面再廣，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n也不可能認識那樣的名人吧。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n我看",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "八成只是名字一樣而已。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "真是的，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "玩笑也開太大了。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "難得有這樣的機會，",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_057"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "拒絕也挺可惜的。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "妳也這麼認為吧？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "姊姊。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "……咦？",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_058"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "茜里妳先等等。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n妳的意思是說，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "要我去參加音樂節嗎？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不行不行！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這我絕對沒辦法啦！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "沒問題的，",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_059"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "姊姊妳現在",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "可是我的外表。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "一定行的啦！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "啊，",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_060"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "對、",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "對了！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我下星期也得參加一場線下聚。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "所以不好意思，去音樂節這件事妳還是死心吧！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "參加線下聚？",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_061"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "姊姊妳",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "打算用那樣的外表參加嗎？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "啊，",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_062"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "對喔……！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我現在也是茜里妳的外表……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "沒辦法，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我會去把線下聚的約推掉，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n茜里妳也忘了音樂節吧。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "你、",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_063"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "你這個蠢蛋！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "出這是什麼餿主意嘛！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n茜里她再怎樣",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "也不可能突然代我參加線下聚吧？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "……嗯，",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_064"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "這主意不錯耶！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "茜、",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_065"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "茜里！？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我們這次",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_066"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "難得互換身體不是嗎？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n要是不趁機會體驗這些情境，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "豈不是太可惜了嗎！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "呃，",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_067"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不是這個的問題吧……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "呵呵，",
        "unit_id": 113812,
        "voice": "vo_adv_5048002_068"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "參加線下聚這種事",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "還真是心動初體驗呢♪",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "包在我身上！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "茜里會用力地跟大家推銷姊姊的優點喔！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "拜託不要──！",
        "unit_id": 113712,
        "voice": "vo_adv_5048002_069"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，依里和茜里將身體互換的事保密，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並前往參加彼此的活動。"
    }
]