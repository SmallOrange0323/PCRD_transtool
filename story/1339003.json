        "words": "一邊哼歌一邊小跳步跑過也是理所當然的吧☆",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "回去之後會幫你設計肌力訓練的項目，",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n好好期待吧♪",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼……",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要繼續演出這場撤退戰拖著她們跑，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n再一一解決也是可以……",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但我差不多覺得膩了。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在小子受傷前收拾掉吧！",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──幫我強化！",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就來蹂躪妳們吧☆",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_064"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n──虛數魔境！",
        "unit_id": 133911
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呼……",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_065"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣就一掃而空了呢。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "從作為遮蔽物的樹木後面",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "發動大火力的掃蕩攻擊，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n即便用絕對防禦也無法擋下吧。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "物件越多細節，演算就需要花越多時間。",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_066"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在充滿細小物件的森林中，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雙方都會增加不確定因素。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果是同樣不穩定的狀況下──",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_067"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n攻擊強的那一方更有利。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是這麼簡單……♪",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "辛苦了，",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_068"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "多虧了小子讓我這次玩得很開心。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然之前也和冒牌的自己戰鬥過，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但數量這麼多的還是第一次呢。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是稍微搞錯撤退戰的路線，",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_069"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算死掉也不奇怪。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "久違地感受到了刺激的生命危險呢♪",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_070"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很棒的刺激，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "感覺可能會有點上癮。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n像這樣賭上性命的惡作劇可不常見啊……",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你那是什麼表情，",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_071"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對明明有生命危險，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n卻看起來很愉快的我感到不可思議嗎？",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我還以為",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子可以理解我呢。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼，",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_072"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是圓滑的回覆，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過算了。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n平時的話可能會給你打個及格分……",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但最後，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再回答我一個問題。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_073"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我總是表現得很愉快的原因，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你知道是什麼嗎？",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼嗯，",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_074"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然直接告訴你答案很簡單……",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但那樣就太無趣了☆",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們回去村子吧，",
        "unit_id": 133911,
        "voice": "vo_adv_1339003_075"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子！",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n答案就在那之後再公布☆",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，{player}沒能得到克莉絲提娜出的謎題答案，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n只好跟在她的身後。"
