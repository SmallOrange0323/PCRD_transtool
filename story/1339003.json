    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和克莉絲提娜兩人，\n行走在被破壞的蘭德索爾的街道上。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是被大肆破壞了呢。",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不過，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這裡也算是跨越過無數次危機的地方了。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "該說是鉅細靡遺，",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "又或者是",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "細心縝密。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯嗯。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個嘛，",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n稍微回想起",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "幾天前發生的事了。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然最後",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "阻止了還原。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但世界卻被破壞得",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不堪入目☆",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不愧是",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以七冠為原型的複製體。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟然這麼執著地徹底破壞，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來是巧妙地利用了我們的資料，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就算是敵人，這點還是值得稱讚呢。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "到處都變成這副模樣，",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n曾以美麗街景為傲的蘭德索爾也變得慘不忍睹。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "乾脆就在這裡",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "建立新的城市……",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我覺得",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個想法",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也不錯呢。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是吧，小子？",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈，",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是率直的感想☆",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你的這種個性，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我打從心底覺得喜歡。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我？",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我嗎……",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這個嘛，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在小子的眼裡看起來如何？",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔，",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你是這麼認為的啊。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "感想稍顯平凡，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但也不錯，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n算你及格吧☆",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "引頸期盼、",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "夢寐以求的非日常",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n突然就在眼前實現了，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼可能會不愉快？",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一開始了解事情始末後，",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n別說是興奮了，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我甚至可以說是深受感動。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……與此同時，",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "卻也感到很不滿。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……沒想到我的情緒，",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "居然會如此動搖。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……好，",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我決定了。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們現在要離開這裡，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "跟我來。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "玩完以後，",
        "unit_id": 133912,
        "voice": "vo_adv_1339003_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "得要好好收拾善後才行呢。",
        "unit_id": 133912
    },
    {
        "type": "background",
        "background": "500333"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克莉絲提娜帶著{player}前往的地方，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n是在蘭德索爾郊外的某座村莊。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……是",
        "unit_id": 107111,
        "voice": "vo_adv_1339003_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "被那些假七冠破壞的村莊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "即使離王都中心這麼遠，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "損害也相當嚴重呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來沒有其他人。",
        "unit_id": 107111,
        "voice": "vo_adv_1339003_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣子正好，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可以毫無顧忌地大鬧一場了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為什麼要來這裡，",
        "unit_id": 107111,
        "voice": "vo_adv_1339003_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你看起來很好奇呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "馬上就能知道了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "本來想這樣說的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但我就直接告訴你答案吧☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "明明一切都結束了──",
        "unit_id": 107111,
        "voice": "vo_adv_1339003_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "卻還有",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不知道祭典已經落幕的蠢蛋們，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n繼續開著派對，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以我來搞破壞了♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……這怎麼看，",
        "unit_id": 107111,
        "voice": "vo_adv_1339003_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都是最適合我的工作吧☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼──",
        "unit_id": 107111,
        "voice": "vo_adv_1339003_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "情況如何。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔，",
        "unit_id": 107111,
        "voice": "vo_adv_1339003_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子的直覺也很敏銳呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n明明空無一人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "卻飄散著詭異的緊張感。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "究竟有什麼東西潛藏著呢……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔！",
        "unit_id": 107111,
        "voice": "vo_adv_1339003_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n──快躲開！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "等等再說，",
        "unit_id": 107111,
        "voice": "vo_adv_1339003_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "先撤退。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……快點。",
        "unit_id": 107111,
        "voice": "vo_adv_1339003_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……看來是一群沒耐心的傢伙們，",
        "unit_id": 107111,
        "voice": "vo_adv_1339003_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真高興，和我很合得來呢……☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是我。",
        "unit_id": 107111,
        "voice": "vo_adv_1339003_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──而且是",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無數個我。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "………………",
        "unit_id": 1,
        "voice": "vo_adv_1339003_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈，",
        "unit_id": 107111,
        "voice": "vo_adv_1339003_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "腦袋拒絕理解……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
