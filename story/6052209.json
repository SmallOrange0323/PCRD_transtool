    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "魔法少女最耀眼的瞬間，",
        "unit_id": 114311,
        "voice": "vo_adv_6052209_000"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "果然是獲勝後",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "擺出招牌姿勢的時候吧！",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "有很多姿勢想要先想好，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "像個人用的姿勢之類的……",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "你可以幫我看一下嗎？",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "有想看的姿勢？",
        "unit_id": 114311,
        "voice": "vo_adv_6052209_001"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "好啊，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "我擺給你看。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "啊，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "不過太大膽的姿勢不行喔。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n畢竟我穿的是裙子……",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "那個……",
        "unit_id": 114311,
        "voice": "vo_adv_6052209_002"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "雖然是我叫你看的，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n但你這樣猛盯著看，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "我也是會害羞的……",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n心跳得好快，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "姿勢都擺得不俐落了啦……",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "你也想一起來？",
        "unit_id": 114311,
        "voice": "vo_adv_6052209_003"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "呵呵，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "我就知道你會這麼說。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "咦！？",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "等等，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "幹嘛把我抱起來啊！？",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "不過，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "這樣好像……",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "也不錯……",
        "unit_id": 114311
    }
]