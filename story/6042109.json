[
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "せんぷぁ～い……",
        "unit_id": 110911,
        "voice": "vo_adv_6038109_000"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "メルクリちゃんの資金援助、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "もらい損ねました……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "企画自体は良かったはずなんですけど、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "プレゼンって難しいですねえ。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ちょっと先輩もやってみてください。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "自分の長所をＰＲするんです。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "強い……",
        "unit_id": 110911,
        "voice": "vo_adv_6038109_001"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "でしたっけ？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "あ、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "精神的にってことです？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "それならまあ。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\nうちら着替えよっかーみたいな流れになっても、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ぼけーっとして\n教室から一向に出て行く気配ないトコとか",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "「強っ！」て思いますけど。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "あー、",
        "unit_id": 110911,
        "voice": "vo_adv_6038109_002"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "いいですよね「優しい」。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "強いとか賢いとか何々が得意とかは、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n努力だったり才能だったりが必要ですけど、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "優しいだけは何も要らない、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n誰でも自称した瞬間に獲得できる、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "実質ただの「無」ですもんね！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "大謙虚！　",
        "unit_id": 110911,
        "voice": "vo_adv_6038109_003"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "なるほど、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "その奥ゆかしさは確かに先輩の長所かもです。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "いますもんね、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "世間の評価４０～５０点なのに何故か８５点ぐらいの\n目線からモノ申してくる人。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "自己肯定感は先輩ぐらいが丁度よきですね。",
        "unit_id": 110911
    }
]