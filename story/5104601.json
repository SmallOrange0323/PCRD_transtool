        "voice": "vo_adv_5100601_011"
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "ちょっと前に、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "次の旅は深い山奥、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "ってお手紙が届いてたもんね。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "『だよな。",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_012"
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "やっぱり気のせいだよな！",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "\nバロメッツが、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "こんなところにいるなんて』",
