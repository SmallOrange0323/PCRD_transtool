    },
    {
        "type": "dialogue",
        "name": "女の子",
        "words": "って思ったんだよ。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女の子",
        "words": "\n怖くって",
        "unit_id": 211
    },
