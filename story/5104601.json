    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "何より……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "劇団のみんなにまた会えるのが\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "私はすっごく楽しみなんだ！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "『あぁ！　",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_006"
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "俺も同じ気持ち……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "ん？』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "マホ",
        "words": "ぷうきちはん？　",
        "unit_id": 101011,
        "voice": "vo_adv_5100601_007"
    },
    {
        "type": "dialogue",
        "name": "マホ",
        "words": "どないしはったん？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "『……いや。",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_008"
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "気のせいだ。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "\n一瞬あいつがいたような気がして、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "な……』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "マホ",
        "words": "あいつ言うんは、",
        "unit_id": 101011,
        "voice": "vo_adv_5100601_009"
    },
    {
        "type": "dialogue",
        "name": "マホ",
        "words": "バロメッツはんのこと？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "『あぁ。",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_010"
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "けどあいつは今旅に出てるし、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "\nいくらなんでも、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "偶然こんなところで会うわけないよな』",
