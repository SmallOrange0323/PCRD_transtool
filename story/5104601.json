    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "いかにも俺がぷうきち様だぜ！",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "\n早速俺のファンがいるのかよ……",
