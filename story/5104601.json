    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "よく晴れたある日。"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n{player}たちは、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "音楽劇団の公演を手伝うために\n村の劇場に向かっていた。"
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "それにしても、",
        "unit_id": 102311,
        "voice": "vo_adv_5100601_000"
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "まさかぷうきちが音楽劇に出る日が来るなんてね！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "『お？　",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_001"
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "なんだ？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "\nムーサの町での俺の活躍を忘れたのかー？』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "忘れるわけないよ！",
        "unit_id": 102311,
        "voice": "vo_adv_5100601_002"
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "あの時のぷうきち、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "かっこよかったもん！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "『あの時はマホの姫さんも、",
        "unit_id": 2111,
        "voice": "vo_adv_5100601_003"
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "アヤネも頼もしく見えたぜ？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "\n二人がいてくれたから、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "俺も音楽劇に出るって、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "ぷうきち",
        "words": "腹を決めたんだ』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "マホ",
        "words": "そうやったんやねえ。",
        "unit_id": 101011,
        "voice": "vo_adv_5100601_004"
    },
    {
        "type": "dialogue",
        "name": "マホ",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "マホ",
        "words": "あの時は",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "マホ",
        "words": "劇団のお人も、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "マホ",
        "words": "ずいぶん喜んでくれはって。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "マホ",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "マホ",
        "words": "またこうして会えるなんて、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "マホ",
        "words": "うれしいご縁やなぁ。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "そうそう、",
        "unit_id": 102311,
        "voice": "vo_adv_5100601_005"
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "そうなんだよね！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "アヤネ",
        "words": "\n音楽劇も楽しみだけど、",
        "unit_id": 102311
