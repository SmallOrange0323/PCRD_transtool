    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔……",
        "unit_id": 113211,
        "voice": "vo_adv_6044304_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯？，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎麼？吉格魯特，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你願意",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "聽我的煩惱啊？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真不愧是吉格魯特。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對象是你的話，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "說出來應該也無所謂。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "其實……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我打算買伴手禮",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "給惠理子和深月，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你覺得什麼比較好？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哦……",
        "unit_id": 113211,
        "voice": "vo_adv_6044304_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這雖然很普通，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "卻有種很吸引人的感覺……！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "明明沒感受到什麼魔力，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "卻不知道為何讓人很想要……！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這個的話，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "相信那兩人也肯定會喜歡吧！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "感謝你，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "祈願竹饅頭……",
        "unit_id": 113211,
        "voice": "vo_adv_6044304_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還有這種東西啊。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "拿來當作伴手禮",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "的確是很簡單明瞭，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n但我身為熾炎戰鬼煉獄血盟暗黑團的團長，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "送這個真的好嗎……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "惠理子和深月會喜歡的東西啊。",
        "unit_id": 113211,
        "voice": "vo_adv_6044304_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我說，吉格魯特。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "可以把你身體的一部分",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "送給我嗎？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "例如頭髮之類的。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不對，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我在想些什麼啊！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "抱歉，吉格魯特！",
        "unit_id": 113211
    }
]