[
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "{player}たちとの戦いに敗れたノウェムとオクトー"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n街に戻ってもノウェムは悔しさを爆発させていた。"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "うぎーっ！　",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_000"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "また負けたぞコンチクショー！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "いやいや、",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_001"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "強かったねぇ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "まさかあそこからあんな粘るなんて、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n今回はボクらの完敗だよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "今回は、",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_002"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "じゃない！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n今回も、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "だろ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "あれぇ？　",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_003"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そうだっけ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "昔のことはよく覚えてないなぁ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ヘラヘラすんな！",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_004"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nアタシたち負けたんだぞ？　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "もっと悔しがれよ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "んー、",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_005"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そうは言ってもさ、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "勝負事なんて",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "負ける時は負けるもんだよ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクだって",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_006"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "別に負けに行ってるわけじゃないよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nこれでも勝つために",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "色々考えてるんだからね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "でも、",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_007"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "勝負は水物だからね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "万全で挑んで",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "勝利目前だったとしても、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nわずかな要因でひっくり返されるなんて",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "よくあることだよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "だからボクは勝つための努力は惜しまないけど、",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_008"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nその後の結果までは",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "高望みしないよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "逆にノウェムが",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_009"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そこまで必死になる意味が",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクには分からないよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "もっと気楽にいけばよくない？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そうか、",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_010"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "分からないか……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "なら教えてやるよ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "負けたら面白くないに決まってるだろ！",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_011"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシは勝って、",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_012"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "気持ちよく高らかに笑いたいんだよ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "負けても次がんばろうなんて、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ちっとも面白くないだろ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "戦いは",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_013"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "全部勝つ！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "それがアタシの生き方だ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "はぁ……",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_014"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "疲れそうな生き方だね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクには到底できそうにないよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ふん、",
        "unit_id": 106114,
        "voice": "vo_adv_5110603_015"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オマエに分かってもらおうなんて思ってないからな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nアタシはもう寝るから、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "次は勝てるようにそのおかっぱ頭ひねっとけ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "やれやれ、",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_016"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "困った子だね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "でも、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "その真っすぐさは",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "結構うらやましいんだよ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ノウェムには、",
        "unit_id": 106211,
        "voice": "vo_adv_5110603_017"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクにはできない生き方を",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "どこまでも貫いてほしいから、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクはどこまでも",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "嫌味なおかっぱ野郎でいくとしますかね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "去り行くムイミの背中にそっと語りかけるオクトーだった。"
    }
]