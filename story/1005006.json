    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真的嗎？",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_044"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n你不是隨便說說的吧，{player}？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我可以相信你吧？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是、",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_045"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是沒錯啦……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "滿是泥巴的衣服和魔法少女的Cosplay，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_046"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不知道哪一邊會比較失禮！",
