        "voice": "vo_adv_1005006_049"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n英雄無論面對什麼困難都絕不會逃跑。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我去換上",
