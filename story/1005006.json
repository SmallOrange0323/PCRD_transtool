    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哦……",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_035"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n生活在這座牧場中，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一個叫做小鈴的人，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n中了什麼獎品之類的是嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "「因為不想自己穿，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_036"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但又覺得丟掉有點不太好，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n如果你收下她會很開心～」",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一邊說著就強塞給你了是嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好、",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_037"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好像在垃圾回收一樣……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那個，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要穿",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這個嗎……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "再、",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_038"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "再更像普通穿著的衣服",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "會比較好！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然我添了這麼多麻煩，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也不太好一直抱怨！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊嗚嗚……？",
