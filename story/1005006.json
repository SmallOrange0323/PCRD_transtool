[
    {
        "type": "background",
        "background": "500151"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哦哦！",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你看你看，{player}！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我們終於到達牧場了～☆",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "暫時放心了！",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哎呀，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "比想像中要遠得多！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n明明一大早就從城裡出發了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "現在太陽都快西沉了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "耶嘿嘿。",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "畢竟途中下了大雨，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n讓我們沒辦法再繼續往前走了呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然說比返回城裡還要近，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n但走山路還是走得很辛苦。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "途中還後悔了好幾次。",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這山路遠比我所想像的，要來的險峻。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在走這條因為大雨而變得濕滑的山路時，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_005"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為了要注意不要滑倒，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以都慢慢地走……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "估計因此，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "花了不少多餘的時間。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "看起來，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要在太陽完全西沉前下山似乎是沒辦法了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n只能拜託牧場的人，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "讓我們借住一晚了……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要是在深夜裡走山路的話，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_007"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n可是會遇難的。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "得用傳信鴿",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_008"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "或通訊魔法，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n聯絡家裡說",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "「今天不能回去了」才行。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不然爸爸和媽媽，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "會擔心的。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為不管怎麼說，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我都想完成任務，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n而且也得見見牧場的人才行。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我看看，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "牧場的人會在哪裡呢？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "會是在對面看見的",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那棟建築物裡嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "總而言之先去看看，\n{player}！",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_011"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "距離終點",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就只差一步了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……嗚嘎！？",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_012"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊好痛……",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_013"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "跌、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "跌倒了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為平安地到達了目的地，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_014"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就不小心鬆懈下來了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一個大意，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_015"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就在下過雨後的泥濘地上被絆倒了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一生的失策。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚啊，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_016"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n一頭栽進水窪裡了……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n滿身泥巴。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然說",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_017"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一路走山路上來，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n本來就已經弄髒不少了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可、",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可不能帶著滿身泥巴的樣子，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n去見牧場的人。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "該怎麼辦……",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_019"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n想準備一套換洗衣物，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這裡",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有沒有店家之類的呢？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "如果有類似伴手禮店之類的店的話，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_020"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n感覺就至少會有在賣襯衫了……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_021"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}要拜託",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "牧場的人，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n幫我和他們借換洗衣物過來是嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哎呀那還真是，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "感激不盡～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哦～",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_022"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n剛好有和我差不多身高體型的孩子，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n在這座牧場裡是嗎。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你打算拜託那孩子，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_023"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n請她借我衣服啊。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "了解，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_024"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "幫了大忙。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "等你的期間，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我先用那邊的自來水把泥巴沖掉。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚……",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_025"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我一直",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在麻煩{player}照顧我。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "如果只有我一個人，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_026"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n絕對在某個地方就讓任務失敗了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_027"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還真是一無是處呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n如果只是一直受人幫助的話，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就沒資格當英雄了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊……\n{player}，\n已經回來了。",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_028"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}～？\n回來得還真早呢。",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_029"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你已經找到替換的衣服了是嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真厲害，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_030"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "果然{player}是個很能幹的人～♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……嗯嗯？",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_031"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那個，{player}？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n你手裡拿著的那個，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是換洗衣物嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "怎、",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_032"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "怎麼",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有種輕飄飄的感覺……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這套衣服總覺得好像在哪裡見過。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_033"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是鈴鈴噹！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n是「魔法少女鈴鈴噹」的服裝對吧……！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "到底為什麼，在牧場裡",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_034"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n會有這種角色扮演的衣服啊？",
