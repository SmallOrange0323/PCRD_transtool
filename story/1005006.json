    },
    {
        "type": "still",
        "still": "100500601"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……那個，{player}。",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_054"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我換好",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "衣服了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚。",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_055"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n果然害羞得像快要死了一樣。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n腦裡像要沸騰了……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "明明模仿虎虎的時候，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_056"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就一點事也沒有的說～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這是為什麼呢？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚呀？\n{player}，",
