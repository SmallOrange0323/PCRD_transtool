        "voice": "vo_adv_1005006_039"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n是、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是這樣嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可是我，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_040"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不適合",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這種女孩子喜歡的東西！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不是嘛你看，",
        "unit_id": 100511,
        "voice": "vo_adv_1005006_041"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "衣服上有很多蕾絲滾邊！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n然後裙子，",
