    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為什麼要用好像在期待著什麼的眼神，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n看向我這裡……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
