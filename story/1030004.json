[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍、將軍！",
        "unit_id": 103011,
        "voice": "vo_adv_1030004_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "今天要去統一哪裡呢？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "欸？你只是要去買晚餐的材料而已？",
        "unit_id": 103011,
        "voice": "vo_adv_1030004_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我不用跟著去也沒關係？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "怎麼可以這樣～您真是太殘忍了是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咦？將軍、",
        "unit_id": 103011,
        "voice": "vo_adv_1030004_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n那裡好像看得到什麼光是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哇，那個光是什麼呢……",
        "unit_id": 103011,
        "voice": "vo_adv_1030004_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "越來越靠近了……！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哇啊啊啊啊啊啊啊！！",
        "unit_id": 103011,
        "voice": "vo_adv_1030004_004"
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍！",
        "unit_id": 103031,
        "voice": "vo_adv_1030004_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這邊是也～！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "突然把將軍叫出來，真是抱歉。",
        "unit_id": 103031,
        "voice": "vo_adv_1030004_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那是因為……剛剛我在路上，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n撿到了非常不得了的東西是也～！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我要在這裡拿出來的是……",
        "unit_id": 103031,
        "voice": "vo_adv_1030004_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "登登登登登，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "藏寶圖是也～！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍請看這裡，這個的建築物上，",
        "unit_id": 103031,
        "voice": "vo_adv_1030004_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n有￥的標示還寫著祕密入口是也～！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "銀行是嗎？原來如此，銀行的話裡面的確有錢……",
        "unit_id": 103031,
        "voice": "vo_adv_1030004_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可是，為什麼需要祕密入侵路線呢？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "啊，那裡的傢伙手上拿的，",
        "unit_id": 1,
        "voice": "vo_adv_1030004_010"
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "\n不正是我們搶劫計畫的地圖嗎！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "強盜２",
        "words": "不會吧，地圖竟然在那種地方！",
        "unit_id": 1,
        "voice": "vo_adv_1030004_011"
    },
    {
        "type": "dialogue",
        "name": "強盜２",
        "words": "\n快把他們抓起來！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗚哇，你們突然冒出來做什麼是也！",
        "unit_id": 103031,
        "voice": "vo_adv_1030004_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "趕、趕快放開我！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n為什麼要把我們綁起來是也～！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "該不會……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你們是壽司師傅嗎！？",
        "unit_id": 103031,
        "voice": "vo_adv_1030004_013"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是在做手捲壽司的練習嗎？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "強盜２",
        "words": "才不是！",
        "unit_id": 1,
        "voice": "vo_adv_1030004_014"
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "嘿嘿……我們可是連大哭的小孩都會嚇傻的強盜團喔……",
        "unit_id": 1,
        "voice": "vo_adv_1030004_015"
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "\n今天本來要根據老大的指示去搶劫銀行。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "\n結果我們把地圖弄丟了，正在頭痛著呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "強盜２",
        "words": "既然那張地圖被你們看到了，可不能讓你們活下去了。",
        "unit_id": 1,
        "voice": "vo_adv_1030004_016"
    },
    {
        "type": "dialogue",
        "name": "強盜２",
        "words": "\n就直接把你們兩個帶到人煙稀少的地方，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "強盜２",
        "words": "\n處理地乾乾淨淨吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你、你們若做這種事，老天爺不會原諒你們的是也！",
        "unit_id": 103031,
        "voice": "vo_adv_1030004_017"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "負、負責人是誰啊！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "嘿嘿嘿，我也不知道喔。",
        "unit_id": 1,
        "voice": "vo_adv_1030004_018"
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "\n除了代號以外，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "\n可是沒有人知道我們老大的真實身份呢……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯～放、放開我們是也～～～！",
        "unit_id": 103031,
        "voice": "vo_adv_1030004_019"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n救命啊！將軍！將～～～軍！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "什麼……你說將、",
        "unit_id": 1,
        "voice": "vo_adv_1030004_020"
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "將軍！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "\n你怎麼會知道我們老大的代號！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "\n該不會，這傢伙是老大吧！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "強盜２",
        "words": "喂、喂、等等！搞不好只是碰巧而已。",
        "unit_id": 1,
        "voice": "vo_adv_1030004_021"
    },
    {
        "type": "dialogue",
        "name": "強盜２",
        "words": "\n這傢伙若真的是我們的團長將軍的話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "強盜２",
        "words": "\n應該說得出我們的暗號吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "暗號……？我們的暗號只有一個！",
        "unit_id": 103031,
        "voice": "vo_adv_1030004_022"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那就是「統一天下」是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "………………",
        "unit_id": 1,
        "voice": "vo_adv_1030004_023"
    },
    {
        "type": "dialogue",
        "name": "強盜２",
        "words": "………………",
        "unit_id": 1,
        "voice": "vo_adv_1030004_024"
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "嗚哇啊啊，這不是連暗號也講對了嗎！",
        "unit_id": 1,
        "voice": "vo_adv_1030004_025"
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "\n果然這個人就是將軍了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "強盜１",
        "words": "\n喂！快把繩子鬆開！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "強盜２",
        "words": "將軍，真是失禮了～！",
        "unit_id": 1,
        "voice": "vo_adv_1030004_026"
    },
    {
        "type": "dialogue",
        "name": "強盜２",
        "words": "\n請、請原諒我們！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真、真是的，還不趕快給我下跪！",
        "unit_id": 103031,
        "voice": "vo_adv_1030004_027"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你們現在就停止當強盜，馬上回家去是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "強盜１、２",
        "words": "是──！真是失禮了──！",
        "unit_id": 1,
        "voice": "vo_adv_1030004_028"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哈哈哈～今天我們也保護了城下町的和平是也～！",
        "unit_id": 103031,
        "voice": "vo_adv_1030004_029"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這個世上才不會讓壞人當道是也～",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……真是太好了呢，將軍 ♪",
        "unit_id": 103031
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？這是我給你的禮物！你做了個好「夢」嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1030004_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛剛的情景，是我依照你和妮諾的「記憶碎片」",
        "unit_id": 190011,
        "voice": "vo_adv_1030004_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n創造出來的「夢」唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n很懷念嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，還不清楚啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你收集到更多的「記憶碎片」，",
        "unit_id": 190011,
        "voice": "vo_adv_1030004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就會再讓你做「夢」的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你和許多女孩在一起的「夢」做得越多……",
        "unit_id": 190011,
        "voice": "vo_adv_1030004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就可以藉此還原世界的真實面貌。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要加油喔♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～ ♪",
        "unit_id": 190011,
        "voice": "vo_adv_1030004_034"
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯……是夢……嗎？",
        "unit_id": 103011,
        "voice": "vo_adv_1030004_035"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "欸……將軍也跟我做了一樣的夢了？",
        "unit_id": 103011,
        "voice": "vo_adv_1030004_036"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不愧是我的將軍！",
        "unit_id": 103011,
        "voice": "vo_adv_1030004_037"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一定因為是將軍，所以才會做了一樣的夢是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而且在夢裡也統一了天下呢。",
        "unit_id": 103011,
        "voice": "vo_adv_1030004_038"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真不愧是將軍！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我也會更加努力的，",
        "unit_id": 103011,
        "voice": "vo_adv_1030004_039"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要讓別人稱呼我為忠臣妮諾是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然很驚訝竟然會有這種不可思議的體驗，\n但一看到妮諾好像很高興的樣子，\n{player}也就想說算了。"
    }
]