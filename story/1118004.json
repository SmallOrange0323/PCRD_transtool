[
    {
        "type": "background",
        "background": "500560"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束參拜的貪吃佩可和{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n悠閒地走在參拜路上。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃了許多美味的東西，",
        "unit_id": 111811,
        "voice": "vo_adv_1118004_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還去求了籤，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n充分享受了新年，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是太滿足了☆",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得眼前明亮了許多，",
        "unit_id": 111811,
        "voice": "vo_adv_1118004_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就像是在觀賞元旦日出一樣……",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是真的在發光耶！？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這道光是……！",
        "unit_id": 111811
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「新年快樂！」",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「哎呀呀？",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真奇怪。",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還以為你會因為我在日本",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而大吃一驚呢……」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「這就叫做命運吧！",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好浪漫喔，真棒☆」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「我也覺得來這裡",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或許就能遇見你，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就趁著公務空檔跑過來了。」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「啊哈哈，",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說得也是。",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "新聞有報導呢。",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是如此。",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我被邀請來參加新年慶祝會，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以又到日本了。」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「話說回來，",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你就像平時見面一般和我自然相處，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣也很讓人開心呢。",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是新發現。」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「那麼那麼，",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "新年問候也說完了……",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你有沒有注意到",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我有什麼不同呢？」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「欸嘿嘿，",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝誇獎。",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我一直很想讓你看看這套打扮呢。」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「聽說日本的新年",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "家家戶戶都會在家裡度過，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大街上空無一人，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我本來還有點擔心會見不到你呢。」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「然而我們卻像現在這樣見到面了，",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這果然是命運呢☆」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「話說回來，",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你手上提著的塑膠袋裡裝了什麼？",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是新年料理嗎？",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "日本的新年",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會吃年菜對吧？」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「啊！",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這不是杯麵嗎！",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "它或許算是日本的傳統食物沒錯啦……」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「難不成，",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你已經吃過年菜了……？」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「太好了！",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然如此，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要不要一起吃年菜呢？",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是啦，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我手裡也沒有現成的料理。",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只是想說",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能去買年菜來",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和你一起吃。」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「咦？",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對耶，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "年菜要在年末就先買好。",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是我沒做好功課……」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「啊！",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有哪裡會賣年菜食材嗎？",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我聽說年菜中的",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "每一道配菜，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都蘊含著人們對幸福的期盼呢。」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「我們要不要試著做做看",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "兩個人能做的菜色呢？",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和你一起做有著美好寓意的年菜，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再一同享用，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺就能度過充滿幸福的一年呢。」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「謝謝！",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那我們就快點",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "去找食材吧！」",
        "unit_id": 111831
    },
    {
        "type": "background",
        "background": "510040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「哇──！",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這就是日本的超市啊！",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "賣的東西和我們完全不一樣，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真有趣！」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「那就先去挑配料吧！",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我看看……",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "魚板！",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有魚板耶！」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「紅白兩色的很喜氣呢。",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對日本人來說是很常見的食材，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但對我來說卻很新鮮。」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「還有什麼呢……",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我記得，",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是叫伊達卷？",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n聽說是那種",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很甜很甜的玉子燒……」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「哦──！",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是這個吧！",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n確實長得有點像點心呢！",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像點心的年菜……",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是最棒的食物☆」",
        "unit_id": 111831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「就保持這個步調再多買一點吧！」",
        "unit_id": 111831,
        "voice": "vo_adv_1118004_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「應該差不多都買齊了吧？",
