    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……我說，",
        "unit_id": 190912,
        "voice": "vo_adv_5150064_000"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "菲歐，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n妳",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "正在跟那個帆稀一起行動吧？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是啊，",
        "unit_id": 131711,
        "voice": "vo_adv_5150064_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了要抓住妳呢。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳要是想聊天的話，能不能讓我抓住啊？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不是啦，",
        "unit_id": 190912,
        "voice": "vo_adv_5150064_002"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就……",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳和那傢伙在一起",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "沒事嗎？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然她好像對嚮導小妖精抱有興趣，",
        "unit_id": 131711,
        "voice": "vo_adv_5150064_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但目前並沒有特別的危險喔？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我姑且有在戒備她。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不是啦！",
        "unit_id": 190912,
        "voice": "vo_adv_5150064_004"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我不是在說那個，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是那傢伙的打扮啦！打扮！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n那件泳裝是怎樣！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "真是莫大的凶器！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好危險啊！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……唔。",
        "unit_id": 131711,
        "voice": "vo_adv_5150064_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦～？",
        "unit_id": 131811,
        "voice": "vo_adv_5150064_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n什麼什麼～？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n有人叫我了～？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "噫，",
        "unit_id": 190912,
        "voice": "vo_adv_5150064_007"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "別靠過來！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "比例尺會失調！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我可能還是第一次因比例尺為由而被拒絕耶～",
        "unit_id": 131811,
        "voice": "vo_adv_5150064_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n為什麼",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我會被妳們這麼竭盡全力地恐懼呢？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "欸，愛梅斯～？",
        "unit_id": 131811,
        "voice": "vo_adv_5150064_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒什麼。",
        "unit_id": 131711,
        "voice": "vo_adv_5150064_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接下來我們稍微離遠點走吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總覺得……",
        "unit_id": 131811,
        "voice": "vo_adv_5150064_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好感度正在迅速暴跌當中……？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我說，",
        "unit_id": 131811,
        "voice": "vo_adv_5150064_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你知道為什麼嗎～？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦～！？",
        "unit_id": 131811,
        "voice": "vo_adv_5150064_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為什麼～！？",
        "unit_id": 131811
    }
]