[
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "太好了呢，",
        "unit_id": 4211,
        "voice": "vo_adv_9076156_000"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "兩位！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n不只是魔物，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "連操控牠的反逆獸也一起打倒囉！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "因為不只是蘭德索爾，",
        "unit_id": 114311,
        "voice": "vo_adv_9076156_001"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n連背面世界的和平都一起守護，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "才是愛與希望的魔法少女啊！",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "是啊！",
        "unit_id": 114211,
        "voice": "vo_adv_9076156_002"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "也順利救出摩拉，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "事情告一段落了呢！",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "作戰結束！",
        "unit_id": 105311,
        "voice": "vo_adv_9076156_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n因為可能還有魔物潛藏在附近。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n所以立刻撤離這裡──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你們打倒",
        "unit_id": 1,
        "voice": "vo_adv_9076156_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那隻魔物了呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n真的很謝謝你們，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "來自蘭德索爾的客人們。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……！？",
        "unit_id": 103711,
        "voice": "vo_adv_9076156_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是誰！？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是在偷窺嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "妳說得真難聽呢。",
        "unit_id": 195212,
        "voice": "vo_adv_9076156_006"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n我只是因為好像有人在戰鬥，",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "所以來確認一下而已。",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "……呵呵，",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "我看到了挺有趣的東西了呢。",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……！？",
        "unit_id": 105311,
        "voice": "vo_adv_9076156_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n難道說她……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "能看出作為魔法少女戰鬥的我們，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n跟現在的我們，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是同一個人嗎……！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎麼可能有那種事……",
        "unit_id": 103711,
        "voice": "vo_adv_9076156_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在變身為魔法少女的前後，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "會對周圍的人們",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "施展妨礙認知魔法，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我們的真面目絕對不會洩漏……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是那樣子吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "沒錯啊！",
        "unit_id": 4211,
        "voice": "vo_adv_9076156_009"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n……但是，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "從她的口氣聽來，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "她有可能用吉歐‧尼布爾黑爾獨有的方法，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n將妨礙認知魔法給無效化了……",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要、",
        "unit_id": 105311,
        "voice": "vo_adv_9076156_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要怎麼辦啊！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣下去，我們是魔法少女這件事，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n可能會被暴露在光天化日之下……！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那樣不行啊，",
        "unit_id": 103711,
        "voice": "vo_adv_9076156_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "絕對不行！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "魔法少女的真面目被人發現，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那是對魔法少女這種存在的",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "褻瀆！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就算要被發現，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也必須要是在故事的最後才可以！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "……我知道了。",
        "unit_id": 4211,
        "voice": "vo_adv_9076156_012"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n既然到這種地步，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "就只剩一種手段……",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "把她也變成魔法少女吧！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "摩拉！",
        "unit_id": 105311,
        "voice": "vo_adv_9076156_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你那種只顧眼前的行動，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "之後會往不好的方向──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "等等，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "聽我說啊──！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "你們從剛剛開始",
        "unit_id": 195212,
        "voice": "vo_adv_9076156_014"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "就在說什麼悄悄話啊？",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "雖然我不想對從蘭德索爾來的客人們動粗，",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n但是要是你們行為可疑的話──",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "收下吧！",
        "unit_id": 4211,
        "voice": "vo_adv_9076156_015"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n愛與希望，成為魔法少女的力量……！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "咦，",
        "unit_id": 195212,
        "voice": "vo_adv_9076156_016"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "等、",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "等等……！？",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "什麼，",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "住手……！？",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，",
        "unit_id": 1,
        "voice": "vo_adv_9076156_017"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "新的魔法少女",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在吉歐‧尼布爾黑爾誕生……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n──本來應該會如此的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但是黎薩卻沒變身成魔法少女。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n……嗯～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是為什麼呢……？",
        "unit_id": 1
    }
]