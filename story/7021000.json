[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "高聳入雲，看起來有如朝天際無限延伸而去的露娜之塔。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有著一群試圖挑戰其遙不可及塔頂的人們的身影出現在此。"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這裡有你記憶的線索嗎……",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然是第一次造訪，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但這座塔比想像中",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "高出非常多呢。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105111,
        "voice": "vo_adv_7021000_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有探索的價值不是很好嗎。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……哎呀？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳要去哪裡？",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "塔在這個方向哦。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為我發現了能做為",
        "unit_id": 105111,
        "voice": "vo_adv_7021000_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "補身藥原料的珍貴藥草。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我想就能進行沒嘗試過的實驗了……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你說呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真可惜。",
        "unit_id": 105111,
        "voice": "vo_adv_7021000_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話說回來",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這裡的植被還真是相當特殊呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "感覺塔裡",
        "unit_id": 105111,
        "voice": "vo_adv_7021000_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也長了很多有趣的藥草，真是令人期待。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "…………",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "深月小姐……",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "聽說要一起進行探索所以調查了一下她的身分，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不只是那個必須小心的公會",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【暮光流星群】的成員，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看起來也不能對她掉以輕心呢。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且還聽說她以",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "遊走在灰色地帶的醫療行為",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n收取高額的看診費。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然因為是{player}的熟人所以很想信任她就是了……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不，",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只憑這種理由是不成立的。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n身為【王宮騎士團】團員，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n得趁這個機會看清楚",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "她是不是危險人物才行。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳怎麼一臉心事重重的樣子呀？",
        "unit_id": 105111,
        "voice": "vo_adv_7021000_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒事的，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "{player}我會最優先",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n尋找他的記憶的線索。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是的，",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我沒有在擔那種心啦。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "比起這件事，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "藥草已經解決了嗎？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n需要的話我也能幫忙。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是這種草對吧──",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "千萬不能隨便亂採。",
        "unit_id": 105111,
        "voice": "vo_adv_7021000_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為汁液有毒呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "根據使用方法不同",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也可能成為劇毒。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "劇毒……",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀？",
        "unit_id": 105111,
        "voice": "vo_adv_7021000_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "難道",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳覺得我會亂用不成？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "放心吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這種毒能夠輕易地被檢測出來。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n換成我會做得更隱蔽呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "說笑的啦♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唉……",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "希望妳別在",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "身為【王宮騎士團】團員的我\n面前開這種玩笑。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為我看小智好像很緊張的樣子，",
        "unit_id": 105111,
        "voice": "vo_adv_7021000_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n只是想讓妳放輕鬆而已啦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我一點都不緊張。",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就是說啊，",
        "unit_id": 105111,
        "voice": "vo_adv_7021000_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "頂尖的【王宮騎士團】閣下",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n怎麼可能對這種塔感到緊張，不是嗎。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "當然了。",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "畢竟我們",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "每天都為了蘭德索爾市民",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n而進行著嚴格的訓練呢。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵。",
        "unit_id": 105111,
        "voice": "vo_adv_7021000_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣的話，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "身為一介弱小市民的我",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就要毫不客氣地",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n依靠小智囉。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來，",
        "unit_id": 105111,
        "voice": "vo_adv_7021000_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們出發吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n感覺會是一次愉快的探索呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看她那大大方方的言行舉止，",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "果然不是普通人。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼就持續保持戒心吧。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要是能掌握到什麼把柄，",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我得獨自逮捕她才行……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？",
        "unit_id": 103712,
        "voice": "vo_adv_7021000_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "對喔。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "說得也是，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "走吧。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n畢竟最重要的目的是",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "找出{player}記憶的線索。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n忘了這點可不行。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一邊對智所說的話感到困惑，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一邊朝高塔內邁步而去。"
    }
]