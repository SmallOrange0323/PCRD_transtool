[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "面對{player}毫不留情的連續打工，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n縱然疲憊不堪，艾姬多娜還是努力完成了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n於是她暫時回到了反映自身記憶的空間。"
    },
    {
        "type": "background",
        "background": "502340"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "真受不了，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_000"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "有夠辛苦的。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "想不到會要連續工作到那地步……",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但是，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_001"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也因此才能夠瞭解他。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n總之，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "算是達成我最初的目的了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我看看喔，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_002"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "愛梅斯……",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不在嗎？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "可能去找失蹤的我了呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "機會難得，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_003"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我就到處調查看看吧。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "愛梅斯似乎總藉由某種能力",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_004"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "觀察著這個世界。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n想必不是任誰都能輕易操控的力量。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "至少平時是如此。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但是在被我的空間覆蓋著的情況之下，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_005"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就有辦法了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "…………",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_006"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "哦～",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_007"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n原來這裡充滿著記憶呀。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這是……",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_008"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "他的記憶碎片嗎？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我來瞧瞧──",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_009"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──！",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_010"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "有設安全裝置。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_011"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看來沒辦法用單純的方法解決呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但是，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_012"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這東西如此激發我的興趣，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n卻要我碰都碰不得，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "未免也太殘忍了點吧。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "嗯……",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_013"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "既然如此，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "試試看另一個方法好了──",
        "unit_id": 132012
    },
    {
        "type": "background",
        "background": "500366"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夜晚的公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n入睡前的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "感到一股奇妙的感覺。"
    },
    {
        "type": "background",
        "background": "502340"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "哎呀，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_014"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "嚇到你了嗎？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你這反應，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_015"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不是感到困惑的樣子。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n……看起來比較像是",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "感覺和平時不太一樣而已吧。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這裡是我的夢之城，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_016"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也是舉辦魔女茶會的地方。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我也只是擅自使用愛梅斯的塔，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_017"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n所以很多地方都有所限制。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "因此",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_018"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也沒辦法好好泡杯茶請你。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也就是沒有茶的茶會囉。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "還是一樣沒什麼欲望呢，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_019"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你這個人。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "啊，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_020"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我們可沒有悠哉聊天的餘裕。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "得在愛梅斯回來前解決才行。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "之所以會邀請你來這裡，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_021"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是因為我厚臉皮地",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "想再次拜託你。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你願意聽聽看嗎？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……這次也毫不猶豫啊。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_022"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這種濫好人的態度，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_023"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是相當受環境眷顧所致嗎？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "還是……",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也罷，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "現在先別多想了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "沒什麼，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_024"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這次要拜託你的不是什麼難事。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我想",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "請你當這次茶會的見證人。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我接下來要邀請",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_025"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "「某人」參加的茶會的",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "見證人──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──歡迎來到",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_026"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "魔女的茶會。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "…………",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_027"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "謝謝接受我的邀請。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_028"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n歡迎你──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "霸瞳皇帝。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "別客氣，請坐。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_029"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我叫艾姬多娜，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是「強欲的──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "──閉上妳的嘴，回到原本的世界去，",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_030"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "異端分子。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "好冷淡喔。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_031"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n至少聽我自我介紹一下嘛。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "原本不該存在於此的東西，",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_032"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n又何須知道名字？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "──尤其是魔女",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_033"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這種東西。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……原來如此。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_034"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n和在他記憶碎片看到的一樣嚴苛。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但是，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "同時又能感受到見聞廣博的一面。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看來會是場有趣的茶會。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……妳說",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_035"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "記憶碎片？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "唉……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那邊一臉呆樣的你，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n看來被這魔女耍得很徹底啊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我早就知道你思慮欠周，",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_036"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "判斷總是過於天真，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "唯獨對誰都敞開心胸的那股傻勁",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "實在是令人難以忍受。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "說我耍弄他就太讓人遺憾了。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_037"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我只是",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "請他來當這茶會的見證人而已。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "而且，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_038"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "要交談應該是跟我才對吧？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n邀請你來的人是我喔？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我可不記得自己成為了妳的客人呢。",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_039"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但是你人在這裡，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_040"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "對吧？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n只要你想，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "其實也能選擇",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不赴約的選項，不是嗎？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "…………",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_041"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "好。",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_042"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我就允許妳的「謁見」。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這樣呀，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_043"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "說是謁見。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n意思是在這世界，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我才是「訪客」。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你想當成這麼一回事，我也無妨。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還真是傲慢無禮呢。",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_044"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n強欲的魔女，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳又了解這世界的什麼了？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我希望自己能夠了解所有的一切啊。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_045"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "因為我是──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "強欲嘛。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "可是眼前這個當下，我想了解的是你。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_046"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "尤其是──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "關於你的權能。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_047"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "「霸瞳天星」。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊～原來是這樣。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳的目的是──",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "──認識這個世界。",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_048"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你這麼快就進入狀況，這樣事情就好辦了。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_049"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你的權能，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_050"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也就是透視這世界的力量。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n以及運用了這個能力，被稱為預知未來的奇蹟。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "要我對那股力量置之不理，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我實在做不到。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "所以，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_051"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "霸瞳皇帝。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──要不要和我聯手？",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_052"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳說",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_053"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "聯手？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "縱然擁有預測未來的力量，你還是輸了。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_054"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n這全都要歸咎於",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n你準備好的可能性數量不足。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也就是你要預測的未來參數還有所不足。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_055"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就由我",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_056"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "來為你準備嶄新的未來吧。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "異端分子的我",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "將成為你計算之外的存在。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "為你預測的未來帶來無限分歧，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "並化為無數的可能性吧。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哼。",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_057"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n還真是充滿吸引力的邀約。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "對吧？",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_058"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n只要我們聯手，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你就能再次──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我拒絕。",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_059"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……我可以問是什麼理由嗎？",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_060"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "可惜啊，",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_061"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "強欲的魔女。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "神是獨一無二的存在。",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_062"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n孤高又絕對，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "因此",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒有任何人可以和祂",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並肩而立。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "為了保持絕對性而自己限縮了可能性。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_063"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "嗯……",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這樣的選擇也很有意思。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "機會難得，",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_064"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "趁現在把妳這可能性",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n剔除……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "或許也很有趣？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你是說要把我當異端分子排除掉的意思嗎？",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_065"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這下可傷腦筋了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "力量受限的我",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "根本無力招架呀。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "…………",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_066"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "…………",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_067"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "…………",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_068"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "…………",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_069"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "吵架……",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_070"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "呵呵，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "的確是。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "可是這下氣氛都沒了呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你不也這樣覺得嗎？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……唉。",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_071"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "實在是",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "令人惱火。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "既然阻止了我，",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_072"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你就得為這個魔女的行為負起責任。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……知道了嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……愚蠢的孩子。",
        "unit_id": 106911,
        "voice": "vo_adv_1320003_073"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你就盡量",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "被魔女耍著玩吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "又被你救了呢。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_074"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "說不想知道對戰結果",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是騙人的，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但要是失手戰敗，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就本利全無了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "比起這個，",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_075"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "為什麼你要幫我？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "如果照霸瞳皇帝說的，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我可是",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "耍著你玩的魔女耶。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "原來如此。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_076"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也就是說，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這是付給我的報酬嗎？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看來不習慣的勞動還是得做一下呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "而且……？",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_077"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n還有什麼理由嗎？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……這個",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_078"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "可是連我",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n都沒預期到可能性的答案。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "和你──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你真的很有意思。",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_079"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "或許是這世界裡",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "最未知的存在。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你的存在",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_080"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "引起了魔女相當大的興趣。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我接下來還要",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "再觀察你一段時間哦。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──因為感覺你可以",
        "unit_id": 132012,
        "voice": "vo_adv_1320003_081"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "充分滿足我的好奇心。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隨心所欲地觀察異世界的艾姬多娜。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她的視線盯著{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n愉悅的光彩流轉其間。"
    }
