[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_0000700_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果您擔心伙伴的體力可能不夠了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可以試試「全回復」或許效果會不錯哦。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105913,
        "voice": "vo_adv_0000700_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回復一天僅能使用一次，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n需要慎重考慮使用回復的時機。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還請三思而後行。",
        "unit_id": 105913
    }
]