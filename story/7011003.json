        "type": "dialogue",
        "name": "妮諾",
        "words": "大姐頭……",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_022"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大姐頭？　",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "妳有聽我講話嗎？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊，",
        "unit_id": 105611,
        "voice": "vo_adv_7011003_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊啊抱歉，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我剛剛稍微發呆了一下。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳剛剛在說什麼？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是！　",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_024"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "剛剛講到",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我要和將軍、大姐頭",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n前往東國",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一邊周遊各地",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一邊懲奸除惡，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
