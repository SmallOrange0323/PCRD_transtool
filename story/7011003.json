    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咦——！　",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_026"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "連人數也剛剛好的說！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊！　",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可是可是這麼一來，",
