    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人繼續探索露娜之塔，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是遲遲未見像是記憶線索的東西。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼，",
        "unit_id": 105611,
        "voice": "vo_adv_7011003_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然原本就覺得",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒那麼容易找到呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "剛好現在有點累了，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要不要在這裡稍微休息一下？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也是呢。",
        "unit_id": 105611,
        "voice": "vo_adv_7011003_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "話雖如此，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是我們沒帶食物……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "交給我吧！　",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "空著肚子",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "豈能戰鬥！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我準備了足夠的兵糧是也！　",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來吧，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大姐頭也請用。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "包在竹葉裡的飯糰，",
        "unit_id": 105611,
        "voice": "vo_adv_7011003_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還有竹筒水壺嗎。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "內餡包著梅子、",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "鮭魚、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "和鰹魚乾是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "吃完以後，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "還有甜饅頭可以享用！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n請各位",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "盡量多吃一點！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈，",
        "unit_id": 105611,
        "voice": "vo_adv_7011003_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真的很喜歡東國呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是的！　",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我從早上",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "到晚上，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒日沒夜",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n腦中想的都是有關東國的事情！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這麼說來，",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "以大姐頭的和服、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "武士刀、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "劍術看來……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "難不成",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大姐頭出身自東國嗎？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這個嘛，",
        "unit_id": 105611,
        "voice": "vo_adv_7011003_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "誰知道呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我四處流浪，早已經不記得了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "神秘的浪人劍士！　",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真是令人憧憬！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哈～",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_010"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我也希望有一天",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "能夠去東國看看。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "希望能親眼",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看看富士山是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "富士山是",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "東國首屈一指的聖山！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "時常被畫進",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "浮世繪裡！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖然我",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也只有在浮世繪裡看過。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "當統一天下之際，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "和將軍一起從山頂",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "俯瞰太平盛世",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就是我的夢想是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊、",
        "unit_id": 105611,
        "voice": "vo_adv_7011003_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊啊……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是嗎……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "東國的",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_014"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "獨特飲食文化也是不容錯過的一大特色是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "米飯料理",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "每一種都",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "非常美味是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "其中最美味的東國料理之王，",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_015"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "非壽司莫屬是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不僅蘊含職人的精湛廚藝，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那美麗的外觀也堪稱是可以吃的藝術品是也！",
        "unit_id": 103011
    },
