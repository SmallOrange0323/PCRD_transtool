        "type": "dialogue",
        "name": "妮諾",
        "words": "另外，",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_016"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "說起得以和壽司齊名的",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "東國代表性料理，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就不得不提蕎麥麵！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那是價格便宜的",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "平民美食！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "發出簌簌的聲音",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_017"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大口吸麵的感覺，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真的非常爽快是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不過之前",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大聲吸義大利麵，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "卻被莫妮卡罵了……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大姐頭喜歡吃",
        "unit_id": 103011,
        "voice": "vo_adv_7011003_018"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哪種東國料理呢？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊、",
        "unit_id": 105611,
        "voice": "vo_adv_7011003_019"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊啊……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊啊，",
        "unit_id": 105611,
        "voice": "vo_adv_7011003_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種感覺……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好熟悉啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n一提到自己感興趣的話題，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說話速度就會變得異常地快速。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然感興趣的東西不同，",
        "unit_id": 105611,
        "voice": "vo_adv_7011003_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是和我們公會的七七香一樣啊……",
        "unit_id": 105611
    },
