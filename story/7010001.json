    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，",
        "unit_id": 101511,
        "voice": "vo_adv_7010001_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "原來裡面是長這樣呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "慢慢來沒關係，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "注意腳邊小心前進吧～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}，四周有點黑，不要緊吧？　",
        "unit_id": 101811,
        "voice": "vo_adv_7010001_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒事吧？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為了讓你不要害怕，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我會待在你身邊的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101511,
        "voice": "vo_adv_7010001_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你和伊緒老師的感情還真好呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}",
        "unit_id": 101511,
        "voice": "vo_adv_7010001_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "竟然會直接叫伊緒，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n比起老師和學生，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "更像是朋友的關係呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我啊，",
        "unit_id": 101811,
        "voice": "vo_adv_7010001_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "作為師長還有很多要學習的地方，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "希望能和學生們一起成長，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n在像朋友一樣",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "良好的關係下學習各式各樣的事物。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "正因為這樣",
        "unit_id": 101811,
        "voice": "vo_adv_7010001_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "才會讓學生們",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n直接叫我伊緒的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "當然，",
        "unit_id": 101811,
        "voice": "vo_adv_7010001_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在該認真的時候，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n作為大人",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還是得做好模範才行。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，",
        "unit_id": 101511,
        "voice": "vo_adv_7010001_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真是了不起的想法呢～！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我也是，",
        "unit_id": 101511,
        "voice": "vo_adv_7010001_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "為了成為對孩子們而言的好老師，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n首先",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "得作為一名優秀的大人，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "總是這樣提醒自己呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "美里老師也這麼想，真令人開心。",
        "unit_id": 101811,
        "voice": "vo_adv_7010001_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天請多多指教了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還不知道會遇上什麼狀況，",
        "unit_id": 101511,
        "voice": "vo_adv_7010001_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "小心一點",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "千萬不要受傷了唷～！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，",
        "unit_id": 101511,
        "voice": "vo_adv_7010001_011"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "魔物呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不用擔心呦～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呀，",
        "unit_id": 101811,
        "voice": "vo_adv_7010001_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "魔物？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真有精神呢～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "被我們嚇到才跑出來的嗎？",
        "unit_id": 101811,
        "voice": "vo_adv_7010001_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嚇到你真的很抱歉。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "——咕嗚嗚嗚……♪",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好乖好乖，",
        "unit_id": 101511,
        "voice": "vo_adv_7010001_014"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "乖孩子",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "乖孩子……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n放心吧，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "已經沒事了。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "——咕嗚♪",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要保重喔～！",
        "unit_id": 101811,
        "voice": "vo_adv_7010001_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 101811,
        "voice": "vo_adv_7010001_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "本來因為太黑有點害怕的，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n跟可愛的魔物玩了一下心情舒服多了！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀～",
        "unit_id": 101511,
        "voice": "vo_adv_7010001_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n看來今天這趟會是愉快的散步呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "當然",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不要把最重要的目的",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也給忘記了喔？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還在說那種話嗎？　",
        "unit_id": 101811,
        "voice": "vo_adv_7010001_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好了快點開始走吧？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不要脫隊，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好好跟緊喔。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但是，",
        "unit_id": 101511,
        "voice": "vo_adv_7010001_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "累了的話一定要跟老師說喔？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n千萬不能逞強喔。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀～",
        "unit_id": 101511,
        "voice": "vo_adv_7010001_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "有氣無力的呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "已經累了嗎？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這可不行呢。",
        "unit_id": 101811,
        "voice": "vo_adv_7010001_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "才剛開始走呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}應該能做得更好才對吧？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很棒的答覆呢～！　",
        "unit_id": 101511,
        "voice": "vo_adv_7010001_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好棒好棒♪",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯！　",
        "unit_id": 101811,
        "voice": "vo_adv_7010001_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "照這股氣勢加油吧～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "走吧，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好好跟著老師們～！",
        "unit_id": 101811
    }
]