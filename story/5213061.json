[
    {
        "type": "background",
        "background": "502791"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「能令齒頰生香，",
        "unit_id": 129711,
        "voice": "vo_adv_5213061_000"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "尚為半吊子。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n得使裳福奔騰，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "方稱真行家。」",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵，",
        "unit_id": 126511,
        "voice": "vo_adv_5213061_001"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "擺在此處的",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "廚師銅像。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n底座上",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "寫了這個",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "料理格言呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_5213061_002"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n「得使裳福奔騰」一語，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "倒是頗為風雅──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "啊，不，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家失禮。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "言歸正傳吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "再次勞煩各位前來，",
        "unit_id": 133111,
        "voice": "vo_adv_5213061_003"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "實在非常抱歉……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "在「公主小餐館」正式上場之前，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n我想至少",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "稍微練習一下料理……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "向騎士先生詢問",
        "unit_id": 133111,
        "voice": "vo_adv_5213061_004"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "有沒有合適的場所之後，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n他便帶領我",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "來到了這裡。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "原來如此原來如此。",
        "unit_id": 129711,
        "voice": "vo_adv_5213061_005"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n此雖為祭事而設之臨時廚房，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然器具食材皆無所缺。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "用以作為「排練」之所，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "甚為相宜。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是的。",
        "unit_id": 133111,
        "voice": "vo_adv_5213061_006"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "而且騎士先生也提議，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "與其只是單純練習，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n不如",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "將做好的料理，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n請來賓們實際品嚐看看。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "的確。",
        "unit_id": 126511,
        "voice": "vo_adv_5213061_007"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "如果是抱著要讓人品評的心情來做，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n也會更加投入呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是個很棒的點子，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "只是……",
        "unit_id": 126511,
        "voice": "vo_adv_5213061_008"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我還有公務在身，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "而且練習用的廚房空間也有限。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "在正式上場之前，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "分開行動會許會比較適合。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "兩位意下如何呢？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "明白了。",
        "unit_id": 129711,
        "voice": "vo_adv_5213061_009"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n雖非有意吊人胃口，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然三公主齊聚之風采，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n留待正式登場時亮相，方為上策。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我明白了，",
        "unit_id": 133111,
        "voice": "vo_adv_5213061_010"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "兩位。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那麼我們就分開，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n各自迎接客人吧。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那可真是幫大忙了。",
        "unit_id": 126511,
        "voice": "vo_adv_5213061_011"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "要和騎士一起下廚……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真讓人期待呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_5213061_012"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n正式場合雖為爭鋒之勁敵，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "練習之際仍是彼此砥礪之同伴。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "既然如此，齊聲呼應，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "以振士氣，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "亦不失為一番樂趣。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵，",
        "unit_id": 126511,
        "voice": "vo_adv_5213061_013"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不錯呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "口號該怎麼喊……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "咦，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這句嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "涅妃‧涅羅皇女，",
        "unit_id": 133111,
        "voice": "vo_adv_5213061_014"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "喜歡這句話嗎……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我、",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我明白了。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那麼就由不才的我，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "來替大家起個頭吧。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "預備──！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「",
        "unit_id": 133111,
        "voice": "vo_adv_5213061_015"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "能令齒頰生香，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "尚為半吊子。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "\n得使裳福奔騰，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "方稱真行家。」",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，在「公主小餐館」開始之前的數日間，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n公主們各自向賓客獻上料理。"
    }
]