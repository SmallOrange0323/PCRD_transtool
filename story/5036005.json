    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "咦，",
        "unit_id": 112531,
        "voice": "vo_adv_5036005_035"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "是這樣啊……",
        "unit_id": 112531
    },
    {
        "type": "still",
        "still": "503600502"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊哈哈。",
        "unit_id": 112631,
        "voice": "vo_adv_5036005_036"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n或許製作人也睡死了，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "然後做了個奇怪的夢也說不定呢♪",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "不過……",
        "unit_id": 112431,
        "voice": "vo_adv_5036005_037"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "雖然很奇怪，",
        "unit_id": 112431
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "但是一個很不可思議的夢呢。",
        "unit_id": 112431
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嗯……",
        "unit_id": 112631,
        "voice": "vo_adv_5036005_038"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "對啊。",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "第一次站在觀眾前面的時候，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
