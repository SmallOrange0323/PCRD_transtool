[
    {
        "type": "background",
        "background": "500931"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【new generations】的演唱會，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n藉由通訊魔法轉播到了各個城鎮，在世界各地掀起了狂熱。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著……灰姑娘女孩們，就這樣消失在光芒之中。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……她們回去了呢。",
        "unit_id": 105812,
        "voice": "vo_adv_5036005_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……她們幾位都回去了呢。",
        "unit_id": 105913,
        "voice": "vo_adv_5036005_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "皮喵太大人也回去了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是呢──",
        "unit_id": 106012,
        "voice": "vo_adv_5036005_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過嘛，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能夠成功回去不是件好事嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的！",
        "unit_id": 105812,
        "voice": "vo_adv_5036005_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳再稍微感傷一點嘛～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個嘛，",
        "unit_id": 106012,
        "voice": "vo_adv_5036005_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼說……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算是我，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不是說沒有感到半點不捨嘛。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但比起那個……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次的委託呀，",
        "unit_id": 106012,
        "voice": "vo_adv_5036005_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "其實讓我們大賺了一筆對吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_5036005_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是這樣嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們想想！",
        "unit_id": 106012,
        "voice": "vo_adv_5036005_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n她們幾個留在這邊的行李之類的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還有演唱會的收入等等，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全都會變成我們的！　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是這樣吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_5036005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱歉辜負您的期待。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而您所說的那些金錢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n其實已經受到【new generations】的請託，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而有確定的用途了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "作為繆思小鎮重建的資金，",
        "unit_id": 105812,
        "voice": "vo_adv_5036005_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有下一次新人偶像甄選大會的獎金等等，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "已經全交出去了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啥啊啊啊～！？",
        "unit_id": 106012,
        "voice": "vo_adv_5036005_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明我這麼辛苦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且還遇上那種糗事遭受到那樣的對待……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "結果這不就",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又是白忙一場嗎～！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過收錄了【new generations】所演唱歌曲的音響盤，",
        "unit_id": 105812,
        "voice": "vo_adv_5036005_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n會成為我們十分珍貴的寶物呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……唔呣。",
        "unit_id": 105913,
        "voice": "vo_adv_5036005_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那筆獎金，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要您參加了下次的偶像甄選，\n並且獲得冠軍的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就能取回了便是。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈啊！？",
        "unit_id": 106012,
        "voice": "vo_adv_5036005_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_5036005_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果小凱留",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一個人當偶像",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會覺得不安……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也可以",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "跟妳一起組成團體唷☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「凱留凱留～☆」",
        "unit_id": 105913,
        "voice": "vo_adv_5036005_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……如此這般。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才不幹呢，",
        "unit_id": 106012,
        "voice": "vo_adv_5036005_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "笨蛋～！！",
        "unit_id": 106012
    },
