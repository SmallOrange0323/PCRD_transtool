        "voice": "vo_adv_5036005_026"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "好像是在",
        "unit_id": 112431,
        "voice": "vo_adv_5036005_027"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "有點奇幻的世界。",
        "unit_id": 112431
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n我們一起冒險，",
        "unit_id": 112431
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "一起吃飯，",
        "unit_id": 112431
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "好像還一起開了演唱會的夢……",
        "unit_id": 112431
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "咦咦！？",
        "unit_id": 112631,
        "voice": "vo_adv_5036005_028"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n島村村也是嗎～！？",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "妳們兩個也是……？",
        "unit_id": 112531,
        "voice": "vo_adv_5036005_029"
    },
    {
        "type": "dialogue",
        "name": "LIVE工作人員",
        "words": "【new generations】的各位～",
        "unit_id": 1,
        "voice": "vo_adv_5036005_030"
    },
    {
        "type": "dialogue",
        "name": "LIVE工作人員",
        "words": "\n差不多要請妳們",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "LIVE工作人員",
        "words": "開始準備囉！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "啊，",
        "unit_id": 112431,
        "voice": "vo_adv_5036005_031"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "對了！",
        "unit_id": 112431
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n我們等一下，",
        "unit_id": 112431
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "還有演唱會呀～！",
        "unit_id": 112431
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……真是的。",
        "unit_id": 112531,
        "voice": "vo_adv_5036005_032"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n竟然會在這種時間點睡著了……",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "早知道不該",
        "unit_id": 112631,
        "voice": "vo_adv_5036005_033"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "為了轉換心情",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "而試玩遊戲樣品了～！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "LIVE工作人員",
        "words": "啊。",
        "unit_id": 1,
        "voice": "vo_adv_5036005_034"
    },
    {
        "type": "dialogue",
        "name": "LIVE工作人員",
        "words": "\n妳們的製作人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "LIVE工作人員",
        "words": "\n剛才好像也在隔壁的房間裡玩VR遊戲唷。",
