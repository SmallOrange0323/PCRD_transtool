    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接近新年前出現了大量的願望。\n那些東西變成集合體附在鏡餅上面，\n變成了巨大的魔物。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "竟然會發生這種事……",
        "unit_id": 108711,
        "voice": "vo_adv_5010006_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總之得讓客人們遠離這裡！",
        "unit_id": 108911,
        "voice": "vo_adv_5010006_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n從那東西身上感受到不祥的氣息。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦……",
        "unit_id": 108811,
        "voice": "vo_adv_5010006_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "它好像在說什麼？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "鏡餅",
        "words": "禿……",
        "unit_id": 10811,
        "voice": "vo_adv_5010006_003"
    },
    {
        "type": "dialogue",
        "name": "鏡餅",
        "words": "禿頭治不好！",
        "unit_id": 10811
    },
    {
        "type": "dialogue",
        "name": "鏡餅",
        "words": "\n養的狗狗沒有回家！",
        "unit_id": 10811
    },
    {
        "type": "dialogue",
        "name": "鏡餅",
        "words": "\n媽媽——！　",
        "unit_id": 10811
    },
    {
        "type": "dialogue",
        "name": "鏡餅",
        "words": "在哪裡呢——！",
        "unit_id": 10811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "各種思念混雜在一起……",
        "unit_id": 108911,
        "voice": "vo_adv_5010006_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好像會變成難纏的對手。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "鏡餅",
        "words": "――咕喔喔喔喔喔！！",
        "unit_id": 10812
