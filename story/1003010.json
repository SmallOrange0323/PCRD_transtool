    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——為了陪同怜前去視察，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}前往了集合地點。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而怜已經到達該處。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喂，",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在這邊！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗨。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "平安到達比什麼都重要。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你這樣子看來做好了萬全準備。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼說，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺你比平常還更可靠了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好，",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就先前往馬車停駐的地方吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "——怎、",
        "unit_id": 511,
        "voice": "vo_adv_1003010_003"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "怎麼會……！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n這跟說好的不一樣！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……怎麼了？　",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很在意嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們去看看吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "因為我聽說修理屋頂不用錢，所以才拜託你的。",
        "unit_id": 511,
        "voice": "vo_adv_1003010_005"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "就算你突然跟我提出報酬……！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "原來如此〜！　",
        "unit_id": 911,
        "voice": "vo_adv_1003010_006"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "若是這樣的話",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "也沒辦法了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "大家！　",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "把那屋頂恢復為原本破爛的狀態吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒們",
        "words": "好～的！！",
        "unit_id": 1,
        "voice": "vo_adv_1003010_007"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "啊……！",
        "unit_id": 511,
        "voice": "vo_adv_1003010_008"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n怎麼這樣……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "好不容易可以躲開風雨……！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該不會",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那些傢伙……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就是最近出現的",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "佯裝為志工的詐騙集團。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這樣是行不通的。",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n雖然一聽就知道他們有問題",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "卻沒有契約能證明。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "恐怕",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他們只有做口頭契約。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在這狀況",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "分不出到底是委託人不願意付修理費",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還是他遭到詐欺……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不知道到底誰是壞人。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n若無犯罪證據，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "便無法做適當的處理。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且騎士團也下令各公會",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n遇到這種事時不要隨便出手。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為只要一個沒處理好，就可能出現冤罪。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……現在王宮的勢力漸弱，",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n整個蘭德索爾上下",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "時常發生這種事。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以得趕快確認狀況，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "恢復應有的法律和秩序……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "因為不太記得屋頂原本的狀況啦……",
        "unit_id": 811,
        "voice": "vo_adv_1003010_014"
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "就隨便弄幾個洞出來吧！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "住、",
        "unit_id": 511,
        "voice": "vo_adv_1003010_015"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "住手啊～！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……抱歉。",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來我們得延遲出發了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那種做法",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼看都有問題。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這就是所謂的看透一切啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "上囉！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "啊啊……",
        "unit_id": 511,
        "voice": "vo_adv_1003010_019"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "這樣下去房子會……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "嘿嘿嘿，",
        "unit_id": 911,
        "voice": "vo_adv_1003010_020"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "如果想付錢可要趁現在喔？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……到此為止。",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_021"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "蛤？　",
        "unit_id": 911,
        "voice": "vo_adv_1003010_022"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "妳這傢伙是哪根蔥？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是個路過的人罷了。",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "別說這個了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在就給我離開那房子。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "喂喂喂……",
        "unit_id": 911,
        "voice": "vo_adv_1003010_024"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "我有修補可是事實喔？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "\n我也沒有強制他付錢，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "妳對我們有什麼意見嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……能夠進行修補作業的",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n照理來說只有王宮所認可的公會才行。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你們有受到認可的證據來證明嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "認、",
        "unit_id": 911,
        "voice": "vo_adv_1003010_026"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "認可……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "那種事我才沒聽過……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "沒、",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "沒事，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "啥都沒！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……你來",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "強化我吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "……真沒辦法呢。",
        "unit_id": 911,
        "voice": "vo_adv_1003010_028"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "\n我就給妳看吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "認可的事是我亂說的……",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來有問題的是這方！　",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "這個……",
        "unit_id": 911,
        "voice": "vo_adv_1003010_030"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "就是證據！！",
        "unit_id": 911
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "——哼！　",
        "unit_id": 100312,
        "voice": "vo_adv_1003010_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "太天真了！！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "莽夫１",
        "words": "啊！？",
        "unit_id": 911,
        "voice": "vo_adv_1003010_032"
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "老大！？",
        "unit_id": 811,
        "voice": "vo_adv_1003010_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是學了那狡猾把戲……",
        "unit_id": 100312,
        "voice": "vo_adv_1003010_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "誰是壞人",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這下可清楚了。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "像你們這種貨色",
        "unit_id": 100312,
        "voice": "vo_adv_1003010_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我現在就可以就地處理！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n喝啊——！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "莽夫２",
        "words": "噫————！！！！",
        "unit_id": 811,
        "voice": "vo_adv_1003010_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我已經把那些傢伙",
        "unit_id": 100311,
        "voice": "vo_adv_1003010_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "綁在那邊的板子上囉。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "接下來的就交給騎士團吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "真的",
        "unit_id": 511,
        "voice": "vo_adv_1003010_038"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "非常謝謝妳。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n該怎麼表達我的感謝……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能把傷害降到最低真是太好了。",
