[
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好了，",
        "unit_id": 128511,
        "voice": "vo_adv_5134601_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然今年也是直到除夕都充滿狀況的一年……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但也像這樣",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "平安迎來元旦了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這都是多虧了大家的努力呢！",
        "unit_id": 128411,
        "voice": "vo_adv_5134601_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而且也開心地去新年參拜了，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "非常滿意～☆",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也是，",
        "unit_id": 128311,
        "voice": "vo_adv_5134601_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有逛到想去逛的攤販，覺得心滿意足。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那間戳糖片的店絕對有動手腳！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n總有一天要去給他好看……！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可以不要大年初一的",
        "unit_id": 128511,
        "voice": "vo_adv_5134601_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就在偵探面前發出犯罪預告嗎……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "今天已經玩很久了，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就乖乖回家好好休息吧。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，",
        "unit_id": 128411,
        "voice": "vo_adv_5134601_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "聽妳這樣說讓我想起來了！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好像是說今天做的夢",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就是初夢對不對？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是啊，",
        "unit_id": 128511,
        "voice": "vo_adv_5134601_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒錯。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "從元旦到隔天這段時間裡所做的夢就是初夢，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳的理解是正確的。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我是在跟森神大人聊天的時候聽說的，",
        "unit_id": 128411,
        "voice": "vo_adv_5134601_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "在睡覺之前要先許下願望，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果初夢有夢到那個願望的話，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "運氣就會變好，願望也會容易實現！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼！？",
        "unit_id": 128311,
        "voice": "vo_adv_5134601_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳還想要去做夢嗎！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我已經受夠預知夢了啦……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過嘛，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對我有利的夢我還是很歡迎的喔。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是的，",
        "unit_id": 128511,
        "voice": "vo_adv_5134601_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳真的有在反省嗎？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "初音說的初夢只是在討個吉利而已，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要是有夢到就是好兆頭……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要這樣想就夠了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯，",
        "unit_id": 128411,
        "voice": "vo_adv_5134601_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "森神大人的說明也差不多是那樣！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難得的新年，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "妳們不會想要從第一天，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n就以幸運的好心情來度過一整年嗎？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是說這是不科學的，那麼話題就到此結束了。",
        "unit_id": 105111,
        "voice": "vo_adv_5134601_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過我認為這聽起來確實很有趣呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而且要是能在夢中實現對那位大人的願望……",
        "unit_id": 102711,
        "voice": "vo_adv_5134601_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n或許就能感受到命運呢……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻♪",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯，",
        "unit_id": 103813,
        "voice": "vo_adv_5134601_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也覺得很有趣。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也來",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "祈禱今年一年的目標能夠實現好了……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "既然這樣，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也去跟鈴說這件事吧。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "大家",
        "unit_id": 128411,
        "voice": "vo_adv_5134601_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "都有興趣嗎？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果夢到好夢，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n明天要跟小初音說喔～☆",
        "unit_id": 128411
    }
]