[
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "嘻嘻……",
        "unit_id": 11111,
        "voice": "vo_adv_5012321_000"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "打倒那些傢伙不是很厲害嘛。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n那麼，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "接下來要給你的絕望是――",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……",
        "unit_id": 105511,
        "voice": "vo_adv_5012321_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "停下來吧。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "……妳說什麼？",
        "unit_id": 11111,
        "voice": "vo_adv_5012321_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "妳說看得到我的懦弱……",
        "unit_id": 105511,
        "voice": "vo_adv_5012321_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "和心裡的黑暗對吧。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "看得到妳的心……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n因為，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我和你很像……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "……閉嘴。",
        "unit_id": 11111,
        "voice": "vo_adv_5012321_004"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "妳一定",
        "unit_id": 105511,
        "voice": "vo_adv_5012321_005"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不希望發生這些事……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "其實妳渴望的不是絕望，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "而是希望――",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "……閉嘴！！！！",
        "unit_id": 11111,
        "voice": "vo_adv_5012321_006"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "妳說妳看的到我心中的黑暗對吧！？",
        "unit_id": 11111,
        "voice": "vo_adv_5012321_007"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n那就盡量看吧！！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這、",
        "unit_id": 105511,
        "voice": "vo_adv_5012321_008"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這股力量……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "這是用",
        "unit_id": 11111,
        "voice": "vo_adv_5012321_009"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "我所有渴望的絕望，帶來的永恆暗黑之力量！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n如果你能承受這股黑暗的話，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "就承受吧！！",
        "unit_id": 11111
    }
]