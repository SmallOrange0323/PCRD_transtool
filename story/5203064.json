[
    {
        "type": "still",
        "still": "520306201"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "波波爺爺的",
        "unit_id": 9212,
        "voice": "vo_adv_5203064_000"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "「克蘿茜大解密」",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "要開始啦～！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n把老夫解析的",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "古代兵器",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "巨型軀體的詳細資訊，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n用大家都能懂的方式",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "慢～慢仔細地講解給大家聽喔。",
        "unit_id": 9212
    },
    {
        "type": "still",
        "still": "520306401"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這次要講解的是，",
        "unit_id": 9212,
        "voice": "vo_adv_5203064_001"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "巨型克蘿茜的駕駛艙。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n駕駛員碧",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "平時都是在這裡進行操控。",
        "unit_id": 9212
    },
    {
        "type": "still",
        "still": "520306402"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這個狹窄的恰到好處的尺寸很令人安心……",
        "unit_id": 134612,
        "voice": "vo_adv_5203064_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然一開始被關進去的時候，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還以為再也沒辦法出來了。",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "妳能喜歡我很高興♪",
        "unit_id": 134511,
        "voice": "vo_adv_5203064_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "碧",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "喜歡",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "狹窄又陰暗的地方呢！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個，",
        "unit_id": 134612,
        "voice": "vo_adv_5203064_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "克蘿茜小姐？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n隨便把真相攤開在光底下偶爾會是暴力行為喔？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n陰沉又邊緣的人，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "馬上就會被燃燒殆盡變成灰喔？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "咦咦？",
        "unit_id": 134511,
        "voice": "vo_adv_5203064_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我沒有那個意思。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n只是因為我",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "沒辦法進去狹窄的地方，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n想說比較難一起去碧喜歡的地方～",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "而已。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯……",
        "unit_id": 9212,
        "voice": "vo_adv_5203064_006"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "不過，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "為了維持駕駛員的心理健康，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n還是想要盡量排除沒必要的壓力呢。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n要把座位做成簡易床鋪嗎？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "毛毯也……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "喔喔！？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊啊啊",
        "unit_id": 134612,
        "voice": "vo_adv_5203064_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "毛毯帶來的黑暗讓我安心很抱歉克蘿茜小姐",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n對打算建立友好關係的對方好意",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n起疑心的我真的很差勁我會反省道歉──",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哇哇！",
        "unit_id": 134511,
        "voice": "vo_adv_5203064_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n碧蓋上毛毯進入休眠模式了，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n碧，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "請妳出來！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "碧～！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "……果然還是盡量改造成沒有壓力的駕駛艙吧。",
        "unit_id": 9212,
        "voice": "vo_adv_5203064_009"
    },
    {
        "type": "still",
        "still": "end"
    }
]